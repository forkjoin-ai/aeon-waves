#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")
basedir_win="$basedir"
exe=""
msys=""

case `uname -a` in
  *CYGWIN*|*MINGW*|*MSYS*)
    if command -v cygpath > /dev/null 2>&1; then
      basedir_win=`cygpath -w "$basedir"`
    fi
    exe=".exe"
    msys="true"
  ;;
  *WSL2*)
    if command -v wslpath > /dev/null 2>&1; then
      basedir_win="$(wslpath -w "$basedir" 2> /dev/null)"
      if [ $? -ne 0 ] || [ -z "$basedir_win" ]; then
        basedir_win="$basedir"
      else
        exe=".exe"
      fi
    fi
  ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/Users/buley/Documents/Code/monorepo/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/Users/buley/Documents/Code/monorepo/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -n "$exe" ] && [ -x "$basedir//bin/sh.exe" ]; then
  exec "$basedir//bin/sh.exe"  "$basedir_win/../@a0n/gnosis/bin/monster" "$@"
elif [ -x "$basedir//bin/sh" ]; then
  exec "$basedir//bin/sh"  "$basedir/../@a0n/gnosis/bin/monster" "$@"
elif command -v /bin/sh >/dev/null 2>&1; then
  exec /bin/sh  "$basedir/../@a0n/gnosis/bin/monster" "$@"
elif [ -n "$exe" ] && command -v /bin/sh.exe >/dev/null 2>&1; then
  exec /bin/sh.exe  "$basedir_win/../@a0n/gnosis/bin/monster" "$@"
else
  exec /bin/sh  "$basedir/../@a0n/gnosis/bin/monster" "$@"
fi
