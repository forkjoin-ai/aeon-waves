#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/proc/cygdrive/c/Users/buley/Documents/Code/monorepo/open-source/gnosis/bin/node_modules:/proc/cygdrive/c/Users/buley/Documents/Code/monorepo/open-source/gnosis/node_modules:/proc/cygdrive/c/Users/buley/Documents/Code/monorepo/open-source/node_modules:/proc/cygdrive/c/Users/buley/Documents/Code/monorepo/node_modules:/proc/cygdrive/c/Users/buley/Documents/Code/node_modules:/proc/cygdrive/c/Users/buley/Documents/node_modules:/proc/cygdrive/c/Users/buley/node_modules:/proc/cygdrive/c/Users/node_modules:/proc/cygdrive/c/node_modules:/proc/cygdrive/c/Users/buley/Documents/Code/monorepo/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/proc/cygdrive/c/Users/buley/Documents/Code/monorepo/open-source/gnosis/bin/node_modules:/proc/cygdrive/c/Users/buley/Documents/Code/monorepo/open-source/gnosis/node_modules:/proc/cygdrive/c/Users/buley/Documents/Code/monorepo/open-source/node_modules:/proc/cygdrive/c/Users/buley/Documents/Code/monorepo/node_modules:/proc/cygdrive/c/Users/buley/Documents/Code/node_modules:/proc/cygdrive/c/Users/buley/Documents/node_modules:/proc/cygdrive/c/Users/buley/node_modules:/proc/cygdrive/c/Users/node_modules:/proc/cygdrive/c/node_modules:/proc/cygdrive/c/Users/buley/Documents/Code/monorepo/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../@a0n/gnosis/bin/gnosis.js" "$@"
else
  exec node  "$basedir/../@a0n/gnosis/bin/gnosis.js" "$@"
fi
