// void-walking.test.gg -- Tests for the self-referential topology
//
// These tests verify that void walking, described as a topology
// and walked by the void walker, produces the same results as
// calling the primitives directly. The topology formalizes the algorithm.

topology void_walking_test {
  import void_walking from "./void-walking.gg"

  // ──────────────────────────────────────────────────────────
  // Structural invariants
  // ──────────────────────────────────────────────────────────

  test "c0-c3 loop is complete" {
    assert node_exists(void_walking, boundary)
    assert node_exists(void_walking, complement)
    assert node_exists(void_walking, update)
    assert node_exists(void_walking, measure)
    assert node_exists(void_walking, observation)
    assert node_exists(void_walking, gait_select)
    assert node_exists(void_walking, active_gait)
    assert node_exists(void_walking, adapt)
    assert node_exists(void_walking, adapted_state)
  }

  test "topology is cyclic (self-referential)" {
    // adapted_state flows back to boundary
    assert edge_exists(void_walking, adapted_state, boundary)
  }

  test "measurement is parallel (fork/fold)" {
    assert edge_type(void_walking, measure, entropy) == "FORK"
    assert edge_type(void_walking, measure, kurtosis) == "FORK"
    assert edge_type(void_walking, measure, gini) == "FORK"
    assert edge_type(void_walking, measure, inv_bule) == "FORK"
    assert edge_type(void_walking, entropy, observation) == "FOLD"
  }

  test "gait selection is superposition/race" {
    assert edge_type(void_walking, gait_select, stand) == "SUPERPOSE"
    assert edge_type(void_walking, stand, active_gait) == "RACE"
  }

  test "choice is superposition/race" {
    assert edge_type(void_walking, complement, choice_a) == "SUPERPOSE"
    assert edge_type(void_walking, choice_a, update) == "RACE"
  }

  // ──────────────────────────────────────────────────────────
  // Escape conditions exist
  // ──────────────────────────────────────────────────────────

  test "convergence escape exists (TUNNEL)" {
    assert edge_type(void_walking, observation, converged) == "TUNNEL"
  }

  test "divergence escape exists (VENT)" {
    assert edge_type(void_walking, observation, diverged) == "VENT"
  }

  // ──────────────────────────────────────────────────────────
  // Self-measurement
  // ──────────────────────────────────────────────────────────

  test "topology measures itself at three points" {
    assert edge_type(void_walking, complement, complement) == "MEASURE"
    assert edge_type(void_walking, observation, observation) == "MEASURE"
    assert edge_type(void_walking, active_gait, active_gait) == "MEASURE"
  }

  // ──────────────────────────────────────────────────────────
  // Adaptation is fork/fold (parallel parameter update)
  // ──────────────────────────────────────────────────────────

  test "adaptation is parallel" {
    assert edge_type(void_walking, adapt, eta_adjust) == "FORK"
    assert edge_type(void_walking, eta_adjust, adapted_state) == "FOLD"
  }

(test_suite: TestSuite { name: 'void-walking' })
(verify_void_walking: Verify { module: './void-walking.test.gg', beta1_max: '8' })
(test_suite)-[:PROCESS]->(verify_void_walking)
(verify_void_walking)-[:PROCESS { expect: 'safe' }]->(result: Result)
(result)-[:PROCESS { strategy: 'all-pass' }]->(verdict: Verdict)
}
