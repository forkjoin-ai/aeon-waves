{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gnosis.forkjoin.ai/schemas/study-graph-snapshot.schema.json",
  "title": "Qualitative / mixed-methods study graph snapshot",
  "description": "Structural JSON for versioned study semantic graphs. Not a runtime guarantee of interpretive truth or ethics approval.",
  "type": "object",
  "required": [
    "schemaVersion",
    "study_id",
    "title",
    "exported_at",
    "study_mode",
    "nodes",
    "edges"
  ],
  "properties": {
    "schemaVersion": { "type": "string", "const": "1.0.0" },
    "study_id": { "type": "string", "minLength": 2 },
    "title": { "type": "string", "minLength": 1 },
    "exported_at": { "type": "string", "format": "date-time" },
    "study_mode": {
      "type": "string",
      "enum": ["confirmatory", "exploratory", "mixed"]
    },
    "preregistration_ref": { "type": "string" },
    "plain_language_summary": { "type": "string" },
    "nodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "kind"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "kind": {
            "type": "string",
            "enum": ["code", "hypothesis", "excerpt", "instrument", "memo", "theme"]
          },
          "label": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["u", "v"],
        "properties": {
          "u": { "type": "string" },
          "v": { "type": "string" },
          "kind": { "type": "string" },
          "provenance": {
            "type": "string",
            "enum": ["human", "agent", "import"]
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
