{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gnosis.forkjoin.ai/schemas/ecology-graph-snapshot.schema.json",
  "title": "Ecology pilot versioned graph snapshot",
  "description": "Structural JSON for bounded ecological pilot exports (ECOLOGY_PILOT_SPEC). Not a runtime guarantee of ecological truth.",
  "type": "object",
  "required": [
    "schemaVersion",
    "domain",
    "graph_id",
    "exported_at",
    "nodes",
    "edges"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "1.0.0"
    },
    "domain": {
      "type": "string",
      "minLength": 1
    },
    "graph_id": {
      "type": "string",
      "minLength": 4
    },
    "exported_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO-8601 instant for export boundary."
    },
    "nodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "taxon": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["u", "v", "provenance"],
        "properties": {
          "u": { "type": "string" },
          "v": { "type": "string" },
          "weight": { "type": "number" },
          "weight_ci": {
            "type": "array",
            "minItems": 2,
            "maxItems": 2,
            "items": { "type": "number" }
          },
          "provenance": {
            "type": "string",
            "enum": ["sensor", "survey", "model"]
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
