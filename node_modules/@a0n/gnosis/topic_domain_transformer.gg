// topic_domain_transformer.gg
// Canonical topic-domain "language hello-world" for Gnosis neural execution.
// This topology models text -> topic attention -> topic distribution.

(topic_tokens: Tensor { role: 'input', activation: 'identity', bias: '0.0' })
(topic_embedding: Projection { role: 'embedding', activation: 'identity', bias: '0.0' })
(qkv_projection: Projection { role: 'qkv_projection', activation: 'identity', bias: '0.0' })

(head_a: AttentionHead { bias: '0.02' })
(head_b: AttentionHead { bias: '0.02' })
(head_c: AttentionHead { bias: '0.02' })
(head_d: AttentionHead { bias: '0.02' })

(attention_mix: Tensor { role: 'multi_head_mix', activation: 'tanh', bias: '0.03' })
(topic_state: Tensor { role: 'residual_state', activation: 'tanh', bias: '0.01' })
(topic_logits: Tensor { role: 'logits', activation: 'identity', bias: '0.0' })
(topic_distribution: Tensor { role: 'distribution', activation: 'tanh', bias: '0.0' })
(topic_trace: Trace)
(topic_prediction: Sink)

(topic_tokens)-[:PROCESS]->(topic_embedding)
(topic_embedding)-[:FORK]->(te_to_qkv | te_to_residual)

(te_to_qkv)-[:PROCESS]->(qkv_projection)
(qkv_projection)-[:FORK]->(head_a | head_b | head_c | head_d)

(head_a | head_b | head_c | head_d)-[:FOLD { strategy: 'concat', weight: '0.25', request_compression: 'middle-out/request/topic-domain-transformer', reuse_scope: 'corridor', corridor_mode: 'readonly' }]->(attention_mix)
(attention_mix | te_to_residual)-[:SLIVER { mode: 'constructive', weight: '0.5' }]->(topic_state)
(topic_state)-[:PROCESS]->(topic_logits)
(topic_logits)-[:PROCESS]->(topic_distribution)
(topic_distribution)-[:PROCESS]->(topic_prediction | topic_trace)
(topic_trace)-[:PROCESS]->(topic_prediction)
(topic_prediction)-[:TUNNEL { condition: 'bounded-reject' }]->(topic_domain_transformer_gg_trace:Trace)
(topic_prediction)-[:MEASURE { reason: 'topology-audit' }]->(topic_domain_transformer_gg_trace:Trace)
