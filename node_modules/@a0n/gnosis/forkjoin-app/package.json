{
  "name": "@affectively/gnosis-forkjoin-app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"wrangler dev --port 8798\" \"vite --config vite.config.ts --port 5198\"",
    "dev:worker": "wrangler dev --port 8798",
    "dev:client": "vite --config vite.config.ts --port 5198",
    "prebuild:client": "npx tsx scripts/generate-ecosystem-manifest.ts",
    "build:client": "vite build --config vite.config.ts",
    "build": "bun run build:client && wrangler deploy --dry-run",
    "deploy": "bun run deploy:prod",
    "deploy:dev": "bun run build:client && wrangler deploy --env dev && bun run register:aeonpid:dev",
    "deploy:staging": "bun run build:client && wrangler deploy --env staging && bun run register:aeonpid:staging",
    "deploy:stage": "bun run deploy:staging",
    "deploy:prod": "bun run build:client && wrangler deploy --env production && bun run register:aeonpid:production && bun run smoke:deployed",
    "deploy:production": "bun run deploy:prod",
    "test": "bun test --timeout 30000 --run --pass-with-no-tests",
    "typecheck": "tsc --noEmit",
    "lint": "bunx eslint \"src/**/*.ts\" \"client/**/*.{ts,tsx}\" \"scripts/**/*.ts\" \"test/**/*.ts\"",
    "smoke:deployed": "bun run ./scripts/smoke-deployed.ts",
    "register:aeonpid": "bun ../../../scripts/register-aeonpid.ts forkjoin-app production",
    "register:aeonpid:dev": "bun ../../../scripts/register-aeonpid.ts forkjoin-app dev",
    "register:aeonpid:staging": "bun ../../../scripts/register-aeonpid.ts forkjoin-app staging",
    "register:aeonpid:production": "bun ../../../scripts/register-aeonpid.ts forkjoin-app production",
    "forge:deploy": "bun ../../../apps/aeon-forge/src/cli/cli.tsx deploy . --oneshot"
  },
  "dependencies": {
    "@a0n/aeon-container": "workspace:*",
    "@a0n/edgework-sdk": "workspace:*",
    "@a0n/gnosis": "workspace:*",
    "@a0n/shared-ui": "workspace:*",
    "@a0n/shared-utils": "workspace:*",
    "@a0n/aeon": "workspace:*",
    "@a0n/aeon-3d": "workspace:*",
    "@a0n/aeon-dev-framework": "workspace:*",
    "@a0n/aeon-flags": "workspace:*",
    "@a0n/aeon-flux": "workspace:*",
    "@a0n/aeon-preferences": "workspace:*",
    "@a0n/aeon-flux-react": "workspace:*",
    "@a0n/aeon-flux-runtime": "workspace:*",
    "@a0n/auth": "workspace:*",
    "@a0n/aeon-icons": "workspace:*",
    "react": "workspace:*",
    "react-dom": "workspace:*",
    "ucans": "^0.10.0",
    "y-websocket": "^2.0.0",
    "yjs": "^13.6.0",
    "zod": "^4.3.6",
    "@a0n/x-gnosis": "workspace:*"
  },
  "devDependencies": {
    "@types/react": "workspace:*",
    "@types/react-dom": "workspace:*",
    "@cloudflare/workers-types": "^4.20260214.0",
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^9.1.2",
    "typescript": "^5.9.3",
    "vite": "^7.2.7",
    "vite-plugin-wasm": "^3.5.0",
    "wrangler": "^4.67.0",
    "@a0n/a0": "workspace:*"
  }
}
