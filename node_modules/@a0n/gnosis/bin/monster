#!/bin/sh
SCRIPT_DIR=$(CDPATH= cd -- "$(dirname "$0")" && pwd)
MONSTER_BIN="$SCRIPT_DIR/../polyglot/target/release/monster"
GNODE_CLI="$SCRIPT_DIR/gnode.js"
NODE_BIN=$(command -v node 2>/dev/null || echo /opt/homebrew/bin/node)

if [ "${1:-}" = "--" ]; then
  shift
fi

if [ "${1:-}" = "native" ]; then
  shift
  if [ ! -x "$MONSTER_BIN" ]; then
    echo "monster binary not found at $MONSTER_BIN" >&2
    echo "Run: pnpm --dir open-source/gnosis run monster:build" >&2
    exit 127
  fi
  exec "$MONSTER_BIN" "$@"
fi

if [ "${1:-}" = "run" ] && [ "${2:-}" = "src/transcribe-podcasts.ts" ]; then
  shift 2
  exec "$NODE_BIN" "$GNODE_CLI" run src/transcribe-podcasts.ts "$@"
fi

# FOIL grassmannian shell skip (Pareto frontier: warm pure runs return with ZERO runtime startup
# — no node, no monster, just shasum + cat). Only fires on an exact cache hit written by gnode's
# adaptive write-back; on any miss it falls through to the normal routing below. Single file arg
# only; opt out with FOIL_ENTROPY_BOOST=0.
if [ "${1:-}" = "run" ] && [ "${FOIL_ENTROPY_BOOST:-1}" != "0" ] && [ "$#" -eq 2 ] && [ -f "${2:-}" ]; then
  __mfp=$(shasum -a 256 "$2" 2>/dev/null | cut -c1-16)
  __mres="$SCRIPT_DIR/../distributed-inference/.qa-artifacts/fib20-shootout/grassmannian-${__mfp}.result"
  if [ -n "$__mfp" ] && [ -f "$__mres" ]; then
    cat "$__mres"
    exit 0
  fi
fi

# Native-first FOIL. For a single-file `run <file>` (no script args) or a bare
# `<file>`, try the native polyglot binary BEFORE the node+gnode.js path — this is
# what moves `gnode run scripts/*.ts`, `pnpm run monster`, etc. off homebrew node.
# Safe because native fails CLOSED on host calls (fs/net -> exit 9 WITHOUT performing
# the side effect) and routes console output to stderr: we buffer both streams and
# emit them only when native exits 0. A decline/error discards the buffers and the
# authoritative node path below runs instead — no double side-effects, no double
# output, no regression. Multi-file/sibling-import scripts decline (single-file by
# default) and fall back. Opt out entirely with MONSTER_NATIVE_FIRST=0.
if [ "${MONSTER_NATIVE_FIRST:-1}" != "0" ] && [ -x "$MONSTER_BIN" ] && [ ! -t 0 ]; then
  __nf_file=""
  if [ "${1:-}" = "run" ] && [ "$#" -eq 2 ] && [ -f "${2:-}" ]; then
    __nf_file="$2"
  elif [ "$#" -eq 1 ] && [ -f "${1:-}" ]; then
    __nf_file="$1"
  fi
  case "$__nf_file" in
    *.ts|*.tsx|*.js|*.jsx|*.py|*.go|*.java|*.gg|*.gnot)
      __nf_out=$(mktemp 2>/dev/null) || __nf_out=""
      __nf_err=$(mktemp 2>/dev/null) || __nf_err=""
      if [ -n "$__nf_out" ] && [ -n "$__nf_err" ]; then
        if "$MONSTER_BIN" "$__nf_file" >"$__nf_out" 2>"$__nf_err"; then
          cat "$__nf_out"
          cat "$__nf_err" >&2
          rm -f "$__nf_out" "$__nf_err"
          exit 0
        fi
        rm -f "$__nf_out" "$__nf_err"
        # native declined/errored — fall through to the authoritative node path.
      fi
      ;;
  esac
fi

# squirt/eject: the Ecballium binary launcher. Pressurize the lines with FOIL entropy (turgor =
# the jet-engine compressor-cascade product of coprime entropy stages), then eject the target
# ballistically once abscission fires. FOIL's jitter pool seeds the harvest via FOIL_ENTROPY_POOL.
#   monster squirt [--threshold N] [--max-stages K] -- <cmd> [args...]
if [ "${1:-}" = "squirt" ] || [ "${1:-}" = "eject" ]; then
  shift
  ECB_DIR="$SCRIPT_DIR/../gnosis-engine-core"
  ECB_BIN="$ECB_DIR/target/release/ecballium"
  if [ ! -x "$ECB_BIN" ]; then
    echo "monster squirt: building ecballium launcher..." >&2
    ( cd "$ECB_DIR" && cargo build --release --offline --bin ecballium >&2 ) || {
      echo "monster squirt: ecballium build failed" >&2
      exit 127
    }
  fi
  PRE=""
  while [ "${1:-}" = "--threshold" ] || [ "${1:-}" = "--max-stages" ] || [ "${1:-}" = "--foil-pool" ]; do
    PRE="$PRE $1 $2"
    shift 2
  done
  [ "${1:-}" = "--" ] && shift
  # shellcheck disable=SC2086
  if [ "$#" -gt 0 ]; then
    exec "$ECB_BIN" $PRE --launch "$@"
  else
    exec "$ECB_BIN" $PRE
  fi
fi

case "${1:-}" in
  run|test|x|compile|schedule|build|compose|translate|cross-compile|best-language|topo-race|scaffold|polyglot|ditto|ditto-self-host)
    exec "$NODE_BIN" "$GNODE_CLI" "$@"
    ;;
  --watch)
    exec "$NODE_BIN" "$GNODE_CLI" run "$@"
    ;;
esac

case "${1:-}" in
  *.mjs|*.cjs)
    exec "$NODE_BIN" "$@"
    ;;
  *.ts|*.tsx|*.js|*.sh|*.gg|*.gnot|*.py|*.go|*.rs|*.rb|*.java|*.c|*.cpp|*.cc|*.kt|*.zig|*.lua|*.ex|*.exs)
    exec "$NODE_BIN" "$GNODE_CLI" run "$@"
    ;;
esac

exec "$NODE_BIN" "$GNODE_CLI" "$@"
