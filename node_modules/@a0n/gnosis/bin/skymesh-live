#!/usr/bin/env bash
#
# Skymesh (Skymesh) live demo -- one command.
#
# Builds (if needed) and runs the aeon-monitor in Skymesh mode: it renders the
# two-station air-gapped teleport view in the terminal AND yields the live frame
# on every channel at once:
#
#   HTTP  http://127.0.0.1:<port>/skymesh/frame.json   (current frame)
#   SSE   http://127.0.0.1:<port>/skymesh/stream        (frame stream, CORS *)
#   UDP   aeon Flow frames (stream 0x5353) -> 239.69.0.66:<udp> (ttl 1)
#         + unicast 127.0.0.1:<udp>
#
# The web app (apps/skymesh) consumes the SSE source by default, or the UDP
# Flow wire over a WebTransport bridge. Point it at this server with:
#
#   cd apps/skymesh && ../../node_modules/.bin/vite dev
#   open 'http://127.0.0.1:8723/?source=live&live=http://127.0.0.1:8722/skymesh'
#
# Usage:  bin/skymesh-live [http_port=8722] [udp_port=8725]
#
set -euo pipefail

GNOSIS_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
DI="$GNOSIS_ROOT/distributed-inference"
BIN="$DI/target/debug/aeon-monitor"
HTTP_PORT="${1:-8722}"
UDP_PORT="${2:-8725}"

if [ ! -x "$BIN" ]; then
  echo "[skymesh-live] building aeon-monitor (first run)..."
  ( cd "$DI" && cargo build --bin aeon-monitor --features aeon-monitor-bin )
fi

echo "[skymesh-live] HTTP  http://127.0.0.1:${HTTP_PORT}/skymesh/frame.json | /skymesh/stream | /healthz"
echo "[skymesh-live] UDP   aeon Flow (stream 0x5353) -> 239.69.0.66:${UDP_PORT} (ttl 1) + 127.0.0.1:${UDP_PORT}"
echo "[skymesh-live] app   cd apps/skymesh && ../../node_modules/.bin/vite dev"
echo "[skymesh-live]       open 'http://127.0.0.1:8723/?source=live&live=http://127.0.0.1:${HTTP_PORT}/skymesh'"
echo

exec "$BIN" --skymesh --serve "$HTTP_PORT" --demo --udp "$UDP_PORT" --udp-target "127.0.0.1:${UDP_PORT}"
