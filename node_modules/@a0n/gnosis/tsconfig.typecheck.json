{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    // Typecheck uses Bundler resolution so authors can write extension-free
    // imports (`./math`) alongside `.ts`-extension imports used elsewhere in
    // the workspace. The build config (`tsconfig.json`) keeps Node16 for ESM
    // output correctness — this override is a typecheck-surface relaxation
    // only, not a runtime change.
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "ignoreDeprecations": "5.0",
    "allowImportingTsExtensions": true,
    "types": ["node"],
    "strict": false,
    "noImplicitAny": false,
    "noEmit": true,
    // Incremental typecheck: persist the program graph so warm runs only re-check
    // CHANGED files instead of the whole program on every `gnosis build`. Same
    // diagnostics, a fraction of the CPU (the prior full re-check pegged tsc at
    // ~48% for its whole duration every build). noEmit requires an explicit
    // tsBuildInfoFile. The buildinfo is a regenerable cache (gitignored).
    "incremental": true,
    "tsBuildInfoFile": "./.tsbuildinfo-typecheck",
    "rootDir": "..",
    "paths": {
      "gnosis_runtime": ["./runtime/pkg/gnosis_runtime.js"],
      "@a0n/gnosis/test": ["./src/testing/index.ts"],
      "@a0n/gnosis/test/bun": ["./src/testing/bun.ts"],
      "@a0n/gnosis/test/vitest": ["./src/testing/vitest.ts"],
      "@a0n/a0/bundler": ["./src/typecheck-shims/a0-bundler.d.ts"],
      "@a0n/buleyean-kernel": ["./src/typecheck-shims/buleyean-kernel.d.ts"],
      "@a0n/polyglot-scanner-core": ["./src/typecheck-shims/polyglot-scanner-core.d.ts"],
      "@a0n/twokeys": ["./src/typecheck-shims/twokeys.d.ts"],
      "@a0n/aeon-logic": ["./src/typecheck-shims/aeon-logic.d.ts"],
      "@a0n/aeon-logic/browser": ["./src/typecheck-shims/aeon-logic.d.ts"],
      "@a0n/aeon-logic/probability-routing": ["../aeon-logic/src/probability-routing.ts"],
      "@a0n/aeon-pipelines": ["./src/typecheck-shims/aeon-pipelines.d.ts"],
      "@a0n/aeon-pipelines/pipeline": ["./src/typecheck-shims/aeon-pipelines.d.ts"],
      "@a0n/aeon": ["./src/typecheck-shims/aeon-empty.d.ts"],
      "@a0n/aeon/flow": ["./src/typecheck-shims/aeon-flow.d.ts"],
      "@a0n/aeon/fabric": ["./src/typecheck-shims/aeon-flow.d.ts"],
      "@a0n/aeon/fabric/client": ["./src/typecheck-shims/aeon-flow.d.ts"],
      "@a0n/aeon/topology": ["./src/typecheck-shims/aeon-topology.d.ts"],
      "@a0n/aeon-3d/topology": ["./src/typecheck-shims/aeon-3d-topology.d.ts"],
      "@a0n/aeon/*": ["./src/typecheck-shims/aeon-empty.d.ts"],
      "@a0n/auth": ["../auth/src/index.ts"],
      "@a0n/bitwise/cache-fp64": ["./src/typecheck-shims/bitwise.d.ts"],
      "@a0n/bitwise/cache-fp48": ["./src/typecheck-shims/bitwise.d.ts"],
      "@a0n/bitwise/opaque-bytes": ["./src/typecheck-shims/bitwise.d.ts"],
      "@a0n/bitwise/knotchain-fabric.js": ["./src/typecheck-shims/bitwise.d.ts"],
      "@a0n/bitwise/pkg": ["./src/typecheck-shims/bitwise.d.ts"],
      "@a0n/bitwise": ["../bitwise/index.ts"],
      "@a0n/bitwise/*": ["../bitwise/*.ts"],
      "@a0n/raect": ["./src/typecheck-shims/raect.d.ts"],
      "@a0n/wretch": ["./src/typecheck-shims/wretch.d.ts"],
      "gnosis-betti-wasm": ["./gnosis-betti-wasm/pkg/gnosis_betti_wasm.js"],
      "@a0n/telemetry": ["./src/telemetry-module.d.ts"],
      "vitest": ["./src/testing/vitest.ts"],
      "@jest/globals": ["./src/testing/index.ts"]
    }
  },
  "exclude": [
    "src/__tests__/**/*",
    "src/**/*.test.ts",
    "src/benchmarks/**",
    "../bitwise/*.test.ts",
    "../bitwise/test-e2e.ts",
    "../aeon-tui/**"
  ]
}
