{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "declaration": true,
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "types": ["vitest/globals"],
    "paths": {
      "@a0n/aeon": ["../../aeon/src/index.ts"],
      "@a0n/aeon/flow": ["../../aeon/src/flow/index.ts"],
      "@a0n/aeon/optimization": ["../../aeon/src/optimization/index.ts"],
      "@a0n/aeon/topology": ["../../aeon/src/topology/index.ts"],
      "@a0n/aeon/*": ["../../aeon/src/*"],
      "@a0n/auth": ["../../auth/src/index.ts"],
      "@a0n/auth/*": ["../../auth/src/*"]
    }
  },
  "include": ["src/**/*.ts", "__tests__/**/*.ts", "scripts/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
