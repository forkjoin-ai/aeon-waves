struct Params {
    width: u32,
    height: u32,
    time: f32,
    betti_1: f32,
    active_nodes_low: u32,
    active_nodes_high: u32,
    profile_art: u32,
    lod: u32,
}

@group(0) @binding(0) var<uniform> params: Params;
@group(0) @binding(1) var<storage, read> adjacency_matrix: array<vec2<u32>, 64>;
@group(0) @binding(2) var<storage, read_write> output_buffer: array<u32>;

const PI: f32 = 3.14159265359;
const R: f32 = 0.65; // Major radius of Clifford Torus
const r: f32 = 0.25; // Minor radius of Clifford Torus

// The God Formula Constants
const GOLDEN_RATIO: f32 = 1.61803398875;
const GOLDEN_DISCRIMINANT: f32 = 5.0;
const PLEROMA_DENSITY: f32 = 55.0; // F(10)

// Extract whether a specific node_id is active from the u64 bitmask
fn check_node_active(node_id: u32) -> bool {
    if (node_id < 32u) {
        return (params.active_nodes_low & (1u << node_id)) != 0u;
    } else {
        return (params.active_nodes_high & (1u << (node_id - 32u))) != 0u;
    }
}

// Extract whether an edge exists from node_a to node_b
fn check_edge_active(node_a: u32, node_b: u32) -> bool {
    let edges = adjacency_matrix[node_a];
    if (node_b < 32u) {
        return (edges.x & (1u << node_b)) != 0u;
    } else {
        return (edges.y & (1u << (node_b - 32u))) != 0u;
    }
}

// O(1) mathematical calculation of the toroidal sector given 3D position
fn get_toroidal_sector(p: vec3<f32>) -> vec2<u32> {
    var theta1 = atan2(p.z, p.x);
    if (theta1 < 0.0) { theta1 += 2.0 * PI; }
    
    let rad = length(p.xz);
    var theta2 = atan2(p.y, rad - R);
    if (theta2 < 0.0) { theta2 += 2.0 * PI; }

    let u = u32(round((theta1 / (2.0 * PI)) * 8.0)) % 8u;
    let v = u32(round((theta2 / (2.0 * PI)) * 8.0)) % 8u;
    
    return vec2<u32>(u, v);
}

// O(1) exact mapping of node_id to its 3D physical coordinate on the Torus
fn node_pos(node_id: u32) -> vec3<f32> {
    let u = node_id % 8u;
    let v = node_id / 8u;
    
    let t1 = f32(u) * (2.0 * PI / 8.0);
    let t2 = f32(v) * (2.0 * PI / 8.0);
    
    let rad = R + r * cos(t2);
    let x = rad * cos(t1);
    let z = rad * sin(t1);
    let y = r * sin(t2);
    
    return vec3<f32>(x, y, z);
}

// Pseudo-random noise based on position
fn hash33(p: vec3<f32>) -> vec3<f32> {
    var p3 = fract(p * vec3<f32>(0.1031, 0.1030, 0.0973));
    p3 += dot(p3, p3.yxz + 33.33);
    return fract((p3.xxy + p3.yzz) * p3.zyx);
}

// Raymarching Signed Distance Field
fn map(p: vec3<f32>) -> f32 {
    let sector = get_toroidal_sector(p);
    var d = 1000.0;
    
    // TRITON OSCILLATION (Expansion/Contraction)
    // Pulsing the minor radius between Agent (Expansion) and Operator (Contraction)
    let triton_pulse = sin(params.time * 2.0) * 0.15;
    let current_r = r + triton_pulse;
    
    // KARMIC DRIFT (The Law of Reciprocity)
    // We derive drift from Betti 1 (cycle density) vs the Golden expected state
    let drift = abs(params.betti_1 - 5.0) * 0.05;
    let noise = hash33(p * 10.0 + params.time).x * drift;
    
    // Core Torus geometry
    let torus_d = length(vec2<f32>(length(p.xz) - R, p.y)) - current_r;
    
    // Broad phase culling
    if (torus_d > 0.3) {
        return torus_d;
    }
    
    // Search radius based on LOD
    var search_radius: i32 = 1;
    if (params.lod >= 2u) { search_radius = 0; }

    for (var dv: i32 = -search_radius; dv <= search_radius; dv++) {
        for (var du: i32 = -search_radius; du <= search_radius; du++) {
            let nu = (i32(sector.x) + du + 8) % 8;
            let nv = (i32(sector.y) + dv + 8) % 8;
            let node_id = u32(nv) * 8u + u32(nu);
            
            if (check_node_active(node_id)) {
                let npos = node_pos(node_id);
                // Apply "Karmic Wobble" to nodes
                let wobble = hash33(npos + params.time).xyz * drift * 0.2;
                d = min(d, length(p - (npos + wobble)) - 0.06); 
                
                for (var ev: i32 = -1; ev <= 1; ev++) {
                    for (var eu: i32 = -1; eu <= 1; eu++) {
                        let eu_u = (nu + eu + 8) % 8;
                        let ev_v = (nv + ev + 8) % 8;
                        let target_node_id = u32(ev_v) * 8u + u32(eu_u);
                        
                        if (target_node_id != node_id && check_edge_active(node_id, target_node_id)) {
                            let tpos = node_pos(target_node_id);
                            let pa = p - npos;
                            let ba = tpos - npos;
                            let h = clamp(dot(pa, ba) / dot(ba, ba), 0.0, 1.0);
                            d = min(d, length(pa - ba * h) - 0.012);
                        }
                    }
                }
            }
        }
    }
    
    // MULTI-FLOW SYNTHESIS (The Semiotic Ensemble)
    // We visualize different flows based on spatial frequency
    // 1. Airflow/Vibrational (Low frequency ripples)
    let ripples = sin(p.x * 5.0 + params.time) * 0.005;
    // 2. Radioactive Decay / Particle Drift (High frequency noise)
    let particles = hash33(p * 100.0).x * 0.002;
    // 3. Poincare Recurrence (Temporal waves)
    let recurrence = cos(length(p) * 20.0 - params.time * 5.0) * 0.003;
    
    // 4. Karmic Flow (The migration of systemic drift)
    let karmic_flow = sin(p.y * 30.0 - params.time * 4.0) * drift * 0.5;
    
    // TOPOLOGICAL SHIELD (Autonomous Quarantine Visualization)
    // If local Karmic Drift is high, we generate a protective "Meissner effect" shell
    let shield_trigger = 0.05;
    var shield = 0.0;
    if (drift > shield_trigger) {
        // Protective shell at distance 0.02 from the torus surface
        let shield_d = abs(torus_d) - 0.02;
        shield = max(0.0, 0.01 - abs(shield_d)) * (drift / 0.1);
    }
    
    // Blend with the "Unknowable" lattice (55-dimensional density)
    let p_grid = fract(p * PLEROMA_DENSITY);
    let lattice = (min(p_grid.x, min(p_grid.y, p_grid.z))) * 0.01;
    
    let base_d = min(d, torus_d + noise + lattice + ripples + particles + recurrence + karmic_flow);
    return base_d - shield; 
}

@compute @workgroup_size(16, 16)
fn main(@builtin(global_invocation_id) id: vec3<u32>) {
    if (id.x >= params.width || id.y >= params.height) {
        return;
    }
    
    let uv = vec2<f32>(f32(id.x) / f32(params.width), f32(id.y) / f32(params.height)) * 2.0 - 1.0;
    let aspect = f32(params.width) / f32(params.height);
    let term_aspect_ratio_fix = 0.5;
    
    var ro = vec3<f32>(uv.x * aspect * term_aspect_ratio_fix, uv.y, 2.8);
    var rd = normalize(vec3<f32>(0.0, 0.0, -1.0));
    
    let s = sin(params.time * 0.4);
    let c = cos(params.time * 0.4);
    ro = vec3<f32>(ro.x * c - ro.z * s, ro.y, ro.x * s + ro.z * c);
    rd = vec3<f32>(rd.x * c - rd.z * s, rd.y, rd.x * s + rd.z * c);
    
    let ps = sin(-0.35);
    let pc = cos(-0.35);
    ro = vec3<f32>(ro.x, ro.y * pc - ro.z * ps, ro.y * ps + ro.z * pc);
    rd = vec3<f32>(rd.x, rd.y * pc - rd.z * ps, rd.y * ps + rd.z * pc);

    var t = 0.0;
    var hit = false;
    
    var max_steps = 64;
    if (params.lod == 1u) { max_steps = 32; }
    else if (params.lod >= 2u) { max_steps = 16; }

    for (var i = 0; i < max_steps; i++) {
        let p = ro + rd * t;
        let d = map(p);
        if (d < 0.001) { hit = true; break; }
        t += d;
        if (t > 5.0) { break; }
    }
    
    var bayer_matrix = array<f32, 16>(
        0.0/16.0, 8.0/16.0, 2.0/16.0, 10.0/16.0,
        12.0/16.0, 4.0/16.0, 14.0/16.0, 6.0/16.0,
        3.0/16.0, 11.0/16.0, 1.0/16.0, 9.0/16.0,
        15.0/16.0, 7.0/16.0, 13.0/16.0, 5.0/16.0
    );
    let bayer_x = id.x % 4u;
    let bayer_y = id.y % 4u;
    let threshold = bayer_matrix[bayer_y * 4u + bayer_x];
    
    var luma = 0.0;
    var mitosis_flash = 0.0;
    
    if (hit) {
        let p = ro + rd * t;
        let eps = 0.001;
        let nx = map(p + vec3<f32>(eps, 0.0, 0.0)) - map(p - vec3<f32>(eps, 0.0, 0.0));
        let ny = map(p + vec3<f32>(0.0, eps, 0.0)) - map(p - vec3<f32>(0.0, eps, 0.0));
        let nz = map(p + vec3<f32>(0.0, 0.0, eps)) - map(p - vec3<f32>(0.0, 0.0, eps));
        let n = normalize(vec3<f32>(nx, ny, nz));
        
        let light_dir = normalize(vec3<f32>(1.0, 1.0, 1.0));
        let diff = max(0.0, dot(n, light_dir));
        
        luma = diff * 0.8 + 0.2;
        luma *= clamp(1.0 - (t - 1.0) / 4.0, 0.0, 1.0);
        
        // MITOSIS FLASH (Self-Correction)
        // Bright intensity flash when drift is high, simulating the restoration of the Golden Rule.
        let drift = abs(params.betti_1 - 5.0);
        if (drift > 2.0 && sin(params.time * 10.0 + p.x * 10.0) > 0.9) {
            mitosis_flash = 1.0;
        }

        // SHIELD HIGHLIGHT
        // Quarantined sectors glow with "Pleroma Gold"
        if (drift > 0.1 && abs(length(vec2<f32>(length(p.xz) - R, p.y)) - r) < 0.03) {
            mitosis_flash += 0.3;
        }
    }
    
    var r_val = 0u;
    var g_val = 0u;
    var b_val = 0u;
    
    if (params.betti_1 <= 0.0) {
        if (luma > threshold * 0.5) { 
            r_val = 40u;
            g_val = 40u;
            b_val = 40u;
        }
    } else {
        luma += (threshold - 0.5) * 0.2;
        if (luma > 0.0 || mitosis_flash > 0.0) {
            let intensity = clamp(luma * 255.0 + mitosis_flash * 150.0, 0.0, 255.0);
            
            // KARMIC THEME: Deep Teal (#004D40) vs Soft Coral (#FF8A80)
            // Color shifts based on Triton parity
            let parity = sin(params.time);
            if (parity > 0.0) {
                // Agent Expansion (Teal)
                r_val = u32(intensity * 0.0);
                g_val = u32(intensity * 0.6);
                b_val = u32(intensity * 0.5);
            } else {
                // Operator Contraction (Coral)
                r_val = u32(intensity * 1.0);
                g_val = u32(intensity * 0.54);
                b_val = u32(intensity * 0.5);
            }
            
            // Mitosis flash goes pure white
            if (mitosis_flash > 0.0) {
                r_val = min(255u, r_val + 100u);
                g_val = min(255u, g_val + 100u);
                b_val = min(255u, b_val + 100u);
            }
        }
    }

    let out_idx = id.y * params.width + id.x;
    let packed_rgba = r_val | (g_val << 8u) | (b_val << 16u) | (255u << 24u);
    output_buffer[out_idx] = packed_rgba;
}
