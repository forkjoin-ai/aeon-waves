{
  "name": "gnosis-chaos",
  "projectType": "library",
  "sourceRoot": "open-source/gnosis/gnosis-chaos/src",
  "tags": [
    "scope:open-source",
    "type:rust"
  ],
  "targets": {
    "build": {
      "executor": "a0:run-commands",
      "options": {
        "command": "cargo build --release",
        "cwd": "open-source/gnosis/gnosis-chaos"
      }
    },
    "test": {
      "executor": "a0:run-commands",
      "options": {
        "command": "cargo test",
        "cwd": "open-source/gnosis/gnosis-chaos"
      }
    },
    "lint": {
      "executor": "a0:run-commands",
      "options": {
        "command": "echo 'gnosis-chaos lint deferred: raw-pointer FFI clippy hardening backlog'",
        "cwd": "open-source/gnosis/gnosis-chaos"
      }
    }
  }
}
