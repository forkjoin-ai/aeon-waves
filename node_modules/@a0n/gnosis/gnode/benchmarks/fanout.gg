// fanout.gg — checked-in GG companion for the TypeScript Promise.all fanout fixture.
// It keeps both the ordinary PROCESS path and the foil sidecar FORK/FOLD topology.
(entry_0: Entry:PolyglotBridgeEntry { language: 'typescript', name: 'app', params: 'input', return_type: 'PromiseString' })
(statement_1: Statement:PolyglotBridgeCall { bind_pattern: 'user_profile', callee: 'Promise.all', branches: 2 })
(statement_2: Statement:PolyglotBridgeCall { bind: 'summary', callee: 'merge' })
(return_3: Return:PolyglotBridgeReturn { expr: 'summary' })
(foil_join_4: Join:PolyglotBridgeJoin:FoilForkFold { arity: 2, bind_pattern: 'user_profile', foil_lowering: 'Promise.all', scheduler: 'gnosis-foil' })
(foil_branch_5: Branch:PolyglotBridgeCall:FoilBranch { branch_index: 0, callee: 'loadUser', foil_lowering: 'Promise.all', scheduler: 'gnosis-foil' })
(foil_branch_6: Branch:PolyglotBridgeCall:FoilBranch { branch_index: 1, callee: 'loadProfile', foil_lowering: 'Promise.all', scheduler: 'gnosis-foil' })

(entry_0)-[:PROCESS]->(statement_1)
(statement_1)-[:PROCESS]->(statement_2)
(statement_2)-[:PROCESS]->(return_3)
(statement_1)-[:FORK { foil_lowering: 'Promise.all', preserves_process_path: true, scheduler: 'gnosis-foil' }]->(foil_branch_5 | foil_branch_6)
(foil_branch_5 | foil_branch_6)-[:FOLD { foil_lowering: 'Promise.all', scheduler: 'gnosis-foil' }]->(foil_join_4)
(foil_join_4)-[:TUNNEL { condition: 'bounded-reject' }]->(fanout_gg_trace:Trace)
(foil_join_4)-[:MEASURE { reason: 'topology-audit' }]->(fanout_gg_trace:Trace)
