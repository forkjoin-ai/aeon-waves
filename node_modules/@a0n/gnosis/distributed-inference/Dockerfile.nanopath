# Sovereign pathology embedding node (CPU-only): builds nanopath-embed-server and bakes
# the DinoV2ViT .knot. Serves POST /nanopath-embedding for the monster-studio Microscope.
# Context is open-source/ (path-deps into gnosis/ + bitwise/), mirroring Dockerfile.skymesh.
FROM rust:1-bookworm AS build
WORKDIR /src
COPY gnosis/ ./gnosis/
COPY bitwise/ ./bitwise/
WORKDIR /src/gnosis/distributed-inference
RUN RUSTFLAGS="-C target-cpu=x86-64-v3" cargo build --release --bin nanopath-embed-server \
 && cp target/release/nanopath-embed-server /nanopath-embed-server

FROM debian:bookworm-slim AS runtime
RUN apt-get update && apt-get install -y --no-install-recommends ca-certificates \
 && rm -rf /var/lib/apt/lists/*
COPY --from=build /nanopath-embed-server /usr/local/bin/nanopath-embed-server
COPY gnosis/distributed-inference/dinov2-path.pack /models/dinov2-path.pack
# Cloud Run injects $PORT (8080); the server binds 0.0.0.0:$PORT. $0-idle at min-instances=0.
ENV PORT=8080
EXPOSE 8080
CMD ["sh", "-c", "exec nanopath-embed-server --knot /models/dinov2-path.pack --port ${PORT}"]
