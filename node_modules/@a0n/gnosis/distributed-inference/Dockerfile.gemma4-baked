# Bakes the gemma4-12b-it-heretic knot (7.37 GB Q4K) into the moonshine GPU image
# so the fat-station mmaps it from local disk (MmapBackend, demand-paged) instead
# of HTTP-Range-streaming every layer from R2 (~5-6s/layer => ~775s cold-start).
# Runtime must point KNOT_URL at the LOCAL path (no http:// prefix) to select the
# mmap backend.
#
# Two-stage: the moonshine CUDA base has no curl, so download in a debian builder
# (Range-capable proxy + exact-size verify) and COPY the knot into the final image.

FROM debian:bookworm-slim AS dl
RUN apt-get update && apt-get install -y --no-install-recommends curl ca-certificates \
 && rm -rf /var/lib/apt/lists/* \
 && curl -fSL --retry 10 --retry-delay 10 --retry-all-errors -C - \
      "https://www-edgework-app.edgework.ai/api/v1/r2/distributed-inference/models/gemma4-12b-it-heretic.knot" \
      -o /knot \
 && sz=$(stat -c%s /knot) && echo "knot size = $sz" \
 && [ "$sz" = "7365613701" ] || { echo "KNOT SIZE MISMATCH (expected 7365613701, got $sz)"; exit 1; }

FROM us-central1-docker.pkg.dev/neutral-418500/gnosis/moonshine:moonshine-gpu-v22-tstimeout
COPY --from=dl /knot /models/gemma4-12b-it-heretic.knot
