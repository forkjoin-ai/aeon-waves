# Dockerfile.quantized-weights: Production container with quantized weight distribution
# Stage 1: Build reconstruction kernel and Python utilities
FROM nvidia/cuda:12.2.2-devel-ubuntu22.04 as builder

WORKDIR /build

# Install build dependencies
RUN apt-get update && apt-get install -y \
    python3 python3-pip python3-dev \
    curl git \
    && rm -rf /var/lib/apt/lists/*

# Copy source files
COPY reconstruct-weights-gpu.cu .
COPY quantize-model-weights.py .
COPY bench_weight_quantization.py .

# Compile CUDA kernel
RUN nvcc -O3 -arch=sm_80 -shared --compiler-options '-fPIC' \
    -o reconstruct_weights.so \
    reconstruct-weights-gpu.cu

# Stage 2: Runtime container with quantized weights
FROM nvidia/cuda:12.2.2-runtime-ubuntu22.04

WORKDIR /app

# Install runtime dependencies
RUN apt-get update && apt-get install -y \
    python3 python3-pip \
    curl ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Copy built artifacts from builder
COPY --from=builder /build/reconstruct_weights.so /app/lib/
COPY --from=builder /build/quantize-model-weights.py /app/
COPY --from=builder /build/bench_weight_quantization.py /app/

# Copy quantized weight files
RUN mkdir -p /app/weights/quantized
COPY rknots/ /app/rknots/

# Python dependencies
RUN pip install --no-cache-dir numpy scipy pydantic

# Environment setup
ENV CUDA_VISIBLE_DEVICES=0
ENV LD_LIBRARY_PATH=/app/lib:$LD_LIBRARY_PATH
ENV PYTHONUNBUFFERED=1

# Health check endpoint (placeholder for inference server)
HEALTHCHECK --interval=30s --timeout=10s --start-period=5s --retries=3 \
    CMD python3 -c "import ctypes; print('OK')" || exit 1

# Entrypoint: default to benchmark, can override for inference
ENTRYPOINT ["python3", "bench_weight_quantization.py"]
