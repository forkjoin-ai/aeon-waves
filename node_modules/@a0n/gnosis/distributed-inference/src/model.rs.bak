//! NativeLlamaPipeline — the per-station LLM forward pass driving the gnosis
//! mesh. Default model is Qwen2.5-Coder-7B (the "consciousness layer" of
//! Pneuma).
//!
//! References:
//!   - arXiv 2412.15115 (Qwen2.5 Technical Report, Qwen Team 2024).
//!     https://arxiv.org/abs/2412.15115
//!   - arXiv 2409.12186 (Qwen2.5-Coder Technical Report, Qwen Team 2024).
//!     https://arxiv.org/abs/2409.12186
//!   - arXiv 2104.09864 (RoFormer / RoPE — Rotary Position Embedding,
//!     Su et al. 2021). https://arxiv.org/abs/2104.09864
//!   - GGUF / k-quant weights: github.com/ggerganov/llama.cpp,
//!     github.com/ggerganov/ggml.

use crate::kv_cache::KVCache;
use crate::loader::{KnotConfig, KnotWeights};
use crate::math::*;
use crate::{amplituhedron, matvec_memo};
use gnosis_frf::prelude::*;

// Used only by the wasm `from_parts` constructor. Gating these keeps the
// native build's "unused import" warnings at zero.
#[cfg(target_arch = "wasm32")]
use crate::loader::{TensorInfo, WeightBackend};
#[cfg(target_arch = "wasm32")]
use std::collections::HashMap;
#[cfg(target_arch = "wasm32")]
use std::sync::Arc;

// Cross-target stopwatch. Native uses `std::time::Instant`; wasm32 returns
// zero because `wasm32-unknown-unknown` has no clock primitive. The forward
// pass uses these only for self-reported telemetry, so a zero stopwatch on
// wasm just means the host sees `t_qkv = t_attn = ... = 0` — no semantic
// change in the inference path.
#[cfg(not(target_arch = "wasm32"))]
struct Stopwatch(std::time::Instant);
#[cfg(not(target_arch = "wasm32"))]
impl Stopwatch {
    #[inline]
    fn now() -> Self {
        Self(std::time::Instant::now())
    }
    #[inline]
    fn elapsed_us(&self) -> u64 {
        self.0.elapsed().as_micros() as u64
    }
}

#[cfg(target_arch = "wasm32")]
struct Stopwatch;
#[cfg(target_arch = "wasm32")]
impl Stopwatch {
    #[inline]
    fn now() -> Self {
        Self
    }
    #[inline]
    fn elapsed_us(&self) -> u64 {
        0
    }
}

#[cfg(feature = "napi")]
use napi::bindgen_prelude::*;
#[cfg(feature = "napi")]
use napi_derive::napi;

#[cfg(not(feature = "napi"))]
mod napi_stubs {
    pub type Result<T> = std::result::Result<T, String>;
    pub struct Uint32Array(Vec<u32>);
    impl Uint32Array {
        pub fn new(v: Vec<u32>) -> Self {
            Self(v)
        }
        pub fn to_vec(&self) -> Vec<u32> {
            self.0.clone()
        }
    }
    pub mod napi {
        pub type Result<T> = std::result::Result<T, String>;
        pub struct Error;
        impl Error {
            pub fn from_reason(s: String) -> String {
                s
            }
        }
    }
}
#[cfg(not(feature = "napi"))]
use napi_stubs::*;

#[cfg(not(feature = "napi"))]
pub use bitwise::flow_frame::FIN as napi_attr; // Dummy

#[cfg(not(feature = "napi"))]
#[allow(unused_macros)]
macro_rules! napi {
    ($($t:tt)*) => {};
}

pub struct TransformerConfig {
    pub hidden_dim: usize,
    pub num_layers: usize,
    pub num_heads: usize,
    pub num_kv_heads: usize,
    pub head_dim: usize,
    pub intermediate_size: usize,
    pub vocab_size: usize,
    pub rms_norm_eps: f32,
    pub rope_theta: f32,
}

impl Default for TransformerConfig {
    fn default() -> Self {
        // TinyLlama 1.1B fallback. Used when a knot has no `config` block in
        // its metadata (legacy 1B knots predate the config addition). Real
        // models load their dims from the knot file.
        Self {
            hidden_dim: 2048,
            num_layers: 22,
            num_heads: 32,
            num_kv_heads: 4,
            head_dim: 64,
            intermediate_size: 5632,
            vocab_size: 32000,
            rms_norm_eps: 1e-5,
            rope_theta: 10000.0,
        }
    }
}

impl From<&KnotConfig> for TransformerConfig {
    fn from(c: &KnotConfig) -> Self {
        Self {
            hidden_dim: c.hidden_dim,
            num_layers: c.num_layers,
            num_heads: c.num_heads,
            num_kv_heads: c.num_kv_heads,
            head_dim: c.head_dim,
            intermediate_size: c.intermediate_size,
            vocab_size: c.vocab_size,
            rms_norm_eps: c.rms_norm_eps,
            rope_theta: c.rope_theta,
        }
    }
}

// ── Pre-resolved tensor references ────────────────────────────────────
// We carry tensor names rather than file offsets, since the HTTP backend
// resolves names → bytes via a Range fetch + LRU cache rather than a direct
// mmap slice. The qtype is resolved once at load time so the matmul dispatch
// can pick the right kernel without re-parsing metadata.

#[derive(Clone, Copy, Debug)]
pub enum QType {
    F32,
    Q4K,
    Q6K,
}

#[derive(Clone, Debug)]
pub struct TensorRef {
    pub name: String,
    pub qtype: QType,
}

#[derive(Debug)]
pub struct LayerLocs {
    pub attn_norm: TensorRef,
    pub q: TensorRef,
    pub k: TensorRef,
    pub v: TensorRef,
    pub o: TensorRef,
    pub ffn_norm: TensorRef,
    pub gate: TensorRef,
    pub up: TensorRef,
    pub down: TensorRef,
    /// Qwen2 / Qwen2.5: Q/K/V projections include bias. Optional because
    /// other architectures (LLaMA, Mistral) use bias=false.
    pub q_bias: Option<TensorRef>,
    pub k_bias: Option<TensorRef>,
    pub v_bias: Option<TensorRef>,
}

impl LayerLocs {
    /// Names that should be prefetched together when this layer is queued.
    pub fn names(&self) -> Vec<String> {
        let mut v = vec![
            self.attn_norm.name.clone(),
            self.q.name.clone(),
            self.k.name.clone(),
            self.v.name.clone(),
            self.o.name.clone(),
            self.ffn_norm.name.clone(),
            self.gate.name.clone(),
            self.up.name.clone(),
            self.down.name.clone(),
        ];
        if let Some(b) = &self.q_bias { v.push(b.name.clone()); }
        if let Some(b) = &self.k_bias { v.push(b.name.clone()); }
        if let Some(b) = &self.v_bias { v.push(b.name.clone()); }
        v
    }
}

#[derive(Debug)]
pub struct ResolvedLocs {
    pub embed: TensorRef,
    pub final_norm: TensorRef,
    pub lm_head: TensorRef,
    pub layers: Vec<LayerLocs>,
}

fn resolve_type(t: &str) -> QType {
    match t {
        "Q4_K" => QType::Q4K,
        "Q6_K" => QType::Q6K,
        _ => QType::F32,
    }
}

fn resolve_tensor(knot: &KnotWeights, name: &str) -> TensorRef {
    let info = knot
        .metadata
        .get(name)
        .unwrap_or_else(|| panic!("Missing tensor: {}", name));
    TensorRef {
        name: name.to_string(),
        qtype: resolve_type(&info.tensor_type),
    }
}

/// Optional resolver for tensors that may or may not be present (e.g. Qwen2
/// attention biases vs. LLaMA bias-free projections).
fn try_resolve_tensor(knot: &KnotWeights, name: &str) -> Option<TensorRef> {
    knot.metadata.get(name).map(|info| TensorRef {
        name: name.to_string(),
        qtype: resolve_type(&info.tensor_type),
    })
}

fn resolve_all(knot: &KnotWeights, config: &TransformerConfig) -> ResolvedLocs {
    let embed = resolve_tensor(knot, "token_embd_weight");
    let final_norm = resolve_tensor(knot, "output_norm_weight");
    let lm_head = if knot.metadata.contains_key("output_weight") {
        resolve_tensor(knot, "output_weight")
    } else {
        embed.clone()
    };

    let mut layers = Vec::with_capacity(config.num_layers);
    for i in 0..config.num_layers {
        layers.push(LayerLocs {
            attn_norm: resolve_tensor(knot, &format!("blk_{}_attn_norm_weight", i)),
            q: resolve_tensor(knot, &format!("blk_{}_attn_q_weight", i)),
            k: resolve_tensor(knot, &format!("blk_{}_attn_k_weight", i)),
            v: resolve_tensor(knot, &format!("blk_{}_attn_v_weight", i)),
            o: resolve_tensor(knot, &format!("blk_{}_attn_output_weight", i)),
            ffn_norm: resolve_tensor(knot, &format!("blk_{}_ffn_norm_weight", i)),
            gate: resolve_tensor(knot, &format!("blk_{}_ffn_gate_weight", i)),
            up: resolve_tensor(knot, &format!("blk_{}_ffn_up_weight", i)),
            down: resolve_tensor(knot, &format!("blk_{}_ffn_down_weight", i)),
            q_bias: try_resolve_tensor(knot, &format!("blk_{}_attn_q_bias", i)),
            k_bias: try_resolve_tensor(knot, &format!("blk_{}_attn_k_bias", i)),
            v_bias: try_resolve_tensor(knot, &format!("blk_{}_attn_v_bias", i)),
        });
    }

    ResolvedLocs {
        embed,
        final_norm,
        lm_head,
        layers,
    }
}

// ── Dispatch helpers ─────────────────────────────────────────────────

#[inline(always)]
fn bytes_to_f32_slice(bytes: &[u8]) -> &[f32] {
    unsafe { std::slice::from_raw_parts(bytes.as_ptr() as *const f32, bytes.len() / 4) }
}

#[inline(always)]
fn mat_vec_run(out: &mut [f32], x: &[f32], w: &[u8], qtype: QType, rows: usize, cols: usize) {
    match qtype {
        QType::Q4K => mat_vec_q4k(out, x, w, rows, cols),
        QType::Q6K => mat_vec_q6k(out, x, w, rows, cols),
        QType::F32 => mat_vec_f32(out, x, bytes_to_f32_slice(w), rows, cols),
    }
}

/// Batched mat-vec dispatch.
///
/// `out` is laid out as `n_batch` strides of `out_stride` floats. Each stride
/// receives `rows` outputs (the remaining stride elements are not touched and
/// must be treated as garbage). `x` is laid out as `n_batch` strides of `cols`
/// floats. The kernel reads exactly `n_batch` input/output slots — slots
/// beyond `n_batch` in the underlying buffer are not visited.
#[inline(always)]
pub fn mat_vec_dispatch_batch(
    out: &mut [f32],
    x: &[f32],
    w: &[u8],
    qtype: QType,
    rows: usize,
    cols: usize,
    n_batch: usize,
    out_stride: usize,
) {
    if n_batch == 0 {
        return;
    }

    // Take exactly n_batch chunks of out_stride / cols. Avoids feeding
    // stale tail slots into the inner kernel (the previous version sent all
    // 8 pre-allocated slots regardless of n_batch, computing wasted dot
    // products against stale batch_xb data).
    let mut out_ptrs: Vec<*mut f32> = Vec::with_capacity(n_batch);
    {
        let mut iter = out.chunks_mut(out_stride);
        for _ in 0..n_batch {
            let chunk = iter.next().expect("out buffer too small for n_batch");
            out_ptrs.push(chunk.as_mut_ptr());
        }
    }
    let x_slices: Vec<&[f32]> = x.chunks(cols).take(n_batch).collect();
    debug_assert_eq!(x_slices.len(), n_batch, "x buffer too small for n_batch");

    match qtype {
        QType::Q4K => {
            let mut out_slices: Vec<&mut [f32]> = unsafe {
                out_ptrs
                    .iter()
                    .map(|&p| std::slice::from_raw_parts_mut(p, rows))
                    .collect()
            };
            mat_vec_q4k_batch(&mut out_slices, &x_slices, w, rows, cols);
        }
        QType::Q6K => {
            let mut out_slices: Vec<&mut [f32]> = unsafe {
                out_ptrs
                    .iter()
                    .map(|&p| std::slice::from_raw_parts_mut(p, rows))
                    .collect()
            };
            mat_vec_q6k_batch(&mut out_slices, &x_slices, w, rows, cols);
        }
        QType::F32 => {
            let mut out_slices: Vec<&mut [f32]> = unsafe {
                out_ptrs
                    .iter()
                    .map(|&p| std::slice::from_raw_parts_mut(p, rows))
                    .collect()
            };
            mat_vec_f32_batch(
                &mut out_slices,
                &x_slices,
                bytes_to_f32_slice(w),
                rows,
                cols,
            );
        }
    }
}

// ── Pipeline ─────────────────────────────────────────────────────────

#[cfg_attr(feature = "napi", napi)]
pub struct NativeLlamaPipeline {
    config: TransformerConfig,
    knot: KnotWeights,
    locs: ResolvedLocs,
    ffn_cache: Vec<Option<FFNCacheEntry>>,
    pub draft_mode: bool,
    pub resonance_threshold: f64,
    kv_cache: KVCache,
    pub(crate) pos: usize,
    x: Vec<f32>,
    xb: Vec<f32>,
    xb2: Vec<f32>,
    hb: Vec<f32>,
    hb2: Vec<f32>,
    q: Vec<f32>,
    k_buf: Vec<f32>,
    v_buf: Vec<f32>,
    logits: Vec<f32>,
    pub acoustic: crate::acoustic::AcousticEngine,
    // Batch buffers for Truly Batched Verification (up to 8 candidates)
    batch_x: Vec<f32>,
    batch_xb: Vec<f32>,
    batch_xb2: Vec<f32>,
    batch_hb: Vec<f32>,
    batch_hb2: Vec<f32>,
    batch_q: Vec<f32>,
    batch_k: Vec<f32>,
    batch_v: Vec<f32>,
    batch_logits: Vec<f32>,
    pub memo: matvec_memo::MatVecMemo,
    pub amplituhedron: amplituhedron::AmplituhedronCache,
}

struct FFNCacheEntry {
    input: Vec<f32>,
    output: Vec<f32>,
    active: bool,
}

// Liquid-mesh (and prefill batches up to 4) need more headroom; cap at
// 4 for the wasm32 build to keep batch_logits = 4 × 151,936 × 4 bytes
// = 2.4 MiB instead of 4.6 MiB. The kernel's loops run for `seq_len`
// elements regardless, so a tighter cap saves ~2 MiB of pre-allocated
// state without hurting throughput on the bench's seq_len ≤ 4 path.
#[cfg(target_arch = "wasm32")]
const BATCH_CAPACITY: usize = 16;
#[cfg(not(target_arch = "wasm32"))]
const BATCH_CAPACITY: usize = 8;

impl NativeLlamaPipeline {
    pub fn get_pos(&self) -> u32 {
        self.pos as u32
    }

    /// Native-only path-based constructor: opens the knot via mmap or HTTP,
    /// then delegates to `from_knot`. Wasm builds can't use this — the host
    /// constructs the backend out of band and calls `from_parts`.
    #[cfg(not(target_arch = "wasm32"))]
    pub fn new(path: String, draft_mode: bool, resonance_threshold: f64) -> Self {
        let knot = KnotWeights::load(&path).expect("Failed to load weights");
        Self::from_knot(knot, draft_mode, resonance_threshold)
    }

    /// Wasm host-driven constructor. The JS shim parses the knot header,
    /// instantiates a `WasmHostBackend`, and hands the parts back. This
    /// returns a pipeline ready for `forward_one` once the host has
    /// pre-populated the first layer's tensors.
    #[cfg(target_arch = "wasm32")]
    pub fn from_parts(
        backend: Arc<dyn WeightBackend>,
        metadata: HashMap<String, TensorInfo>,
        config: Option<KnotConfig>,
        payload_offset: usize,
        draft_mode: bool,
        resonance_threshold: f64,
    ) -> Self {
        let knot = KnotWeights::from_parts(backend, metadata, config, payload_offset);
        Self::from_knot(knot, draft_mode, resonance_threshold)
    }

    /// Cross-target initializer: takes a fully-built `KnotWeights` and
    /// allocates buffers + resolves tensor refs. Both `new` (native) and
    /// `from_parts` (wasm) bottom out here.
    pub fn from_knot(knot: KnotWeights, draft_mode: bool, resonance_threshold: f64) -> Self {
        // Use config from knot metadata if present; fall back to TinyLlama
        // defaults for legacy 1B knots that predate the config block.
        let config = match &knot.config {
            Some(c) => {
                eprintln!(
                    "[Pipeline] knot config: hidden_dim={} layers={} heads={} kv_heads={} head_dim={} ffn={} vocab={} rope_theta={}",
                    c.hidden_dim, c.num_layers, c.num_heads, c.num_kv_heads,
                    c.head_dim, c.intermediate_size, c.vocab_size, c.rope_theta
                );
                TransformerConfig::from(c)
            }
            None => {
                eprintln!("[Pipeline] no knot config block; using TinyLlama defaults");
                TransformerConfig::default()
            }
        };
        let locs = resolve_all(&knot, &config);

        let mut ffn_cache = Vec::with_capacity(config.num_layers);
        for _ in 0..config.num_layers {
            ffn_cache.push(None);
        }

        // KV cache size = num_layers × num_kv_heads × max_seq_len × head_dim
        //                  × 4 bytes (f32) × 2 (keys + values).
        //
        // For qwen-coder-7b (28 layers, 4 kv_heads, 128 head_dim): max_seq_len=2048
        // works out to 234 MiB, which fits comfortably in a native heap but
        // overflows a Cloudflare Worker's 128 MiB request-memory cap and
        // makes the Wasm linear-memory grow fail with `unreachable!()` at
        // boot. We don't currently size per-station (each layer worker only
        // owns a subset of the 28 layers, but the cache still allocates for
        // all of them so layer index → cache offset stays a stable identity).
        // Until the deeper refactor lands, cap wasm32 builds at max_seq_len=512
        // — that cuts the cache to ~58 MiB on qwen-7b, leaves headroom for
        // pipeline scratch buffers, and still covers four-paragraph-class
        // prompts. Native (NAPI / chaos-swarm / shard-knot) keeps the full
        // 2048 budget where the heap is unbounded.
        // Liquid-mesh sizing: 28 single-layer workers each carry the full
        // KV cache budget (one isolate per layer, but each holds K/V for
        // *all* layers because the per-layer struct is shared with multi-
        // layer stations). Dropping to 128 is the difference between
        // ~14 MiB cache (fits) and ~58 MiB cache (OOMs at boot when stacked
        // with ~80 MiB of resident layer weights).
        //
        // 128 caps practical prompt + generation length to 128 tokens. Good
        // enough for the bench; production needs the per-instance num_layers
        // override (tracked in #31) to reclaim the wasted 27/28 of the cache
        // on liquid-mesh single-layer isolates.
        #[cfg(target_arch = "wasm32")]
        const KV_MAX_SEQ_LEN: usize = 128;
        #[cfg(not(target_arch = "wasm32"))]
        const KV_MAX_SEQ_LEN: usize = 2048;
        let kv_cache = KVCache::new(
            config.num_layers,
            config.num_kv_heads,
            config.head_dim,
            KV_MAX_SEQ_LEN,
        );
        // Probe parallelism on native; wasm32 has no thread runtime so we
        // default to single-threaded — the gnosis-frf prelude par-iters will
        // sequentially fold for us regardless.
        #[cfg(not(target_arch = "wasm32"))]
        let _k = std::thread::available_parallelism()
            .map(|n| n.get())
            .unwrap_or(1);
        #[cfg(target_arch = "wasm32")]
        let _k: usize = 1;
        let x = vec![0.0f32; config.hidden_dim];
        let xb = vec![0.0f32; config.hidden_dim];
        let xb2 = vec![0.0f32; config.hidden_dim];
        let hb = vec![0.0f32; config.intermediate_size];
        let hb2 = vec![0.0f32; config.intermediate_size];
        let q = vec![0.0f32; config.num_heads * config.head_dim];
        let k_buf = vec![0.0f32; config.num_kv_heads * config.head_dim];
        let v_buf = vec![0.0f32; config.num_kv_heads * config.head_dim];
        let logits = vec![0.0f32; config.vocab_size];

        let batch_x = vec![0.0f32; BATCH_CAPACITY * config.hidden_dim];
        let batch_xb = vec![0.0f32; BATCH_CAPACITY * config.hidden_dim];
        let batch_xb2 = vec![0.0f32; BATCH_CAPACITY * config.hidden_dim];
        let batch_hb = vec![0.0f32; BATCH_CAPACITY * config.intermediate_size];
        let batch_hb2 = vec![0.0f32; BATCH_CAPACITY * config.intermediate_size];
        let batch_q = vec![0.0f32; BATCH_CAPACITY * (config.num_heads * config.head_dim)];
        let batch_k = vec![0.0f32; BATCH_CAPACITY * (config.num_kv_heads * config.head_dim)];
        let batch_v = vec![0.0f32; BATCH_CAPACITY * (config.num_kv_heads * config.head_dim)];
        let batch_logits = vec![0.0f32; BATCH_CAPACITY * config.vocab_size];

        // Eager prefetch of the first layer's weights so the very first
        // forward_one() doesn't pay a full layer-fetch latency. Subsequent
        // layers are prefetched one ahead during the forward pass.
        if !locs.layers.is_empty() {
            knot.backend.prefetch(&locs.layers[0].names());
        }

        Self {
            config,
            knot,
            locs,
            ffn_cache,
            draft_mode,
            resonance_threshold,
            kv_cache,
            pos: 0,
            x,
            xb,
            xb2,
            hb,
            hb2,
            q,
            k_buf,
            v_buf,
            logits,
            acoustic: crate::acoustic::AcousticEngine::new(),
            batch_x,
            batch_xb,
            batch_xb2,
            batch_hb,
            batch_hb2,
            batch_q,
            batch_k,
            batch_v,
            batch_logits,
            memo: matvec_memo::MatVecMemo::new(),
            amplituhedron: amplituhedron::AmplituhedronCache::new(),
        }
    }

    pub fn generate(
        &mut self,
        prompt_tokens: Uint32Array,
        max_new_tokens: u32,
    ) -> napi::Result<Uint32Array> {
        let tokens_vec = prompt_tokens.to_vec();
        match self.inner_generate(&tokens_vec, max_new_tokens) {
            Ok(result) => Ok(Uint32Array::new(result)),
            Err(e) => Err(napi::Error::from_reason(e)),
        }
    }

    pub fn inner_generate(
        &mut self,
        prompt_tokens: &[u32],
        max_new_tokens: u32,
    ) -> std::result::Result<Vec<u32>, String> {
        let mut result_tokens = Vec::new();
        for step in 0..(prompt_tokens.len() + max_new_tokens as usize) {
            let pos = self.pos;
            let token = if step < prompt_tokens.len() {
                prompt_tokens[step] as usize
            } else {
                let mut max_val = self.logits[0];
                let mut max_idx = 0usize;
                for (i, &val) in self.logits.iter().enumerate() {
                    if val > max_val {
                        max_val = val;
                        max_idx = i;
                    }
                }
                max_idx
            };

            self.forward_one(token, pos, false)?;
            if step >= prompt_tokens.len() {
                result_tokens.push(token as u32);
            }
            self.pos += 1;
        }
        Ok(result_tokens)
    }

    /// Hint the backend to start fetching layer (L+1) while we run layer L.
    /// No-op for mmap; for HTTP it queues the 9 tensors in the worker pool.
    #[inline]
    fn prefetch_next_layer(&self, current: usize) {
        if current + 1 < self.locs.layers.len() {
            let next = &self.locs.layers[current + 1];
            self.knot.backend.prefetch(&next.names());
        }
    }

    pub fn forward_one(&mut self, token: usize, pos: usize, _do_time: bool) -> Result<(u64, u64, u64, u64)> {
        let config = &self.config;
        let locs = &self.locs;

        // 1. Embedding lookup
        let embed_bytes = self.knot.backend.fetch_tensor(&locs.embed.name)?;
        match locs.embed.qtype {
            QType::F32 => {
                let emb = bytes_to_f32_slice(&embed_bytes);
                let start = token * config.hidden_dim;
                self.x
                    .copy_from_slice(&emb[start..start + config.hidden_dim]);
            }
            QType::Q4K => dequantize_q4k_row(&mut self.x, &embed_bytes, token, config.hidden_dim),
            QType::Q6K => dequantize_q6k_row(&mut self.x, &embed_bytes, token, config.hidden_dim),
        }
        drop(embed_bytes);

        let t0 = Stopwatch::now();
        let mut t_qkv = 0u64;
        let mut t_attn = 0u64;

        for l in 0..self.config.num_layers {
            if self.draft_mode && (l % 2 != 0) {
                continue;
            }

            // Prefetch (L+1) before doing layer L's compute, so the HTTP
            // backend can overlap the next fetch with the current matmul.
            self.prefetch_next_layer(l);

            let lw = &self.locs.layers[l];

            // attn_norm
            let attn_norm_w = self.knot.backend.fetch_tensor(&lw.attn_norm.name)?;
            rms_norm(
                &mut self.xb,
                &self.x,
                bytes_to_f32_slice(&attn_norm_w),
                config.rms_norm_eps,
            );
            drop(attn_norm_w);

            let t_start_qkv = Stopwatch::now();
            let q_w = self.knot.backend.fetch_tensor(&lw.q.name)?;
            mat_vec_run(
                &mut self.q,
                &self.xb,
                &q_w,
                lw.q.qtype,
                config.num_heads * config.head_dim,
                config.hidden_dim,
            );
            drop(q_w);
            let k_w = self.knot.backend.fetch_tensor(&lw.k.name)?;
            mat_vec_run(
                &mut self.k_buf,
                &self.xb,
                &k_w,
                lw.k.qtype,
                config.num_kv_heads * config.head_dim,
                config.hidden_dim,
            );
            drop(k_w);
            let v_w = self.knot.backend.fetch_tensor(&lw.v.name)?;
            mat_vec_run(
                &mut self.v_buf,
                &self.xb,
                &v_w,
                lw.v.qtype,
                config.num_kv_heads * config.head_dim,
                config.hidden_dim,
            );
            drop(v_w);
            t_qkv += t_start_qkv.elapsed_us();

            rope_neox(
                &mut self.q,
                &mut self.k_buf,
                pos,
                config.num_heads,
                config.num_kv_heads,
                config.head_dim,
                config.rope_theta,
            );
            self.kv_cache.save_kv(l, pos, &self.k_buf, &self.v_buf);

            let t_start_attn = Stopwatch::now();
            let num_kv_groups = config.num_heads / config.num_kv_heads;
            let keys = &self.kv_cache.keys;
            let values = &self.kv_cache.values;
            let q = &self.q;
            let head_dim = config.head_dim;
            let max_seq_len = self.kv_cache.max_seq_len;
            let layer_offset = self.kv_cache.get_key_layer_offset(l);

            self.xb
                .par_chunks_mut(head_dim)
                .enumerate()
                .for_each(|(h, head_out)| {
                    let kv_h = h / num_kv_groups;
                    let q_offset = h * head_dim;
                    let kv_head_offset = layer_offset + kv_h * max_seq_len * head_dim;

                    let mut head_att = [0.0f32; 2048];
                    let att_slice = &mut head_att[..=pos];

                    let q_head = &q[q_offset..q_offset + head_dim];
                    let k_head_all = &keys[kv_head_offset..kv_head_offset + (pos + 1) * head_dim];

                    mat_vec_f32(att_slice, q_head, k_head_all, pos + 1, head_dim);

                    for v in att_slice.iter_mut() {
                        *v /= (head_dim as f32).sqrt();
                    }
                    softmax(att_slice);

                    for i in 0..head_dim {
                        head_out[i] = 0.0;
                    }
                    for t in 0..=pos {
                        let v_offset = kv_head_offset + t * head_dim;
                        accumulate_weighted(
                            head_out,
                            &values[v_offset..v_offset + head_dim],
                            att_slice[t],
                        );
                    }
                });

            // Note: above writes into self.xb only for h*head_dim < num_heads*head_dim.
            // For Llama-family num_heads*head_dim == hidden_dim so the whole xb is filled.
            let o_w = self.knot.backend.fetch_tensor(&lw.o.name)?;
            mat_vec_run(
                &mut self.xb2,
                &self.xb,
                &o_w,
                lw.o.qtype,
                config.hidden_dim,
                config.num_heads * config.head_dim,
            );
            drop(o_w);
            t_attn += t_start_attn.elapsed_us();

            for i in 0..config.hidden_dim {
                self.x[i] += self.xb2[i];
            }

            let ffn_norm_w = self.knot.backend.fetch_tensor(&lw.ffn_norm.name)?;
            rms_norm(
                &mut self.xb,
                &self.x,
                bytes_to_f32_slice(&ffn_norm_w),
                config.rms_norm_eps,
            );
            drop(ffn_norm_w);

            let _t_start_ffn = Stopwatch::now();
            let mut skip_ffn = false;

            if self.ffn_cache[l].is_none() {
                self.ffn_cache[l] = Some(FFNCacheEntry {
                    input: vec![0.0; config.hidden_dim],
                    output: vec![0.0; config.hidden_dim],
                    active: false,
                });
            }

            // Resonance shortcut runs first; if we hit, skip the FFN matmuls
            // entirely (and the associated weight fetches).
            let cache_hit = if let Some(entry) = &self.ffn_cache[l] {
                entry.active
                    && cosine_similarity(
                        &self.xb[..256.min(config.hidden_dim)],
                        &entry.input[..256.min(config.hidden_dim)],
                    ) > self.resonance_threshold as f32
            } else {
                false
            };

            if cache_hit {
                if let Some(entry) = &self.ffn_cache[l] {
                    self.xb.copy_from_slice(&entry.output);
                }
                skip_ffn = true;
            }

            if !skip_ffn {
                if let Some(entry) = &mut self.ffn_cache[l] {
                    entry.input.copy_from_slice(&self.xb);
                }
                let gate_w = self.knot.backend.fetch_tensor(&lw.gate.name)?;
                mat_vec_run(
                    &mut self.hb,
                    &self.xb,
                    &gate_w,
                    lw.gate.qtype,
                    config.intermediate_size,
                    config.hidden_dim,
                );
                drop(gate_w);
                let up_w = self.knot.backend.fetch_tensor(&lw.up.name)?;
                mat_vec_run(
                    &mut self.hb2,
                    &self.xb,
                    &up_w,
                    lw.up.qtype,
                    config.intermediate_size,
                    config.hidden_dim,
                );
                drop(up_w);
                swiglu_inplace(&mut self.hb, &self.hb2);
                let down_w = self.knot.backend.fetch_tensor(&lw.down.name)?;
                mat_vec_run(
                    &mut self.xb,
                    &self.hb,
                    &down_w,
                    lw.down.qtype,
                    config.hidden_dim,
                    config.intermediate_size,
                );
                drop(down_w);
                if let Some(entry) = &mut self.ffn_cache[l] {
                    entry.output.copy_from_slice(&self.xb);
                    entry.active = true;
                }
            }
            for (h, f) in self.x.iter_mut().zip(self.xb.iter()) {
                *h += f;
            }
        }

        let final_norm_w = self.knot.backend.fetch_tensor(&locs.final_norm.name)?;
        rms_norm(
            &mut self.xb,
            &self.x,
            bytes_to_f32_slice(&final_norm_w),
            config.rms_norm_eps,
        );
        drop(final_norm_w);
        std::mem::swap(&mut self.x, &mut self.xb);

        let t_start_logits = Stopwatch::now();
        let lm_w = self.knot.backend.fetch_tensor(&locs.lm_head.name)?;
        mat_vec_run(
            &mut self.logits,
            &self.x,
            &lm_w,
            locs.lm_head.qtype,
            config.vocab_size,
            config.hidden_dim,
        );
        drop(lm_w);
        let logit_us = t_start_logits.elapsed_us();

        let total_us = t0.elapsed_us();
        Ok((total_us, t_qkv, t_attn, logit_us))
    }

    pub fn inner_verify(
        &mut self,
        prompt_tokens: Vec<u32>,
        candidates: Vec<u32>,
    ) -> Result<Vec<u32>> {
        let mut accepted = Vec::new();

        if !prompt_tokens.is_empty() {
            self.forward_batch(&prompt_tokens)?;
        }

        if candidates.is_empty() {
            return Ok(accepted);
        }

        for &cand in candidates.iter() {
            let pos = self.pos;
            let mut max_val = self.logits[0];
            let mut max_idx = 0usize;
            for (i, &val) in self.logits.iter().enumerate() {
                if val > max_val {
                    max_val = val;
                    max_idx = i;
                }
            }

            if max_idx as u32 == cand {
                accepted.push(cand);
                self.forward_one(cand as usize, pos, false)?;
                self.pos += 1;
            } else {
                let next_token = max_idx as u32;
                self.forward_one(next_token as usize, pos, false)?;
                self.pos += 1;
                break;
            }
        }
        Ok(accepted)
    }

    pub fn inner_verify_batch(
        &mut self,
        prompt_tokens: Vec<u32>,
        candidates: Vec<u32>,
    ) -> Result<Vec<u32>> {
        if !prompt_tokens.is_empty() {
            self.forward_batch(&prompt_tokens)?;
        }

        if candidates.is_empty() {
            return Ok(Vec::new());
        }

        let pos_original = self.pos;
        let n_batch = candidates.len();
        let vocab_size = self.config.vocab_size;

        let original_logits = self.logits.clone();
        self.forward_batch_truly(&candidates)?;

        let mut accepted_count = 0;

        for i in 0..n_batch {
            let cand = candidates[i];
            let step_logits = if i == 0 {
                &original_logits
            } else {
                &self.batch_logits[(i - 1) * vocab_size..i * vocab_size]
            };

            let mut max_val = step_logits[0];
            let mut max_idx = 0usize;
            for (v_i, &v) in step_logits.iter().enumerate() {
                if v > max_val {
                    max_val = v;
                    max_idx = v_i;
                }
            }

            if cand == max_idx as u32 {
                accepted_count += 1;
            } else {
                break;
            }
        }

        self.pos = pos_original + accepted_count;

        if accepted_count == n_batch {
            self.logits =
                self.batch_logits[(n_batch - 1) * vocab_size..n_batch * vocab_size].to_vec();
        } else {
            self.logits = if accepted_count == 0 {
                original_logits
            } else {
                self.batch_logits[(accepted_count - 1) * vocab_size..accepted_count * vocab_size]
                    .to_vec()
            };
        }

        Ok(candidates[..accepted_count].to_vec())
    }

    fn forward_batch_truly(&mut self, tokens: &[u32]) -> Result<()> {
        let n_batch = tokens.len();
        if n_batch == 0 {
            return Ok(());
        }
        if n_batch > BATCH_CAPACITY {
            panic!(
                "forward_batch_truly: n_batch {} exceeds BATCH_CAPACITY {}",
                n_batch, BATCH_CAPACITY
            );
        }
        let config = &self.config;
        let locs = &self.locs;
        let pos_start = self.pos;
        let qkv_dim = config.num_heads * config.head_dim;
        let kv_dim = config.num_kv_heads * config.head_dim;

        // 1. Embedding lookup for each token.
        let embed_bytes = self.knot.backend.fetch_tensor(&locs.embed.name)?;
        for (i, &token) in tokens.iter().enumerate() {
            let out_slice = &mut self.batch_x[i * config.hidden_dim..(i + 1) * config.hidden_dim];
            match locs.embed.qtype {
                QType::F32 => {
                    let emb = bytes_to_f32_slice(&embed_bytes);
                    let start = token as usize * config.hidden_dim;
                    out_slice.copy_from_slice(&emb[start..start + config.hidden_dim]);
                }
                QType::Q4K => {
                    dequantize_q4k_row(out_slice, &embed_bytes, token as usize, config.hidden_dim)
                }
                QType::Q6K => {
                    dequantize_q6k_row(out_slice, &embed_bytes, token as usize, config.hidden_dim)
                }
            }
        }
        drop(embed_bytes);

        for l in 0..config.num_layers {
            self.prefetch_next_layer(l);
            let lw = &locs.layers[l];

            // 2. attn_norm per batch token (writes into batch_xb slot i).
            let attn_norm_w = self.knot.backend.fetch_tensor(&lw.attn_norm.name)?;
            for i in 0..n_batch {
                let x_i = &self.batch_x[i * config.hidden_dim..(i + 1) * config.hidden_dim];
                let xb_i = &mut self.batch_xb[i * config.hidden_dim..(i + 1) * config.hidden_dim];
                rms_norm(
                    xb_i,
                    x_i,
                    bytes_to_f32_slice(&attn_norm_w),
                    config.rms_norm_eps,
                );
            }
            drop(attn_norm_w);

            // 3. Q/K/V matmuls (batched). Buffers are sized to qkv_dim/kv_dim
            //    not hidden_dim, so out_stride matches rows and there is no
            //    "garbage gap" between adjacent batch slots.
            let q_w = self.knot.backend.fetch_tensor(&lw.q.name)?;
            mat_vec_dispatch_batch(
                &mut self.batch_q,
                &self.batch_xb,
                &q_w,
                lw.q.qtype,
                qkv_dim,
                config.hidden_dim,
                n_batch,
                qkv_dim,
            );
            drop(q_w);
            let k_w = self.knot.backend.fetch_tensor(&lw.k.name)?;
            mat_vec_dispatch_batch(
                &mut self.batch_k,
                &self.batch_xb,
                &k_w,
                lw.k.qtype,
                kv_dim,
                config.hidden_dim,
                n_batch,
                kv_dim,
            );
            drop(k_w);
            let v_w = self.knot.backend.fetch_tensor(&lw.v.name)?;
            mat_vec_dispatch_batch(
                &mut self.batch_v,
                &self.batch_xb,
                &v_w,
                lw.v.qtype,
                kv_dim,
                config.hidden_dim,
                n_batch,
                kv_dim,
            );
            drop(v_w);

            // 4. Per-token: rope + save_kv + attention. Tokens are processed
            //    sequentially so that the KV cache for token i is visible to
            //    token i+1's attention.
            for i in 0..n_batch {
                let pos = pos_start + i;
                {
                    let q_i = &mut self.batch_q[i * qkv_dim..(i + 1) * qkv_dim];
                    let k_i = &mut self.batch_k[i * kv_dim..(i + 1) * kv_dim];
                    rope_neox(
                        q_i,
                        k_i,
                        pos,
                        config.num_heads,
                        config.num_kv_heads,
                        config.head_dim,
                        config.rope_theta,
                    );
                }
                let k_slice = &self.batch_k[i * kv_dim..(i + 1) * kv_dim];
                let v_slice = &self.batch_v[i * kv_dim..(i + 1) * kv_dim];
                self.k_buf.copy_from_slice(k_slice);
                self.v_buf.copy_from_slice(v_slice);
                self.kv_cache.save_kv(l, pos, &self.k_buf, &self.v_buf);

                let head_dim = config.head_dim;
                let hidden_dim = config.hidden_dim;
                let num_kv_groups = config.num_heads / config.num_kv_heads;
                let layer_offset = self.kv_cache.get_key_layer_offset(l);
                let max_seq_len = self.kv_cache.max_seq_len;

                let i_offset_xb = i * hidden_dim;
                let i_offset_q = i * qkv_dim;

                // Aliasing: q_batch reads from the same buffer that q_i wrote
                // (rope is now finished, q_i borrow has ended at end of inner
                // block above, so aliasing rules are satisfied via NLL).
                let (keys, values, q_batch) = unsafe {
                    (
                        std::slice::from_raw_parts(
                            self.kv_cache.keys.as_ptr(),
                            self.kv_cache.keys.len(),
                        ),
                        std::slice::from_raw_parts(
                            self.kv_cache.values.as_ptr(),
                            self.kv_cache.values.len(),
                        ),
                        std::slice::from_raw_parts(self.batch_q.as_ptr(), self.batch_q.len()),
                    )
                };

                let xb_i_slice = &mut self.batch_xb[i_offset_xb..i_offset_xb + hidden_dim];
                xb_i_slice
                    .chunks_mut(head_dim)
                    .enumerate()
                    .for_each(|(h, head_out)| {
                        let kv_h = h / num_kv_groups;
                        let q_offset = h * head_dim;
                        let kv_head_offset = layer_offset + kv_h * max_seq_len * head_dim;

                        let mut head_att = [0.0f32; 2048];
                        let att_slice = &mut head_att[..=pos];

                        let q_head =
                            &q_batch[i_offset_q + q_offset..i_offset_q + q_offset + head_dim];
                        let k_head_all =
                            &keys[kv_head_offset..kv_head_offset + (pos + 1) * head_dim];

                        mat_vec_f32(att_slice, q_head, k_head_all, pos + 1, head_dim);
                        for v in att_slice.iter_mut() {
                            *v /= (head_dim as f32).sqrt();
                        }
                        softmax(att_slice);

                        for j in 0..head_dim {
                            head_out[j] = 0.0;
                        }
                        for t in 0..=pos {
                            let v_offset = kv_head_offset + t * head_dim;
                            let v_slice = &values[v_offset..v_offset + head_dim];
                            accumulate_weighted(head_out, v_slice, att_slice[t]);
                        }
                    });
            }

            // 5. O matmul (batched).
            let o_w = self.knot.backend.fetch_tensor(&lw.o.name)?;
            mat_vec_dispatch_batch(
                &mut self.batch_xb2,
                &self.batch_xb,
                &o_w,
                lw.o.qtype,
                config.hidden_dim,
                qkv_dim,
                n_batch,
                config.hidden_dim,
            );
            drop(o_w);

            // 6. Residual add + ffn pre-norm (per-batch).
            let ffn_norm_w = self.knot.backend.fetch_tensor(&lw.ffn_norm.name)?;
            for i in 0..n_batch {
                let x_i = &mut self.batch_x[i * config.hidden_dim..(i + 1) * config.hidden_dim];
                let xb2_i = &self.batch_xb2[i * config.hidden_dim..(i + 1) * config.hidden_dim];
                for j in 0..config.hidden_dim {
                    x_i[j] += xb2_i[j];
                }

                let xb_i = &mut self.batch_xb[i * config.hidden_dim..(i + 1) * config.hidden_dim];
                rms_norm(
                    xb_i,
                    x_i,
                    bytes_to_f32_slice(&ffn_norm_w),
                    config.rms_norm_eps,
                );
            }
            drop(ffn_norm_w);

            // 7. FFN gate / up / swiglu / down (batched).
            let gate_w = self.knot.backend.fetch_tensor(&lw.gate.name)?;
            mat_vec_dispatch_batch(
                &mut self.batch_hb,
                &self.batch_xb,
                &gate_w,
                lw.gate.qtype,
                config.intermediate_size,
                config.hidden_dim,
                n_batch,
                config.intermediate_size,
            );
            drop(gate_w);
            let up_w = self.knot.backend.fetch_tensor(&lw.up.name)?;
            mat_vec_dispatch_batch(
                &mut self.batch_hb2,
                &self.batch_xb,
                &up_w,
                lw.up.qtype,
                config.intermediate_size,
                config.hidden_dim,
                n_batch,
                config.intermediate_size,
            );
            drop(up_w);

            for i in 0..n_batch {
                let hb_i = &mut self.batch_hb
                    [i * config.intermediate_size..(i + 1) * config.intermediate_size];
                let hb2_i = &self.batch_hb2
                    [i * config.intermediate_size..(i + 1) * config.intermediate_size];
                swiglu_inplace(hb_i, hb2_i);
            }

            let down_w = self.knot.backend.fetch_tensor(&lw.down.name)?;
            mat_vec_dispatch_batch(
                &mut self.batch_xb,
                &self.batch_hb,
                &down_w,
                lw.down.qtype,
                config.hidden_dim,
                config.intermediate_size,
                n_batch,
                config.hidden_dim,
            );
            drop(down_w);

            // 8. Final residual add.
            for i in 0..n_batch {
                let x_i = &mut self.batch_x[i * config.hidden_dim..(i + 1) * config.hidden_dim];
                let xb_i = &self.batch_xb[i * config.hidden_dim..(i + 1) * config.hidden_dim];
                for j in 0..config.hidden_dim {
                    x_i[j] += xb_i[j];
                }
            }
        }

        // Final norm + lm_head per batch.
        let final_norm_w = self.knot.backend.fetch_tensor(&locs.final_norm.name)?;
        for i in 0..n_batch {
            let x_i = &self.batch_x[i * config.hidden_dim..(i + 1) * config.hidden_dim];
            let xb_i = &mut self.batch_xb[i * config.hidden_dim..(i + 1) * config.hidden_dim];
            rms_norm(
                xb_i,
                x_i,
                bytes_to_f32_slice(&final_norm_w),
                config.rms_norm_eps,
            );
        }
        drop(final_norm_w);

        let lm_w = self.knot.backend.fetch_tensor(&locs.lm_head.name)?;
        mat_vec_dispatch_batch(
            &mut self.batch_logits,
            &self.batch_xb,
            &lm_w,
            locs.lm_head.qtype,
            config.vocab_size,
            config.hidden_dim,
            n_batch,
            config.vocab_size,
        );
        drop(lm_w);

        // Update self.logits to match the LAST batch slot for compatibility
        // with single-token callers that read self.logits afterwards.
        let last_logits =
            &self.batch_logits[(n_batch - 1) * config.vocab_size..n_batch * config.vocab_size];
        self.logits.copy_from_slice(last_logits);
        self.pos += n_batch;
        Ok(())
    }

    fn forward_batch(&mut self, tokens: &[u32]) -> Result<()> {
        self.forward_batch_truly(tokens)
    }

    // ── Log-rolling primitives (Wallington Rotation, ch10/ch12) ─────────
    //
    // These split the existing monolithic `forward_one` / `forward_batch_truly`
    // into three station-callable steps so a chain of CF Workers (each pinned
    // to a contiguous layer range) can implement pipelined prefill:
    //
    //   embed_chunk   → entry station: token IDs → initial residual stream
    //   forward_range → middle/all stations: residual + KV update over [a,b)
    //   lm_head_only  → exit station: final norm + lm_head → next-token logits
    //
    // Causal masking (intra-chunk) is applied for `seq_len > 1`; the per-token
    // path matches `forward_one` exactly when the FFN resonance cache is
    // inactive (resonance_threshold ≥ 1.0 disables it). The batched path
    // mirrors `forward_batch_truly` over a layer subrange instead of 0..L.
    //
    // None of these primitives mutates `self.pos` — the caller (the host shim)
    // is the sole owner of the position counter for log-rolling sessions.

    /// Embedding-only forward. Looks up `seq_len` rows of the token-embedding
    /// table and concatenates them into a flat `[seq_len * hidden_dim]` Vec.
    /// `_start_pos` is accepted for API symmetry with the chunk descriptors
    /// the coordinator builds (`{ startPos, count }`); the embedding lookup
    /// itself doesn't depend on position (RoPE is applied later, inside the
    /// attention layer).
    pub fn embed_chunk(&mut self, tokens: &[u32], _start_pos: usize) -> Result<Vec<f32>> {
        let config = &self.config;
        let locs = &self.locs;
        let mut out = vec![0.0f32; tokens.len() * config.hidden_dim];

        let embed_bytes = self.knot.backend.fetch_tensor(&locs.embed.name)?;
        for (i, &token) in tokens.iter().enumerate() {
            let dst = &mut out[i * config.hidden_dim..(i + 1) * config.hidden_dim];
            match locs.embed.qtype {
                QType::F32 => {
                    let emb = bytes_to_f32_slice(&embed_bytes);
                    let start = token as usize * config.hidden_dim;
                    dst.copy_from_slice(&emb[start..start + config.hidden_dim]);
                }
                QType::Q4K => {
                    dequantize_q4k_row(dst, &embed_bytes, token as usize, config.hidden_dim)
                }
                QType::Q6K => {
                    dequantize_q6k_row(dst, &embed_bytes, token as usize, config.hidden_dim)
                }
            }
        }
        drop(embed_bytes);
        Ok(out)
    }

    /// Vocabulary-sharded embedding lookup for TQFT cobordism workers.
    ///
    /// Identical to `embed_chunk` except it only dequantizes rows for tokens
    /// whose IDs fall within `[vocab_start, vocab_end)`. Tokens outside that
    /// range produce zero vectors. This allows sharding the embedding table
    /// across N cobordism workers, each pinning a disjoint vocabulary range,
    /// so that no single Worker isolate needs to hold the full table.
    ///
    /// The Frobenius merge (μ: A ⊗ A → A) at the coordinator is elementwise
    /// addition of the partial embeddings. Because token ranges are disjoint,
    /// exactly one shard contributes a non-zero vector per token, making the
    /// merge equivalent to identity.
    ///
    /// See: FORMAL_LEDGER.md § Atiyah-Segal TQFT Functor
    pub fn embed_chunk_range(
        &mut self,
        tokens: &[u32],
        _start_pos: usize,
        vocab_start: usize,
        vocab_end: usize,
    ) -> Result<Vec<f32>> {
        let config = &self.config;
        let locs = &self.locs;
        let mut out = vec![0.0f32; tokens.len() * config.hidden_dim];

        let embed_bytes = self.knot.backend.fetch_tensor(&locs.embed.name)?;
        for (i, &token) in tokens.iter().enumerate() {
            let tid = token as usize;
            if tid < vocab_start || tid >= vocab_end {
                // Out of range for this shard — leave as zero vector.
                continue;
            }
            let dst = &mut out[i * config.hidden_dim..(i + 1) * config.hidden_dim];
            match locs.embed.qtype {
                QType::F32 => {
                    let emb = bytes_to_f32_slice(&embed_bytes);
                    let start = tid * config.hidden_dim;
                    dst.copy_from_slice(&emb[start..start + config.hidden_dim]);
                }
                QType::Q4K => dequantize_q4k_row(dst, &embed_bytes, tid, config.hidden_dim),
                QType::Q6K => dequantize_q6k_row(dst, &embed_bytes, tid, config.hidden_dim),
            }
        }
        drop(embed_bytes);
        Ok(out)
    }

    /// Vocabulary-sharded lm_head for TQFT cobordism workers.
    ///
    /// Computes logits only for vocabulary indices `[vocab_start, vocab_end)`,
    /// returning a vector of length `(vocab_end - vocab_start)` per token in
    /// the sequence. The coordinator concatenates partial logits from all
    /// cobordism shards to reconstruct the full `[vocab_size]` logits vector.
    ///
    /// This is the comultiplication (Δ: A → A ⊗ A) dual of `embed_chunk_range`.
    ///
    /// See: FORMAL_LEDGER.md § Atiyah-Segal TQFT Functor
    pub fn lm_head_range(
        &mut self,
        input: &[f32],
        seq_len: usize,
        vocab_start: usize,
        vocab_end: usize,
    ) -> Result<Vec<f32>> {
        let config = &self.config;
        let locs = &self.locs;
        let hidden_dim = config.hidden_dim;
        let shard_vocab = vocab_end - vocab_start;

        assert_eq!(
            input.len(),
            seq_len * hidden_dim,
            "lm_head_range: input shape {} != seq_len*hidden_dim {}",
            input.len(),
            seq_len * hidden_dim
        );
        assert!(
            seq_len > 0 && seq_len <= BATCH_CAPACITY,
            "seq_len {} out of range (0, {}]",
            seq_len,
            BATCH_CAPACITY
        );
        assert!(
            vocab_end > vocab_start && vocab_end <= config.vocab_size,
            "vocab range [{}, {}) out of bounds for vocab_size {}",
            vocab_start,
            vocab_end,
            config.vocab_size
        );

        // Stage incoming residual into batch_x for the final-norm pass.
        self.batch_x[..seq_len * hidden_dim].copy_from_slice(input);

        let final_norm_w = self.knot.backend.fetch_tensor(&locs.final_norm.name).unwrap();
        for i in 0..seq_len {
            let x_i = &self.batch_x[i * hidden_dim..(i + 1) * hidden_dim];
            let xb_i = &mut self.batch_xb[i * hidden_dim..(i + 1) * hidden_dim];
            rms_norm(
                xb_i,
                x_i,
                bytes_to_f32_slice(&final_norm_w),
                config.rms_norm_eps,
            );
        }
        drop(final_norm_w);

        // Compute matmul only over the vocabulary sub-range.
        //
        // The previous shape passed the FULL `lm_w` and used
        // `out_stride=config.vocab_size`, which made `mat_vec_dispatch_batch`
        // compute logits for ROWS 0..shard_vocab — i.e., always the first
        // `shard_vocab` vocab ids regardless of `vocab_start`. The
        // coordinator then placed those wrong logits at the right offsets
        // (logits[18992..37984] held logits-for-ids-0..18992 from shard 1,
        // etc.), producing scrambled logits and gibberish tokens.
        //
        // Correct behavior: slice `lm_w` to ONLY rows [vocab_start, vocab_end)
        // and have the matmul write `shard_vocab` rows contiguously into
        // `partial_logits` (out_stride = shard_vocab, matching the pre-sliced
        // `lm_head_partial` flow).
        let lm_w = self.knot.backend.fetch_tensor(&locs.lm_head.name)?;
        let bytes_per_row = match locs.lm_head.qtype {
            QType::F32 => hidden_dim * 4,
            QType::Q4K => (hidden_dim / 256) * 144,
            QType::Q6K => (hidden_dim / 256) * 210,
        };
        let row_start = vocab_start * bytes_per_row;
        let row_end = vocab_end * bytes_per_row;
        assert!(
            row_end <= lm_w.len(),
            "lm_head_range: weight slice [{}, {}) exceeds tensor len {}",
            row_start,
            row_end,
            lm_w.len()
        );
        let lm_w_slice = &lm_w[row_start..row_end];

        let mut partial_logits = vec![0.0f32; seq_len * shard_vocab];
        mat_vec_dispatch_batch(
            &mut partial_logits,
            &self.batch_xb,
            lm_w_slice,
            locs.lm_head.qtype,
            shard_vocab,
            hidden_dim,
            seq_len,
            shard_vocab, // contiguous output stride for the sliced weight
        );
        drop(lm_w);

        // Return partial logits for the LAST token in the chunk.
        let last = (seq_len - 1) * shard_vocab;
        let mut out = vec![0.0f32; shard_vocab];
        out.copy_from_slice(&partial_logits[last..last + shard_vocab]);
        Ok(out)
    }

    /// Vocabulary-sharded lm_head — fluid-memory variant.
    ///
    /// Unlike `lm_head_range` (which expects the FULL `output_weight`
    /// loaded into the backend cache and is therefore unusable on the
    /// 128 MiB CF Worker tier), this method expects ONLY the slice of
    /// `output_weight` rows for `[vocab_start, vocab_end)` to be
    /// pre-loaded under the synthetic name `lm_head_partial_weight`.
    ///
    /// The host-side flow:
    ///   1. Compute the slice byte range: `output_weight.offset +
    ///      vocab_start * bytes_per_row`, length =
    ///      `(vocab_end - vocab_start) * bytes_per_row`.
    ///   2. R2 Range fetch + `set_tensor("lm_head_partial_weight", ...)`.
    ///   3. Call `lm_head_partial(residual, seq_len, vocab_start, vocab_end)`.
    ///   4. `evict(["lm_head_partial_weight"])`.
    ///
    /// Returns partial logits for the LAST token in the chunk
    /// (a `(vocab_end - vocab_start)`-length vector). The coordinator
    /// concatenates partials from all 8 shards to reconstruct the full
    /// vocab-size logits row.
    ///
    /// `output_norm_weight` is required to be already resident.
    pub fn lm_head_partial(
        &mut self,
        input: &[f32],
        seq_len: usize,
        vocab_start: usize,
        vocab_end: usize,
    ) -> Result<Vec<f32>> {
        let config = &self.config;
        let locs = &self.locs;
        let hidden_dim = config.hidden_dim;
        let shard_vocab = vocab_end - vocab_start;

        assert_eq!(
            input.len(),
            seq_len * hidden_dim,
            "lm_head_partial: input shape {} != seq_len*hidden_dim {}",
            input.len(),
            seq_len * hidden_dim
        );
        assert!(
            seq_len > 0 && seq_len <= BATCH_CAPACITY,
            "seq_len {} out of range (0, {}]",
            seq_len,
            BATCH_CAPACITY
        );
        assert!(
            vocab_end > vocab_start && vocab_end <= config.vocab_size,
            "vocab range [{}, {}) out of bounds for vocab_size {}",
            vocab_start,
            vocab_end,
            config.vocab_size
        );

        // Stage residual + apply final RMS norm.
        self.batch_x[..seq_len * hidden_dim].copy_from_slice(input);
        let final_norm_w = self.knot.backend.fetch_tensor(&locs.final_norm.name).unwrap();
        for i in 0..seq_len {
            let x_i = &self.batch_x[i * hidden_dim..(i + 1) * hidden_dim];
            let xb_i = &mut self.batch_xb[i * hidden_dim..(i + 1) * hidden_dim];
            rms_norm(
                xb_i,
                x_i,
                bytes_to_f32_slice(&final_norm_w),
                config.rms_norm_eps,
            );
        }
        drop(final_norm_w);

        // Matmul against the slice. Output stride = shard_vocab, so writes
        // are contiguous and `partial_logits` is sized exactly right
        // (no holes; works correctly for seq_len > 1).
        let lm_w_slice = self.knot.backend.fetch_tensor("lm_head_partial_weight")?;
        let mut partial_logits = vec![0.0f32; seq_len * shard_vocab];
        mat_vec_dispatch_batch(
            &mut partial_logits,
            &self.batch_xb,
            &lm_w_slice,
            locs.lm_head.qtype,
            shard_vocab,
            hidden_dim,
            seq_len,
            shard_vocab,
        );
        drop(lm_w_slice);

        // Return partial logits for the LAST token only — the only one
        // that contributes to the next-token prediction.
        let last = (seq_len - 1) * shard_vocab;
        Ok(partial_logits[last..last + shard_vocab].to_vec())
    }

    /// Run the transformer body over layers `[start_layer, end_layer)` for
    /// a chunk of `seq_len` tokens whose first token is at absolute position
    /// `start_pos`. The KV cache is updated at positions
    /// `start_pos..start_pos + seq_len` for each layer in the range.
    ///
    /// For `seq_len == 1` this matches one iteration of `forward_one`'s layer
    /// loop (no FFN resonance shortcut — log-rolling stations don't share the
    /// per-layer FFN cache state across chunks).
    ///
    /// For `seq_len > 1` this matches `forward_batch_truly`'s per-layer body.
    /// Causal masking falls out of the per-token attention loop attending over
    /// `0..=pos` for each token in the chunk.
    pub fn forward_range_chunk(
        &mut self,
        input: &[f32],
        start_layer: usize,
        end_layer: usize,
        start_pos: usize,
        seq_len: usize,
    ) -> Result<Vec<f32>> {
        let config = &self.config;
        let locs = &self.locs;
        let hidden_dim = config.hidden_dim;
        let qkv_dim = config.num_heads * config.head_dim;
        let kv_dim = config.num_kv_heads * config.head_dim;

        assert_eq!(
            input.len(),
            seq_len * hidden_dim,
            "forward_range_chunk: input shape {} != seq_len*hidden_dim {}",
            input.len(),
            seq_len * hidden_dim
        );
        assert!(start_layer <= end_layer, "start_layer > end_layer");
        assert!(
            end_layer <= config.num_layers,
            "end_layer beyond num_layers"
        );
        assert!(
            seq_len > 0 && seq_len <= BATCH_CAPACITY,
            "seq_len {} out of range (0, {}]",
            seq_len,
            BATCH_CAPACITY
        );

        // Stage the incoming residual into batch_x (single canonical buffer
        // shared with `forward_batch_truly`). Do this even for seq_len==1 so
        // both paths converge on the same code below.
        self.batch_x[..seq_len * hidden_dim].copy_from_slice(input);

        for l in start_layer..end_layer {
            self.prefetch_next_layer(l);
            let lw = &locs.layers[l];

            // attn_norm per token
            let attn_norm_w = self.knot.backend.fetch_tensor(&lw.attn_norm.name)?;
            for i in 0..seq_len {
                let x_i = &self.batch_x[i * hidden_dim..(i + 1) * hidden_dim];
                let xb_i = &mut self.batch_xb[i * hidden_dim..(i + 1) * hidden_dim];
                rms_norm(
                    xb_i,
                    x_i,
                    bytes_to_f32_slice(&attn_norm_w),
                    config.rms_norm_eps,
                );
            }
            drop(attn_norm_w);

            // Q / K / V matmuls (batched)
            let q_w = self.knot.backend.fetch_tensor(&lw.q.name)?;
            mat_vec_dispatch_batch(
                &mut self.batch_q,
                &self.batch_xb,
                &q_w,
                lw.q.qtype,
                qkv_dim,
                hidden_dim,
                seq_len,
                qkv_dim,
            );
            drop(q_w);
            let k_w = self.knot.backend.fetch_tensor(&lw.k.name)?;
            mat_vec_dispatch_batch(
                &mut self.batch_k,
                &self.batch_xb,
                &k_w,
                lw.k.qtype,
                kv_dim,
                hidden_dim,
                seq_len,
                kv_dim,
            );
            drop(k_w);
            let v_w = self.knot.backend.fetch_tensor(&lw.v.name)?;
            mat_vec_dispatch_batch(
                &mut self.batch_v,
                &self.batch_xb,
                &v_w,
                lw.v.qtype,
                kv_dim,
                hidden_dim,
                seq_len,
                kv_dim,
            );
            drop(v_w);

            // Qwen2 / Qwen2.5: add Q/K/V projection biases. Per-token broadcast
            // of the same bias vector across the batch. LLaMA-family knots omit
            // these tensors (q_bias/k_bias/v_bias = None) and the kernel skips
            // the add unchanged. MUST happen before RoPE — qwen's biases are
            // applied to pre-rotated Q/K. Mirrors the exact shape used by the
            // chunked-split sibling `forward_range_attn_chunk` so both entries
            // produce identical residuals.
            if let Some(qb) = lw.q_bias.as_ref() {
                let qb_bytes = self.knot.backend.fetch_tensor(&qb.name)?;
                let qb_f = bytes_to_f32_slice(&qb_bytes);
                debug_assert_eq!(qb_f.len(), qkv_dim, "q_bias size mismatch: have {} need {}", qb_f.len(), qkv_dim);
                for i in 0..seq_len {
                    let q_i = &mut self.batch_q[i * qkv_dim..(i + 1) * qkv_dim];
                    for j in 0..qkv_dim {
                        q_i[j] += qb_f[j];
                    }
                }
                drop(qb_bytes);
            }
            if let Some(kb) = lw.k_bias.as_ref() {
                let kb_bytes = self.knot.backend.fetch_tensor(&kb.name)?;
                let kb_f = bytes_to_f32_slice(&kb_bytes);
                debug_assert_eq!(kb_f.len(), kv_dim, "k_bias size mismatch: have {} need {}", kb_f.len(), kv_dim);
                for i in 0..seq_len {
                    let k_i = &mut self.batch_k[i * kv_dim..(i + 1) * kv_dim];
                    for j in 0..kv_dim {
                        k_i[j] += kb_f[j];
                    }
                }
                drop(kb_bytes);
            }
            if let Some(vb) = lw.v_bias.as_ref() {
                let vb_bytes = self.knot.backend.fetch_tensor(&vb.name)?;
                let vb_f = bytes_to_f32_slice(&vb_bytes);
                debug_assert_eq!(vb_f.len(), kv_dim, "v_bias size mismatch: have {} need {}", vb_f.len(), kv_dim);
                for i in 0..seq_len {
                    let v_i = &mut self.batch_v[i * kv_dim..(i + 1) * kv_dim];
                    for j in 0..kv_dim {
                        v_i[j] += vb_f[j];
                    }
                }
                drop(vb_bytes);
            }

            // Per-token: rope + save_kv + causal attention. Tokens are walked
            // in order so token i+1 can attend to token i's freshly-saved KV
            // (this IS the intra-chunk causal rotation).
            for i in 0..seq_len {
                let pos = start_pos + i;
                {
                    let q_i = &mut self.batch_q[i * qkv_dim..(i + 1) * qkv_dim];
                    let k_i = &mut self.batch_k[i * kv_dim..(i + 1) * kv_dim];
                    rope_neox(
                        q_i,
                        k_i,
                        pos,
                        config.num_heads,
                        config.num_kv_heads,
                        config.head_dim,
                        config.rope_theta,
                    );
                }
                let k_slice = &self.batch_k[i * kv_dim..(i + 1) * kv_dim];
                let v_slice = &self.batch_v[i * kv_dim..(i + 1) * kv_dim];
                self.k_buf.copy_from_slice(k_slice);
                self.v_buf.copy_from_slice(v_slice);
                self.kv_cache.save_kv(l, pos, &self.k_buf, &self.v_buf);

                let head_dim = config.head_dim;
                let num_kv_groups = config.num_heads / config.num_kv_heads;
                let layer_offset = self.kv_cache.get_key_layer_offset(l);
                let max_seq_len = self.kv_cache.max_seq_len;

                let i_offset_xb = i * hidden_dim;
                let i_offset_q = i * qkv_dim;

                let (keys, values, q_batch) = unsafe {
                    (
                        std::slice::from_raw_parts(
                            self.kv_cache.keys.as_ptr(),
                            self.kv_cache.keys.len(),
                        ),
                        std::slice::from_raw_parts(
                            self.kv_cache.values.as_ptr(),
                            self.kv_cache.values.len(),
                        ),
                        std::slice::from_raw_parts(self.batch_q.as_ptr(), self.batch_q.len()),
                    )
                };

                let xb_i_slice = &mut self.batch_xb[i_offset_xb..i_offset_xb + hidden_dim];
                xb_i_slice
                    .chunks_mut(head_dim)
                    .enumerate()
                    .for_each(|(h, head_out)| {
                        let kv_h = h / num_kv_groups;
                        let q_offset = h * head_dim;
                        let kv_head_offset = layer_offset + kv_h * max_seq_len * head_dim;

                        let mut head_att = [0.0f32; 2048];
                        let att_slice = &mut head_att[..=pos];

                        let q_head =
                            &q_batch[i_offset_q + q_offset..i_offset_q + q_offset + head_dim];
                        let k_head_all =
                            &keys[kv_head_offset..kv_head_offset + (pos + 1) * head_dim];

                        mat_vec_f32(att_slice, q_head, k_head_all, pos + 1, head_dim);
                        for v in att_slice.iter_mut() {
                            *v /= (head_dim as f32).sqrt();
                        }
                        softmax(att_slice);

                        for j in 0..head_dim {
                            head_out[j] = 0.0;
                        }
                        for t in 0..=pos {
                            let v_offset = kv_head_offset + t * head_dim;
                            let v_slice_t = &values[v_offset..v_offset + head_dim];
                            accumulate_weighted(head_out, v_slice_t, att_slice[t]);
                        }
                    });
            }

            // O matmul (batched)
            let o_w = self.knot.backend.fetch_tensor(&lw.o.name).unwrap();
            mat_vec_dispatch_batch(
                &mut self.batch_xb2,
                &self.batch_xb,
                &o_w,
                lw.o.qtype,
                hidden_dim,
                qkv_dim,
                seq_len,
                hidden_dim,
            );
            drop(o_w);

            // Residual add + ffn pre-norm (per-batch)
            let ffn_norm_w = self.knot.backend.fetch_tensor(&lw.ffn_norm.name)?;
            for i in 0..seq_len {
                let x_i = &mut self.batch_x[i * hidden_dim..(i + 1) * hidden_dim];
                let xb2_i = &self.batch_xb2[i * hidden_dim..(i + 1) * hidden_dim];
                for j in 0..hidden_dim {
                    x_i[j] += xb2_i[j];
                }

                let xb_i = &mut self.batch_xb[i * hidden_dim..(i + 1) * hidden_dim];
                rms_norm(
                    xb_i,
                    x_i,
                    bytes_to_f32_slice(&ffn_norm_w),
                    config.rms_norm_eps,
                );
            }
            drop(ffn_norm_w);

            // FFN gate / up / swiglu / down (batched)
            let gate_w = self.knot.backend.fetch_tensor(&lw.gate.name).unwrap();
            mat_vec_dispatch_batch(
                &mut self.batch_hb,
                &self.batch_xb,
                &gate_w,
                lw.gate.qtype,
                config.intermediate_size,
                hidden_dim,
                seq_len,
                config.intermediate_size,
            );
            drop(gate_w);
            let up_w = self.knot.backend.fetch_tensor(&lw.up.name)?;
            mat_vec_dispatch_batch(
                &mut self.batch_hb2,
                &self.batch_xb,
                &up_w,
                lw.up.qtype,
                config.intermediate_size,
                hidden_dim,
                seq_len,
                config.intermediate_size,
            );
            drop(up_w);

            for i in 0..seq_len {
                let hb_i = &mut self.batch_hb
                    [i * config.intermediate_size..(i + 1) * config.intermediate_size];
                let hb2_i = &self.batch_hb2
                    [i * config.intermediate_size..(i + 1) * config.intermediate_size];
                swiglu_inplace(hb_i, hb2_i);
            }

            let down_w = self.knot.backend.fetch_tensor(&lw.down.name)?;
            mat_vec_dispatch_batch(
                &mut self.batch_xb,
                &self.batch_hb,
                &down_w,
                lw.down.qtype,
                hidden_dim,
                config.intermediate_size,
                seq_len,
                hidden_dim,
            );
            drop(down_w);

            // Final residual add (per-batch)
            for i in 0..seq_len {
                let x_i = &mut self.batch_x[i * hidden_dim..(i + 1) * hidden_dim];
                let xb_i = &self.batch_xb[i * hidden_dim..(i + 1) * hidden_dim];
                for j in 0..hidden_dim {
                    x_i[j] += xb_i[j];
                }
            }
        }

        // Copy out the resulting residual stream (seq_len * hidden_dim).
        let mut out = vec![0.0f32; seq_len * hidden_dim];
        out.copy_from_slice(&self.batch_x[..seq_len * hidden_dim]);
        Ok(out)
    }

    /// Split phase 1: Attention (computes attn_norm, q, k, v, rope, kv cache, o)
    /// Expects `input` on the first layer, or reads from internal `batch_x`.
    pub fn forward_range_attn_chunk(
        &mut self,
        input: &[f32],
        layer: usize,
        start_pos: usize,
        seq_len: usize,
        is_first_layer: bool,
    ) -> Result<()> {
        let config = &self.config;
        let locs = &self.locs;
        let hidden_dim = config.hidden_dim;
        let qkv_dim = config.num_heads * config.head_dim;
        let kv_dim = config.num_kv_heads * config.head_dim;

        if is_first_layer {
            self.batch_x[..seq_len * hidden_dim].copy_from_slice(input);
        }

        let l = layer;
        let lw = &locs.layers[l];

        // attn_norm per token
        let attn_norm_w = self.knot.backend.fetch_tensor(&lw.attn_norm.name)?;
        for i in 0..seq_len {
            let x_i = &self.batch_x[i * hidden_dim..(i + 1) * hidden_dim];
            let xb_i = &mut self.batch_xb[i * hidden_dim..(i + 1) * hidden_dim];
            rms_norm(
                xb_i,
                x_i,
                bytes_to_f32_slice(&attn_norm_w),
                config.rms_norm_eps,
            );
        }
        drop(attn_norm_w);

        // Q / K / V matmuls (batched)
        let q_w = self.knot.backend.fetch_tensor(&lw.q.name)?;
        matvec_memo::cached_mat_vec(
            &mut self.memo,
            &mut self.batch_q,
            &self.batch_xb,
            &q_w,
            lw.q.qtype,
            qkv_dim,
            hidden_dim,
            seq_len,
            qkv_dim,
            layer,
            matvec_memo::OP_Q,
            mat_vec_dispatch_batch,
        );
        drop(q_w);
        let k_w = self.knot.backend.fetch_tensor(&lw.k.name)?;
        matvec_memo::cached_mat_vec(
            &mut self.memo,
            &mut self.batch_k,
            &self.batch_xb,
            &k_w,
            lw.k.qtype,
            kv_dim,
            hidden_dim,
            seq_len,
            kv_dim,
            layer,
            matvec_memo::OP_K,
            mat_vec_dispatch_batch,
        );
        drop(k_w);
        let v_w = self.knot.backend.fetch_tensor(&lw.v.name)?;
        matvec_memo::cached_mat_vec(
            &mut self.memo,
            &mut self.batch_v,
            &self.batch_xb,
            &v_w,
            lw.v.qtype,
            kv_dim,
            hidden_dim,
            seq_len,
            kv_dim,
            layer,
            matvec_memo::OP_V,
            mat_vec_dispatch_batch,
        );
        drop(v_w);

        // Qwen2 / Qwen2.5: add Q/K/V projection biases. Per-token broadcast
        // of the same bias vector across the batch. LLaMA-family knots omit
        // these tensors (q_bias/k_bias/v_bias = None) and the kernel skips
        // the add unchanged.
        if let Some(qb) = lw.q_bias.as_ref() {
            let qb_bytes = self.knot.backend.fetch_tensor(&qb.name)?;
            let qb_f = bytes_to_f32_slice(&qb_bytes);
            debug_assert_eq!(qb_f.len(), qkv_dim, "q_bias size mismatch: have {} need {}", qb_f.len(), qkv_dim);
            if std::env::var("KERNEL_DEBUG").is_ok() && layer == 0 {
                eprintln!("[KERNEL] L0 q_bias len={} first8=[{:.3} {:.3} {:.3} {:.3} {:.3} {:.3} {:.3} {:.3}]",
                    qb_f.len(), qb_f[0], qb_f[1], qb_f[2], qb_f[3], qb_f[4], qb_f[5], qb_f[6], qb_f[7]);
                eprintln!("[KERNEL] L0 batch_q[0][0..8] BEFORE bias=[{:.3} {:.3} {:.3} {:.3} {:.3} {:.3} {:.3} {:.3}]",
                    self.batch_q[0], self.batch_q[1], self.batch_q[2], self.batch_q[3],
                    self.batch_q[4], self.batch_q[5], self.batch_q[6], self.batch_q[7]);
            }
            for i in 0..seq_len {
                let q_i = &mut self.batch_q[i * qkv_dim..(i + 1) * qkv_dim];
                for j in 0..qkv_dim {
                    q_i[j] += qb_f[j];
                }
            }
            if std::env::var("KERNEL_DEBUG").is_ok() && layer == 0 {
                eprintln!("[KERNEL] L0 batch_q[0][0..8] AFTER bias=[{:.3} {:.3} {:.3} {:.3} {:.3} {:.3} {:.3} {:.3}]",
                    self.batch_q[0], self.batch_q[1], self.batch_q[2], self.batch_q[3],
                    self.batch_q[4], self.batch_q[5], self.batch_q[6], self.batch_q[7]);
            }
            drop(qb_bytes);
        }
        if let Some(kb) = lw.k_bias.as_ref() {
            let kb_bytes = self.knot.backend.fetch_tensor(&kb.name)?;
            let kb_f = bytes_to_f32_slice(&kb_bytes);
            debug_assert_eq!(kb_f.len(), kv_dim, "k_bias size mismatch: have {} need {}", kb_f.len(), kv_dim);
            for i in 0..seq_len {
                let k_i = &mut self.batch_k[i * kv_dim..(i + 1) * kv_dim];
                for j in 0..kv_dim {
                    k_i[j] += kb_f[j];
                }
            }
            drop(kb_bytes);
        }
        if let Some(vb) = lw.v_bias.as_ref() {
            let vb_bytes = self.knot.backend.fetch_tensor(&vb.name)?;
            let vb_f = bytes_to_f32_slice(&vb_bytes);
            debug_assert_eq!(vb_f.len(), kv_dim, "v_bias size mismatch: have {} need {}", vb_f.len(), kv_dim);
            for i in 0..seq_len {
                let v_i = &mut self.batch_v[i * kv_dim..(i + 1) * kv_dim];
                for j in 0..kv_dim {
                    v_i[j] += vb_f[j];
                }
            }
            drop(vb_bytes);
        }

        for i in 0..seq_len {
            let pos = start_pos + i;
            {
                let q_i = &mut self.batch_q[i * qkv_dim..(i + 1) * qkv_dim];
                let k_i = &mut self.batch_k[i * kv_dim..(i + 1) * kv_dim];
                rope(
                    q_i,
                    k_i,
                    pos,
                    config.num_heads,
                    config.num_kv_heads,
                    config.head_dim,
                    config.rope_theta,
                );
            }
            let k_slice = &self.batch_k[i * kv_dim..(i + 1) * kv_dim];
            let v_slice = &self.batch_v[i * kv_dim..(i + 1) * kv_dim];
            self.k_buf.copy_from_slice(k_slice);
            self.v_buf.copy_from_slice(v_slice);
            self.kv_cache.save_kv(l, pos, &self.k_buf, &self.v_buf);

            let head_dim = config.head_dim;
            let num_kv_groups = config.num_heads / config.num_kv_heads;
            let layer_offset = self.kv_cache.get_key_layer_offset(l);
            let max_seq_len = self.kv_cache.max_seq_len;

            let i_offset_xb = i * hidden_dim;
            let i_offset_q = i * qkv_dim;

            let (keys, values, q_batch) = unsafe {
                (
                    std::slice::from_raw_parts(
                        self.kv_cache.keys.as_ptr(),
                        self.kv_cache.keys.len(),
                    ),
                    std::slice::from_raw_parts(
                        self.kv_cache.values.as_ptr(),
                        self.kv_cache.values.len(),
                    ),
                    std::slice::from_raw_parts(self.batch_q.as_ptr(), self.batch_q.len()),
                )
            };

            let xb_i_slice = &mut self.batch_xb[i_offset_xb..i_offset_xb + hidden_dim];
            xb_i_slice
                .chunks_mut(head_dim)
                .enumerate()
                .for_each(|(h, head_out)| {
                    let kv_h = h / num_kv_groups;
                    let q_offset = h * head_dim;
                    let kv_head_offset = layer_offset + kv_h * max_seq_len * head_dim;

                    let mut head_att = [0.0f32; 2048];
                    let att_slice = &mut head_att[..=pos];

                    let q_head = &q_batch[i_offset_q + q_offset..i_offset_q + q_offset + head_dim];
                    let k_head_all = &keys[kv_head_offset..kv_head_offset + (pos + 1) * head_dim];

                    mat_vec_f32(att_slice, q_head, k_head_all, pos + 1, head_dim);
                    for v in att_slice.iter_mut() {
                        *v /= (head_dim as f32).sqrt();
                    }
                    softmax(att_slice);

                    for j in 0..head_dim {
                        head_out[j] = 0.0;
                    }
                    for t in 0..=pos {
                        let v_offset = kv_head_offset + t * head_dim;
                        let v_slice_t = &values[v_offset..v_offset + head_dim];
                        accumulate_weighted(head_out, v_slice_t, att_slice[t]);
                    }
                });
        }

        // O matmul (batched)
        let o_w = self.knot.backend.fetch_tensor(&lw.o.name)?;
        matvec_memo::cached_mat_vec(
            &mut self.memo,
            &mut self.batch_xb2,
            &self.batch_xb,
            &o_w,
            lw.o.qtype,
            hidden_dim,
            qkv_dim,
            seq_len,
            hidden_dim,
            layer,
            matvec_memo::OP_O,
            mat_vec_dispatch_batch,
        );
        drop(o_w);

        // Residual add + ffn pre-norm (per-batch)
        let ffn_norm_w = self.knot.backend.fetch_tensor(&lw.ffn_norm.name)?;
        for i in 0..seq_len {
            let x_i = &mut self.batch_x[i * hidden_dim..(i + 1) * hidden_dim];
            let xb2_i = &self.batch_xb2[i * hidden_dim..(i + 1) * hidden_dim];
            for j in 0..hidden_dim {
                x_i[j] += xb2_i[j];
            }

            let xb_i = &mut self.batch_xb[i * hidden_dim..(i + 1) * hidden_dim];
            rms_norm(
                xb_i,
                x_i,
                bytes_to_f32_slice(&ffn_norm_w),
                config.rms_norm_eps,
            );
        }
        drop(ffn_norm_w);
        Ok(())
    }

    /// Split FFN phase 2 into 2a (gate) and 2b (up + swiglu) so each
    /// half can hold only its own weight matrix in WASM memory at a
    /// time. The combined version below is retained for callers that
    /// don't need fluid memory (laptop tests, `bin/chaos-swarm`).
    ///
    /// The swiglu step has to follow up because it reads both
    /// `batch_hb` (gate output) and `batch_hb2` (up output) in place.
    /// We pin it to the up half so a worker can do
    ///   loadLayerPhase('ffn_gate') → forward_range_ffn_gate_chunk → evict
    ///   loadLayerPhase('ffn_up')   → forward_range_ffn_up_chunk   → evict
    /// and only ever holds one of the two big matrices resident at once
    /// — the difference between fitting and OOMing on a 128 MB CF Worker
    /// for qwen-7b's 18,944-d FFN (~14 MB per Q4_K matrix per layer).
    pub fn forward_range_ffn_gate_chunk(&mut self, layer: usize, seq_len: usize) -> Result<()> {
        let config = &self.config;
        let locs = &self.locs;
        let hidden_dim = config.hidden_dim;
        let lw = &locs.layers[layer];

        let gate_w = self.knot.backend.fetch_tensor(&lw.gate.name)?;
        matvec_memo::cached_mat_vec(
            &mut self.memo,
            &mut self.batch_hb,
            &self.batch_xb,
            &gate_w,
            lw.gate.qtype,
            config.intermediate_size,
            hidden_dim,
            seq_len,
            config.intermediate_size,
            layer,
            matvec_memo::OP_FFN_GATE,
            mat_vec_dispatch_batch,
        );
        drop(gate_w);
        Ok(())
    }

    /// Split phase 2b — see `forward_range_ffn_gate_chunk` doc for the
    /// rationale. Must follow the gate call for the same layer + seq_len.
    pub fn forward_range_ffn_up_chunk(&mut self, layer: usize, seq_len: usize) -> Result<()> {
        let config = &self.config;
        let locs = &self.locs;
        let hidden_dim = config.hidden_dim;
        let lw = &locs.layers[layer];

        let up_w = self.knot.backend.fetch_tensor(&lw.up.name)?;
        matvec_memo::cached_mat_vec(
            &mut self.memo,
            &mut self.batch_hb2,
            &self.batch_xb,
            &up_w,
            lw.up.qtype,
            config.intermediate_size,
            hidden_dim,
            seq_len,
            config.intermediate_size,
            layer,
            matvec_memo::OP_FFN_UP,
            mat_vec_dispatch_batch,
        );
        drop(up_w);

        for i in 0..seq_len {
            let hb_i = &mut self.batch_hb
                [i * config.intermediate_size..(i + 1) * config.intermediate_size];
            let hb2_i =
                &self.batch_hb2[i * config.intermediate_size..(i + 1) * config.intermediate_size];
            swiglu_inplace(hb_i, hb2_i);
        }
        Ok(())
    }

    /// Combined gate + up + swiglu path. Retained for tests + bins that
    /// don't care about fluid memory; new worker code should call the
    /// two split methods above.
    pub fn forward_range_ffn_gate_up_chunk(&mut self, layer: usize, seq_len: usize) -> Result<()> {
        self.forward_range_ffn_gate_chunk(layer, seq_len)?;
        self.forward_range_ffn_up_chunk(layer, seq_len)?;
        Ok(())
    }

    /// Split phase 3: FFN Down (computes ffn_down, residual add)
    /// Returns the accumulated output if it's the last layer, or empty vec if not requested yet.
    pub fn forward_range_ffn_down_chunk(
        &mut self,
        layer: usize,
        seq_len: usize,
        is_last_layer: bool,
    ) -> Result<Vec<f32>> {
        let config = &self.config;
        let locs = &self.locs;
        let hidden_dim = config.hidden_dim;
        let lw = &locs.layers[layer];

        let down_w = self.knot.backend.fetch_tensor(&lw.down.name)?;
        matvec_memo::cached_mat_vec(
            &mut self.memo,
            &mut self.batch_xb,
            &self.batch_hb,
            &down_w,
            lw.down.qtype,
            hidden_dim,
            config.intermediate_size,
            seq_len,
            hidden_dim,
            layer,
            matvec_memo::OP_FFN_DOWN,
            mat_vec_dispatch_batch,
        );
        drop(down_w);

        for i in 0..seq_len {
            let x_i = &mut self.batch_x[i * hidden_dim..(i + 1) * hidden_dim];
            let xb_i = &self.batch_xb[i * hidden_dim..(i + 1) * hidden_dim];
            for j in 0..hidden_dim {
                x_i[j] += xb_i[j];
            }
        }

        if is_last_layer {
            let mut out = vec![0.0f32; seq_len * hidden_dim];
            out.copy_from_slice(&self.batch_x[..seq_len * hidden_dim]);
            Ok(out)
        } else {
            Ok(vec![])
        }
    }

    /// Read the first `seq_len * hidden_dim` floats out of `batch_x`.
    /// Used by the liquid-mesh `/forward-one` path to bypass the
    /// problematic `is_last_layer=true` Vec return of
    /// `forward_range_ffn_down_chunk`.
    pub fn get_batch_x_residual(&self, seq_len: usize) -> Vec<f32> {
        let hidden_dim = self.config.hidden_dim;
        let n = seq_len * hidden_dim;
        assert!(
            n <= self.batch_x.len(),
            "seq_len {} × hidden_dim {} = {} > batch_x.len() {}",
            seq_len,
            hidden_dim,
            n,
            self.batch_x.len()
        );
        self.batch_x[..n].to_vec()
    }

    pub fn set_batch_x_residual(&mut self, input: &[f32]) {
        assert!(
            input.len() <= self.batch_x.len(),
            "batch_x input len {} > batch_x.len() {}",
            input.len(),
            self.batch_x.len()
        );
        self.batch_x[..input.len()].copy_from_slice(input);
    }

    pub fn get_batch_xb_residual(&self, seq_len: usize) -> Vec<f32> {
        let hidden_dim = self.config.hidden_dim;
        let n = seq_len * hidden_dim;
        assert!(
            n <= self.batch_xb.len(),
            "seq_len {} × hidden_dim {} = {} > batch_xb.len() {}",
            seq_len,
            hidden_dim,
            n,
            self.batch_xb.len()
        );
        self.batch_xb[..n].to_vec()
    }

    pub fn set_batch_xb_residual(&mut self, input: &[f32]) {
        assert!(
            input.len() <= self.batch_xb.len(),
            "batch_xb input len {} > batch_xb.len() {}",
            input.len(),
            self.batch_xb.len()
        );
        self.batch_xb[..input.len()].copy_from_slice(input);
    }

    pub fn get_batch_hb_residual(&self, seq_len: usize) -> Vec<f32> {
        let intermediate = self.config.intermediate_size;
        let n = seq_len * intermediate;
        assert!(
            n <= self.batch_hb.len(),
            "seq_len {} × intermediate_size {} = {} > batch_hb.len() {}",
            seq_len,
            intermediate,
            n,
            self.batch_hb.len()
        );
        self.batch_hb[..n].to_vec()
    }

    pub fn set_batch_hb_residual(&mut self, input: &[f32]) {
        assert!(
            input.len() <= self.batch_hb.len(),
            "batch_hb input len {} > batch_hb.len() {}",
            input.len(),
            self.batch_hb.len()
        );
        self.batch_hb[..input.len()].copy_from_slice(input);
    }

    pub fn get_kv_slab(&self, layer_lo: usize, layer_hi: usize, prefix_len: usize) -> Vec<f32> {
        assert!(
            layer_lo < layer_hi && layer_hi <= self.kv_cache.num_layers,
            "bad KV layer range [{}, {}) for num_layers {}",
            layer_lo,
            layer_hi,
            self.kv_cache.num_layers
        );
        assert!(
            prefix_len <= self.kv_cache.max_seq_len,
            "prefix_len {} > KV max_seq_len {}",
            prefix_len,
            self.kv_cache.max_seq_len
        );

        let per_layer = self.kv_cache.num_kv_heads * prefix_len * self.kv_cache.head_dim;
        let layers = layer_hi - layer_lo;
        let mut slab = Vec::with_capacity(layers * per_layer * 2);

        for layer in layer_lo..layer_hi {
            let layer_offset = self.kv_cache.get_key_layer_offset(layer);
            for h in 0..self.kv_cache.num_kv_heads {
                let head_offset =
                    layer_offset + h * self.kv_cache.max_seq_len * self.kv_cache.head_dim;
                let end = head_offset + prefix_len * self.kv_cache.head_dim;
                slab.extend_from_slice(&self.kv_cache.keys[head_offset..end]);
            }
        }
        for layer in layer_lo..layer_hi {
            let layer_offset = self.kv_cache.get_val_layer_offset(layer);
            for h in 0..self.kv_cache.num_kv_heads {
                let head_offset =
                    layer_offset + h * self.kv_cache.max_seq_len * self.kv_cache.head_dim;
                let end = head_offset + prefix_len * self.kv_cache.head_dim;
                slab.extend_from_slice(&self.kv_cache.values[head_offset..end]);
            }
        }
        slab
    }

    pub fn set_kv_slab(
        &mut self,
        layer_lo: usize,
        layer_hi: usize,
        prefix_len: usize,
        slab: &[f32],
    ) {
        assert!(
            layer_lo < layer_hi && layer_hi <= self.kv_cache.num_layers,
            "bad KV layer range [{}, {}) for num_layers {}",
            layer_lo,
            layer_hi,
            self.kv_cache.num_layers
        );
        assert!(
            prefix_len <= self.kv_cache.max_seq_len,
            "prefix_len {} > KV max_seq_len {}",
            prefix_len,
            self.kv_cache.max_seq_len
        );
        let per_layer = self.kv_cache.num_kv_heads * prefix_len * self.kv_cache.head_dim;
        let expected = (layer_hi - layer_lo) * per_layer * 2;
        assert_eq!(
            slab.len(),
            expected,
            "KV slab len {} != expected {}",
            slab.len(),
            expected
        );

        let mut src = 0;
        for layer in layer_lo..layer_hi {
            let layer_offset = self.kv_cache.get_key_layer_offset(layer);
            for h in 0..self.kv_cache.num_kv_heads {
                let head_offset =
                    layer_offset + h * self.kv_cache.max_seq_len * self.kv_cache.head_dim;
                let end = head_offset + prefix_len * self.kv_cache.head_dim;
                let n = end - head_offset;
                self.kv_cache.keys[head_offset..end].copy_from_slice(&slab[src..src + n]);
                src += n;
            }
        }
        for layer in layer_lo..layer_hi {
            let layer_offset = self.kv_cache.get_val_layer_offset(layer);
            for h in 0..self.kv_cache.num_kv_heads {
                let head_offset =
                    layer_offset + h * self.kv_cache.max_seq_len * self.kv_cache.head_dim;
                let end = head_offset + prefix_len * self.kv_cache.head_dim;
                let n = end - head_offset;
                self.kv_cache.values[head_offset..end].copy_from_slice(&slab[src..src + n]);
                src += n;
            }
        }
    }

    /// Apply final RMSNorm + lm_head projection over the input residual chunk
    /// and return the logits row for the LAST token only (next-token-prediction
    /// row). Exit stations call this after the final `forward_range` to obtain
    /// the sampling distribution.
    ///
    /// Returns a `vocab_size`-length vector. Intermediate-token logits are
    /// computed but discarded — log-rolling pipelined prefill only ever needs
    /// the trailing row to advance generation; computing all rows would waste
    /// network bandwidth on the way back to the coordinator.
    pub fn lm_head_only(&mut self, input: &[f32], seq_len: usize) -> Result<Vec<f32>> {
        let config = &self.config;
        let locs = &self.locs;
        let hidden_dim = config.hidden_dim;

        assert_eq!(
            input.len(),
            seq_len * hidden_dim,
            "lm_head_only: input shape {} != seq_len*hidden_dim {}",
            input.len(),
            seq_len * hidden_dim
        );
        assert!(
            seq_len > 0 && seq_len <= BATCH_CAPACITY,
            "seq_len {} out of range (0, {}]",
            seq_len,
            BATCH_CAPACITY
        );

        // Stage incoming residual into batch_x for the final-norm pass.
        self.batch_x[..seq_len * hidden_dim].copy_from_slice(input);

        let final_norm_w = self.knot.backend.fetch_tensor(&locs.final_norm.name).unwrap();
        for i in 0..seq_len {
            let x_i = &self.batch_x[i * hidden_dim..(i + 1) * hidden_dim];
            let xb_i = &mut self.batch_xb[i * hidden_dim..(i + 1) * hidden_dim];
            rms_norm(
                xb_i,
                x_i,
                bytes_to_f32_slice(&final_norm_w),
                config.rms_norm_eps,
            );
        }
        drop(final_norm_w);

        let lm_w = self.knot.backend.fetch_tensor(&locs.lm_head.name).unwrap();
        mat_vec_dispatch_batch(
            &mut self.batch_logits,
            &self.batch_xb,
            &lm_w,
            locs.lm_head.qtype,
            config.vocab_size,
            hidden_dim,
            seq_len,
            config.vocab_size,
        );
        drop(lm_w);

        // Return logits for the LAST token in the chunk.
        let last = (seq_len - 1) * config.vocab_size;
        let mut out = vec![0.0f32; config.vocab_size];
        out.copy_from_slice(&self.batch_logits[last..last + config.vocab_size]);
        Ok(out)
    }
}

#[cfg(feature = "napi")]
#[napi]
impl NativeLlamaPipeline {
    #[napi(constructor)]
    pub fn napi_new(path: String, draft_mode: bool, resonance_threshold: f64) -> Self {
        Self::new(path, draft_mode, resonance_threshold)
    }

    #[napi(js_name = "getPos")]
    pub fn napi_get_pos(&self) -> u32 {
        self.get_pos()
    }

    #[napi(js_name = "generate")]
    pub fn napi_generate(
        &mut self,
        prompt_tokens: Uint32Array,
        max_new_tokens: u32,
    ) -> napi::Result<Uint32Array> {
        self.generate(prompt_tokens, max_new_tokens)
    }

    #[napi(js_name = "innerVerify")]
    pub fn napi_inner_verify(
        &mut self,
        prompt_tokens: Vec<u32>,
        candidates: Vec<u32>,
    ) -> napi::Result<Vec<u32>> {
        self.inner_verify(prompt_tokens, candidates)
    }

    #[napi(js_name = "innerVerifyBatch")]
    pub fn napi_inner_verify_batch(
        &mut self,
        prompt_tokens: Vec<u32>,
        candidates: Vec<u32>,
    ) -> napi::Result<Vec<u32>> {
        self.inner_verify_batch(prompt_tokens, candidates)
    }
}

// ─────────────────────────────────────────────────────────────────────────
// Tests
// ─────────────────────────────────────────────────────────────────────────

#[cfg(all(test, not(target_arch = "wasm32")))]
mod tests {
    use super::*;
    use crate::loader::{KnotConfig, KnotWeights, OwnedBytes, TensorInfo, WeightBackend};
    use std::collections::HashMap;
    use std::sync::Arc;

    /// In-memory weight backend for tests. Holds tensor name → bytes map and
    /// hands out `OwnedBytes::Owned` slices on fetch.
    struct TestBackend {
        tensors: HashMap<String, Arc<Vec<u8>>>,
    }

    impl WeightBackend for TestBackend {
        fn has_tensor(&self, name: &str) -> bool { self.tensors.contains_key(name) }
        fn fetch_tensor(&self, name: &str) -> Result<OwnedBytes> {
            let arc = self
                .tensors
                .get(name)
                .ok_or_else(|| format!("TestBackend: missing tensor '{}'", name))?;
            Ok(OwnedBytes::Owned(Arc::clone(arc)))
        }
    }

    /// Tiny deterministic F32 fill: small magnitudes (~1e-2) keyed by index +
    /// salt so two different tensor names never get identical buffers but the
    /// values are small enough that 22 layers worth of residual addition stays
    /// within f32's exact range (no overflow → bit-exact accumulation).
    fn fill_f32(out: &mut [f32], salt: u32) {
        for (i, v) in out.iter_mut().enumerate() {
            let x = ((i as u64).wrapping_mul(2654435761) ^ (salt as u64).wrapping_mul(1597334677))
                as u32;
            // Scale into ~[-0.05, 0.05] for stability in the tiny test config.
            *v = ((x % 10_001) as f32 / 10_000.0 - 0.5) * 0.1;
        }
    }

    fn f32_bytes(values: &[f32]) -> Vec<u8> {
        let mut out = Vec::with_capacity(values.len() * 4);
        for v in values {
            out.extend_from_slice(&v.to_le_bytes());
        }
        out
    }

    fn build_test_knot() -> (KnotWeights, KnotConfig) {
        // Tiny synthetic config: small enough to make cheap tensors but large
        // enough to exercise multi-head GQA, RoPE, RMSNorm, SwiGLU, and the
        // residual-stream wiring.
        let cfg = KnotConfig {
            hidden_dim: 64,
            num_layers: 2,
            num_heads: 4,
            num_kv_heads: 2,
            head_dim: 16,
            intermediate_size: 128,
            vocab_size: 64,
            rms_norm_eps: 1.0e-5,
            rope_theta: 10000.0,
        };

        // Build every tensor referenced by `resolve_all` in the same shapes the
        // production loader expects. F32 layout throughout (no quantization).
        let mut tensors: HashMap<String, Arc<Vec<u8>>> = HashMap::new();
        let mut metadata: HashMap<String, TensorInfo> = HashMap::new();
        let mut salt: u32 = 0;
        let mut next_offset: usize = 0;

        let add_tensor = |tensors: &mut HashMap<String, Arc<Vec<u8>>>,
                          metadata: &mut HashMap<String, TensorInfo>,
                          salt: &mut u32,
                          next_offset: &mut usize,
                          name: &str,
                          numel: usize| {
            let mut buf = vec![0.0f32; numel];
            fill_f32(&mut buf, *salt);
            *salt = salt.wrapping_add(1);
            let bytes = f32_bytes(&buf);
            let length = bytes.len();
            tensors.insert(name.to_string(), Arc::new(bytes));
            // Offsets here are bookkeeping only — TestBackend looks up by name,
            // not by offset. They still need to be plausibly non-overlapping so
            // a future debug print doesn't show two tensors at offset 0.
            metadata.insert(
                name.to_string(),
                TensorInfo {
                    offset: *next_offset,
                    length,
                    tensor_type: "F32".to_string(),
                },
            );
            *next_offset += length;
        };

        // Embedding + final norm + lm_head
        add_tensor(
            &mut tensors,
            &mut metadata,
            &mut salt,
            &mut next_offset,
            "token_embd_weight",
            cfg.vocab_size * cfg.hidden_dim,
        );
        add_tensor(
            &mut tensors,
            &mut metadata,
            &mut salt,
            &mut next_offset,
            "output_norm_weight",
            cfg.hidden_dim,
        );
        add_tensor(
            &mut tensors,
            &mut metadata,
            &mut salt,
            &mut next_offset,
            "output_weight",
            cfg.vocab_size * cfg.hidden_dim,
        );

        // Per-layer tensors
        let qkv_dim = cfg.num_heads * cfg.head_dim;
        let kv_dim = cfg.num_kv_heads * cfg.head_dim;
        for l in 0..cfg.num_layers {
            add_tensor(
                &mut tensors,
                &mut metadata,
                &mut salt,
                &mut next_offset,
                &format!("blk_{}_attn_norm_weight", l),
                cfg.hidden_dim,
            );
            add_tensor(
                &mut tensors,
                &mut metadata,
                &mut salt,
                &mut next_offset,
                &format!("blk_{}_attn_q_weight", l),
                qkv_dim * cfg.hidden_dim,
            );
            add_tensor(
                &mut tensors,
                &mut metadata,
                &mut salt,
                &mut next_offset,
                &format!("blk_{}_attn_k_weight", l),
                kv_dim * cfg.hidden_dim,
            );
            add_tensor(
                &mut tensors,
                &mut metadata,
                &mut salt,
                &mut next_offset,
                &format!("blk_{}_attn_v_weight", l),
                kv_dim * cfg.hidden_dim,
            );
            add_tensor(
                &mut tensors,
                &mut metadata,
                &mut salt,
                &mut next_offset,
                &format!("blk_{}_attn_output_weight", l),
                cfg.hidden_dim * qkv_dim,
            );
            add_tensor(
                &mut tensors,
                &mut metadata,
                &mut salt,
                &mut next_offset,
                &format!("blk_{}_ffn_norm_weight", l),
                cfg.hidden_dim,
            );
            add_tensor(
                &mut tensors,
                &mut metadata,
                &mut salt,
                &mut next_offset,
                &format!("blk_{}_ffn_gate_weight", l),
                cfg.intermediate_size * cfg.hidden_dim,
            );
            add_tensor(
                &mut tensors,
                &mut metadata,
                &mut salt,
                &mut next_offset,
                &format!("blk_{}_ffn_up_weight", l),
                cfg.intermediate_size * cfg.hidden_dim,
            );
            add_tensor(
                &mut tensors,
                &mut metadata,
                &mut salt,
                &mut next_offset,
                &format!("blk_{}_ffn_down_weight", l),
                cfg.hidden_dim * cfg.intermediate_size,
            );
        }

        let backend: Arc<dyn WeightBackend> = Arc::new(TestBackend { tensors });
        let knot = KnotWeights {
            backend,
            config: Some(cfg.clone()),
            metadata,
            mmap: None,
            payload_offset: 0,
        };

        (knot, cfg)
    }

    /// Behavioural parity: the decomposed log-rolling primitives
    /// (`embed_chunk` → `forward_range_chunk` → `lm_head_only`) must produce
    /// the same last-token logits as a single monolithic prompt-only
    /// `inner_generate(prompt, 0)` (which runs `forward_one` per token).
    ///
    /// Tolerance: 1e-4 absolute per element, per the spec.
    ///
    /// Note: `resonance_threshold = 1.0` disables the FFN resonance shortcut,
    /// which is the one place where the per-token (`forward_one`) and batched
    /// (`forward_range_chunk`) paths can diverge — the batched path doesn't
    /// touch `ffn_cache`. With the cache disabled, both paths execute the same
    /// kernel sequence over the same inputs and should agree to f32 precision.
    #[test]
    fn log_rolling_primitives_match_monolithic_forward() {
        let (knot_a, cfg) = build_test_knot();
        // Build a second independent knot for the decomposed pipeline so the
        // two pipelines never share KV cache or FFN cache state.
        let (knot_b, _) = build_test_knot();

        let resonance_threshold = 1.0; // disable FFN resonance shortcut
        let mut pipe_mono = NativeLlamaPipeline::from_knot(knot_a, false, resonance_threshold);
        let mut pipe_chunk = NativeLlamaPipeline::from_knot(knot_b, false, resonance_threshold);

        let prompt: Vec<u32> = vec![3, 1, 4, 1, 5, 9, 2, 6];

        // Monolithic: feed prompt through the existing per-token path. After
        // generate(prompt, 0) returns, self.logits holds the next-token-
        // prediction logits for the LAST prompt token.
        let _ = pipe_mono
            .inner_generate(&prompt, 0)
            .expect("monolithic generate failed");
        let mono_logits = pipe_mono.logits.clone();
        assert_eq!(mono_logits.len(), cfg.vocab_size);

        // Decomposed: simulate one station with start_layer=0, end_layer=L.
        let residual = pipe_chunk.embed_chunk(&prompt, 0).unwrap();
        assert_eq!(residual.len(), prompt.len() * cfg.hidden_dim);

        let final_residual =
            pipe_chunk.forward_range_chunk(&residual, 0, cfg.num_layers, 0, prompt.len()).unwrap();
        assert_eq!(final_residual.len(), prompt.len() * cfg.hidden_dim);

        let chunk_logits = pipe_chunk.lm_head_only(&final_residual, prompt.len()).unwrap();
        assert_eq!(chunk_logits.len(), cfg.vocab_size);

        // Per-element absolute tolerance.
        let tol = 1.0e-4f32;
        let mut max_diff = 0.0f32;
        let mut max_idx = 0usize;
        for i in 0..cfg.vocab_size {
            let d = (mono_logits[i] - chunk_logits[i]).abs();
            if d > max_diff {
                max_diff = d;
                max_idx = i;
            }
        }
        assert!(
            max_diff <= tol,
            "log-rolling parity drift at vocab idx {}: |mono - chunk| = {} (mono={}, chunk={}), tol={}",
            max_idx, max_diff, mono_logits[max_idx], chunk_logits[max_idx], tol
        );
    }

    /// Sanity check: the embed primitive returns the same bytes as a manual
    /// row lookup into the embedding table. Catches off-by-one on stride.
    #[test]
    fn embed_chunk_matches_manual_lookup() {
        let (knot, cfg) = build_test_knot();
        let mut pipe = NativeLlamaPipeline::from_knot(knot, false, 1.0);

        let tokens: Vec<u32> = vec![7, 2, 11];
        let out = pipe.embed_chunk(&tokens, 0).unwrap();
        assert_eq!(out.len(), tokens.len() * cfg.hidden_dim);

        // Re-fetch the embedding table directly and compare each row.
        let bytes = pipe.knot.backend.fetch_tensor("token_embd_weight").unwrap();
        let table = bytes_to_f32_slice(&bytes);
        for (i, &tok) in tokens.iter().enumerate() {
            let row = &table[tok as usize * cfg.hidden_dim..(tok as usize + 1) * cfg.hidden_dim];
            let got = &out[i * cfg.hidden_dim..(i + 1) * cfg.hidden_dim];
            assert_eq!(row, got, "embed row {} mismatch (token {})", i, tok);
        }
    }
}
