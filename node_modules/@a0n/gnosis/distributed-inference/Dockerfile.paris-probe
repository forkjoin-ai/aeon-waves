FROM rust:1.87-bookworm

WORKDIR /work

RUN apt-get update \
    && apt-get install -y --no-install-recommends ca-certificates pkg-config libssl-dev \
    && rm -rf /var/lib/apt/lists/*

COPY gnosis/distributed-inference /work/gnosis/distributed-inference
COPY gnosis/gnosis-frf /work/gnosis/gnosis-frf
COPY gnosis/gnosis-http /work/gnosis/gnosis-http
COPY gnosis/rtl-bridge /work/gnosis/rtl-bridge
COPY bitwise /work/bitwise

WORKDIR /work/gnosis/distributed-inference
RUN cargo build --release --bin paris-probe-rknot

ENTRYPOINT ["/work/gnosis/distributed-inference/target/release/paris-probe-rknot"]
