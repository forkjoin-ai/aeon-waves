<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.forkjoin.kaiju-zoo-watcher</string>

    <!-- Login zsh so gcloud (PATH) + user env resolve; the script also pins
         PATH + CLOUDSDK_CONFIG (belt-and-suspenders). -->
    <key>ProgramArguments</key>
    <array>
        <string>/bin/zsh</string>
        <string>-lc</string>
        <string>/Users/buley/Documents/Code/monorepo/open-source/gnosis/distributed-inference/scripts/kaiju-zoo-watcher.sh</string>
    </array>

    <!-- Hourly. Idempotent + single-flight + one-encode-at-a-time, so re-firing
         forever is safe; drains the queue one model per tick. -->
    <key>StartInterval</key>
    <integer>3600</integer>

    <!-- Do not fire on load; wait for the first interval. -->
    <key>RunAtLoad</key>
    <false/>

    <key>StandardOutPath</key>
    <string>/Users/buley/Documents/Code/monorepo/open-source/gnosis/distributed-inference/scripts/.kaiju-zoo-watcher/launchd.out.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/buley/Documents/Code/monorepo/open-source/gnosis/distributed-inference/scripts/.kaiju-zoo-watcher/launchd.err.log</string>
</dict>
</plist>
