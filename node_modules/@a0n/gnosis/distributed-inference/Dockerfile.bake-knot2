# Two-knot baker (e.g. ltx needs KNOT + T5_KNOT). Downloads both in a debian
# builder, size-verifies, COPYs /models into the target base image.
ARG BASE_IMAGE
FROM debian:bookworm-slim AS dl
ARG KNOT1
ARG SIZE1
ARG KNOT2
ARG SIZE2
RUN apt-get update && apt-get install -y --no-install-recommends curl ca-certificates \
 && rm -rf /var/lib/apt/lists/* && mkdir -p /models \
 && for pair in "${KNOT1}=${SIZE1}" "${KNOT2}=${SIZE2}"; do \
      k="${pair%%=*}"; s="${pair##*=}"; \
      curl -fSL --retry 10 --retry-delay 10 --retry-all-errors -C - \
        "https://www-edgework-app.edgework.ai/api/v1/r2/distributed-inference/models/${k}" -o "/models/${k}" \
      && got=$(stat -c%s "/models/${k}") && echo "${k} = ${got}" \
      && [ "$got" = "$s" ] || { echo "SIZE MISMATCH ${k} want $s got $got"; exit 1; }; \
    done
FROM ${BASE_IMAGE}
COPY --from=dl /models /models
