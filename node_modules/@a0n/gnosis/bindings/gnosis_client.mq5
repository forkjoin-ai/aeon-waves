//+------------------------------------------------------------------+
//| gnosis_client.mq5 — Gnosis CLI binding for MetaTrader 5          |
//|                                                                    |
//| Subprocess-based binding following the gnosis binding-contract.json|
//| shape. Enables MT5 EAs to invoke gnosis lint/analyze/run/verify/  |
//| test on .gg topology files.                                       |
//|                                                                    |
//| Usage:                                                             |
//|   #include "gnosis_client.mq5"                                    |
//|   GnosisResult result;                                            |
//|   if(GnosisLint("strategy.gg", "node", true, result))             |
//|     Print("Lint output: ", result.stdout);                        |
//+------------------------------------------------------------------+

//--- Result structure matching binding-contract.json
struct GnosisResult
{
   int    exit_code;
   string stdout;
   string stderr;
};

//--- Configuration
input string GnosisBinaryPath = "gnosis"; // Path to gnosis CLI binary

//+------------------------------------------------------------------+
//| Execute a gnosis CLI command via ShellExecute                     |
//| MQL5 does not have native subprocess support, so this uses        |
//| file-based IPC: write args to temp file, execute, read output.    |
//+------------------------------------------------------------------+
bool GnosisExec(string command, string args, GnosisResult &result)
{
   // Build the full command line
   string cmdLine = GnosisBinaryPath + " " + command + " " + args;
   
   // MQL5 ShellExecute workaround:
   // Write command to a batch/shell script, execute it, capture output via file
   string tempDir = TerminalInfoString(TERMINAL_DATA_PATH) + "\\MQL5\\Files\\gnosis_tmp\\";
   string cmdFile = tempDir + "gnosis_cmd.bat";
   string outFile = tempDir + "gnosis_out.txt";
   string errFile = tempDir + "gnosis_err.txt";
   
   // Create temp directory
   FolderCreate("gnosis_tmp");
   
   // Write batch script
   int cmdHandle = FileOpen("gnosis_tmp\\gnosis_cmd.bat", FILE_WRITE | FILE_TXT | FILE_ANSI);
   if(cmdHandle == INVALID_HANDLE)
   {
      result.exit_code = -1;
      result.stderr = "Failed to create command file";
      return false;
   }
   
   FileWriteString(cmdHandle, "@echo off\r\n");
   FileWriteString(cmdHandle, cmdLine + " > \"" + outFile + "\" 2> \"" + errFile + "\"\r\n");
   FileWriteString(cmdHandle, "echo %ERRORLEVEL% > \"" + tempDir + "gnosis_exit.txt\"\r\n");
   FileClose(cmdHandle);
   
   // Execute
   ShellExecuteW(0, "open", cmdFile, "", tempDir, 0);
   
   // Wait for completion (simple polling)
   int maxWait = 30000; // 30 seconds
   int waited = 0;
   while(waited < maxWait)
   {
      if(FileIsExist("gnosis_tmp\\gnosis_exit.txt"))
         break;
      Sleep(100);
      waited += 100;
   }
   
   if(waited >= maxWait)
   {
      result.exit_code = -2;
      result.stderr = "Gnosis command timed out after 30 seconds";
      return false;
   }
   
   // Read results
   result.exit_code = ReadExitCode();
   result.stdout = ReadFileContents("gnosis_tmp\\gnosis_out.txt");
   result.stderr = ReadFileContents("gnosis_tmp\\gnosis_err.txt");
   
   // Cleanup
   FileDelete("gnosis_tmp\\gnosis_cmd.bat");
   FileDelete("gnosis_tmp\\gnosis_out.txt");
   FileDelete("gnosis_tmp\\gnosis_err.txt");
   FileDelete("gnosis_tmp\\gnosis_exit.txt");
   
   return result.exit_code == 0;
}

//+------------------------------------------------------------------+
//| gnosis lint <topology.gg> [--target <target>] [--json]           |
//+------------------------------------------------------------------+
bool GnosisLint(string topologyPath, string target, bool json, GnosisResult &result)
{
   string args = "\"" + topologyPath + "\"";
   if(target != "")
      args += " --target " + target;
   if(json)
      args += " --json";
   return GnosisExec("lint", args, result);
}

//+------------------------------------------------------------------+
//| gnosis analyze <path> [--json]                                    |
//+------------------------------------------------------------------+
bool GnosisAnalyze(string targetPath, bool json, GnosisResult &result)
{
   string args = "\"" + targetPath + "\"";
   if(json)
      args += " --json";
   return GnosisExec("analyze", args, result);
}

//+------------------------------------------------------------------+
//| gnosis verify <topology.gg> [--tla-out <dir>]                    |
//+------------------------------------------------------------------+
bool GnosisVerify(string topologyPath, string tlaOutDir, GnosisResult &result)
{
   string args = "\"" + topologyPath + "\"";
   if(tlaOutDir != "")
      args += " --tla-out \"" + tlaOutDir + "\"";
   return GnosisExec("verify", args, result);
}

//+------------------------------------------------------------------+
//| gnosis run <topology.gg> [--native]                               |
//+------------------------------------------------------------------+
bool GnosisRun(string topologyPath, bool native, GnosisResult &result)
{
   string args = "\"" + topologyPath + "\"";
   if(native)
      args += " --native";
   return GnosisExec("run", args, result);
}

//+------------------------------------------------------------------+
//| gnosis test <topology.test.gg>                                    |
//+------------------------------------------------------------------+
bool GnosisTest(string testTopologyPath, GnosisResult &result)
{
   string args = "\"" + testTopologyPath + "\"";
   return GnosisExec("test", args, result);
}

//+------------------------------------------------------------------+
//| Helper: Read file contents as string                              |
//+------------------------------------------------------------------+
string ReadFileContents(string filePath)
{
   int handle = FileOpen(filePath, FILE_READ | FILE_TXT | FILE_ANSI);
   if(handle == INVALID_HANDLE)
      return "";
   
   string contents = "";
   while(!FileIsEnding(handle))
   {
      contents += FileReadString(handle) + "\n";
   }
   FileClose(handle);
   return contents;
}

//+------------------------------------------------------------------+
//| Helper: Read exit code from file                                  |
//+------------------------------------------------------------------+
int ReadExitCode()
{
   int handle = FileOpen("gnosis_tmp\\gnosis_exit.txt", FILE_READ | FILE_TXT | FILE_ANSI);
   if(handle == INVALID_HANDLE)
      return -1;
   
   string exitStr = FileReadString(handle);
   FileClose(handle);
   
   return (int)StringToInteger(StringTrimRight(StringTrimLeft(exitStr)));
}

//+------------------------------------------------------------------+
//| ShellExecuteW import (Windows API)                                |
//+------------------------------------------------------------------+
#import "shell32.dll"
int ShellExecuteW(int hwnd, string lpOperation, string lpFile,
                   string lpParameters, string lpDirectory, int nShowCmd);
#import
