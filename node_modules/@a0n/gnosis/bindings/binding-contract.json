{
  "commands": {
    "lint": {
      "requiredArgs": ["topologyPath"],
      "optionalFlags": ["--target <workers|node|bun|agnostic>", "--json"]
    },
    "analyze": {
      "requiredArgs": ["targetPath"],
      "optionalFlags": ["--json"]
    },
    "verify": {
      "requiredArgs": ["topologyPath"],
      "optionalFlags": ["--tla-out <directory>"]
    },
    "run": {
      "requiredArgs": ["topologyPath"],
      "optionalFlags": ["--native"]
    },
    "test": {
      "requiredArgs": ["testTopologyPath"],
      "optionalFlags": []
    }
  },
  "result": {
    "fields": ["exit_code", "stdout", "stderr"]
  }
}
