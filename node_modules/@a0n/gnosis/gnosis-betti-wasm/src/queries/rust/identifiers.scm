;; Rust Identifiers and Functions Query

;; Match function definitions
(function_item
  name: (identifier) @function.name
  parameters: (parameters) @function.params) @function.decl

;; Match variable declarations (let bindings)
(let_declaration
  pattern: (identifier) @var.name
  value: (_) @var.value) @var.assign

;; Match function calls
(call_expression
  function: (identifier) @call.callee
  arguments: (arguments) @call.args) @call.expr
