------------------------------ MODULE storms_state_reduction ------------------------------
EXTENDS Naturals, FiniteSets, Sequences

NODES == {"state_reduction", "info_branch", "sufficiency_branch", "factorization_branch", "scope_branch", "reject_extra_info", "info_qed", "sufficiency_qed", "reject_bypass", "g(H,F", "g*(S,F", "factorization_qed", "reject_horizon", "scope_qed", "state_reduction_qed"}
ROOTS == {"state_reduction", "reject_horizon"}
TERMINALS == {"scope_branch", "state_reduction_qed"}
FOLD_TARGETS == {"state_reduction_qed"}
CORRIDOR_TARGETS == {}
EFFECTS == {}
DECLARED_EFFECTS == {}
INFERRED_EFFECTS == {}

VARIABLES active, beta1, payloadPresent, consensusReached
vars == <<active, beta1, payloadPresent, consensusReached>>

Max2(a, b) == IF a > b THEN a ELSE b
CanFire(sourceSet) == sourceSet \subseteq active
UpdateActive(sourceSet, targetSet) == (active \ sourceSet) \cup targetSet

Init ==
  /\ active = ROOTS
  /\ beta1 = 0
  /\ payloadPresent = TRUE
  /\ consensusReached = FALSE

Edge_01_FORK ==
  /\ CanFire({"state_reduction"})
  /\ active' = UpdateActive({"state_reduction"}, {"info_branch", "sufficiency_branch", "factorization_branch", "scope_branch"})
  /\ beta1' = beta1 + (Cardinality({"info_branch", "sufficiency_branch", "factorization_branch", "scope_branch"}) - 1)
  /\ payloadPresent' = payloadPresent
  /\ consensusReached' = consensusReached \/ ({"info_branch", "sufficiency_branch", "factorization_branch", "scope_branch"} \cap FOLD_TARGETS # {})
Edge_02_REJECT ==
  /\ CanFire({"info_branch"})
  /\ active' = UpdateActive({"info_branch"}, {"reject_extra_info"})
  /\ beta1' = beta1
  /\ payloadPresent' = payloadPresent
  /\ consensusReached' = consensusReached \/ ({"reject_extra_info"} \cap FOLD_TARGETS # {})
Edge_03_REJECT ==
  /\ CanFire({"reject_extra_info"})
  /\ active' = UpdateActive({"reject_extra_info"}, {"info_qed"})
  /\ beta1' = beta1
  /\ payloadPresent' = payloadPresent
  /\ consensusReached' = consensusReached \/ ({"info_qed"} \cap FOLD_TARGETS # {})
Edge_04_REJECT ==
  /\ CanFire({"sufficiency_branch"})
  /\ active' = UpdateActive({"sufficiency_branch"}, {"sufficiency_qed"})
  /\ beta1' = beta1
  /\ payloadPresent' = payloadPresent
  /\ consensusReached' = consensusReached \/ ({"sufficiency_qed"} \cap FOLD_TARGETS # {})
Edge_05_REJECT ==
  /\ CanFire({"factorization_branch"})
  /\ active' = UpdateActive({"factorization_branch"}, {"reject_bypass"})
  /\ beta1' = beta1
  /\ payloadPresent' = payloadPresent
  /\ consensusReached' = consensusReached \/ ({"reject_bypass"} \cap FOLD_TARGETS # {})
Edge_06_REJECT ==
  /\ CanFire({"reject_bypass"})
  /\ active' = UpdateActive({"reject_bypass"}, {"factorization_qed"})
  /\ beta1' = beta1
  /\ payloadPresent' = payloadPresent
  /\ consensusReached' = consensusReached \/ ({"factorization_qed"} \cap FOLD_TARGETS # {})
Edge_07_REJECT ==
  /\ CanFire({"reject_horizon"})
  /\ active' = UpdateActive({"reject_horizon"}, {"scope_qed"})
  /\ beta1' = beta1
  /\ payloadPresent' = payloadPresent
  /\ consensusReached' = consensusReached \/ ({"scope_qed"} \cap FOLD_TARGETS # {})
Edge_08_FOLD ==
  /\ CanFire({"info_qed", "sufficiency_qed", "factorization_qed", "scope_qed"})
  /\ active' = UpdateActive({"info_qed", "sufficiency_qed", "factorization_qed", "scope_qed"}, {"state_reduction_qed"})
  /\ beta1' = 0
  /\ payloadPresent' = payloadPresent
  /\ consensusReached' = consensusReached \/ ({"state_reduction_qed"} \cap FOLD_TARGETS # {})

Next ==
  \/ Edge_01_FORK
  \/ Edge_02_REJECT
  \/ Edge_03_REJECT
  \/ Edge_04_REJECT
  \/ Edge_05_REJECT
  \/ Edge_06_REJECT
  \/ Edge_07_REJECT
  \/ Edge_08_FOLD

TypeInvariant ==
  /\ active \subseteq NODES
  /\ beta1 \in Nat
  /\ payloadPresent \in BOOLEAN
  /\ consensusReached \in BOOLEAN

NoLostPayloadInvariant == payloadPresent = TRUE
HasFoldTargets == FOLD_TARGETS # {}
HasCorridorTargets == CORRIDOR_TARGETS # {}
EventuallyTerminal == <> (active \cap TERMINALS # {})
EventuallyConsensus == IF HasFoldTargets THEN <> consensusReached ELSE TRUE
EventuallyMiddleOutCompression == IF HasCorridorTargets THEN <> (active \cap CORRIDOR_TARGETS # {}) ELSE TRUE
FirstSufficientCompression == IF HasCorridorTargets THEN <> ((active \cap CORRIDOR_TARGETS # {}) /\ beta1 <= Cardinality(CORRIDOR_TARGETS)) ELSE TRUE
DeadlockFree == []<>(ENABLED Next)

Spec ==
  /\ Init
  /\ [][Next]_vars
  /\ WF_vars(Next)

THEOREM Spec => []NoLostPayloadInvariant

=============================================================================
