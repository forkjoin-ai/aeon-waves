// qcounter.gg — Quantum Counter: commutative FOLD (not COLLAPSE)
// Addition commutes — order never matters. FOLD, not OBSERVE.
// No memory. The topology of increments formalizes the count.

(counter: QCounter { initial: '0' })

// Concurrent increments FORK into superposition
(counter)-[:FORK]->(inc_a | inc_b | dec_c)

(inc_a: Increment { delta: '1' })
(inc_b: Increment { delta: '3' })
(dec_c: Decrement { delta: '1' })

// FOLD — not COLLAPSE. Commutativity means order is irrelevant.
// This is cheaper than OBSERVE: no strategy needed, just sum.
(inc_a | inc_b | dec_c)-[:FOLD { strategy: 'fold-sum' }]->(total)

// beta1 = 0. Total = 1 + 3 - 1 = 3.
// All increment/decrement nodes are permanent history.
(total: Converged { type: 'counter' })
(total)-[:TUNNEL { condition: 'bounded-reject' }]->(qcounter_gg_trace:Trace)
(total)-[:MEASURE { reason: 'topology-audit' }]->(qcounter_gg_trace:Trace)
