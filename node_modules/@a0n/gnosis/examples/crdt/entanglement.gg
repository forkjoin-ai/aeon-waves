// entanglement.gg — ENTANGLE: correlated collapse across data types
// When content collapses, entangled cursors transform.
// Presence never collapses — SLIVER keeps it in superposition.

(doc: QDocument)

// Content and presence are separate superpositions
(doc)-[:FORK]->(content_layer | presence_layer)

// ── Content: edits that collapse on OBSERVE ──────────────
(content_layer)-[:FORK]->(edit_a | edit_b)
(edit_a)-[:PROCESS { op: 'insert', pos: '5', text: 'hello' }]->(ea)
(edit_b)-[:PROCESS { op: 'delete', pos: '3', len: '1' }]->(eb)
(ea | eb)-[:OBSERVE { strategy: 'ot-transform' }]->(content)

// ── Presence: cursors that SLIVER (never collapse) ────
(presence_layer)-[:FORK]->(cursor_alice | cursor_bob)
(cursor_alice)-[:PROCESS { user: 'alice', pos: '12' }]->(ca)
(cursor_bob)-[:PROCESS { user: 'bob', pos: '7' }]->(cb)
(ca)-[:SLIVER]->(cb)

// ── ENTANGLE: content collapse propagates to cursors ─────
// When content resolves, cursor positions transform.
// Alice at pos 12 shifts if Bob's delete at pos 3 changes offsets.
(content)-[:ENTANGLE]->(ca)
(content)-[:ENTANGLE]->(cb)
