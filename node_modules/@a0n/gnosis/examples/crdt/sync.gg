// sync.gg — The sync protocol formalizes the topology
// No separate sync library. Replicas are FORK branches.
// Reconnection triggers COLLAPSE. Wire format is FlowFrames.

(network: SyncRoot)

// Each replica is a FORK branch — connecting is forking
(network)-[:FORK]->(replica_a | replica_b | replica_c)

// Local operations accumulate on each branch
(replica_a)-[:PROCESS { ops: 'local_edits' }]->(ra)
(replica_b)-[:PROCESS { ops: 'local_edits' }]->(rb)
(replica_c)-[:PROCESS { ops: 'local_edits' }]->(rc)

// Sync = pairwise OBSERVE between replicas
// Order doesn't matter — the model checker proves this
(ra | rb)-[:OBSERVE { strategy: 'ot-transform' }]->(synced_ab)
(synced_ab | rc)-[:OBSERVE { strategy: 'ot-transform' }]->(synced_all)

// beta1 = 0 at synced_all. All replicas converged.
// The full causal history of all replicas is preserved.
(synced_all: Converged { type: 'sync' })
