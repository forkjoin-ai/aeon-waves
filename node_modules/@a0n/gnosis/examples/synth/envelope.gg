// envelope.gg — ADSR Envelope as Temporal Topology
//
// Attack → Decay → Sustain → Release
// This is pure PROCESS — a state machine through time.
// Each phase is a node. The gate signal triggers traversal.
//
// The envelope shapes amplitude over time. When the gate opens,
// the signal travels Attack → Decay → Sustain.
// When the gate closes, it jumps to Release → silence.
//
// β₁ = 0 (no superposition — one phase at a time)

(gate: Trigger { type: 'gate' })

(attack: Ramp { direction: 'up', default: '0.01' })
(decay: Ramp { direction: 'down', default: '0.1' })
(sustain: Hold { level: '0.7' })
(release: Ramp { direction: 'down', default: '0.3' })
(silence: Constant { value: '0' })

(gate)-[:PROCESS]->(attack)-[:PROCESS]->(decay)-[:PROCESS]->(sustain)
(sustain)-[:VENT { on: 'gate-off' }]->(release)
(release)-[:PROCESS]->(silence)

// The envelope output is the current amplitude
(attack)-[:PROCESS]->(env_out: Amplitude)
(decay)-[:PROCESS]->(env_out)
(sustain)-[:PROCESS]->(env_out)
(release)-[:PROCESS]->(env_out)
(env_out)-[:MEASURE { reason: 'topology-audit' }]->(envelope_gg_trace:Trace)
