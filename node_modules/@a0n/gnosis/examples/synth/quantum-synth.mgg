// quantum-synth.mgg вҖ” A Quantum Synthesizer
//
// The synthesizer is a topology. Every signal path is a graph.
// Every parameter is a node. Every wire is an edge.
//
// Polyphony is superposition. When you press 4 keys, 4 voices
// exist in parallel вҖ” forked from the same patch. They interfere
// constructively at the mixer, then fold into stereo output.
//
// The entire signal flow:
//
//   MIDI Input
//     в”Ӯ
//     в”ңв”Җв”ҖFORKв”Җв”Җв–ә Voice 0 в”Җв”Җв”җ
//     в”ңв”Җв”ҖFORKв”Җв”Җв–ә Voice 1 в”Җв”Җв”Ө
//     в”ңв”Җв”ҖFORKв”Җв”Җв–ә Voice 2 в”Җв”Җв”јв”Җв”ҖFOLDв”Җв”Җв–ә Mixer в”Җв”Җв–ә Effects в”Җв”Җв–ә Output
//     в”ңв”Җв”ҖFORKв”Җв”Җв–ә Voice 3 в”Җв”Җв”Ө
//     в”ңв”Җв”ҖFORKв”Җв”Җв–ә Voice 4 в”Җв”Җв”Ө
//     в”ңв”Җв”ҖFORKв”Җв”Җв–ә Voice 5 в”Җв”Җв”Ө
//     в”ңв”Җв”ҖFORKв”Җв”Җв–ә Voice 6 в”Җв”Җв”Ө
//     в””в”Җв”ҖFORKв”Җв”Җв–ә Voice 7 в”Җв”Җв”ҳ
//
// ОІвӮҒ of the full synth:
//   - 8 voices Г— (3 osc waveforms + 1 filter race + 3 effects) = 56
//   - Plus the voice allocation fork itself = 7
//   - Total ОІвӮҒ = 63
//
// 63 independent cycles of superposition. 63 parallel universes
// of sound, all collapsing into two channels of audio.

import { note, voice_out, lfo_rate, cutoff, resonance } from './voice.mgg'
import { fx_input, fx_out } from './effects.gg'

// в•җв•җв•җ Input в•җв•җв•җ

(midi_in: MIDI { source: 'keyboard' })
(clock: Clock { rate: '48000', unit: 'Hz' })

// в•җв•җв•җ Voice Allocation в•җв•җв•җ
// MIDI notes fork into available voices.
// Voice stealing: if all voices are busy, the oldest note is vented.

(voice_0: Voice { id: '0' })
(voice_1: Voice { id: '1' })
(voice_2: Voice { id: '2' })
(voice_3: Voice { id: '3' })
(voice_4: Voice { id: '4' })
(voice_5: Voice { id: '5' })
(voice_6: Voice { id: '6' })
(voice_7: Voice { id: '7' })

(midi_in)-[:FORK]->(voice_0 | voice_1 | voice_2 | voice_3 | voice_4 | voice_5 | voice_6 | voice_7)

// Each voice processes its note through the full signal chain
(voice_0)-[:PROCESS]->(note)
(voice_1)-[:PROCESS]->(note)
(voice_2)-[:PROCESS]->(note)
(voice_3)-[:PROCESS]->(note)
(voice_4)-[:PROCESS]->(note)
(voice_5)-[:PROCESS]->(note)
(voice_6)-[:PROCESS]->(note)
(voice_7)-[:PROCESS]->(note)

// в•җв•җв•җ Mixer в•җв•җв•җ
// All voices fold into a single mix bus.
// This is the collapse: 8 parallel universes of sound вҶ’ one signal.

(v0_out: Signal)
(v1_out: Signal)
(v2_out: Signal)
(v3_out: Signal)
(v4_out: Signal)
(v5_out: Signal)
(v6_out: Signal)
(v7_out: Signal)

(voice_out)-[:PROCESS]->(v0_out)
(voice_out)-[:PROCESS]->(v1_out)
(voice_out)-[:PROCESS]->(v2_out)
(voice_out)-[:PROCESS]->(v3_out)
(voice_out)-[:PROCESS]->(v4_out)
(voice_out)-[:PROCESS]->(v5_out)
(voice_out)-[:PROCESS]->(v6_out)
(voice_out)-[:PROCESS]->(v7_out)

(v0_out | v1_out | v2_out | v3_out | v4_out | v5_out | v6_out | v7_out)-[:FOLD { strategy: 'sum' }]->(mix_bus)

// в•җв•җв•җ Master Section в•җв•җв•җ

(mix_bus)-[:PROCESS]->(master_volume: Gain { default: '0.8' })
(master_volume)-[:PROCESS]->(limiter: Limiter { threshold: '-1', release: '0.05' })

// в•җв•җв•җ Effects в•җв•җв•җ
(limiter)-[:PROCESS]->(fx_input)

// в•җв•җв•җ Output в•җв•җв•җ
(fx_out)-[:PROCESS]->(stereo_width: StereoWidth { width: '0.7' })
(stereo_width)-[:FORK]->(left: Channel { pan: '-1' } | right: Channel { pan: '1' })
(left)-[:PROCESS]->(dac_left: DAC { channel: '0' })
(right)-[:PROCESS]->(dac_right: DAC { channel: '1' })

export { midi_in, clock, cutoff, resonance, lfo_rate, dac_left, dac_right }
(dac_right)-[:TUNNEL { condition: 'bounded-reject' }]->(quantum_synth_mgg_trace:Trace)
(dac_right)-[:MEASURE { reason: 'topology-audit' }]->(quantum_synth_mgg_trace:Trace)
