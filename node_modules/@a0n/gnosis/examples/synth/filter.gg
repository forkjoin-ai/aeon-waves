// filter.gg — Resonant Filter as Topology
//
// A filter is selective collapse. The input signal exists across
// all frequencies (superposition). The filter collapses the
// frequency spectrum — only resonant frequencies survive.
//
// The cutoff frequency determines WHERE collapse happens.
// Resonance determines HOW SHARP the collapse boundary is.
//
// Low-pass: everything below cutoff survives
// High-pass: everything above cutoff survives
// Band-pass: fork low-pass and high-pass, race them
//
// β₁ = 1 (band-pass forks two filter paths)

(filter_input: Signal)
(cutoff: Parameter { range: '20-20000', unit: 'Hz', default: '1000' })
(resonance: Parameter { range: '0-1', default: '0.7' })

// State variables (SVF — state variable filter)
(integrator_1: Integrator)
(integrator_2: Integrator)

(filter_input)-[:PROCESS]->(integrator_1)
(cutoff)-[:PROCESS]->(integrator_1)
(resonance)-[:PROCESS]->(integrator_1)
(integrator_1)-[:PROCESS]->(integrator_2)

// Fork: all filter modes exist simultaneously
(lowpass: Tap { mode: 'lowpass' })
(highpass: Tap { mode: 'highpass' })
(bandpass: Tap { mode: 'bandpass' })

(integrator_2)-[:FORK]->(lowpass | highpass | bandpass)

// Race: the selected mode wins (mode selector collapses superposition)
(lowpass | highpass | bandpass)-[:RACE]->(filter_out)
(filter_out)-[:MEASURE { reason: 'topology-audit' }]->(filter_gg_trace:Trace)
