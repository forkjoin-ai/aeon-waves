// self_verification.test.gg -- Verify self-verification annotations
// Phase 6: verify annotations on edges trigger compiler checks

(test_suite:TestSuite { name: 'self_verification' })

(source:Source { void_density: '1.0' })
(source)-[:FORK]->(a { bule: '2' } | b { bule: '3' } | c { bule: '1' })

// FOLD with positivity verification
(a | b | c)-[:FOLD { strategy: 'merge', verify: 'positivity' }]->(result)

// RACE with conservation verification
(result)-[:FORK]->(d | e)
(d | e)-[:RACE { verify: 'conservation' }]->(final)

// Final node with deficit_zero verification
(final)-[:PROCESS { verify: 'deficit_zero' }]->(sink:Sink)
(sink)-[:TUNNEL { condition: 'bounded-reject' }]->(self_verification_test_gg_trace:Trace)
(sink)-[:MEASURE { reason: 'topology-audit' }]->(self_verification_test_gg_trace:Trace)
