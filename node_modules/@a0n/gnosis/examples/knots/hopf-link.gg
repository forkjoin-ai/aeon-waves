// Hopf Link -- simplest non-trivial link (two linked rings)
//
// Not a knot but a LINK: two separate loops that are entangled.
// In code: two independent modules that share mutable state.
// Neither module is tangled alone, but they cross each other.
//
// Module A: reads and writes to shared cache
// Module B: reads and writes to shared cache
// The crossings happen at the shared state, not within either module.
//
// This is the ENTANGLE edge type in gnosis: two paths coupled
// through shared mutable state, creating a link invariant that
// neither path has alone.
//
// Unlinking number: 1 (break one crossing to separate the rings)
// Untangled form: immutable message passing (no shared state)

(shared_state: Process { op: 'mutable_cache' })

// Ring A: read → compute → write cycle
(a_read: Process { op: 'cache_read', module: 'A' })
(a_compute: Process { op: 'transform', module: 'A' })
(a_write: Process { op: 'cache_write', module: 'A' })

// Ring B: read → compute → write cycle
(b_read: Process { op: 'cache_read', module: 'B' })
(b_compute: Process { op: 'transform', module: 'B' })
(b_write: Process { op: 'cache_write', module: 'B' })

// Ring A
(shared_state)-[:PROCESS]->(a_read)
(a_read)-[:PROCESS]->(a_compute)
(a_compute)-[:PROCESS]->(a_write)
(a_write)-[:PROCESS]->(shared_state)

// Ring B
(shared_state)-[:PROCESS]->(b_read)
(b_read)-[:PROCESS]->(b_compute)
(b_compute)-[:PROCESS]->(b_write)
(b_write)-[:PROCESS]->(shared_state)

// The ENTANGLE: shared state couples the two rings
(a_write)-[:ENTANGLE]->(b_read)
(b_write)-[:ENTANGLE]->(a_read)

// Untangled form (unlinked):
// Replace shared mutable state with message passing.
// Each ring becomes independent (no ENTANGLE edges).
//
// (a_compute)-[:PROCESS { op: 'send_message' }]->(channel)
// (channel)-[:PROCESS { op: 'receive_message' }]->(b_compute)
//
// The Hopf link becomes two unknots.
// Crossing number: 2 → 0. One Reidemeister type II move.
// The modules are decoupled. The link invariant dissolves.
