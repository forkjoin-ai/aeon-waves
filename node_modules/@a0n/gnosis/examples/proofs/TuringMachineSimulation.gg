// ═══════════════════════════════════════════════════════════════════════════════
// Turing Machine Simulation in GGL
// ═══════════════════════════════════════════════════════════════════════════════
//
// A universal Turing machine expressed as a fork/race/fold topology.
// The topology formalizes the computation. The void boundary formalizes the trace.
//
// Structure:
//   1. Tape + head + state = the configuration node
//   2. Transition table = FORK to all possible (state, symbol) pairs
//   3. Matching transition = RACE (first match wins, rest are vented)
//   4. Tape update = FOLD (write symbol, move head, change state)
//   5. Halt detection = FOLD to accept/reject
//   6. Loop = METACOG (repeat until halt)
//
// The void boundary at termination contains the full computation trace:
// every rejected transition at every step. This is the rejection history
// that the Buleyean framework uses as the proof.

// ═══════════════════════════════════════════════════════════════════════════════
// The machine definition
// ═══════════════════════════════════════════════════════════════════════════════

(machine: TuringMachine {
  name: 'Universal Turing Machine',
  alphabet: '0,1,B',
  states: 'q0,q1,q2,q_accept,q_reject',
  initial_state: 'q0',
  blank_symbol: 'B'
})

// ═══════════════════════════════════════════════════════════════════════════════
// The configuration: tape + head + state
// ═══════════════════════════════════════════════════════════════════════════════

(config: Configuration {
  tape: 'B,1,0,1,B',
  head_position: '1',
  current_state: 'q0',
  step_count: '0'
})

// ═══════════════════════════════════════════════════════════════════════════════
// Transition table as nodes (each is a candidate)
// ═══════════════════════════════════════════════════════════════════════════════

(t_q0_0: Transition { from_state: 'q0', read: '0', write: '1', move: 'R', to_state: 'q1' })
(t_q0_1: Transition { from_state: 'q0', read: '1', write: '0', move: 'R', to_state: 'q0' })
(t_q0_B: Transition { from_state: 'q0', read: 'B', write: 'B', move: 'L', to_state: 'q2' })
(t_q1_0: Transition { from_state: 'q1', read: '0', write: '0', move: 'R', to_state: 'q1' })
(t_q1_1: Transition { from_state: 'q1', read: '1', write: '1', move: 'R', to_state: 'q1' })
(t_q1_B: Transition { from_state: 'q1', read: 'B', write: 'B', move: 'L', to_state: 'q_accept' })
(t_q2_0: Transition { from_state: 'q2', read: '0', write: '0', move: 'L', to_state: 'q2' })
(t_q2_1: Transition { from_state: 'q2', read: '1', write: '1', move: 'L', to_state: 'q2' })
(t_q2_B: Transition { from_state: 'q2', read: 'B', write: 'B', move: 'R', to_state: 'q_accept' })

// ═══════════════════════════════════════════════════════════════════════════════
// One computation step: FORK → RACE → FOLD
// ═══════════════════════════════════════════════════════════════════════════════

// FORK: consider all transitions simultaneously
(config)-[:FORK { reason: 'enumerate all possible transitions for current (state, symbol)' }]->(t_q0_0 | t_q0_1 | t_q0_B | t_q1_0 | t_q1_1 | t_q1_B | t_q2_0 | t_q2_1 | t_q2_B)

// RACE: the matching transition wins; all others are vented to the void boundary
// The void records WHY each non-matching transition was rejected:
// "from_state does not match current_state" or "read does not match current symbol"
(t_q0_0 | t_q0_1 | t_q0_B | t_q1_0 | t_q1_1 | t_q1_B | t_q2_0 | t_q2_1 | t_q2_B)-[:RACE { strategy: 'first-complete', failure: 'vent', reason: 'match (current_state, current_symbol) to transition' }]->(matched_transition: MatchedTransition)

// FOLD: apply the winning transition to produce the next configuration
// This is irreversible: the old configuration is consumed
(matched_transition)-[:PROCESS { strategy: 'all-pass', reason: 'write symbol, move head, change state' }]->(next_config: Configuration { step_count: 'incremented' })

// ═══════════════════════════════════════════════════════════════════════════════
// Halt detection
// ═══════════════════════════════════════════════════════════════════════════════

// Check if the new state is q_accept or q_reject
(halt_check: HaltDetector { accept_states: 'q_accept', reject_states: 'q_reject' })
(next_config)-[:PROCESS { reason: 'check if current_state is in accept or reject set' }]->(halt_check)

// FORK: either halt or continue
(halt_check)-[:FORK { reason: 'halt or continue' }]->(halted: Halted | continue: Continue)

// If halted: FOLD to final result
(halted)-[:PROCESS { strategy: 'all-pass', reason: 'machine has halted' }]->(result: ComputationResult { status: 'halted' })

// If not halted: METACOG loop back to config
// The METACOG edge is the only legal cycle in GGL
// It feeds the new configuration back as the next step's input
(continue)-[:METACOG { eta: '1.0', exploration: '0.0', reason: 'feed next_config back as config for next step' }]->(config)

// ═══════════════════════════════════════════════════════════════════════════════
// The void boundary formalizes the computation trace
// ═══════════════════════════════════════════════════════════════════════════════

// At each step, the RACE vents (transitions - 1) rejected transitions.
// After T steps on a machine with K transitions:
//   void boundary size = T × (K - 1)
//   void boundary content = full trace of every rejected transition at every step
//
// This is the Buleyean rejection history of the computation.
// The weight of the accepted computation path:
//   w = R - min(v, R) + 1
// where R = total steps and v = 0 (the winning path was never rejected).
// So w = R + 1 (maximal weight).
//
// The weight of any rejected transition:
//   w = R - min(v, R) + 1
// where v ≥ 1 (rejected at least once).
// So w ≤ R (strictly less than the winner).
//
// This formalizes the god formula applied to computation.

(void_trace: VoidBoundary {
  description: 'full computation trace: every rejected transition at every step',
  content: 'accumulated via RACE venting at each METACOG iteration'
})
(result)-[:MEASURE { reason: 'extract void boundary as computation trace' }]->(void_trace)
