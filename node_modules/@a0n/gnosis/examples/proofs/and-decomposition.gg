// and-decomposition.gg -- Proving A AND B via FORK/FOLD
//
// Buleyean AND: bules(A AND B) = bules(A) + bules(B)
// Both must independently reach ground state (bules = 0).
//
// The proof topology uses FORK to decompose the conjunction
// into parallel sub-proofs, then FOLD to compose the results.
// This is fork/race/fold applied to theorem proving.

(theorem_and: Theorem { bules: '5', proposition: 'A AND B' })

// FORK decomposes AND into independent sub-proofs
// 5 = 3 + 2: A needs 3 rejections, B needs 2
(proof_a: Lemma { bules: '3', proposition: 'A' })
(proof_b: Lemma { bules: '2', proposition: 'B' })
(theorem_and)-[:FORK { reason: 'AND decomposition: 5 = 3 + 2' }]->(proof_a | proof_b)

// Prove A (3 rejections)
(a1: Lemma { bules: '2' })
(a2: Lemma { bules: '1' })
(a_qed: Lemma { bules: '0' })
(proof_a)-[:REJECT { reason: 'reject ~A case 1' }]->(a1)
(a1)-[:REJECT { reason: 'reject ~A case 2' }]->(a2)
(a2)-[:REJECT { reason: 'reject ~A case 3' }]->(a_qed)

// Prove B (2 rejections)
(b1: Lemma { bules: '1' })
(b_qed: Lemma { bules: '0' })
(proof_b)-[:REJECT { reason: 'reject ~B case 1' }]->(b1)
(b1)-[:REJECT { reason: 'reject ~B case 2' }]->(b_qed)

// FOLD composes: both at 0 = QED
// bAnd(0, 0) = 0 + 0 = 0 (proved)
(a_qed | b_qed)-[:FOLD { reason: 'AND composition: 0 + 0 = 0' }]->(result: Theorem { bules: '0', proposition: 'A AND B QED' })
(result)-[:TUNNEL { condition: 'bounded-reject' }]->(and_decomposition_gg_trace:Trace)
(result)-[:MEASURE { reason: 'topology-audit' }]->(and_decomposition_gg_trace:Trace)
