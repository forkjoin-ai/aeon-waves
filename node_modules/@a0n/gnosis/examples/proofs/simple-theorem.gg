// simple-theorem.gg -- A Buleyean proof topology
//
// Theorem: A is provable (3 Bules = 3 rejections needed)
//
// The topology formalizes the proof. Each REJECT edge eliminates one alternative.
// When bules reaches 0, the proposition is at ground state: proved.
// The void (rejection history) formalizes the proof trace.

(theorem_a: Theorem { bules: '3', proposition: 'A is provable' })

// Three rejection steps -- each eliminates one alternative
(step1: Lemma { bules: '2' })
(step2: Lemma { bules: '1' })
(qed: Lemma { bules: '0' })

// REJECT edges decrease the Bule count by 1
(theorem_a)-[:REJECT { reason: 'alternative 1 eliminated by contradiction' }]->(step1)
(step1)-[:REJECT { reason: 'alternative 2 eliminated by construction' }]->(step2)
(step2)-[:REJECT { reason: 'alternative 3 eliminated by induction' }]->(qed)

// At qed: bules = 0. Deficit = 0. QED.
// Betty verifies: terminal node at ground state.
// Lean4 emits: Nat.iterate bReject 3 3 = 0 := n_rejections_reach_ground 3
