// void_walking_sufficient_statistic.gg — THM-VOID-MEMORY-EFFICIENCY witness
//
// The void boundary encoding is exponentially more compact than full
// path history. N choices with T rounds: boundary = N counters,
// full history = N^T paths.

(space: BuleyeanSpace { theorem: 'THM-VOID-MEMORY-EFFICIENCY', choices: '4', rounds: '10' })
(boundary_encoding: Encoding { size: '4', description: 'rejection counters' })
(full_history: Encoding { size: '1048576', description: '4^10 path histories' })
(compression: Invariant { claim: 'boundary << full_history', ratio: '262144:1' })
(result: Result { theorem: 'boundary-exponentially-compact' })

(space)-[:FORK]->(boundary_encoding | full_history)
(boundary_encoding | full_history)-[:RACE { expect: 'boundary-smaller' }]->(compression)
(compression)-[:PROCESS { strategy: 'verify-compression' }]->(result)
(result)-[:MEASURE { reason: 'topology-audit' }]->(void_walking_sufficient_statistic_gg_trace:Trace)
