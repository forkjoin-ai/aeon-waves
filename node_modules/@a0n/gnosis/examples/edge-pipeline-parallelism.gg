// edge-pipeline-parallelism.gg — Aeon-style 13B inference split across constrained edge workers
//
// No single worker holds the full model shard set.
// The coordinator relays quantized hidden state between layer spans and
// races a warm standby for the second shard so the request can still fold.

(request_in: Prompt { model: '13b', total_layers: '40' })
(coordinator: PipelineCoordinator { relay: 'webtransport', routing: 'edge-workers' })
(tokenizer: Tokenizer { microbatch: '2' })
(shard_a: WorkerShard { capacity_gb: '5.0', footprint_gb: '4.8', layer_span: '1-20' })
(hidden_state: RelayFrame { codec: 'binary-quantized-hidden-state' })
(shard_b_primary: WorkerShard { capacity_gb: '5.0', footprint_gb: '4.9', layer_span: '21-40' })
(shard_b_standby: WarmStandby { capacity_gb: '5.0', footprint_gb: '4.9', layer_span: '21-40' })
(logits: Logits { collapse: 'deterministic' })
(response_out: Response)

(request_in)-[:PROCESS]->(coordinator)
(coordinator)-[:PROCESS]->(tokenizer)
(tokenizer)-[:PROCESS]->(shard_a)
(shard_a)-[:PROCESS]->(hidden_state)
(hidden_state)-[:FORK]->(shard_b_primary | shard_b_standby)
(shard_b_primary | shard_b_standby)-[:RACE { strategy: 'first-healthy' }]->(logits)
(logits)-[:PROCESS]->(response_out)
(response_out)-[:MEASURE { reason: 'topology-audit' }]->(edge_pipeline_parallelism_gg_trace:Trace)
