// password-digest-md5-toy.gg -- explicit MD5 toy offline-risk calibration surface

(secret: Secret { purpose: 'password' })
(nonce: Nonce { reuse: 'false' })
(proof: Proof { verified: 'true' })
(digest: Hash {
  purpose: 'password',
  algorithm: 'md5',
  salted: 'false',
  bits: '32',
  toy: 'true',
  mode: 'toy'
})
(record: Envelope { replayGuard: 'true' })

(secret)-[:PROCESS]->(nonce)-[:PROCESS]->(proof)-[:PROCESS]->(digest)-[:PROCESS]->(record)
