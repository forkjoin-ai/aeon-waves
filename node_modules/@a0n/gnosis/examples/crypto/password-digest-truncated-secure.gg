// password-digest-truncated-secure.gg -- full-width password digest control

(secret: Secret { purpose: 'password' })
(derive: KDF {
  purpose: 'password',
  algorithm: 'argon2id',
  iterations: '3',
  memoryKb: '65536',
  saltBytes: '16'
})
(nonce: Nonce { reuse: 'false' })
(proof: Proof { verified: 'true' })
(digest: Digest {
  purpose: 'password',
  algorithm: 'argon2id',
  salted: 'true',
  saltBytes: '16',
  bits: '256'
})
(record: Envelope { replayGuard: 'true' })

(secret)-[:PROCESS]->(derive)-[:PROCESS]->(nonce)-[:PROCESS]->(proof)-[:PROCESS]->(digest)-[:PROCESS]->(record)
