// password-digest-unsalted-weak.gg -- slow but unsalted password digest surface

(secret: Secret { purpose: 'password' })
(derive: KDF {
  purpose: 'password',
  algorithm: 'argon2id',
  iterations: '3',
  memoryKb: '65536'
})
(nonce: Nonce { reuse: 'false' })
(proof: Proof { verified: 'true' })
(digest: Digest {
  purpose: 'password',
  algorithm: 'argon2id',
  salted: 'false'
})
(record: Envelope { replayGuard: 'true' })

(secret)-[:PROCESS]->(derive)-[:PROCESS]->(nonce)-[:PROCESS]->(proof)-[:PROCESS]->(digest)-[:PROCESS]->(record)
