// recovery-trust-toy.gg -- reduced-strength recovery calibration surface

(request: Request)
(channel: Channel { channelBinding: 'true', toy: 'true', mode: 'toy' })
(identity: IdentityProof { identityBinding: 'true', toy: 'true', mode: 'toy' })
(approval: Approval { quorum: '2', toy: 'true', mode: 'toy' })
(audit: Audit { retained: 'true', visible: 'true', alertUser: 'true', toy: 'true', mode: 'toy' })
(recovery: Recovery { requireProof: 'true', notifyUser: 'true', toy: 'true', mode: 'toy' })
(trust: TrustEdge { freshnessDays: '14', toy: 'true', mode: 'toy' })
(helpdesk: Helpdesk { override: 'false', requireTicket: 'true', toy: 'true', mode: 'toy' })
(receipt: Receipt)

(request)-[:PROCESS]->(channel)-[:PROCESS]->(identity)-[:PROCESS]->(approval)-[:PROCESS]->(audit)-[:PROCESS]->(recovery)-[:PROCESS]->(trust)-[:PROCESS]->(helpdesk)-[:PROCESS]->(receipt)
