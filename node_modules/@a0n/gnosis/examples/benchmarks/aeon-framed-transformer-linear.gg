// aeon-framed-transformer-linear.gg — four-stage triangle with internal rotation and whip

(frame_pair: FlowFrame { role: 'aeon-input-pair', frame_stages: '4' })
(rotation: RotationScheduler { schedule: 'wallington_rotation', stages: '4', chunks: '4', role: 'triangle-envelope' })
(router: RoutingGate { transformerlets: '4', active_paths: '2' })
(x_pos: ToyTransformerlet { axis: 'x', region: 'positive', parameters: '4', stages: '4' })
(x_neg: ToyTransformerlet { axis: 'x', region: 'negative', parameters: '4', stages: '4' })
(y_pos: ToyTransformerlet { axis: 'y', region: 'positive', parameters: '4', stages: '4' })
(y_neg: ToyTransformerlet { axis: 'y', region: 'negative', parameters: '4', stages: '4' })

(x_pos_stage_1: TransformerNode { stage: '1', role: 'input-chain' })
(x_pos_stage_2: TransformerNode { stage: '2', role: 'head-entry' })
(x_pos_stage_3: TransformerNode { stage: '3', role: 'activation-entry' })
(x_pos_stage_4: TransformerNode { stage: '4', role: 'branch-exit' })
(x_pos_head_rotation: RotationScheduler { schedule: 'wallington_rotation', stages: '4', chunks: '2', role: 'attention-triangle' })
(x_pos_head_0_q: AttentionHead { head: '0', op: 'query' })
(x_pos_head_0_v: AttentionHead { head: '0', op: 'value' })
(x_pos_head_1_q: AttentionHead { head: '1', op: 'query' })
(x_pos_head_1_v: AttentionHead { head: '1', op: 'value' })
(x_pos_head_whip: FoldOperator { role: 'worthington-whip', boundary: 'attention-heads' })
(x_pos_ffn_rotation: RotationScheduler { schedule: 'wallington_rotation', stages: '4', chunks: '2', role: 'feedforward-triangle' })
(x_pos_ffn_up: ActivationChain { lane: 'expand' })
(x_pos_ffn_gate: ActivationChain { lane: 'gate' })
(x_pos_ffn_down: ActivationChain { lane: 'project' })
(x_pos_residual_in: ActivationChain { lane: 'residual-in' })
(x_pos_residual_out: ActivationChain { lane: 'residual-out' })
(x_pos_ffn_whip: FoldOperator { role: 'worthington-whip', boundary: 'feedforward' })

(x_neg_stage_1: TransformerNode { stage: '1', role: 'input-chain' })
(x_neg_stage_2: TransformerNode { stage: '2', role: 'head-entry' })
(x_neg_stage_3: TransformerNode { stage: '3', role: 'activation-entry' })
(x_neg_stage_4: TransformerNode { stage: '4', role: 'branch-exit' })
(x_neg_head_rotation: RotationScheduler { schedule: 'wallington_rotation', stages: '4', chunks: '2', role: 'attention-triangle' })
(x_neg_head_0_q: AttentionHead { head: '0', op: 'query' })
(x_neg_head_0_v: AttentionHead { head: '0', op: 'value' })
(x_neg_head_1_q: AttentionHead { head: '1', op: 'query' })
(x_neg_head_1_v: AttentionHead { head: '1', op: 'value' })
(x_neg_head_whip: FoldOperator { role: 'worthington-whip', boundary: 'attention-heads' })
(x_neg_ffn_rotation: RotationScheduler { schedule: 'wallington_rotation', stages: '4', chunks: '2', role: 'feedforward-triangle' })
(x_neg_ffn_up: ActivationChain { lane: 'expand' })
(x_neg_ffn_gate: ActivationChain { lane: 'gate' })
(x_neg_ffn_down: ActivationChain { lane: 'project' })
(x_neg_residual_in: ActivationChain { lane: 'residual-in' })
(x_neg_residual_out: ActivationChain { lane: 'residual-out' })
(x_neg_ffn_whip: FoldOperator { role: 'worthington-whip', boundary: 'feedforward' })

(y_pos_stage_1: TransformerNode { stage: '1', role: 'input-chain' })
(y_pos_stage_2: TransformerNode { stage: '2', role: 'head-entry' })
(y_pos_stage_3: TransformerNode { stage: '3', role: 'activation-entry' })
(y_pos_stage_4: TransformerNode { stage: '4', role: 'branch-exit' })
(y_pos_head_rotation: RotationScheduler { schedule: 'wallington_rotation', stages: '4', chunks: '2', role: 'attention-triangle' })
(y_pos_head_0_q: AttentionHead { head: '0', op: 'query' })
(y_pos_head_0_v: AttentionHead { head: '0', op: 'value' })
(y_pos_head_1_q: AttentionHead { head: '1', op: 'query' })
(y_pos_head_1_v: AttentionHead { head: '1', op: 'value' })
(y_pos_head_whip: FoldOperator { role: 'worthington-whip', boundary: 'attention-heads' })
(y_pos_ffn_rotation: RotationScheduler { schedule: 'wallington_rotation', stages: '4', chunks: '2', role: 'feedforward-triangle' })
(y_pos_ffn_up: ActivationChain { lane: 'expand' })
(y_pos_ffn_gate: ActivationChain { lane: 'gate' })
(y_pos_ffn_down: ActivationChain { lane: 'project' })
(y_pos_residual_in: ActivationChain { lane: 'residual-in' })
(y_pos_residual_out: ActivationChain { lane: 'residual-out' })
(y_pos_ffn_whip: FoldOperator { role: 'worthington-whip', boundary: 'feedforward' })

(y_neg_stage_1: TransformerNode { stage: '1', role: 'input-chain' })
(y_neg_stage_2: TransformerNode { stage: '2', role: 'head-entry' })
(y_neg_stage_3: TransformerNode { stage: '3', role: 'activation-entry' })
(y_neg_stage_4: TransformerNode { stage: '4', role: 'branch-exit' })
(y_neg_head_rotation: RotationScheduler { schedule: 'wallington_rotation', stages: '4', chunks: '2', role: 'attention-triangle' })
(y_neg_head_0_q: AttentionHead { head: '0', op: 'query' })
(y_neg_head_0_v: AttentionHead { head: '0', op: 'value' })
(y_neg_head_1_q: AttentionHead { head: '1', op: 'query' })
(y_neg_head_1_v: AttentionHead { head: '1', op: 'value' })
(y_neg_head_whip: FoldOperator { role: 'worthington-whip', boundary: 'attention-heads' })
(y_neg_ffn_rotation: RotationScheduler { schedule: 'wallington_rotation', stages: '4', chunks: '2', role: 'feedforward-triangle' })
(y_neg_ffn_up: ActivationChain { lane: 'expand' })
(y_neg_ffn_gate: ActivationChain { lane: 'gate' })
(y_neg_ffn_down: ActivationChain { lane: 'project' })
(y_neg_residual_in: ActivationChain { lane: 'residual-in' })
(y_neg_residual_out: ActivationChain { lane: 'residual-out' })
(y_neg_ffn_whip: FoldOperator { role: 'worthington-whip', boundary: 'feedforward' })

(whip_boundary: FoldOperator { role: 'worthington-whip', boundary: 'benchmark-collapse' })
(prediction: FlowFrame { role: 'aeon-output-pair' })

(frame_pair)-[:PROCESS]->(rotation)
(rotation)-[:PROCESS { schedule: 'wallington_rotation' }]->(router)
(router)-[:FORK]->(x_pos | x_neg | y_pos | y_neg)

(x_pos)-[:PROCESS]->(x_pos_stage_1)-[:PROCESS]->(x_pos_stage_2)
(x_pos_stage_2)-[:PROCESS]->(x_pos_head_rotation)
(x_pos_head_rotation)-[:FORK { schedule: 'wallington_rotation' }]->(x_pos_head_0_q | x_pos_head_1_q)
(x_pos_head_0_q)-[:PROCESS]->(x_pos_head_0_v)
(x_pos_head_1_q)-[:PROCESS]->(x_pos_head_1_v)
(x_pos_head_0_v | x_pos_head_1_v)-[:FOLD { strategy: 'worthington-whip' }]->(x_pos_head_whip)
(x_pos_head_whip)-[:PROCESS]->(x_pos_stage_3)
(x_pos_stage_3)-[:PROCESS]->(x_pos_ffn_rotation)
(x_pos_ffn_rotation)-[:FORK { schedule: 'wallington_rotation' }]->(x_pos_ffn_up | x_pos_residual_in)
(x_pos_ffn_up)-[:PROCESS]->(x_pos_ffn_gate)-[:PROCESS]->(x_pos_ffn_down)
(x_pos_residual_in)-[:PROCESS]->(x_pos_residual_out)
(x_pos_ffn_down | x_pos_residual_out)-[:FOLD { strategy: 'worthington-whip' }]->(x_pos_ffn_whip)
(x_pos_ffn_whip)-[:PROCESS]->(x_pos_stage_4)

(x_neg)-[:PROCESS]->(x_neg_stage_1)-[:PROCESS]->(x_neg_stage_2)
(x_neg_stage_2)-[:PROCESS]->(x_neg_head_rotation)
(x_neg_head_rotation)-[:FORK { schedule: 'wallington_rotation' }]->(x_neg_head_0_q | x_neg_head_1_q)
(x_neg_head_0_q)-[:PROCESS]->(x_neg_head_0_v)
(x_neg_head_1_q)-[:PROCESS]->(x_neg_head_1_v)
(x_neg_head_0_v | x_neg_head_1_v)-[:FOLD { strategy: 'worthington-whip' }]->(x_neg_head_whip)
(x_neg_head_whip)-[:PROCESS]->(x_neg_stage_3)
(x_neg_stage_3)-[:PROCESS]->(x_neg_ffn_rotation)
(x_neg_ffn_rotation)-[:FORK { schedule: 'wallington_rotation' }]->(x_neg_ffn_up | x_neg_residual_in)
(x_neg_ffn_up)-[:PROCESS]->(x_neg_ffn_gate)-[:PROCESS]->(x_neg_ffn_down)
(x_neg_residual_in)-[:PROCESS]->(x_neg_residual_out)
(x_neg_ffn_down | x_neg_residual_out)-[:FOLD { strategy: 'worthington-whip' }]->(x_neg_ffn_whip)
(x_neg_ffn_whip)-[:PROCESS]->(x_neg_stage_4)

(y_pos)-[:PROCESS]->(y_pos_stage_1)-[:PROCESS]->(y_pos_stage_2)
(y_pos_stage_2)-[:PROCESS]->(y_pos_head_rotation)
(y_pos_head_rotation)-[:FORK { schedule: 'wallington_rotation' }]->(y_pos_head_0_q | y_pos_head_1_q)
(y_pos_head_0_q)-[:PROCESS]->(y_pos_head_0_v)
(y_pos_head_1_q)-[:PROCESS]->(y_pos_head_1_v)
(y_pos_head_0_v | y_pos_head_1_v)-[:FOLD { strategy: 'worthington-whip' }]->(y_pos_head_whip)
(y_pos_head_whip)-[:PROCESS]->(y_pos_stage_3)
(y_pos_stage_3)-[:PROCESS]->(y_pos_ffn_rotation)
(y_pos_ffn_rotation)-[:FORK { schedule: 'wallington_rotation' }]->(y_pos_ffn_up | y_pos_residual_in)
(y_pos_ffn_up)-[:PROCESS]->(y_pos_ffn_gate)-[:PROCESS]->(y_pos_ffn_down)
(y_pos_residual_in)-[:PROCESS]->(y_pos_residual_out)
(y_pos_ffn_down | y_pos_residual_out)-[:FOLD { strategy: 'worthington-whip' }]->(y_pos_ffn_whip)
(y_pos_ffn_whip)-[:PROCESS]->(y_pos_stage_4)

(y_neg)-[:PROCESS]->(y_neg_stage_1)-[:PROCESS]->(y_neg_stage_2)
(y_neg_stage_2)-[:PROCESS]->(y_neg_head_rotation)
(y_neg_head_rotation)-[:FORK { schedule: 'wallington_rotation' }]->(y_neg_head_0_q | y_neg_head_1_q)
(y_neg_head_0_q)-[:PROCESS]->(y_neg_head_0_v)
(y_neg_head_1_q)-[:PROCESS]->(y_neg_head_1_v)
(y_neg_head_0_v | y_neg_head_1_v)-[:FOLD { strategy: 'worthington-whip' }]->(y_neg_head_whip)
(y_neg_head_whip)-[:PROCESS]->(y_neg_stage_3)
(y_neg_stage_3)-[:PROCESS]->(y_neg_ffn_rotation)
(y_neg_ffn_rotation)-[:FORK { schedule: 'wallington_rotation' }]->(y_neg_ffn_up | y_neg_residual_in)
(y_neg_ffn_up)-[:PROCESS]->(y_neg_ffn_gate)-[:PROCESS]->(y_neg_ffn_down)
(y_neg_residual_in)-[:PROCESS]->(y_neg_residual_out)
(y_neg_ffn_down | y_neg_residual_out)-[:FOLD { strategy: 'worthington-whip' }]->(y_neg_ffn_whip)
(y_neg_ffn_whip)-[:PROCESS]->(y_neg_stage_4)

(x_pos_stage_4 | x_neg_stage_4 | y_pos_stage_4 | y_neg_stage_4)-[:FOLD { strategy: 'linear' }]->(whip_boundary)
(whip_boundary)-[:PROCESS]->(prediction)
(prediction)-[:TUNNEL { condition: 'bounded-reject' }]->(aeon_framed_transformer_linear_gg_trace:Trace)
(prediction)-[:MEASURE { reason: 'topology-audit' }]->(aeon_framed_transformer_linear_gg_trace:Trace)
