// moa-transformer-regular.gg — dense rotated transformer baseline

(frame_in: FlowFrame { role: 'token-frame' })
(outer_rotation: RotationScheduler { schedule: 'wallington_rotation', stages: '4', chunks: '2', role: 'outer-transformer-rotation' })

(x_pos: DenseTransformerlet { parameters: '18', heads: '4', family: 'regular' })
(x_pos_head_rotation: RotationScheduler { schedule: 'wallington_rotation', stages: '4', chunks: '2', role: 'inner-head-rotation' })
(x_pos_h0: AttentionHeadChain { parameters: '4', head: '0' })
(x_pos_h1: AttentionHeadChain { parameters: '4', head: '1' })
(x_pos_h2: AttentionHeadChain { parameters: '4', head: '2' })
(x_pos_h3: AttentionHeadChain { parameters: '4', head: '3' })
(x_pos_head_whip: FoldOperator { role: 'worthington-whip', boundary: 'head-whip' })
(x_pos_out: FlowFrame { role: 'transformerlet-out' })

(x_neg: DenseTransformerlet { parameters: '18', heads: '4', family: 'regular' })
(x_neg_head_rotation: RotationScheduler { schedule: 'wallington_rotation', stages: '4', chunks: '2', role: 'inner-head-rotation' })
(x_neg_h0: AttentionHeadChain { parameters: '4', head: '0' })
(x_neg_h1: AttentionHeadChain { parameters: '4', head: '1' })
(x_neg_h2: AttentionHeadChain { parameters: '4', head: '2' })
(x_neg_h3: AttentionHeadChain { parameters: '4', head: '3' })
(x_neg_head_whip: FoldOperator { role: 'worthington-whip', boundary: 'head-whip' })
(x_neg_out: FlowFrame { role: 'transformerlet-out' })

(y_pos: DenseTransformerlet { parameters: '18', heads: '4', family: 'regular' })
(y_pos_head_rotation: RotationScheduler { schedule: 'wallington_rotation', stages: '4', chunks: '2', role: 'inner-head-rotation' })
(y_pos_h0: AttentionHeadChain { parameters: '4', head: '0' })
(y_pos_h1: AttentionHeadChain { parameters: '4', head: '1' })
(y_pos_h2: AttentionHeadChain { parameters: '4', head: '2' })
(y_pos_h3: AttentionHeadChain { parameters: '4', head: '3' })
(y_pos_head_whip: FoldOperator { role: 'worthington-whip', boundary: 'head-whip' })
(y_pos_out: FlowFrame { role: 'transformerlet-out' })

(y_neg: DenseTransformerlet { parameters: '18', heads: '4', family: 'regular' })
(y_neg_head_rotation: RotationScheduler { schedule: 'wallington_rotation', stages: '4', chunks: '2', role: 'inner-head-rotation' })
(y_neg_h0: AttentionHeadChain { parameters: '4', head: '0' })
(y_neg_h1: AttentionHeadChain { parameters: '4', head: '1' })
(y_neg_h2: AttentionHeadChain { parameters: '4', head: '2' })
(y_neg_h3: AttentionHeadChain { parameters: '4', head: '3' })
(y_neg_head_whip: FoldOperator { role: 'worthington-whip', boundary: 'head-whip' })
(y_neg_out: FlowFrame { role: 'transformerlet-out' })

(frame_in)-[:PROCESS]->(outer_rotation)
(outer_rotation)-[:FORK { schedule: 'wallington_rotation' }]->(x_pos | x_neg | y_pos | y_neg)

(x_pos)-[:PROCESS]->(x_pos_head_rotation)
(x_pos_head_rotation)-[:FORK { schedule: 'wallington_rotation' }]->(x_pos_h0 | x_pos_h1 | x_pos_h2 | x_pos_h3)
(x_pos_h0 | x_pos_h1 | x_pos_h2 | x_pos_h3)-[:FOLD { strategy: 'linear', boundary: 'head-whip' }]->(x_pos_head_whip)
(x_pos_head_whip)-[:PROCESS]->(x_pos_out)

(x_neg)-[:PROCESS]->(x_neg_head_rotation)
(x_neg_head_rotation)-[:FORK { schedule: 'wallington_rotation' }]->(x_neg_h0 | x_neg_h1 | x_neg_h2 | x_neg_h3)
(x_neg_h0 | x_neg_h1 | x_neg_h2 | x_neg_h3)-[:FOLD { strategy: 'linear', boundary: 'head-whip' }]->(x_neg_head_whip)
(x_neg_head_whip)-[:PROCESS]->(x_neg_out)

(y_pos)-[:PROCESS]->(y_pos_head_rotation)
(y_pos_head_rotation)-[:FORK { schedule: 'wallington_rotation' }]->(y_pos_h0 | y_pos_h1 | y_pos_h2 | y_pos_h3)
(y_pos_h0 | y_pos_h1 | y_pos_h2 | y_pos_h3)-[:FOLD { strategy: 'linear', boundary: 'head-whip' }]->(y_pos_head_whip)
(y_pos_head_whip)-[:PROCESS]->(y_pos_out)

(y_neg)-[:PROCESS]->(y_neg_head_rotation)
(y_neg_head_rotation)-[:FORK { schedule: 'wallington_rotation' }]->(y_neg_h0 | y_neg_h1 | y_neg_h2 | y_neg_h3)
(y_neg_h0 | y_neg_h1 | y_neg_h2 | y_neg_h3)-[:FOLD { strategy: 'linear', boundary: 'head-whip' }]->(y_neg_head_whip)
(y_neg_head_whip)-[:PROCESS]->(y_neg_out)

(x_pos_out | x_neg_out | y_pos_out | y_neg_out)-[:FOLD { strategy: 'linear', boundary: 'outer-whip' }]->(regular_out: Tensor)
(regular_out)-[:TUNNEL { condition: 'bounded-reject' }]->(moa_transformer_regular_gg_trace:Trace)
(regular_out)-[:MEASURE { reason: 'topology-audit' }]->(moa_transformer_regular_gg_trace:Trace)
