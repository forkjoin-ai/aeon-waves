// fold-training-linear.gg — parameter-matched additive recombination baseline

(pair: Tensor { role: 'input-pair' })
(left_branch: AffineBranch { channel: 'left', bias: '0.0', parameters: '2' })
(right_branch: AffineBranch { channel: 'right', bias: '0.0', parameters: '2' })
(recombine: FoldOperator { role: 'sum' })
(prediction: Tensor { role: 'output' })

(pair)-[:FORK]->(left_branch | right_branch)
(left_branch | right_branch)-[:FOLD { strategy: 'linear', request_compression: 'middle-out/request/fold-training-linear', reuse_scope: 'corridor', corridor_mode: 'readonly' }]->(recombine)
(recombine)-[:PROCESS]->(prediction)
(prediction)-[:TUNNEL { condition: 'bounded-reject' }]->(fold_training_linear_gg_trace:Trace)
(prediction)-[:MEASURE { reason: 'topology-audit' }]->(fold_training_linear_gg_trace:Trace)
