// fold-training-winner-take-all.gg — nonlinear winner-selection ablation

(pair: Tensor { role: 'input-pair' })
(left_branch: AffineBranch { channel: 'left', bias: '0.0', parameters: '2' })
(right_branch: AffineBranch { channel: 'right', bias: '0.0', parameters: '2' })
(recombine: FoldOperator { role: 'winner' })
(prediction: Tensor { role: 'output' })

(pair)-[:FORK]->(left_branch | right_branch)
(left_branch | right_branch)-[:FOLD { strategy: 'winner-take-all', request_compression: 'middle-out/request/fold-training-winner-take-all', reuse_scope: 'corridor', corridor_mode: 'readonly' }]->(recombine)
(recombine)-[:PROCESS]->(prediction)
(prediction)-[:TUNNEL { condition: 'bounded-reject' }]->(fold_training_winner_take_all_gg_trace:Trace)
(prediction)-[:MEASURE { reason: 'topology-audit' }]->(fold_training_winner_take_all_gg_trace:Trace)
