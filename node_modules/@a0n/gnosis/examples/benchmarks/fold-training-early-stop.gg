// fold-training-early-stop.gg — nonlinear first-branch ablation

(pair: Tensor { role: 'input-pair' })
(left_branch: AffineBranch { channel: 'left', bias: '0.0', parameters: '2' })
(right_branch: AffineBranch { channel: 'right', bias: '0.0', parameters: '2' })
(recombine: FoldOperator { role: 'first-branch' })
(prediction: Tensor { role: 'output' })

(pair)-[:FORK]->(left_branch | right_branch)
(left_branch | right_branch)-[:FOLD { strategy: 'early-stop', request_compression: 'middle-out/request/fold-training-early-stop', reuse_scope: 'corridor', corridor_mode: 'readonly' }]->(recombine)
(recombine)-[:PROCESS]->(prediction)
(prediction)-[:TUNNEL { condition: 'bounded-reject' }]->(fold_training_early_stop_gg_trace:Trace)
(prediction)-[:MEASURE { reason: 'topology-audit' }]->(fold_training_early_stop_gg_trace:Trace)
