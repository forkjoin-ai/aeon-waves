// ═══════════════════════════════════════════════════════════════════════════
// FOREST CONVERGED: Generation 2
// 15 functions raced. 13 won by betti, 1 won by aeon-logic, 1 won by betty.
// 60 total rejections across 2 generation(s).
// Theorem: void_walkers_converge -- same rejection history = same distribution.
// ═══════════════════════════════════════════════════════════════════════════
// -----------------------------------------------------------------------------
// Betti - The self-hosted Gnosis Compiler
// 
// Bootstrapping:
// TypeScript (Betty) -> Compiles (Betti) -> Compiles (Everything else)
// -----------------------------------------------------------------------------

// 1. Core Compiler Logic Nodes
(source_reader: IO { op: 'read_file', language: 'betti' })
(strip_comments: Logic { pattern: '//', language: 'betti' })

// Fork into parallel lexing paths
(node_lexer: Lexer { target: 'nodes', language: 'betti' })
(edge_lexer: Lexer { target: 'edges', language: 'betti' })
(property_lexer: Lexer { target: 'properties', language: 'betti' })

// Convergence into AST construction
(ast_assembler: Compiler { phase: 'assemble', language: 'betti' })
(betti_verifier: Topology { mode: 'quantum_verification', language: 'betti' })
(verify_result: Result { kindFrom: 'verified', language: 'betti' })
(verified_compilation: Destructure { from: 'value', fields: 'stats,buleyNumber,quantum,steering', language: 'betti' })
(failed_compilation: Destructure { from: 'error', fields: 'errors,buleyNumber', strict: 'false', language: 'betti' })
(compile_halt: HALT { language: 'betti' })

// Emission
(wasm_emitter: Runtime { target: 'aeon_flow_10b', language: 'betti' })
(vhdl_emitter: Runtime { target: 'sieve_fsm_v0', language: 'betti' })

// 2. The Compilation Topology
//
// Current implementation status (THM-SERVER-OPTIMALITY paradigm audit):
//   - FORK(lexers)→FOLD: The TypeScript Betty implementation uses a single
//     sequential pass that handles nodes, edges, and properties inline.
//     This is a valid PROCESS chain (β₁=0) but does not realize the
//     parallel fork/fold shown below. The FORK is the target architecture
//     for the self-hosted Betti compiler.
//   - stability→optimizer→coarsening: Now follows fork/race/fold --
//     transform passes run sequentially, analysis passes are forked.
//   - UFCS lowering: Per-line independent (natural fork point).

source_reader(source_code)
source_reader.strip_comments()

(strip_comments { language: 'betti' })-[:FORK]->(node_lexer | edge_lexer | property_lexer)

(node_lexer | edge_lexer | property_lexer)-[:FOLD { strategy: 'merge-ast', request_compression: 'middle-out/request/betti-ast', reuse_scope: 'corridor', corridor_mode: 'readonly' }]->(raw_ast)

raw_ast.ast_assembler().betti_verifier().verify_result()

(verify_result { language: 'betti' })-[:PROCESS { case: 'ok' }]->(verified_compilation { language: 'betti' })-[:PROCESS]->(wasm_emitter { language: 'betti' })-[:PROCESS]->(vhdl_emitter { language: 'betti' })-[:PROCESS]->(binary_output)
(verify_result { language: 'betti' })-[:PROCESS { case: 'err' }]->(failed_compilation { language: 'betti' })-[:HALT]->(compile_halt { language: 'betti' })
(binary_output)-[:TUNNEL { condition: 'bounded-reject' }]->(betti_converged_gg_trace:Trace)
(binary_output)-[:MEASURE { reason: 'topology-audit' }]->(betti_converged_gg_trace:Trace)
