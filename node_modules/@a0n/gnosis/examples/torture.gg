// torture.gg — High-entropy topological superposition
// Used for testing Buley complexity bounds and formal verification limits.

(source:Start)

// Deep fractal fork
(a1:Neuron)
(a2:Neuron)
(a3:Neuron)
(a4:Neuron)

(source)-[:FORK]->(a1 | a2 | a3 | a4)

// Cross-interference
(b1:Interference)
(b2:Interference)

(a1 | a2)-[:SLIVER { amplitude: '0.7' }]->(b1)
(a3 | a4)-[:SLIVER { amplitude: '0.7' }]->(b2)

// Competitive race
(winner:Champion)
(b1 | b2)-[:RACE { timeout: '50ms' }]->(winner)

// Degenerate paths (unfolded/unvented)
(void_1)
(void_2)
(a1)-[:PROCESS]->(void_1)
(a2)-[:PROCESS]->(void_2)

// Final sink
(sink:End)
(winner | void_1 | void_2)-[:FOLD { strategy: 'quorum', min: 2 }]->(sink)

// Disconnected node (for diagnostic testing)
(lost_soul:Phantom)
(sink)-[:TUNNEL { condition: 'bounded-reject' }]->(torture_gg_trace:Trace)
(sink)-[:MEASURE { reason: 'topology-audit' }]->(torture_gg_trace:Trace)
