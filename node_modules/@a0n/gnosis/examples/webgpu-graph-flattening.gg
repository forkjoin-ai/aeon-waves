// webgpu-graph-flattening.gg — Flatten a scattered JS object graph into a contiguous Float32Array path
//
// The CPU pointer-chasing path races the packed WebGPU path.
// The packed path wins by folding index, bias, and weight extraction into one
// contiguous buffer before dispatch.

(object_graph: ObjectGraph { layout: 'pointer-chasing' })
(cpu_pointer_chase: JSObjectWalk { layout: 'scattered' })
(id_index: IndexMap { role: 'id-to-index' })
(bias_vector: TensorBuffer { buffer: 'Float32Array', role: 'biases' })
(weight_matrix: TensorBuffer { buffer: 'Float32Array', role: 'weights' })
(flatten_buffer: FlattenBuffer { buffer: 'Float32Array', layout: 'contiguous' })
(gpu_kernel: WebGPUKernel { backend: 'webgpu' })
(prediction_out: Tensor { role: 'output' })

(object_graph)-[:PROCESS]->(cpu_pointer_chase)
(object_graph)-[:FORK]->(id_index | bias_vector | weight_matrix)
(id_index | bias_vector | weight_matrix)-[:FOLD { strategy: 'pack-contiguous' }]->(flatten_buffer)
(flatten_buffer)-[:PROCESS]->(gpu_kernel)
(cpu_pointer_chase | gpu_kernel)-[:RACE { strategy: 'lowest-latency' }]->(prediction_out)
(prediction_out)-[:TUNNEL { condition: 'bounded-reject' }]->(webgpu_graph_flattening_gg_trace:Trace)
(prediction_out)-[:MEASURE { reason: 'topology-audit' }]->(webgpu_graph_flattening_gg_trace:Trace)
