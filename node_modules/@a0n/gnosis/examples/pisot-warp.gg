// -----------------------------------------------------------------------------
// pisot-warp.gg -- end-to-end Pisot Vickrey CPU topology
//
// Demonstrates the Pisot primitive: FORK two Fibonacci slots, RACE them under
// the Vickrey second-price rule, then SMOOTH a natural number into its
// Zeckendorf non-adjacent decomposition. A CHECK node runs the Cassini
// invariant (F[n-1]*F[n+1] - F[n]^2 == (-1)^n); if it ever fails the
// topology halts -- this is the TS mirror of cassini_no_silent_corruption
// in lean/Lean/ForkRaceFoldTheorems/PisotVickreyTable.lean.
// -----------------------------------------------------------------------------

(init: Pisot { op: 'fork', arg: '5' })
(alt:  Pisot { op: 'fork', arg: '7' })
(bid:  Pisot { op: 'race' })
(warp: Pisot { op: 'smooth', arg: '100' })
(guard: Pisot { op: 'check', arg: '10' })

init-[:PROCESS]->alt
alt-[:PROCESS]->bid
bid-[:PROCESS]->warp
warp-[:PROCESS]->guard
