// audio-token-privacy.gg — Token-level auditory privacy with noise injected into identity layers
//
// Semantic and prosodic channels stay intact while the biometric texture lane
// is noised before anything is folded into the public mesh.

(raw_mic: AudioCapture { source: 'mic' })
(local_patcher: LocalPatcher { strip_background: 'true' })
(moss_tokenizer: RVQTokenizer { rvq_layers: '8' })
(semantic_stream: TokenLane { preserve: 'semantic' })
(prosody_stream: TokenLane { preserve: 'prosody' })
(identity_stream: TokenLane { preserve: 'biometric' })
(identity_noise: DifferentialNoise { epsilon: '0.35', target_layers: '5-8' })
(public_identity: TokenLane { reconstructable: 'false' })
(public_mesh: SharedMesh { visibility: 'public', voiceprint_recoverable: 'false' })

(raw_mic)-[:PROCESS]->(local_patcher)
(local_patcher)-[:PROCESS]->(moss_tokenizer)
(moss_tokenizer)-[:FORK]->(semantic_stream | prosody_stream | identity_stream)
(identity_stream)-[:PROCESS]->(identity_noise)
(identity_noise)-[:PROCESS]->(public_identity)
(semantic_stream | prosody_stream | public_identity)-[:FOLD { strategy: 'vibe-preserving' }]->(public_mesh)
(public_mesh)-[:TUNNEL { condition: 'bounded-reject' }]->(audio_token_privacy_gg_trace:Trace)
(public_mesh)-[:MEASURE { reason: 'topology-audit' }]->(audio_token_privacy_gg_trace:Trace)
