// void-attention.gg — Void Walking is Attention
//
// The structural identity between void walking and transformer attention:
//
//   complement distribution = softmax(-eta * voidCounts)
//   neighborhood poisoning  = attention pattern spread
//   multi-head              = multiple walkers
//   cross-attention         = Skyrms walker on joint void surface
//   residual                = void boundary persistence
//   layer norm              = void decay
//   feed-forward            = c3 gait adaptation
//
// This topology runs one "round" of the void walking transformer.
// Each round processes one "token" -- the interaction outcome.

// ── Inputs ──────────────────────────────────────────────────────────

(input_token:Parameter { value: "interaction_outcome" })
(walker_a_boundary:Parameter { value: "void_boundary_a" })
(walker_b_boundary:Parameter { value: "void_boundary_b" })
(skyrms_boundary:Parameter { value: "void_boundary_cross" })

// ── Multi-Head Self-Attention ────────────────────────────────────────
//
// Each head maps to a void boundary. Attending = computing the complement.
// Q = "what should I do?", K = void counts, V = complement weights.
// score(q, k) = softmax(-eta * counts) = complementDistribution()

(head_a_0:Logic { op: "complement_distribution", walker: "a", head: "0" })
(head_a_1:Logic { op: "complement_distribution", walker: "a", head: "1" })
(head_b_0:Logic { op: "complement_distribution", walker: "b", head: "0" })
(head_b_1:Logic { op: "complement_distribution", walker: "b", head: "1" })

(walker_a_boundary)-[:FORK]->(head_a_0 | head_a_1)
(walker_b_boundary)-[:FORK]->(head_b_0 | head_b_1)

// Merge heads: fold the per-head complement distributions
(self_attn_a:Logic { op: "merge_heads" })
(self_attn_b:Logic { op: "merge_heads" })
(head_a_0 | head_a_1)-[:FOLD { strategy: "average" }]->(self_attn_a)
(head_b_0 | head_b_1)-[:FOLD { strategy: "average" }]->(self_attn_b)

// ── Cross-Attention (Skyrms Walker) ──────────────────────────────────
//
// The Skyrms walker attends to both walkers' voids simultaneously.
// Gated cross-attention: score = distA[i] * distB[j] * distS[i*B+j]
// The gate (distS) is the Skyrms walker's own complement distribution
// over the proposal space -- learned from failed proposals.

(outer_product:Logic { op: "outer_product" })
(self_attn_a | self_attn_b)-[:FOLD { strategy: "outer_product" }]->(outer_product)

(gate:Logic { op: "complement_distribution", walker: "skyrms" })
(skyrms_boundary)-[:PROCESS]->(gate)

(cross_attn:Logic { op: "gated_product" })
(outer_product | gate)-[:FOLD { strategy: "elementwise_multiply" }]->(cross_attn)

// ── Decision: Accept Proposal or Play Own Choice ─────────────────────

(proposal:Logic { op: "argmax" })
(cross_attn)-[:PROCESS]->(proposal)

(own_choice_a:Logic { op: "argmax" })
(own_choice_b:Logic { op: "argmax" })
(self_attn_a)-[:PROCESS]->(own_choice_a)
(self_attn_b)-[:PROCESS]->(own_choice_b)

(decide_a:Logic { op: "accept_if_higher_weight" })
(decide_b:Logic { op: "accept_if_higher_weight" })
(proposal | own_choice_a)-[:RACE { metric: "complement_weight" }]->(decide_a)
(proposal | own_choice_b)-[:RACE { metric: "complement_weight" }]->(decide_b)

// ── Interaction ──────────────────────────────────────────────────────

(interact:Logic { op: "evaluate_payoff" })
(decide_a | decide_b)-[:FOLD]->(interact)

(success:Result { kind: "ok" })
(failure:Result { kind: "err" })
(interact)-[:FORK]->(success | failure)

// ── Residual Connection (Void Boundary Persists) ─────────────────────
//
// In transformers: x + Attention(x)
// In void walking: boundary += rejection
// The boundary formalizes the residual stream. It accumulates.

(update_a:GradientStep { learningRate: "1", parameterKey: "void_a" })
(update_b:GradientStep { learningRate: "1", parameterKey: "void_b" })
(update_s:GradientStep { learningRate: "1", parameterKey: "void_cross" })

(failure)-[:FORK]->(update_a | update_b | update_s)
(update_a)-[:PROCESS]->(walker_a_boundary)
(update_b)-[:PROCESS]->(walker_b_boundary)
(update_s)-[:PROCESS]->(skyrms_boundary)
(success)-[:PROCESS]->(settlement:Sink)

// ── Neighborhood Poisoning (Attention Pattern Spread) ────────────────
//
// When a proposal fails, adjacent proposals get lighter updates.
// This formalizes the attention pattern: the query attends to nearby keys.
// Radius scales with gait (stand=0, trot=1, canter=2, gallop=3).

(neighborhood:Logic { op: "spread_rejection", radius: "gait_radius" })
(update_s)-[:PROCESS]->(neighborhood)
(neighborhood)-[:PROCESS]->(skyrms_boundary)

// ── Layer Norm (Void Decay) ──────────────────────────────────────────
//
// In transformers: LayerNorm stabilizes the residual stream.
// In void walking: decay prevents the boundary from saturating.

(decay_a:Logic { op: "void_decay", rate: "timescale" })
(decay_b:Logic { op: "void_decay", rate: "timescale" })
(decay_s:Logic { op: "void_decay", rate: "timescale" })

(walker_a_boundary)-[:PROCESS]->(decay_a)-[:PROCESS]->(walker_a_boundary)
(walker_b_boundary)-[:PROCESS]->(decay_b)-[:PROCESS]->(walker_b_boundary)
(skyrms_boundary)-[:PROCESS]->(decay_s)-[:PROCESS]->(skyrms_boundary)

// ── Feed-Forward (c3 Gait Adaptation) ────────────────────────────────
//
// In transformers: FFN = two linear layers with activation.
// In void walking: c3 = gait selection + eta/exploration update.
// The gait formalizes the temperature schedule. The FFN formalizes the adaptation.

(c1_a:Logic { op: "measure", metrics: "kurtosis,entropy,inverseBule" })
(c1_b:Logic { op: "measure", metrics: "kurtosis,entropy,inverseBule" })
(c1_s:Logic { op: "measure", metrics: "kurtosis,entropy,inverseBule" })

(self_attn_a)-[:PROCESS]->(c1_a)
(self_attn_b)-[:PROCESS]->(c1_b)
(cross_attn)-[:PROCESS]->(c1_s)

(c3_a:GradientStep { learningRate: "adaptive", parameterKey: "eta_a,exploration_a,gait_a" })
(c3_b:GradientStep { learningRate: "adaptive", parameterKey: "eta_b,exploration_b,gait_b" })
(c3_s:GradientStep { learningRate: "adaptive", parameterKey: "eta_s,exploration_s,gait_s" })

(c1_a)-[:PROCESS]->(c3_a)-[:PROCESS]->(walker_a_boundary)
(c1_b)-[:PROCESS]->(c3_b)-[:PROCESS]->(walker_b_boundary)
(c1_s)-[:PROCESS]->(c3_s)-[:PROCESS]->(skyrms_boundary)

// ── Output ───────────────────────────────────────────────────────────
//
// The output of one void transformer round is the updated void boundaries.
// They feed back into the next round. The "KV cache" formalizes the void.
// "Training" formalizes the mediation itself.
//
// The identification table:
//
// | Transformer          | Void Walking                              |
// |----------------------|-------------------------------------------|
// | Query                | Current proposal                          |
// | Key                  | Void boundary (rejection counts)          |
// | Value                | Complement weight exp(-eta * voidDensity) |
// | Attention score      | complementDistribution()                  |
// | Temperature          | 1/eta                                     |
// | Multi-head           | Multiple walkers                          |
// | Cross-attention      | Skyrms walker (gated by proposal void)    |
// | Residual stream      | Void boundary (accumulates across rounds) |
// | Layer norm           | Void decay                                |
// | Feed-forward         | c3 gait adaptation                        |
// | KV cache             | Accumulated rejection history             |
// | Token                | Interaction outcome                       |
// | Training             | The mediation itself                      |
(skyrms_boundary)-[:TUNNEL { condition: 'bounded-reject' }]->(void_attention_gg_trace:Trace)
(skyrms_boundary)-[:MEASURE { reason: 'topology-audit' }]->(void_attention_gg_trace:Trace)
