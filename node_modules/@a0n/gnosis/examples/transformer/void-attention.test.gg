// void-attention.test.gg -- Tests for the void walking transformer
//
// Verifies the structural identification:
//   complement distribution = softmax(-eta * voidCounts)
//   residual = void boundary accumulates
//   cross-attention = gated outer product
//   layer norm = void decay stabilizes
//
// Fork all tests → Race for failures → Fold verdict

(test_suite:Parameter { value: "void_attention_tests" })

// ── Test 1: Complement is Softmax ────────────────────────────────────

(test_complement:Logic { op: "assert_complement_is_softmax" })
(uniform_void:Parameter { value: "zeros" })
(non_uniform_void:Parameter { value: "asymmetric" })

(uniform_void)-[:PROCESS]->(test_complement)
(non_uniform_void)-[:PROCESS]->(test_complement)

// Invariant: complement sums to 1, all weights > 0
(complement_sum:Logic { op: "assert_sum_equals_one" })
(complement_positive:Logic { op: "assert_all_positive" })
(test_complement)-[:FORK]->(complement_sum | complement_positive)

// ── Test 2: Residual Accumulates ─────────────────────────────────────

(test_residual:Logic { op: "assert_void_monotone" })
(before_boundary:Parameter { value: "snapshot_before" })
(after_boundary:Parameter { value: "snapshot_after" })

(before_boundary | after_boundary)-[:FOLD]->(test_residual)

// Invariant: totalEntries(after) >= totalEntries(before)

// ── Test 3: Cross-Attention is Gated Product ─────────────────────────

(test_cross:Logic { op: "assert_gated_product" })
(marginal_a:Logic { op: "complement_distribution", walker: "a" })
(marginal_b:Logic { op: "complement_distribution", walker: "b" })
(gate:Logic { op: "complement_distribution", walker: "skyrms" })

(marginal_a | marginal_b)-[:FOLD { strategy: "outer_product" }]->(joint)
(joint | gate)-[:FOLD { strategy: "elementwise_multiply" }]->(gated)
(gated)-[:PROCESS]->(test_cross)

// Invariant: gated surface sums to 1, argmax matches expected nadir

// ── Test 4: Layer Norm Prevents Saturation ───────────────────────────

(test_decay:Logic { op: "assert_decay_stabilizes" })
(saturated_void:Parameter { value: "high_density" })
(decay_rate:Parameter { value: "0.01" })

(saturated_void | decay_rate)-[:FOLD]->(test_decay)

// Invariant: after decay, totalEntries < before

// ── Test 5: Gait Schedule Monotone ───────────────────────────────────

(test_gait:Logic { op: "assert_gait_progression" })
(round_5:Parameter { value: "5" })
(round_20:Parameter { value: "20" })
(round_50:Parameter { value: "50" })

(round_5 | round_20 | round_50)-[:FOLD { strategy: "sequence" }]->(test_gait)

// Invariant: gait(5)="trot", gait(20)="canter", gait(50)="gallop"

// ── Test 6: Neighborhood Poisoning Spreads ───────────────────────────

(test_neighborhood:Logic { op: "assert_neighborhood_spread" })
(center_rejection:Parameter { value: "[1,1]" })
(radius:Parameter { value: "2" })

(center_rejection | radius)-[:FOLD]->(test_neighborhood)

// Invariant: adjacent cells have positive void after center rejection

// ── Verdict ──────────────────────────────────────────────────────────

(complement_sum | complement_positive | test_residual | test_cross | test_decay | test_gait | test_neighborhood)-[:RACE { metric: "first_failure" }]->(verdict)

(pass:Result { kind: "ok", valueFrom: "all_passed" })
(fail:Result { kind: "err", errorFrom: "test_failure" })
(verdict)-[:FORK]->(pass | fail)
(verdict)-[:TUNNEL { condition: 'bounded-reject' }]->(void_attention_test_gg_trace:Trace)
(verdict)-[:MEASURE { reason: 'topology-audit' }]->(void_attention_test_gg_trace:Trace)
