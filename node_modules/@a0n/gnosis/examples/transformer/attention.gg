// attention.gg — Multi-Head Attention as a topology
//
// Attention is FORK → FOLD. Each head is a parallel universe
// that observes the sequence from a different subspace.
// The fold concatenates these observations back into one.
//
// β₁ = num_heads - 1 (the superposition during attention)

(query: Projection { dim: '64', role: 'Q' })
(key: Projection { dim: '64', role: 'K' })
(value: Projection { dim: '64', role: 'V' })

// QKV projection is a 3-way fork from the input
(input: Tensor)-[:FORK]->(query | key | value)

// Each head independently computes scaled dot-product attention
(head_0: ScaledDotProduct { d_k: '64' })
(head_1: ScaledDotProduct { d_k: '64' })
(head_2: ScaledDotProduct { d_k: '64' })
(head_3: ScaledDotProduct { d_k: '64' })
(head_4: ScaledDotProduct { d_k: '64' })
(head_5: ScaledDotProduct { d_k: '64' })
(head_6: ScaledDotProduct { d_k: '64' })
(head_7: ScaledDotProduct { d_k: '64' })

// Fork Q into heads — each head sees a different 64-dim slice
(query)-[:FORK]->(head_0 | head_1 | head_2 | head_3 | head_4 | head_5 | head_6 | head_7)

// Each head races K and V to compute attention scores
// (in practice, K and V are broadcast — topology models the dataflow)
(key)-[:PROCESS]->(head_0)
(key)-[:PROCESS]->(head_1)
(key)-[:PROCESS]->(head_2)
(key)-[:PROCESS]->(head_3)
(key)-[:PROCESS]->(head_4)
(key)-[:PROCESS]->(head_5)
(key)-[:PROCESS]->(head_6)
(key)-[:PROCESS]->(head_7)

(value)-[:PROCESS]->(head_0)
(value)-[:PROCESS]->(head_1)
(value)-[:PROCESS]->(head_2)
(value)-[:PROCESS]->(head_3)
(value)-[:PROCESS]->(head_4)
(value)-[:PROCESS]->(head_5)
(value)-[:PROCESS]->(head_6)
(value)-[:PROCESS]->(head_7)

// Fold all heads back — concat then linear projection
(head_0 | head_1 | head_2 | head_3 | head_4 | head_5 | head_6 | head_7)-[:FOLD { strategy: 'concat' }]->(concat_heads)
(output_projection: Linear { dim: '512' })
(concat_heads)-[:PROCESS]->(output_projection)
(output_projection)-[:PROCESS]->(attention_out)
(attention_out)-[:TUNNEL { condition: 'bounded-reject' }]->(attention_gg_trace:Trace)
(attention_out)-[:MEASURE { reason: 'topology-audit' }]->(attention_gg_trace:Trace)
