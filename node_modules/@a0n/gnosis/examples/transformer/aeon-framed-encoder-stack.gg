// aeon-framed-encoder-stack.gg — staged encoder companion for the Wallington Rotation

(frame_in: FlowFrame { role: 'input-sequence', frame_stages: '4' })
(rotation: RotationScheduler { schedule: 'wallington_rotation', stages: '4', chunks: '4' })
(chunk_a: EncoderChunk { ordinal: '0' })
(chunk_b: EncoderChunk { ordinal: '1' })
(chunk_c: EncoderChunk { ordinal: '2' })
(chunk_d: EncoderChunk { ordinal: '3' })
(stage_aligned: FlowFrame { role: 'rotated-chunks' })
(embed_stage: EncoderShard { stage: 'embedding', parameters: '2' })
(attn_stage: EncoderShard { stage: 'attention', parameters: '4' })
(attn_out: FlowFrame { role: 'attention-out' })
(residual_out: FlowFrame { role: 'residual-out' })
(ffn_stage: EncoderShard { stage: 'ffn', parameters: '4' })
(frame_out: FlowFrame { role: 'encoded-sequence' })

(frame_in)-[:PROCESS]->(rotation)
(rotation)-[:FORK { schedule: 'wallington_rotation' }]->(chunk_a | chunk_b | chunk_c | chunk_d)
(chunk_a | chunk_b | chunk_c | chunk_d)-[:FOLD { strategy: 'chunk-order' }]->(stage_aligned)
(stage_aligned)-[:PROCESS]->(embed_stage)
(embed_stage)-[:PROCESS]->(attn_stage)
(attn_stage)-[:PROCESS]->(attn_out)
(stage_aligned | attn_out)-[:SLIVER { mode: 'constructive' }]->(residual_out)
(residual_out)-[:PROCESS]->(ffn_stage)
(ffn_stage)-[:PROCESS]->(frame_out)
(frame_out)-[:TUNNEL { condition: 'bounded-reject' }]->(aeon_framed_encoder_stack_gg_trace:Trace)
(frame_out)-[:MEASURE { reason: 'topology-audit' }]->(aeon_framed_encoder_stack_gg_trace:Trace)
