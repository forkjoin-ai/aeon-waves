import Init

/-!
# State entropy reduction — a dissipation monovariant

Reducing a state's entropy by some amount is antitone and floored at zero.  The
finite core proves the dissipation laws: a reduction never raises entropy, two
reductions compose additively, entropy is floored at zero, and a reduction by the
full entropy reaches the ground state.

Init-only; every proof closes from `Nat` lemmas with no banned tactic on an open
goal.
-/

namespace Gnosis

/-- Reduce an entropy by `k` (floored at zero). -/
def reduceEntropy (entropy k : Nat) : Nat := entropy - k

/-- A reduction never raises entropy. -/
theorem reduce_le (entropy k : Nat) : reduceEntropy entropy k ≤ entropy :=
  Nat.sub_le entropy k

/-- **Antitone in the reduction amount:** reducing more leaves less entropy. -/
theorem reduce_antitone (entropy : Nat) {j k : Nat} (h : j ≤ k) :
    reduceEntropy entropy k ≤ reduceEntropy entropy j :=
  Nat.sub_le_sub_left h entropy

/-- Two reductions compose additively. -/
theorem reduce_compose (entropy j k : Nat) :
    reduceEntropy (reduceEntropy entropy j) k = reduceEntropy entropy (j + k) := by
  show (entropy - j) - k = entropy - (j + k)
  rw [Nat.sub_sub]

/-- Reducing by the full entropy reaches the ground state. -/
theorem reduce_to_ground (entropy : Nat) : reduceEntropy entropy entropy = 0 :=
  Nat.sub_self entropy

end Gnosis
