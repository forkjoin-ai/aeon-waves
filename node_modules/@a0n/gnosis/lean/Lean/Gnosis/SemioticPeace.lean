import Init

/-!
# Semiotic peace — confusion is heat, peace is the zero-deficit fixed point

Unresolved semiotic deficit dissipates as the heat of confusion; peace is the
fixed point where the deficit is zero.  The finite core proves: confusion heat is
non-negative, a positive deficit generates positive heat, accumulated context
reduces the deficit, sufficient context reaches peace (zero deficit), and peace is
a fixed point of the fold.

The original carried `ℝ` heat through a Mathlib web; here the finite core is
self-contained over `Nat`, every proof closing from `Init`.
-/

namespace Gnosis
namespace SemioticPeace

/-- A semiotic channel with thermodynamic parameters. -/
structure SemioticChannel where
  dimensions : Nat
  articulationStreams : Nat
  boltzmann : Nat
  temperature : Nat
  hStreamsPos : 0 < articulationStreams
  hkPos : 0 < boltzmann
  hTPos : 0 < temperature

/-- The semiotic deficit. -/
def semioticDeficit (ch : SemioticChannel) : Nat :=
  (ch.dimensions - 1) - (ch.articulationStreams - 1)

/-- The heat of confusion: proportional to the deficit. -/
def confusionHeat (ch : SemioticChannel) : Nat :=
  ch.boltzmann * ch.temperature * semioticDeficit ch

/-- The fold reduces the deficit by accumulated context. -/
def semioticFold (ch : SemioticChannel) (context : Nat) : Nat := semioticDeficit ch - context

/-- **Confusion heat is non-negative.** -/
theorem confusion_heat_nonneg (ch : SemioticChannel) : 0 ≤ confusionHeat ch := Nat.zero_le _

/-- **A positive deficit generates positive heat.** -/
theorem confusion_generates_heat (ch : SemioticChannel) (h : 0 < semioticDeficit ch) :
    0 < confusionHeat ch :=
  Nat.mul_pos (Nat.mul_pos ch.hkPos ch.hTPos) h

/-- Context reduces the residual deficit (the path to peace). -/
theorem peace_context_reduces (ch : SemioticChannel) (context : Nat) :
    semioticFold ch context ≤ semioticDeficit ch :=
  Nat.sub_le _ context

/-- **Peace is reachable:** sufficient context drives the deficit to zero. -/
theorem peace_sufficient_context (ch : SemioticChannel) (context : Nat)
    (h : semioticDeficit ch ≤ context) : semioticFold ch context = 0 :=
  Nat.sub_eq_zero_of_le h

/-- **Peace is a fixed point:** at zero deficit the fold stays at zero. -/
theorem peace_fixed_point (ch : SemioticChannel) (h : semioticDeficit ch = 0) (context : Nat) :
    semioticFold ch context = 0 := by
  show semioticDeficit ch - context = 0
  rw [h]
  exact Nat.zero_sub context

/-- **Hope.** Even speech (one stream) reaches peace once its `dimensions - 1`
    deficit is matched by context. -/
theorem hope (ch : SemioticChannel) (hSpeech : ch.articulationStreams = 1) :
    semioticFold ch (ch.dimensions - 1) = 0 := by
  apply peace_sufficient_context
  show (ch.dimensions - 1) - (ch.articulationStreams - 1) ≤ ch.dimensions - 1
  rw [hSpeech]
  exact Nat.le_of_eq (Nat.sub_zero _)

end SemioticPeace
end Gnosis
