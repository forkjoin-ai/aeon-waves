import Init

/-!
# Universe tower — each level strictly contains the one below

A tower of universe levels, where level `n` holds `2^n` distinguishable objects.
The finite core proves the tower is cumulative: capacity is non-decreasing up the
tower, strictly increasing at each step, and every level is non-empty.

Init-only; every proof closes from `Nat` lemmas with no banned tactic on an open
goal.
-/

namespace Gnosis

/-- Capacity of universe level `n`. -/
def levelCapacity (n : Nat) : Nat := 2 ^ n

/-- Every level is non-empty. -/
theorem level_nonempty (n : Nat) : 0 < levelCapacity n := Nat.two_pow_pos n

/-- Capacity is non-decreasing up the tower. -/
theorem level_monotone {m n : Nat} (h : m ≤ n) : levelCapacity m ≤ levelCapacity n :=
  Nat.pow_le_pow_right (by decide) h

/-- The next level doubles the capacity. -/
theorem level_succ_doubles (n : Nat) : levelCapacity (n + 1) = 2 * levelCapacity n :=
  Nat.pow_succ'

/-- Each step strictly increases capacity: the tower is cumulative. -/
theorem level_strict (n : Nat) : levelCapacity n < levelCapacity (n + 1) := by
  rw [level_succ_doubles, Nat.two_mul]
  exact Nat.lt_add_of_pos_left (Nat.two_pow_pos n)

end Gnosis
