import Init

/-!
# State resistance topology — series resistance grows monotonically

Resistors placed in series add their resistances.  The finite core proves the
monovariant of a series chain: total resistance is additive, dominates every
component, and strictly increases when a positive resistor is added.

Init-only; every proof closes from `Nat`/`List` lemmas with no banned tactic on an
open goal.
-/

namespace Gnosis

/-- Total series resistance of a chain. -/
def seriesResistance : List Nat → Nat
  | [] => 0
  | r :: rs => r + seriesResistance rs

/-- The empty chain has zero resistance. -/
theorem series_nil : seriesResistance [] = 0 := rfl

/-- Adding a resistor adds its resistance. -/
theorem series_cons (r : Nat) (rs : List Nat) :
    seriesResistance (r :: rs) = r + seriesResistance rs := rfl

/-- Each resistor bounds the series total below. -/
theorem component_le_series (r : Nat) (rs : List Nat) :
    r ≤ seriesResistance (r :: rs) := by
  rw [series_cons]; exact Nat.le_add_right _ _

/-- Series resistance never decreases when a resistor is added. -/
theorem series_monotone (r : Nat) (rs : List Nat) :
    seriesResistance rs ≤ seriesResistance (r :: rs) := by
  rw [series_cons]; exact Nat.le_add_left _ _

/-- **Strict growth.** A positive resistor strictly raises the series total. -/
theorem series_strict (r : Nat) (rs : List Nat) (hr : 0 < r) :
    seriesResistance rs < seriesResistance (r :: rs) := by
  rw [series_cons]; exact Nat.lt_add_of_pos_left hr

end Gnosis
