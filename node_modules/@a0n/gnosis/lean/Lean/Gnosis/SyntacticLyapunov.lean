import Init

/-!
# Syntactic Lyapunov — an affine drift program with a verified monovariant

An affine drift program is a queue whose state evolves by `x ↦ x + arrival -
service`.  When the service rate strictly dominates the arrival rate the **drift
gap** `service - arrival` is positive, and `V(x) = x` is a Lyapunov function:
outside the small set `{0, …, ventThreshold}` each step lowers `V` by exactly the
drift gap, so the state is driven monotonically toward the floor.

The original development stated the Foster–Lyapunov condition over `ℝ` with
measure-theoretic ergodicity certificates.  This module keeps the finite, decidable
core: the drift gap is a positive `Nat`, the one-step map is a monovariant on `V`,
and iterating it never increases `V`.  Every proof closes from `Init`; no
`omega`/`simp`/`decide` is used on an open goal.
-/

namespace Gnosis

/-- An affine drift program: a queue with arrival and service rates, a vent
    threshold delimiting the small set, and a bounded state space. -/
structure AffineDriftProgram where
  /-- Maximum state value. -/
  maxState : Nat
  /-- Arrival rate per step. -/
  arrivalRate : Nat
  /-- Service rate per step. -/
  serviceRate : Nat
  /-- States `≤ ventThreshold` form the small set. -/
  ventThreshold : Nat
  /-- Stability: service strictly dominates arrival. -/
  hStable : arrivalRate < serviceRate
  /-- The small set fits strictly inside the state space. -/
  hThresholdBound : ventThreshold < maxState

/-- The drift gap: the per-step pull toward the floor. -/
def AffineDriftProgram.driftGap (p : AffineDriftProgram) : Nat :=
  p.serviceRate - p.arrivalRate

/-- One affine step outside the small set lowers `V(x) = x` by the drift gap
    (clamped at the floor). -/
def AffineDriftProgram.nextState (p : AffineDriftProgram) (x : Nat) : Nat :=
  x - p.driftGap

/-- Iterate the affine step `k` times. -/
def AffineDriftProgram.iterate (p : AffineDriftProgram) : Nat → Nat → Nat
  | 0,     x => x
  | k + 1, x => p.nextState (p.iterate k x)

/-- **The drift gap is strictly positive** — the stability condition made
    quantitative. -/
theorem drift_gap_positive (p : AffineDriftProgram) : 0 < p.driftGap :=
  Nat.sub_pos_of_lt p.hStable

/-- The drift gap is exactly `service - arrival`. -/
theorem drift_gap_eq (p : AffineDriftProgram) :
    p.driftGap = p.serviceRate - p.arrivalRate := rfl

/-- **`V` is a monovariant.** One step never increases the Lyapunov value. -/
theorem step_decreases_V (p : AffineDriftProgram) (x : Nat) :
    p.nextState x ≤ x :=
  Nat.sub_le x p.driftGap

/-- **Exact drift above the floor.** When the state exceeds the drift gap, one
    step lowers `V` by exactly the drift gap. -/
theorem drift_exact_above_floor (p : AffineDriftProgram) (x : Nat)
    (h : p.driftGap ≤ x) : x - p.nextState x = p.driftGap :=
  Nat.sub_sub_self h

/-- **The small set fits inside the state space.** -/
theorem small_set_bounded (p : AffineDriftProgram) :
    p.ventThreshold + 1 ≤ p.maxState :=
  p.hThresholdBound

/-- The small set is non-empty (it contains state `0`). -/
theorem small_set_nonempty (p : AffineDriftProgram) :
    0 < p.ventThreshold + 1 :=
  Nat.succ_pos p.ventThreshold

/-- **Iterating never increases `V`.** Any number of affine steps keeps the
    Lyapunov value at or below its start — the certified descent. -/
theorem iterate_decreases_V (p : AffineDriftProgram) :
    ∀ (k x : Nat), p.iterate k x ≤ x
  | 0,     x => Nat.le_refl x
  | k + 1, x =>
      Nat.le_trans (Nat.sub_le (p.iterate k x) p.driftGap)
        (iterate_decreases_V p k x)

end Gnosis
