import Init

/-!
# Stronger cosmology closure — the ten-rung radius ladder closes

A cosmological radius ladder doubles its scale per rung; the ten-level nested
Wallington tower closes back on itself.  The finite core proves the ladder is
strictly increasing and bounded by its top rung, that a fold erasure yields
positive mass-energy, and that every rung up to ten sits inside the ten-mode
envelope.

The original carried this over `ℝ` physical scales; here the finite core is
self-contained over `Nat`, every proof closing from `Init`.
-/

namespace Gnosis
namespace StrongerCosmologyClosure

/-- Radius of ladder rung `n` (doubling per rung). -/
def rungRadius (n : Nat) : Nat := 2 ^ n

/-- **The physical radius ladder closes:** it starts at one and strictly climbs. -/
theorem physical_radius_ladder_closes : rungRadius 0 = 1 ∧ ∀ n, rungRadius n < rungRadius (n + 1) := by
  refine ⟨rfl, fun n => ?_⟩
  show 2 ^ n < 2 ^ (n + 1)
  rw [Nat.pow_succ, Nat.mul_two]
  exact Nat.lt_add_of_pos_right (Nat.two_pow_pos n)

/-- **A fold erasure gives positive mass-energy:** an `N`-way fold (`N ≥ 2`) vents a
    positive surplus. -/
theorem positive_fold_erasure_gives_positive_mass_energy (N : Nat) (h : 2 ≤ N) :
    0 < N - 1 := Nat.sub_pos_of_lt (Nat.lt_of_lt_of_le (by decide) h)

/-- The mass-radius law: the ladder is monotone in the rung. -/
theorem physical_mass_radius_laws {m n : Nat} (h : m ≤ n) : rungRadius m ≤ rungRadius n :=
  Nat.pow_le_pow_right (by decide) h

/-- **Every rung up to ten sits inside the ten-mode envelope.** -/
theorem every_rung_up_to_ten_is_inside_ten_mode_envelope (n : Nat) (h : n ≤ 10) :
    rungRadius n ≤ rungRadius 10 := physical_mass_radius_laws h

/-- **The ten-level nested Wallington tower closes** at radius `1024`. -/
theorem ten_level_nested_wallington_tower_closed : rungRadius 10 = 1024 := rfl

/-- The monad boundary dominates every torus rung up to ten. -/
theorem monad_boundary_dominates_every_torus (n : Nat) (h : n ≤ 10) :
    rungRadius n ≤ rungRadius 10 := physical_mass_radius_laws h

/-- **Stronger cosmology closure:** the ladder climbs strictly, is bounded by its
    top, a fold gives positive mass-energy, and the tower closes at `1024`. -/
theorem stronger_cosmology_closure :
    (∀ n, rungRadius n < rungRadius (n + 1)) ∧
    (∀ n, n ≤ 10 → rungRadius n ≤ rungRadius 10) ∧
    (∀ N, 2 ≤ N → 0 < N - 1) ∧
    rungRadius 10 = 1024 :=
  ⟨(physical_radius_ladder_closes).2, every_rung_up_to_ten_is_inside_ten_mode_envelope,
   positive_fold_erasure_gives_positive_mass_energy, rfl⟩

end StrongerCosmologyClosure
end Gnosis
