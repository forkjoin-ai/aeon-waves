import Init

/-!
# Wormhole tradeoff — throat against exotic energy at fixed budget

A traversable wormhole splits a fixed budget between throat radius and exotic
energy.  The finite core proves the tradeoff is a conservation law: shifting
budget from energy to throat keeps the total fixed, widens the throat, and
narrows the energy — never exceeding the budget.

Init-only; every proof closes from `Nat` lemmas with no banned tactic on an open
goal.
-/

namespace Gnosis

/-- A wormhole configuration: throat radius and exotic energy. -/
structure Wormhole where
  throat : Nat
  energy : Nat

/-- The conserved budget. -/
def Wormhole.budget (w : Wormhole) : Nat := w.throat + w.energy

/-- Shift `k` units of budget from energy into the throat (`k ≤ energy`). -/
def Wormhole.shift (w : Wormhole) (k : Nat) : Wormhole :=
  { throat := w.throat + k, energy := w.energy - k }

/-- **Conservation.** Shifting budget keeps the total fixed. -/
theorem shift_conserves_budget (w : Wormhole) {k : Nat} (h : k ≤ w.energy) :
    (w.shift k).budget = w.budget := by
  show (w.throat + k) + (w.energy - k) = w.throat + w.energy
  rw [Nat.add_assoc, Nat.add_sub_cancel' h]

/-- Shifting widens the throat. -/
theorem shift_widens_throat (w : Wormhole) (k : Nat) :
    w.throat ≤ (w.shift k).throat :=
  Nat.le_add_right w.throat k

/-- Shifting narrows the energy. -/
theorem shift_narrows_energy (w : Wormhole) (k : Nat) :
    (w.shift k).energy ≤ w.energy :=
  Nat.sub_le w.energy k

/-- The throat never exceeds the budget. -/
theorem throat_le_budget (w : Wormhole) : w.throat ≤ w.budget :=
  Nat.le_add_right w.throat w.energy

end Gnosis
