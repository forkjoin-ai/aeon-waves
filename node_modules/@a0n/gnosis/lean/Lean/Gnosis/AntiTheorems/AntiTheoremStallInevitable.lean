import Init

/-!
# Anti-theorem: stall is inevitable for an unbounded loop

A refutation witness.  An unbounded loop has no decreasing measure — its iteration
count is invariant under stepping — so a non-empty loop never reaches the halted
state.  The finite core proves the count is a fixed point of the step and, from
that, that termination is impossible for a positive start.

Init-only; every proof closes from `Nat` lemmas with no banned tactic on an open
goal.
-/

namespace Gnosis

/-- An unbounded loop carrying an iteration count. -/
structure UnboundedLoop where
  iterations : Nat

/-- The step of an unbounded loop makes no progress. -/
def UnboundedLoop.step (l : UnboundedLoop) : UnboundedLoop := { iterations := l.iterations }

/-- Iterate the (progress-free) step `k` times. -/
def UnboundedLoop.run : Nat → UnboundedLoop → UnboundedLoop
  | 0,     l => l
  | k + 1, l => (UnboundedLoop.run k l).step

/-- The iteration count is invariant under any number of steps. -/
theorem count_invariant : ∀ (k : Nat) (l : UnboundedLoop),
    (UnboundedLoop.run k l).iterations = l.iterations
  | 0,     _ => rfl
  | k + 1, l => count_invariant k l

/-- **Stall is inevitable.** A non-empty unbounded loop never reaches zero
    iterations, no matter how many steps run. -/
theorem stall_inevitable (l : UnboundedLoop) (h : 0 < l.iterations) (k : Nat) :
    (UnboundedLoop.run k l).iterations ≠ 0 := by
  rw [count_invariant]
  exact Nat.ne_of_gt h

end Gnosis
