import Init

/-!
# Surface reduction — the Seven Laws reduce to a few generators

Hundreds of domain theorems reduce to a handful of generators: Buleyean
positivity, strict concentration, the weight-formula bounds, and the `Nat` facts
`a - a = 0` and `c < d → 0 < d - c`.  The finite core proves each generating law
and exhibits the two arithmetic facts that the whole surface stands on.

The original built this over `BuleyeanSpace` from a Mathlib web; here the finite
core is self-contained over `Nat`, every proof closing from `Init`.
-/

namespace Gnosis
namespace SurfaceReduction

/-- A Buleyean space: per-choice void boundary over a number of rounds. -/
structure BuleyeanSpace where
  rounds : Nat
  voidBoundary : Nat → Nat
  bounded : ∀ i, voidBoundary i ≤ rounds

/-- The complement weight of a choice. -/
def BuleyeanSpace.weight (bs : BuleyeanSpace) (i : Nat) : Nat :=
  bs.rounds - bs.voidBoundary i + 1

/-- **Generator — positivity.** Every weight is positive. -/
theorem buleyean_positivity (bs : BuleyeanSpace) (i : Nat) : 0 < bs.weight i :=
  Nat.succ_pos _

/-- **Generator — strict concentration.** Fewer rejections give strictly more weight. -/
theorem buleyean_strict_concentration (bs : BuleyeanSpace) (i j : Nat)
    (h : bs.voidBoundary i < bs.voidBoundary j) : bs.weight j < bs.weight i := by
  show bs.rounds - bs.voidBoundary j + 1 < bs.rounds - bs.voidBoundary i + 1
  apply Nat.add_lt_add_right
  have hiR : bs.voidBoundary i < bs.rounds := Nat.lt_of_lt_of_le h (bs.bounded j)
  have step : bs.rounds - bs.voidBoundary j ≤ bs.rounds - (bs.voidBoundary i + 1) :=
    Nat.sub_le_sub_left h bs.rounds
  rw [Nat.sub_add_eq] at step
  exact Nat.lt_of_le_of_lt step (Nat.sub_lt (Nat.sub_pos_of_lt hiR) (by decide))

/-- **Law 1** is positivity. -/
theorem law1_is_positivity (bs : BuleyeanSpace) (i : Nat) : 0 < bs.weight i :=
  buleyean_positivity bs i

/-- **Law 1 (negation form):** no weight is zero. -/
theorem law1_negation_form (bs : BuleyeanSpace) (i : Nat) : ¬ (bs.weight i = 0) :=
  fun h => absurd (h ▸ buleyean_positivity bs i) (by decide)

/-- **Law 2** is strict concentration. -/
theorem law2_is_concentration_strict (bs : BuleyeanSpace) (i j : Nat)
    (h : bs.voidBoundary i < bs.voidBoundary j) : bs.weight j < bs.weight i :=
  buleyean_strict_concentration bs i j h

/-- **Law 3** is the weight-formula bounds `1 ≤ weight ≤ rounds + 1`. -/
theorem law3_is_formula_bounds (bs : BuleyeanSpace) (i : Nat) :
    1 ≤ bs.weight i ∧ bs.weight i ≤ bs.rounds + 1 :=
  ⟨buleyean_positivity bs i,
   Nat.add_le_add_right (Nat.sub_le bs.rounds (bs.voidBoundary i)) 1⟩

/-- **Law 4** is a subtraction: more dimensions than channels gives a positive deficit. -/
theorem law4_is_subtraction (dims channels : Nat) (h : channels < dims) :
    0 < dims - channels := Nat.sub_pos_of_lt h

/-- **The reduction thesis.** Every law follows from the generators plus the two
    `Nat` facts `a - a = 0` (termination) and `c < d → 0 < d - c` (deficit). -/
theorem surface_reduction_master (bs : BuleyeanSpace) (i : Nat) (a c d : Nat) (h : c < d) :
    0 < bs.weight i ∧
    (1 ≤ bs.weight i ∧ bs.weight i ≤ bs.rounds + 1) ∧
    a - a = 0 ∧
    0 < d - c :=
  ⟨law1_is_positivity bs i, law3_is_formula_bounds bs i, Nat.sub_self a,
   law4_is_subtraction d c h⟩

end SurfaceReduction
end Gnosis
