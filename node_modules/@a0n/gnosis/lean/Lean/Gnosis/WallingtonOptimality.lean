import Init

/-!
# Wallington optimality — the rotation schedule dominates sequential

A fork/race/fold DAG runs `numStages` sequential stages, each forking into
`numPaths` parallel branches.  The Wallington rotation runs the paths in parallel,
achieving makespan `numStages · maxStageTime` (the critical path).  The finite core
proves the rotation is admissible, its makespan is exactly `numPaths` times smaller
than the sequential schedule, it strictly dominates whenever there is real
parallelism, and its speedup equals `β₁ + 1`.

The original used `ring`/`omega`; this restoration closes from `Init`.
-/

namespace Gnosis

/-- A fork/race/fold DAG. -/
structure ForkRaceFoldDAG where
  numStages : Nat
  numPaths : Nat
  maxStageTime : Nat
  hStagesPos : 0 < numStages
  hPathsPos : 0 < numPaths
  hTimePos : 0 < maxStageTime

/-- β₁ of the DAG: independent cycles `numPaths - 1`. -/
def ForkRaceFoldDAG.beta1 (dag : ForkRaceFoldDAG) : Nat := dag.numPaths - 1

/-- Sequential makespan: paths serialized per stage. -/
def sequentialMakespan (dag : ForkRaceFoldDAG) : Nat :=
  dag.numStages * dag.numPaths * dag.maxStageTime

/-- Rotation makespan: paths parallel per stage (the critical path). -/
def rotationMakespan (dag : ForkRaceFoldDAG) : Nat := dag.numStages * dag.maxStageTime

/-- Sequential resources: one worker. -/
def sequentialResources : Nat := 1

/-- Rotation resources: `numPaths` concurrent workers. -/
def rotationResources (dag : ForkRaceFoldDAG) : Nat := dag.numPaths

/-- Speedup factor: `numPaths`. -/
def speedupFactor (dag : ForkRaceFoldDAG) : Nat := dag.numPaths

/-- **Admissibility.** The rotation makespan is positive (and finite). -/
theorem rotation_admissible (dag : ForkRaceFoldDAG) : 0 < rotationMakespan dag :=
  Nat.mul_pos dag.hStagesPos dag.hTimePos

/-- The rotation makespan is the critical path. -/
theorem rotation_makespan_bound (dag : ForkRaceFoldDAG) :
    rotationMakespan dag = dag.numStages * dag.maxStageTime := rfl

/-- The sequential makespan is `numPaths` times the rotation makespan. -/
theorem sequential_rotation_ratio (dag : ForkRaceFoldDAG) :
    sequentialMakespan dag = dag.numPaths * rotationMakespan dag := by
  show dag.numStages * dag.numPaths * dag.maxStageTime
    = dag.numPaths * (dag.numStages * dag.maxStageTime)
  rw [Nat.mul_comm dag.numStages dag.numPaths, Nat.mul_assoc]

/-- **Domination.** With real parallelism the rotation is strictly faster. -/
theorem rotation_dominates_sequential (dag : ForkRaceFoldDAG) (hParallel : 2 ≤ dag.numPaths) :
    rotationMakespan dag < sequentialMakespan dag := by
  rw [sequential_rotation_ratio]
  have h1 : 1 < dag.numPaths := Nat.lt_of_lt_of_le (by decide) hParallel
  calc rotationMakespan dag = 1 * rotationMakespan dag := (Nat.one_mul _).symm
    _ < dag.numPaths * rotationMakespan dag :=
        Nat.mul_lt_mul_of_pos_right h1 (rotation_admissible dag)

/-- The speedup factor is exactly `numPaths`. -/
theorem rotation_speedup_exact (dag : ForkRaceFoldDAG)
    (hMakespanPos : 0 < rotationMakespan dag) :
    sequentialMakespan dag / rotationMakespan dag = dag.numPaths := by
  rw [sequential_rotation_ratio, Nat.mul_comm dag.numPaths (rotationMakespan dag)]
  exact Nat.mul_div_cancel_left dag.numPaths hMakespanPos

/-- **Pareto optimality.** The rotation trades more resources for strictly lower
    makespan. -/
theorem rotation_pareto_schedule (dag : ForkRaceFoldDAG) (hParallel : 2 ≤ dag.numPaths) :
    sequentialResources < rotationResources dag ∧
    rotationMakespan dag < sequentialMakespan dag :=
  ⟨Nat.lt_of_lt_of_le (by decide) hParallel, rotation_dominates_sequential dag hParallel⟩

/-- The speedup equals the topological deficit reduction plus one: `β₁ + 1`. -/
theorem rotation_deficit_correlation (dag : ForkRaceFoldDAG) (hParallel : 1 ≤ dag.numPaths) :
    speedupFactor dag = dag.beta1 + 1 :=
  (Nat.sub_add_cancel hParallel).symm

end Gnosis
