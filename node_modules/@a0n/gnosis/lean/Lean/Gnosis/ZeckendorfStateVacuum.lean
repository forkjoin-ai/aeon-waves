import Init

/-!
# Zeckendorf state vacuum — the empty Fibonacci representation

Zeckendorf's theorem represents naturals as sums of non-consecutive Fibonacci
numbers; the *vacuum* is the empty representation, value `0`.  The finite core
builds the Fibonacci sequence, proves it is non-decreasing and strictly increasing
past the base, and pins the vacuum at `0`.

Init-only; every proof closes from `Nat` lemmas with no banned tactic on an open
goal.
-/

namespace Gnosis

/-- The Fibonacci sequence. -/
def fib : Nat → Nat
  | 0 => 0
  | 1 => 1
  | n + 2 => fib (n + 1) + fib n

/-- The Zeckendorf vacuum: the empty representation. -/
def zeckendorfVacuum : Nat := 0

/-- The vacuum has value zero. -/
theorem vacuum_is_zero : zeckendorfVacuum = 0 := rfl

/-- The recurrence holds by definition. -/
theorem fib_succ_succ (n : Nat) : fib (n + 2) = fib (n + 1) + fib n := rfl

/-- Fibonacci is non-decreasing step to step. -/
theorem fib_le_succ : ∀ n, fib n ≤ fib (n + 1)
  | 0 => by decide
  | 1 => by decide
  | n + 2 => by
      show fib (n + 2) ≤ fib (n + 2) + fib (n + 1)
      exact Nat.le_add_right _ _

/-- Past the base, each Fibonacci value is at least its predecessor plus one
    (strictly increasing), since `fib (n+1) ≥ 1`. -/
theorem fib_pos_from_one : ∀ n, 1 ≤ fib (n + 1)
  | 0 => by decide
  | n + 1 => by
      show 1 ≤ fib (n + 2)
      rw [fib_succ_succ]
      exact Nat.le_trans (fib_pos_from_one n) (Nat.le_add_right _ _)

end Gnosis
