import Init

/-!
# Contrarian memory thrashing efficiency — accesses are conserved

A contrarian look at cache thrashing: hits and misses partition every access.  The
finite core proves the conservation — hits plus misses equal accesses, hits never
exceed accesses, and a thrash-free run (no misses) is all hits.

Init-only; every proof closes from `Nat` lemmas with no banned tactic on an open
goal.
-/

namespace Gnosis

/-- A cache run: hits and misses. -/
structure CacheRun where
  hits : Nat
  misses : Nat

/-- Total accesses. -/
def CacheRun.accesses (r : CacheRun) : Nat := r.hits + r.misses

/-- **Conservation.** Hits and misses partition the accesses. -/
theorem access_conservation (r : CacheRun) : r.hits + r.misses = r.accesses := rfl

/-- Hits never exceed accesses. -/
theorem hits_le_accesses (r : CacheRun) : r.hits ≤ r.accesses :=
  Nat.le_add_right r.hits r.misses

/-- A thrash-free run is all hits. -/
theorem no_misses_all_hits (r : CacheRun) (h : r.misses = 0) : r.accesses = r.hits := by
  show r.hits + r.misses = r.hits
  rw [h, Nat.add_zero]

/-- Every miss is a lost access relative to a perfect run. -/
theorem misses_le_accesses (r : CacheRun) : r.misses ≤ r.accesses :=
  Nat.le_add_left r.misses r.hits

end Gnosis
