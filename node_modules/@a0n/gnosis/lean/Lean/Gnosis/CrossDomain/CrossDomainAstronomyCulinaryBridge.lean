import Init

/-!
# Astronomy ↔ culinary bridge — stellar temperature is flavor intensity

A correspondence carrying a star's temperature to a flavor intensity.  The finite
core proves the bridge preserves the measure, is monotone (a hotter star yields a
stronger flavor), and is strictly monotone on a genuine temperature increase.

Init-only; every proof closes from `Nat` lemmas with no banned tactic on an open
goal.
-/

namespace Gnosis

/-- A star carrying a temperature. -/
structure Star where
  temperature : Nat

/-- The culinary image: flavor intensity equals temperature. -/
def Star.flavorIntensity (s : Star) : Nat := s.temperature

/-- The bridge preserves the measure. -/
theorem flavor_preserves (s : Star) : s.flavorIntensity = s.temperature := rfl

/-- A hotter star yields a stronger flavor. -/
theorem flavor_monotone {a b : Nat} (h : a ≤ b) :
    (Star.mk a).flavorIntensity ≤ (Star.mk b).flavorIntensity := h

/-- A strictly hotter star yields a strictly stronger flavor. -/
theorem flavor_strict {a b : Nat} (h : a < b) :
    (Star.mk a).flavorIntensity < (Star.mk b).flavorIntensity := h

end Gnosis
