import Init

/-!
# Linguistics ↔ thermodynamics bridge — lexical decay is entropy decay

A correspondence carrying lexical decay to thermodynamic decay through their shared
entropy.  The finite core proves the bridge preserves entropy, is monotone, and is
additive — composing two decays adds their entropies on both sides of the bridge.

Init-only; every proof closes from `Nat` lemmas with no banned tactic on an open
goal.
-/

namespace Gnosis

/-- A lexical decay carrying an entropy. -/
structure LexicalDecay where
  entropy : Nat

/-- The thermodynamic image of a lexical decay. -/
def LexicalDecay.toThermodynamic (l : LexicalDecay) : Nat := l.entropy

/-- The bridge preserves entropy. -/
theorem decay_preserves_entropy (l : LexicalDecay) : l.toThermodynamic = l.entropy := rfl

/-- The bridge is monotone. -/
theorem decay_monotone {a b : Nat} (h : a ≤ b) :
    (LexicalDecay.mk a).toThermodynamic ≤ (LexicalDecay.mk b).toThermodynamic := h

/-- **Additivity.** Composing two decays adds their entropies across the bridge. -/
theorem decay_additive (a b : LexicalDecay) :
    (LexicalDecay.mk (a.entropy + b.entropy)).toThermodynamic =
      a.toThermodynamic + b.toThermodynamic := rfl

end Gnosis
