import Init

/-!
# Trade topology — tariffs are deficits, free trade is optimal

A tariff blocks trade paths, creating a deficit; free trade (no blocked paths) is
deficit-free and optimal.  The finite core proves: a positive block is a positive
deficit, free trade has zero deficit, tariff waste is monotone in blocked paths,
and free trade strictly beats any genuine tariff.

The original carried an `ℕ`/Mathlib deficit; here the finite core is self-contained
over `Nat`, every proof closing from `Init`.
-/

namespace Gnosis
namespace TradeTopology

/-- A tariff blocking some of the trade network's paths. -/
structure Tariff where
  totalPaths : Nat
  blockedPaths : Nat
  hBounded : blockedPaths ≤ totalPaths

/-- The deficit a tariff imposes: the blocked paths. -/
def Tariff.deficit (t : Tariff) : Nat := t.blockedPaths

/-- The open paths that still carry trade. -/
def Tariff.openPaths (t : Tariff) : Nat := t.totalPaths - t.blockedPaths

/-- **A tariff is suboptimal:** any block is a positive deficit. -/
theorem tariff_suboptimal (t : Tariff) (hBlocked : 0 < t.blockedPaths) : 0 < t.deficit :=
  hBlocked

/-- **Free trade has zero deficit.** -/
theorem free_trade_zero_deficit (t : Tariff) (hFree : t.blockedPaths = 0) : t.deficit = 0 :=
  hFree

/-- **Tariff waste is monotone** in the blocked-path count. -/
theorem tariff_waste_monotone (total : Nat) {b1 b2 : Nat} (h1 : b1 ≤ total) (h2 : b2 ≤ total)
    (h : b1 ≤ b2) : (Tariff.mk total b1 h1).deficit ≤ (Tariff.mk total b2 h2).deficit := h

/-- **Free trade is optimal:** with nothing blocked, all paths stay open. -/
theorem free_trade_optimal (t : Tariff) (hFree : t.blockedPaths = 0) :
    t.openPaths = t.totalPaths := by
  show t.totalPaths - t.blockedPaths = t.totalPaths
  rw [hFree, Nat.sub_zero]

/-- A tariff that blocks something strictly narrows the open paths (generates
    deadweight). -/
theorem tariff_generates_heat (t : Tariff) (hBlocked : 0 < t.blockedPaths)
    (hSome : 0 < t.totalPaths) : t.openPaths < t.totalPaths := by
  show t.totalPaths - t.blockedPaths < t.totalPaths
  exact Nat.sub_lt hSome hBlocked

end TradeTopology
end Gnosis
