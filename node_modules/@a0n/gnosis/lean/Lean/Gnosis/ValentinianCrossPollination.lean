import Init

/-!
# Valentinian cross-pollination — syzygy of aeons

In the Valentinian system aeons pair into syzygies.  Cross-pollinating two aeons
combines their fullness additively.  The finite core proves the pairing is
symmetric, associative, and never diminishes either partner's fullness.

Init-only; every proof closes from `Nat` lemmas with no banned tactic on an open
goal.
-/

namespace Gnosis

/-- An aeon, summarized by its fullness (pleromatic charge). -/
structure Aeon where
  fullness : Nat

/-- The syzygy of two aeons. -/
def Aeon.syzygy (a b : Aeon) : Aeon := { fullness := a.fullness + b.fullness }

/-- Syzygy combines fullness additively. -/
theorem syzygy_fullness (a b : Aeon) : (a.syzygy b).fullness = a.fullness + b.fullness := rfl

/-- The syzygy is symmetric in fullness. -/
theorem syzygy_symm (a b : Aeon) : (a.syzygy b).fullness = (b.syzygy a).fullness :=
  Nat.add_comm _ _

/-- The syzygy is associative in fullness. -/
theorem syzygy_assoc (a b c : Aeon) :
    ((a.syzygy b).syzygy c).fullness = (a.syzygy (b.syzygy c)).fullness :=
  Nat.add_assoc a.fullness b.fullness c.fullness

/-- A syzygy never diminishes a partner's fullness. -/
theorem syzygy_ge_left (a b : Aeon) : a.fullness ≤ (a.syzygy b).fullness :=
  Nat.le_add_right a.fullness b.fullness

end Gnosis
