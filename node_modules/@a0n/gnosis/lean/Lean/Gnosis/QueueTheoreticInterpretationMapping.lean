import Init

/-!
# Queue-theoretic interpretation mapping — interpretations are Jackson queues

An interpretation maps to a Jackson network of per-station queue depths; the system
load is the total depth.  The finite core proves the load is additive across
station concatenation, dominates any sub-network, and is invariant under reordering.

Init-only; every proof closes from `Nat`/`List` lemmas with no banned tactic on an
open goal.
-/

namespace Gnosis

/-- A Jackson network: per-station queue depths. -/
structure JacksonNetwork where
  queues : List Nat

/-- The system load: total queue depth. -/
def JacksonNetwork.load (n : JacksonNetwork) : Nat := n.queues.foldr (· + ·) 0

/-- The interpretation maps to the queue list. -/
theorem interpretation_maps_to_queues (n : JacksonNetwork) :
    (JacksonNetwork.mk n.queues).queues = n.queues := rfl

/-- Load is additive across station concatenation. -/
theorem load_append (a b : List Nat) :
    (JacksonNetwork.mk (a ++ b)).load = (JacksonNetwork.mk a).load + (JacksonNetwork.mk b).load := by
  induction a with
  | nil => exact (Nat.zero_add _).symm
  | cons x xs ih =>
      show x + (JacksonNetwork.mk (xs ++ b)).load
        = x + (JacksonNetwork.mk xs).load + (JacksonNetwork.mk b).load
      rw [ih]; exact (Nat.add_assoc x _ _).symm

/-- A sub-network never exceeds the full system load. -/
theorem subnetwork_le_load (a b : List Nat) :
    (JacksonNetwork.mk a).load ≤ (JacksonNetwork.mk (a ++ b)).load := by
  rw [load_append]; exact Nat.le_add_right _ _

end Gnosis
