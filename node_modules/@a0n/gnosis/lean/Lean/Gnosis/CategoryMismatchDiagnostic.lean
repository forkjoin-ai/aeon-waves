import Init

/-!
# Category mismatch diagnostic — detecting type-category disagreement

A diagnostic over category identifiers: the mismatch penalty between two
categories is their symmetric difference, which is zero exactly when the
categories agree.  The finite core proves the penalty characterizes compatibility
and is symmetric.

Init-only; every proof closes from `Nat` lemmas with no banned tactic on an open
goal.
-/

namespace Gnosis

/-- Two categories are compatible when their identifiers agree. -/
def compatible (a b : Nat) : Prop := a = b

/-- The mismatch penalty: the symmetric difference of the identifiers. -/
def mismatchPenalty (a b : Nat) : Nat := (a - b) + (b - a)

/-- Compatible categories incur no penalty. -/
theorem compatible_zero_penalty (a b : Nat) (h : compatible a b) : mismatchPenalty a b = 0 := by
  show (a - b) + (b - a) = 0
  rw [h, Nat.sub_self]

/-- **Zero penalty characterizes compatibility.** -/
theorem penalty_zero_iff_compatible (a b : Nat) : mismatchPenalty a b = 0 ↔ compatible a b := by
  constructor
  · intro hp
    have hpair := Nat.add_eq_zero_iff.mp hp
    exact Nat.le_antisymm (Nat.sub_eq_zero_iff_le.mp hpair.1) (Nat.sub_eq_zero_iff_le.mp hpair.2)
  · exact compatible_zero_penalty a b

/-- The penalty is symmetric. -/
theorem penalty_symm (a b : Nat) : mismatchPenalty a b = mismatchPenalty b a := Nat.add_comm _ _

/-- A genuine mismatch incurs a positive penalty. -/
theorem mismatch_positive (a b : Nat) (h : ¬ compatible a b) : 0 < mismatchPenalty a b := by
  rcases Nat.lt_or_ge a b with hlt | hge
  · exact Nat.lt_of_lt_of_le (Nat.sub_pos_of_lt hlt) (Nat.le_add_left _ _)
  · have : b < a := Nat.lt_of_le_of_ne hge (fun he => h he.symm)
    exact Nat.lt_of_lt_of_le (Nat.sub_pos_of_lt this) (Nat.le_add_right _ _)

end Gnosis
