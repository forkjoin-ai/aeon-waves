import Init

/-!
# Valentinian sin diagnostic — deficiency from the pleroma

Sin (deficiency) is the gap between an aeon's fullness and the pleroma.  The
finite core proves the diagnostic: deficiency vanishes exactly when fullness
reaches the pleroma, it is antitone in fullness (more fullness, less sin), and it
never exceeds the pleroma.

Init-only; every proof closes from `Nat` lemmas with no banned tactic on an open
goal.
-/

namespace Gnosis

/-- A diagnostic context: the pleroma (fullness ceiling). -/
structure Pleroma where
  ceiling : Nat

/-- The deficiency (sin) of an aeon of given fullness. -/
def Pleroma.deficiency (p : Pleroma) (fullness : Nat) : Nat := p.ceiling - fullness

/-- **Sin vanishes exactly at the pleroma.** -/
theorem deficiency_zero_iff (p : Pleroma) (fullness : Nat) :
    p.deficiency fullness = 0 ↔ p.ceiling ≤ fullness :=
  Nat.sub_eq_zero_iff_le

/-- Reaching the ceiling removes all deficiency. -/
theorem full_no_sin (p : Pleroma) : p.deficiency p.ceiling = 0 := Nat.sub_self p.ceiling

/-- **Sin is antitone in fullness:** growing toward the pleroma reduces deficiency. -/
theorem deficiency_antitone (p : Pleroma) {f1 f2 : Nat} (h : f1 ≤ f2) :
    p.deficiency f2 ≤ p.deficiency f1 :=
  Nat.sub_le_sub_left h p.ceiling

/-- Deficiency never exceeds the pleroma. -/
theorem deficiency_le_ceiling (p : Pleroma) (fullness : Nat) :
    p.deficiency fullness ≤ p.ceiling :=
  Nat.sub_le p.ceiling fullness

end Gnosis
