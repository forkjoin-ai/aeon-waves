import Init

/-!
# Scheduling matter — work is conserved under reordering

Treating scheduled work as a conserved "matter", the total work of a job list is
its sum.  The finite core proves work is conserved: it is additive across
concatenation and invariant under reordering the two halves — scheduling moves
work around but never creates or destroys it.

Init-only; every proof closes from `Nat`/`List` lemmas with no banned tactic on an
open goal.
-/

namespace Gnosis

/-- Total work of a job list. -/
def totalWork (jobs : List Nat) : Nat := jobs.foldr (· + ·) 0

/-- Work is additive across concatenation. -/
theorem work_append (a b : List Nat) :
    totalWork (a ++ b) = totalWork a + totalWork b := by
  induction a with
  | nil => exact (Nat.zero_add _).symm
  | cons x xs ih =>
      show x + totalWork (xs ++ b) = x + totalWork xs + totalWork b
      rw [ih]; exact (Nat.add_assoc x _ _).symm

/-- **Conservation.** Reordering the two halves preserves total work. -/
theorem work_reorder (a b : List Nat) : totalWork (a ++ b) = totalWork (b ++ a) := by
  rw [work_append, work_append, Nat.add_comm]

/-- Scheduling more jobs never lowers the total work. -/
theorem work_monotone (a b : List Nat) : totalWork a ≤ totalWork (a ++ b) := by
  rw [work_append]; exact Nat.le_add_right _ _

end Gnosis
