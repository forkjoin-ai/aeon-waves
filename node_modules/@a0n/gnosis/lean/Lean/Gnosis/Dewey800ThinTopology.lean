import Init

/-!
# Dewey 800 thin topology — literature subclasses refine the base

The Dewey 800s (literature) subdivide into subclasses 810–819 (American), 820–829
(English), and so on.  Each subclass code is `base + offset` with `offset < 100`,
so it refines its base: strictly above the base yet still inside the class.  The
finite core proves these refinement bounds.

Init-only; every proof closes from `Nat` lemmas with no banned tactic on an open
goal.
-/

namespace Gnosis

/-- A Dewey subclass: a base hundred plus an in-class offset (`< 100`). -/
structure DeweyClass where
  base : Nat
  offset : Nat
  hOffset : offset < 100

/-- The full Dewey code. -/
def DeweyClass.code (d : DeweyClass) : Nat := d.base + d.offset

/-- A subclass code is at least its base. -/
theorem code_ge_base (d : DeweyClass) : d.base ≤ d.code :=
  Nat.le_add_right d.base d.offset

/-- A subclass code stays inside its hundred-block. -/
theorem code_lt_next (d : DeweyClass) : d.code < d.base + 100 :=
  Nat.add_lt_add_left d.hOffset d.base

/-- **Refinement is strict** for any nonzero offset (e.g. 810 above 800). -/
theorem code_gt_base_of_offset (d : DeweyClass) (h : 0 < d.offset) : d.base < d.code :=
  Nat.lt_add_of_pos_right h

/-- American literature (810) refines the 800 base. -/
theorem dewey_810_refines_800 :
    (DeweyClass.mk 800 10 (by decide)).code = 810 := rfl

end Gnosis
