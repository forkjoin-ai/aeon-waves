namespace Gnosis

/-!
# Tukey Exploratory Data Analysis (EDA) Formalization

This module formalizes core concepts of Tukey's EDA as implemented in `open-source/twokeys`.

Focus areas:
1.  Tukey's Trimean: A robust measure of central tendency.
2.  Tukey Fences: Outlier detection using the Interquartile Range (IQR).

Style: Rustic Church (Init-only, no omega, no Mathlib).
-/

namespace TukeyEDA

/-- 
Tukey's Trimean is defined as (Q1 + 2*Median + Q3) / 4.
-/
def trimean (q1 median q3 : Int) : Int :=
  (q1 + 2 * median + q3) / 4

/--
Tukey Fences for outlier detection.
Inner fences: [Q1 - 1.5*IQR, Q3 + 1.5*IQR]
-/
def lowerFence (q1 iqr : Int) : Int :=
  q1 - (3 * iqr) / 2

def upperFence (q3 iqr : Int) : Int :=
  q3 + (3 * iqr) / 2

/--
The IQR is defined as Q3 - Q1.
-/
def iqr (q1 q3 : Int) : Int :=
  q3 - q1

/--
A basic consistency property: if q1 <= q3, then iqr >= 0.
-/
theorem iqr_nonneg {q1 q3 : Int} (h : q1 ≤ q3) : 0 ≤ iqr q1 q3 := by
  unfold iqr
  exact Int.sub_nonneg_of_le h

/--
Trimean monotonicity: if we increase the median, the trimean does not decrease.
(Proof requires handling Int division monotonicity).
-/
theorem trimean_mono_med {q1 med1 med2 q3 : Int} (h : med1 ≤ med2) :
    (q1 + 2 * med1 + q3) ≤ (q1 + 2 * med2 + q3) := by
  have h2 : 2 * med1 ≤ 2 * med2 := 
    Int.mul_le_mul_of_nonneg_left h (by decide)
  have h3 : q1 + 2 * med1 ≤ q1 + 2 * med2 :=
    Int.add_le_add_left h2 q1
  exact Int.add_le_add_right h3 q3

end TukeyEDA
end Gnosis