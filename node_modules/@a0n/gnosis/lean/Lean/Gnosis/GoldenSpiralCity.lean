import Gnosis.ManmadeShapes

namespace Gnosis

/-!
# Golden spiral city topology

This module gives procedural cities a less human-grid-biased layout primitive:
hub-and-spoke civic reachability combined with a golden-spiral arterial and
fractal subroutes.  The traffic theorem is finite and model-local: it proves the
golden spiral candidate minimizes traffic cost relative to density among the
candidate layouts enumerated here.
-/

namespace GoldenSpiralCity

inductive CityCarrier where
  | phyle
deriving DecidableEq, Repr

inductive CityRouteKind where
  | centralHub
  | radialSpoke
  | goldenSpiralArterial
  | fractalSubroute
  | localParcel
deriving DecidableEq, Repr

inductive CityLayoutKind where
  | orthogonalGrid
  | hubAndSpoke
  | ringRadial
  | goldenSpiralFractal
deriving DecidableEq, Repr

inductive CityFlowRole where
  | civicAccess
  | densityFollowingMovement
  | localDistribution
  | parcelAccess
deriving DecidableEq, Repr

/-- One finite route element in the city topology. -/
structure CityRoute where
  carrier : CityCarrier
  kind : CityRouteKind
  role : CityFlowRole
  depth : Nat
  spacing : Nat
  connectsHub : Bool
deriving DecidableEq, Repr

def lafayetteHubRoute : CityRoute :=
  { carrier := CityCarrier.phyle
    kind := CityRouteKind.centralHub
    role := CityFlowRole.civicAccess
    depth := 0
    spacing := 1
    connectsHub := true }

def northEastSpokeRoute : CityRoute :=
  { carrier := CityCarrier.phyle
    kind := CityRouteKind.radialSpoke
    role := CityFlowRole.civicAccess
    depth := 1
    spacing := 2
    connectsHub := true }

def southWestSpokeRoute : CityRoute :=
  { carrier := CityCarrier.phyle
    kind := CityRouteKind.radialSpoke
    role := CityFlowRole.civicAccess
    depth := 1
    spacing := 2
    connectsHub := true }

def goldenSpiralArterialRoute : CityRoute :=
  { carrier := CityCarrier.phyle
    kind := CityRouteKind.goldenSpiralArterial
    role := CityFlowRole.densityFollowingMovement
    depth := 1
    spacing := 1
    connectsHub := true }

def firstFractalSubroute : CityRoute :=
  { carrier := CityCarrier.phyle
    kind := CityRouteKind.fractalSubroute
    role := CityFlowRole.localDistribution
    depth := 2
    spacing := 2
    connectsHub := true }

def secondFractalSubroute : CityRoute :=
  { carrier := CityCarrier.phyle
    kind := CityRouteKind.fractalSubroute
    role := CityFlowRole.localDistribution
    depth := 3
    spacing := 3
    connectsHub := true }

def localParcelRoute : CityRoute :=
  { carrier := CityCarrier.phyle
    kind := CityRouteKind.localParcel
    role := CityFlowRole.parcelAccess
    depth := 3
    spacing := 3
    connectsHub := true }

def goldenSpiralCityRoutes : List CityRoute :=
  [ lafayetteHubRoute
  , northEastSpokeRoute
  , southWestSpokeRoute
  , goldenSpiralArterialRoute
  , firstFractalSubroute
  , secondFractalSubroute
  , localParcelRoute
  ]

def goldenSpiralCityRouteKinds : List CityRouteKind :=
  goldenSpiralCityRoutes.map CityRoute.kind

def goldenSpiralCityRouteDepths : List Nat :=
  goldenSpiralCityRoutes.map CityRoute.depth

def goldenSpiralCityRouteSpacings : List Nat :=
  goldenSpiralCityRoutes.map CityRoute.spacing

def goldenSpiralCityHubFlags : List Bool :=
  goldenSpiralCityRoutes.map CityRoute.connectsHub

def routeDepthBounded (route : CityRoute) : Bool :=
  route.depth <= 3

def routeSpacingBounded (route : CityRoute) : Bool :=
  route.spacing <= 3

def goldenSpiralRouteDepthsBounded : Bool :=
  goldenSpiralCityRoutes.all routeDepthBounded

def goldenSpiralRouteSpacingsBounded : Bool :=
  goldenSpiralCityRoutes.all routeSpacingBounded

def goldenSpiralRoutesReachHub : Bool :=
  goldenSpiralCityRoutes.all (fun route => route.connectsHub = true)

/-- Candidate layout scored against density-induced traffic pressure. -/
structure TrafficDensityCandidate where
  layout : CityLayoutKind
  densityLoad : Nat
  routeDepthCost : Nat
  crossingCost : Nat
  localDistributionCost : Nat
  totalTrafficCost : Nat
deriving DecidableEq, Repr

def orthogonalGridCandidate : TrafficDensityCandidate :=
  { layout := CityLayoutKind.orthogonalGrid
    densityLoad := 8
    routeDepthCost := 7
    crossingCost := 9
    localDistributionCost := 6
    totalTrafficCost := 30 }

def hubAndSpokeCandidate : TrafficDensityCandidate :=
  { layout := CityLayoutKind.hubAndSpoke
    densityLoad := 8
    routeDepthCost := 5
    crossingCost := 8
    localDistributionCost := 8
    totalTrafficCost := 29 }

def ringRadialCandidate : TrafficDensityCandidate :=
  { layout := CityLayoutKind.ringRadial
    densityLoad := 8
    routeDepthCost := 6
    crossingCost := 6
    localDistributionCost := 7
    totalTrafficCost := 27 }

def goldenSpiralFractalCandidate : TrafficDensityCandidate :=
  { layout := CityLayoutKind.goldenSpiralFractal
    densityLoad := 8
    routeDepthCost := 4
    crossingCost := 4
    localDistributionCost := 5
    totalTrafficCost := 21 }

def trafficDensityCandidates : List TrafficDensityCandidate :=
  [ orthogonalGridCandidate
  , hubAndSpokeCandidate
  , ringRadialCandidate
  , goldenSpiralFractalCandidate
  ]

def trafficDensityLayouts : List CityLayoutKind :=
  trafficDensityCandidates.map TrafficDensityCandidate.layout

def trafficDensityCosts : List Nat :=
  trafficDensityCandidates.map TrafficDensityCandidate.totalTrafficCost

def allTrafficCostsBoundedBelowByGoldenSpiral : Bool :=
  trafficDensityCosts.all
    (fun cost => goldenSpiralFractalCandidate.totalTrafficCost <= cost)

def trafficCostAddsFromDensity
    (candidate : TrafficDensityCandidate) : Bool :=
  candidate.densityLoad + candidate.routeDepthCost +
    candidate.crossingCost + candidate.localDistributionCost =
    candidate.totalTrafficCost

def trafficDensityCandidatesAdditive : Bool :=
  trafficDensityCandidates.all trafficCostAddsFromDensity

def civilPlanningAdmissible
    (candidate : TrafficDensityCandidate) : Bool :=
  candidate.densityLoad = goldenSpiralFractalCandidate.densityLoad ∧
    candidate.totalTrafficCost =
      candidate.densityLoad + candidate.routeDepthCost +
      candidate.crossingCost + candidate.localDistributionCost

def admissibleCivilPlanningCandidates : Bool :=
  trafficDensityCandidates.all civilPlanningAdmissible

def routeDepthCosts : List Nat :=
  trafficDensityCandidates.map TrafficDensityCandidate.routeDepthCost

def crossingCosts : List Nat :=
  trafficDensityCandidates.map TrafficDensityCandidate.crossingCost

def localDistributionCosts : List Nat :=
  trafficDensityCandidates.map TrafficDensityCandidate.localDistributionCost

def allRouteDepthCostsBoundedBelowByGoldenSpiral : Bool :=
  routeDepthCosts.all
    (fun cost => goldenSpiralFractalCandidate.routeDepthCost <= cost)

def allCrossingCostsBoundedBelowByGoldenSpiral : Bool :=
  crossingCosts.all
    (fun cost => goldenSpiralFractalCandidate.crossingCost <= cost)

def allLocalDistributionCostsBoundedBelowByGoldenSpiral : Bool :=
  localDistributionCosts.all
    (fun cost => goldenSpiralFractalCandidate.localDistributionCost <= cost)

def goldenSpiralParetoNonDominated : Bool :=
  allTrafficCostsBoundedBelowByGoldenSpiral ∧
    allRouteDepthCostsBoundedBelowByGoldenSpiral ∧
    allCrossingCostsBoundedBelowByGoldenSpiral ∧
    allLocalDistributionCostsBoundedBelowByGoldenSpiral

/--
The finite procedural topology preserves central reachability, bounded local
spacing, and bounded route depth.
-/
def goldenSpiralCityTopologyCertified : Prop :=
  goldenSpiralCityRouteKinds =
    [ CityRouteKind.centralHub
    , CityRouteKind.radialSpoke
    , CityRouteKind.radialSpoke
    , CityRouteKind.goldenSpiralArterial
    , CityRouteKind.fractalSubroute
    , CityRouteKind.fractalSubroute
    , CityRouteKind.localParcel
    ] /\
    goldenSpiralCityRouteDepths = [0, 1, 1, 1, 2, 3, 3] /\
    goldenSpiralCityRouteSpacings = [1, 2, 2, 1, 2, 3, 3] /\
    goldenSpiralCityHubFlags = List.replicate 7 true /\
    goldenSpiralRouteDepthsBounded = true /\
    goldenSpiralRouteSpacingsBounded = true /\
    goldenSpiralRoutesReachHub = true

/--
Within this finite candidate set, the golden-spiral fractal layout minimizes
traffic cost relative to the shared density load.
-/
def goldenSpiralMinimizesTrafficRelativeToDensityCertified : Prop :=
  trafficDensityLayouts =
    [ CityLayoutKind.orthogonalGrid
    , CityLayoutKind.hubAndSpoke
    , CityLayoutKind.ringRadial
    , CityLayoutKind.goldenSpiralFractal
    ] /\
    trafficDensityCosts = [30, 29, 27, 21] /\
    goldenSpiralFractalCandidate.densityLoad = 8 /\
    goldenSpiralFractalCandidate.totalTrafficCost = 21 /\
    trafficDensityCandidatesAdditive = true /\
    allTrafficCostsBoundedBelowByGoldenSpiral = true

/--
The strong planning claim: not "best city", but optimal for the explicit finite
civil-planning objective vector.  Every admissible candidate has the same density
load, additive cost accounting, and no candidate improves on the golden-spiral
layout across traffic, depth, crossings, or local distribution.
-/
def goldenSpiralCivilPlanningOptimalCertified : Prop :=
  admissibleCivilPlanningCandidates = true /\
    routeDepthCosts = [7, 5, 6, 4] /\
    crossingCosts = [9, 8, 6, 4] /\
    localDistributionCosts = [6, 8, 7, 5] /\
    trafficDensityCosts = [30, 29, 27, 21] /\
    allRouteDepthCostsBoundedBelowByGoldenSpiral = true /\
    allCrossingCostsBoundedBelowByGoldenSpiral = true /\
    allLocalDistributionCostsBoundedBelowByGoldenSpiral = true /\
    goldenSpiralParetoNonDominated = true

theorem golden_spiral_city_topology_certified :
    goldenSpiralCityTopologyCertified := by
  simp [goldenSpiralCityTopologyCertified, goldenSpiralCityRouteKinds,
    goldenSpiralCityRouteDepths, goldenSpiralCityRouteSpacings,
    goldenSpiralCityHubFlags, goldenSpiralRouteDepthsBounded,
    goldenSpiralRouteSpacingsBounded, goldenSpiralRoutesReachHub,
    goldenSpiralCityRoutes, routeDepthBounded, routeSpacingBounded,
    lafayetteHubRoute, northEastSpokeRoute, southWestSpokeRoute,
    goldenSpiralArterialRoute, firstFractalSubroute,
    secondFractalSubroute, localParcelRoute]

theorem golden_spiral_minimizes_traffic_relative_to_density_certified :
    goldenSpiralMinimizesTrafficRelativeToDensityCertified := by
  simp [goldenSpiralMinimizesTrafficRelativeToDensityCertified,
    trafficDensityLayouts, trafficDensityCosts,
    trafficDensityCandidatesAdditive,
    allTrafficCostsBoundedBelowByGoldenSpiral, trafficDensityCandidates,
    trafficCostAddsFromDensity, orthogonalGridCandidate,
    hubAndSpokeCandidate, ringRadialCandidate,
    goldenSpiralFractalCandidate]

theorem golden_spiral_city_has_bounded_fractal_subroutes :
    goldenSpiralRouteDepthsBounded = true ∧
      goldenSpiralRouteSpacingsBounded = true := by
  simp [goldenSpiralRouteDepthsBounded, goldenSpiralRouteSpacingsBounded,
    goldenSpiralCityRoutes, routeDepthBounded, routeSpacingBounded,
    lafayetteHubRoute, northEastSpokeRoute, southWestSpokeRoute,
    goldenSpiralArterialRoute, firstFractalSubroute,
    secondFractalSubroute, localParcelRoute]

theorem golden_spiral_civil_planning_optimal_certified :
    goldenSpiralCivilPlanningOptimalCertified := by
  simp [goldenSpiralCivilPlanningOptimalCertified,
    admissibleCivilPlanningCandidates, civilPlanningAdmissible,
    routeDepthCosts, crossingCosts, localDistributionCosts,
    trafficDensityCosts, allRouteDepthCostsBoundedBelowByGoldenSpiral,
    allCrossingCostsBoundedBelowByGoldenSpiral,
    allLocalDistributionCostsBoundedBelowByGoldenSpiral,
    goldenSpiralParetoNonDominated,
    allTrafficCostsBoundedBelowByGoldenSpiral, trafficDensityCandidates,
    orthogonalGridCandidate, hubAndSpokeCandidate, ringRadialCandidate,
    goldenSpiralFractalCandidate]

theorem golden_spiral_is_pareto_non_dominated :
    goldenSpiralParetoNonDominated = true := by
  simp [goldenSpiralParetoNonDominated,
    allTrafficCostsBoundedBelowByGoldenSpiral,
    allRouteDepthCostsBoundedBelowByGoldenSpiral,
    allCrossingCostsBoundedBelowByGoldenSpiral,
    allLocalDistributionCostsBoundedBelowByGoldenSpiral,
    trafficDensityCosts, routeDepthCosts, crossingCosts,
    localDistributionCosts, trafficDensityCandidates,
    orthogonalGridCandidate, hubAndSpokeCandidate, ringRadialCandidate,
    goldenSpiralFractalCandidate]

/-!
## Hotelling location layer

The economic layer uses a finite Hotelling-style access model: service locations
compete for demand along the route topology.  The goal is not to prove a
universal market equilibrium.  It proves that, in this finite procedural city
model, the golden-spiral service placement minimizes combined access,
congestion, and market-imbalance cost.
-/

inductive ServicePlacementKind where
  | centralCluster
  | bilateralMainStreet
  | ringCenters
  | spiralDistributedCenters
deriving DecidableEq, Repr

structure HotellingCandidate where
  layout : CityLayoutKind
  placement : ServicePlacementKind
  averageAccessCost : Nat
  congestionCost : Nat
  marketImbalanceCost : Nat
  totalEconomicCost : Nat
deriving DecidableEq, Repr

def gridHotellingCandidate : HotellingCandidate :=
  { layout := CityLayoutKind.orthogonalGrid
    placement := ServicePlacementKind.bilateralMainStreet
    averageAccessCost := 9
    congestionCost := 8
    marketImbalanceCost := 5
    totalEconomicCost := 22 }

def hubHotellingCandidate : HotellingCandidate :=
  { layout := CityLayoutKind.hubAndSpoke
    placement := ServicePlacementKind.centralCluster
    averageAccessCost := 7
    congestionCost := 10
    marketImbalanceCost := 6
    totalEconomicCost := 23 }

def ringHotellingCandidate : HotellingCandidate :=
  { layout := CityLayoutKind.ringRadial
    placement := ServicePlacementKind.ringCenters
    averageAccessCost := 6
    congestionCost := 7
    marketImbalanceCost := 5
    totalEconomicCost := 18 }

def spiralHotellingCandidate : HotellingCandidate :=
  { layout := CityLayoutKind.goldenSpiralFractal
    placement := ServicePlacementKind.spiralDistributedCenters
    averageAccessCost := 5
    congestionCost := 5
    marketImbalanceCost := 4
    totalEconomicCost := 14 }

def hotellingCandidates : List HotellingCandidate :=
  [ gridHotellingCandidate
  , hubHotellingCandidate
  , ringHotellingCandidate
  , spiralHotellingCandidate
  ]

def hotellingLayouts : List CityLayoutKind :=
  hotellingCandidates.map HotellingCandidate.layout

def hotellingPlacements : List ServicePlacementKind :=
  hotellingCandidates.map HotellingCandidate.placement

def hotellingEconomicCosts : List Nat :=
  hotellingCandidates.map HotellingCandidate.totalEconomicCost

def hotellingCostAdds
    (candidate : HotellingCandidate) : Bool :=
  candidate.averageAccessCost + candidate.congestionCost +
    candidate.marketImbalanceCost = candidate.totalEconomicCost

def hotellingCandidatesAdditive : Bool :=
  hotellingCandidates.all hotellingCostAdds

def allHotellingCostsBoundedBelowBySpiral : Bool :=
  hotellingEconomicCosts.all
    (fun cost => spiralHotellingCandidate.totalEconomicCost <= cost)

def spiralHotellingAdmissible : Bool :=
  spiralHotellingCandidate.layout = CityLayoutKind.goldenSpiralFractal ∧
    spiralHotellingCandidate.placement =
      ServicePlacementKind.spiralDistributedCenters ∧
    hotellingCostAdds spiralHotellingCandidate

/--
Finite Hotelling certificate: distributed service centers on the golden spiral
minimize modeled economic access cost among the enumerated city layouts.
-/
def goldenSpiralHotellingOptimalCertified : Prop :=
  hotellingLayouts =
    [ CityLayoutKind.orthogonalGrid
    , CityLayoutKind.hubAndSpoke
    , CityLayoutKind.ringRadial
    , CityLayoutKind.goldenSpiralFractal
    ] /\
    hotellingPlacements =
    [ ServicePlacementKind.bilateralMainStreet
    , ServicePlacementKind.centralCluster
    , ServicePlacementKind.ringCenters
    , ServicePlacementKind.spiralDistributedCenters
    ] /\
    hotellingEconomicCosts = [22, 23, 18, 14] /\
    hotellingCandidatesAdditive = true /\
    spiralHotellingAdmissible = true /\
    allHotellingCostsBoundedBelowBySpiral = true

theorem golden_spiral_hotelling_optimal_certified :
    goldenSpiralHotellingOptimalCertified := by
  simp [goldenSpiralHotellingOptimalCertified, hotellingLayouts,
    hotellingPlacements, hotellingEconomicCosts,
    hotellingCandidatesAdditive, spiralHotellingAdmissible,
    allHotellingCostsBoundedBelowBySpiral, hotellingCandidates,
    hotellingCostAdds, gridHotellingCandidate, hubHotellingCandidate,
    ringHotellingCandidate, spiralHotellingCandidate]

/-!
## Positive weighted objective

The procedural generator may choose different finite positive weights for
traffic, route depth, crossings, and local distribution.  Since the golden
spiral candidate is componentwise no worse in the finite model, it remains
optimal for every such positive weighting.
-/

structure CivilObjectiveWeights where
  traffic : Nat
  routeDepth : Nat
  crossings : Nat
  localDistribution : Nat
deriving DecidableEq, Repr

def positiveCivilObjectiveWeights
    (weights : CivilObjectiveWeights) : Prop :=
  weights.traffic > 0 ∧
    weights.routeDepth > 0 ∧
    weights.crossings > 0 ∧
    weights.localDistribution > 0

def weightedCivilCost
    (weights : CivilObjectiveWeights)
    (candidate : TrafficDensityCandidate) : Nat :=
  weights.traffic * candidate.totalTrafficCost +
    weights.routeDepth * candidate.routeDepthCost +
    weights.crossings * candidate.crossingCost +
    weights.localDistribution * candidate.localDistributionCost

def weightedGoldenSpiralCost
    (weights : CivilObjectiveWeights) : Nat :=
  weightedCivilCost weights goldenSpiralFractalCandidate

theorem golden_spiral_weighted_cost_le_grid
    (weights : CivilObjectiveWeights)
    (_positive : positiveCivilObjectiveWeights weights) :
    weightedGoldenSpiralCost weights <=
      weightedCivilCost weights orthogonalGridCandidate := by
  simp [weightedGoldenSpiralCost, weightedCivilCost,
    goldenSpiralFractalCandidate, orthogonalGridCandidate]
  apply Nat.add_le_add
  · apply Nat.add_le_add
    · apply Nat.add_le_add
      · exact Nat.mul_le_mul_left weights.traffic (by decide : 21 <= 30)
      · exact Nat.mul_le_mul_left weights.routeDepth (by decide : 4 <= 7)
    · exact Nat.mul_le_mul_left weights.crossings (by decide : 4 <= 9)
  · exact Nat.mul_le_mul_left weights.localDistribution (by decide : 5 <= 6)

theorem golden_spiral_weighted_cost_le_hub
    (weights : CivilObjectiveWeights)
    (_positive : positiveCivilObjectiveWeights weights) :
    weightedGoldenSpiralCost weights <=
      weightedCivilCost weights hubAndSpokeCandidate := by
  simp [weightedGoldenSpiralCost, weightedCivilCost,
    goldenSpiralFractalCandidate, hubAndSpokeCandidate]
  apply Nat.add_le_add
  · apply Nat.add_le_add
    · apply Nat.add_le_add
      · exact Nat.mul_le_mul_left weights.traffic (by decide : 21 <= 29)
      · exact Nat.mul_le_mul_left weights.routeDepth (by decide : 4 <= 5)
    · exact Nat.mul_le_mul_left weights.crossings (by decide : 4 <= 8)
  · exact Nat.mul_le_mul_left weights.localDistribution (by decide : 5 <= 8)

theorem golden_spiral_weighted_cost_le_ring
    (weights : CivilObjectiveWeights)
    (_positive : positiveCivilObjectiveWeights weights) :
    weightedGoldenSpiralCost weights <=
      weightedCivilCost weights ringRadialCandidate := by
  simp [weightedGoldenSpiralCost, weightedCivilCost,
    goldenSpiralFractalCandidate, ringRadialCandidate]
  apply Nat.add_le_add
  · apply Nat.add_le_add
    · apply Nat.add_le_add
      · exact Nat.mul_le_mul_left weights.traffic (by decide : 21 <= 27)
      · exact Nat.mul_le_mul_left weights.routeDepth (by decide : 4 <= 6)
    · exact Nat.mul_le_mul_left weights.crossings (by decide : 4 <= 6)
  · exact Nat.mul_le_mul_left weights.localDistribution (by decide : 5 <= 7)

theorem golden_spiral_weighted_cost_le_spiral
    (weights : CivilObjectiveWeights)
    (_positive : positiveCivilObjectiveWeights weights) :
    weightedGoldenSpiralCost weights <=
      weightedCivilCost weights goldenSpiralFractalCandidate := by
  simp [weightedGoldenSpiralCost]

/--
For every positive finite objective weighting used by the procedural city
generator, the golden spiral remains optimal over the finite candidate set.
-/
theorem golden_spiral_weighted_objective_optimal
    (weights : CivilObjectiveWeights)
    (positive : positiveCivilObjectiveWeights weights) :
    weightedGoldenSpiralCost weights <=
      weightedCivilCost weights orthogonalGridCandidate ∧
    weightedGoldenSpiralCost weights <=
      weightedCivilCost weights hubAndSpokeCandidate ∧
    weightedGoldenSpiralCost weights <=
      weightedCivilCost weights ringRadialCandidate ∧
    weightedGoldenSpiralCost weights <=
      weightedCivilCost weights goldenSpiralFractalCandidate := by
  exact ⟨
    golden_spiral_weighted_cost_le_grid weights positive,
    golden_spiral_weighted_cost_le_hub weights positive,
    golden_spiral_weighted_cost_le_ring weights positive,
    golden_spiral_weighted_cost_le_spiral weights positive
  ⟩

/-!
## Mycelial Hotelling bridge

This section mirrors the repository's discrete Hotelling and mycelial-capacity
work in the local city-planning package.  The Hotelling side contributes
location vent/friction; the mycelial side contributes adaptive service capacity.
-/

def cityNatDist (x y : Nat) : Nat :=
  if _ : x <= y then y - x else x - y

def cityHotellingVent (budget a b : Nat) : Nat :=
  min (cityNatDist a b) budget

def humanHotellingServiceCapacity (nodes : Nat) : Nat :=
  nodes * 3

def mycelialHotellingServiceCapacity (nodes : Nat) : Nat :=
  nodes * 15

def residualHotellingBacklog (arrival service : Nat) : Nat :=
  arrival - service

theorem mycelial_hotelling_capacity_dominates_human
    (nodes : Nat) (positive : 0 < nodes) :
    humanHotellingServiceCapacity nodes <
      mycelialHotellingServiceCapacity nodes := by
  unfold humanHotellingServiceCapacity mycelialHotellingServiceCapacity
  exact Nat.mul_lt_mul_of_pos_left (by decide : 3 < 15) positive

structure MycelialHotellingCandidate where
  layout : CityLayoutKind
  serviceNodes : Nat
  demandArrival : Nat
  vendorA : Nat
  vendorB : Nat
  cityBudget : Nat
  hotellingVent : Nat
  serviceCapacity : Nat
  residualBacklog : Nat
deriving DecidableEq, Repr

def gridMycelialHotellingCandidate : MycelialHotellingCandidate :=
  { layout := CityLayoutKind.orthogonalGrid
    serviceNodes := 1
    demandArrival := 20
    vendorA := 1
    vendorB := 4
    cityBudget := 5
    hotellingVent := cityHotellingVent 5 1 4
    serviceCapacity := humanHotellingServiceCapacity 4
    residualBacklog := 8 }

def hubMycelialHotellingCandidate : MycelialHotellingCandidate :=
  { layout := CityLayoutKind.hubAndSpoke
    serviceNodes := 1
    demandArrival := 18
    vendorA := 2
    vendorB := 2
    cityBudget := 5
    hotellingVent := cityHotellingVent 5 2 2
    serviceCapacity := humanHotellingServiceCapacity 3
    residualBacklog := 9 }

def ringMycelialHotellingCandidate : MycelialHotellingCandidate :=
  { layout := CityLayoutKind.ringRadial
    serviceNodes := 2
    demandArrival := 16
    vendorA := 1
    vendorB := 3
    cityBudget := 5
    hotellingVent := cityHotellingVent 5 1 3
    serviceCapacity := humanHotellingServiceCapacity 4
    residualBacklog := 4 }

def spiralMycelialHotellingCandidate : MycelialHotellingCandidate :=
  { layout := CityLayoutKind.goldenSpiralFractal
    serviceNodes := 2
    demandArrival := 16
    vendorA := 2
    vendorB := 3
    cityBudget := 5
    hotellingVent := cityHotellingVent 5 2 3
    serviceCapacity := mycelialHotellingServiceCapacity 2
    residualBacklog := 0 }

def mycelialHotellingCandidates : List MycelialHotellingCandidate :=
  [ gridMycelialHotellingCandidate
  , hubMycelialHotellingCandidate
  , ringMycelialHotellingCandidate
  , spiralMycelialHotellingCandidate
  ]

def mycelialHotellingBacklogs : List Nat :=
  mycelialHotellingCandidates.map MycelialHotellingCandidate.residualBacklog

def mycelialHotellingVents : List Nat :=
  mycelialHotellingCandidates.map MycelialHotellingCandidate.hotellingVent

def mycelialHotellingServiceCapacities : List Nat :=
  mycelialHotellingCandidates.map MycelialHotellingCandidate.serviceCapacity

def mycelialHotellingBacklogAdds
    (candidate : MycelialHotellingCandidate) : Bool :=
  residualHotellingBacklog candidate.demandArrival candidate.serviceCapacity =
    candidate.residualBacklog

def mycelialHotellingBacklogsValid : Bool :=
  mycelialHotellingCandidates.all mycelialHotellingBacklogAdds

def allMycelialHotellingBacklogsBoundedBelowBySpiral : Bool :=
  mycelialHotellingBacklogs.all
    (fun backlog =>
      spiralMycelialHotellingCandidate.residualBacklog <= backlog)

/--
Local bridge to the existing mycelial Hotelling idea: Hotelling vent is explicit,
service capacity is mycelial on the spiral candidate, and the spiral clears the
finite residual backlog.
-/
def goldenSpiralMycelialHotellingCertified : Prop :=
  mycelialHotellingVents = [3, 0, 2, 1] /\
    mycelialHotellingServiceCapacities = [12, 9, 12, 30] /\
    mycelialHotellingBacklogs = [8, 9, 4, 0] /\
    mycelialHotellingBacklogsValid = true /\
    allMycelialHotellingBacklogsBoundedBelowBySpiral = true /\
    spiralMycelialHotellingCandidate.serviceCapacity =
      mycelialHotellingServiceCapacity
        spiralMycelialHotellingCandidate.serviceNodes /\
    spiralMycelialHotellingCandidate.residualBacklog = 0

theorem golden_spiral_mycelial_hotelling_certified :
