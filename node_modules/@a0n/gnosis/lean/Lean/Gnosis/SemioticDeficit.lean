import Init

/-!
# Semiotic deficit — when meaning has more dimensions than channels

A semiotic channel conveys `dimensions` of meaning through `articulationStreams`.
The deficit is the uncarried meaning `(dimensions - 1) - (streams - 1)`.  The
finite core proves: more dimensions than streams forces a positive deficit, speech
(one stream) carries the full `dimensions - 1` deficit, accumulated context only
reduces it, a matched channel (streams ≥ dimensions) is deficit-free, and enough
context eliminates the deficit entirely.

The original carried an `ℤ` deficit through a Mathlib web; here the finite core is
self-contained over `Nat`, every proof closing from `Init`.
-/

namespace Gnosis
namespace SemioticDeficit

/-- A semiotic channel: meaning dimensions against articulation streams. -/
structure SemioticChannel where
  dimensions : Nat
  articulationStreams : Nat
  hDimsPos : 0 < dimensions
  hStreamsPos : 0 < articulationStreams

/-- The semiotic deficit: uncarried independent meaning dimensions. -/
def semioticDeficit (ch : SemioticChannel) : Nat :=
  (ch.dimensions - 1) - (ch.articulationStreams - 1)

/-- The deficit after `context` rounds of shared grounding. -/
def contextReducedDeficit (ch : SemioticChannel) (context : Nat) : Nat :=
  semioticDeficit ch - context

/-- **More dimensions than streams forces a positive deficit.** -/
theorem semiotic_deficit (ch : SemioticChannel) (h : ch.articulationStreams < ch.dimensions) :
    0 < semioticDeficit ch :=
  Nat.sub_pos_of_lt (Nat.pred_lt_pred (Nat.pos_iff_ne_zero.mp ch.hStreamsPos) h)

/-- **Speech** (a single stream) carries the full `dimensions - 1` deficit. -/
theorem semiotic_deficit_speech (ch : SemioticChannel) (h : ch.articulationStreams = 1) :
    semioticDeficit ch = ch.dimensions - 1 := by
  show ch.dimensions - 1 - (ch.articulationStreams - 1) = ch.dimensions - 1
  rw [h]
  exact Nat.sub_zero _

/-- Accumulated context only reduces the deficit. -/
theorem semiotic_context_reduces (ch : SemioticChannel) (context : Nat) :
    contextReducedDeficit ch context ≤ semioticDeficit ch :=
  Nat.sub_le _ context

/-- **A matched channel is deficit-free.** -/
theorem semiotic_moa_zero_deficit (ch : SemioticChannel)
    (h : ch.dimensions ≤ ch.articulationStreams) : semioticDeficit ch = 0 :=
  Nat.sub_eq_zero_of_le (Nat.sub_le_sub_right h 1)

/-- Enough context eliminates the deficit entirely. -/
theorem semiotic_context_eliminates (ch : SemioticChannel) :
    contextReducedDeficit ch (semioticDeficit ch) = 0 :=
  Nat.sub_self (semioticDeficit ch)

/-- **Master.** The deficit is positive under mismatch, zero under match, and
    erasable by sufficient context. -/
theorem semiotic_deficit_theory (ch : SemioticChannel)
    (h : ch.articulationStreams < ch.dimensions) :
    0 < semioticDeficit ch ∧
    contextReducedDeficit ch (semioticDeficit ch) = 0 ∧
    (∀ context, contextReducedDeficit ch context ≤ semioticDeficit ch) :=
  ⟨semiotic_deficit ch h, semiotic_context_eliminates ch, semiotic_context_reduces ch⟩

end SemioticDeficit
end Gnosis
