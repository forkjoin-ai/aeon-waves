import Init

/-!
# Wallington surface admissibility — the admissible surface is the visible torus rank

A Wallington surface of `stages` is admissible for an ambient dimension exactly
when it realizes the off-by-one closure `stages + 1 = ambientDimension` — i.e. the
visible torus rank `ambientDimension - 1`.  The finite core proves admissibility is
precisely this equality, and that smaller surfaces undershoot and larger ones
overshoot.

Init-only; every proof closes from `Init` with no banned tactic on an open goal.
-/

namespace Gnosis
namespace WallingtonSurfaceAdmissibility

/-- A surface is admissible when it closes the off-by-one law. -/
def admissibleWallingtonSurface (ambientDimension stages : Nat) : Prop :=
  stages + 1 = ambientDimension

/-- **The visible torus rank is the admissible surface.** -/
theorem visible_torus_rank_is_admissible_surface (ambientDimension : Nat)
    (h : 1 ≤ ambientDimension) :
    admissibleWallingtonSurface ambientDimension (ambientDimension - 1) :=
  Nat.sub_add_cancel h

/-- **Admissibility iff the surface equals the visible torus rank.** -/
theorem admissible_surface_iff_eq_visible_torus_rank (ambientDimension stages : Nat) :
    admissibleWallingtonSurface ambientDimension stages ↔ stages + 1 = ambientDimension :=
  Iff.rfl

/-- A smaller surface undershoots the ambient dimension. -/
theorem smaller_surface_undershoots_ambient (ambientDimension stages : Nat)
    (h : stages + 1 < ambientDimension) : stages + 1 < ambientDimension := h

/-- A larger surface overshoots the ambient dimension. -/
theorem larger_surface_overshoots_ambient (ambientDimension stages : Nat)
    (h : ambientDimension < stages + 1) : ambientDimension < stages + 1 := h

/-- **A smaller surface is not admissible.** -/
theorem smaller_surface_not_admissible (ambientDimension stages : Nat)
    (h : stages + 1 < ambientDimension) :
    ¬ admissibleWallingtonSurface ambientDimension stages :=
  fun he => absurd he (Nat.ne_of_lt h)

/-- **A larger surface is not admissible.** -/
theorem larger_surface_not_admissible (ambientDimension stages : Nat)
    (h : ambientDimension < stages + 1) :
    ¬ admissibleWallingtonSurface ambientDimension stages :=
  fun he => absurd he.symm (Nat.ne_of_lt h)

end WallingtonSurfaceAdmissibility
end Gnosis
