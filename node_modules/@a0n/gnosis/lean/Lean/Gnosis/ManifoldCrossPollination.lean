import Init

/-!
# Manifold cross-pollination — dimensions and genus add under product

Cross-pollinating two manifolds forms their product.  The finite core records the
additive invariants: the product's dimension is the sum of the factor dimensions
and its genus is the sum of the factor genera, so the construction is symmetric
and never lowers either invariant.

Init-only; every proof closes from `Nat` lemmas with no banned tactic on an open
goal.
-/

namespace Gnosis

/-- A manifold summarized by its dimension and genus. -/
structure Manifold where
  dimension : Nat
  genus : Nat

/-- Cross-pollination: the product manifold. -/
def Manifold.crossPollinate (a b : Manifold) : Manifold :=
  { dimension := a.dimension + b.dimension, genus := a.genus + b.genus }

/-- Dimensions add under cross-pollination. -/
theorem cross_dimension (a b : Manifold) :
    (a.crossPollinate b).dimension = a.dimension + b.dimension := rfl

/-- Genera add under cross-pollination. -/
theorem cross_genus (a b : Manifold) :
    (a.crossPollinate b).genus = a.genus + b.genus := rfl

/-- Cross-pollination is symmetric in its invariants. -/
theorem cross_symmetric (a b : Manifold) :
    (a.crossPollinate b).dimension = (b.crossPollinate a).dimension ∧
    (a.crossPollinate b).genus = (b.crossPollinate a).genus :=
  ⟨Nat.add_comm _ _, Nat.add_comm _ _⟩

/-- The product never has lower dimension than either factor. -/
theorem cross_dimension_ge_left (a b : Manifold) :
    a.dimension ≤ (a.crossPollinate b).dimension :=
  Nat.le_add_right a.dimension b.dimension

/-- Cross-pollination is associative in dimension. -/
theorem cross_dimension_assoc (a b c : Manifold) :
    ((a.crossPollinate b).crossPollinate c).dimension =
      (a.crossPollinate (b.crossPollinate c)).dimension :=
  Nat.add_assoc a.dimension b.dimension c.dimension

end Gnosis
