import Init

/-!
# Spiderweb mesh network — `β₁ = peers × hops`

A spiderweb mesh of `peers` rings at `hops` depth has first Betti number
`peers · hops`.  The finite core proves the β₁ formula, that it vanishes exactly
when a factor is trivial, that a genuine mesh has positive β₁, and the wiring/node
relations.

The original carried an `ℤ` Euler characteristic; here the finite core is
self-contained over `Nat`, every proof closing from `Init`.
-/

namespace Gnosis
namespace SpiderwebMeshNetwork

/-- A mesh configuration: peer rings at a given hop depth. -/
structure MeshConfig where
  peers : Nat
  hops : Nat

/-- Independent routing paths. -/
def meshRoutingPaths (m : MeshConfig) : Nat := m.peers * m.hops

/-- Total wires. -/
def meshWireCount (m : MeshConfig) : Nat := m.peers * (2 * m.hops + 1)

/-- Total nodes (with the hub). -/
def meshNodeCount (m : MeshConfig) : Nat := m.peers * m.hops + m.peers + 1

/-- First Betti number of the mesh. -/
def beta1 (m : MeshConfig) : Nat := m.peers * m.hops

theorem beta1_eq_peers_times_hops (m : MeshConfig) : beta1 m = m.peers * m.hops := rfl

/-- β₁ vanishes exactly when a factor is trivial. -/
theorem beta1_zero_iff (m : MeshConfig) : beta1 m = 0 ↔ m.peers = 0 ∨ m.hops = 0 :=
  Nat.mul_eq_zero

/-- A genuine mesh has positive β₁. -/
theorem beta1_pos_of_nontrivial (m : MeshConfig) (hp : 0 < m.peers) (hh : 0 < m.hops) :
    0 < beta1 m := Nat.mul_pos hp hh

/-- Routing paths never exceed the wire count. -/
theorem routing_le_wires (m : MeshConfig) : meshRoutingPaths m ≤ meshWireCount m := by
  show m.peers * m.hops ≤ m.peers * (2 * m.hops + 1)
  apply Nat.mul_le_mul_left
  show m.hops ≤ 2 * m.hops + 1
  exact Nat.le_trans (Nat.le_mul_of_pos_left m.hops (by decide)) (Nat.le_succ _)

/-- The node count exceeds the routing paths (the hub and peers add nodes). -/
theorem nodes_gt_paths (m : MeshConfig) : meshRoutingPaths m < meshNodeCount m := by
  show m.peers * m.hops < m.peers * m.hops + m.peers + 1
  exact Nat.lt_of_le_of_lt (Nat.le_add_right (m.peers * m.hops) m.peers)
    (Nat.lt_succ_self (m.peers * m.hops + m.peers))

end SpiderwebMeshNetwork
end Gnosis
