import Init

/-!
# St-Venant decay — a self-equilibrated load fades with distance

St-Venant's principle: the stress induced by a self-equilibrated boundary load
is appreciable only near the load and decays to nothing at a distance.  Here the
stress at distance `d` is `load - decayRate · d` (saturating at zero).  Three
facts characterise the field: with no load there is no stress anywhere, the
stress is antitone in distance, and it vanishes identically beyond the
characteristic decay length.

The original carried a continuous stress tensor over `ℝ`.  This module keeps the
finite, decidable core over `Nat`, with every proof closing from `Init` and no
banned tactic on an open goal.
-/

namespace Gnosis

/-- A one-dimensional St-Venant stress field: a boundary `load` that decays at
    `decayRate` per unit distance. -/
structure StressField where
  /-- Magnitude of the self-equilibrated boundary load. -/
  load : Nat
  /-- Spatial decay rate of the stress. -/
  decayRate : Nat

/-- Stress at distance `d`, saturating at zero. -/
def StressField.stress (f : StressField) (d : Nat) : Nat :=
  f.load - f.decayRate * d

/-- The characteristic decay length: distances at or beyond it carry no stress. -/
def StressField.decayLength (f : StressField) : Nat :=
  f.load

/-- **No load, no stress.** A vanishing boundary load gives a stress-free field
    at every distance. -/
theorem zero_load_zero_stress (f : StressField) (h : f.load = 0) (d : Nat) :
    f.stress d = 0 := by
  show f.load - f.decayRate * d = 0
  rw [h]
  exact Nat.zero_sub (f.decayRate * d)

/-- Stress never exceeds the applied load. -/
theorem stress_le_load (f : StressField) (d : Nat) :
    f.stress d ≤ f.load :=
  Nat.sub_le f.load (f.decayRate * d)

/-- **St-Venant decay is monotone.** Stress is antitone in distance: farther
    from the load, the stress is no larger. -/
theorem stress_antitone (f : StressField) {d₁ d₂ : Nat} (h : d₁ ≤ d₂) :
    f.stress d₂ ≤ f.stress d₁ :=
  Nat.sub_le_sub_left (Nat.mul_le_mul_left f.decayRate h) f.load

/-- **The stress vanishes beyond the decay length.** Once `decayRate · d`
    overtakes the load, the field is identically zero. -/
theorem stress_vanishes_beyond_range (f : StressField) (d : Nat)
    (h : f.load ≤ f.decayRate * d) : f.stress d = 0 :=
  Nat.sub_eq_zero_of_le h

/-- **Master statement.** No load gives no stress, stress is bounded by the load
    and antitone in distance, and it vanishes beyond range. -/
theorem saint_venant_decay (f : StressField) {d₁ d₂ : Nat} (h : d₁ ≤ d₂) :
    f.stress d₁ ≤ f.load ∧ f.stress d₂ ≤ f.stress d₁ :=
  ⟨stress_le_load f d₁, stress_antitone f h⟩

end Gnosis
