import Init

/-!
# Critical path — the makespan of a task chain

A task chain is a list of task durations; its **makespan** is the total time to
run them in sequence.  The critical path is the chain whose makespan bounds the
whole project from below: the project cannot finish before any of its chains, and
the makespan grows monotonically as tasks are added — strictly so for any task of
positive duration.

The original carried a scheduling lattice with real-valued slack.  This module
keeps the finite, decidable core over `Nat` lists, with every proof closing from
`Init` and no banned tactic on an open goal.
-/

namespace Gnosis

/-- A task chain: the ordered durations of its tasks. -/
structure TaskPath where
  /-- Durations of the tasks along the chain. -/
  durations : List Nat

/-- The makespan of a chain: the sum of its task durations. -/
def TaskPath.makespan (p : TaskPath) : Nat :=
  p.durations.foldr (· + ·) 0

/-- Makespan of the empty chain is zero. -/
theorem makespan_nil : (TaskPath.mk []).makespan = 0 := rfl

/-- Prepending a task adds its duration to the makespan. -/
theorem makespan_cons (d : Nat) (ds : List Nat) :
    (TaskPath.mk (d :: ds)).makespan = d + (TaskPath.mk ds).makespan := rfl

/-- **A task finishes within the project.** The makespan is at least the leading
    task's duration. -/
theorem head_le_makespan (d : Nat) (ds : List Nat) :
    d ≤ (TaskPath.mk (d :: ds)).makespan :=
  Nat.le_add_right d ((TaskPath.mk ds).makespan)

/-- **Concatenation is additive.** Running two chains in sequence sums their
    makespans. -/
theorem makespan_append (ds es : List Nat) :
    (TaskPath.mk (ds ++ es)).makespan
      = (TaskPath.mk ds).makespan + (TaskPath.mk es).makespan := by
  induction ds with
  | nil => exact (Nat.zero_add _).symm
  | cons d ds ih =>
      show d + (TaskPath.mk (ds ++ es)).makespan
        = d + (TaskPath.mk ds).makespan + (TaskPath.mk es).makespan
      rw [ih]
      exact (Nat.add_assoc d _ _).symm

/-- **The project bounds every sub-chain below.** Completion is at least the
    makespan of any prefix chain. -/
theorem prefix_le_makespan (ds es : List Nat) :
    (TaskPath.mk ds).makespan ≤ (TaskPath.mk (ds ++ es)).makespan := by
  rw [makespan_append]
  exact Nat.le_add_right _ _

/-- **Adding a task is a strict monovariant.** Any task of positive duration
    strictly increases the makespan. -/
theorem adding_task_increases (d : Nat) (ds : List Nat) (h : 0 < d) :
    (TaskPath.mk ds).makespan < (TaskPath.mk (d :: ds)).makespan := by
  show (TaskPath.mk ds).makespan < d + (TaskPath.mk ds).makespan
  exact Nat.lt_add_of_pos_left h

end Gnosis
