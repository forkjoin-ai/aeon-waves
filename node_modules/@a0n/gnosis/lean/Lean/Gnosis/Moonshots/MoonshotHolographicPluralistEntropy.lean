import Init

/-!
# Holographic pluralist entropy — entropy bounded by the boundary

The holographic principle caps a region's pluralist entropy by its boundary
information.  Modeling the realized entropy as the smaller of the bulk
interpretation count and the holographic boundary, the finite core proves the
bound holds by construction and is saturated only when the bulk is the binding
constraint.

Init-only; every proof closes from `Nat` lemmas with no banned tactic on an open
goal.
-/

namespace Gnosis

/-- A holographic region: bulk interpretations against a boundary bound. -/
structure HolographicRegion where
  interpretations : Nat
  holographicBound : Nat

/-- Realized pluralist entropy: capped by the boundary. -/
def HolographicRegion.pluralistEntropy (r : HolographicRegion) : Nat :=
  min r.interpretations r.holographicBound

/-- **The holographic bound holds.** -/
theorem entropy_le_bound (r : HolographicRegion) :
    r.pluralistEntropy ≤ r.holographicBound :=
  Nat.min_le_right r.interpretations r.holographicBound

/-- Entropy never exceeds the available bulk interpretations either. -/
theorem entropy_le_interpretations (r : HolographicRegion) :
    r.pluralistEntropy ≤ r.interpretations :=
  Nat.min_le_left r.interpretations r.holographicBound

/-- When the bulk is the binding constraint, entropy equals the interpretations. -/
theorem entropy_eq_interpretations (r : HolographicRegion)
    (h : r.interpretations ≤ r.holographicBound) :
    r.pluralistEntropy = r.interpretations :=
  Nat.min_eq_left h

end Gnosis
