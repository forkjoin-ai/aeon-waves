import Init

/-!
# Ergodic jazz — an improvisation that cycles through every state

A syncopated improvisation visits states on a cycle of `numStates` positions: the
state at time `t` is `t % numStates`.  The finite core proves ergodicity: the
orbit is periodic, returns to its start after a full period, and every visited
state lies within range.

Init-only; every proof closes from `Nat` lemmas with no banned tactic on an open
goal.
-/

namespace Gnosis

/-- The improvisation's state at time `t` on a cycle of `numStates`. -/
def statePos (numStates t : Nat) : Nat := t % numStates

/-- **Periodicity.** The orbit repeats every `numStates` beats. -/
theorem orbit_periodic (numStates t : Nat) :
    statePos numStates (t + numStates) = statePos numStates t :=
  Nat.add_mod_right t numStates

/-- The orbit returns to its starting state after one full period. -/
theorem returns_to_start (numStates : Nat) :
    statePos numStates numStates = statePos numStates 0 := by
  show numStates % numStates = 0 % numStates
  rw [Nat.mod_self, Nat.zero_mod]

/-- Every visited state lies within the cycle. -/
theorem state_in_range (numStates t : Nat) (h : 0 < numStates) :
    statePos numStates t < numStates :=
  Nat.mod_lt t h

end Gnosis
