import Init

/-!
# Interpretation layer holography — layers encoded on the boundary

Each interpretation layer is recorded on one boundary cell, so the number of
realized layers is capped by the boundary capacity.  The finite core proves the
holographic cap: realized layers never exceed the boundary, and the boundary binds
exactly when there are more requested layers than cells.

Init-only; every proof closes from `Nat` lemmas with no banned tactic on an open
goal.
-/

namespace Gnosis

/-- An interpretation stack: requested layers against a boundary capacity. -/
structure InterpretationStack where
  requestedLayers : Nat
  boundaryCells : Nat

/-- Realized layers: capped by the boundary. -/
def InterpretationStack.realizedLayers (s : InterpretationStack) : Nat :=
  min s.requestedLayers s.boundaryCells

/-- **Holographic cap.** Realized layers never exceed the boundary. -/
theorem layers_le_boundary (s : InterpretationStack) :
    s.realizedLayers ≤ s.boundaryCells :=
  Nat.min_le_right s.requestedLayers s.boundaryCells

/-- Realized layers never exceed the request. -/
theorem layers_le_requested (s : InterpretationStack) :
    s.realizedLayers ≤ s.requestedLayers :=
  Nat.min_le_left s.requestedLayers s.boundaryCells

/-- When the request fits, every layer is realized. -/
theorem all_layers_realized (s : InterpretationStack)
    (h : s.requestedLayers ≤ s.boundaryCells) :
    s.realizedLayers = s.requestedLayers :=
  Nat.min_eq_left h

end Gnosis
