import Init

/-!
# Subatomic bureaucracy — overhead caps usable entropy

A bureaucratic layer of overhead reduces the entropy a system can usefully carry:
usable entropy is the capacity minus the overhead.  The finite core proves the cap
— usable entropy never exceeds capacity, is antitone in overhead, and vanishes
once overhead saturates capacity.

Init-only; every proof closes from `Nat` lemmas with no banned tactic on an open
goal.
-/

namespace Gnosis

/-- A subatomic system: an entropy capacity and a bureaucratic overhead. -/
structure SubatomicState where
  capacity : Nat
  overhead : Nat

/-- Usable entropy after overhead. -/
def SubatomicState.usableEntropy (s : SubatomicState) : Nat := s.capacity - s.overhead

/-- **Usable entropy never exceeds capacity.** -/
theorem usable_le_capacity (s : SubatomicState) : s.usableEntropy ≤ s.capacity :=
  Nat.sub_le s.capacity s.overhead

/-- More overhead leaves less usable entropy. -/
theorem usable_antitone_overhead (cap : Nat) {o1 o2 : Nat} (h : o1 ≤ o2) :
    SubatomicState.usableEntropy ⟨cap, o2⟩ ≤ SubatomicState.usableEntropy ⟨cap, o1⟩ :=
  Nat.sub_le_sub_left h cap

/-- Saturating overhead drives usable entropy to zero. -/
theorem saturated_zero_entropy (s : SubatomicState) (h : s.capacity ≤ s.overhead) :
    s.usableEntropy = 0 :=
  Nat.sub_eq_zero_of_le h

end Gnosis
