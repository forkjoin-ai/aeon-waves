import Init

/-!
# Witness gap homotopy bypass — invariants cover the gap

A homotopy bypasses a witness gap when its invariants account for the gap plus a
surplus.  The finite core proves the bypass: the homotopy invariants always
dominate the witness gap, with equality exactly when the surplus is zero.

Init-only; every proof closes from `Nat` lemmas with no banned tactic on an open
goal.
-/

namespace Gnosis

/-- A homotopy carrying a witness gap plus a surplus of invariants. -/
structure WitnessGapHomotopy where
  witnessGap : Nat
  surplus : Nat

/-- The homotopy invariants: gap plus surplus. -/
def WitnessGapHomotopy.invariants (w : WitnessGapHomotopy) : Nat := w.witnessGap + w.surplus

/-- **The bypass.** Invariants dominate the witness gap. -/
theorem homotopy_bypasses_gap (w : WitnessGapHomotopy) :
    w.witnessGap ≤ w.invariants :=
  Nat.le_add_right w.witnessGap w.surplus

/-- A positive surplus strictly exceeds the gap. -/
theorem strict_bypass (w : WitnessGapHomotopy) (h : 0 < w.surplus) :
    w.witnessGap < w.invariants :=
  Nat.lt_add_of_pos_right h

/-- With no surplus the invariants meet the gap exactly. -/
theorem tight_bypass (w : WitnessGapHomotopy) (h : w.surplus = 0) :
    w.invariants = w.witnessGap := by
  show w.witnessGap + w.surplus = w.witnessGap
  rw [h, Nat.add_zero]

end Gnosis
