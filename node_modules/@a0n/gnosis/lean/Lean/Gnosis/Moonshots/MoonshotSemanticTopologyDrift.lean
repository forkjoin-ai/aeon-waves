import Init

/-!
# Semantic topology drift — bounded accumulation of per-step drift

Semantic drift accumulates a bounded amount per step.  The finite core proves the
total drift after `k` steps is bounded by `k · stepBound`, is monotone in the step
count, and is zero when there is no per-step drift.

Init-only; every proof closes from `Nat` lemmas with no banned tactic on an open
goal.
-/

namespace Gnosis

/-- A drift process: a per-step drift bound. -/
structure DriftProcess where
  stepBound : Nat

/-- Accumulated drift after `k` steps. -/
def DriftProcess.drift (p : DriftProcess) (k : Nat) : Nat := k * p.stepBound

/-- **Drift is bounded by `k · stepBound`.** -/
theorem drift_bounded (p : DriftProcess) (k : Nat) : p.drift k ≤ k * p.stepBound :=
  Nat.le_refl _

/-- Drift is monotone in the step count. -/
theorem drift_monotone (p : DriftProcess) {j k : Nat} (h : j ≤ k) :
    p.drift j ≤ p.drift k :=
  Nat.mul_le_mul_right p.stepBound h

/-- A driftless process never drifts. -/
theorem no_step_no_drift (p : DriftProcess) (h : p.stepBound = 0) (k : Nat) :
    p.drift k = 0 := by
  show k * p.stepBound = 0
  rw [h, Nat.mul_zero]

/-- One more step adds at most `stepBound` of drift. -/
theorem drift_step (p : DriftProcess) (k : Nat) :
    p.drift (k + 1) = p.drift k + p.stepBound := by
  show (k + 1) * p.stepBound = k * p.stepBound + p.stepBound
  rw [Nat.succ_mul]

end Gnosis
