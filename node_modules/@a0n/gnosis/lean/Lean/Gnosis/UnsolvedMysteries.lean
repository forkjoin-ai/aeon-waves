import Init

/-!
# Unsolved mysteries — Buleyean structure behind the open problems

Several open problems share Buleyean structure: fine-tuning is structural (every
constant keeps positive weight), stable constants are preferred (concentration), a
fold breaks symmetry (an `N`-way fork vents `N - 1 ≥ 1`), and a saturated niche
(more lineages than resources) carries a positive deficit.

The original mapped each domain into `BuleyeanSpace`; here the finite core is
self-contained over `Nat`, every proof closing from `Init`.
-/

namespace Gnosis
namespace UnsolvedMysteries

/-- A space of physical constants as competing settings. -/
structure BuleyeanSpace where
  rounds : Nat
  rejection : Nat → Nat
  bounded : ∀ i, rejection i ≤ rounds

def BuleyeanSpace.weight (bs : BuleyeanSpace) (i : Nat) : Nat := bs.rounds - bs.rejection i + 1

/-- **Fine-tuning is structural:** every constant keeps positive weight. -/
theorem fine_tuning_is_structural (bs : BuleyeanSpace) (i : Nat) : 1 ≤ bs.weight i :=
  Nat.le_add_left 1 (bs.rounds - bs.rejection i)

/-- **Stable constants are preferred** (concentration). -/
theorem stable_constants_preferred (bs : BuleyeanSpace) (i j : Nat)
    (h : bs.rejection i ≤ bs.rejection j) : bs.weight j ≤ bs.weight i := by
  show bs.rounds - bs.rejection j + 1 ≤ bs.rounds - bs.rejection i + 1
  exact Nat.add_le_add_right (Nat.sub_le_sub_left h bs.rounds) 1

/-- An `N`-way fold step. -/
structure FoldStep where
  forkWidth : Nat
  nontrivial : 2 ≤ forkWidth

/-- **Baryon asymmetry from the fold:** an `N`-way fork vents at least one path. -/
theorem baryon_asymmetry_from_fold (step : FoldStep) : 1 ≤ step.forkWidth - 1 :=
  Nat.sub_le_sub_right step.nontrivial 1

/-- **The fold breaks symmetry:** any nontrivial fork vents a positive surplus. -/
theorem fold_breaks_symmetry {N : Nat} (hN : 2 ≤ N) : 0 < N - 1 :=
  Nat.sub_pos_of_lt (Nat.lt_of_lt_of_le (by decide) hN)

/-- **Cambrian saturation:** more lineages than resources forces a positive deficit. -/
theorem cambrian_saturation (niches resources : Nat) (h : resources < niches) :
    0 < niches - resources := Nat.sub_pos_of_lt h

end UnsolvedMysteries
end Gnosis
