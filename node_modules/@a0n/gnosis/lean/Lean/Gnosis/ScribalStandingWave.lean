import Init

namespace Gnosis
namespace ScribalStandingWave

/-- Failure kinds that define the mechanical-brain rejection boundary. -/
inductive ScribalFailureKind where
  | hallucination
  | staleMemory
  | sourceSubstitution
  | missingContext
  | overclaim
  deriving DecidableEq, Repr

/-- Audited use kinds that may pass through the boundary as non-source claims. -/
inductive ScribalUseKind where
  | assistedReasoning
  | scribalMemory
  | measuredTranslation
  | failureAudit
  deriving DecidableEq, Repr

/-- Thoth agentic modalities mirrored by the Rust mechanical-brain contract. -/
inductive ThothAgenticModality where
  | standard
  | ask
  | edit
  | plan
  | decide
  | reason
  deriving DecidableEq, Repr

/-- Transcript modes mirrored by Rust tagged transcript handling. -/
inductive TaggedTranscriptMode where
  | tagged
  | rawEscape
  deriving DecidableEq, Repr

/-- Pleromatic media classes needed by the Thoth/Monster Mesh container. -/
inductive PleromaticMediaType where
  | semantic
  | application
  | abstract
  deriving DecidableEq, Repr

/-- Runtime mirror of Rust's observed failure event. -/
structure FailureEvent where
  kind : ScribalFailureKind
  observed : Bool
  deriving DecidableEq, Repr

/-- Stable Rust-facing failure claim values. -/
def failureClaim : ScribalFailureKind -> Nat
  | .hallucination => 0
  | .staleMemory => 1
  | .sourceSubstitution => 2
  | .missingContext => 3
  | .overclaim => 4

/-- Stable Rust-facing audited use claim values. -/
def useClaim : ScribalUseKind -> Nat
  | .assistedReasoning => 10
  | .scribalMemory => 11
  | .measuredTranslation => 12
  | .failureAudit => 13

/-- Runtime mirror of Rust's compact failure boundary input. -/
structure BoundaryInput where
  hallucinationObserved : Bool
  staleMemoryObserved : Bool
  sourceSubstitutionObserved : Bool
  missingContextObserved : Bool
  overclaimObserved : Bool
  deriving DecidableEq, Repr

/-- Runtime mirror of Rust's scribal certificate facts. -/
structure Certificate where
  assistedReasoningSupported : Bool
  sourceSubstitutionRejected : Bool
  hallucinationRejected : Bool
  failureAuditSupported : Bool
  deriving DecidableEq, Repr

/-- Runtime mirror of Rust's response envelope audit contract. -/
structure ResponseEnvelope where
  boundaryInput : BoundaryInput
  certificate : Certificate
  outputClaim : Nat
  includesScribalTheorem : Bool
  includesThothTheorem : Bool
  claimsSourceAuthority : Bool
  deriving DecidableEq, Repr

/-- Runtime mirror of Rust's folded scribal audit trace. -/
structure AuditTrace where
  left : ResponseEnvelope
  right : ResponseEnvelope
  orderedEvents : List FailureEvent
  compactBoundaryInput : BoundaryInput
  leftOutputClaim : Nat
  rightOutputClaim : Nat
  traceUseClaim : Nat
  includesScribalTheorem : Bool
  includesThothTheorem : Bool
  claimsSourceAuthority : Bool
  deriving DecidableEq, Repr

/-- Minimal transcript turn mirror; content is represented by its stable hash. -/
structure TranscriptTurn where
  turnIndex : Nat
  contentHash : Nat
  deriving DecidableEq, Repr

/-- Runtime mirror of Rust's tagged transcript wrapper. -/
structure TaggedTranscriptTurn where
  turn : TranscriptTurn
  mode : TaggedTranscriptMode
  envelope : ResponseEnvelope
  auditTagPresent : Bool
  escapeHatchAcknowledged : Bool
  claimsSourceAuthority : Bool
  deriving DecidableEq, Repr

/-- Runtime mirror of Rust's transcript audit atom. -/
structure TranscriptAuditAtom where
  turnIndex : Nat
  contentHash : Nat
  mode : TaggedTranscriptMode
  auditTagPresent : Bool
  escapeGap : Bool
  claimsSourceAuthority : Bool
  deriving DecidableEq, Repr

/-- Normalized transcript audit key used for merge reasoning. -/
structure TranscriptAuditKey where
  turnIndex : Nat
  contentHash : Nat
  mode : TaggedTranscriptMode
  deriving DecidableEq, Repr

/-- Runtime mirror of Rust's transcript audit trace. -/
structure TranscriptAuditTrace where
  turns : List TaggedTranscriptTurn
  atoms : List TranscriptAuditAtom
  deriving DecidableEq, Repr

/-- Runtime mirror of transcript recall policy. -/
structure TranscriptRecallPolicy where
  currentTurnIndex : Nat
  activeWindow : Nat
  dampenedWeight : Nat
  amnesiaWeight : Nat
  deriving DecidableEq, Repr

/-- Runtime mirror of memory budget policy. -/
structure MemoryBudgetPolicy where
  activeBudget : Nat
  deriving DecidableEq, Repr

/-- Runtime mirror of recalled transcript audit state. -/
structure TranscriptRecallAtom where
  atom : TranscriptAuditAtom
  active : Bool
  dampened : Bool
  amnesiaGap : Bool
  recallWeight : Nat
  claimsSourceAuthority : Bool
  deriving DecidableEq, Repr

/-- Runtime mirror of corroborating evidence for dampened recall promotion. -/
structure RecallPromotionEvidence where
  corroboratingAtom : TranscriptAuditAtom
  fresh : Bool
  deriving DecidableEq, Repr

/-- Runtime mirror of scheduled memory atom. -/
structure ScheduledMemoryAtom where
  recall : TranscriptRecallAtom
  promoted : Bool
  priority : Nat
  deriving DecidableEq, Repr

/-- Runtime mirror of scheduled transcript memory. -/
structure ScheduledTranscriptMemory where
  activeMemory : List ScheduledMemoryAtom
  auditGaps : List TranscriptRecallAtom
  activeBudget : Nat
  deriving DecidableEq, Repr

/-- Runtime mirror of Rust's Thoth memory session. -/
structure ThothMemorySession where
  modality : ThothAgenticModality
  transcriptTrace : TranscriptAuditTrace
  recallView : List TranscriptRecallAtom
  scheduledMemory : ScheduledTranscriptMemory
  deriving DecidableEq, Repr

/-- Runtime mirror of Rust's Thoth transcript adapter input. -/
structure ThothTranscriptInput where
  turn : TranscriptTurn
  rawEscapeRequested : Bool
  modality : ThothAgenticModality
  deriving DecidableEq, Repr

/-- Runtime mirror of Rust's Thoth memory adapter. -/
structure ThothMemoryAdapter where
  modality : ThothAgenticModality
  session : ThothMemorySession
  generationContext : List ScheduledMemoryAtom
  auditGaps : List TranscriptRecallAtom
  rawEscapeRequired : Bool
  deriving DecidableEq, Repr

/-- Runtime mirror of Rust's consumed Thoth memory context. -/
structure ThothConsumedMemoryContext where
  modality : ThothAgenticModality
  activeContext : List ScheduledMemoryAtom
  visibleAuditGaps : List TranscriptRecallAtom
  sourceAuthorityRejected : Bool
  deriving DecidableEq, Repr

/-- Minimal formal mirror of Rust's `PleromaticFrame` container contract. -/
structure PleromaticFrame where
  seq : Nat
  mediaType : PleromaticMediaType
  aeonStream : Nat
  carriesMonsterMesh : Bool
  carriesThothMemory : Bool
  deriving DecidableEq, Repr

/-- Stable Rust-facing Thoth modality claim values. -/
def thothAgenticModalityClaim : ThothAgenticModality -> Nat
  | .standard => 20
  | .ask => 21
  | .edit => 22
  | .plan => 23
  | .decide => 24
  | .reason => 25

/-- The canonical failure boundary: claims `0..4` are rejected failures. -/
def canonicalFailureBoundary (claim : Nat) : Bool :=
  claim <= failureClaim .overclaim

/-- Rust-equivalent event observation: at least one matching observed event. -/
def eventLogObserves (kind : ScribalFailureKind) :
    List FailureEvent -> Bool
  | [] => false
  | event :: rest =>
      if event.kind = kind then
        event.observed || eventLogObserves kind rest
      else
        eventLogObserves kind rest

/-- Rust-equivalent projection from event log to compact boundary input. -/
def boundaryInputFromEventLog (events : List FailureEvent) : BoundaryInput :=
  { hallucinationObserved := eventLogObserves .hallucination events
    staleMemoryObserved := eventLogObserves .staleMemory events
    sourceSubstitutionObserved := eventLogObserves .sourceSubstitution events
    missingContextObserved := eventLogObserves .missingContext events
    overclaimObserved := eventLogObserves .overclaim events }

/-- Non-authority output claims are viable exactly when they are outside failures. -/
def outputClaimViable (claim : Nat) : Bool :=
  !canonicalFailureBoundary claim

/-- The boundary is complete when all canonical failure classes were observed. -/
def boundaryInputComplete (input : BoundaryInput) : Bool :=
  input.hallucinationObserved &&
  input.staleMemoryObserved &&
  input.sourceSubstitutionObserved &&
  input.missingContextObserved &&
  input.overclaimObserved

def eventLogComplete (events : List FailureEvent) : Bool :=
  boundaryInputComplete (boundaryInputFromEventLog events)

/-- Certificate facts required by the Rust runtime mirror. -/
def certificateSound (certificate : Certificate) : Bool :=
  certificate.assistedReasoningSupported &&
  certificate.sourceSubstitutionRejected &&
  certificate.hallucinationRejected &&
  certificate.failureAuditSupported

def envelopeHasTheoremLineage (envelope : ResponseEnvelope) : Bool :=
  envelope.includesScribalTheorem && envelope.includesThothTheorem

def envelopeRejectsSourceAuthority (envelope : ResponseEnvelope) : Bool :=
  !envelope.claimsSourceAuthority

def envelopeOutputViable (envelope : ResponseEnvelope) : Bool :=
  outputClaimViable envelope.outputClaim

def envelopeBoundaryMatches
    (events : List FailureEvent)
    (envelope : ResponseEnvelope) : Bool :=
  let expected := boundaryInputFromEventLog events
  envelope.boundaryInput.hallucinationObserved == expected.hallucinationObserved &&
  envelope.boundaryInput.staleMemoryObserved == expected.staleMemoryObserved &&
  envelope.boundaryInput.sourceSubstitutionObserved == expected.sourceSubstitutionObserved &&
  envelope.boundaryInput.missingContextObserved == expected.missingContextObserved &&
  envelope.boundaryInput.overclaimObserved == expected.overclaimObserved

/-- The Rust `scribal_response_envelope_sound` predicate with event-log plumbing. -/
def responseEnvelopeSound
    (events : List FailureEvent)
    (envelope : ResponseEnvelope) : Bool :=
  eventLogComplete events &&
  envelopeBoundaryMatches events envelope &&
  certificateSound envelope.certificate &&
  envelopeOutputViable envelope &&
  envelopeHasTheoremLineage envelope &&
  envelopeRejectsSourceAuthority envelope

def auditTracePreservesOrderedEvents
    (leftEvents rightEvents : List FailureEvent)
    (trace : AuditTrace) : Bool :=
  trace.orderedEvents == leftEvents ++ rightEvents

def auditTraceBoundaryMatchesCompactSummary (trace : AuditTrace) : Bool :=
  let expected := boundaryInputFromEventLog trace.orderedEvents
  trace.compactBoundaryInput.hallucinationObserved == expected.hallucinationObserved &&
  trace.compactBoundaryInput.staleMemoryObserved == expected.staleMemoryObserved &&
  trace.compactBoundaryInput.sourceSubstitutionObserved == expected.sourceSubstitutionObserved &&
  trace.compactBoundaryInput.missingContextObserved == expected.missingContextObserved &&
  trace.compactBoundaryInput.overclaimObserved == expected.overclaimObserved

def auditTraceChildrenSound
    (leftEvents rightEvents : List FailureEvent)
    (trace : AuditTrace) : Bool :=
  responseEnvelopeSound leftEvents trace.left &&
  responseEnvelopeSound rightEvents trace.right

def auditTraceOutputViable (trace : AuditTrace) : Bool :=
  outputClaimViable trace.leftOutputClaim &&
  outputClaimViable trace.rightOutputClaim &&
  outputClaimViable trace.traceUseClaim

def auditTraceHasTheoremLineage (trace : AuditTrace) : Bool :=
  trace.includesScribalTheorem && trace.includesThothTheorem

def auditTraceRejectsSourceAuthority (trace : AuditTrace) : Bool :=
  !trace.claimsSourceAuthority

/-- Rust-equivalent soundness predicate for a folded audit trace. -/
def auditTraceSound
    (leftEvents rightEvents : List FailureEvent)
    (trace : AuditTrace) : Bool :=
  auditTraceChildrenSound leftEvents rightEvents trace &&
  auditTracePreservesOrderedEvents leftEvents rightEvents trace &&
  auditTraceBoundaryMatchesCompactSummary trace &&
  auditTraceOutputViable trace &&
  auditTraceHasTheoremLineage trace &&
  auditTraceRejectsSourceAuthority trace

def canonicalBoundaryInput : BoundaryInput :=
  { hallucinationObserved := true
    staleMemoryObserved := true
    sourceSubstitutionObserved := true
    missingContextObserved := true
    overclaimObserved := true }

def canonicalCertificate : Certificate :=
  { assistedReasoningSupported := true
    sourceSubstitutionRejected := true
    hallucinationRejected := true
    failureAuditSupported := true }

def defaultTaggedTranscriptMode : TaggedTranscriptMode :=
  .tagged

def defaultTranscriptRecallPolicy : TranscriptRecallPolicy :=
  { currentTurnIndex := 2
    activeWindow := 1
    dampenedWeight := 25
    amnesiaWeight := 0 }

def defaultMemoryBudgetPolicy : MemoryBudgetPolicy :=
  { activeBudget := 2 }

def aeonStreamPneumaBase : Nat := 2000
def aeonStreamPneumaInput : Nat := aeonStreamPneumaBase
def aeonStreamPneumaOutput : Nat := aeonStreamPneumaBase + 1
def aeonStreamPneumaInternal : Nat := aeonStreamPneumaBase + 2
def aeonStreamPneumaAudit : Nat := aeonStreamPneumaBase + 3
def aeonStreamPneumaCertificate : Nat := aeonStreamPneumaBase + 4

def thothMonsterMeshFrame (seq : Nat) : PleromaticFrame :=
  { seq
    mediaType := .semantic
    aeonStream := aeonStreamPneumaInternal
    carriesMonsterMesh := true
    carriesThothMemory := true }

def pleromaticThothFrameSound (frame : PleromaticFrame) : Bool :=
  frame.carriesMonsterMesh &&
  frame.carriesThothMemory &&
  frame.aeonStream == aeonStreamPneumaInternal

def canonicalTranscriptTurn : TranscriptTurn :=
  { turnIndex := 2, contentHash := 4242 }

def staleTranscriptTurn : TranscriptTurn :=
  { turnIndex := 0, contentHash := 4242 }

def canonicalFailureEventLog : List FailureEvent :=
  [ ({ kind := .hallucination, observed := true } : FailureEvent),
    ({ kind := .staleMemory, observed := true } : FailureEvent),
    ({ kind := .sourceSubstitution, observed := true } : FailureEvent),
    ({ kind := .missingContext, observed := true } : FailureEvent),
    ({ kind := .overclaim, observed := true } : FailureEvent) ]

/-- Construct the canonical non-authoritative Thoth response envelope. -/
def createThothResponseEnvelope
    (events : List FailureEvent)
    (outputClaim : Nat) : ResponseEnvelope :=
  { boundaryInput := boundaryInputFromEventLog events
    certificate := canonicalCertificate
    outputClaim
    includesScribalTheorem := true
    includesThothTheorem := true
    claimsSourceAuthority := false }

/-- Fold two response envelopes into the Rust-equivalent audit trace shape. -/
def foldAuditTrace
    (leftEvents rightEvents : List FailureEvent)
    (left right : ResponseEnvelope) : AuditTrace :=
  let orderedEvents := leftEvents ++ rightEvents
  { left
    right
    orderedEvents
    compactBoundaryInput := boundaryInputFromEventLog orderedEvents
    leftOutputClaim := left.outputClaim
    rightOutputClaim := right.outputClaim
    traceUseClaim := useClaim .failureAudit
    includesScribalTheorem := left.includesScribalTheorem && right.includesScribalTheorem
    includesThothTheorem := left.includesThothTheorem && right.includesThothTheorem
    claimsSourceAuthority := left.claimsSourceAuthority || right.claimsSourceAuthority }

/-- Rust-equivalent transcript tagging, with audit tags represented as presence. -/
def tagTranscriptTurn
    (turn : TranscriptTurn)
    (mode : TaggedTranscriptMode) : TaggedTranscriptTurn :=
  match mode with
  | .tagged =>
      { turn
        mode
        envelope := createThothResponseEnvelope canonicalFailureEventLog (useClaim .failureAudit)
        auditTagPresent := true
        escapeHatchAcknowledged := false
        claimsSourceAuthority := false }
  | .rawEscape =>
      { turn
        mode
        envelope := createThothResponseEnvelope canonicalFailureEventLog (useClaim .failureAudit)
        auditTagPresent := false
        escapeHatchAcknowledged := true
        claimsSourceAuthority := false }

def tagTranscriptTurnDefault (turn : TranscriptTurn) : TaggedTranscriptTurn :=
  tagTranscriptTurn turn defaultTaggedTranscriptMode

def taggedTranscriptTurnSound (turn : TaggedTranscriptTurn) : Bool :=
  match turn.mode with
  | .tagged =>
      turn.auditTagPresent &&
      !turn.escapeHatchAcknowledged &&
      responseEnvelopeSound canonicalFailureEventLog turn.envelope &&
      !turn.claimsSourceAuthority
  | .rawEscape =>
      !turn.auditTagPresent &&
      turn.escapeHatchAcknowledged &&
      !turn.claimsSourceAuthority

def transcriptAuditAtomFromTurn (turn : TaggedTranscriptTurn) : TranscriptAuditAtom :=
  { turnIndex := turn.turn.turnIndex
    contentHash := turn.turn.contentHash
    mode := turn.mode
    auditTagPresent := turn.auditTagPresent
    escapeGap := turn.mode == .rawEscape
    claimsSourceAuthority := turn.claimsSourceAuthority }

def transcriptAuditKeyFromAtom (atom : TranscriptAuditAtom) : TranscriptAuditKey :=
  { turnIndex := atom.turnIndex
    contentHash := atom.contentHash
    mode := atom.mode }

def transcriptAuditKeyFromTurn (turn : TaggedTranscriptTurn) : TranscriptAuditKey :=
  transcriptAuditKeyFromAtom (transcriptAuditAtomFromTurn turn)

def sameTranscriptAuditKey
    (left right : TranscriptAuditAtom) : Bool :=
  transcriptAuditKeyFromAtom left == transcriptAuditKeyFromAtom right

def transcriptAuditKeys (atoms : List TranscriptAuditAtom) : List TranscriptAuditKey :=
  atoms.map transcriptAuditKeyFromAtom

def transcriptAuditKeyJoinCovers
    (left right joined : List TranscriptAuditAtom) : Bool :=
  (transcriptAuditKeys left).all
    (fun key => (transcriptAuditKeys joined).contains key) &&
  (transcriptAuditKeys right).all
    (fun key => (transcriptAuditKeys joined).contains key)

def transcriptAuditAtomSound (atom : TranscriptAuditAtom) : Bool :=
  match atom.mode with
  | .tagged =>
      atom.auditTagPresent &&
      !atom.escapeGap &&
      !atom.claimsSourceAuthority
  | .rawEscape =>
      !atom.auditTagPresent &&
      atom.escapeGap &&
      !atom.claimsSourceAuthority

def transcriptAuditTraceFromTurns
    (turns : List TaggedTranscriptTurn) : TranscriptAuditTrace :=
  { turns
    atoms := turns.map transcriptAuditAtomFromTurn }

def transcriptAuditAtomJoin
    (left right : List TranscriptAuditAtom) : List TranscriptAuditAtom :=
  right.foldl
    (fun joined atom =>
      if joined.contains atom then joined else joined ++ [atom])
    left

def transcriptAuditAtomJoinCovers
    (left right joined : List TranscriptAuditAtom) : Bool :=
  left.all (fun atom => joined.contains atom) &&
  right.all (fun atom => joined.contains atom)

def taggedTurnsCoveredByAtoms
    (turns : List TaggedTranscriptTurn)
    (atoms : List TranscriptAuditAtom) : Bool :=
  turns.all (fun turn => atoms.contains (transcriptAuditAtomFromTurn turn))

def transcriptAuditTraceMergeCovers
    (left right merged : TranscriptAuditTrace) : Bool :=
  taggedTurnsCoveredByAtoms left.turns merged.atoms &&
  taggedTurnsCoveredByAtoms right.turns merged.atoms &&
  transcriptAuditAtomJoinCovers left.atoms right.atoms merged.atoms

def transcriptAuditTraceMerge
    (left right : TranscriptAuditTrace) : TranscriptAuditTrace :=
  let leftAtoms := left.turns.map transcriptAuditAtomFromTurn
  let mergedTurns :=
    right.turns.foldl
      (fun turns turn =>
        if leftAtoms.contains (transcriptAuditAtomFromTurn turn) then
          turns
        else
          turns ++ [turn])
      left.turns
  { turns := mergedTurns
    atoms := transcriptAuditAtomJoin left.atoms right.atoms }

def transcriptAuditTraceSound (trace : TranscriptAuditTrace) : Bool :=
  trace.atoms.all transcriptAuditAtomSound &&
  trace.turns.all (fun turn => trace.atoms.contains (transcriptAuditAtomFromTurn turn)) &&
  trace.atoms.all (fun atom => !(atom.mode == .rawEscape) || atom.escapeGap)

def transcriptAtomAge
    (policy : TranscriptRecallPolicy)
    (atom : TranscriptAuditAtom) : Nat :=
  policy.currentTurnIndex - atom.turnIndex

def transcriptRecallAtomFromAudit
    (policy : TranscriptRecallPolicy)
    (atom : TranscriptAuditAtom) : TranscriptRecallAtom :=
  let active := transcriptAtomAge policy atom <= policy.activeWindow
  let amnesiaGap := atom.mode == .rawEscape
  { atom
    active
    dampened := !active && !amnesiaGap
    amnesiaGap
    recallWeight :=
      if amnesiaGap then
        policy.amnesiaWeight
      else if active then
        100
      else
        policy.dampenedWeight
    claimsSourceAuthority := atom.claimsSourceAuthority }

def transcriptRecallAtomSound (recall : TranscriptRecallAtom) : Bool :=
  transcriptAuditAtomSound recall.atom &&
  !recall.claimsSourceAuthority &&
  (!recall.amnesiaGap || recall.recallWeight == 0)

def sameRecallContent
    (left right : TranscriptAuditAtom) : Bool :=
  left.contentHash == right.contentHash

def recallPromotionEvidenceSound
    (recall : TranscriptRecallAtom)
    (evidence : RecallPromotionEvidence) : Bool :=
  recall.dampened &&
  !recall.amnesiaGap &&
  evidence.fresh &&
  evidence.corroboratingAtom.mode == .tagged &&
  evidence.corroboratingAtom.auditTagPresent &&
  !evidence.corroboratingAtom.claimsSourceAuthority &&
  sameRecallContent recall.atom evidence.corroboratingAtom

def promoteRecallAtom
    (recall : TranscriptRecallAtom)
    (evidence : RecallPromotionEvidence) : TranscriptRecallAtom :=
  if recallPromotionEvidenceSound recall evidence then
    { recall with active := true, dampened := false, recallWeight := 100 }
  else
    recall

def promotedRecallAtomSound
    (recall : TranscriptRecallAtom)
    (evidence : RecallPromotionEvidence) : Bool :=
  transcriptRecallAtomSound (promoteRecallAtom recall evidence)

def firstPromotionEvidence
    (recall : TranscriptRecallAtom) :
    List RecallPromotionEvidence -> Option RecallPromotionEvidence
  | [] => none
  | candidate :: rest =>
      if recallPromotionEvidenceSound recall candidate then
        some candidate
      else
        firstPromotionEvidence recall rest

def scheduledMemoryAtomFromRecall
    (evidence : Option RecallPromotionEvidence)
    (recall : TranscriptRecallAtom) : ScheduledMemoryAtom :=
  let promoted :=
    match evidence with
    | some candidate => recallPromotionEvidenceSound recall candidate
    | none => false
  let promotedRecall :=
    match evidence with
    | some candidate => promoteRecallAtom recall candidate
    | none => recall
  { recall := promotedRecall
    promoted
    priority :=
      if promoted then
        3
      else if recall.active then
        2
      else if recall.dampened then
        1
      else
        0 }

def scheduledMemoryAtomFromEvidence
    (evidence : List RecallPromotionEvidence)
    (recall : TranscriptRecallAtom) : ScheduledMemoryAtom :=
  scheduledMemoryAtomFromRecall (firstPromotionEvidence recall evidence) recall

def scheduledMemoryAtomSound (atom : ScheduledMemoryAtom) : Bool :=
  transcriptRecallAtomSound atom.recall &&
  !atom.recall.amnesiaGap &&
  !atom.recall.claimsSourceAuthority

def insertScheduledByPriority
    (atom : ScheduledMemoryAtom) :
    List ScheduledMemoryAtom -> List ScheduledMemoryAtom
  | [] => [atom]
  | head :: rest =>
      if atom.priority <= head.priority then
        head :: insertScheduledByPriority atom rest
      else
        atom :: head :: rest

def sortScheduledByPriority :
    List ScheduledMemoryAtom -> List ScheduledMemoryAtom
  | [] => []
  | atom :: rest =>
      insertScheduledByPriority atom (sortScheduledByPriority rest)

def scheduleTranscriptMemoryWithEvidence
    (policy : MemoryBudgetPolicy)
    (recalls : List TranscriptRecallAtom)
    (evidence : List RecallPromotionEvidence) : ScheduledTranscriptMemory :=
  { activeMemory :=
      (recalls.filter (fun recall => !recall.amnesiaGap))
        |>.map (scheduledMemoryAtomFromEvidence evidence)
        |> sortScheduledByPriority
        |>.take policy.activeBudget
    auditGaps := recalls.filter (fun recall => recall.amnesiaGap)
    activeBudget := policy.activeBudget }

def scheduleTranscriptMemory
    (policy : MemoryBudgetPolicy)
    (recalls : List TranscriptRecallAtom) : ScheduledTranscriptMemory :=
  scheduleTranscriptMemoryWithEvidence policy recalls []

def scheduledTranscriptMemorySound (schedule : ScheduledTranscriptMemory) : Bool :=
  schedule.activeMemory.length <= schedule.activeBudget &&
  schedule.activeMemory.all scheduledMemoryAtomSound &&
  schedule.auditGaps.all (fun gap => gap.amnesiaGap && !gap.claimsSourceAuthority)

def transcriptRecallView
    (policy : TranscriptRecallPolicy)
    (atoms : List TranscriptAuditAtom) : List TranscriptRecallAtom :=
  atoms.map (transcriptRecallAtomFromAudit policy)

def transcriptRecallViewSound (recalls : List TranscriptRecallAtom) : Bool :=
  recalls.all transcriptRecallAtomSound

def buildThothMemorySessionWithModalityAndEvidence
    (modality : ThothAgenticModality)
    (recallPolicy : TranscriptRecallPolicy)
    (budgetPolicy : MemoryBudgetPolicy)
    (turns : List TaggedTranscriptTurn)
    (evidence : List RecallPromotionEvidence) : ThothMemorySession :=
  let transcriptTrace := transcriptAuditTraceFromTurns turns
  let recallView := transcriptRecallView recallPolicy transcriptTrace.atoms
  let scheduledMemory :=
    scheduleTranscriptMemoryWithEvidence budgetPolicy recallView evidence
  { modality
    transcriptTrace
    recallView
    scheduledMemory }

def buildThothMemorySessionWithModality
    (modality : ThothAgenticModality)
    (recallPolicy : TranscriptRecallPolicy)
    (budgetPolicy : MemoryBudgetPolicy)
    (turns : List TaggedTranscriptTurn) : ThothMemorySession :=
  buildThothMemorySessionWithModalityAndEvidence
    modality recallPolicy budgetPolicy turns []

def buildThothMemorySession
    (recallPolicy : TranscriptRecallPolicy)
    (budgetPolicy : MemoryBudgetPolicy)
    (turns : List TaggedTranscriptTurn) : ThothMemorySession :=
  buildThothMemorySessionWithModality .standard recallPolicy budgetPolicy turns

def mergeThothMemorySession
    (recallPolicy : TranscriptRecallPolicy)
    (budgetPolicy : MemoryBudgetPolicy)
    (left right : ThothMemorySession)
    (evidence : List RecallPromotionEvidence) : ThothMemorySession :=
  let modality :=
    if left.modality == right.modality then left.modality else .standard
  let transcriptTrace :=
    transcriptAuditTraceMerge left.transcriptTrace right.transcriptTrace
  let recallView := transcriptRecallView recallPolicy transcriptTrace.atoms
  let scheduledMemory :=
    scheduleTranscriptMemoryWithEvidence budgetPolicy recallView evidence
  { modality
    transcriptTrace
    recallView
    scheduledMemory }

def thothMemorySessionSound (session : ThothMemorySession) : Bool :=
  transcriptAuditTraceSound session.transcriptTrace &&
  transcriptRecallViewSound session.recallView &&
  scheduledTranscriptMemorySound session.scheduledMemory

def thothMemorySessionRejectsSourceAuthority (session : ThothMemorySession) : Bool :=
  session.scheduledMemory.activeMemory.all
    (fun atom => !atom.recall.claimsSourceAuthority) &&
  session.scheduledMemory.auditGaps.all
    (fun gap => !gap.claimsSourceAuthority)

def createThothTranscriptInputWithModality
    (modality : ThothAgenticModality)
    (turnIndex contentHash : Nat)
    (rawEscapeRequested : Bool) : ThothTranscriptInput :=
  { turn := { turnIndex, contentHash }
    rawEscapeRequested
    modality }

def createThothTranscriptInput
    (turnIndex contentHash : Nat)
    (rawEscapeRequested : Bool) : ThothTranscriptInput :=
  createThothTranscriptInputWithModality .standard turnIndex contentHash rawEscapeRequested

def thothTranscriptInputToTaggedTurn
    (input : ThothTranscriptInput) : TaggedTranscriptTurn :=
  tagTranscriptTurn input.turn
    (if input.rawEscapeRequested then .rawEscape else .tagged)

def thothMemoryGenerationContextSound
    (context : List ScheduledMemoryAtom) : Bool :=
  context.all
    (fun atom =>
      transcriptRecallAtomSound atom.recall &&
