import Init

/-!
# Rate-distortion frontier — rate against distortion at a fixed budget

A quotient is summarized by a rate-distortion point; on the frontier rate and
distortion sum to a fixed budget.  The finite core proves the rate-distortion
identity, the inverse tradeoff (refining to a higher rate lowers distortion), and
that the minimum-rate point attains the full distortion budget.

The original carried this over `PMF`/`ℝ`; here the finite core is self-contained
over `Nat`, every proof closing from `Init`.
-/

namespace Gnosis
namespace RateDistortionFrontier

/-- A point on the rate-distortion plane. -/
structure RateDistortionPoint where
  rate : Nat
  distortion : Nat

/-- The budget consumed: rate plus distortion. -/
def RateDistortionPoint.budget (p : RateDistortionPoint) : Nat := p.rate + p.distortion

/-- **The rate-distortion identity:** rate plus distortion is the budget. -/
theorem rate_distortion_heat_identity (p : RateDistortionPoint) :
    p.rate + p.distortion = p.budget := rfl

/-- **The inverse tradeoff:** on the same frontier, a higher rate gives a lower
    distortion. -/
theorem rate_monotone_under_refinement (p1 p2 : RateDistortionPoint)
    (hBudget : p1.budget = p2.budget) (hRate : p1.rate ≤ p2.rate) :
    p2.distortion ≤ p1.distortion := by
  have h1 : p2.rate + p2.distortion = p1.rate + p1.distortion := hBudget.symm
  have h2 : p1.rate + p1.distortion ≤ p2.rate + p1.distortion :=
    Nat.add_le_add_right hRate p1.distortion
  rw [← h1] at h2
  exact Nat.le_of_add_le_add_left h2

/-- **The minimum-rate point attains the full distortion budget.** -/
theorem minimum_rate_quotient_exists (budget : Nat) :
    ∃ p : RateDistortionPoint, p.rate = 0 ∧ p.distortion = budget ∧ p.budget = budget :=
  ⟨{ rate := 0, distortion := budget }, rfl, rfl, Nat.zero_add budget⟩

/-- **The minimum-heat (zero-distortion) point spends the budget on rate.** -/
theorem minimum_heat_quotient_exists (budget : Nat) :
    ∃ p : RateDistortionPoint, p.distortion = 0 ∧ p.rate = budget ∧ p.budget = budget :=
  ⟨{ rate := budget, distortion := 0 }, rfl, rfl, Nat.add_zero budget⟩

/-- Distortion never exceeds the budget. -/
theorem distortion_le_budget (p : RateDistortionPoint) : p.distortion ≤ p.budget :=
  Nat.le_add_left p.distortion p.rate

end RateDistortionFrontier
end Gnosis
