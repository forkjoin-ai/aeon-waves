import Init

/-!
# The gain — the habitable zone between floor and ceiling

The floor of the framework is positivity (`weight ≥ 1`); the ceiling is the weight
bound (`weight ≤ rounds + 1`).  The **gain** is the discrimination range between
them: `(rounds + 1) - 1 = rounds`.  With `rounds` observations the framework
distinguishes `rounds + 1` weight levels; with none, floor and ceiling coincide and
the gain is zero.  The gain is earned by observation.

The original built this over `BuleyeanSpace` from a Mathlib web; here the finite
core is self-contained over `Nat`, and every proof closes from `Init`.
-/

namespace Gnosis
namespace TheGain

/-- A Buleyean space: per-choice void boundary over a positive number of rounds. -/
structure BuleyeanSpace where
  rounds : Nat
  voidBoundary : Nat → Nat
  bounded : ∀ i, voidBoundary i ≤ rounds
  positiveRounds : 0 < rounds

/-- The complement weight of a choice. -/
def BuleyeanSpace.weight (bs : BuleyeanSpace) (i : Nat) : Nat :=
  bs.rounds - bs.voidBoundary i + 1

/-- The floor: every weight is positive. -/
theorem buleyean_positivity (bs : BuleyeanSpace) (i : Nat) : 0 < bs.weight i :=
  Nat.succ_pos _

/-- A never-rejected choice carries maximum weight `rounds + 1`. -/
theorem buleyean_max_uncertainty (bs : BuleyeanSpace) (i : Nat)
    (h : bs.voidBoundary i = 0) : bs.weight i = bs.rounds + 1 := by
  show bs.rounds - bs.voidBoundary i + 1 = bs.rounds + 1
  rw [h, Nat.sub_zero]

/-- A fully-rejected choice carries minimum weight `1`. -/
theorem buleyean_min_uncertainty (bs : BuleyeanSpace) (i : Nat)
    (h : bs.voidBoundary i = bs.rounds) : bs.weight i = 1 := by
  show bs.rounds - bs.voidBoundary i + 1 = 1
  rw [h, Nat.sub_self]

/-- **The discrimination gain.** Between the best and worst choice the weight gap is
    exactly `rounds`: the framework distinguishes `rounds + 1` levels. -/
theorem discrimination_gain (bs : BuleyeanSpace) (best worst : Nat)
    (hBest : bs.voidBoundary best = 0) (hWorst : bs.voidBoundary worst = bs.rounds) :
    bs.weight best - bs.weight worst = bs.rounds ∧
    bs.weight best = bs.rounds + 1 ∧
    bs.weight worst = 1 ∧
    0 < bs.rounds := by
  refine ⟨?_, buleyean_max_uncertainty bs best hBest,
    buleyean_min_uncertainty bs worst hWorst, bs.positiveRounds⟩
  rw [buleyean_max_uncertainty bs best hBest, buleyean_min_uncertainty bs worst hWorst]
  exact Nat.add_sub_cancel bs.rounds 1

/-- The gain a space earns from its observation rounds. -/
def BuleyeanSpace.gain (bs : BuleyeanSpace) : Nat := bs.rounds

/-- **The gain theorem.** Gain = ceiling − floor = `(rounds + 1) - 1 = rounds`. -/
theorem gain_eq_ceiling_minus_floor (bs : BuleyeanSpace) :
    (bs.rounds + 1) - 1 = bs.gain := Nat.add_sub_cancel bs.rounds 1

/-- The gain is earned: with observation the discrimination range is positive. -/
theorem gain_positive (bs : BuleyeanSpace) : 0 < bs.gain := bs.positiveRounds

/-- More observation rounds means at least as much gain. -/
theorem gain_monotone {a b : Nat} (h : a ≤ b) (va vb : Nat → Nat)
    (ba : ∀ i, va i ≤ a) (bb : ∀ i, vb i ≤ b) (pa : 0 < a) (pb : 0 < b) :
    (BuleyeanSpace.mk a va ba pa).gain ≤ (BuleyeanSpace.mk b vb bb pb).gain := h

end TheGain
end Gnosis
