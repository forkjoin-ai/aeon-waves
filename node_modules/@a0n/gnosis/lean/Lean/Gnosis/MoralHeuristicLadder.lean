import Init

/-!
# Moral heuristic ladder — cumulative ascent through weighted rungs

A moral ladder assigns a non-negative weight to each rung; the standing at level
`n` is the cumulative weight of the first `n` rungs.  The finite core proves the
standing is non-decreasing, grows by exactly the next rung's weight, and starts at
zero.

Init-only; every proof closes from `Nat`/`List` lemmas with no banned tactic on an
open goal.
-/

namespace Gnosis

/-- Cumulative moral standing after the first `n` rung weights. -/
def standing : List Nat → Nat
  | [] => 0
  | w :: ws => w + standing ws

/-- The empty ladder has zero standing. -/
theorem standing_nil : standing [] = 0 := rfl

/-- Adding a rung raises the standing by its weight. -/
theorem standing_cons (w : Nat) (ws : List Nat) :
    standing (w :: ws) = w + standing ws := rfl

/-- The standing never decreases when a rung is added. -/
theorem standing_monotone (w : Nat) (ws : List Nat) :
    standing ws ≤ standing (w :: ws) := by
  rw [standing_cons]; exact Nat.le_add_left _ _

/-- A rung of positive weight strictly raises the standing. -/
theorem standing_strict (w : Nat) (ws : List Nat) (hw : 0 < w) :
    standing ws < standing (w :: ws) := by
  rw [standing_cons]; exact Nat.lt_add_of_pos_left hw

/-- Each rung weight bounds the standing it tops. -/
theorem rung_le_standing (w : Nat) (ws : List Nat) : w ≤ standing (w :: ws) := by
  rw [standing_cons]; exact Nat.le_add_right _ _

end Gnosis
