import Gnosis.RootEnergyMass
import Gnosis.ProceduralShapeSoundness

namespace Gnosis

/-!
# Musculoskeletal internal roots

This module refines the internal-root model for humans and animals: muscle and
skeleton act as roots inside the body.  They convert stress-energy into bounded
posture, locomotion, and load-bearing flow rather than external collection.
-/

namespace MusculoskeletalRoot

open RootEnergyMass
open ProceduralShapeSoundness

inductive MusculoskeletalComponent where
  | skeleton
  | muscle
  | tendon
  | fascia
deriving DecidableEq, Repr

inductive InternalRootFlow where
  | posture
  | locomotion
  | loadBearing
deriving DecidableEq, Repr

inductive RootContainer where
  | bodyEnvelope
  | soilMedia
  | mineralMatrix
deriving DecidableEq, Repr

/-- One bounded flow path through the internal musculoskeletal root. -/
structure MusculoskeletalFlowSpec where
  object : RootedObject
  component : MusculoskeletalComponent
  stress : StressBucket
  flow : InternalRootFlow
  rootLoad : Nat
  bodyLoad : Nat
  bound : Nat
deriving DecidableEq, Repr

def musculoskeletalBound (_stress : StressBucket) : Nat :=
  4

def mkMusculoskeletalFlowSpec
    (object : RootedObject)
    (component : MusculoskeletalComponent)
    (stress : StressBucket)
    (flow : InternalRootFlow) : MusculoskeletalFlowSpec :=
  { object
    component
    stress
    flow
    rootLoad := rootMassFromStress stress
    bodyLoad := bodyMassFromStress stress
    bound := musculoskeletalBound stress }

def humanPostureFlow : MusculoskeletalFlowSpec :=
  mkMusculoskeletalFlowSpec RootedObject.human
    MusculoskeletalComponent.skeleton StressBucket.high
    InternalRootFlow.posture

def humanLocomotionFlow : MusculoskeletalFlowSpec :=
  mkMusculoskeletalFlowSpec RootedObject.human
    MusculoskeletalComponent.muscle StressBucket.high
    InternalRootFlow.locomotion

def humanLoadBearingFlow : MusculoskeletalFlowSpec :=
  mkMusculoskeletalFlowSpec RootedObject.human
    MusculoskeletalComponent.tendon StressBucket.high
    InternalRootFlow.loadBearing

def animalPostureFlow : MusculoskeletalFlowSpec :=
  mkMusculoskeletalFlowSpec RootedObject.animal
    MusculoskeletalComponent.skeleton StressBucket.balanced
    InternalRootFlow.posture

def animalLocomotionFlow : MusculoskeletalFlowSpec :=
  mkMusculoskeletalFlowSpec RootedObject.animal
    MusculoskeletalComponent.muscle StressBucket.balanced
    InternalRootFlow.locomotion

def animalLoadBearingFlow : MusculoskeletalFlowSpec :=
  mkMusculoskeletalFlowSpec RootedObject.animal
    MusculoskeletalComponent.fascia StressBucket.balanced
    InternalRootFlow.loadBearing

def musculoskeletalFlowCatalog : List MusculoskeletalFlowSpec :=
  [ humanPostureFlow
  , humanLocomotionFlow
  , humanLoadBearingFlow
  , animalPostureFlow
  , animalLocomotionFlow
  , animalLoadBearingFlow
  ]

def musculoskeletalObjectTrace : List RootedObject :=
  musculoskeletalFlowCatalog.map MusculoskeletalFlowSpec.object

def musculoskeletalComponentTrace : List MusculoskeletalComponent :=
  musculoskeletalFlowCatalog.map MusculoskeletalFlowSpec.component

def musculoskeletalStressTrace : List StressBucket :=
  musculoskeletalFlowCatalog.map MusculoskeletalFlowSpec.stress

def musculoskeletalFlowTrace : List InternalRootFlow :=
  musculoskeletalFlowCatalog.map MusculoskeletalFlowSpec.flow

def musculoskeletalRootLoads : List Nat :=
  musculoskeletalFlowCatalog.map MusculoskeletalFlowSpec.rootLoad

def musculoskeletalBodyLoads : List Nat :=
  musculoskeletalFlowCatalog.map MusculoskeletalFlowSpec.bodyLoad

def musculoskeletalBounds : List Nat :=
  musculoskeletalFlowCatalog.map MusculoskeletalFlowSpec.bound

def flowWithinBound (spec : MusculoskeletalFlowSpec) : Bool :=
  spec.rootLoad + spec.bodyLoad <= spec.bound

def musculoskeletalFlowsBounded : Bool :=
  musculoskeletalFlowCatalog.all flowWithinBound

def musculoskeletalObjectsHaveInternalRoots : Bool :=
  [humanRootSpec, animalRootSpec].all
    (fun spec =>
      spec.placement = RootPlacement.internal ∧
      spec.role = RootRole.musculoskeletalAnchor)

def catalogBridgeHasAnimalMusculoskeletalRoot : Bool :=
  animalCatalogRootFlowBridge.placement = RootPlacement.internal ∧
    animalCatalogRootFlowBridge.role = RootRole.musculoskeletalAnchor

/-- A root may grow into its container, but it cannot exceed the medium. -/
structure RootContainerConstraint where
  object : RootedObject
  placement : RootPlacement
  container : RootContainer
  rootLoad : Nat
  mediaCapacity : Nat
deriving DecidableEq, Repr

def humanContainerConstraint : RootContainerConstraint :=
  { object := RootedObject.human
    placement := RootPlacement.internal
    container := RootContainer.bodyEnvelope
    rootLoad := humanRootSpec.rootMass
    mediaCapacity := humanRootSpec.totalMass }

def animalContainerConstraint : RootContainerConstraint :=
  { object := RootedObject.animal
    placement := RootPlacement.internal
    container := RootContainer.bodyEnvelope
    rootLoad := animalRootSpec.rootMass
    mediaCapacity := animalRootSpec.totalMass }

def treeContainerConstraint : RootContainerConstraint :=
  { object := RootedObject.tree
    placement := RootPlacement.external
    container := RootContainer.soilMedia
    rootLoad := treeRootSpec.rootMass
    mediaCapacity := treeRootSpec.totalMass }

def fernContainerConstraint : RootContainerConstraint :=
  { object := RootedObject.fern
    placement := RootPlacement.external
    container := RootContainer.soilMedia
    rootLoad := fernRootSpec.rootMass
    mediaCapacity := fernRootSpec.totalMass }

def rockContainerConstraint : RootContainerConstraint :=
  { object := RootedObject.rock
    placement := RootPlacement.internal
    container := RootContainer.mineralMatrix
    rootLoad := rockRootSpec.rootMass
    mediaCapacity := rockRootSpec.totalMass }

def rootContainerConstraints : List RootContainerConstraint :=
  [ humanContainerConstraint
  , animalContainerConstraint
  , treeContainerConstraint
  , fernContainerConstraint
  , rockContainerConstraint
  ]

def rootContainerTrace : List RootContainer :=
  rootContainerConstraints.map RootContainerConstraint.container

def rootContainerPlacements : List RootPlacement :=
  rootContainerConstraints.map RootContainerConstraint.placement

def rootContainerLoads : List Nat :=
  rootContainerConstraints.map RootContainerConstraint.rootLoad

def rootContainerCapacities : List Nat :=
  rootContainerConstraints.map RootContainerConstraint.mediaCapacity

def rootContainedByMedia (constraint : RootContainerConstraint) : Bool :=
  constraint.rootLoad <= constraint.mediaCapacity

def allRootsContainedByMedia : Bool :=
  rootContainerConstraints.all rootContainedByMedia

/--
Human and animal internal roots are musculoskeletal anchors.  Stress-energy is
routed into bounded posture, locomotion, and load-bearing flow.
-/
def musculoskeletalRootCertified : Prop :=
  musculoskeletalObjectTrace =
    [ RootedObject.human
    , RootedObject.human
    , RootedObject.human
    , RootedObject.animal
    , RootedObject.animal
    , RootedObject.animal
    ] /\
    musculoskeletalComponentTrace =
    [ MusculoskeletalComponent.skeleton
    , MusculoskeletalComponent.muscle
    , MusculoskeletalComponent.tendon
    , MusculoskeletalComponent.skeleton
    , MusculoskeletalComponent.muscle
    , MusculoskeletalComponent.fascia
    ] /\
    musculoskeletalStressTrace =
    [ StressBucket.high
    , StressBucket.high
    , StressBucket.high
    , StressBucket.balanced
    , StressBucket.balanced
    , StressBucket.balanced
    ] /\
    musculoskeletalFlowTrace =
    [ InternalRootFlow.posture
    , InternalRootFlow.locomotion
    , InternalRootFlow.loadBearing
    , InternalRootFlow.posture
    , InternalRootFlow.locomotion
    , InternalRootFlow.loadBearing
    ] /\
    musculoskeletalRootLoads = [3, 3, 3, 2, 2, 2] /\
    musculoskeletalBodyLoads = [1, 1, 1, 2, 2, 2] /\
    musculoskeletalBounds = List.replicate 6 4 /\
    musculoskeletalFlowsBounded = true /\
    musculoskeletalObjectsHaveInternalRoots = true /\
    catalogBridgeHasAnimalMusculoskeletalRoot = true /\
    rootContainerTrace =
    [ RootContainer.bodyEnvelope
    , RootContainer.bodyEnvelope
    , RootContainer.soilMedia
    , RootContainer.soilMedia
    , RootContainer.mineralMatrix
    ] /\
    rootContainerPlacements =
    [ RootPlacement.internal
    , RootPlacement.internal
    , RootPlacement.external
    , RootPlacement.external
    , RootPlacement.internal
    ] /\
    rootContainerLoads = [3, 2, 1, 1, 2] /\
    rootContainerCapacities = List.replicate 5 4 /\
    allRootsContainedByMedia = true

theorem musculoskeletal_root_certified :
    musculoskeletalRootCertified := by
  simp [musculoskeletalRootCertified, musculoskeletalObjectTrace,
    musculoskeletalComponentTrace, musculoskeletalStressTrace,
    musculoskeletalFlowTrace, musculoskeletalRootLoads,
    musculoskeletalBodyLoads, musculoskeletalBounds,
    musculoskeletalFlowsBounded, musculoskeletalObjectsHaveInternalRoots,
    catalogBridgeHasAnimalMusculoskeletalRoot, rootContainerTrace,
    rootContainerPlacements, rootContainerLoads, rootContainerCapacities,
    allRootsContainedByMedia, rootContainerConstraints,
    rootContainedByMedia, humanContainerConstraint,
    animalContainerConstraint, treeContainerConstraint,
    fernContainerConstraint, rockContainerConstraint,
    musculoskeletalFlowCatalog,
    flowWithinBound, humanPostureFlow, humanLocomotionFlow,
    humanLoadBearingFlow, animalPostureFlow, animalLocomotionFlow,
    animalLoadBearingFlow, mkMusculoskeletalFlowSpec,
    musculoskeletalBound, rootMassFromStress, bodyMassFromStress,
    stressEnergy, humanRootSpec, animalRootSpec, treeRootSpec,
    fernRootSpec, rockRootSpec, mkRootEnergySpec,
    mycelialRouteFromStress, routeRootLoad, routeBodyLoad,
    totalMassFromStress,
    animalCatalogRootFlowBridge, rootFlowBridgeFromSpec]

theorem musculoskeletal_flows_are_bounded :
    musculoskeletalFlowsBounded = true := by
  simp [musculoskeletalFlowsBounded, musculoskeletalFlowCatalog,
    flowWithinBound, humanPostureFlow, humanLocomotionFlow,
    humanLoadBearingFlow, animalPostureFlow, animalLocomotionFlow,
    animalLoadBearingFlow, mkMusculoskeletalFlowSpec,
    musculoskeletalBound, rootMassFromStress, bodyMassFromStress,
    stressEnergy]

theorem human_and_animal_roots_are_musculoskeletal :
    musculoskeletalObjectsHaveInternalRoots = true := by
  simp [musculoskeletalObjectsHaveInternalRoots, humanRootSpec,
    animalRootSpec, mkRootEnergySpec]

theorem roots_are_constrained_by_their_containers :
    allRootsContainedByMedia = true := by
  simp [allRootsContainedByMedia, rootContainerConstraints,
    rootContainedByMedia, humanContainerConstraint,
    animalContainerConstraint, treeContainerConstraint,
    fernContainerConstraint, rockContainerConstraint, humanRootSpec,
    animalRootSpec, treeRootSpec, fernRootSpec, rockRootSpec,
    mkRootEnergySpec, mycelialRouteFromStress, routeRootLoad,
    routeBodyLoad, totalMassFromStress]

end MusculoskeletalRoot
end Gnosis
