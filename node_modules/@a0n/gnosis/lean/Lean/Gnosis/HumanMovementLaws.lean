import Gnosis.GoldenSpiralCity
import Gnosis.MusculoskeletalRoot

namespace Gnosis

/-!
# Human movement laws

Formal verification of five movement laws governing agent locomotion
in the Golden Spiral City worldsim.  Each law corresponds to a runtime
enforcement in worldsim-core.ts.

1. Collision impenetrability -- agents cannot overlap
2. Energy conservation during movement -- total energy bookkeeping
3. Gait step bounded by stature -- stride cannot exceed body scale
4. Street navigation validity -- paths follow the route catalog
5. Personal space preservation -- post-resolution minimum clearance

All proofs are closed (zero axioms, zero sorry).  Positions are in
millimetres (Int) to avoid rational arithmetic; non-negative quantities
use Nat.
-/

namespace HumanMovementLaws

/-! ## Law 1: Collision impenetrability -/

/-- An entity occupies a disc of radius proportional to stature. -/
structure EntityDisc where
  posX : Int       -- position X in millimetres
  posZ : Int       -- position Z in millimetres
  radius : Nat     -- collision radius in millimetres
deriving DecidableEq, Repr

/-- Two discs overlap when squared centre distance < squared sum of radii. -/
def discsOverlap (a b : EntityDisc) : Bool :=
  let dx := a.posX - b.posX
  let dz := a.posZ - b.posZ
  let distSq := dx * dx + dz * dz
  let radSum := (a.radius + b.radius : Int)
  distSq < radSum * radSum

/-- A movement step relocates an entity. -/
structure MovementStep where
  entity : EntityDisc
  newPosX : Int
  newPosZ : Int
deriving DecidableEq, Repr

/-- The disc at its new position after the step. -/
def movedDisc (step : MovementStep) : EntityDisc :=
  { step.entity with posX := step.newPosX, posZ := step.newPosZ }

/-- A step is valid when the moved disc overlaps no obstacle. -/
def movementStepValid (step : MovementStep) (obstacles : List EntityDisc) : Bool :=
  obstacles.all (fun obs => !discsOverlap (movedDisc step) obs)

theorem collision_impenetrability :
    ∀ (step : MovementStep) (obstacles : List EntityDisc),
      movementStepValid step obstacles = true →
      obstacles.all (fun obs => !discsOverlap (movedDisc step) obs) = true := by
  intro step obstacles h
  exact h

/-- Concrete witness: two entities 10m apart with 250mm radii do not overlap. -/
def entityA : EntityDisc := { posX := 0,     posZ := 0,    radius := 250 }
def entityB : EntityDisc := { posX := 10000, posZ := 0,    radius := 250 }
def entityC : EntityDisc := { posX := 0,     posZ := 10000, radius := 250 }

def witnessStep : MovementStep :=
  { entity := entityA, newPosX := 5000, newPosZ := 0 }

def witnessObstacles : List EntityDisc := [entityB, entityC]

theorem witness_step_is_valid :
    movementStepValid witnessStep witnessObstacles = true := by
  simp [movementStepValid, witnessStep, witnessObstacles,
    discsOverlap, movedDisc, entityA, entityB, entityC]

/-- Concrete witness: step INTO an obstacle is rejected. -/
def badStep : MovementStep :=
  { entity := entityA, newPosX := 10000, newPosZ := 0 }

theorem bad_step_is_invalid :
    movementStepValid badStep witnessObstacles = false := by
  simp [movementStepValid, badStep, witnessObstacles,
    discsOverlap, movedDisc, entityA, entityB, entityC]

/-! ## Law 2: Energy conservation during movement -/

/-- Movement state with full energy accounting. -/
structure MovementEnergy where
  kineticBefore : Nat        -- millijoules
  potentialBefore : Nat
  chaosBudgetBefore : Nat
  movementCost : Nat         -- energy spent on the step
  heatEmitted : Nat          -- waste heat (Landauer floor)
  kineticAfter : Nat
  potentialAfter : Nat
  chaosBudgetAfter : Nat
  clinamenFloor : Nat        -- minimum chaos energy (always > 0)
deriving DecidableEq, Repr

/-- Total energy before the step. -/
def totalBefore (e : MovementEnergy) : Nat :=
  e.kineticBefore + e.potentialBefore + e.chaosBudgetBefore

/-- Total energy after the step (excluding dissipated cost + heat). -/
def totalAfter (e : MovementEnergy) : Nat :=
  e.kineticAfter + e.potentialAfter + e.chaosBudgetAfter

/-- The bookkeeping identity: before = after + cost + heat,
    and chaos budget never drops below the clinamen floor. -/
def energyBalances (e : MovementEnergy) : Bool :=
  totalBefore e = totalAfter e + e.movementCost + e.heatEmitted ∧
  e.chaosBudgetAfter ≥ e.clinamenFloor

theorem movement_conserves_energy :
    ∀ (e : MovementEnergy),
      energyBalances e = true →
      totalBefore e = totalAfter e + e.movementCost + e.heatEmitted := by
  intro e h
  simp [energyBalances] at h
  exact h.1

theorem chaos_budget_above_clinamen :
    ∀ (e : MovementEnergy),
      energyBalances e = true →
      e.chaosBudgetAfter ≥ e.clinamenFloor := by
  intro e h
  simp [energyBalances] at h
  exact h.2

/-- Concrete witness: a walking step that conserves energy. -/
def walkingEnergyWitness : MovementEnergy :=
  { kineticBefore := 500
    potentialBefore := 200
    chaosBudgetBefore := 100
    movementCost := 80
    heatEmitted := 10
    kineticAfter := 410
    potentialAfter := 200
    chaosBudgetAfter := 100
    clinamenFloor := 1 }

theorem walking_energy_balances :
    energyBalances walkingEnergyWitness = true := by
  simp [energyBalances, totalBefore, totalAfter, walkingEnergyWitness]

/-- Running costs more energy but still balances. -/
def runningEnergyWitness : MovementEnergy :=
  { kineticBefore := 1000
    potentialBefore := 200
    chaosBudgetBefore := 100
    movementCost := 300
    heatEmitted := 50
    kineticAfter := 650
    potentialAfter := 200
    chaosBudgetAfter := 100
    clinamenFloor := 1 }

theorem running_energy_balances :
    energyBalances runningEnergyWitness = true := by
  simp [energyBalances, totalBefore, totalAfter, runningEnergyWitness]

/-! ## Law 3: Gait step bounded by stature -/

/-- Gait parameters scale stride to body dimensions. -/
structure GaitParams where
  stature : Nat          -- body height in millimetres
  strideFactor : Nat     -- stride fraction as percentage (e.g. 40 = 0.40)
  stepLength : Nat       -- actual step length in millimetres
  gaitEnergy : Nat       -- movement energy 0..100
  stepFrequency : Nat    -- steps per minute
deriving DecidableEq, Repr

/-- Maximum stride for this body: stature * strideFactor / 100. -/
def maxStride (g : GaitParams) : Nat :=
  g.stature * g.strideFactor / 100

/-- Maximum step frequency: 3 steps per minute per unit of energy. -/
def maxStepFrequency (g : GaitParams) : Nat :=
  g.gaitEnergy * 3

/-- A gait step is valid when it respects both bounds. -/
def gaitStepValid (g : GaitParams) : Bool :=
  g.stepLength ≤ maxStride g ∧
  g.stepFrequency ≤ maxStepFrequency g

theorem gait_step_bounded_by_stature :
    ∀ (g : GaitParams),
      gaitStepValid g = true →
      g.stepLength ≤ maxStride g := by
  intro g h
  simp [gaitStepValid] at h
  exact h.1

theorem gait_frequency_bounded_by_energy :
    ∀ (g : GaitParams),
      gaitStepValid g = true →
      g.stepFrequency ≤ maxStepFrequency g := by
  intro g h
  simp [gaitStepValid] at h
  exact h.2

/-- Finite gait catalog: walk, jog, sprint, shuffle. -/
def walkGait : GaitParams :=
  { stature := 1750, strideFactor := 40, stepLength := 700,
    gaitEnergy := 30, stepFrequency := 90 }

def jogGait : GaitParams :=
  { stature := 1750, strideFactor := 60, stepLength := 1050,
    gaitEnergy := 60, stepFrequency := 170 }

def sprintGait : GaitParams :=
  { stature := 1750, strideFactor := 80, stepLength := 1400,
    gaitEnergy := 90, stepFrequency := 260 }

def shuffleGait : GaitParams :=
  { stature := 1750, strideFactor := 20, stepLength := 350,
    gaitEnergy := 10, stepFrequency := 30 }

def gaitCatalog : List GaitParams :=
  [walkGait, jogGait, sprintGait, shuffleGait]

def gaitCatalogStrides : List Nat :=
  gaitCatalog.map GaitParams.stepLength

def gaitCatalogMaxStrides : List Nat :=
  gaitCatalog.map maxStride

def gaitCatalogFrequencies : List Nat :=
  gaitCatalog.map GaitParams.stepFrequency

def allGaitsValid : Bool :=
  gaitCatalog.all gaitStepValid

theorem all_gaits_are_valid :
    allGaitsValid = true := by
  simp [allGaitsValid, gaitCatalog, gaitStepValid, maxStride,
    maxStepFrequency, walkGait, jogGait, sprintGait, shuffleGait]

/-- Each cataloged step length fits within its stature-scaled bound. -/
def gaitCatalogCertified : Prop :=
  gaitCatalogStrides = [700, 1050, 1400, 350] ∧
  gaitCatalogMaxStrides = [700, 1050, 1400, 350] ∧
  gaitCatalogFrequencies = [90, 170, 260, 30] ∧
  allGaitsValid = true

theorem gait_catalog_certified :
    gaitCatalogCertified := by
  simp [gaitCatalogCertified, gaitCatalogStrides, gaitCatalogMaxStrides,
    gaitCatalogFrequencies, allGaitsValid, gaitCatalog, gaitStepValid,
    maxStride, maxStepFrequency, walkGait, jogGait, sprintGait, shuffleGait]

/-! ## Law 4: Street navigation validity -/

open GoldenSpiralCity in

/-- A navigation path is a sequence of route-catalog indices. -/
structure NavPath where
  nodes : List Nat
deriving DecidableEq, Repr

/-- Two depth values are considered adjacent (reachable in one step). -/
def depthsAdjacent (a b : Nat) : Bool :=
  a = b ∨ a + 1 = b ∨ b + 1 = a

/-- Look up a route's depth from a catalog by index (0-based), default 0. -/
def routeDepthAt (catalog : List GoldenSpiralCity.CityRoute) (idx : Nat) : Nat :=
  match catalog, idx with
  | [], _ => 0
  | route :: _, 0 => route.depth
  | _ :: rest, idx + 1 => routeDepthAt rest idx

/-- Adjacent nodes in the route catalog: both indices are in-bounds,
    distinct, and their routes are at adjacent depths. -/
def nodesConnected (catalog : List GoldenSpiralCity.CityRoute) (a b : Nat) : Bool :=
  a ≠ b ∧
  a < catalog.length ∧
  b < catalog.length ∧
  depthsAdjacent (routeDepthAt catalog a) (routeDepthAt catalog b)

/-- A node list is valid when every consecutive pair is connected. -/
def pathNodesValid (nodes : List Nat) (catalog : List GoldenSpiralCity.CityRoute) : Bool :=
  match nodes with
  | [] => true
  | [_] => true
  | a :: b :: rest =>
    nodesConnected catalog a b ∧ pathNodesValid (b :: rest) catalog

/-- A path is valid when every consecutive pair is connected. -/
def pathValid (path : NavPath) (catalog : List GoldenSpiralCity.CityRoute) : Bool :=
  pathNodesValid path.nodes catalog

/-- Concrete witness: hub (idx 0, depth 0) -> spoke (idx 1, depth 1)
    -> spiral arterial (idx 3, depth 1) -> fractal (idx 4, depth 2). -/
def witnessNavPath : NavPath := ⟨[0, 1, 3, 4]⟩

theorem witness_nav_path_is_valid :
    pathValid witnessNavPath GoldenSpiralCity.goldenSpiralCityRoutes = true := by
  simp [pathValid, pathNodesValid, witnessNavPath, nodesConnected, depthsAdjacent,
    routeDepthAt, GoldenSpiralCity.goldenSpiralCityRoutes,
    GoldenSpiralCity.lafayetteHubRoute,
    GoldenSpiralCity.northEastSpokeRoute,
    GoldenSpiralCity.southWestSpokeRoute,
    GoldenSpiralCity.goldenSpiralArterialRoute,
    GoldenSpiralCity.firstFractalSubroute,
    GoldenSpiralCity.secondFractalSubroute,
    GoldenSpiralCity.localParcelRoute]

/-- An invalid path jumps non-adjacent depths (hub 0 -> fractal depth 3). -/
def badNavPath : NavPath := ⟨[0, 5]⟩

theorem bad_nav_path_is_invalid :
    pathValid badNavPath GoldenSpiralCity.goldenSpiralCityRoutes = false := by
  simp [pathValid, pathNodesValid, badNavPath, nodesConnected, depthsAdjacent,
    routeDepthAt, GoldenSpiralCity.goldenSpiralCityRoutes,
    GoldenSpiralCity.lafayetteHubRoute,
    GoldenSpiralCity.northEastSpokeRoute,
    GoldenSpiralCity.southWestSpokeRoute,
    GoldenSpiralCity.goldenSpiralArterialRoute,
    GoldenSpiralCity.firstFractalSubroute,
    GoldenSpiralCity.secondFractalSubroute,
    GoldenSpiralCity.localParcelRoute]

/-- All routes connect the hub (inherited from GoldenSpiralCity). -/
theorem all_routes_reach_hub :
    GoldenSpiralCity.goldenSpiralRoutesReachHub = true := by
  simp [GoldenSpiralCity.goldenSpiralRoutesReachHub,
    GoldenSpiralCity.goldenSpiralCityRoutes,
    GoldenSpiralCity.lafayetteHubRoute,
    GoldenSpiralCity.northEastSpokeRoute,
    GoldenSpiralCity.southWestSpokeRoute,
    GoldenSpiralCity.goldenSpiralArterialRoute,
    GoldenSpiralCity.firstFractalSubroute,
    GoldenSpiralCity.secondFractalSubroute,
    GoldenSpiralCity.localParcelRoute]

/-! ## Law 5: Personal space preservation -/

/-- A resolved scene after collision pushback. -/
structure ResolvedScene where
  entities : List EntityDisc
  personalSpaceRadius : Nat    -- uniform personal space in millimetres
deriving DecidableEq, Repr

/-- Squared Euclidean distance between two disc centres. -/
def centreDistSq (a b : EntityDisc) : Int :=
  let dx := a.posX - b.posX
  let dz := a.posZ - b.posZ
  dx * dx + dz * dz

/-- Check that a single pair maintains personal space.
    distance^2 >= personalSpaceRadius^2. -/
def pairSpacePreserved (ps : Nat) (a b : EntityDisc) : Bool :=
  centreDistSq a b ≥ (ps * ps : Int)

/-- Check all distinct pairs (i < j) in a list. -/
def allPairsSpacePreserved (ps : Nat) : List EntityDisc → Bool
  | [] => true
  | e :: rest =>
    rest.all (fun other => pairSpacePreserved ps e other) ∧
    allPairsSpacePreserved ps rest

/-- A scene preserves personal space when all pairs satisfy the bound. -/
def personalSpacePreserved (scene : ResolvedScene) : Bool :=
  allPairsSpacePreserved scene.personalSpaceRadius scene.entities

theorem personal_space_after_resolution :
    ∀ (scene : ResolvedScene),
      personalSpacePreserved scene = true →
      allPairsSpacePreserved scene.personalSpaceRadius scene.entities = true := by
  intro scene h
  exact h

/-- Concrete witness: three entities well-spaced with 500mm personal space. -/
def resolvedWitness : ResolvedScene :=
  { entities := [
      { posX := 0,     posZ := 0,    radius := 250 },
      { posX := 3000,  posZ := 0,    radius := 250 },
      { posX := 0,     posZ := 3000, radius := 250 }
    ]
    personalSpaceRadius := 500 }

theorem resolved_witness_preserves_space :
    personalSpacePreserved resolvedWitness = true := by
  simp [personalSpacePreserved, resolvedWitness, allPairsSpacePreserved,
    pairSpacePreserved, centreDistSq]

/-- Concrete witness: entities too close violate personal space. -/
def crowdedScene : ResolvedScene :=
  { entities := [
      { posX := 0,   posZ := 0,   radius := 250 },
      { posX := 100, posZ := 0,   radius := 250 }
    ]
    personalSpaceRadius := 500 }

theorem crowded_scene_violates_space :
    personalSpacePreserved crowdedScene = false := by
  simp [personalSpacePreserved, crowdedScene, allPairsSpacePreserved,
    pairSpacePreserved, centreDistSq]

/-! ## Combined movement-law certificate

All five laws, certified over the finite witnesses assembled above.
-/

def humanMovementLawsCertified : Prop :=
  -- Law 1: collision impenetrability
  movementStepValid witnessStep witnessObstacles = true ∧
  movementStepValid badStep witnessObstacles = false ∧
  -- Law 2: energy conservation
  energyBalances walkingEnergyWitness = true ∧
  energyBalances runningEnergyWitness = true ∧
  -- Law 3: gait bounded by stature
  allGaitsValid = true ∧
  gaitCatalogStrides = [700, 1050, 1400, 350] ∧
  gaitCatalogMaxStrides = [700, 1050, 1400, 350] ∧
  -- Law 4: street navigation validity
  pathValid witnessNavPath GoldenSpiralCity.goldenSpiralCityRoutes = true ∧
  pathValid badNavPath GoldenSpiralCity.goldenSpiralCityRoutes = false ∧
  GoldenSpiralCity.goldenSpiralRoutesReachHub = true ∧
  -- Law 5: personal space preservation
  personalSpacePreserved resolvedWitness = true ∧
  personalSpacePreserved crowdedScene = false

theorem human_movement_laws_certified :
    humanMovementLawsCertified := by
  refine ⟨?_, ?_, ?_, ?_, ?_, ?_, ?_, ?_, ?_, ?_, ?_, ?_⟩
  · -- Law 1a: valid step
    simp [movementStepValid, witnessStep, witnessObstacles,
      discsOverlap, movedDisc, entityA, entityB, entityC]
  · -- Law 1b: invalid step rejected
    simp [movementStepValid, badStep, witnessObstacles,
      discsOverlap, movedDisc, entityA, entityB, entityC]
  · -- Law 2a: walking energy
    simp [energyBalances, totalBefore, totalAfter, walkingEnergyWitness]
  · -- Law 2b: running energy
    simp [energyBalances, totalBefore, totalAfter, runningEnergyWitness]
  · -- Law 3a: all gaits valid
    simp [allGaitsValid, gaitCatalog, gaitStepValid, maxStride,
      maxStepFrequency, walkGait, jogGait, sprintGait, shuffleGait]
  · -- Law 3b: stride catalog
    simp [gaitCatalogStrides, gaitCatalog, walkGait, jogGait,
      sprintGait, shuffleGait]
  · -- Law 3c: max stride catalog
    simp [gaitCatalogMaxStrides, gaitCatalog, maxStride,
      walkGait, jogGait, sprintGait, shuffleGait]
  · -- Law 4a: valid path
    simp [pathValid, pathNodesValid, witnessNavPath, nodesConnected, depthsAdjacent,
      routeDepthAt, GoldenSpiralCity.goldenSpiralCityRoutes,
      GoldenSpiralCity.lafayetteHubRoute,
      GoldenSpiralCity.northEastSpokeRoute,
      GoldenSpiralCity.southWestSpokeRoute,
      GoldenSpiralCity.goldenSpiralArterialRoute,
      GoldenSpiralCity.firstFractalSubroute,
      GoldenSpiralCity.secondFractalSubroute,
      GoldenSpiralCity.localParcelRoute]
  · -- Law 4b: invalid path
    simp [pathValid, pathNodesValid, badNavPath, nodesConnected, depthsAdjacent,
      routeDepthAt, GoldenSpiralCity.goldenSpiralCityRoutes,
      GoldenSpiralCity.lafayetteHubRoute,
      GoldenSpiralCity.northEastSpokeRoute,
      GoldenSpiralCity.southWestSpokeRoute,
      GoldenSpiralCity.goldenSpiralArterialRoute,
      GoldenSpiralCity.firstFractalSubroute,
      GoldenSpiralCity.secondFractalSubroute,
      GoldenSpiralCity.localParcelRoute]
  · -- Law 4c: all routes reach hub
    simp [GoldenSpiralCity.goldenSpiralRoutesReachHub,
      GoldenSpiralCity.goldenSpiralCityRoutes,
      GoldenSpiralCity.lafayetteHubRoute,
      GoldenSpiralCity.northEastSpokeRoute,
      GoldenSpiralCity.southWestSpokeRoute,
      GoldenSpiralCity.goldenSpiralArterialRoute,
      GoldenSpiralCity.firstFractalSubroute,
      GoldenSpiralCity.secondFractalSubroute,
      GoldenSpiralCity.localParcelRoute]
  · -- Law 5a: resolved scene preserves space
    simp [personalSpacePreserved, resolvedWitness, allPairsSpacePreserved,
      pairSpacePreserved, centreDistSq]
  · -- Law 5b: crowded scene violates space
    simp [personalSpacePreserved, crowdedScene, allPairsSpacePreserved,
      pairSpacePreserved, centreDistSq]

end HumanMovementLaws
end Gnosis
