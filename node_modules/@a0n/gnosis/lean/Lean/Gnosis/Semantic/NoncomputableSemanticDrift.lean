import Init

/-!
# Noncomputable semantic drift — the embedding gap is conserved

Although the drift itself is noncomputable, its embedding gap is conserved under
the drift step.  The finite core proves the conservation law: a step leaves the gap
unchanged, so a zero gap stays zero and any gap is preserved across iterated steps.

Init-only; every proof closes from `Nat` lemmas with no banned tactic on an open
goal.
-/

namespace Gnosis

/-- A semantic state carrying an embedding gap. -/
structure SemanticState where
  embeddingGap : Nat

/-- The drift step conserves the embedding gap. -/
def SemanticState.drift (s : SemanticState) : SemanticState := { embeddingGap := s.embeddingGap }

/-- Iterate the drift `k` times. -/
def SemanticState.driftIter : Nat → SemanticState → SemanticState
  | 0,     s => s
  | k + 1, s => (SemanticState.driftIter k s).drift

/-- **Conservation.** A drift step leaves the embedding gap unchanged. -/
theorem drift_conservation (s : SemanticState) : (s.drift).embeddingGap = s.embeddingGap := rfl

/-- The gap is conserved across any number of drift steps. -/
theorem driftIter_conserves : ∀ (k : Nat) (s : SemanticState),
    (SemanticState.driftIter k s).embeddingGap = s.embeddingGap
  | 0,     _ => rfl
  | k + 1, s => driftIter_conserves k s

/-- A zero embedding gap stays zero under drift. -/
theorem zero_gap_stays (s : SemanticState) (h : s.embeddingGap = 0) :
    (s.drift).embeddingGap = 0 := h

end Gnosis
