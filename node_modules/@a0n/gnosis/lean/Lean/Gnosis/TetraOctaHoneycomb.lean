import Init

/-!
# Tetra-octa honeycomb — the 2 : 1 cell ratio

The tetrahedral-octahedral honeycomb tiles space with two tetrahedra for every
octahedron.  The finite core fixes that ratio and its consequences: the
tetrahedron count is twice the octahedron count, the total cell count is `3·octa`,
and (for a non-empty honeycomb) tetrahedra strictly outnumber octahedra.

Init-only; every proof closes from `Nat` lemmas with no banned tactic on an open
goal.
-/

namespace Gnosis

/-- A patch of the honeycomb, indexed by its octahedron count. -/
structure Honeycomb where
  octahedra : Nat

/-- Two tetrahedra per octahedron. -/
def Honeycomb.tetrahedra (h : Honeycomb) : Nat := 2 * h.octahedra

/-- Total cells in the patch. -/
def Honeycomb.cells (h : Honeycomb) : Nat := h.tetrahedra + h.octahedra

/-- The defining ratio: tetrahedra are twice the octahedra. -/
theorem tetra_eq_two_octa (h : Honeycomb) : h.tetrahedra = 2 * h.octahedra := rfl

/-- Total cells equal three octahedra. -/
theorem cells_eq_three_octa (h : Honeycomb) : h.cells = 3 * h.octahedra := by
  show 2 * h.octahedra + h.octahedra = 3 * h.octahedra
  rw [Nat.succ_mul 2 h.octahedra]

/-- Octahedra never outnumber tetrahedra. -/
theorem octa_le_tetra (h : Honeycomb) : h.octahedra ≤ h.tetrahedra := by
  show h.octahedra ≤ 2 * h.octahedra
  exact Nat.le_mul_of_pos_left h.octahedra (by decide)

/-- A non-empty honeycomb has strictly more tetrahedra than octahedra. -/
theorem tetra_gt_octa (h : Honeycomb) (hne : 0 < h.octahedra) :
    h.octahedra < h.tetrahedra := by
  show h.octahedra < 2 * h.octahedra
  rw [Nat.two_mul]
  exact Nat.lt_add_of_pos_left hne

end Gnosis
