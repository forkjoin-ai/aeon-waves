import Init

/-!
# Oracle stall topological surgery — excising a stalled branch

Topological surgery removes one stalled branch and reconnects the rest, lowering
the branch count by exactly one while keeping the live branches intact.  The finite
core proves the surgery shrinks the branch set and conserves the live branches.

Init-only; every proof closes from `Nat` lemmas with no banned tactic on an open
goal.
-/

namespace Gnosis

/-- A stall surgery context: live branches and a stalled branch count. -/
structure StallSurgery where
  liveBranches : Nat
  stalledBranches : Nat

/-- Total branch count before surgery. -/
def StallSurgery.totalBranches (s : StallSurgery) : Nat := s.liveBranches + s.stalledBranches

/-- Excise one stalled branch. -/
def StallSurgery.excise (s : StallSurgery) : StallSurgery :=
  { liveBranches := s.liveBranches, stalledBranches := s.stalledBranches - 1 }

/-- Surgery preserves the live branches. -/
theorem excise_preserves_live (s : StallSurgery) :
    (s.excise).liveBranches = s.liveBranches := rfl

/-- **Surgery shrinks the branch set.** -/
theorem excise_le_total (s : StallSurgery) :
    (s.excise).totalBranches ≤ s.totalBranches :=
  Nat.add_le_add_left (Nat.sub_le s.stalledBranches 1) s.liveBranches

/-- With a stalled branch present, surgery strictly lowers the total. -/
theorem excise_strict (s : StallSurgery) (h : 0 < s.stalledBranches) :
    (s.excise).totalBranches < s.totalBranches := by
  show s.liveBranches + (s.stalledBranches - 1) < s.liveBranches + s.stalledBranches
  exact Nat.add_lt_add_left (Nat.sub_lt h (by decide)) s.liveBranches

end Gnosis
