import Init

/-!
# Oracle execution stall breakthrough — positive fuel guarantees progress

While fuel remains, an oracle makes strict progress: one step strictly lowers the
fuel.  The finite core proves the breakthrough — a positive-fuel state advances,
the advance is bounded by the start, and the fuel is a strict monovariant.

Init-only; every proof closes from `Nat` lemmas with no banned tactic on an open
goal.
-/

namespace Gnosis

/-- An oracle state carrying remaining fuel. -/
structure OracleState where
  fuel : Nat

/-- One step of execution. -/
def OracleState.step (s : OracleState) : OracleState := { fuel := s.fuel - 1 }

/-- **Breakthrough.** With positive fuel, a step strictly lowers it. -/
theorem step_strict_progress (s : OracleState) (h : 0 < s.fuel) :
    (s.step).fuel < s.fuel :=
  Nat.sub_lt h (by decide)

/-- A step never increases the fuel. -/
theorem step_le (s : OracleState) : (s.step).fuel ≤ s.fuel := Nat.sub_le s.fuel 1

/-- A positive-fuel state has not stalled: it can still step down. -/
theorem positive_fuel_not_stalled (s : OracleState) (h : 0 < s.fuel) :
    (s.step).fuel < s.fuel :=
  step_strict_progress s h

end Gnosis
