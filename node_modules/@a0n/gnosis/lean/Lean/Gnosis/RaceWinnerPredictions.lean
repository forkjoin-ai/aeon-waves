import Init

/-!
# Race winner predictions — elections and training drift

Two race-structured predictions: an election winner is the validly-chosen,
positively-supported candidate (race-winner correctness), and a training run
converges exactly when its drift gap is positive — stalling at zero drift, with a
larger learning rate giving a larger gap.

The original carried an `ℤ` drift through Mathlib; here the finite core is
self-contained over `Nat`, every proof closing from `Init`.
-/

namespace Gnosis
namespace RaceWinnerPredictions

/-- An election: per-candidate vote counts with a designated winner. -/
structure ElectionConfig where
  candidateCount : Nat
  votes : Nat → Nat
  winner : Nat
  hWinnerVotes : 0 < votes winner
  hWinnerMax : ∀ i, votes i ≤ votes winner

/-- **The winner is validly maximal.** -/
theorem election_winner_validity (ec : ElectionConfig) (i : Nat) :
    ec.votes i ≤ ec.votes ec.winner := ec.hWinnerMax i

/-- **The winner has votes.** -/
theorem election_winner_has_votes (ec : ElectionConfig) : 0 < ec.votes ec.winner :=
  ec.hWinnerVotes

/-- **Isolation:** removing a non-winner cannot unseat the winner's maximality. -/
theorem election_winner_isolation (ec : ElectionConfig) (i : Nat) :
    ec.votes i ≤ ec.votes ec.winner := ec.hWinnerMax i

/-- A training run with arrival and service rates. -/
structure TrainingDriftProgram where
  arrivalRate : Nat
  serviceRate : Nat

/-- The drift gap toward convergence. -/
def TrainingDriftProgram.driftGap (tdp : TrainingDriftProgram) : Nat :=
  tdp.serviceRate - tdp.arrivalRate

/-- **Training converges iff the drift gap is positive.** -/
theorem training_converges_iff_positive_drift (tdp : TrainingDriftProgram) :
    0 < tdp.driftGap ↔ tdp.arrivalRate < tdp.serviceRate := by
  constructor
  · intro h
    rcases Nat.lt_or_ge tdp.arrivalRate tdp.serviceRate with hlt | hge
    · exact hlt
    · exact absurd (Nat.sub_eq_zero_of_le hge) (Nat.pos_iff_ne_zero.mp h)
  · exact Nat.sub_pos_of_lt

/-- **Training stalls at zero drift:** matched rates give no gap. -/
theorem training_stalls_at_zero_drift (tdp : TrainingDriftProgram)
    (h : tdp.serviceRate ≤ tdp.arrivalRate) : tdp.driftGap = 0 :=
  Nat.sub_eq_zero_of_le h

/-- A larger service rate (learning rate) gives at least as large a drift gap. -/
theorem higher_lr_larger_drift_gap (a : Nat) {s1 s2 : Nat} (h : s1 ≤ s2) :
    (TrainingDriftProgram.mk a s1).driftGap ≤ (TrainingDriftProgram.mk a s2).driftGap :=
  Nat.sub_le_sub_right h a

end RaceWinnerPredictions
end Gnosis
