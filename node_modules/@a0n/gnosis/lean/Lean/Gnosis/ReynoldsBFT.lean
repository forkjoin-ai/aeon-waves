import Init

/-!
# Reynolds BFT — pipeline chunking and quorum safety

A Reynolds pipeline of `numStages` stages processes `numChunks` chunks; the idle
stages are `numStages - numChunks`.  The finite core proves: idle stages are
bounded and vanish once chunks meet stages; a quorum-safe fold (chunks ≥ stages)
keeps every stage busy and implies majority safety (`stages < 2·chunks`).

The original imported Mathlib; here the finite core is self-contained over `Nat`,
every proof closing from `Init`.
-/

namespace Gnosis
namespace ReynoldsBFT

/-- Idle stages when `numChunks` chunks flow through `numStages` stages. -/
def idleStages (numStages numChunks : Nat) : Nat := numStages - numChunks

/-- Idle stages never exceed the stage count. -/
theorem idleStages_le_numStages (N C : Nat) : idleStages N C ≤ N := Nat.sub_le N C

/-- Enough chunks leave no stage idle. -/
theorem idleStages_zero_of_chunks_ge_stages (N C : Nat) (h : N ≤ C) : idleStages N C = 0 :=
  Nat.sub_eq_zero_of_le h

/-- Below saturation the idle count is exactly the shortfall. -/
theorem idleStages_eq_of_chunks_lt_stages (N C : Nat) : idleStages N C = N - C := rfl

/-- A fold is quorum-safe when chunks meet the stages. -/
def quorumSafeFold (numStages numChunks : Nat) : Prop := numStages ≤ numChunks

/-- A fold is majority-safe when twice the chunks exceed the stages. -/
def majoritySafeFold (numStages numChunks : Nat) : Prop := numStages < 2 * numChunks

/-- Chunks meeting stages give a quorum-safe fold. -/
theorem quorumSafe_of_chunks_ge_stages (N C : Nat) (h : N ≤ C) : quorumSafeFold N C := h

/-- Chunks meeting a positive stage count give a majority-safe fold. -/
theorem majoritySafe_of_chunks_ge_stages (N C : Nat) (hN : 0 < N) (h : N ≤ C) :
    majoritySafeFold N C := by
  show N < 2 * C
  have h2 : 2 * N ≤ 2 * C := Nat.mul_le_mul_left 2 h
  have hNN : N < 2 * N := by rw [Nat.two_mul]; exact Nat.lt_add_of_pos_left hN
  exact Nat.lt_of_lt_of_le hNN h2

/-- **Quorum safety implies majority safety** (for a live pipeline). -/
theorem quorumSafe_implies_majoritySafe (N C : Nat) (hN : 0 < N) (h : quorumSafeFold N C) :
    majoritySafeFold N C := majoritySafe_of_chunks_ge_stages N C hN h

/-- Twice the chunks exceeding the stages is exactly majority safety. -/
theorem majoritySafe_of_two_chunks_gt_stages (N C : Nat) (h : N < 2 * C) :
    majoritySafeFold N C := h

end ReynoldsBFT
end Gnosis
