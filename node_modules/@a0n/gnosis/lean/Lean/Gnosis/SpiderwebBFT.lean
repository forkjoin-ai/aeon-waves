import Init

/-!
# Spiderweb BFT — Byzantine quorum intersection on a mesh

A Byzantine-fault-tolerant spiderweb of `n` nodes tolerating `f` faults requires
`n ≥ 3f + 1`.  Taking a quorum to be the largest reachable set, `n - f`, the
finite core proves the two guarantees that make BFT work:

* a quorum is *reachable* despite `f` silent nodes (`quorum + f = n`);
* any two quorums *intersect* in at least `f + 1` nodes, so they share an honest
  node (`n + (f+1) ≤ 2·quorum`) — which holds exactly because `n ≥ 3f + 1`.

Init-only; every proof closes from `Nat` lemmas with no banned tactic on an open
goal.
-/

namespace Gnosis

/-- A Byzantine config: `n` nodes tolerating `f` faults with `n ≥ 3f + 1`. -/
structure BFTConfig where
  nodes : Nat
  faults : Nat
  hBound : 3 * faults + 1 ≤ nodes

/-- The quorum: the largest set reachable despite `f` faulty nodes. -/
def BFTConfig.quorum (c : BFTConfig) : Nat := c.nodes - c.faults

/-- Faults never exceed the network. -/
theorem faults_le_nodes (c : BFTConfig) : c.faults ≤ c.nodes :=
  Nat.le_trans (Nat.le_trans (Nat.le_mul_of_pos_left c.faults (by decide))
    (Nat.le_succ _)) c.hBound

/-- A quorum is at least `2f + 1` (a strict majority of honest nodes). -/
theorem quorum_ge (c : BFTConfig) : 2 * c.faults + 1 ≤ c.quorum := by
  show 2 * c.faults + 1 ≤ c.nodes - c.faults
  have e : 3 * c.faults + 1 - c.faults = 2 * c.faults + 1 := by
    rw [Nat.succ_mul 2 c.faults, Nat.add_right_comm, Nat.add_sub_cancel]
  exact e ▸ Nat.sub_le_sub_right c.hBound c.faults

/-- **Quorum reachability.** A quorum plus the faulty nodes is the whole network. -/
theorem quorum_reachable (c : BFTConfig) : c.quorum + c.faults = c.nodes :=
  Nat.sub_add_cancel (faults_le_nodes c)

/-- A quorum fits inside the network. -/
theorem quorum_le_nodes (c : BFTConfig) : c.quorum ≤ c.nodes :=
  Nat.sub_le c.nodes c.faults

/-- **Quorum intersection.** Two quorums overlap by at least `f + 1` nodes, so
    they share an honest one: `nodes + (f + 1) ≤ 2·quorum`. -/
theorem quorums_intersect (c : BFTConfig) :
    c.nodes + (c.faults + 1) ≤ 2 * c.quorum :=
  calc c.nodes + (c.faults + 1)
      = (c.quorum + c.faults) + (c.faults + 1) := by rw [quorum_reachable]
    _ = c.quorum + (2 * c.faults + 1) := by
          rw [Nat.two_mul, Nat.add_assoc, ← Nat.add_assoc c.faults c.faults 1]
    _ ≤ c.quorum + c.quorum := Nat.add_le_add_left (quorum_ge c) c.quorum
    _ = 2 * c.quorum := (Nat.two_mul c.quorum).symm

end Gnosis
