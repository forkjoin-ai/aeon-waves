import Init

/-!
# Universal domain conservation — survived plus vented is conserved

Across every domain (combat, humor, music, …) a fork/race/fold conserves paths:
the total splits into survivors plus the vented sliver.  The finite core proves
conservation, the positive vent sliver, bounded survival, strict loss whenever
something vents, and a positive fork — uniformly for every domain.

The original carried these over a Mathlib topology; here the finite core is
self-contained over `Nat`, every proof closing from `Init`.
-/

namespace Gnosis
namespace UniversalDomainConservation

/-- A domain's fork/race/fold topology. -/
structure DomainTopology where
  totalPaths : Nat
  survivedPaths : Nat
  ventedPaths : Nat
  hConservation : totalPaths = survivedPaths + ventedPaths
  hVent : 0 < ventedPaths

/-- **Conservation:** survivors plus vented equal the total. -/
theorem domain_conservation (d : DomainTopology) :
    d.survivedPaths + d.ventedPaths = d.totalPaths := d.hConservation.symm

/-- **The sliver:** every domain vents a positive surplus. -/
theorem domain_sliver (d : DomainTopology) : 0 < d.ventedPaths := d.hVent

/-- **Bounded work:** survivors never exceed the total. -/
theorem domain_bounded_work (d : DomainTopology) : d.survivedPaths ≤ d.totalPaths := by
  rw [d.hConservation]; exact Nat.le_add_right _ _

/-- **Strict loss:** venting strictly reduces the survivor count below the total. -/
theorem domain_strict_loss (d : DomainTopology) : d.survivedPaths < d.totalPaths := by
  rw [d.hConservation]; exact Nat.lt_add_of_pos_right d.hVent

/-- **Positive fork:** every domain has at least one path. -/
theorem domain_fork_positive (d : DomainTopology) : 0 < d.totalPaths := by
  rw [d.hConservation]
  exact Nat.lt_of_lt_of_le d.hVent (Nat.le_add_left d.ventedPaths d.survivedPaths)

/-- Domain instances. -/
def combat : DomainTopology := ⟨10, 7, 3, rfl, by decide⟩
def humor : DomainTopology := ⟨8, 5, 3, rfl, by decide⟩
def music : DomainTopology := ⟨12, 9, 3, rfl, by decide⟩

theorem combat_conserves : combat.survivedPaths + combat.ventedPaths = combat.totalPaths := rfl

end UniversalDomainConservation
end Gnosis
