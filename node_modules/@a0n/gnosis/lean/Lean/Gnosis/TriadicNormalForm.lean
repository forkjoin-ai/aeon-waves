import Init

/-!
# Triadic normal form — the cyclic invariant of a triad

A triad of three components has a normal form given by its component sum.  The
finite core proves this normal form is a genuine invariant: it is unchanged by
cyclic rotation of the triad and by full reversal, and it dominates every single
component.

Init-only; every proof closes from `Nat` lemmas with no banned tactic on an open
goal.
-/

namespace Gnosis

/-- A triad of three components. -/
structure Triad where
  a : Nat
  b : Nat
  c : Nat

/-- The normal form: the component sum. -/
def Triad.normalForm (t : Triad) : Nat := t.a + t.b + t.c

/-- Cyclic rotation of a triad. -/
def Triad.rotate (t : Triad) : Triad := { a := t.b, b := t.c, c := t.a }

/-- The normal form is invariant under cyclic rotation. -/
theorem normalForm_cyclic (t : Triad) : t.rotate.normalForm = t.normalForm := by
  show t.b + t.c + t.a = t.a + t.b + t.c
  rw [Nat.add_comm (t.b + t.c) t.a, ← Nat.add_assoc]

/-- The normal form is invariant under full reversal. -/
theorem normalForm_reverse (t : Triad) :
    Triad.normalForm { a := t.c, b := t.b, c := t.a } = t.normalForm := by
  show t.c + t.b + t.a = t.a + t.b + t.c
  rw [Nat.add_comm (t.c + t.b) t.a, Nat.add_comm t.c t.b, ← Nat.add_assoc]

/-- The normal form dominates the first component. -/
theorem component_le_normalForm (t : Triad) : t.a ≤ t.normalForm :=
  Nat.le_trans (Nat.le_add_right t.a t.b) (Nat.le_add_right (t.a + t.b) t.c)

end Gnosis
