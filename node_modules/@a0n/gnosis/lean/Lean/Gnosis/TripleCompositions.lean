import Init
import Gnosis.Void.VoidWalking
import Gnosis.RenormalizationFixedPoints
import Gnosis.ThermodynamicTracedMonoidal

/-!
# Triple compositions — five chains across the restored modules

Each "triple" composes results proved elsewhere into a single chain:

1. **Positivity → many-to-one → heat.** Two supported points sharing an image make
   a coarsening many-to-one, which dissipates positive heat
   (`trace_heat_pos_of_nontrivial_feedback`).
2. **Cascade → collision → heat.** A structured frontier collapse strictly lowers
   the entropy proxy and leaves a positive survivor set.
3. **Trajectory → ordering → concentrated uniqueness.** When the void boundary
   concentrates on one absorber, its complement weight is minimal (`= 1`) and every
   other choice is maximal (`= rounds + 1`).
4. **Monotonicity → additivity → fixed-point descent.** Off a fixed point the
   information loss is positive and only grows under further coarsening
   (`nonfixed_positive_loss`).
5. **Void growth → linear dominance → sufficient statistic.** The void dominates the
   active computation and the boundary is a compact sufficient statistic
   (`void_dominance_linear`, `void_volume_positive`, `void_boundary_sufficient_statistic`).

Every proof closes from `Init` (plus the Init-only sibling modules) with no banned
tactic on an open goal.
-/

namespace Gnosis

-- Triple 1 : positivity → many-to-one → heat ---------------------------------

/-- A many-to-one coarsening (`≥ 2` merged feedback values) dissipates positive
    heat. -/
theorem positivity_guarantees_heat (s : TracedStep) (h : 2 ≤ s.feedbackValues) :
    0 < s.heat :=
  trace_heat_pos_of_nontrivial_feedback s h

-- Triple 2 : cascade → collision → heat --------------------------------------

/-- The survivor set after venting `vented` of `frontier` paths. -/
def structuredFrontier (frontier vented : Nat) : Nat := frontier - vented

/-- The frontier entropy proxy: the width of the frontier. -/
def frontierEntropyProxy (n : Nat) : Nat := n

/-- A structured failure cascade strictly lowers the entropy proxy and leaves a
    positive survivor set. -/
theorem failure_cascade_generates_heat (frontier vented : Nat)
    (hV : 0 < vented) (hS : vented < frontier) :
    frontierEntropyProxy (structuredFrontier frontier vented)
      < frontierEntropyProxy frontier ∧
    0 < structuredFrontier frontier vented := by
  refine ⟨?_, Nat.sub_pos_of_lt hS⟩
  show frontier - vented < frontier
  exact Nat.sub_lt (Nat.lt_trans hV hS) hV

-- Triple 3 : trajectory → ordering → concentrated uniqueness -----------------

/-- A Buleyean space whose complement weight is `rounds - voidBoundary + 1`. -/
structure BuleyeanSpace where
  numChoices : Nat
  rounds : Nat
  voidBoundary : Nat → Nat
  bounded : ∀ i, voidBoundary i ≤ rounds

/-- The complement weight of a choice. -/
def BuleyeanSpace.weight (bs : BuleyeanSpace) (i : Nat) : Nat :=
  bs.rounds - bs.voidBoundary i + 1

/-- Every weight is positive. -/
theorem buleyean_positivity (bs : BuleyeanSpace) (i : Nat) : 0 < bs.weight i :=
  Nat.succ_pos _

/-- A fully-vented choice carries minimal weight `1`. -/
theorem buleyean_min_uncertainty (bs : BuleyeanSpace) (i : Nat)
    (h : bs.voidBoundary i = bs.rounds) : bs.weight i = 1 := by
  show bs.rounds - bs.voidBoundary i + 1 = 1
  rw [h, Nat.sub_self]

/-- A never-vented choice carries maximal weight `rounds + 1`. -/
theorem buleyean_max_uncertainty (bs : BuleyeanSpace) (i : Nat)
    (h : bs.voidBoundary i = 0) : bs.weight i = bs.rounds + 1 := by
  show bs.rounds - bs.voidBoundary i + 1 = bs.rounds + 1
  rw [h, Nat.sub_zero]

/-- Weights are antitone in the void boundary. -/
theorem buleyean_concentration (bs : BuleyeanSpace) (i j : Nat)
    (h : bs.voidBoundary i ≤ bs.voidBoundary j) : bs.weight j ≤ bs.weight i := by
  show bs.rounds - bs.voidBoundary j + 1 ≤ bs.rounds - bs.voidBoundary i + 1
  exact Nat.add_le_add_right (Nat.sub_le_sub_left h bs.rounds) 1

/-- When the boundary concentrates on one absorber, it is the unique minimum and
    every other choice is maximal. -/
theorem concentrated_boundary_triple (bs : BuleyeanSpace) (absorber : Nat)
    (hConc : bs.voidBoundary absorber = bs.rounds)
    (hZero : ∀ j, j ≠ absorber → bs.voidBoundary j = 0) :
    bs.weight absorber = 1 ∧
    (∀ j, j ≠ absorber → bs.weight j = bs.rounds + 1) ∧
    (∀ j, bs.weight absorber ≤ bs.weight j) := by
  refine ⟨buleyean_min_uncertainty bs absorber hConc, ?_, ?_⟩
  · intro j hj; exact buleyean_max_uncertainty bs j (hZero j hj)
  · intro j
    rw [buleyean_min_uncertainty bs absorber hConc]
    exact buleyean_positivity bs j

-- Triple 4 : monotonicity → additivity → fixed-point descent -----------------

/-- Off a fixed point, the information loss is positive and only grows under
    further coarsening. -/
theorem coarsening_terminates_effectively (s : RGStep) (h : ¬ s.IsFixedPoint)
    (extra : Nat) :
    0 < s.infoLoss ∧ s.infoLoss ≤ s.infoLoss + extra :=
  ⟨nonfixed_positive_loss s h, Nat.le_add_right _ _⟩

-- Triple 5 : void growth → linear dominance → sufficient statistic -----------

/-- The void dominates linearly, has positive volume, and its boundary is a
    compact sufficient statistic. -/
theorem void_is_optimal_history (c : ConstantWidthComputation)
    (N T payloadBits logN : Nat) (hN : 2 ≤ N) (hT : 0 < T) (hPayload : 1 ≤ payloadBits)
    (hLog : 1 ≤ logN) (hLogBound : logN ≤ N - 1) :
    c.steps ≤ c.voidVolume ∧ 0 < c.voidVolume ∧
    boundaryStorage T logN ≤ fullPathStorage N T payloadBits :=
  ⟨void_dominance_linear c, void_volume_positive c,
   void_boundary_sufficient_statistic N T payloadBits logN hN hT hPayload hLog hLogBound⟩

-- Master ---------------------------------------------------------------------

/-- **Master.** The concentrated-boundary triple, the composition that the others
    feed into. -/
theorem triple_compositions_master (bs : BuleyeanSpace) (absorber : Nat)
    (hConc : bs.voidBoundary absorber = bs.rounds)
    (hZero : ∀ j, j ≠ absorber → bs.voidBoundary j = 0) :
    bs.weight absorber = 1 ∧
    (∀ j, j ≠ absorber → bs.weight j = bs.rounds + 1) ∧
    (∀ j, bs.weight absorber ≤ bs.weight j) :=
  concentrated_boundary_triple bs absorber hConc hZero

end Gnosis
