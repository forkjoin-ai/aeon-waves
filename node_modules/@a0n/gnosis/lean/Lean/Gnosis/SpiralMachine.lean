import Init

/-!
# Spiral machine — a counter that spirals through states

A spiral machine advances a state counter by a fixed stride per tick.  The finite
core proves the run is additive in the tick count (composable), monotone, and
returns the exact closed form `start + ticks · stride`.

Init-only; every proof closes from `Nat` lemmas with no banned tactic on an open
goal.
-/

namespace Gnosis

/-- A spiral machine: an initial state and a per-tick stride. -/
structure SpiralMachine where
  initial : Nat
  stride : Nat

/-- State after `n` ticks. -/
def SpiralMachine.run (m : SpiralMachine) (n : Nat) : Nat := m.initial + n * m.stride

/-- A single tick advances by one stride. -/
theorem run_succ (m : SpiralMachine) (n : Nat) :
    m.run (n + 1) = m.run n + m.stride := by
  show m.initial + (n + 1) * m.stride = m.initial + n * m.stride + m.stride
  rw [Nat.succ_mul, ← Nat.add_assoc]

/-- Running zero ticks is the initial state. -/
theorem run_zero (m : SpiralMachine) : m.run 0 = m.initial := by
  show m.initial + 0 * m.stride = m.initial
  rw [Nat.zero_mul, Nat.add_zero]

/-- The run is monotone in the tick count. -/
theorem run_monotone (m : SpiralMachine) {j k : Nat} (h : j ≤ k) :
    m.run j ≤ m.run k :=
  Nat.add_le_add_left (Nat.mul_le_mul_right m.stride h) m.initial

/-- **Composition.** Running `a` then `b` more ticks equals running `a + b`. -/
theorem run_additive (m : SpiralMachine) (a b : Nat) :
    m.run (a + b) = m.run a + b * m.stride := by
  show m.initial + (a + b) * m.stride = m.initial + a * m.stride + b * m.stride
  rw [Nat.add_mul, ← Nat.add_assoc]

end Gnosis
