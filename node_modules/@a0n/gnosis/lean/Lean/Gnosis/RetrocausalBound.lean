import Init

/-!
# Retrocausal bound — the void boundary bounds the trajectory

A trajectory is a sequence of choices; the void boundary at a choice counts how
often it was vented along the way.  The finite core proves the retrocausal bound:
each void boundary count is at most the trajectory length, the counts are additive
over concatenation, and the empty trajectory has zero boundary.

The original carried this over `Fin`/Mathlib; here the finite core is
self-contained over `Nat`/`List`, every proof closing from `Init`.
-/

namespace Gnosis
namespace RetrocausalBound

/-- The void boundary of choice `i` along a trajectory: how often `i` was vented. -/
def trajectoryVoidBoundary (traj : List Nat) (i : Nat) : Nat :=
  (traj.filter (fun x => x == i)).length

/-- The empty trajectory has zero void boundary. -/
theorem trajectoryVoidBoundary_nil (i : Nat) : trajectoryVoidBoundary [] i = 0 := rfl

/-- The void boundary is additive over concatenation. -/
theorem trajectoryVoidBoundary_append (a b : List Nat) (i : Nat) :
    trajectoryVoidBoundary (a ++ b) i =
      trajectoryVoidBoundary a i + trajectoryVoidBoundary b i := by
  show (List.filter (fun x => x == i) (a ++ b)).length =
    (List.filter (fun x => x == i) a).length + (List.filter (fun x => x == i) b).length
  rw [List.filter_append, List.length_append]

/-- **The retrocausal bound:** a void boundary count never exceeds the trajectory
    length. -/
theorem retrocausal_boundary_bounds_trajectory (traj : List Nat) (i : Nat) :
    trajectoryVoidBoundary traj i ≤ traj.length :=
  List.length_filter_le _ traj

/-- **Ordering preserved:** a prefix's void boundary never exceeds the whole
    trajectory's. -/
theorem retrocausal_ordering_preserved (a b : List Nat) (i : Nat) :
    trajectoryVoidBoundary a i ≤ trajectoryVoidBoundary (a ++ b) i := by
  rw [trajectoryVoidBoundary_append]; exact Nat.le_add_right _ _

end RetrocausalBound
end Gnosis
