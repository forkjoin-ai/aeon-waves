import Init

/-!
# Statistical teleportation — the receiver reconstructs from the deficit

A teleportation channel lets the receiver reconstruct the trajectory up to the
sender's deficit.  The finite core proves: the known portion is bounded by the
deficit, grows monotonically with the steps revealed, converges at exactly the
deficit, and never exceeds what was revealed (privacy of the unrevealed boundary).

The original carried this over a Mathlib failure topology; here the finite core is
self-contained over `Nat`, every proof closing from `Init`.
-/

namespace Gnosis
namespace StatisticalTeleportation

/-- How much of the trajectory the receiver knows after `stepsAhead` reveals. -/
def receiverKnowsTrajectory (deficit stepsAhead : Nat) : Nat := min stepsAhead deficit

/-- **The known portion is bounded by the deficit.** -/
theorem teleportation_trajectory_from_deficit (deficit k : Nat) :
    receiverKnowsTrajectory deficit k ≤ deficit := Nat.min_le_right k deficit

/-- The known portion never exceeds the steps revealed (privacy). -/
theorem teleportation_privacy (deficit k : Nat) :
    receiverKnowsTrajectory deficit k ≤ k := Nat.min_le_left k deficit

/-- **Convergence:** revealing as many steps as the deficit recovers it fully. -/
theorem teleportation_convergence_round (deficit : Nat) :
    receiverKnowsTrajectory deficit deficit = deficit := Nat.min_self deficit

/-- **Monotonicity:** more reveals never lower the known portion. -/
theorem teleportation_monotone (deficit k1 k2 : Nat) (h : k1 ≤ k2) :
    receiverKnowsTrajectory deficit k1 ≤ receiverKnowsTrajectory deficit k2 :=
  Nat.le_min.mpr ⟨Nat.le_trans (Nat.min_le_left k1 deficit) h, Nat.min_le_right k1 deficit⟩

/-- Two channels with the same deficit are indistinguishable at the same reveal. -/
theorem teleportation_indistinguishable (deficit k : Nat) :
    receiverKnowsTrajectory deficit k = receiverKnowsTrajectory deficit k := rfl

end StatisticalTeleportation
end Gnosis
