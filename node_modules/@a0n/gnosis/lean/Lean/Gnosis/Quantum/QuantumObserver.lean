import Init

/-!
# Quantum Observer — the measurement fold as a topological deficit

A quantum search over `rootN` paths is modelled as a *fork* whose first Betti
number (`β₁`, the count of independent cycles) is `rootN - 1`.  Measurement is a
*fold*: the observer selects one path and vents the remaining `rootN - 1` into
the void, collapsing `β₁` to `0`.  The **measurement deficit** — the topological
cost of observation — is therefore exactly `rootN - 1`, and the fold is lossless:
the surviving path plus the vented paths reconstitute `rootN`.

The original development quantified the same statements over `ℝ`/`ENNReal` with
measure-theoretic priors.  This module keeps the finite, decidable arithmetic
core: every claim below is a `Nat` law proved from `Init` primitives, with no
`omega`/`simp`/`decide` on open goals.
-/

namespace Gnosis

/-- β₁ of the pre-measurement fork: `rootN` superposed paths carry `rootN - 1`
    independent cycles. -/
def intrinsicBeta1 (rootN : Nat) : Nat := rootN - 1

/-- Classical post-fold β₁: a path graph has no independent cycles. -/
def classicalBeta1 : Nat := 0

/-- Quantum algorithms preserve every cycle, so their deficit is zero. -/
def quantumDeficit (_rootN : Nat) : Nat := 0

/-- Classical observation collapses the fork to a path: deficit `rootN - 1`. -/
def classicalDeficit (rootN : Nat) : Nat := intrinsicBeta1 rootN - classicalBeta1

/-- A quantum system as a fork/fold topology over a search space of side
    `rootN ≥ 2` (a nontrivial superposition). -/
structure QuantumSystem where
  /-- Square root of the search-space size. -/
  rootN : Nat
  /-- At least two paths: the superposition is nontrivial. -/
  nontrivial : 2 ≤ rootN

/-- β₁ before measurement equals the intrinsic fork count. -/
def QuantumSystem.preBeta1 (qs : QuantumSystem) : Nat := intrinsicBeta1 qs.rootN

/-- β₁ after measurement: the fold leaves a path graph. -/
def QuantumSystem.postBeta1 (_qs : QuantumSystem) : Nat := 0

/-- Quantum speedup associated with the fold. -/
def QuantumSystem.speedup (qs : QuantumSystem) : Nat := classicalDeficit qs.rootN + 1

/-- A nontrivial system has at least one path. -/
theorem one_le_rootN (qs : QuantumSystem) : 1 ≤ qs.rootN :=
  Nat.le_trans (by decide) qs.nontrivial

/-- **Superposition is a fork.** The intrinsic β₁ of `rootN` paths is `rootN - 1`. -/
theorem superposition_is_fork (rootN : Nat) :
    intrinsicBeta1 rootN = rootN - 1 := rfl

/-- **The fold collapses β₁.** Post-measurement topology is a path graph. -/
theorem observer_fold_collapses_beta1 (qs : QuantumSystem) :
    qs.postBeta1 = 0 := rfl

/-- **The measurement deficit is exact.** The fold vents exactly `rootN - 1`
    paths — not asymptotically, exactly. -/
theorem measurement_deficit_exact (qs : QuantumSystem) :
    qs.preBeta1 - qs.postBeta1 = qs.rootN - 1 := rfl

/-- **Path conservation.** The surviving path plus the vented paths equal the
    original `rootN`: the fold destroys nothing, it only vents to the void. -/
theorem path_conservation (qs : QuantumSystem) :
    1 + (qs.rootN - 1) = qs.rootN :=
  Nat.add_sub_cancel' (one_le_rootN qs)

/-- The quantum deficit is identically zero. -/
theorem quantum_deficit_is_zero (rootN : Nat) :
    quantumDeficit rootN = 0 := rfl

/-- The classical deficit is exactly `rootN - 1`. -/
theorem classical_deficit_exact (rootN : Nat) :
    classicalDeficit rootN = rootN - 1 := rfl

/-- **The Observer Effect is the fold.** Quantum runs lose no cycles; classical
    runs pay the full `rootN - 1` deficit of collapsing to a path. -/
theorem observer_effect_is_fold (rootN : Nat) :
    quantumDeficit rootN = 0 ∧ classicalDeficit rootN = rootN - 1 :=
  ⟨rfl, rfl⟩

/-- The speedup is one more than the classical deficit. -/
theorem observer_speedup_is_deficit_plus_one (qs : QuantumSystem) :
    qs.speedup = (qs.rootN - 1) + 1 := rfl

/-- The speedup recovers `rootN` exactly (deficit plus the surviving path). -/
theorem speedup_recovers_rootN (qs : QuantumSystem) :
    qs.speedup = qs.rootN :=
  Nat.sub_add_cancel (one_le_rootN qs)

/-- **Master statement.** Superposition is a fork, the fold collapses β₁ to zero,
    the deficit is exactly `rootN - 1`, paths are conserved, the quantum deficit
    vanishes while the classical deficit is full, and the speedup recovers
    `rootN`. -/
theorem quantum_observer_master (qs : QuantumSystem) :
    qs.preBeta1 = qs.rootN - 1 ∧
    qs.postBeta1 = 0 ∧
    qs.preBeta1 - qs.postBeta1 = qs.rootN - 1 ∧
    1 + (qs.rootN - 1) = qs.rootN ∧
    quantumDeficit qs.rootN = 0 ∧
    classicalDeficit qs.rootN = qs.rootN - 1 ∧
    qs.speedup = qs.rootN :=
  ⟨rfl, rfl, rfl, path_conservation qs, rfl, rfl, speedup_recovers_rootN qs⟩

end Gnosis
