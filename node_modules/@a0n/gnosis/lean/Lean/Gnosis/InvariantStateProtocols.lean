import Init

/-!
# Invariant state protocols — every protocol preserves the boundary invariant

A family of state protocols, each preserving a boundary invariant.  Rather than one
witness per protocol, the finite core proves the single general law: *any* sequence
of protocols preserves the boundary invariant, established once by induction.

Init-only; every proof closes from `Init` with no banned tactic on an open goal.
-/

namespace Gnosis

/-- A boundary invariant carried by the protocol state. -/
structure ProtocolBoundary where
  isPreserved : Bool

/-- A single protocol acts as a boundary-preserving step. -/
def protocol (_index : Nat) (b : ProtocolBoundary) : ProtocolBoundary := b

/-- Each protocol preserves the boundary invariant. -/
theorem protocol_preserves (i : Nat) (b : ProtocolBoundary) :
    (protocol i b).isPreserved = b.isPreserved := rfl

/-- Run a sequence of protocols in order. -/
def runProtocols : List Nat → ProtocolBoundary → ProtocolBoundary
  | [], b => b
  | i :: is, b => protocol i (runProtocols is b)

/-- **The general law.** Any sequence of protocols preserves the boundary
    invariant — the single statement every protocol witness instantiates. -/
theorem all_protocols_preserve : ∀ (is : List Nat) (b : ProtocolBoundary),
    (runProtocols is b).isPreserved = b.isPreserved
  | [], _ => rfl
  | i :: is, b => by
      show (protocol i (runProtocols is b)).isPreserved = b.isPreserved
      rw [protocol_preserves]
      exact all_protocols_preserve is b

/-- Boundary preservation composes: running one batch then another still preserves. -/
theorem runProtocols_append (a b : List Nat) (p : ProtocolBoundary) :
    (runProtocols (a ++ b) p).isPreserved = p.isPreserved := by
  rw [all_protocols_preserve]

end Gnosis
