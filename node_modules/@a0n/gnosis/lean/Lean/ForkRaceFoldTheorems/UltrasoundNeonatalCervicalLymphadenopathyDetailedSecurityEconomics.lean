/-!
# UltrasoundNeonatalCervicalLymphadenopathyDetailedSecurityEconomics

Neonatal cervical lymphadenopathy and lymphadenitis ultrasound diagnostic
gap theorems. Five proofs that absence of specific US-guided clinical steps
creates measurable patient-safety risk. Anti-thesis pattern; zero sorry.
-/

namespace ForkRaceFoldTheorems

structure NeonatalCervicalLNSuppurativeDistinctionGapAssumptions where
  usDistinguishesSuppurativeFromReactive : Bool
  drainageIndicationGap : Nat
  gapFromUndistinguished :
    usDistinguishesSuppurativeFromReactive = false → 0 < drainageIndicationGap

theorem neonatal_cervical_ln_suppurative_distinction_gap_exists
    (a : NeonatalCervicalLNSuppurativeDistinctionGapAssumptions)
    (h : a.usDistinguishesSuppurativeFromReactive = false) :
    0 < a.drainageIndicationGap :=
  a.gapFromUndistinguished h

structure NeonatalCervicalLNDopplerHilarGapAssumptions where
  dopplerHilarVascularityAssessed : Bool
  missedDiagnosisGap : Nat
  gapFromUnassessedHilar :
    dopplerHilarVascularityAssessed = false → 0 < missedDiagnosisGap

theorem neonatal_cervical_ln_doppler_hilar_gap_exists
    (a : NeonatalCervicalLNDopplerHilarGapAssumptions)
    (h : a.dopplerHilarVascularityAssessed = false) :
    0 < a.missedDiagnosisGap :=
  a.gapFromUnassessedHilar h

structure NeonatalCervicalLNSerialUSGapAssumptions where
  serialUSPerformedPostTherapy : Bool
  resolutionConfirmed : Bool
  treatmentFailureGap : Nat
  gapFromMissingSerialUS :
    serialUSPerformedPostTherapy = false →
    resolutionConfirmed = false →
    0 < treatmentFailureGap

theorem neonatal_cervical_ln_serial_us_gap_exists
    (a : NeonatalCervicalLNSerialUSGapAssumptions)
    (hUS : a.serialUSPerformedPostTherapy = false)
    (hRes : a.resolutionConfirmed = false) :
    0 < a.treatmentFailureGap :=
  a.gapFromMissingSerialUS hUS hRes

structure NeonatalDeepNeckExtensionUSGapAssumptions where
  deepNeckExtensionEvaluated : Bool
  airwayRiskStratified : Bool
  airwayCompressionGap : Nat
  gapFromUnassessedExtension :
    deepNeckExtensionEvaluated = false →
    airwayRiskStratified = false →
    0 < airwayCompressionGap

theorem neonatal_deep_neck_extension_us_gap_exists
    (a : NeonatalDeepNeckExtensionUSGapAssumptions)
    (hEval : a.deepNeckExtensionEvaluated = false)
    (hStrat : a.airwayRiskStratified = false) :
    0 < a.airwayCompressionGap :=
  a.gapFromUnassessedExtension hEval hStrat

structure NeonatalCervicalLNFollowUpUSGapAssumptions where
  followUpUSScheduled : Bool
  residualAdenopathyExcluded : Bool
  longTermOutcomeGap : Nat
  gapFromMissingFollowUp :
    followUpUSScheduled = false →
    residualAdenopathyExcluded = false →
    0 < longTermOutcomeGap

theorem neonatal_cervical_ln_follow_up_us_gap_exists
    (a : NeonatalCervicalLNFollowUpUSGapAssumptions)
    (hFU : a.followUpUSScheduled = false)
    (hRes : a.residualAdenopathyExcluded = false) :
    0 < a.longTermOutcomeGap :=
  a.gapFromMissingFollowUp hFU hRes

end ForkRaceFoldTheorems
