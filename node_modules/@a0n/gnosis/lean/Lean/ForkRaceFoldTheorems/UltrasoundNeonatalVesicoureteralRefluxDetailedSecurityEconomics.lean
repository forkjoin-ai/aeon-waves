/-!
# UltrasoundNeonatalVesicoureteralRefluxDetailedSecurityEconomics

Neonatal renal ultrasound — vesicoureteral reflux (VUR).
Security-economics gap theorems derived from absent diagnostic controls.

Anti-thesis pattern: each structure posits the ABSENCE of a required
measurement or finding, then derives a positive risk quantity.
Zero sorry — all theorems close by exact.
-/

namespace ForkRaceFoldTheorems

-- ── Theorem 1 ────────────────────────────────────────────────────────────────
-- Anti-thesis: renal pelvis APD and ureter calibre are NOT measured bilaterally
-- AND VUR grade is not documented → severity classification gap is strictly
-- positive.

structure VURGradingDocumentationGapAssumptions where
  apdMeasuredBilaterally : Bool
  vurGradeDocumented : Bool
  severityClassificationGap : Nat
  gapFromMissingGradeData :
    apdMeasuredBilaterally = false →
    vurGradeDocumented = false →
    0 < severityClassificationGap

theorem vur_grading_documentation_gap_exists
    (a : VURGradingDocumentationGapAssumptions)
    (hAPD : a.apdMeasuredBilaterally = false)
    (hGrade : a.vurGradeDocumented = false) :
    0 < a.severityClassificationGap :=
  a.gapFromMissingGradeData hAPD hGrade

-- ── Theorem 2 ────────────────────────────────────────────────────────────────
-- Anti-thesis: renal cortical thickness and parenchymal echogenicity are NOT
-- documented bilaterally → renal scarring risk assessment gap is strictly
-- positive.

structure VURParenchymalScarringGapAssumptions where
  corticalThicknessDocumented : Bool
  echogenicityDocumented : Bool
  scarringRiskAssessmentGap : Nat
  gapFromMissingScarData :
    corticalThicknessDocumented = false →
    echogenicityDocumented = false →
    0 < scarringRiskAssessmentGap

theorem vur_parenchymal_scarring_gap_exists
    (a : VURParenchymalScarringGapAssumptions)
    (hThickness : a.corticalThicknessDocumented = false)
    (hEcho : a.echogenicityDocumented = false) :
    0 < a.scarringRiskAssessmentGap :=
  a.gapFromMissingScarData hThickness hEcho

-- ── Theorem 3 ────────────────────────────────────────────────────────────────
-- Anti-thesis: colour Doppler ureteral jets at the vesicoureteral junction are
-- NOT assessed → functional VUR confirmation gap is strictly positive.

structure VURUreteralJetDopplerGapAssumptions where
  ureteralJetsAssessed : Bool
  functionalConfirmationGap : Nat
  gapFromMissingJetData :
    ureteralJetsAssessed = false → 0 < functionalConfirmationGap

theorem vur_ureteral_jet_doppler_gap_exists
    (a : VURUreteralJetDopplerGapAssumptions)
    (h : a.ureteralJetsAssessed = false) :
    0 < a.functionalConfirmationGap :=
  a.gapFromMissingJetData h

-- ── Theorem 4 ────────────────────────────────────────────────────────────────
-- Anti-thesis: bladder wall thickness, post-void residual volume, and
-- urethral calibre are NOT measured → lower urinary tract dysfunction
-- assessment gap is strictly positive.

structure VURLUTDAssessmentGapAssumptions where
  bladderWallThicknessMeasured : Bool
  postVoidResidualMeasured : Bool
  lowerUrinaryTractDysfunctionGap : Nat
  gapFromMissingLUTDData :
    bladderWallThicknessMeasured = false →
    postVoidResidualMeasured = false →
    0 < lowerUrinaryTractDysfunctionGap

theorem vur_lutd_assessment_gap_exists
    (a : VURLUTDAssessmentGapAssumptions)
    (hBladder : a.bladderWallThicknessMeasured = false)
    (hPVR : a.postVoidResidualMeasured = false) :
    0 < a.lowerUrinaryTractDysfunctionGap :=
  a.gapFromMissingLUTDData hBladder hPVR

-- ── Theorem 5 ────────────────────────────────────────────────────────────────
-- Anti-thesis: contralateral kidney Z-score is NOT calculated AND no
-- follow-up DMSA scan or ultrasound interval is specified → surveillance
-- gap is strictly positive.

structure VURSurveillancePlanGapAssumptions where
  contralateralZScoreCalculated : Bool
  followUpImagingScheduled : Bool
  surveillanceGap : Nat
  gapFromMissingSurveillancePlan :
    contralateralZScoreCalculated = false →
    followUpImagingScheduled = false →
    0 < surveillanceGap

theorem vur_surveillance_plan_gap_exists
    (a : VURSurveillancePlanGapAssumptions)
    (hZScore : a.contralateralZScoreCalculated = false)
    (hFollowUp : a.followUpImagingScheduled = false) :
    0 < a.surveillanceGap :=
  a.gapFromMissingSurveillancePlan hZScore hFollowUp

end ForkRaceFoldTheorems
