/-!
# UltrasoundNeonatalTetralogyOfFallotDetailedSecurityEconomics

Neonatal Tetralogy of Fallot (ToF): the four-element complex of large
perimembranous VSD, rightward override of the aorta, right ventricular
outflow tract obstruction, and right ventricular hypertrophy. Five security-
economics gap theorems for clinical imaging gaps that constitute missed-
diagnosis risk — each with measurable economic (medico-legal / readmission)
cost.

Anti-thesis pattern: structure posits the ABSENCE of an imaging assessment,
theorem derives strictly-positive risk. Zero sorry — all close by exact.
-/

namespace ForkRaceFoldTheorems

-- ── Theorem 1 ────────────────────────────────────────────────────────────────
-- Anti-thesis: right ventricular outflow tract morphology (valvar, subvalvar,
-- supravalvar obstruction level) NOT characterised AND pulmonary valve annulus
-- Z-score NOT calculated → incorrect palliative vs. primary-repair strategy
-- risk is strictly positive.

structure ToFRVOTMorphologyPulmonaryAnnulusGapAssumptions where
  rvotMorphologyCharacterised : Bool
  pulmonaryAnnulusZScoreCalculated : Bool
  strategyRisk : Nat
  gapFromUncharacterisedRVOTAndZScore :
    rvotMorphologyCharacterised = false →
    pulmonaryAnnulusZScoreCalculated = false →
    0 < strategyRisk

theorem tof_rvot_morphology_pulmonary_annulus_gap_exists
    (a : ToFRVOTMorphologyPulmonaryAnnulusGapAssumptions)
    (hRVOT : a.rvotMorphologyCharacterised = false)
    (hZ : a.pulmonaryAnnulusZScoreCalculated = false) :
    0 < a.strategyRisk :=
  a.gapFromUncharacterisedRVOTAndZScore hRVOT hZ

-- ── Theorem 2 ────────────────────────────────────────────────────────────────
-- Anti-thesis: pulmonary artery branch sizes NOT measured (right and left PA
-- Z-scores NOT calculated) AND pulmonary artery confluence NOT assessed →
-- incorrect Nakata index / McGoon ratio risk is strictly positive.

structure ToFPulmonaryArteryBranchSizesGapAssumptions where
  pulmonaryArteryBranchesMeasured : Bool
  pulmonaryConfluenceAssessed : Bool
  natakaMcGoonRisk : Nat
  gapFromUnmeasuredBranchesAndConfluence :
    pulmonaryArteryBranchesMeasured = false →
    pulmonaryConfluenceAssessed = false →
    0 < natakaMcGoonRisk

theorem tof_pulmonary_artery_branch_sizes_gap_exists
    (a : ToFPulmonaryArteryBranchSizesGapAssumptions)
    (hPA : a.pulmonaryArteryBranchesMeasured = false)
    (hConf : a.pulmonaryConfluenceAssessed = false) :
    0 < a.natakaMcGoonRisk :=
  a.gapFromUnmeasuredBranchesAndConfluence hPA hConf

-- ── Theorem 3 ────────────────────────────────────────────────────────────────
-- Anti-thesis: coronary artery anatomy NOT mapped (LAD from RCA crossing RVOT
-- NOT excluded) AND anomalous coronary origin NOT documented → intraoperative
-- coronary injury risk is strictly positive.

structure ToFCoronaryAnateryMappingGapAssumptions where
  coronaryAnatomyMapped : Bool
  anomalousCoronaryOriginDocumented : Bool
  intraoperativeCoronaryInjuryRisk : Nat
  gapFromUnmappedCoronaryAndOrigin :
    coronaryAnatomyMapped = false →
    anomalousCoronaryOriginDocumented = false →
    0 < intraoperativeCoronaryInjuryRisk

theorem tof_coronary_anatomy_mapping_gap_exists
    (a : ToFCoronaryAnateryMappingGapAssumptions)
    (hCor : a.coronaryAnatomyMapped = false)
    (hOrig : a.anomalousCoronaryOriginDocumented = false) :
    0 < a.intraoperativeCoronaryInjuryRisk :=
  a.gapFromUnmappedCoronaryAndOrigin hCor hOrig

-- ── Theorem 4 ────────────────────────────────────────────────────────────────
-- Anti-thesis: aortic arch sidedness and ductal anatomy NOT documented AND
-- associated major aortopulmonary collateral arteries (MAPCAs) NOT excluded
-- → incomplete pre-surgical anatomy / missed source of pulmonary blood flow
-- risk is strictly positive.

structure ToFArchDuctalMAPCAGapAssumptions where
  archSidednessDocumented : Bool
  mapcasExcluded : Bool
  incompleteSurgicalAnatomyRisk : Nat
  gapFromUndocumentedArchAndMAPCAs :
    archSidednessDocumented = false →
    mapcasExcluded = false →
    0 < incompleteSurgicalAnatomyRisk

theorem tof_arch_ductal_mapca_gap_exists
    (a : ToFArchDuctalMAPCAGapAssumptions)
    (hArch : a.archSidednessDocumented = false)
    (hMAPCA : a.mapcasExcluded = false) :
    0 < a.incompleteSurgicalAnatomyRisk :=
  a.gapFromUndocumentedArchAndMAPCAs hArch hMAPCA

-- ── Theorem 5 ────────────────────────────────────────────────────────────────
-- Anti-thesis: ductal dependency of pulmonary circulation NOT assessed AND
-- PGE1 continuation indication NOT documented → hypoxic spell / duct-
-- dependent cyanosis iatrogenic risk is strictly positive.

structure ToFDuctalDependencyHypoxicSpellGapAssumptions where
  ductalDependencyAssessed : Bool
  pge1IndicationDocumented : Bool
  hypoxicSpellRisk : Nat
  gapFromUnassessedDependencyAndPGE1 :
    ductalDependencyAssessed = false →
    pge1IndicationDocumented = false →
    0 < hypoxicSpellRisk

theorem tof_ductal_dependency_hypoxic_spell_gap_exists
    (a : ToFDuctalDependencyHypoxicSpellGapAssumptions)
    (hDep : a.ductalDependencyAssessed = false)
    (hPGE : a.pge1IndicationDocumented = false) :
    0 < a.hypoxicSpellRisk :=
  a.gapFromUnassessedDependencyAndPGE1 hDep hPGE

end ForkRaceFoldTheorems
