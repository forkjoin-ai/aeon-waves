namespace ForkRaceFoldTheorems

structure OccupancyGridMLPCMKGapAssumptions where
  occupancyMlpEncryptedWithCMK : Bool
  complianceRisk : Nat
  gapFromMissingCMK : occupancyMlpEncryptedWithCMK = false → 0 < complianceRisk

theorem occupancy_grid_mlp_cmk_gap_exists (a : OccupancyGridMLPCMKGapAssumptions)
    (h : a.occupancyMlpEncryptedWithCMK = false) : 0 < a.complianceRisk :=
  a.gapFromMissingCMK h

structure MultiSceneOccupancyGridSLAHijackAssumptions where
  sceneCount : Nat
  slaIsolated : Bool
  hijackRisk : Nat
  hijackFromSharedBoundary : 1 < sceneCount → slaIsolated = false → 0 < hijackRisk

theorem multi_scene_occupancy_grid_sla_hijack_exists (a : MultiSceneOccupancyGridSLAHijackAssumptions)
    (hScenes : 1 < a.sceneCount) (hShared : a.slaIsolated = false) : 0 < a.hijackRisk :=
  a.hijackFromSharedBoundary hScenes hShared

structure OccupancyGridMLPRolePoisoningGapAssumptions where
  iamRoleScopedToScene : Bool
  poisoningRisk : Nat
  gapFromUnscopedRole : iamRoleScopedToScene = false → 0 < poisoningRisk

theorem occupancy_grid_mlp_role_poisoning_gap_exists (a : OccupancyGridMLPRolePoisoningGapAssumptions)
    (h : a.iamRoleScopedToScene = false) : 0 < a.poisoningRisk :=
  a.gapFromUnscopedRole h

structure OccupancyGridDensityAlarmSOCGapAssumptions where
  densityDivergenceAlarmConfigured : Bool
  socRunbookExists : Bool
  socGap : Nat
  gapFromMissingAlarmAndRunbook : densityDivergenceAlarmConfigured = false → socRunbookExists = false → 0 < socGap

theorem occupancy_grid_density_alarm_soc_gap_exists (a : OccupancyGridDensityAlarmSOCGapAssumptions)
    (hAlarm : a.densityDivergenceAlarmConfigured = false) (hRunbook : a.socRunbookExists = false) : 0 < a.socGap :=
  a.gapFromMissingAlarmAndRunbook hAlarm hRunbook

structure OccupancyGridMLPXRayGapAssumptions where
  xRayTracingEnabled : Bool
  occupancyWeightsLogged : Bool
  observabilityGap : Nat
  gapFromMissingXRay : xRayTracingEnabled = false → occupancyWeightsLogged = false → 0 < observabilityGap

theorem occupancy_grid_mlp_xray_gap_exists (a : OccupancyGridMLPXRayGapAssumptions)
    (hXRay : a.xRayTracingEnabled = false) (hLogs : a.occupancyWeightsLogged = false) : 0 < a.observabilityGap :=
  a.gapFromMissingXRay hXRay hLogs

end ForkRaceFoldTheorems
