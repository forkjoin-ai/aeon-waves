/-!
# UltrasoundNeonatalUmbilicalArterialCatheterDetailedSecurityEconomics

Neonatal umbilical arterial catheter (UAC) ultrasound diagnostic gap theorems.
Five proofs that absence of specific US-guided clinical steps creates
measurable patient-safety risk. Anti-thesis pattern; zero sorry.
-/

namespace ForkRaceFoldTheorems

structure UACTipPositionUSGapAssumptions where
  usTipPositionConfirmedInAorta : Bool
  organIschaemiaGap : Nat
  gapFromUnconfirmedTip :
    usTipPositionConfirmedInAorta = false → 0 < organIschaemiaGap

theorem uac_tip_position_us_gap_exists
    (a : UACTipPositionUSGapAssumptions)
    (h : a.usTipPositionConfirmedInAorta = false) :
    0 < a.organIschaemiaGap :=
  a.gapFromUnconfirmedTip h

structure UACLimbPerfusionDopplerGapAssumptions where
  dopplerLimbFlowAssessed : Bool
  limbPerfusionDocumented : Bool
  limbIschaemiaGap : Nat
  gapFromUnassessedLimbFlow :
    dopplerLimbFlowAssessed = false →
    limbPerfusionDocumented = false →
    0 < limbIschaemiaGap

theorem uac_limb_perfusion_doppler_gap_exists
    (a : UACLimbPerfusionDopplerGapAssumptions)
    (hDoppler : a.dopplerLimbFlowAssessed = false)
    (hDoc : a.limbPerfusionDocumented = false) :
    0 < a.limbIschaemiaGap :=
  a.gapFromUnassessedLimbFlow hDoppler hDoc

structure UACRenalArteryThrombosisUSGapAssumptions where
  usDetectsRenalArteryThrombus : Bool
  renalFunctionMonitored : Bool
  renalInfarctionGap : Nat
  gapFromUndetectedRenalThrombus :
    usDetectsRenalArteryThrombus = false →
    renalFunctionMonitored = false →
    0 < renalInfarctionGap

theorem uac_renal_artery_thrombosis_us_gap_exists
    (a : UACRenalArteryThrombosisUSGapAssumptions)
    (hUS : a.usDetectsRenalArteryThrombus = false)
    (hRenal : a.renalFunctionMonitored = false) :
    0 < a.renalInfarctionGap :=
  a.gapFromUndetectedRenalThrombus hUS hRenal

structure UACAorticThrombusTipUSGapAssumptions where
  usAssessesAorticThrombusAtTip : Bool
  thrombusExcluded : Bool
  aorticOcclusionGap : Nat
  gapFromUnassessedAorticThrombus :
    usAssessesAorticThrombusAtTip = false →
    thrombusExcluded = false →
    0 < aorticOcclusionGap

theorem uac_aortic_thrombus_tip_us_gap_exists
    (a : UACAorticThrombusTipUSGapAssumptions)
    (hUS : a.usAssessesAorticThrombusAtTip = false)
    (hExcl : a.thrombusExcluded = false) :
    0 < a.aorticOcclusionGap :=
  a.gapFromUnassessedAorticThrombus hUS hExcl

structure UACSerialUSPostInsertionGapAssumptions where
  serialUSAt24hPerformed : Bool
  delayedVasospasmOrThrombosisExcluded : Bool
  delayedComplicationGap : Nat
  gapFromMissingSerialUS :
    serialUSAt24hPerformed = false →
    delayedVasospasmOrThrombosisExcluded = false →
    0 < delayedComplicationGap

theorem uac_serial_us_post_insertion_gap_exists
    (a : UACSerialUSPostInsertionGapAssumptions)
    (hUS : a.serialUSAt24hPerformed = false)
    (hExcl : a.delayedVasospasmOrThrombosisExcluded = false) :
    0 < a.delayedComplicationGap :=
  a.gapFromMissingSerialUS hUS hExcl

end ForkRaceFoldTheorems
