/-!
# UltrasoundNeonatalGlennCirculationDetailedSecurityEconomics

Neonatal Glenn shunt assessment: superior vena cava to pulmonary artery
anastomosis. Five security-economics gap theorems for clinical imaging gaps
that constitute missed-diagnosis risk — each with a measurable economic
(medico-legal / readmission) cost.

Anti-thesis pattern: structure posits the ABSENCE of an imaging assessment,
theorem derives strictly-positive risk. Zero sorry — all close by exact.
-/

namespace ForkRaceFoldTheorems

-- ── Theorem 1 ────────────────────────────────────────────────────────────────
-- Anti-thesis: SVC-PA anastomosis patency NOT assessed during Doppler
-- study → missed occlusion risk is strictly positive.

structure SVCPAAnastomosisPatencyGapAssumptions where
  anastomosisPatencyAssessed : Bool
  missedOcclusionRisk : Nat
  gapFromUnassessedPatency : anastomosisPatencyAssessed = false → 0 < missedOcclusionRisk

theorem svc_pa_anastomosis_patency_gap_exists
    (a : SVCPAAnastomosisPatencyGapAssumptions)
    (h : a.anastomosisPatencyAssessed = false) :
    0 < a.missedOcclusionRisk :=
  a.gapFromUnassessedPatency h

-- ── Theorem 2 ────────────────────────────────────────────────────────────────
-- Anti-thesis: pulmonary artery distortion NOT assessed (branch PA narrowing
-- excluded) → Glenn failure risk is strictly positive.

structure PulmonaryArteryDistortionGapAssumptions where
  distortionAssessed : Bool
  glennFailureRisk : Nat
  gapFromUnassessedDistortion : distortionAssessed = false → 0 < glennFailureRisk

theorem pulmonary_artery_distortion_gap_exists
    (a : PulmonaryArteryDistortionGapAssumptions)
    (h : a.distortionAssessed = false) :
    0 < a.glennFailureRisk :=
  a.gapFromUnassessedDistortion h

-- ── Theorem 3 ────────────────────────────────────────────────────────────────
-- Anti-thesis: Glenn conduit peak flow velocity NOT measured AND pulmonary
-- pressure gradient unknown → hemodynamic mismanagement risk is strictly
-- positive.

structure GlennConduitFlowVelocityGapAssumptions where
  flowVelocityMeasured : Bool
  pressureGradientQuantified : Bool
  hemodynamicRisk : Nat
  gapFromUnmeasuredVelocity :
    flowVelocityMeasured = false →
    pressureGradientQuantified = false →
    0 < hemodynamicRisk

theorem glenn_conduit_flow_velocity_gap_exists
    (a : GlennConduitFlowVelocityGapAssumptions)
    (hVelocity : a.flowVelocityMeasured = false)
    (hPressure : a.pressureGradientQuantified = false) :
    0 < a.hemodynamicRisk :=
  a.gapFromUnmeasuredVelocity hVelocity hPressure

-- ── Theorem 4 ────────────────────────────────────────────────────────────────
-- Anti-thesis: collateral aortopulmonary vessels NOT identified on colour
-- Doppler → surgical planning gap is strictly positive (uncharted steal).

structure CollateralVesselIdentificationGapAssumptions where
  collateralVesselsIdentified : Bool
  surgicalPlanningGap : Nat
  gapFromUnidentifiedCollaterals :
    collateralVesselsIdentified = false → 0 < surgicalPlanningGap

theorem collateral_vessel_identification_gap_exists
    (a : CollateralVesselIdentificationGapAssumptions)
    (h : a.collateralVesselsIdentified = false) :
    0 < a.surgicalPlanningGap :=
  a.gapFromUnidentifiedCollaterals h

-- ── Theorem 5 ────────────────────────────────────────────────────────────────
-- Anti-thesis: SVC obstruction NOT actively excluded (no venous flow
-- characterisation proximal to anastomosis) → misdiagnosis risk is strictly
-- positive.

structure SVCObstructionExclusionGapAssumptions where
  obstructionExcluded : Bool
  misdiagnosisRisk : Nat
  gapFromUnexcludedObstruction : obstructionExcluded = false → 0 < misdiagnosisRisk

theorem svc_obstruction_exclusion_gap_exists
    (a : SVCObstructionExclusionGapAssumptions)
    (h : a.obstructionExcluded = false) :
    0 < a.misdiagnosisRisk :=
  a.gapFromUnexcludedObstruction h

end ForkRaceFoldTheorems
