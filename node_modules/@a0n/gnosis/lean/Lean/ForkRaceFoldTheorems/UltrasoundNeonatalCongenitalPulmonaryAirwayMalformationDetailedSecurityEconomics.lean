/-!
# UltrasoundNeonatalCongenitalPulmonaryAirwayMalformationDetailedSecurityEconomics

Anti-thesis: neonatal fetal ultrasound reliably characterizes congenital pulmonary
airway malformation (CPAM) by identifying lobe/type/diameter, measuring
CVR/hydrops risk, excluding sequestration on Doppler, assessing mediastinal
shift/EXIT candidacy, and staging postnatal CT/PPB risk. Management decisions
based on these assessments are clinically sound.

Refutation: each failure mode below proves that the ABSENCE of a systematic
assessment control implies a strictly positive clinical and economic risk.
Zero sorry — all theorems close by exact.
-/

namespace ForkRaceFoldTheorems

-- ── Theorem 1 ────────────────────────────────────────────────────────────────
-- Anti-thesis: affected lobe, CPAM type, and largest cyst diameter are NOT
-- systematically documented → misclassification risk is strictly positive.

structure CPAMLobeTypeDiameterGapAssumptions where
  lobeDocumented : Bool
  typeDocumented : Bool
  diameterMeasured : Bool
  misclassificationRisk : Nat
  gapFromMissingLobeTypeAndDiameter :
    lobeDocumented = false →
    typeDocumented = false →
    diameterMeasured = false →
    0 < misclassificationRisk

theorem cpam_lobe_type_diameter_gap_exists
    (a : CPAMLobeTypeDiameterGapAssumptions)
    (hLobe : a.lobeDocumented = false)
    (hType : a.typeDocumented = false)
    (hDiam : a.diameterMeasured = false) :
    0 < a.misclassificationRisk :=
  a.gapFromMissingLobeTypeAndDiameter hLobe hType hDiam

-- ── Theorem 2 ────────────────────────────────────────────────────────────────
-- Anti-thesis: congenital pulmonary airway malformation volume ratio (CVR) is
-- NOT calculated AND hydrops is NOT assessed → fetal intervention risk is
-- strictly positive.

structure CPAMCVRHydropsGapAssumptions where
  cvrCalculated : Bool
  hydropsAssessed : Bool
  interventionRisk : Nat
  gapFromMissingCVRAndHydrops :
    cvrCalculated = false →
    hydropsAssessed = false →
    0 < interventionRisk

theorem cpam_cvr_hydrops_gap_exists
    (a : CPAMCVRHydropsGapAssumptions)
    (hCVR : a.cvrCalculated = false)
    (hHydrops : a.hydropsAssessed = false) :
    0 < a.interventionRisk :=
  a.gapFromMissingCVRAndHydrops hCVR hHydrops

-- ── Theorem 3 ────────────────────────────────────────────────────────────────
-- Anti-thesis: Doppler interrogation is NOT used to exclude a systemic feeding
-- artery (sequestration) → misdiagnosis risk is strictly positive.

structure CPAMSequestrationDopplerExclusionGapAssumptions where
  dopplerPerformed : Bool
  systemicArteryExcluded : Bool
  misdiagnosisRisk : Nat
  gapFromMissingDopplerExclusion :
    dopplerPerformed = false →
    systemicArteryExcluded = false →
    0 < misdiagnosisRisk

theorem cpam_sequestration_doppler_exclusion_gap_exists
    (a : CPAMSequestrationDopplerExclusionGapAssumptions)
    (hDoppler : a.dopplerPerformed = false)
    (hArtery : a.systemicArteryExcluded = false) :
    0 < a.misdiagnosisRisk :=
  a.gapFromMissingDopplerExclusion hDoppler hArtery

-- ── Theorem 4 ────────────────────────────────────────────────────────────────
-- Anti-thesis: mediastinal shift severity is NOT graded AND EXIT procedure
-- candidacy is NOT assessed → delivery-plan risk is strictly positive.

structure CPAMMediastinalShiftEXITGapAssumptions where
  mediastinalShiftGraded : Bool
  exitCandidacyAssessed : Bool
  deliveryPlanRisk : Nat
  gapFromMissingShiftAndEXIT :
    mediastinalShiftGraded = false →
    exitCandidacyAssessed = false →
    0 < deliveryPlanRisk

theorem cpam_mediastinal_shift_exit_gap_exists
    (a : CPAMMediastinalShiftEXITGapAssumptions)
    (hShift : a.mediastinalShiftGraded = false)
    (hEXIT : a.exitCandidacyAssessed = false) :
    0 < a.deliveryPlanRisk :=
  a.gapFromMissingShiftAndEXIT hShift hEXIT

-- ── Theorem 5 ────────────────────────────────────────────────────────────────
-- Anti-thesis: postnatal CT staging is NOT planned AND pleuropulmonary blastoma
-- (PPB) risk is NOT communicated to parents → postnatal management risk is
-- strictly positive.

structure CPAMPostnatalCTPPBRiskGapAssumptions where
  postnatalCTPlanned : Bool
  ppbRiskCommunicated : Bool
  managementRisk : Nat
  gapFromMissingCTAndPPBRisk :
    postnatalCTPlanned = false →
    ppbRiskCommunicated = false →
    0 < managementRisk

theorem cpam_postnatal_ct_ppb_risk_gap_exists
    (a : CPAMPostnatalCTPPBRiskGapAssumptions)
    (hCT : a.postnatalCTPlanned = false)
    (hPPB : a.ppbRiskCommunicated = false) :
    0 < a.managementRisk :=
  a.gapFromMissingCTAndPPBRisk hCT hPPB

end ForkRaceFoldTheorems
