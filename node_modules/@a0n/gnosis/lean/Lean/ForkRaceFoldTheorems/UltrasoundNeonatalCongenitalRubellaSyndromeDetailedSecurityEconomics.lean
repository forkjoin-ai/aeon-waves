namespace ForkRaceFoldTheorems

structure CongenitalRubellaCardiacAnomalyGapAssumptions where
  foetalEchocardiogramPerformed : Bool
  cardiacSurgeryReferralTriggered : Bool
  cardiacMorbidityRisk : Nat
  gapFromMissingEcho : foetalEchocardiogramPerformed = false → cardiacSurgeryReferralTriggered = false → 0 < cardiacMorbidityRisk

theorem congenital_rubella_cardiac_anomaly_gap_exists (a : CongenitalRubellaCardiacAnomalyGapAssumptions)
    (hEcho : a.foetalEchocardiogramPerformed = false) (hRef : a.cardiacSurgeryReferralTriggered = false) : 0 < a.cardiacMorbidityRisk :=
  a.gapFromMissingEcho hEcho hRef

