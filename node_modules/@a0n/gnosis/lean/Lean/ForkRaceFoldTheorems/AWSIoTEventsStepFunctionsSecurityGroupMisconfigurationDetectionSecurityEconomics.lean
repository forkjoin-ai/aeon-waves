/-!
# AWSIoTEventsStepFunctionsSecurityGroupMisconfigurationDetectionSecurityEconomics

Security-group misconfiguration detection gap theorems for IoT Events /
Step Functions pipelines. Five proofs that absence of controls creates
measurable revenue-at-risk or compliance exposure. Anti-thesis pattern;
zero sorry — all theorems close by exact.
-/

namespace ForkRaceFoldTheorems

-- ── Theorem 1 ────────────────────────────────────────────────────────────────
-- Anti-thesis: VPC flow logs for security-group-associated ENIs are NOT
-- encrypted with a customer-managed KMS key → compliance gap is strictly positive.

structure SGFlowLogCMKGapAssumptions where
  flowLogEncryptedWithCMK : Bool
  complianceRisk : Nat
  gapFromMissingCMK : flowLogEncryptedWithCMK = false → 0 < complianceRisk

theorem sg_flow_log_cmk_gap_exists
    (a : SGFlowLogCMKGapAssumptions)
    (h : a.flowLogEncryptedWithCMK = false) :
    0 < a.complianceRisk :=
  a.gapFromMissingCMK h

-- ── Theorem 2 ────────────────────────────────────────────────────────────────
-- Anti-thesis: no SCP or AWS Config rule prevents security-group deletion AND
-- no backup exists → availability gap is strictly positive.

structure SGDeletionPreventionGapAssumptions where
  scpOrConfigRuleExists : Bool
  sgBackupExists : Bool
  availabilityGap : Nat
  gapFromMissingPrevention :
    scpOrConfigRuleExists = false →
    sgBackupExists = false →
    0 < availabilityGap

theorem sg_deletion_prevention_gap_exists
    (a : SGDeletionPreventionGapAssumptions)
    (hSCP : a.scpOrConfigRuleExists = false)
    (hBackup : a.sgBackupExists = false) :
    0 < a.availabilityGap :=
  a.gapFromMissingPrevention hSCP hBackup

-- ── Theorem 3 ────────────────────────────────────────────────────────────────
-- Anti-thesis: the IAM policy allowing security-group rule modification is NOT
-- scoped to specific group IDs → privilege-escalation gap is strictly positive.

structure SGIAMScopeGapAssumptions where
  iamPolicyScopedToGroupIds : Bool
  privilegeEscalationGap : Nat
  gapFromUnscopedPolicy : iamPolicyScopedToGroupIds = false → 0 < privilegeEscalationGap

theorem sg_iam_scope_gap_exists
    (a : SGIAMScopeGapAssumptions)
    (h : a.iamPolicyScopedToGroupIds = false) :
    0 < a.privilegeEscalationGap :=
  a.gapFromUnscopedPolicy h

-- ── Theorem 4 ────────────────────────────────────────────────────────────────
-- Anti-thesis: no CloudWatch alarm fires on security-group rule changes AND the
-- SOC has no on-call runbook for that signal → SOC gap is strictly positive.

structure SGChangeAlarmSOCGapAssumptions where
  cloudWatchAlarmConfigured : Bool
  socRunbookExists : Bool
  socGap : Nat
  gapFromMissingAlarmAndRunbook :
    cloudWatchAlarmConfigured = false →
    socRunbookExists = false →
    0 < socGap

theorem sg_change_alarm_soc_gap_exists
    (a : SGChangeAlarmSOCGapAssumptions)
    (hAlarm : a.cloudWatchAlarmConfigured = false)
    (hRunbook : a.socRunbookExists = false) :
    0 < a.socGap :=
  a.gapFromMissingAlarmAndRunbook hAlarm hRunbook

-- ── Theorem 5 ────────────────────────────────────────────────────────────────
-- Anti-thesis: AWS X-Ray tracing is NOT enabled on the Step Functions state
-- machine that modifies security groups AND CloudTrail data-event logging is
-- absent → observability gap is strictly positive.

structure SGXRayCloudTrailGapAssumptions where
  xRayTracingEnabled : Bool
  cloudTrailDataEventsLogged : Bool
  observabilityGap : Nat
  gapFromMissingXRayAndTrail :
    xRayTracingEnabled = false →
    cloudTrailDataEventsLogged = false →
    0 < observabilityGap

theorem sg_xray_cloudtrail_gap_exists
    (a : SGXRayCloudTrailGapAssumptions)
    (hXRay : a.xRayTracingEnabled = false)
    (hTrail : a.cloudTrailDataEventsLogged = false) :
    0 < a.observabilityGap :=
  a.gapFromMissingXRayAndTrail hXRay hTrail

end ForkRaceFoldTheorems
