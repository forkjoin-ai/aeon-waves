/-!
# AWSIoTEventsStepFunctionsEKSClusterNetworkingMisconfigurationDetectionSecurityEconomics

EKS cluster VPC/networking misconfiguration detection security-economics.
Five gap theorems: each proves that absence of a specific networking control
creates strictly-positive compliance or revenue-at-risk exposure.

Anti-thesis pattern: structure posits absence of a control, theorem derives
strictly-positive risk. Zero sorry — all close by exact.
-/

namespace ForkRaceFoldTheorems

-- ── Theorem 1 ────────────────────────────────────────────────────────────────
-- Anti-thesis: EKS cluster is NOT deployed into private subnets only AND no
-- customer-managed KMS key encrypts EBS volumes used by cluster nodes →
-- network-exposure compliance gap is strictly positive.

structure EKSNetworkPrivateSubnetCMKGapAssumptions where
  deployedInPrivateSubnetsOnly : Bool
  ebsEncryptedWithCMK : Bool
  complianceRisk : Nat
  gapFromPublicSubnetAndCMK :
    deployedInPrivateSubnetsOnly = false →
    ebsEncryptedWithCMK = false →
    0 < complianceRisk

theorem eks_network_private_subnet_cmk_gap_exists
    (a : EKSNetworkPrivateSubnetCMKGapAssumptions)
    (hSubnet : a.deployedInPrivateSubnetsOnly = false)
    (hCMK : a.ebsEncryptedWithCMK = false) :
    0 < a.complianceRisk :=
  a.gapFromPublicSubnetAndCMK hSubnet hCMK

-- ── Theorem 2 ────────────────────────────────────────────────────────────────
-- Anti-thesis: cluster security groups permit ingress from 0.0.0.0/0 on
-- node ports AND no SCP restricts VPC configuration modifications →
-- internet-reachable node-port revenue risk is strictly positive.

structure EKSNetworkSGSCPGapAssumptions where
  securityGroupsRestrictIngress : Bool
  scpRestrictsVPCModification : Bool
  internetReachableNodePortRisk : Nat
  gapFromWorldOpenSGAndSCP :
    securityGroupsRestrictIngress = false →
    scpRestrictsVPCModification = false →
    0 < internetReachableNodePortRisk

theorem eks_network_sg_scp_gap_exists
    (a : EKSNetworkSGSCPGapAssumptions)
    (hSG : a.securityGroupsRestrictIngress = false)
    (hSCP : a.scpRestrictsVPCModification = false) :
    0 < a.internetReachableNodePortRisk :=
  a.gapFromWorldOpenSGAndSCP hSG hSCP

-- ── Theorem 3 ────────────────────────────────────────────────────────────────
-- Anti-thesis: the IAM role authorising VPC/subnet association changes on
-- the EKS cluster is NOT scoped to the specific cluster ARN → cross-cluster
-- network mis-routing risk is strictly positive.

structure EKSNetworkIAMScopeGapAssumptions where
  iamRoleScopedToCluster : Bool
  crossClusterMisRoutingRisk : Nat
  gapFromUnscopedRole :
    iamRoleScopedToCluster = false → 0 < crossClusterMisRoutingRisk

theorem eks_network_iam_scope_gap_exists
    (a : EKSNetworkIAMScopeGapAssumptions)
    (h : a.iamRoleScopedToCluster = false) :
    0 < a.crossClusterMisRoutingRisk :=
  a.gapFromUnscopedRole h

-- ── Theorem 4 ────────────────────────────────────────────────────────────────
-- Anti-thesis: no CloudWatch alarm fires when VPC flow logs show unexpected
-- lateral movement between node security groups AND the SOC has no runbook
-- for inter-node lateral movement patterns → SOC gap is strictly positive.

structure EKSNetworkFlowLogAlarmSOCGapAssumptions where
  flowLogLateralMovementAlarmConfigured : Bool
  socRunbookExists : Bool
  socGap : Nat
  gapFromMissingAlarmAndRunbook :
    flowLogLateralMovementAlarmConfigured = false →
    socRunbookExists = false →
    0 < socGap

theorem eks_network_flow_log_alarm_soc_gap_exists
    (a : EKSNetworkFlowLogAlarmSOCGapAssumptions)
    (hAlarm : a.flowLogLateralMovementAlarmConfigured = false)
    (hRunbook : a.socRunbookExists = false) :
    0 < a.socGap :=
  a.gapFromMissingAlarmAndRunbook hAlarm hRunbook

-- ── Theorem 5 ────────────────────────────────────────────────────────────────
-- Anti-thesis: AWS X-Ray active tracing is NOT enabled on the EKS networking-
-- configuration API call path AND VPC/subnet association changes are not
-- logged to CloudTrail → observability gap is strictly positive.

structure EKSNetworkXRayGapAssumptions where
  xRayTracingEnabled : Bool
  cloudTrailLoggingEnabled : Bool
  observabilityGap : Nat
  gapFromMissingXRayAndCloudTrail :
    xRayTracingEnabled = false →
    cloudTrailLoggingEnabled = false →
    0 < observabilityGap

theorem eks_network_xray_gap_exists
    (a : EKSNetworkXRayGapAssumptions)
    (hXRay : a.xRayTracingEnabled = false)
    (hTrail : a.cloudTrailLoggingEnabled = false) :
    0 < a.observabilityGap :=
  a.gapFromMissingXRayAndCloudTrail hXRay hTrail

end ForkRaceFoldTheorems
