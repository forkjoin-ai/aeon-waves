/-!
# UltrasoundNeonatalPeriorbitalCellulitisDetailedSecurityEconomics

Neonatal periorbital (preseptal) and orbital cellulitis: five security-economics
gap theorems proving that absence of ultrasound-guided detection and monitoring
controls creates measurable patient-safety risk or compliance exposure.

Anti-thesis pattern: structure posits the ABSENCE of a control, theorem
derives strictly-positive gap. Zero sorry — all close by exact.
-/

namespace ForkRaceFoldTheorems

-- ── Theorem 1 ────────────────────────────────────────────────────────────────
-- Anti-thesis: orbital B-scan ultrasound is NOT performed to distinguish
-- preseptal from true orbital cellulitis in neonates → patient-safety risk
-- is strictly positive.

structure PeriorbitalUSOrbitaldistinctionGapAssumptions where
  orbitalBScanPerformed : Bool
  patientSafetyRisk : Nat
  gapFromMissingBScan : orbitalBScanPerformed = false → 0 < patientSafetyRisk

theorem periorbital_us_orbital_distinction_gap_exists
    (a : PeriorbitalUSOrbitaldistinctionGapAssumptions)
    (h : a.orbitalBScanPerformed = false) :
    0 < a.patientSafetyRisk :=
  a.gapFromMissingBScan h

-- ── Theorem 2 ────────────────────────────────────────────────────────────────
-- Anti-thesis: lacrimal sac ultrasound is NOT performed to detect
-- dacryocystocele or dacryocystitis complicating neonatal conjunctivitis AND
-- nasolacrimal duct probing is not considered → lacrimal complication risk is
-- strictly positive.

structure DacryocystoceleUSNLDGapAssumptions where
  lacrimalUSPerformed : Bool
  nldProbingConsidered : Bool
  lacrimalComplicationRisk : Nat
  gapFromMissingUSAndProbing :
    lacrimalUSPerformed = false →
    nldProbingConsidered = false →
    0 < lacrimalComplicationRisk

theorem dacryocystocele_us_nld_gap_exists
    (a : DacryocystoceleUSNLDGapAssumptions)
    (hUS : a.lacrimalUSPerformed = false)
    (hNLD : a.nldProbingConsidered = false) :
    0 < a.lacrimalComplicationRisk :=
  a.gapFromMissingUSAndProbing hUS hNLD

-- ── Theorem 3 ────────────────────────────────────────────────────────────────
-- Anti-thesis: Doppler ultrasound is NOT used to assess periorbital abscess
-- vascularity and extent AND IV antibiotic escalation is delayed → abscess
-- progression risk is strictly positive.

structure PeriorbitalAbscessDopplerGapAssumptions where
  dopplerUSPerformed : Bool
  ivAntibioticEscalated : Bool
  abscessProgressionRisk : Nat
  gapFromMissingDopplerAndAntibiotic :
    dopplerUSPerformed = false →
    ivAntibioticEscalated = false →
    0 < abscessProgressionRisk

theorem periorbital_abscess_doppler_gap_exists
    (a : PeriorbitalAbscessDopplerGapAssumptions)
    (hDoppler : a.dopplerUSPerformed = false)
    (hAb : a.ivAntibioticEscalated = false) :
    0 < a.abscessProgressionRisk :=
  a.gapFromMissingDopplerAndAntibiotic hDoppler hAb

-- ── Theorem 4 ────────────────────────────────────────────────────────────────
-- Anti-thesis: ocular B-scan ultrasound is NOT performed to evaluate posterior
-- segment in neonates with corneal opacification complicating conjunctivitis
-- AND no ophthalmology referral is made → vision-threatening complication risk
-- is strictly positive.

structure OcularBScanPosteriorSegmentGapAssumptions where
  ocularBScanPerformed : Bool
  ophthalmologyReferralMade : Bool
  visionRisk : Nat
  gapFromMissingBScanAndReferral :
    ocularBScanPerformed = false →
    ophthalmologyReferralMade = false →
    0 < visionRisk

theorem ocular_bscan_posterior_segment_gap_exists
    (a : OcularBScanPosteriorSegmentGapAssumptions)
    (hBScan : a.ocularBScanPerformed = false)
    (hRef : a.ophthalmologyReferralMade = false) :
    0 < a.visionRisk :=
  a.gapFromMissingBScanAndReferral hBScan hRef

-- ── Theorem 5 ────────────────────────────────────────────────────────────────
-- Anti-thesis: follow-up lacrimal system ultrasound is NOT scheduled after
-- discharge AND nasolacrimal duct reassessment is absent → long-term visual
-- and lacrimal outcome risk is strictly positive.

structure PeriorbitalFollowUpUSGapAssumptions where
  followUpLacrimalUSScheduled : Bool
  nldReassessmentPerformed : Bool
  longTermOutcomeRisk : Nat
  gapFromMissingFollowUp :
    followUpLacrimalUSScheduled = false →
    nldReassessmentPerformed = false →
    0 < longTermOutcomeRisk

theorem periorbital_follow_up_us_gap_exists
    (a : PeriorbitalFollowUpUSGapAssumptions)
    (hUS : a.followUpLacrimalUSScheduled = false)
    (hNLD : a.nldReassessmentPerformed = false) :
    0 < a.longTermOutcomeRisk :=
  a.gapFromMissingFollowUp hUS hNLD

end ForkRaceFoldTheorems
