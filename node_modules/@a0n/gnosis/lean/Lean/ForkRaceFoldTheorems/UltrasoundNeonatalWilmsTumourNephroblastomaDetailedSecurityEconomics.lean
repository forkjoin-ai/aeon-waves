/-!
# UltrasoundNeonatalWilmsTumourNephroblastomaDetailedSecurityEconomics

Neonatal abdominal ultrasound — Wilms tumour / nephroblastoma (early antenatal
or postnatal detection). Security-economics gap theorems derived from absent
diagnostic controls.

Anti-thesis pattern: each structure posits the ABSENCE of a required
measurement or finding, then derives a positive risk quantity.
Zero sorry — all theorems close by exact.
-/

namespace ForkRaceFoldTheorems

-- ── Theorem 1 ────────────────────────────────────────────────────────────────
-- Anti-thesis: renal mass three-dimensional measurements, intrarenal origin
-- confirmation, and claw-sign documentation are NOT recorded → mass
-- characterisation gap is strictly positive.

structure WilmsTumourMassCharacterisationGapAssumptions where
  massMeasurementsRecorded : Bool
  intrarenaOriginConfirmed : Bool
  massCharacterisationGap : Nat
  gapFromMissingCharacterisation :
    massMeasurementsRecorded = false →
    intrarenaOriginConfirmed = false →
    0 < massCharacterisationGap

theorem wilms_tumour_mass_characterisation_gap_exists
    (a : WilmsTumourMassCharacterisationGapAssumptions)
    (hMass : a.massMeasurementsRecorded = false)
    (hOrigin : a.intrarenaOriginConfirmed = false) :
    0 < a.massCharacterisationGap :=
  a.gapFromMissingCharacterisation hMass hOrigin

-- ── Theorem 2 ────────────────────────────────────────────────────────────────
-- Anti-thesis: colour Doppler renal vein and IVC tumour-thrombus assessment is
-- NOT performed AND renal artery flow in the mass is not characterised →
-- vascular-invasion gap is strictly positive.

structure WilmsTumourVascularInvasionGapAssumptions where
  renalVeinThrombusAssessed : Bool
  renalArteryFlowCharacterised : Bool
  vascularInvasionGap : Nat
  gapFromMissingVascularData :
    renalVeinThrombusAssessed = false →
    renalArteryFlowCharacterised = false →
    0 < vascularInvasionGap

theorem wilms_tumour_vascular_invasion_gap_exists
    (a : WilmsTumourVascularInvasionGapAssumptions)
    (hThrombus : a.renalVeinThrombusAssessed = false)
    (hArtery : a.renalArteryFlowCharacterised = false) :
    0 < a.vascularInvasionGap :=
  a.gapFromMissingVascularData hThrombus hArtery

-- ── Theorem 3 ────────────────────────────────────────────────────────────────
-- Anti-thesis: contralateral kidney morphology and presence of nephrogenic rests
-- or bilateral involvement are NOT evaluated → bilateral-disease gap is strictly
-- positive.

structure WilmsTumourBilateralDiseaseGapAssumptions where
  contralateralKidneyEvaluated : Bool
  bilateralInvolvementAssessed : Bool
  bilateralDiseaseGap : Nat
  gapFromMissingBilateralData :
    contralateralKidneyEvaluated = false →
    bilateralInvolvementAssessed = false →
    0 < bilateralDiseaseGap

theorem wilms_tumour_bilateral_disease_gap_exists
    (a : WilmsTumourBilateralDiseaseGapAssumptions)
    (hContralateral : a.contralateralKidneyEvaluated = false)
    (hBilateral : a.bilateralInvolvementAssessed = false) :
    0 < a.bilateralDiseaseGap :=
  a.gapFromMissingBilateralData hContralateral hBilateral

-- ── Theorem 4 ────────────────────────────────────────────────────────────────
-- Anti-thesis: lymph node stations (retroperitoneal, para-aortic) and liver
-- echogenicity for metastatic deposits are NOT surveyed → staging completeness
-- gap is strictly positive.

structure WilmsTumourStagingGapAssumptions where
  lymphNodeStationsSurveyed : Bool
  liverMetastasisAssessed : Bool
  stagingGap : Nat
  gapFromMissingStagingData :
    lymphNodeStationsSurveyed = false →
    liverMetastasisAssessed = false →
    0 < stagingGap

theorem wilms_tumour_staging_gap_exists
    (a : WilmsTumourStagingGapAssumptions)
    (hNodes : a.lymphNodeStationsSurveyed = false)
    (hLiver : a.liverMetastasisAssessed = false) :
    0 < a.stagingGap :=
  a.gapFromMissingStagingData hNodes hLiver

-- ── Theorem 5 ────────────────────────────────────────────────────────────────
-- Anti-thesis: associated anomalies (aniridia, hemihypertrophy, Beckwith-
-- Wiedemann features) are NOT documented AND no oncology referral urgency
-- timeline is specified → syndromic-association and referral gap is strictly
-- positive.

structure WilmsTumourSyndromicReferralGapAssumptions where
  syndromicFeaturesDocumented : Bool
  oncologyReferralTimelineSpecified : Bool
  syndromicReferralGap : Nat
  gapFromMissingSyndromicData :
    syndromicFeaturesDocumented = false →
    oncologyReferralTimelineSpecified = false →
    0 < syndromicReferralGap

theorem wilms_tumour_syndromic_referral_gap_exists
    (a : WilmsTumourSyndromicReferralGapAssumptions)
    (hSyndromic : a.syndromicFeaturesDocumented = false)
    (hReferral : a.oncologyReferralTimelineSpecified = false) :
    0 < a.syndromicReferralGap :=
  a.gapFromMissingSyndromicData hSyndromic hReferral

end ForkRaceFoldTheorems
