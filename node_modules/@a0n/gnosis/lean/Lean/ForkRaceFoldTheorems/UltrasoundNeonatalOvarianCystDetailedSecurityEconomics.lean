/-!
# UltrasoundNeonatalOvarianCystDetailedSecurityEconomics

Neonatal pelvic/abdominal ultrasound — neonatal ovarian cyst.
Security-economics gap theorems derived from absent diagnostic controls.

Anti-thesis pattern: each structure posits the ABSENCE of a required
measurement or finding, then derives a positive risk quantity.
Zero sorry — all theorems close by exact.
-/

namespace ForkRaceFoldTheorems

-- ── Theorem 1 ────────────────────────────────────────────────────────────────
-- Anti-thesis: cyst maximum diameter, locule count, and wall thickness are NOT
-- measured AND cyst location relative to the uterus/ovary is not characterised
-- → morphology gap is strictly positive.

structure OvarianCystMorphologyGapAssumptions where
  cystDiameterMeasured : Bool
  cystLocationCharacterised : Bool
  morphologyGap : Nat
  gapFromMissingMorphology :
    cystDiameterMeasured = false →
    cystLocationCharacterised = false →
    0 < morphologyGap

theorem ovarian_cyst_morphology_gap_exists
    (a : OvarianCystMorphologyGapAssumptions)
    (hDiam : a.cystDiameterMeasured = false)
    (hLoc : a.cystLocationCharacterised = false) :
    0 < a.morphologyGap :=
  a.gapFromMissingMorphology hDiam hLoc

-- ── Theorem 2 ────────────────────────────────────────────────────────────────
-- Anti-thesis: colour Doppler pedicle vascularity is NOT assessed AND flow
-- within the cyst wall is not documented → torsion-risk Doppler gap is strictly
-- positive.

structure OvarianCystTorsionDopplerGapAssumptions where
  colorDopplerAssessed : Bool
  pedicleVascularityDocumented : Bool
  torsionDopplerGap : Nat
  gapFromMissingDoppler :
    colorDopplerAssessed = false →
    pedicleVascularityDocumented = false →
    0 < torsionDopplerGap

theorem ovarian_cyst_torsion_doppler_gap_exists
    (a : OvarianCystTorsionDopplerGapAssumptions)
    (hDoppler : a.colorDopplerAssessed = false)
    (hPedicle : a.pedicleVascularityDocumented = false) :
    0 < a.torsionDopplerGap :=
  a.gapFromMissingDoppler hDoppler hPedicle

-- ── Theorem 3 ────────────────────────────────────────────────────────────────
-- Anti-thesis: internal echoes, debris level, and haemorrhagic transformation
-- are NOT characterised AND dependent layering or retracting clot is not
-- reported → haemorrhage characterisation gap is strictly positive.

structure OvarianCystHaemorrhageCharacterisationGapAssumptions where
  internalEchoesCharacterised : Bool
  haemorrhagicTransformationReported : Bool
  haemorrhageGap : Nat
  gapFromMissingHaemorrhageData :
    internalEchoesCharacterised = false →
    haemorrhagicTransformationReported = false →
    0 < haemorrhageGap

theorem ovarian_cyst_haemorrhage_characterisation_gap_exists
    (a : OvarianCystHaemorrhageCharacterisationGapAssumptions)
    (hEchoes : a.internalEchoesCharacterised = false)
    (hTransform : a.haemorrhagicTransformationReported = false) :
    0 < a.haemorrhageGap :=
  a.gapFromMissingHaemorrhageData hEchoes hTransform

-- ── Theorem 4 ────────────────────────────────────────────────────────────────
-- Anti-thesis: the contralateral ovary size and morphology are NOT documented
-- AND bilateral involvement is not assessed → contralateral ovary gap is
-- strictly positive.

structure OvarianCystContralateralGapAssumptions where
  contralateralOvaryDocumented : Bool
  bilateralAssessmentCompleted : Bool
  contralateralGap : Nat
  gapFromMissingContralateralData :
    contralateralOvaryDocumented = false →
    bilateralAssessmentCompleted = false →
    0 < contralateralGap

theorem ovarian_cyst_contralateral_gap_exists
    (a : OvarianCystContralateralGapAssumptions)
    (hContralateral : a.contralateralOvaryDocumented = false)
    (hBilateral : a.bilateralAssessmentCompleted = false) :
    0 < a.contralateralGap :=
  a.gapFromMissingContralateralData hContralateral hBilateral

-- ── Theorem 5 ────────────────────────────────────────────────────────────────
-- Anti-thesis: no malignancy/teratoma exclusion criteria are documented AND no
-- follow-up interval for cyst regression or surgery referral threshold is
-- specified → malignancy-exclusion and surveillance gap is strictly positive.

structure OvarianCystMalignancyExclusionGapAssumptions where
  malignancyExclusionDocumented : Bool
  followUpIntervalSpecified : Bool
  malignancyExclusionGap : Nat
  gapFromMissingExclusion :
    malignancyExclusionDocumented = false →
    followUpIntervalSpecified = false →
    0 < malignancyExclusionGap

theorem ovarian_cyst_malignancy_exclusion_gap_exists
    (a : OvarianCystMalignancyExclusionGapAssumptions)
    (hExclusion : a.malignancyExclusionDocumented = false)
    (hInterval : a.followUpIntervalSpecified = false) :
    0 < a.malignancyExclusionGap :=
  a.gapFromMissingExclusion hExclusion hInterval

end ForkRaceFoldTheorems
