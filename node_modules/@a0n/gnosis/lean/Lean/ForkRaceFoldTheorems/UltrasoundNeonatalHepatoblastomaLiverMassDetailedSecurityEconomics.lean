/-!
# UltrasoundNeonatalHepatoblastomaLiverMassDetailedSecurityEconomics

Neonatal hepatoblastoma / hepatic mass ultrasound diagnostic-gap theorems.
Each theorem proves that ABSENCE of a required ultrasound assessment
creates a measurable patient-safety or diagnostic-quality gap.

Anti-thesis pattern: structure posits missing assessment; theorem
derives strictly-positive gap. Zero sorry — all close by exact.
-/

namespace ForkRaceFoldTheorems

-- ── Theorem 1 ────────────────────────────────────────────────────────────────
-- Anti-thesis: hepatic mass echogenicity, size, and lobar segment are NOT
-- systematically characterised → diagnostic gap is strictly positive,
-- precluding PRETEXT staging and surgical planning.

structure HepaticMassMorphologyGapAssumptions where
  echogenicityCharacterised : Bool
  lobarSegmentDocumented : Bool
  diagnosticGap : Nat
  gapFromMissingMorphology :
    echogenicityCharacterised = false →
    lobarSegmentDocumented = false →
    0 < diagnosticGap

theorem hepatic_mass_morphology_gap_exists
    (a : HepaticMassMorphologyGapAssumptions)
    (hEcho : a.echogenicityCharacterised = false)
    (hSeg : a.lobarSegmentDocumented = false) :
    0 < a.diagnosticGap :=
  a.gapFromMissingMorphology hEcho hSeg

-- ── Theorem 2 ────────────────────────────────────────────────────────────────
-- Anti-thesis: hepatic vein and portal vein Doppler is NOT performed to
-- exclude tumour thrombus or vascular invasion → vascular safety gap is
-- strictly positive.

structure HepaticVeinPortalDopplerGapAssumptions where
  hepaticVeinDopplerPerformed : Bool
  portalVeinThrombusExcluded : Bool
  vascularSafetyGap : Nat
  gapFromMissingDoppler :
    hepaticVeinDopplerPerformed = false →
    portalVeinThrombusExcluded = false →
    0 < vascularSafetyGap

theorem hepatic_vein_portal_doppler_gap_exists
    (a : HepaticVeinPortalDopplerGapAssumptions)
    (hHV : a.hepaticVeinDopplerPerformed = false)
    (hPV : a.portalVeinThrombusExcluded = false) :
    0 < a.vascularSafetyGap :=
  a.gapFromMissingDoppler hHV hPV

-- ── Theorem 3 ────────────────────────────────────────────────────────────────
-- Anti-thesis: extrahepatic extension (diaphragm, IVC, right atrium) is NOT
-- assessed on ultrasound → staging gap is strictly positive, missing
-- information critical for resectability determination.

structure ExtrahepaticExtensionGapAssumptions where
  diaphragmAssessed : Bool
  ivcRightAtriumAssessed : Bool
  stagingGap : Nat
  gapFromMissingExtrahepaticAssessment :
    diaphragmAssessed = false →
    ivcRightAtriumAssessed = false →
    0 < stagingGap

theorem extrahepatic_extension_gap_exists
    (a : ExtrahepaticExtensionGapAssumptions)
    (hDiaphragm : a.diaphragmAssessed = false)
    (hIVC : a.ivcRightAtriumAssessed = false) :
    0 < a.stagingGap :=
  a.gapFromMissingExtrahepaticAssessment hDiaphragm hIVC

-- ── Theorem 4 ────────────────────────────────────────────────────────────────
-- Anti-thesis: bilateral hepatic lobe involvement and multifocality are NOT
-- documented → treatment-plan gap is strictly positive, potentially missing
-- the need for orthotopic liver transplantation instead of resection.

structure MultifocalHepticLobeBilateralGapAssumptions where
  bilateralInvolvementDocumented : Bool
  multifocalityAssessed : Bool
  treatmentPlanGap : Nat
  gapFromMissingBilateralAssessment :
    bilateralInvolvementDocumented = false →
    multifocalityAssessed = false →
    0 < treatmentPlanGap

theorem multifocal_hepatic_lobe_bilateral_gap_exists
    (a : MultifocalHepticLobeBilateralGapAssumptions)
    (hBilateral : a.bilateralInvolvementDocumented = false)
    (hMulti : a.multifocalityAssessed = false) :
    0 < a.treatmentPlanGap :=
  a.gapFromMissingBilateralAssessment hBilateral hMulti

-- ── Theorem 5 ────────────────────────────────────────────────────────────────
-- Anti-thesis: syndromic associations (Beckwith-Wiedemann, familial
-- adenomatous polyposis) are NOT noted AND AFP correlation with imaging
-- findings is NOT documented, and oncology referral is NOT made → oncology
-- referral gap is strictly positive.

structure HepatoblastomaSyndromicAFPReferralGapAssumptions where
  syndromicAssociationDocumented : Bool
  oncologyReferralMade : Bool
  referralGap : Nat
  gapFromMissingSyndromicAndReferral :
    syndromicAssociationDocumented = false →
    oncologyReferralMade = false →
    0 < referralGap

theorem hepatoblastoma_syndromic_afp_referral_gap_exists
    (a : HepatoblastomaSyndromicAFPReferralGapAssumptions)
    (hSyn : a.syndromicAssociationDocumented = false)
    (hRef : a.oncologyReferralMade = false) :
    0 < a.referralGap :=
  a.gapFromMissingSyndromicAndReferral hSyn hRef

end ForkRaceFoldTheorems
