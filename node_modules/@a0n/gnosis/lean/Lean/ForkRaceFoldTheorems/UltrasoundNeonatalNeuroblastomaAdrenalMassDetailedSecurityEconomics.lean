/-!
# UltrasoundNeonatalNeuroblastomaAdrenalMassDetailedSecurityEconomics

Neonatal adrenal neuroblastoma ultrasound diagnostic-gap theorems.
Each theorem proves that ABSENCE of a required ultrasound assessment
creates a measurable patient-safety or diagnostic-quality gap.

Anti-thesis pattern: structure posits missing assessment; theorem
derives strictly-positive gap. Zero sorry — all close by exact.
-/

namespace ForkRaceFoldTheorems

-- ── Theorem 1 ────────────────────────────────────────────────────────────────
-- Anti-thesis: adrenal mass morphology (echogenicity, heterogeneity, calcification
-- presence) is NOT systematically characterised on ultrasound → diagnostic gap
-- is strictly positive, precluding neuroblastoma risk stratification.

structure AdrenalMassMorphologyGapAssumptions where
  massEchogenicityCharacterised : Bool
  calcificationDocumented : Bool
  diagnosticGap : Nat
  gapFromMissingMorphology :
    massEchogenicityCharacterised = false →
    calcificationDocumented = false →
    0 < diagnosticGap

theorem adrenal_mass_morphology_gap_exists
    (a : AdrenalMassMorphologyGapAssumptions)
    (hEcho : a.massEchogenicityCharacterised = false)
    (hCalc : a.calcificationDocumented = false) :
    0 < a.diagnosticGap :=
  a.gapFromMissingMorphology hEcho hCalc

-- ── Theorem 2 ────────────────────────────────────────────────────────────────
-- Anti-thesis: Doppler vascularity of the adrenal mass is NOT assessed →
-- gap is strictly positive, as hypervascular pattern raises malignancy index
-- and guides biopsy urgency.

structure AdrenalMassDopplerVascularityGapAssumptions where
  dopplerVascularityAssessed : Bool
  malignancyIndexGap : Nat
  gapFromMissingDoppler : dopplerVascularityAssessed = false → 0 < malignancyIndexGap

theorem adrenal_mass_doppler_vascularity_gap_exists
    (a : AdrenalMassDopplerVascularityGapAssumptions)
    (h : a.dopplerVascularityAssessed = false) :
    0 < a.malignancyIndexGap :=
  a.gapFromMissingDoppler h

-- ── Theorem 3 ────────────────────────────────────────────────────────────────
-- Anti-thesis: ipsilateral kidney displacement or invasion is NOT documented
-- on the ultrasound report → staging gap is strictly positive, potentially
-- missing surgical corridor planning information.

structure IpsilateralKidneyInvasionGapAssumptions where
  kidneyDisplacementDocumented : Bool
  invasionAssessed : Bool
  stagingGap : Nat
  gapFromMissingKidneyAssessment :
    kidneyDisplacementDocumented = false →
    invasionAssessed = false →
    0 < stagingGap

theorem ipsilateral_kidney_invasion_gap_exists
    (a : IpsilateralKidneyInvasionGapAssumptions)
    (hDisp : a.kidneyDisplacementDocumented = false)
    (hInv : a.invasionAssessed = false) :
    0 < a.stagingGap :=
  a.gapFromMissingKidneyAssessment hDisp hInv

-- ── Theorem 4 ────────────────────────────────────────────────────────────────
-- Anti-thesis: inferior vena cava (IVC) and renal vein are NOT interrogated
-- for tumour thrombus → vascular gap is strictly positive, missing a
-- life-threatening surgical hazard.

structure IVCTumourThrombusDopplerGapAssumptions where
  ivcInterrogated : Bool
  renalVeinThrombusSought : Bool
  vascularSafetyGap : Nat
  gapFromMissingIVCDoppler :
    ivcInterrogated = false →
    renalVeinThrombusSought = false →
    0 < vascularSafetyGap

theorem ivc_tumour_thrombus_doppler_gap_exists
    (a : IVCTumourThrombusDopplerGapAssumptions)
    (hIVC : a.ivcInterrogated = false)
    (hRV : a.renalVeinThrombusSought = false) :
    0 < a.vascularSafetyGap :=
  a.gapFromMissingIVCDoppler hIVC hRV

-- ── Theorem 5 ────────────────────────────────────────────────────────────────
-- Anti-thesis: contralateral adrenal gland and syndromic associations
-- (Beckwith-Wiedemann, hemihypertrophy) are NOT documented and oncology
-- referral is NOT made → oncology referral gap is strictly positive.

structure NeuroblastomaSyndromicReferralGapAssumptions where
  contralateralAdrenalDocumented : Bool
  oncologyReferralMade : Bool
  referralGap : Nat
  gapFromMissingSyndromicWorkup :
    contralateralAdrenalDocumented = false →
    oncologyReferralMade = false →
    0 < referralGap

theorem neuroblastoma_syndromic_referral_gap_exists
    (a : NeuroblastomaSyndromicReferralGapAssumptions)
    (hContra : a.contralateralAdrenalDocumented = false)
    (hRef : a.oncologyReferralMade = false) :
    0 < a.referralGap :=
  a.gapFromMissingSyndromicWorkup hContra hRef

end ForkRaceFoldTheorems
