/-!
# UltrasoundNeonatalPatentDuctusArteriosusDetailedSecurityEconomics

Neonatal patent ductus arteriosus (PDA): persistent fetal communication
between the main pulmonary artery and descending aorta. Five security-
economics gap theorems for clinical imaging gaps that constitute missed-
diagnosis risk — each with measurable economic (medico-legal / readmission)
cost.

Anti-thesis pattern: structure posits the ABSENCE of an imaging assessment,
theorem derives strictly-positive risk. Zero sorry — all close by exact.
-/

namespace ForkRaceFoldTheorems

-- ── Theorem 1 ────────────────────────────────────────────────────────────────
-- Anti-thesis: PDA minimum diameter NOT measured at the pulmonary end AND
-- ductal shunt direction NOT confirmed by colour-flow Doppler → incorrect
-- haemodynamic significance classification risk is strictly positive.

structure PDADiameterShuntDirectionGapAssumptions where
  pdaDiameterMeasured : Bool
  shuntDirectionConfirmed : Bool
  haemodynamicMisclassificationRisk : Nat
  gapFromUnmeasuredDiameterAndShunt :
    pdaDiameterMeasured = false →
    shuntDirectionConfirmed = false →
    0 < haemodynamicMisclassificationRisk

theorem pda_diameter_shunt_direction_gap_exists
    (a : PDADiameterShuntDirectionGapAssumptions)
    (hDiam : a.pdaDiameterMeasured = false)
    (hDir : a.shuntDirectionConfirmed = false) :
    0 < a.haemodynamicMisclassificationRisk :=
  a.gapFromUnmeasuredDiameterAndShunt hDiam hDir

-- ── Theorem 2 ────────────────────────────────────────────────────────────────
-- Anti-thesis: pulmonary overcirculation NOT quantified by Qp:Qs ratio AND
-- LA:Ao ratio NOT measured to assess left-heart volume loading → missed
-- haemodynamically significant PDA readmission risk is strictly positive.

structure PDAQpQsLAAoRatioGapAssumptions where
  qpQsMeasured : Bool
  laAoRatioMeasured : Bool
  readmissionRisk : Nat
  gapFromUnmeasuredQpQsAndLAAo :
    qpQsMeasured = false →
    laAoRatioMeasured = false →
    0 < readmissionRisk

theorem pda_qpqs_laao_ratio_gap_exists
    (a : PDAQpQsLAAoRatioGapAssumptions)
    (hQpQs : a.qpQsMeasured = false)
    (hLAAo : a.laAoRatioMeasured = false) :
    0 < a.readmissionRisk :=
  a.gapFromUnmeasuredQpQsAndLAAo hQpQs hLAAo

-- ── Theorem 3 ────────────────────────────────────────────────────────────────
-- Anti-thesis: ductal dependency of systemic or pulmonary circulation NOT
-- excluded AND PGE1-weaning candidacy NOT assessed → premature PGE1
-- withdrawal iatrogenic injury risk is strictly positive.

structure PDADuctalDependencyPGE1GapAssumptions where
  ductalDependencyExcluded : Bool
  pge1WeaningAssessed : Bool
  iatrogenicInjuryRisk : Nat
  gapFromUnexcludedDependencyAndPGE1 :
    ductalDependencyExcluded = false →
    pge1WeaningAssessed = false →
    0 < iatrogenicInjuryRisk

theorem pda_ductal_dependency_pge1_gap_exists
    (a : PDADuctalDependencyPGE1GapAssumptions)
    (hDep : a.ductalDependencyExcluded = false)
    (hPGE : a.pge1WeaningAssessed = false) :
    0 < a.iatrogenicInjuryRisk :=
  a.gapFromUnexcludedDependencyAndPGE1 hDep hPGE

-- ── Theorem 4 ────────────────────────────────────────────────────────────────
-- Anti-thesis: left ventricular volume overload NOT quantified by LV
-- end-diastolic dimension Z-score AND descending aorta diastolic flow
-- reversal NOT documented → NEC / gut-ischaemia risk mis-estimation is
-- strictly positive.

structure PDALVVolumeOverloadDiastolicReversalGapAssumptions where
  lvEddzScoreCalculated : Bool
  diastolicFlowReversalDocumented : Bool
  necRiskMisestimationRisk : Nat
  gapFromUncalculatedLVAndReversal :
    lvEddzScoreCalculated = false →
    diastolicFlowReversalDocumented = false →
    0 < necRiskMisestimationRisk

theorem pda_lv_volume_overload_diastolic_reversal_gap_exists
    (a : PDALVVolumeOverloadDiastolicReversalGapAssumptions)
    (hLV : a.lvEddzScoreCalculated = false)
    (hRev : a.diastolicFlowReversalDocumented = false) :
    0 < a.necRiskMisestimationRisk :=
  a.gapFromUncalculatedLVAndReversal hLV hRev

-- ── Theorem 5 ────────────────────────────────────────────────────────────────
-- Anti-thesis: pulmonary arterial pressure NOT estimated from ductal Doppler
-- gradient AND Eisenmenger physiology NOT excluded → irreversible pulmonary
-- vascular disease missed-diagnosis risk is strictly positive.

structure PDAPulmonaryHypertensionEisenmengerGapAssumptions where
  pulmonaryPressureEstimated : Bool
  eisenmengerExcluded : Bool
  pulmonaryVascularDiseaseRisk : Nat
  gapFromUnestimatedPAPAndEisenmenger :
    pulmonaryPressureEstimated = false →
    eisenmengerExcluded = false →
    0 < pulmonaryVascularDiseaseRisk

theorem pda_pulmonary_hypertension_eisenmenger_gap_exists
    (a : PDAPulmonaryHypertensionEisenmengerGapAssumptions)
    (hPAP : a.pulmonaryPressureEstimated = false)
    (hEis : a.eisenmengerExcluded = false) :
    0 < a.pulmonaryVascularDiseaseRisk :=
  a.gapFromUnestimatedPAPAndEisenmenger hPAP hEis

end ForkRaceFoldTheorems
