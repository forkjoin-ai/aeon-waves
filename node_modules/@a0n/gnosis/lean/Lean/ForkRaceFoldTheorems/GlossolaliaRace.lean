namespace ForkRaceFoldTheorems
namespace GlossolaliaRace

/-!
# Glossolalia RACE identity preservation

The Aether `filterFiniteAgents` RACE gate must preserve original fork agent
identity. When prior filters have already compressed the array of logits, the
next safety gate still reports the original agent index, not the local array
offset. This module gives that contract a finite proof surface.
-/

/-- One agent observation entering the Glossolalia RACE safety gate. -/
structure AgentObservation where
  originalIndex : Nat
  finiteLogits : Bool
deriving DecidableEq, Repr

/-- Full RACE outcome for a scheduled fork lane. -/
inductive AgentRaceStatus where
  | finite
  | nonFinite
  | timedOut
  | thrown
  | excluded
deriving DecidableEq, Repr

/-- One scheduled agent lane before timeout and finite-logit safety gates. -/
structure ScheduledAgentObservation where
  originalIndex : Nat
  status : AgentRaceStatus
deriving DecidableEq, Repr

/-- Boolean status classifier used by the executable-style list filters. -/
def raceStatusIsFinite : AgentRaceStatus → Bool
  | AgentRaceStatus.finite => true
  | AgentRaceStatus.nonFinite => false
  | AgentRaceStatus.timedOut => false
  | AgentRaceStatus.thrown => false
  | AgentRaceStatus.excluded => false

/-- Boolean timeout classifier used by failed-agent accounting. -/
def raceStatusIsTimedOut : AgentRaceStatus → Bool
  | AgentRaceStatus.finite => false
  | AgentRaceStatus.nonFinite => false
  | AgentRaceStatus.timedOut => true
  | AgentRaceStatus.thrown => false
  | AgentRaceStatus.excluded => false

/-- Boolean failed-lane classifier used by post-RACE accounting. -/
def raceStatusIsFailed : AgentRaceStatus → Bool
  | AgentRaceStatus.finite => false
  | AgentRaceStatus.nonFinite => true
  | AgentRaceStatus.timedOut => true
  | AgentRaceStatus.thrown => true
  | AgentRaceStatus.excluded => true

/-- Original indices of agents whose logits survive the finite-logit gate. -/
def validAgentIndices (observations : List AgentObservation) : List Nat :=
  (observations.filter (fun observation => observation.finiteLogits)).map
    (fun observation => observation.originalIndex)

/-- Original indices of agents rejected by the finite-logit gate. -/
def invalidAgentIndices (observations : List AgentObservation) : List Nat :=
  (observations.filter (fun observation => !observation.finiteLogits)).map
    (fun observation => observation.originalIndex)

/--
Completed original identities after both forward-timeout and finite-logit RACE
gates. Timed-out lanes do not enter this list.
-/
def scheduledCompletedAgentsForFold
    (observations : List ScheduledAgentObservation) : List Nat :=
  (observations.filter
    (fun observation => raceStatusIsFinite observation.status)).map
      (fun observation => observation.originalIndex)

/-- Original identities rejected specifically by the timeout side of RACE. -/
def timedOutAgentIndices
    (observations : List ScheduledAgentObservation) : List Nat :=
  (observations.filter
    (fun observation => raceStatusIsTimedOut observation.status)).map
      (fun observation => observation.originalIndex)

/-- Original identities rejected by any post-RACE failure reason. -/
def failedAgentIndices
    (observations : List ScheduledAgentObservation) : List Nat :=
  (observations.filter
    (fun observation => raceStatusIsFailed observation.status)).map
      (fun observation => observation.originalIndex)

/--
The completed-agent list handed to downstream fold/void-boundary accounting
after the RACE gate. This deliberately uses original identities rather than
local compressed offsets.
-/
def completedAgentsForFold (observations : List AgentObservation) : List Nat :=
  validAgentIndices observations

/-- A void-boundary update may charge only agents completed for the fold. -/
def voidBoundaryChargeable
    (observations : List AgentObservation)
    (agentIndex : Nat) : Prop :=
  agentIndex ∈ completedAgentsForFold observations

/--
Original indices charged by a fold-side top-1 disagreement update. The
`disagrees` predicate abstracts `agentTop !== mergedTop`; the finite-logit
guard models the runtime call shape `updateAgentVoidBoundary(validLogits,
mergedLogits, validAgentIndices)`.
-/
def foldDisagreementChargedIndices
    (observations : List AgentObservation)
    (disagrees : AgentObservation → Bool) : List Nat :=
  (observations.filter
    (fun observation => observation.finiteLogits && disagrees observation)).map
      (fun observation => observation.originalIndex)

/-- A concrete fold-side rejection charge for one original agent identity. -/
def voidBoundaryChargedByFold
    (observations : List AgentObservation)
    (disagrees : AgentObservation → Bool)
    (agentIndex : Nat) : Prop :=
  agentIndex ∈ foldDisagreementChargedIndices observations disagrees

/-- Fold-side rejection charges in the full scheduled-lane model. -/
def scheduledFoldDisagreementChargedIndices
    (observations : List ScheduledAgentObservation)
    (disagrees : ScheduledAgentObservation → Bool) : List Nat :=
  (observations.filter
    (fun observation =>
      raceStatusIsFinite observation.status && disagrees observation)).map
        (fun observation => observation.originalIndex)

/-- A concrete fold-side charge in the full scheduled-lane model. -/
def scheduledVoidBoundaryChargedByFold
    (observations : List ScheduledAgentObservation)
    (disagrees : ScheduledAgentObservation → Bool)
    (agentIndex : Nat) : Prop :=
  agentIndex ∈ scheduledFoldDisagreementChargedIndices observations disagrees

/-- Original fork identities are unique within one RACE batch. -/
def uniqueOriginalIdentities (observations : List AgentObservation) : Prop :=
  ∀ left right,
    left ∈ observations →
      right ∈ observations →
        left.originalIndex = right.originalIndex →
          left = right

/-- Original fork identities are unique within one scheduled RACE batch. -/
def uniqueScheduledOriginalIdentities
    (observations : List ScheduledAgentObservation) : Prop :=
  ∀ left right,
    left ∈ observations →
      right ∈ observations →
        left.originalIndex = right.originalIndex →
          left = right

/-- The RACE gate reports valid original indices exactly as map-after-filter. -/
theorem valid_indices_are_original_indices
    (observations : List AgentObservation) :
    validAgentIndices observations =
      (observations.filter (fun observation => observation.finiteLogits)).map
        (fun observation => observation.originalIndex) := by
  rfl

/-- The RACE gate reports invalid original indices exactly as map-after-filter. -/
theorem invalid_indices_are_original_indices
    (observations : List AgentObservation) :
    invalidAgentIndices observations =
      (observations.filter (fun observation => !observation.finiteLogits)).map
        (fun observation => observation.originalIndex) := by
  rfl

/-- Fold accounting receives exactly the valid original indices after RACE. -/
theorem completed_agents_for_fold_are_valid_indices
    (observations : List AgentObservation) :
    completedAgentsForFold observations = validAgentIndices observations := by
  rfl

/--
Every valid reported index has a source observation with the same original
agent identity; it is never justified by the compressed array offset alone.
-/
theorem valid_index_has_source
    {observations : List AgentObservation}
    {agentIndex : Nat}
    (hMember : agentIndex ∈ validAgentIndices observations) :
    ∃ observation,
      observation ∈ observations ∧
        observation.finiteLogits = true ∧
        observation.originalIndex = agentIndex := by
  unfold validAgentIndices at hMember
  rcases List.mem_map.mp hMember with ⟨observation, hFiltered, hIndex⟩
  rcases List.mem_filter.mp hFiltered with ⟨hIn, hFinite⟩
  exact ⟨observation, hIn, hFinite, hIndex⟩

/-- Every finite source observation contributes its original index. -/
theorem valid_source_index_survives
    {observations : List AgentObservation}
    {observation : AgentObservation}
    (hIn : observation ∈ observations)
    (hFinite : observation.finiteLogits = true) :
    observation.originalIndex ∈ validAgentIndices observations := by
  unfold validAgentIndices
  exact List.mem_map.mpr
    ⟨observation, List.mem_filter.mpr ⟨hIn, hFinite⟩, rfl⟩

/-- A chargeable fold agent has a finite source observation with that identity. -/
theorem chargeable_agent_has_valid_source
    {observations : List AgentObservation}
    {agentIndex : Nat}
    (hChargeable : voidBoundaryChargeable observations agentIndex) :
    ∃ observation,
      observation ∈ observations ∧
        observation.finiteLogits = true ∧
        observation.originalIndex = agentIndex := by
  unfold voidBoundaryChargeable completedAgentsForFold at hChargeable
  exact valid_index_has_source hChargeable

/--
A fold-side disagreement charge has a finite source observation with the same
original identity and a true disagreement predicate.
-/
theorem fold_charge_has_valid_disagreement_source
    {observations : List AgentObservation}
    {disagrees : AgentObservation → Bool}
    {agentIndex : Nat}
    (hCharged : voidBoundaryChargedByFold observations disagrees agentIndex) :
    ∃ observation,
      observation ∈ observations ∧
        observation.finiteLogits = true ∧
        disagrees observation = true ∧
        observation.originalIndex = agentIndex := by
  unfold voidBoundaryChargedByFold foldDisagreementChargedIndices at hCharged
  rcases List.mem_map.mp hCharged with ⟨observation, hFiltered, hIndex⟩
  rcases List.mem_filter.mp hFiltered with ⟨hIn, hPassed⟩
  have hFinite : observation.finiteLogits = true := by
    cases hFiniteValue : observation.finiteLogits <;>
      cases hDisagreesValue : disagrees observation <;>
        simp [hFiniteValue, hDisagreesValue] at hPassed ⊢
  have hDisagrees : disagrees observation = true := by
    cases hFiniteValue : observation.finiteLogits <;>
      cases hDisagreesValue : disagrees observation <;>
        simp [hFiniteValue, hDisagreesValue] at hPassed ⊢
  exact ⟨observation, hIn, hFinite, hDisagrees, hIndex⟩

/-- Every fold-side disagreement charge is chargeable by the post-RACE list. -/
theorem fold_charge_is_chargeable
    {observations : List AgentObservation}
    {disagrees : AgentObservation → Bool}
    {agentIndex : Nat}
    (hCharged : voidBoundaryChargedByFold observations disagrees agentIndex) :
    voidBoundaryChargeable observations agentIndex := by
  rcases fold_charge_has_valid_disagreement_source hCharged with
    ⟨observation, hIn, hFinite, _hDisagrees, hIndex⟩
  unfold voidBoundaryChargeable completedAgentsForFold
  rw [← hIndex]
  exact valid_source_index_survives hIn hFinite

/--
A scheduled fold-side disagreement charge has a finite source lane with the
same original identity.
-/
theorem scheduled_fold_charge_has_finite_source
    {observations : List ScheduledAgentObservation}
    {disagrees : ScheduledAgentObservation → Bool}
    {agentIndex : Nat}
    (hCharged :
      scheduledVoidBoundaryChargedByFold observations disagrees agentIndex) :
    ∃ observation,
      observation ∈ observations ∧
        observation.status = AgentRaceStatus.finite ∧
        disagrees observation = true ∧
        observation.originalIndex = agentIndex := by
  unfold scheduledVoidBoundaryChargedByFold
    scheduledFoldDisagreementChargedIndices at hCharged
  rcases List.mem_map.mp hCharged with ⟨observation, hFiltered, hIndex⟩
  rcases List.mem_filter.mp hFiltered with ⟨hIn, hPassed⟩
  have hFinite : observation.status = AgentRaceStatus.finite := by
    cases hStatus : observation.status <;>
      cases hDisagreesValue : disagrees observation <;>
        simp [raceStatusIsFinite, hStatus, hDisagreesValue] at hPassed ⊢
  have hDisagrees : disagrees observation = true := by
    cases hStatus : observation.status <;>
      cases hDisagreesValue : disagrees observation <;>
        simp [raceStatusIsFinite, hStatus, hDisagreesValue] at hPassed ⊢
  exact ⟨observation, hIn, hFinite, hDisagrees, hIndex⟩

/-- Every scheduled fold-side charge came from the completed-for-fold list. -/
theorem scheduled_fold_charge_is_completed
    {observations : List ScheduledAgentObservation}
    {disagrees : ScheduledAgentObservation → Bool}
    {agentIndex : Nat}
    (hCharged :
      scheduledVoidBoundaryChargedByFold observations disagrees agentIndex) :
    agentIndex ∈ scheduledCompletedAgentsForFold observations := by
  rcases scheduled_fold_charge_has_finite_source hCharged with
    ⟨observation, hIn, hFinite, _hDisagrees, hIndex⟩
  unfold scheduledCompletedAgentsForFold
  rw [← hIndex]
  exact List.mem_map.mpr
    ⟨observation,
      List.mem_filter.mpr
        ⟨hIn, by simp [raceStatusIsFinite, hFinite]⟩,
      rfl⟩

/-- Every completed scheduled identity has a finite source lane. -/
theorem scheduled_completed_index_has_finite_source
    {observations : List ScheduledAgentObservation}
    {agentIndex : Nat}
    (hCompleted : agentIndex ∈ scheduledCompletedAgentsForFold observations) :
    ∃ observation,
      observation ∈ observations ∧
        observation.status = AgentRaceStatus.finite ∧
        observation.originalIndex = agentIndex := by
  unfold scheduledCompletedAgentsForFold at hCompleted
  rcases List.mem_map.mp hCompleted with ⟨observation, hFiltered, hIndex⟩
  rcases List.mem_filter.mp hFiltered with ⟨hIn, hFiniteBool⟩
  have hFinite : observation.status = AgentRaceStatus.finite := by
    cases hValue : observation.status <;>
      simp [raceStatusIsFinite, hValue] at hFiniteBool ⊢
  exact ⟨observation, hIn, hFinite, hIndex⟩

/-- Every failed scheduled identity has a failed source lane. -/
theorem failed_index_has_source
    {observations : List ScheduledAgentObservation}
    {agentIndex : Nat}
    (hFailed : agentIndex ∈ failedAgentIndices observations) :
    ∃ observation,
      observation ∈ observations ∧
        raceStatusIsFailed observation.status = true ∧
        observation.originalIndex = agentIndex := by
  unfold failedAgentIndices at hFailed
  rcases List.mem_map.mp hFailed with ⟨observation, hFiltered, hIndex⟩
  rcases List.mem_filter.mp hFiltered with ⟨hIn, hFailedStatus⟩
  exact ⟨observation, hIn, hFailedStatus, hIndex⟩

/-- Any source lane with a failed status contributes its original index to failures. -/
theorem failed_source_index_survives
    {observations : List ScheduledAgentObservation}
    {observation : ScheduledAgentObservation}
    (hIn : observation ∈ observations)
    (hFailed : raceStatusIsFailed observation.status = true) :
    observation.originalIndex ∈ failedAgentIndices observations := by
  unfold failedAgentIndices
  exact List.mem_map.mpr
    ⟨observation, List.mem_filter.mpr ⟨hIn, hFailed⟩, rfl⟩

/--
Every scheduled source identity is either completed for fold or reported as a
failed identity.
-/
theorem scheduled_source_completed_or_failed
    {observations : List ScheduledAgentObservation}
    {observation : ScheduledAgentObservation}
    (hIn : observation ∈ observations) :
    observation.originalIndex ∈ scheduledCompletedAgentsForFold observations ∨
      observation.originalIndex ∈ failedAgentIndices observations := by
  cases hStatus : observation.status
  · left
    unfold scheduledCompletedAgentsForFold
    exact List.mem_map.mpr
      ⟨observation,
        List.mem_filter.mpr
          ⟨hIn, by simp [raceStatusIsFinite, hStatus]⟩,
        rfl⟩
  · right
    exact failed_source_index_survives hIn
      (by simp [raceStatusIsFailed, hStatus])
  · right
    exact failed_source_index_survives hIn
      (by simp [raceStatusIsFailed, hStatus])
  · right
    exact failed_source_index_survives hIn
      (by simp [raceStatusIsFailed, hStatus])
  · right
    exact failed_source_index_survives hIn
      (by simp [raceStatusIsFailed, hStatus])

/--
Under unique original identities, completed-for-fold and failed identities are
disjoint.
-/
theorem completed_and_failed_disjoint
    {observations : List ScheduledAgentObservation}
    (hUnique : uniqueScheduledOriginalIdentities observations)
    {agentIndex : Nat}
    (hCompleted : agentIndex ∈ scheduledCompletedAgentsForFold observations) :
    Not (agentIndex ∈ failedAgentIndices observations) := by
  intro hFailed
  rcases scheduled_completed_index_has_finite_source hCompleted with
    ⟨completedObservation, hCompletedIn, hCompletedStatus, hCompletedIndex⟩
  rcases failed_index_has_source hFailed with
    ⟨failedObservation, hFailedIn, hFailedStatus, hFailedIndex⟩
  have hSameIndex :
      completedObservation.originalIndex = failedObservation.originalIndex := by
    rw [hCompletedIndex, hFailedIndex]
  have hSameObservation :
      completedObservation = failedObservation :=
    hUnique completedObservation failedObservation hCompletedIn hFailedIn
      hSameIndex
  subst failedObservation
  rw [hCompletedStatus] at hFailedStatus
  cases hFailedStatus

/--
Every invalid reported index has a non-finite source observation with the same
original agent identity; non-finite outputs are reported by original fork index.
-/
theorem invalid_index_has_source
    {observations : List AgentObservation}
    {agentIndex : Nat}
    (hMember : agentIndex ∈ invalidAgentIndices observations) :
    ∃ observation,
      observation ∈ observations ∧
        observation.finiteLogits = false ∧
        observation.originalIndex = agentIndex := by
  unfold invalidAgentIndices at hMember
  rcases List.mem_map.mp hMember with ⟨observation, hFiltered, hIndex⟩
  rcases List.mem_filter.mp hFiltered with ⟨hIn, hRejected⟩
  have hFinite : observation.finiteLogits = false := by
    cases hValue : observation.finiteLogits <;> simp [hValue] at hRejected ⊢
  exact ⟨observation, hIn, hFinite, hIndex⟩

/-- Every non-finite source observation contributes its original index. -/
theorem invalid_source_index_survives
    {observations : List AgentObservation}
    {observation : AgentObservation}
    (hIn : observation ∈ observations)
    (hFinite : observation.finiteLogits = false) :
    observation.originalIndex ∈ invalidAgentIndices observations := by
  unfold invalidAgentIndices
  have hRejected : (!observation.finiteLogits) = true := by
    simp [hFinite]
  exact List.mem_map.mpr
    ⟨observation, List.mem_filter.mpr ⟨hIn, hRejected⟩, rfl⟩

/-- Every reported timeout identity has a timed-out scheduled source lane. -/
theorem timed_out_index_has_source
    {observations : List ScheduledAgentObservation}
    {agentIndex : Nat}
    (hTimedOut : agentIndex ∈ timedOutAgentIndices observations) :
    ∃ observation,
      observation ∈ observations ∧
        observation.status = AgentRaceStatus.timedOut ∧
        observation.originalIndex = agentIndex := by
  unfold timedOutAgentIndices at hTimedOut
  rcases List.mem_map.mp hTimedOut with ⟨observation, hFiltered, hIndex⟩
  rcases List.mem_filter.mp hFiltered with ⟨hIn, hTimedOutStatus⟩
  have hStatus : observation.status = AgentRaceStatus.timedOut := by
    cases hValue : observation.status <;>
      simp [raceStatusIsTimedOut, hValue] at hTimedOutStatus ⊢
  exact ⟨observation, hIn, hStatus, hIndex⟩

/--
If original fork identities are unique in the batch, an invalid agent cannot be
charged by fold/void-boundary accounting after RACE filtering.
-/
theorem invalid_agent_not_chargeable_after_race
    {observations : List AgentObservation}
    (hUnique : uniqueOriginalIdentities observations)
    {agentIndex : Nat}
    (hInvalid : agentIndex ∈ invalidAgentIndices observations) :
    Not (voidBoundaryChargeable observations agentIndex) := by
  intro hChargeable
  rcases chargeable_agent_has_valid_source hChargeable with
    ⟨validObservation, hValidIn, hValidFinite, hValidIndex⟩
  rcases invalid_index_has_source hInvalid with
    ⟨invalidObservation, hInvalidIn, hInvalidFinite, hInvalidIndex⟩
  have hSameIndex :
      validObservation.originalIndex = invalidObservation.originalIndex := by
    rw [hValidIndex, hInvalidIndex]
  have hSameObservation :
      validObservation = invalidObservation :=
    hUnique validObservation invalidObservation hValidIn hInvalidIn hSameIndex
  subst invalidObservation
  rw [hValidFinite] at hInvalidFinite
  cases hInvalidFinite

/--
Under unique original identities, no invalid agent can be charged by a
fold-side top-1 disagreement update.
-/
theorem invalid_agent_not_charged_by_fold_disagreement
    {observations : List AgentObservation}
    (hUnique : uniqueOriginalIdentities observations)
    {disagrees : AgentObservation → Bool}
    {agentIndex : Nat}
    (hInvalid : agentIndex ∈ invalidAgentIndices observations) :
    Not (voidBoundaryChargedByFold observations disagrees agentIndex) := by
  intro hCharged
  exact invalid_agent_not_chargeable_after_race hUnique hInvalid
    (fold_charge_is_chargeable hCharged)

/--
Under unique original identities, a timed-out scheduled lane cannot be charged
by fold-side disagreement accounting.
-/
theorem timed_out_agent_not_charged_by_fold_disagreement
    {observations : List ScheduledAgentObservation}
    (hUnique : uniqueScheduledOriginalIdentities observations)
    {disagrees : ScheduledAgentObservation → Bool}
    {agentIndex : Nat}
    (hTimedOut : agentIndex ∈ timedOutAgentIndices observations) :
    Not (scheduledVoidBoundaryChargedByFold observations disagrees agentIndex) := by
  intro hCharged
  rcases scheduled_fold_charge_has_finite_source hCharged with
    ⟨chargedObservation, hChargedIn, hChargedStatus, _hDisagrees,
      hChargedIndex⟩
  rcases timed_out_index_has_source hTimedOut with
    ⟨timedOutObservation, hTimedOutIn, hTimedOutStatus, hTimedOutIndex⟩
  have hSameIndex :
      chargedObservation.originalIndex = timedOutObservation.originalIndex := by
    rw [hChargedIndex, hTimedOutIndex]
  have hSameObservation :
      chargedObservation = timedOutObservation :=
    hUnique chargedObservation timedOutObservation hChargedIn hTimedOutIn
      hSameIndex
  subst timedOutObservation
  rw [hChargedStatus] at hTimedOutStatus
  cases hTimedOutStatus

/--
Regression witness for the implementation bug: after a prior compression, the
middle local offset is `1`, but the invalid original agent index is `4`.
-/
theorem compressed_offset_not_reported_as_invalid_identity :
    invalidAgentIndices
      [
        { originalIndex := 2, finiteLogits := true },
        { originalIndex := 4, finiteLogits := false },
        { originalIndex := 7, finiteLogits := true }
      ] = [4] := by
  rfl

/-- The same regression witness keeps the valid original identities. -/
theorem valid_identity_survives_compressed_filter :
    validAgentIndices
      [
        { originalIndex := 2, finiteLogits := true },
        { originalIndex := 4, finiteLogits := false },
        { originalIndex := 7, finiteLogits := true }
      ] = [2, 7] := by
  rfl

/-- The compressed-offset regression witness cannot charge invalid original index `4`. -/
theorem compressed_invalid_identity_not_chargeable :
    Not
      (voidBoundaryChargeable
        [
          { originalIndex := 2, finiteLogits := true },
          { originalIndex := 4, finiteLogits := false },
          { originalIndex := 7, finiteLogits := true }
        ]
        4) := by
  unfold voidBoundaryChargeable completedAgentsForFold validAgentIndices
  simp

/--
Even if every source would disagree with the merged top-1, RACE lets only the
finite original identities reach fold-side rejection accounting.
-/
theorem compressed_disagreement_charges_only_valid_identities :
    foldDisagreementChargedIndices
      [
        { originalIndex := 2, finiteLogits := true },
        { originalIndex := 4, finiteLogits := false },
        { originalIndex := 7, finiteLogits := true }
      ]
      (fun _ => true) = [2, 7] := by
  rfl

/-- The compressed-offset regression witness cannot charge invalid `4` by disagreement. -/
theorem compressed_invalid_identity_not_charged_by_disagreement :
    Not
      (voidBoundaryChargedByFold
        [
          { originalIndex := 2, finiteLogits := true },
          { originalIndex := 4, finiteLogits := false },
          { originalIndex := 7, finiteLogits := true }
        ]
        (fun _ => true)
        4) := by
  unfold voidBoundaryChargedByFold foldDisagreementChargedIndices
  simp

/-- Timeout regression witness: timed-out original identity `4` is failed. -/
theorem compressed_timeout_reported_as_failed_identity :
    timedOutAgentIndices
      [
        { originalIndex := 2, status := AgentRaceStatus.finite },
        { originalIndex := 4, status := AgentRaceStatus.timedOut },
        { originalIndex := 7, status := AgentRaceStatus.finite }
      ] = [4] := by
  rfl

/-- Timeout regression witness: only finite scheduled lanes complete for fold. -/
theorem compressed_timeout_completed_agents_skip_timed_out :
    scheduledCompletedAgentsForFold
      [
        { originalIndex := 2, status := AgentRaceStatus.finite },
        { originalIndex := 4, status := AgentRaceStatus.timedOut },
        { originalIndex := 7, status := AgentRaceStatus.finite }
      ] = [2, 7] := by
  rfl

/--
Even if every scheduled lane would disagree, the timed-out original identity
does not reach fold-side rejection accounting.
-/
theorem compressed_timeout_disagreement_charges_only_completed_identities :
    scheduledFoldDisagreementChargedIndices
      [
        { originalIndex := 2, status := AgentRaceStatus.finite },
        { originalIndex := 4, status := AgentRaceStatus.timedOut },
        { originalIndex := 7, status := AgentRaceStatus.finite }
      ]
      (fun _ => true) = [2, 7] := by
  rfl

/-- The compressed timeout regression witness cannot charge timed-out `4`. -/
theorem compressed_timeout_identity_not_charged_by_disagreement :
    Not
      (scheduledVoidBoundaryChargedByFold
        [
          { originalIndex := 2, status := AgentRaceStatus.finite },
          { originalIndex := 4, status := AgentRaceStatus.timedOut },
          { originalIndex := 7, status := AgentRaceStatus.finite }
        ]
        (fun _ => true)
        4) := by
  unfold scheduledVoidBoundaryChargedByFold
    scheduledFoldDisagreementChargedIndices
  simp [raceStatusIsFinite]

/-- Full partition witness: only finite fulfilled identities complete for fold. -/
theorem full_failure_partition_completed_witness :
    scheduledCompletedAgentsForFold
      [
        { originalIndex := 0, status := AgentRaceStatus.excluded },
        { originalIndex := 1, status := AgentRaceStatus.thrown },
        { originalIndex := 2, status := AgentRaceStatus.timedOut },
        { originalIndex := 3, status := AgentRaceStatus.nonFinite },
        { originalIndex := 4, status := AgentRaceStatus.finite },
        { originalIndex := 5, status := AgentRaceStatus.finite }
      ] = [4, 5] := by
  rfl

/-- Full partition witness: excluded, thrown, timed-out, and non-finite identities fail. -/
theorem full_failure_partition_failed_witness :
    failedAgentIndices
      [
        { originalIndex := 0, status := AgentRaceStatus.excluded },
        { originalIndex := 1, status := AgentRaceStatus.thrown },
        { originalIndex := 2, status := AgentRaceStatus.timedOut },
        { originalIndex := 3, status := AgentRaceStatus.nonFinite },
        { originalIndex := 4, status := AgentRaceStatus.finite },
        { originalIndex := 5, status := AgentRaceStatus.finite }
      ] = [0, 1, 2, 3] := by
  rfl

/--
Full partition witness: even if every lane would disagree, only completed
finite identities can be charged.
-/
theorem full_failure_partition_charges_only_completed_witness :
    scheduledFoldDisagreementChargedIndices
      [
        { originalIndex := 0, status := AgentRaceStatus.excluded },
        { originalIndex := 1, status := AgentRaceStatus.thrown },
        { originalIndex := 2, status := AgentRaceStatus.timedOut },
        { originalIndex := 3, status := AgentRaceStatus.nonFinite },
        { originalIndex := 4, status := AgentRaceStatus.finite },
        { originalIndex := 5, status := AgentRaceStatus.finite }
      ]
      (fun _ => true) = [4, 5] := by
  rfl

/-- Full partition witness: a completed identity is not also failed. -/
theorem full_failure_partition_completed_not_failed_witness :
    Not
      (4 ∈ failedAgentIndices
        [
          { originalIndex := 0, status := AgentRaceStatus.excluded },
          { originalIndex := 1, status := AgentRaceStatus.thrown },
          { originalIndex := 2, status := AgentRaceStatus.timedOut },
          { originalIndex := 3, status := AgentRaceStatus.nonFinite },
          { originalIndex := 4, status := AgentRaceStatus.finite },
          { originalIndex := 5, status := AgentRaceStatus.finite }
        ]) := by
  unfold failedAgentIndices
  simp [raceStatusIsFailed]

end GlossolaliaRace
end ForkRaceFoldTheorems
