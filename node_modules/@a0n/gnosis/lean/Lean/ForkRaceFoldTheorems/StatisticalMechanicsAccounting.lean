/-!
# Statistical mechanics accounting

This module gives the closed 10/12/17/22 architecture a finite statistical
mechanics accounting layer. The macrostate is the exact layer stack plus the
10/30/90 saturation trace. Microstate enumeration is deliberately absent: the
accounting surface counts visible mass, leakage, and density-times-volume mass
from the constrained macrostate.
-/

/-- The visible row budget is the local Aeon coordinate. -/
def visibleRowBudget : Nat :=
  layerCoordinate CosmosLayer.localAeon

/-- The topological volume used by this finite accounting pass. -/
def topologicalVolume : Nat :=
  visibleRowBudget

/-- Visible mass is the part of a saturation density admitted by the row budget. -/
def visibleMass (saturation : Nat) : Nat :=
  min saturation visibleRowBudget

/-- Leakage is the unresolved pressure beyond the row budget. -/
def leakage (saturation : Nat) : Nat :=
  saturation - visibleRowBudget

/-- Saturation mass is density multiplied by finite topological volume. -/
def informationMass (saturation : Nat) : Nat :=
  saturation * topologicalVolume

/-- Leakage pressure multiplied by finite topological volume. -/
def leakageMass (saturation : Nat) : Nat :=
  leakage saturation * topologicalVolume

/-- Visible mass trace over a harmonic frequency. -/
def visibleMassTrace (omega : HarmonicFrequency) : List Nat :=
  (saturationCoordinates omega).map visibleMass

/-- Leakage trace over a harmonic frequency. -/
def leakageTrace (omega : HarmonicFrequency) : List Nat :=
  (saturationCoordinates omega).map leakage

/-- Density-times-volume mass trace over a harmonic frequency. -/
def informationMassTrace (omega : HarmonicFrequency) : List Nat :=
  (saturationCoordinates omega).map informationMass

/-- Leakage-times-volume mass trace over a harmonic frequency. -/
def leakageMassTrace (omega : HarmonicFrequency) : List Nat :=
  (saturationCoordinates omega).map leakageMass

/-- Total leakage pressure in the finite accounting trace. -/
def totalLeakage (omega : HarmonicFrequency) : Nat :=
  (leakageTrace omega).foldl (fun acc value => acc + value) 0

/-- Total density-times-volume mass in the finite accounting trace. -/
def totalInformationMass (omega : HarmonicFrequency) : Nat :=
  (informationMassTrace omega).foldl (fun acc value => acc + value) 0

/-- The bucket size is the same aperture as the visible row budget. -/
def bucketSize : Nat :=
  visibleRowBudget

/-- A bucket is full when the incoming saturation matches the bucket size. -/
def bucketFull (saturation : Nat) : Prop :=
  saturation = bucketSize

/-- The local carrying capacity is saturation-at-capacity times volume. -/
def localCarryingCapacity : Nat :=
  informationMass bucketSize

/-- The stable white signal mass is the white saturation across volume 12. -/
def whiteStableSignalMass : Nat :=
  informationMass 10

/-- Virtual mass is total mass not carried by the local capacity. -/
def virtualMass (omega : HarmonicFrequency) : Nat :=
  totalInformationMass omega - localCarryingCapacity

/-- Capacity of a hypothetical square bucket with matching row and volume. -/
def carryingCapacityAtBudget (budget : Nat) : Nat :=
  budget * budget

/-- Leakage under a hypothetical row budget. -/
def leakageAtBudget (budget saturation : Nat) : Nat :=
  saturation - budget

/-- The local bucket exposes its useful small-factor symmetries. -/
def bucketSymmetryWitness : Prop :=
  2 * 6 = bucketSize /\
    3 * 4 = bucketSize /\
    4 * 3 = bucketSize /\
    6 * 2 = bucketSize

/-- Pink and brown enclosure bucket ratios, encoded without rationals. -/
def enclosureBucketRatiosMeasured : Prop :=
  30 * 2 = bucketSize * 5 /\
    90 * 2 = bucketSize * 15

/-- The exact pressure gradient is eight local bucket units. -/
def pressureGradientMultiplier : Nat :=
  8

/-- Pressure-gradient certificate used by runtime allocation/checksum adapters. -/
def pressureGradientCertificate
    (witness : ReconstructionWitness) : Prop :=
  totalLeakage witness.omega = 96 /\
    totalLeakage witness.omega = pressureGradientMultiplier * bucketSize /\
    96 = pressureGradientMultiplier * bucketSize

/-- Calibrated physical pressure transports SPa into an external pressure unit. -/
def calibratedPhysicalPressure
    (calibration : Nat)
    (omega : HarmonicFrequency) : Nat :=
  calibration * totalLeakage omega

/--
Fluidic routing can use the information-pressure gradient once an external
calibration from SPa into physical pressure units is supplied.
-/
def calibratedFluidicPressureBridge
    (calibration : Nat)
    (witness : ReconstructionWitness) : Prop :=
  pressureGradientCertificate witness /\
    calibratedPhysicalPressure calibration witness.omega =
      calibration * (pressureGradientMultiplier * bucketSize)

/-- Exact runtime mass checksum for admitting pressure-routed execution. -/
def exactMassChecksum
    (observedMass : Nat)
    (omega : HarmonicFrequency) : Prop :=
  observedMass = totalInformationMass omega /\
    observedMass = 1560

/-- Brown leakage remains the dominant pressure rank after calibration. -/
def calibratedBrownPressureDominatesPink
    (calibration : Nat) : Prop :=
  calibration * leakage 30 <= calibration * leakage 90

/-- Pressure ranking preserves the same calibrated total-gradient law. -/
def pressureRankPreservesGradient
    (calibration : Nat)
    (witness : ReconstructionWitness) : Prop :=
  calibratedBrownPressureDominatesPink calibration /\
    calibratedPhysicalPressure calibration witness.omega =
      calibration * (leakage 10 + leakage 30 + leakage 90)

/--
Fluidic routing is admissible only when calibration is positive, the exact mass
checksum matches, and pressure-ranked routing preserves the same gradient.
-/
def fluidicRoutingAdmissible
    (calibration observedMass : Nat)
    (witness : ReconstructionWitness) : Prop :=
  0 < calibration /\
    exactMassChecksum observedMass witness.omega /\
    calibratedFluidicPressureBridge calibration witness /\
    pressureRankPreservesGradient calibration witness

/-- A route is represented by its pressure drop; `none` means no route was selected. -/
abbrev RoutePressureDecision :=
  Option Nat

/-- A pressure budget admits a route when the route's pressure drop fits inside it. -/
def routeWithinPressureBudget
    (budget pressureDrop : Nat) : Prop :=
  pressureDrop <= budget

/-- A pressure budget rejects a route when the route's pressure drop exceeds it. -/
def routeRejectedByPressureBudget
    (budget pressureDrop : Nat) : Prop :=
  budget < pressureDrop

/--
Tightening a pressure budget is monotonic when it only rejects the selected
route or preserves the selected route's pressure ordering.
-/
def pressureBudgetTighteningAudit
    (lowerBudget upperBudget : Nat)
    (lowerDecision upperDecision : RoutePressureDecision) : Prop :=
  lowerBudget <= upperBudget /\
    match lowerDecision, upperDecision with
    | none, none => True
    | none, some upperDrop =>
        routeWithinPressureBudget upperBudget upperDrop
    | some lowerDrop, some upperDrop =>
        routeWithinPressureBudget lowerBudget lowerDrop /\
          routeWithinPressureBudget upperBudget upperDrop /\
          lowerDrop <= upperDrop
    | some _, none => False

/-- A lower budget may reject a route that a looser budget still admits. -/
def lowerBudgetRejectsButUpperAdmits
    (lowerBudget upperBudget pressureDrop : Nat) : Prop :=
  lowerBudget <= upperBudget /\
    routeRejectedByPressureBudget lowerBudget pressureDrop /\
    routeWithinPressureBudget upperBudget pressureDrop

/-- Binary pressure comparator used by finite route selection. -/
def lowerRoutePressure
    (left right : Nat) : Nat :=
  if left <= right then left else right

/-- Lowest pressure drop in a finite route list; `none` means no candidates. -/
def lowestRoutePressure : List Nat -> RoutePressureDecision
  | [] => none
  | first :: rest => some (rest.foldl lowerRoutePressure first)

/--
Finite selector matching the runtime control flow: compute the lowest route
pressure, then reject it when it exceeds the active pressure budget.
-/
def selectLowestPressureWithinBudget
    (budget : Nat)
    (routePressures : List Nat) : RoutePressureDecision :=
  match lowestRoutePressure routePressures with
  | none => none
  | some pressureDrop =>
      if pressureDrop <= budget then
        some pressureDrop
      else
        none

/-- Indexed runtime route candidate: a stable route id plus its pressure drop. -/
structure IndexedRouteCandidate where
  routeId : Nat
  pressureDrop : Nat

/-- Indexed route selection; `none` means no candidate survived the budget. -/
abbrev IndexedRouteDecision :=
  Option IndexedRouteCandidate

/-- Project an indexed route decision back down to the pressure-only audit surface. -/
def indexedDecisionPressure
    (decision : IndexedRouteDecision) : RoutePressureDecision :=
  match decision with
  | none => none
  | some candidate => some candidate.pressureDrop

/-- Project an indexed route decision to the selected route id. -/
def indexedDecisionRouteId
    (decision : IndexedRouteDecision) : Option Nat :=
  match decision with
  | none => none
  | some candidate => some candidate.routeId

/-- Runtime-observable route-id order for an indexed candidate list. -/
def indexedRouteIdTrace
    (candidates : List IndexedRouteCandidate) : List Nat :=
  candidates.map (fun candidate => candidate.routeId)

/-- Runtime-observable indexed candidate lookup by original input position. -/
def indexedCandidateAtInputIndex :
    List IndexedRouteCandidate -> Nat -> IndexedRouteDecision
  | [], _ => none
  | candidate :: _, 0 => some candidate
  | _ :: rest, index + 1 => indexedCandidateAtInputIndex rest index

/-- Binary comparator for indexed route candidates, ordered by pressure drop. -/
def lowerIndexedRoutePressure
    (left right : IndexedRouteCandidate) : IndexedRouteCandidate :=
  if left.pressureDrop <= right.pressureDrop then left else right

/-- The selected candidate's pressure is no greater than every listed candidate. -/
def indexedPressureNoGreaterThanAll
    (selected : IndexedRouteCandidate) :
    List IndexedRouteCandidate -> Prop
  | [] => True
  | candidate :: rest =>
      selected.pressureDrop <= candidate.pressureDrop /\
        indexedPressureNoGreaterThanAll selected rest

/-- Every remaining candidate has the same pressure drop as the seed candidate. -/
def indexedPressureTiedTo
    (seed : IndexedRouteCandidate) :
    List IndexedRouteCandidate -> Prop
  | [] => True
  | candidate :: rest =>
      seed.pressureDrop = candidate.pressureDrop /\
        indexedPressureTiedTo seed rest

/-- Combined selector contract: selected candidate is an input and pressure-minimal. -/
def indexedRouteSelectionCertified
    (selected : IndexedRouteCandidate)
    (candidates : List IndexedRouteCandidate) : Prop :=
  selected ∈ candidates /\
    indexedPressureNoGreaterThanAll selected candidates

/--
Budgeted selector contract: selected candidate is inside budget, an input
candidate, and pressure-minimal among the original candidates.
-/
def indexedBudgetRouteSelectionCertified
    (budget : Nat)
    (selected : IndexedRouteCandidate)
    (candidates : List IndexedRouteCandidate) : Prop :=
  selected.pressureDrop <= budget /\
    indexedRouteSelectionCertified selected candidates

/-- Lowest-pressure candidate from an already-known non-empty seed. -/
def lowestIndexedRouteCandidateFrom
    (seed : IndexedRouteCandidate) :
    List IndexedRouteCandidate -> IndexedRouteCandidate
  | [] => seed
  | candidate :: rest =>
      lowestIndexedRouteCandidateFrom
        (lowerIndexedRoutePressure seed candidate)
        rest

/-- Lowest-pressure indexed candidate in a finite route list. -/
def lowestIndexedRouteCandidate : List IndexedRouteCandidate -> IndexedRouteDecision
  | [] => none
  | first :: rest => some (lowestIndexedRouteCandidateFrom first rest)

/-- Indexed selector matching runtime node selection plus pressure-budget rejection. -/
def selectIndexedRouteWithinBudget
    (budget : Nat)
    (candidates : List IndexedRouteCandidate) : IndexedRouteDecision :=
  match lowestIndexedRouteCandidate candidates with
  | none => none
  | some candidate =>
      if candidate.pressureDrop <= budget then
        some candidate
      else
        none

/-- Exact lower-pressure route candidate at the prime witness id. -/
def exactPrimaryRouteCandidate : IndexedRouteCandidate :=
  { routeId := 17, pressureDrop := bucketSize }

/-- Exact higher-pressure route candidate at the double witness id. -/
def exactHigherPressureRouteCandidate : IndexedRouteCandidate :=
  { routeId := 22, pressureDrop := bucketSize + 8 }

/-- Exact route that is rejected by a tight budget but admitted by the bucket. -/
def exactTightRouteCandidate : IndexedRouteCandidate :=
  { routeId := 17, pressureDrop := bucketSize - 2 }

/-- Exact tied-pressure route that is rejected by a tight budget. -/
def exactTightTiedRouteCandidate : IndexedRouteCandidate :=
  { routeId := 22, pressureDrop := bucketSize - 2 }

/-- Exact tied-pressure route candidate at the double witness id. -/
def exactTiedPressureRouteCandidate : IndexedRouteCandidate :=
  { routeId := 22, pressureDrop := bucketSize }

/--
The accounting is constrained when both the exact layer handshake and the full
reconstruction certificate are present.
-/
def constrainedAccounting (witness : ReconstructionWitness) : Prop :=
  layerHandshake witness /\ reconstructionComplete witness /\ baseReady witness

/-- Complete statistical mechanics accounting for a witness. -/
def statisticalMechanicsAccountingComplete
    (witness : ReconstructionWitness) : Prop :=
  constrainedAccounting witness /\
    visibleMassTrace witness.omega = [10, 12, 12] /\
    leakageTrace witness.omega = [0, 18, 78] /\
    informationMassTrace witness.omega = [120, 360, 1080] /\
    leakageMassTrace witness.omega = [0, 216, 936]

/-- Complete gnostic metrology for the finite accounting profile. -/
def gnosticMetrologyComplete
    (witness : ReconstructionWitness) : Prop :=
  statisticalMechanicsAccountingComplete witness /\
    bucketSize = 12 /\
    bucketFull 12 /\
    localCarryingCapacity = 144 /\
    whiteStableSignalMass = 120 /\
    virtualMass witness.omega = 1416 /\
    pressureGradientCertificate witness /\
    totalLeakage witness.omega = 8 * bucketSize /\
    bucketSymmetryWitness /\
    enclosureBucketRatiosMeasured

