/-- The exact pressure-gradient certificate is fixed by the accounting trace. -/
theorem exact_pressure_gradient_certificate :
    pressureGradientCertificate exactReconstructionWitness := by
  exact And.intro exact_total_leakage
    (And.intro exact_total_pressure_eight_bucket_sizes
      exact_pressure_gradient_value)

/-- Any calibration transports the exact pressure to calibration times 96. -/
theorem exact_calibrated_physical_pressure
    (calibration : Nat) :
    calibratedPhysicalPressure calibration exactReconstructionWitness.omega =
      calibration * 96 := by
  rfl

/-- The calibrated pressure obeys the same eight-bucket gradient law. -/
theorem exact_calibrated_physical_pressure_bucket_law
    (calibration : Nat) :
    calibratedPhysicalPressure calibration exactReconstructionWitness.omega =
      calibration * (pressureGradientMultiplier * bucketSize) := by
  rw [exact_calibrated_physical_pressure, exact_pressure_gradient_value]

/-- The exact pressure-gradient certificate lifts into calibrated fluidic pressure. -/
theorem exact_calibrated_fluidic_pressure_bridge
    (calibration : Nat) :
    calibratedFluidicPressureBridge calibration exactReconstructionWitness := by
  exact And.intro exact_pressure_gradient_certificate
    (exact_calibrated_physical_pressure_bucket_law calibration)

/-- The exact witness satisfies the 1560 gG mass checksum. -/
theorem exact_mass_checksum
    (observedMass : Nat)
    (hObserved : observedMass = 1560) :
    exactMassChecksum observedMass exactReconstructionWitness.omega := by
  exact And.intro
    (by rw [hObserved, exact_total_information_mass])
    hObserved

/-- Calibration preserves the brown-over-pink pressure ranking. -/
theorem exact_calibrated_brown_pressure_dominates_pink
    (calibration : Nat) :
    calibratedBrownPressureDominatesPink calibration := by
  unfold calibratedBrownPressureDominatesPink
  rw [pink_leakage_eighteen, brown_leakage_seventy_eight]
  exact Nat.mul_le_mul_left calibration (by decide)

/-- The pressure-ranked route preserves the calibrated 96-unit gradient. -/
theorem exact_pressure_rank_preserves_gradient
    (calibration : Nat) :
    pressureRankPreservesGradient calibration exactReconstructionWitness := by
  exact And.intro
    (exact_calibrated_brown_pressure_dominates_pink calibration)
    (by
      rw [exact_calibrated_physical_pressure]
      rw [white_leakage_zero, pink_leakage_eighteen, brown_leakage_seventy_eight])

/--
Positive calibration plus the exact 1560 gG checksum admits fluidic routing
without changing the underlying pressure-gradient certificate.
-/
theorem exact_fluidic_routing_admissible
    (calibration observedMass : Nat)
    (hCalibration : 0 < calibration)
    (hObserved : observedMass = 1560) :
    fluidicRoutingAdmissible calibration observedMass exactReconstructionWitness := by
  exact And.intro hCalibration
    (And.intro
      (exact_mass_checksum observedMass hObserved)
      (And.intro
        (exact_calibrated_fluidic_pressure_bridge calibration)
        (exact_pressure_rank_preserves_gradient calibration)))

/-- If both budgets reject, tightening preserves the audit invariant. -/
theorem pressure_budget_tightening_both_reject
    {lowerBudget upperBudget : Nat}
    (hBudget : lowerBudget <= upperBudget) :
    pressureBudgetTighteningAudit lowerBudget upperBudget none none := by
  unfold pressureBudgetTighteningAudit
  exact And.intro hBudget trivial

/--
If the tighter budget rejects the selected route but the looser budget admits
it, no higher-pressure route has been promoted by tightening.
-/
theorem pressure_budget_tightening_lower_rejects_route
    {lowerBudget upperBudget upperDrop : Nat}
    (hBudget : lowerBudget <= upperBudget)
    (hUpper : routeWithinPressureBudget upperBudget upperDrop) :
    pressureBudgetTighteningAudit lowerBudget upperBudget none (some upperDrop) := by
  unfold pressureBudgetTighteningAudit
  exact And.intro hBudget hUpper

/--
If both budgets select routes and the lower-budget selection is no more
expensive, tightening preserves pressure order.
-/
theorem pressure_budget_tightening_rejects_or_preserves_order
    {lowerBudget upperBudget lowerDrop upperDrop : Nat}
    (hBudget : lowerBudget <= upperBudget)
    (hLower : routeWithinPressureBudget lowerBudget lowerDrop)
    (hUpper : routeWithinPressureBudget upperBudget upperDrop)
    (hOrder : lowerDrop <= upperDrop) :
    pressureBudgetTighteningAudit lowerBudget upperBudget
      (some lowerDrop) (some upperDrop) := by
  unfold pressureBudgetTighteningAudit
  exact And.intro hBudget
    (And.intro hLower
      (And.intro hUpper hOrder))

/-- A proved lower-rejection/upper-admission relation lifts into the audit. -/
theorem lower_rejection_lifts_to_pressure_budget_audit
    {lowerBudget upperBudget pressureDrop : Nat}
    (hRejection : lowerBudgetRejectsButUpperAdmits
      lowerBudget upperBudget pressureDrop) :
    pressureBudgetTighteningAudit lowerBudget upperBudget
      none (some pressureDrop) := by
  unfold lowerBudgetRejectsButUpperAdmits at hRejection
  exact pressure_budget_tightening_lower_rejects_route
    hRejection.left hRejection.right.right

/-- The exact pressure budget preserves equal selected-route pressure order. -/
theorem exact_pressure_budget_same_order_preserved :
    pressureBudgetTighteningAudit
      bucketSize
      (totalLeakage exactReconstructionWitness.omega)
      (some bucketSize)
      (some bucketSize) := by
  unfold pressureBudgetTighteningAudit routeWithinPressureBudget
  rw [bucket_size_is_twelve, exact_total_leakage]
  decide

/--
In row units, a tight 9-unit budget rejects the representative 10-unit route
while the exact 12-unit bucket admits it.
-/
theorem exact_pressure_budget_lower_rejection_without_promotion :
    lowerBudgetRejectsButUpperAdmits
      (bucketSize - 3)
      bucketSize
      (bucketSize - 2) := by
  unfold lowerBudgetRejectsButUpperAdmits
  unfold routeRejectedByPressureBudget routeWithinPressureBudget
  rw [bucket_size_is_twelve]
  decide

/-- The row-unit lower-rejection case also satisfies the tightening audit. -/
theorem exact_pressure_budget_lower_rejection_audit :
    pressureBudgetTighteningAudit
      (bucketSize - 3)
      bucketSize
      none
      (some (bucketSize - 2)) := by
  exact lower_rejection_lifts_to_pressure_budget_audit
    exact_pressure_budget_lower_rejection_without_promotion

/-- The finite selector returns no route when no candidates are available. -/
theorem pressure_selector_empty_rejects
    (budget : Nat) :
    selectLowestPressureWithinBudget budget [] = none := by
  rfl

/-- The exact selector picks the lower-pressure bucket route before budgeting. -/
theorem exact_pressure_selector_picks_lowest_route :
    lowestRoutePressure [bucketSize + 8, bucketSize] = some bucketSize := by
  rw [bucket_size_is_twelve]
  unfold lowestRoutePressure lowerRoutePressure
  rfl

/-- The exact selector admits the lowest route when it fits the bucket budget. -/
theorem exact_pressure_selector_admits_lowest_route :
    selectLowestPressureWithinBudget bucketSize
      [bucketSize + 8, bucketSize] = some bucketSize := by
  rw [bucket_size_is_twelve]
  unfold selectLowestPressureWithinBudget lowestRoutePressure lowerRoutePressure
  rfl

/-- The exact selector also admits the lowest route under the full pressure budget. -/
theorem exact_pressure_selector_admits_lowest_route_under_total_pressure :
    selectLowestPressureWithinBudget
      (totalLeakage exactReconstructionWitness.omega)
      [bucketSize + 8, bucketSize] = some bucketSize := by
  rw [bucket_size_is_twelve, exact_total_leakage]
  unfold selectLowestPressureWithinBudget lowestRoutePressure lowerRoutePressure
  rfl

/-- The exact selector rejects a route whose pressure exceeds the tight budget. -/
theorem exact_pressure_selector_rejects_over_budget :
    selectLowestPressureWithinBudget (bucketSize - 3)
      [bucketSize - 2] = none := by
  rw [bucket_size_is_twelve]
  unfold selectLowestPressureWithinBudget lowestRoutePressure
  rfl

/-- The exact selector admits that same route under the looser bucket budget. -/
theorem exact_pressure_selector_admits_under_bucket_budget :
    selectLowestPressureWithinBudget bucketSize
      [bucketSize - 2] = some (bucketSize - 2) := by
  rw [bucket_size_is_twelve]
  unfold selectLowestPressureWithinBudget lowestRoutePressure
  rfl

/-- Exact finite selection satisfies the same-order tightening audit. -/
theorem exact_pressure_selector_same_order_audit :
    pressureBudgetTighteningAudit
      bucketSize
      (totalLeakage exactReconstructionWitness.omega)
      (selectLowestPressureWithinBudget bucketSize
        [bucketSize + 8, bucketSize])
      (selectLowestPressureWithinBudget
        (totalLeakage exactReconstructionWitness.omega)
        [bucketSize + 8, bucketSize]) := by
  rw [exact_pressure_selector_admits_lowest_route,
    exact_pressure_selector_admits_lowest_route_under_total_pressure]
  exact exact_pressure_budget_same_order_preserved

/-- Exact finite selection satisfies the lower-rejection audit path. -/
theorem exact_pressure_selector_lower_rejection_audit :
    pressureBudgetTighteningAudit
      (bucketSize - 3)
      bucketSize
      (selectLowestPressureWithinBudget (bucketSize - 3)
        [bucketSize - 2])
      (selectLowestPressureWithinBudget bucketSize
        [bucketSize - 2]) := by
  rw [exact_pressure_selector_rejects_over_budget,
    exact_pressure_selector_admits_under_bucket_budget]
  exact exact_pressure_budget_lower_rejection_audit

/-- The lower indexed comparator is no greater than its left input. -/
theorem lower_indexed_route_pressure_le_left
    (left right : IndexedRouteCandidate) :
    (lowerIndexedRoutePressure left right).pressureDrop <= left.pressureDrop := by
  unfold lowerIndexedRoutePressure
  by_cases h : left.pressureDrop <= right.pressureDrop
  · simp [h]
  · simp [h]
    exact Nat.le_of_lt (Nat.lt_of_not_ge h)

/-- The lower indexed comparator is no greater than its right input. -/
theorem lower_indexed_route_pressure_le_right
    (left right : IndexedRouteCandidate) :
    (lowerIndexedRoutePressure left right).pressureDrop <= right.pressureDrop := by
  unfold lowerIndexedRoutePressure
  by_cases h : left.pressureDrop <= right.pressureDrop
  · simp [h]
  · simp [h]

/-- The lower indexed comparator returns one of its two input candidates. -/
theorem lower_indexed_route_pressure_eq_left_or_right
    (left right : IndexedRouteCandidate) :
    lowerIndexedRoutePressure left right = left \/
      lowerIndexedRoutePressure left right = right := by
  unfold lowerIndexedRoutePressure
  by_cases h : left.pressureDrop <= right.pressureDrop
  · left
    simp [h]
  · right
    simp [h]

/-- Equal pressure keeps the left indexed route candidate. -/
theorem lower_indexed_route_pressure_left_biased_on_tie
    (left right : IndexedRouteCandidate)
    (hTie : left.pressureDrop = right.pressureDrop) :
    lowerIndexedRoutePressure left right = left := by
  unfold lowerIndexedRoutePressure
  rw [hTie]
  simp

/--
When every remaining candidate ties the seed pressure, the selector helper keeps
the seed rather than replacing it with a later equal-pressure candidate.
-/
theorem lowest_indexed_route_candidate_from_preserves_seed_on_ties
    (seed : IndexedRouteCandidate)
    (rest : List IndexedRouteCandidate)
    (hTies : indexedPressureTiedTo seed rest) :
    lowestIndexedRouteCandidateFrom seed rest = seed := by
  induction rest with
  | nil =>
      rfl
  | cons candidate rest ih =>
      change seed.pressureDrop = candidate.pressureDrop /\
        indexedPressureTiedTo seed rest at hTies
      unfold lowestIndexedRouteCandidateFrom
      have hLower :
          lowerIndexedRoutePressure seed candidate = seed :=
        lower_indexed_route_pressure_left_biased_on_tie
          seed
          candidate
          hTies.left
      rw [hLower]
      exact ih hTies.right

/-- A non-empty all-tied indexed candidate list selects its first candidate. -/
theorem lowest_indexed_route_candidate_stable_tie_contract
    (seed : IndexedRouteCandidate)
    (rest : List IndexedRouteCandidate)
    (hTies : indexedPressureTiedTo seed rest) :
    lowestIndexedRouteCandidate (seed :: rest) = some seed := by
  change some (lowestIndexedRouteCandidateFrom seed rest) = some seed
  rw [lowest_indexed_route_candidate_from_preserves_seed_on_ties
    seed rest hTies]

/--
The budgeted indexed selector preserves the first candidate across tied
pressures whenever that first candidate fits the budget.
-/
theorem select_indexed_route_within_budget_stable_tie_contract
    (budget : Nat)
    (seed : IndexedRouteCandidate)
    (rest : List IndexedRouteCandidate)
    (hBudget : seed.pressureDrop <= budget)
    (hTies : indexedPressureTiedTo seed rest) :
    selectIndexedRouteWithinBudget budget (seed :: rest) = some seed := by
  unfold selectIndexedRouteWithinBudget
  rw [lowest_indexed_route_candidate_stable_tie_contract seed rest hTies]
  simp [hBudget]

/--
For any budget-admitted tied candidate list, the selected route id matches the
first id in the runtime-observable candidate order.
-/
theorem select_indexed_route_within_budget_stable_tie_runtime_order_alignment
    (budget : Nat)
    (seed : IndexedRouteCandidate)
    (rest : List IndexedRouteCandidate)
    (hBudget : seed.pressureDrop <= budget)
    (hTies : indexedPressureTiedTo seed rest) :
    indexedDecisionRouteId
      (selectIndexedRouteWithinBudget budget (seed :: rest)) =
      (indexedRouteIdTrace (seed :: rest)).head? := by
  rw [select_indexed_route_within_budget_stable_tie_contract
    budget seed rest hBudget hTies]
  unfold indexedDecisionRouteId indexedRouteIdTrace
  rfl

/--
For any budget-admitted tied candidate list, the selected candidate is exactly
the input candidate at index zero.
-/
theorem select_indexed_route_within_budget_stable_tie_preserves_input_index_zero
    (budget : Nat)
    (seed : IndexedRouteCandidate)
    (rest : List IndexedRouteCandidate)
    (hBudget : seed.pressureDrop <= budget)
    (hTies : indexedPressureTiedTo seed rest) :
    selectIndexedRouteWithinBudget budget (seed :: rest) =
      indexedCandidateAtInputIndex (seed :: rest) 0 := by
  rw [select_indexed_route_within_budget_stable_tie_contract
    budget seed rest hBudget hTies]
  rfl

/--
When the tied seed exceeds the budget, the budgeted indexed selector rejects
the entire tied candidate list.
-/
theorem select_indexed_route_within_budget_stable_tie_rejects_over_budget
    (budget : Nat)
    (seed : IndexedRouteCandidate)
    (rest : List IndexedRouteCandidate)
    (hOverBudget : ¬ seed.pressureDrop <= budget)
    (hTies : indexedPressureTiedTo seed rest) :
    selectIndexedRouteWithinBudget budget (seed :: rest) = none := by
  unfold selectIndexedRouteWithinBudget
  rw [lowest_indexed_route_candidate_stable_tie_contract seed rest hTies]
  simp [hOverBudget]

/--
When a tied list is over budget, the route-id projection of the rejected
decision is empty.
-/
theorem select_indexed_route_within_budget_stable_tie_rejects_route_id
    (budget : Nat)
    (seed : IndexedRouteCandidate)
    (rest : List IndexedRouteCandidate)
    (hOverBudget : ¬ seed.pressureDrop <= budget)
    (hTies : indexedPressureTiedTo seed rest) :
    indexedDecisionRouteId
      (selectIndexedRouteWithinBudget budget (seed :: rest)) = none := by
  rw [select_indexed_route_within_budget_stable_tie_rejects_over_budget
    budget seed rest hOverBudget hTies]
  rfl

/--
When a tied list is over budget, the pressure projection of the rejected
decision is empty.
-/
theorem select_indexed_route_within_budget_stable_tie_rejects_pressure
    (budget : Nat)
    (seed : IndexedRouteCandidate)
    (rest : List IndexedRouteCandidate)
    (hOverBudget : ¬ seed.pressureDrop <= budget)
    (hTies : indexedPressureTiedTo seed rest) :
    indexedDecisionPressure
      (selectIndexedRouteWithinBudget budget (seed :: rest)) = none := by
  rw [select_indexed_route_within_budget_stable_tie_rejects_over_budget
    budget seed rest hOverBudget hTies]
  rfl

/--
The non-empty indexed selector helper returns a candidate whose pressure is no
greater than the seed and every remaining candidate.
-/
theorem lowest_indexed_route_candidate_from_minimum_correct
    (seed : IndexedRouteCandidate)
    (rest : List IndexedRouteCandidate) :
    (lowestIndexedRouteCandidateFrom seed rest).pressureDrop <= seed.pressureDrop /\
      indexedPressureNoGreaterThanAll
        (lowestIndexedRouteCandidateFrom seed rest)
        rest := by
  induction rest generalizing seed with
  | nil =>
      unfold lowestIndexedRouteCandidateFrom indexedPressureNoGreaterThanAll
      exact And.intro (Nat.le_refl seed.pressureDrop) trivial
  | cons candidate rest ih =>
      unfold lowestIndexedRouteCandidateFrom
      have hRest := ih (lowerIndexedRoutePressure seed candidate)
      exact And.intro
        (Nat.le_trans hRest.left
          (lower_indexed_route_pressure_le_left seed candidate))
        (And.intro
          (Nat.le_trans hRest.left
            (lower_indexed_route_pressure_le_right seed candidate))
          hRest.right)

/--
The non-empty indexed selector helper returns either the seed or a candidate
from the remaining input list.
-/
theorem lowest_indexed_route_candidate_from_membership_preserved
    (seed : IndexedRouteCandidate)
    (rest : List IndexedRouteCandidate) :
    lowestIndexedRouteCandidateFrom seed rest = seed \/
      lowestIndexedRouteCandidateFrom seed rest ∈ rest := by
  induction rest generalizing seed with
  | nil =>
      unfold lowestIndexedRouteCandidateFrom
      exact Or.inl rfl
  | cons candidate rest ih =>
      unfold lowestIndexedRouteCandidateFrom
      have hRecursive := ih (lowerIndexedRoutePressure seed candidate)
      rcases hRecursive with hSelectedLower | hSelectedRest
      · rcases lower_indexed_route_pressure_eq_left_or_right seed candidate with
        hLowerSeed | hLowerCandidate
        · left
          rw [hSelectedLower, hLowerSeed]
        · right
          rw [hSelectedLower, hLowerCandidate]
          simp
      · right
        exact List.Mem.tail candidate hSelectedRest

/--
Any candidate returned by the indexed selector has pressure no greater than
every candidate in the original list.
-/
theorem lowest_indexed_route_candidate_minimum_correct
    {candidates : List IndexedRouteCandidate}
    {selected : IndexedRouteCandidate}
    (hSelected : lowestIndexedRouteCandidate candidates = some selected) :
    indexedPressureNoGreaterThanAll selected candidates := by
  cases candidates with
  | nil =>
      unfold lowestIndexedRouteCandidate at hSelected
      cases hSelected
  | cons first rest =>
      unfold lowestIndexedRouteCandidate at hSelected
      cases hSelected
      have hMinimum :=
        lowest_indexed_route_candidate_from_minimum_correct first rest
      unfold indexedPressureNoGreaterThanAll
      exact And.intro hMinimum.left hMinimum.right

/-- Any candidate returned by the indexed selector came from the original list. -/
theorem lowest_indexed_route_candidate_membership_preserved
    {candidates : List IndexedRouteCandidate}
    {selected : IndexedRouteCandidate}
    (hSelected : lowestIndexedRouteCandidate candidates = some selected) :
    selected ∈ candidates := by
  cases candidates with
  | nil =>
      unfold lowestIndexedRouteCandidate at hSelected
      cases hSelected
  | cons first rest =>
      unfold lowestIndexedRouteCandidate at hSelected
      cases hSelected
      have hMember :=
        lowest_indexed_route_candidate_from_membership_preserved first rest
      rcases hMember with hSeed | hRest
      · rw [hSeed]
        simp
      · exact List.Mem.tail first hRest

/--
Any route admitted by the indexed budget selector is inside budget and remains
the minimum-pressure candidate for the original list.
-/
theorem select_indexed_route_within_budget_minimum_correct
    {budget : Nat}
    {candidates : List IndexedRouteCandidate}
    {selected : IndexedRouteCandidate}
    (hSelected :
      selectIndexedRouteWithinBudget budget candidates = some selected) :
    selected.pressureDrop <= budget /\
      indexedPressureNoGreaterThanAll selected candidates := by
  unfold selectIndexedRouteWithinBudget at hSelected
  cases hLowest : lowestIndexedRouteCandidate candidates with
  | none =>
      rw [hLowest] at hSelected
      cases hSelected
  | some lowest =>
      rw [hLowest] at hSelected
      by_cases hBudget : lowest.pressureDrop <= budget
      · simp [hBudget] at hSelected
        cases hSelected
        exact And.intro hBudget
          (lowest_indexed_route_candidate_minimum_correct hLowest)
      · simp [hBudget] at hSelected

/-- Any route admitted by the indexed budget selector came from the original list. -/
theorem select_indexed_route_within_budget_membership_preserved
    {budget : Nat}
    {candidates : List IndexedRouteCandidate}
    {selected : IndexedRouteCandidate}
    (hSelected :
      selectIndexedRouteWithinBudget budget candidates = some selected) :
    selected ∈ candidates := by
  unfold selectIndexedRouteWithinBudget at hSelected
  cases hLowest : lowestIndexedRouteCandidate candidates with
  | none =>
      rw [hLowest] at hSelected
      cases hSelected
  | some lowest =>
      rw [hLowest] at hSelected
      by_cases hBudget : lowest.pressureDrop <= budget
      · simp [hBudget] at hSelected
        cases hSelected
        exact lowest_indexed_route_candidate_membership_preserved hLowest
      · simp [hBudget] at hSelected

/--
Any candidate returned by the indexed selector is certified as both originating
from the input list and minimizing pressure over that list.
-/
theorem lowest_indexed_route_candidate_certified_selector_contract
    {candidates : List IndexedRouteCandidate}
    {selected : IndexedRouteCandidate}
    (hSelected : lowestIndexedRouteCandidate candidates = some selected) :
    indexedRouteSelectionCertified selected candidates := by
  exact And.intro
    (lowest_indexed_route_candidate_membership_preserved hSelected)
    (lowest_indexed_route_candidate_minimum_correct hSelected)

/--
Any route admitted by the budgeted indexed selector is certified as inside
budget, from the input list, and pressure-minimal over that list.
-/
theorem select_indexed_route_within_budget_certified_selector_contract
    {budget : Nat}
    {candidates : List IndexedRouteCandidate}
    {selected : IndexedRouteCandidate}
    (hSelected :
      selectIndexedRouteWithinBudget budget candidates = some selected) :
    indexedBudgetRouteSelectionCertified budget selected candidates := by
  have hMinimum := select_indexed_route_within_budget_minimum_correct hSelected
  exact And.intro hMinimum.left
    (And.intro
      (select_indexed_route_within_budget_membership_preserved hSelected)
      hMinimum.right)

/-- The indexed selector returns no route when no candidates are available. -/
theorem indexed_pressure_selector_empty_rejects
    (budget : Nat) :
    selectIndexedRouteWithinBudget budget [] = none := by
  rfl

/-- The indexed selector picks the candidate attached to the lower pressure. -/
theorem exact_indexed_pressure_selector_picks_primary_route :
    lowestIndexedRouteCandidate
      [exactHigherPressureRouteCandidate, exactPrimaryRouteCandidate] =
      some exactPrimaryRouteCandidate := by
  unfold exactHigherPressureRouteCandidate exactPrimaryRouteCandidate
  rw [bucket_size_is_twelve]
  unfold lowestIndexedRouteCandidate lowestIndexedRouteCandidateFrom
  unfold lowerIndexedRoutePressure
  rfl

/-- The indexed selector admits the primary candidate under the bucket budget. -/
theorem exact_indexed_pressure_selector_admits_primary_route :
    selectIndexedRouteWithinBudget bucketSize
      [exactHigherPressureRouteCandidate, exactPrimaryRouteCandidate] =
      some exactPrimaryRouteCandidate := by
  unfold exactHigherPressureRouteCandidate exactPrimaryRouteCandidate
  rw [bucket_size_is_twelve]
  unfold selectIndexedRouteWithinBudget
  unfold lowestIndexedRouteCandidate lowestIndexedRouteCandidateFrom
  unfold lowerIndexedRoutePressure
  rfl

/-- The indexed selector admits the primary candidate under the full pressure budget. -/
theorem exact_indexed_pressure_selector_admits_primary_route_under_total_pressure :
    selectIndexedRouteWithinBudget
      (totalLeakage exactReconstructionWitness.omega)
      [exactHigherPressureRouteCandidate, exactPrimaryRouteCandidate] =
      some exactPrimaryRouteCandidate := by
  unfold exactHigherPressureRouteCandidate exactPrimaryRouteCandidate
  rw [bucket_size_is_twelve, exact_total_leakage]
  unfold selectIndexedRouteWithinBudget
  unfold lowestIndexedRouteCandidate lowestIndexedRouteCandidateFrom
  unfold lowerIndexedRoutePressure
  rfl

/-- The indexed selector returns the prime witness route id for the exact candidate set. -/
theorem exact_indexed_pressure_selector_selects_prime_route_id :
    indexedDecisionRouteId
      (selectIndexedRouteWithinBudget bucketSize
        [exactHigherPressureRouteCandidate, exactPrimaryRouteCandidate]) =
      some 17 := by
  rw [exact_indexed_pressure_selector_admits_primary_route]
  unfold indexedDecisionRouteId exactPrimaryRouteCandidate
  rfl

/-- The indexed selector projects back to the pressure-only selector. -/
theorem exact_indexed_pressure_selector_pressure_projection :
    indexedDecisionPressure
      (selectIndexedRouteWithinBudget bucketSize
        [exactHigherPressureRouteCandidate, exactPrimaryRouteCandidate]) =
      selectLowestPressureWithinBudget bucketSize
        [bucketSize + 8, bucketSize] := by
  rw [exact_indexed_pressure_selector_admits_primary_route,
    exact_pressure_selector_admits_lowest_route]
  unfold indexedDecisionPressure exactPrimaryRouteCandidate
  rfl

/-- The selected indexed route is the prime candidate at the admitted minimum pressure. -/
theorem exact_indexed_pressure_selector_selected_candidate_has_minimum_pressure :
    selectIndexedRouteWithinBudget bucketSize
      [exactHigherPressureRouteCandidate, exactPrimaryRouteCandidate] =
      some exactPrimaryRouteCandidate /\
    indexedDecisionPressure
      (selectIndexedRouteWithinBudget bucketSize
        [exactHigherPressureRouteCandidate, exactPrimaryRouteCandidate]) =
      some bucketSize /\
    indexedDecisionRouteId
      (selectIndexedRouteWithinBudget bucketSize
        [exactHigherPressureRouteCandidate, exactPrimaryRouteCandidate]) =
      some 17 := by
  exact And.intro exact_indexed_pressure_selector_admits_primary_route
    (And.intro
      (by
        rw [exact_indexed_pressure_selector_admits_primary_route]
        unfold indexedDecisionPressure exactPrimaryRouteCandidate
        rfl)
      exact_indexed_pressure_selector_selects_prime_route_id)

/-- The exact primary route selection satisfies the combined budgeted contract. -/
theorem exact_indexed_pressure_selector_certified_primary_route_contract :
    indexedBudgetRouteSelectionCertified
      bucketSize
      exactPrimaryRouteCandidate
      [exactHigherPressureRouteCandidate, exactPrimaryRouteCandidate] := by
  exact select_indexed_route_within_budget_certified_selector_contract
    exact_indexed_pressure_selector_admits_primary_route

/-- Equal pressure keeps the first exact indexed route candidate. -/
theorem exact_indexed_pressure_selector_stable_tie_contract :
    selectIndexedRouteWithinBudget bucketSize
      [exactPrimaryRouteCandidate, exactTiedPressureRouteCandidate] =
      some exactPrimaryRouteCandidate := by
  have hTies :
      indexedPressureTiedTo
        exactPrimaryRouteCandidate
        [exactTiedPressureRouteCandidate] := by
    unfold indexedPressureTiedTo exactPrimaryRouteCandidate
      exactTiedPressureRouteCandidate
    exact And.intro rfl trivial
  have hBudget :
      exactPrimaryRouteCandidate.pressureDrop <= bucketSize := by
    unfold exactPrimaryRouteCandidate
    exact Nat.le_refl bucketSize
  exact select_indexed_route_within_budget_stable_tie_contract
    bucketSize
    exactPrimaryRouteCandidate
    [exactTiedPressureRouteCandidate]
    hBudget
    hTies

/-- The exact tied-pressure pair selects the first route id. -/
theorem exact_indexed_pressure_selector_stable_tie_selects_first_route_id :
    indexedDecisionRouteId
      (selectIndexedRouteWithinBudget bucketSize
        [exactPrimaryRouteCandidate, exactTiedPressureRouteCandidate]) =
      some 17 := by
  rw [exact_indexed_pressure_selector_stable_tie_contract]
  unfold indexedDecisionRouteId exactPrimaryRouteCandidate
  rfl

/--
For the exact tied-pressure pair, the selected route id matches the first id in
the runtime-observable candidate order.
-/
theorem exact_indexed_pressure_selector_stable_tie_runtime_order_alignment :
    indexedDecisionRouteId
      (selectIndexedRouteWithinBudget bucketSize
        [exactPrimaryRouteCandidate, exactTiedPressureRouteCandidate]) =
      (indexedRouteIdTrace
        [exactPrimaryRouteCandidate, exactTiedPressureRouteCandidate]).head? := by
  have hTies :
      indexedPressureTiedTo
        exactPrimaryRouteCandidate
        [exactTiedPressureRouteCandidate] := by
    unfold indexedPressureTiedTo exactPrimaryRouteCandidate
      exactTiedPressureRouteCandidate
    exact And.intro rfl trivial
  have hBudget :
      exactPrimaryRouteCandidate.pressureDrop <= bucketSize := by
    unfold exactPrimaryRouteCandidate
    exact Nat.le_refl bucketSize
  exact select_indexed_route_within_budget_stable_tie_runtime_order_alignment
    bucketSize
    exactPrimaryRouteCandidate
    [exactTiedPressureRouteCandidate]
    hBudget
    hTies

/-- The exact tied-pressure pair selects the input candidate at index zero. -/
theorem exact_indexed_pressure_selector_stable_tie_preserves_input_index_zero :
    selectIndexedRouteWithinBudget bucketSize
        [exactPrimaryRouteCandidate, exactTiedPressureRouteCandidate] =
      indexedCandidateAtInputIndex
        [exactPrimaryRouteCandidate, exactTiedPressureRouteCandidate]
        0 := by
  have hTies :
      indexedPressureTiedTo
        exactPrimaryRouteCandidate
        [exactTiedPressureRouteCandidate] := by
    unfold indexedPressureTiedTo exactPrimaryRouteCandidate
      exactTiedPressureRouteCandidate
    exact And.intro rfl trivial
  have hBudget :
      exactPrimaryRouteCandidate.pressureDrop <= bucketSize := by
    unfold exactPrimaryRouteCandidate
    exact Nat.le_refl bucketSize
  exact select_indexed_route_within_budget_stable_tie_preserves_input_index_zero
    bucketSize
    exactPrimaryRouteCandidate
    [exactTiedPressureRouteCandidate]
    hBudget
    hTies

/-- The exact tied tight-pressure pair is rejected by the tighter budget. -/
theorem exact_indexed_pressure_selector_stable_tie_rejects_over_budget :
    selectIndexedRouteWithinBudget (bucketSize - 3)
      [exactTightRouteCandidate, exactTightTiedRouteCandidate] = none := by
  have hTies :
      indexedPressureTiedTo
        exactTightRouteCandidate
        [exactTightTiedRouteCandidate] := by
    unfold indexedPressureTiedTo exactTightRouteCandidate
      exactTightTiedRouteCandidate
    exact And.intro rfl trivial
  have hOverBudget :
      ¬ exactTightRouteCandidate.pressureDrop <= bucketSize - 3 := by
    unfold exactTightRouteCandidate
    rw [bucket_size_is_twelve]
    decide
  exact select_indexed_route_within_budget_stable_tie_rejects_over_budget
    (bucketSize - 3)
    exactTightRouteCandidate
    [exactTightTiedRouteCandidate]
    hOverBudget
    hTies

/-- The exact tied tight-pressure rejection has no selected route id. -/
theorem exact_indexed_pressure_selector_stable_tie_rejects_route_id :
    indexedDecisionRouteId
      (selectIndexedRouteWithinBudget (bucketSize - 3)
        [exactTightRouteCandidate, exactTightTiedRouteCandidate]) =
      none := by
  rw [exact_indexed_pressure_selector_stable_tie_rejects_over_budget]
  rfl

/-- The exact tied tight-pressure rejection has no selected pressure. -/
theorem exact_indexed_pressure_selector_stable_tie_rejects_pressure :
    indexedDecisionPressure
      (selectIndexedRouteWithinBudget (bucketSize - 3)
        [exactTightRouteCandidate, exactTightTiedRouteCandidate]) =
      none := by
  rw [exact_indexed_pressure_selector_stable_tie_rejects_over_budget]
  rfl

/-- The exact tied tight-pressure pair is admitted under the bucket budget. -/
theorem exact_indexed_pressure_selector_stable_tie_admits_tight_route_under_bucket :
    selectIndexedRouteWithinBudget bucketSize
      [exactTightRouteCandidate, exactTightTiedRouteCandidate] =
      some exactTightRouteCandidate := by
  have hTies :
      indexedPressureTiedTo
        exactTightRouteCandidate
        [exactTightTiedRouteCandidate] := by
    unfold indexedPressureTiedTo exactTightRouteCandidate
      exactTightTiedRouteCandidate
    exact And.intro rfl trivial
  have hBudget :
      exactTightRouteCandidate.pressureDrop <= bucketSize := by
    unfold exactTightRouteCandidate
    exact Nat.sub_le bucketSize 2
  exact select_indexed_route_within_budget_stable_tie_contract
    bucketSize
    exactTightRouteCandidate
    [exactTightTiedRouteCandidate]
    hBudget
    hTies

/-- Exact tied tight-pressure selection satisfies the lower-rejection audit path. -/
theorem exact_indexed_pressure_selector_stable_tie_lower_rejection_audit :
    pressureBudgetTighteningAudit
      (bucketSize - 3)
      bucketSize
      (indexedDecisionPressure
        (selectIndexedRouteWithinBudget (bucketSize - 3)
          [exactTightRouteCandidate, exactTightTiedRouteCandidate]))
      (indexedDecisionPressure
        (selectIndexedRouteWithinBudget bucketSize
          [exactTightRouteCandidate, exactTightTiedRouteCandidate])) := by
  rw [exact_indexed_pressure_selector_stable_tie_rejects_over_budget,
    exact_indexed_pressure_selector_stable_tie_admits_tight_route_under_bucket]
  unfold indexedDecisionPressure exactTightRouteCandidate
  exact exact_pressure_budget_lower_rejection_audit

/-- The indexed selector rejects a route whose pressure exceeds the tight budget. -/
theorem exact_indexed_pressure_selector_rejects_over_budget :
    selectIndexedRouteWithinBudget (bucketSize - 3)
      [exactTightRouteCandidate] = none := by
  unfold exactTightRouteCandidate
  rw [bucket_size_is_twelve]
  unfold selectIndexedRouteWithinBudget lowestIndexedRouteCandidate
  rfl

/-- The indexed selector admits the same candidate under the looser bucket budget. -/
