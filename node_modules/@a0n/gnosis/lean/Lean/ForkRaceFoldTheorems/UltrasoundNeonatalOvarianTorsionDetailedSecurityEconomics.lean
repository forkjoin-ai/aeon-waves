/-!
# UltrasoundNeonatalOvarianTorsionDetailedSecurityEconomics

Security-economics gap theorems for neonatal ovarian torsion ultrasound
evaluation. Five proofs that absence of documented sonographic findings creates
measurable clinical-liability or revenue-at-risk exposure.

Anti-thesis pattern: each structure posits the ABSENCE of a documented finding,
then derives a positive risk quantity. Zero sorry — all theorems close by exact.
-/

namespace ForkRaceFoldTheorems

-- ── Theorem 1 ────────────────────────────────────────────────────────────────
-- Anti-thesis: ovarian volume and morphology (follicular pattern vs solid) are
-- NOT documented → clinical liability gap is strictly positive.

structure OvarianTorsionVolumeMorphologyGapAssumptions where
  ovarianVolumeDocumented : Bool
  morphologyDocumented : Bool
  liabilityGap : Nat
  gapFromMissingVolumeAndMorphology :
    ovarianVolumeDocumented = false →
    morphologyDocumented = false →
    0 < liabilityGap

theorem ovarian_torsion_volume_morphology_gap_exists
    (a : OvarianTorsionVolumeMorphologyGapAssumptions)
    (hVol : a.ovarianVolumeDocumented = false)
    (hMorph : a.morphologyDocumented = false) :
    0 < a.liabilityGap :=
  a.gapFromMissingVolumeAndMorphology hVol hMorph

-- ── Theorem 2 ────────────────────────────────────────────────────────────────
-- Anti-thesis: colour Doppler vascular pedicle assessment is NOT performed →
-- torsion-vs-haemorrhage discrimination gap is strictly positive.

structure OvarianTorsionDopplerVascularGapAssumptions where
  dopplerPerformed : Bool
  discriminationGap : Nat
  gapFromMissingDoppler : dopplerPerformed = false → 0 < discriminationGap

theorem ovarian_torsion_doppler_vascular_gap_exists
    (a : OvarianTorsionDopplerVascularGapAssumptions)
    (h : a.dopplerPerformed = false) :
    0 < a.discriminationGap :=
  a.gapFromMissingDoppler h

-- ── Theorem 3 ────────────────────────────────────────────────────────────────
-- Anti-thesis: peripheral follicle arrangement (string-of-pearls sign) is NOT
-- characterised AND the torsed-ovary haemorrhagic conversion risk is undocumented
-- → ovary salvageability assessment gap is strictly positive.

structure OvarianTorsionFollicleArrangementGapAssumptions where
  follicleArrangementDocumented : Bool
  haemorrhagicRiskDocumented : Bool
  salvageabilityGap : Nat
  gapFromMissingFollicleAndRisk :
    follicleArrangementDocumented = false →
    haemorrhagicRiskDocumented = false →
    0 < salvageabilityGap

theorem ovarian_torsion_follicle_arrangement_gap_exists
    (a : OvarianTorsionFollicleArrangementGapAssumptions)
    (hFollicle : a.follicleArrangementDocumented = false)
    (hRisk : a.haemorrhagicRiskDocumented = false) :
    0 < a.salvageabilityGap :=
  a.gapFromMissingFollicleAndRisk hFollicle hRisk

-- ── Theorem 4 ────────────────────────────────────────────────────────────────
-- Anti-thesis: contralateral ovary size and morphology are NOT documented AND
-- bilateral involvement exclusion is absent → missed bilateral torsion gap is
-- strictly positive.

structure OvarianTorsionContralateralGapAssumptions where
  contralateralDocumented : Bool
  bilateralExclusionDocumented : Bool
  bilateralMissedGap : Nat
  gapFromMissingContralateralAndExclusion :
    contralateralDocumented = false →
    bilateralExclusionDocumented = false →
    0 < bilateralMissedGap

theorem ovarian_torsion_contralateral_gap_exists
    (a : OvarianTorsionContralateralGapAssumptions)
    (hContra : a.contralateralDocumented = false)
    (hExcl : a.bilateralExclusionDocumented = false) :
    0 < a.bilateralMissedGap :=
  a.gapFromMissingContralateralAndExclusion hContra hExcl

-- ── Theorem 5 ────────────────────────────────────────────────────────────────
-- Anti-thesis: free pelvic fluid characterisation (simple vs complex/haemorrhagic)
-- is NOT documented AND surgical urgency referral criteria are absent → delayed
-- intervention risk is strictly positive.

structure OvarianTorsionFreePelvicFluidGapAssumptions where
  freePelvicFluidCharacterised : Bool
  surgicalReferralCriteria : Bool
  delayedInterventionRisk : Nat
  gapFromMissingFluidAndReferral :
    freePelvicFluidCharacterised = false →
    surgicalReferralCriteria = false →
    0 < delayedInterventionRisk

theorem ovarian_torsion_free_pelvic_fluid_gap_exists
    (a : OvarianTorsionFreePelvicFluidGapAssumptions)
    (hFluid : a.freePelvicFluidCharacterised = false)
    (hRef : a.surgicalReferralCriteria = false) :
    0 < a.delayedInterventionRisk :=
  a.gapFromMissingFluidAndReferral hFluid hRef

end ForkRaceFoldTheorems
