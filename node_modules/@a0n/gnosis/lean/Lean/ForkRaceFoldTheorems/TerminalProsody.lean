namespace ForkRaceFoldTheorems
namespace TerminalProsody

/-!
# Terminal prosody pressure

This module gives the decode-time wrap-up rule a finite proof surface. A decode
horizon carries the number of emitted tokens and the maximum token budget. The
wrap pressure rises with emitted tokens. The wrap threshold rises with remaining
tokens. When pressure crosses the Reynolds/Phi threshold, the controller must
start closing the sentence if the tail is open, or choose a stop token if the
tail is already sentence-closed.
-/

/-- Phi scaled by 1000, matching the finite convention used by TLA specs. -/
def phiMilli : Nat := 1618

/-- Classical transitional Reynolds scale, also represented in milli-units. -/
def reynoldsCriticalMilli : Nat := 2300

/-- Finite generation horizon for one decode sequence. -/
structure DecodeHorizon where
  emitted : Nat
  maxTokens : Nat
deriving DecidableEq, Repr

/-- Tokens still available under the hard generation budget. -/
def remaining (horizon : DecodeHorizon) : Nat :=
  horizon.maxTokens - horizon.emitted

/-- The next decode step preserves the max-token budget and emits one token. -/
def successorHorizon (horizon : DecodeHorizon) : DecodeHorizon :=
  {
    emitted := horizon.emitted + 1,
    maxTokens := horizon.maxTokens,
  }

/-- Pressure is present throughout and rises with emitted tokens. -/
def wrapPressure (horizon : DecodeHorizon) : Nat :=
  (horizon.emitted + 1) * reynoldsCriticalMilli

/-- Resistance to wrapping is the Phi-scaled remaining budget. -/
def wrapThreshold (horizon : DecodeHorizon) : Nat :=
  (remaining horizon + 1) * phiMilli

/-- The Reynolds/Phi break: pressure has overcome remaining-budget resistance. -/
def reynoldsPhiBreak (horizon : DecodeHorizon) : Prop :=
  wrapPressure horizon >= wrapThreshold horizon

/-- The finite Reynolds/Phi break predicate is decidable by Nat comparison. -/
instance decidableReynoldsPhiBreak
    (horizon : DecodeHorizon) : Decidable (reynoldsPhiBreak horizon) := by
  unfold reynoldsPhiBreak
  infer_instance

/-- Minimal text-tail state needed by the terminal controller. -/
inductive TailState where
  | openClause
  | sentenceClosed
deriving DecidableEq, Repr

/-- Token roles exposed to the terminal prosody controller. -/
inductive TokenRole where
  | continuation
  | sentenceClose
  | stop
deriving DecidableEq, Repr

/-- High-level action emitted by the terminal controller. -/
inductive WrapDirective where
  | continue
  | chooseSentenceClose
  | chooseStop
deriving DecidableEq, Repr

/-- Observable intervention-stage terminal prosody event. -/
inductive InterventionEvent where
  | noIntervention
  | closeCandidateInjected
  | stopDeferred
  | logitsAdjusted
deriving DecidableEq, Repr

/-- Observable selection-stage terminal prosody event. -/
inductive SelectionEvent where
  | noSelectionOutcome
  | selectionOutcome
deriving DecidableEq, Repr

/-- Candidate-role availability visible to the sampler at a decode step. -/
structure CandidateSet where
  hasSentenceClose : Prop

/-- Evidence produced by one terminal intervention operation. -/
structure InterventionEvidence where
  omittedSentenceClose : Prop
  deferredStop : Prop
  adjustedLogits : Prop

/--
Bias table for the controller. Before the break every role has neutral weight.
After the break, open clauses prefer sentence-close tokens; closed sentences
prefer stop tokens.
-/
def terminalBias
    (horizon : DecodeHorizon)
    (tail : TailState)
    (role : TokenRole) : Nat :=
  if reynoldsPhiBreak horizon then
    match tail, role with
    | TailState.openClause, TokenRole.continuation => 0
    | TailState.openClause, TokenRole.sentenceClose => 3
    | TailState.openClause, TokenRole.stop => 1
    | TailState.sentenceClosed, TokenRole.continuation => 0
    | TailState.sentenceClosed, TokenRole.sentenceClose => 1
    | TailState.sentenceClosed, TokenRole.stop => 3
  else
    1

/-- A sampler score after terminal pressure has added the role-specific bias. -/
def adjustedScore
    (horizon : DecodeHorizon)
    (tail : TailState)
    (role : TokenRole)
    (rawLogit : Nat) : Nat :=
  rawLogit + terminalBias horizon tail role

/-- Controller decision derived from the same break predicate as the bias table. -/
def wrapDirective (horizon : DecodeHorizon) (tail : TailState) : WrapDirective :=
  if reynoldsPhiBreak horizon then
    match tail with
    | TailState.openClause => WrapDirective.chooseSentenceClose
    | TailState.sentenceClosed => WrapDirective.chooseStop
  else
    WrapDirective.continue

/--
Hard close-before-stop gate. Once the break has fired on an open clause, stop
is disallowed whenever the visible candidate set contains a sentence-close
token. This is stronger than merely assigning sentence-close a larger bias.
-/
def stopAllowed
    (horizon : DecodeHorizon)
    (tail : TailState)
    (candidates : CandidateSet) : Prop :=
  if reynoldsPhiBreak horizon then
    match tail with
    | TailState.openClause => Not candidates.hasSentenceClose
    | TailState.sentenceClosed => True
  else
    True

/--
Sampler score after the hard close-before-stop gate. `none` represents an
excluded candidate, matching the runtime `-Infinity` stop logit.
-/
def gatedAdjustedScore
    (horizon : DecodeHorizon)
    (tail : TailState)
    (candidates : CandidateSet)
    (role : TokenRole)
    (rawLogit : Nat)
    [Decidable candidates.hasSentenceClose] : Option Nat :=
  if reynoldsPhiBreak horizon then
    match tail, role with
    | TailState.openClause, TokenRole.stop =>
        if candidates.hasSentenceClose then
          none
        else
          some (adjustedScore horizon tail role rawLogit)
    | _, _ =>
        some (adjustedScore horizon tail role rawLogit)
  else
    some (adjustedScore horizon tail role rawLogit)

/--
Classify a single intervention operation. Projection injection, stop deferral,
and ordinary logit adjustment are distinct operation stages; if a caller has
multiple stages, it classifies each stage separately.
-/
def interventionEvent
    (horizon : DecodeHorizon)
    (evidence : InterventionEvidence)
    [Decidable evidence.omittedSentenceClose]
    [Decidable evidence.deferredStop]
    [Decidable evidence.adjustedLogits] : InterventionEvent :=
  if reynoldsPhiBreak horizon then
    if evidence.omittedSentenceClose then
      InterventionEvent.closeCandidateInjected
    else if evidence.deferredStop then
      InterventionEvent.stopDeferred
    else if evidence.adjustedLogits then
      InterventionEvent.logitsAdjusted
    else
      InterventionEvent.noIntervention
  else
    InterventionEvent.noIntervention

/-- Selection-stage telemetry is emitted exactly after the pressure break. -/
def selectionEvent (horizon : DecodeHorizon) : SelectionEvent :=
  if reynoldsPhiBreak horizon then
    SelectionEvent.selectionOutcome
  else
    SelectionEvent.noSelectionOutcome

/-- Pressure fields carried by terminal telemetry for one decode step. -/
structure PressureTrace where
  emitted : Nat
  maxTokens : Nat
  remainingTokens : Nat
  pressure : Nat
  threshold : Nat
  directive : WrapDirective
deriving DecidableEq, Repr

/-- Shared pressure snapshot for all terminal telemetry emitted at one step. -/
def pressureTrace (horizon : DecodeHorizon) (tail : TailState) : PressureTrace :=
  {
    emitted := horizon.emitted,
    maxTokens := horizon.maxTokens,
    remainingTokens := remaining horizon,
    pressure := wrapPressure horizon,
    threshold := wrapThreshold horizon,
    directive := wrapDirective horizon tail,
  }

/-!
## Rust runtime alignment

`open-source/gnosis/distributed-inference/src/terminal_prosody.rs` carries the
same pressure model for the native fat-station `/generate` path. These
definitions mirror the Rust field names and less-than branch shape, then prove
they fold back to the canonical finite model above.
-/

/-- Rust `terminal_remaining_tokens(emitted_tokens, max_tokens)`. -/
def rustRemainingTokens (emittedTokens maxTokens : Nat) : Nat :=
  maxTokens - emittedTokens

/-- Rust `terminal_wrap_pressure(emitted_tokens)`. -/
def rustWrapPressure (emittedTokens : Nat) : Nat :=
  (emittedTokens + 1) * reynoldsCriticalMilli

/-- Rust `terminal_wrap_threshold(emitted_tokens, max_tokens)`. -/
def rustWrapThreshold (emittedTokens maxTokens : Nat) : Nat :=
  (rustRemainingTokens emittedTokens maxTokens + 1) * phiMilli

/--
Rust `terminal_wrap_directive` branches on `pressure < threshold`; the canonical
Lean directive branches on `pressure >= threshold`. These are complements over
natural numbers.
-/
def rustWrapDirective
    (emittedTokens maxTokens : Nat)
    (tail : TailState) : WrapDirective :=
  if rustWrapPressure emittedTokens <
      rustWrapThreshold emittedTokens maxTokens then
    WrapDirective.continue
  else
    match tail with
    | TailState.openClause => WrapDirective.chooseSentenceClose
    | TailState.sentenceClosed => WrapDirective.chooseStop

/-- Rust `TerminalProsodyPressure`, omitting only the floating `ratio` field. -/
structure RustPressureTrace where
  emittedTokens : Nat
  maxTokens : Nat
  remainingTokens : Nat
  pressure : Nat
  threshold : Nat
  crossedBreak : Bool
  directive : WrapDirective
deriving DecidableEq, Repr

/-- Rust `measure_terminal_prosody`, represented in the finite Nat model. -/
def rustPressureTrace
    (emittedTokens maxTokens : Nat)
    (tail : TailState) : RustPressureTrace :=
  {
    emittedTokens := emittedTokens,
    maxTokens := maxTokens,
    remainingTokens := rustRemainingTokens emittedTokens maxTokens,
    pressure := rustWrapPressure emittedTokens,
    threshold := rustWrapThreshold emittedTokens maxTokens,
    crossedBreak :=
      decide (rustWrapPressure emittedTokens >=
        rustWrapThreshold emittedTokens maxTokens),
    directive := rustWrapDirective emittedTokens maxTokens tail,
  }

/-- Telemetry emitted by an intervention-stage operation. -/
structure InterventionTelemetry where
  trace : PressureTrace
  event : InterventionEvent
deriving DecidableEq, Repr

/-- Telemetry emitted by the selection stage. -/
structure SelectionTelemetry where
  trace : PressureTrace
  event : SelectionEvent
deriving DecidableEq, Repr

/-- Build intervention telemetry with the shared step pressure snapshot. -/
def interventionTelemetry
    (horizon : DecodeHorizon)
    (tail : TailState)
    (evidence : InterventionEvidence)
    [Decidable evidence.omittedSentenceClose]
    [Decidable evidence.deferredStop]
    [Decidable evidence.adjustedLogits] : InterventionTelemetry :=
  {
    trace := pressureTrace horizon tail,
    event := interventionEvent horizon evidence,
  }

/-- Build selection telemetry with the shared step pressure snapshot. -/
def selectionTelemetry
    (horizon : DecodeHorizon)
    (tail : TailState) : SelectionTelemetry :=
  {
    trace := pressureTrace horizon tail,
    event := selectionEvent horizon,
  }

/-- Whether a selected role is legal under the current stop gate. -/
def legalSelectedRole
    (horizon : DecodeHorizon)
    (tail : TailState)
    (candidates : CandidateSet)
    (selected : TokenRole) : Prop :=
  match selected with
  | TokenRole.stop => stopAllowed horizon tail candidates
  | TokenRole.continuation => True
  | TokenRole.sentenceClose => True

/-- Tail transition induced by the selected token role. -/
def nextTailState (tail : TailState) (selected : TokenRole) : TailState :=
  match tail, selected with
  | TailState.openClause, TokenRole.sentenceClose => TailState.sentenceClosed
  | _, _ => tail

/--
Finite role-logit surface for proving selector behavior without modeling
arbitrary tokenizer ids or floating-point vectors. This is the order-level
counterpart of Rust `select_terminal_token`: classify token ids into roles,
gate disallowed roles, then choose a maximal surviving adjusted score.
-/
structure RoleLogits where
  continuation : Nat
  sentenceClose : Nat
  stop : Nat
deriving DecidableEq, Repr

/-- Read the raw logit assigned to a role in the finite selector model. -/
def roleRawLogit (logits : RoleLogits) (role : TokenRole) : Nat :=
  match role with
  | TokenRole.continuation => logits.continuation
  | TokenRole.sentenceClose => logits.sentenceClose
  | TokenRole.stop => logits.stop

/-- Adjusted role score after mapping the finite role-logit surface into the controller. -/
def roleAdjustedScore
    (horizon : DecodeHorizon)
    (tail : TailState)
    (logits : RoleLogits)
    (role : TokenRole) : Nat :=
  adjustedScore horizon tail role (roleRawLogit logits role)

/--
Rust-style selection over Lean's gated score surface. A role is selectable iff
its gated score exists and no other role with a gated score is larger.
-/
def selectableByGatedScore
    (horizon : DecodeHorizon)
    (tail : TailState)
    (candidates : CandidateSet)
    (logits : RoleLogits)
    (selected : TokenRole)
    [Decidable candidates.hasSentenceClose] : Prop :=
  Exists fun selectedScore =>
    gatedAdjustedScore horizon tail candidates selected
        (roleRawLogit logits selected) = some selectedScore ∧
      ∀ role score,
        gatedAdjustedScore horizon tail candidates role
            (roleRawLogit logits role) = some score ->
          score <= selectedScore

/--
Default Rust stop-deferral condition: the pressure directive is
`chooseSentenceClose` and a sentence-close candidate is visible.
-/
def rustDefaultStopDeferred
    (emittedTokens maxTokens : Nat)
    (tail : TailState)
    (candidates : CandidateSet) : Prop :=
  rustWrapDirective emittedTokens maxTokens tail =
      WrapDirective.chooseSentenceClose ∧
    candidates.hasSentenceClose

/--
Rust `classify_terminal_token`, with stop-token precedence matching the native
implementation when a tokenizer id appears in both configured sets.
-/
def classifyTokenId
    (sentenceCloseToken stopToken : Nat -> Bool)
    (tokenId : Nat) : TokenRole :=
  if stopToken tokenId then
    TokenRole.stop
  else if sentenceCloseToken tokenId then
    TokenRole.sentenceClose
  else
    TokenRole.continuation

/-- A finite concrete tokenizer candidate visible to the Rust selector. -/
structure ConcreteTokenCandidate where
  tokenId : Nat
  role : TokenRole
  rawLogit : Nat
deriving DecidableEq, Repr

/-- Build a concrete candidate by classifying its tokenizer id. -/
def concreteCandidateFromTokenId
    (sentenceCloseToken stopToken : Nat -> Bool)
    (tokenId rawLogit : Nat) : ConcreteTokenCandidate :=
  {
    tokenId := tokenId,
    role := classifyTokenId sentenceCloseToken stopToken tokenId,
    rawLogit := rawLogit,
  }

/--
Concrete Rust-style selection over finite token-id candidates. The selected
candidate must survive the gate and dominate every surviving concrete
candidate.
-/
def concreteSelectableByGatedScore
    (horizon : DecodeHorizon)
    (tail : TailState)
    (candidates : CandidateSet)
    (tokens : List ConcreteTokenCandidate)
    (selected : ConcreteTokenCandidate)
    [Decidable candidates.hasSentenceClose] : Prop :=
  selected ∈ tokens ∧
    Exists fun selectedScore =>
      gatedAdjustedScore horizon tail candidates selected.role
          selected.rawLogit = some selectedScore ∧
        ∀ token score,
          token ∈ tokens ->
          gatedAdjustedScore horizon tail candidates token.role
              token.rawLogit = some score ->
            score <= selectedScore

/-- Concrete visible sentence-close candidates are classified by role, not only set membership. -/
def concreteHasSentenceCloseCandidate
    (tokens : List ConcreteTokenCandidate) : Prop :=
  ∃ token, token ∈ tokens ∧ token.role = TokenRole.sentenceClose

/-- Concrete visible stop candidates are classified by role, not only set membership. -/
def concreteHasStopCandidate
    (tokens : List ConcreteTokenCandidate) : Prop :=
  ∃ token, token ∈ tokens ∧ token.role = TokenRole.stop

/--
A concrete stop token that is maximal over every surviving concrete candidate
under the gated score surface.
-/
def concreteStopMaximalByGatedScore
    (horizon : DecodeHorizon)
    (tail : TailState)
    (candidates : CandidateSet)
    (tokens : List ConcreteTokenCandidate)
    (selected : ConcreteTokenCandidate)
    [Decidable candidates.hasSentenceClose] : Prop :=
  selected ∈ tokens ∧
    selected.role = TokenRole.stop ∧
    Exists fun selectedScore =>
      gatedAdjustedScore horizon tail candidates selected.role
          selected.rawLogit = some selectedScore ∧
        ∀ token score,
          token ∈ tokens ->
          gatedAdjustedScore horizon tail candidates token.role
              token.rawLogit = some score ->
            score <= selectedScore

/-- Bridge from concrete classified candidates to the abstract candidate-set predicate. -/
def candidateSetMatchesConcreteCandidates
    (candidates : CandidateSet)
    (tokens : List ConcreteTokenCandidate) : Prop :=
  candidates.hasSentenceClose ↔ concreteHasSentenceCloseCandidate tokens

/--
The role-logit projection is covered by concrete token-id candidates: each
role score in `RoleLogits` is witnessed by at least one concrete token.
-/
def roleLogitsCoveredByConcreteCandidates
    (tokens : List ConcreteTokenCandidate)
    (logits : RoleLogits) : Prop :=
  ∀ role,
    ∃ token,
      token ∈ tokens ∧
        token.role = role ∧
        token.rawLogit = roleRawLogit logits role

/--
Runtime-facing certificate for the terminal telemetry story: an open-tail
selection emits a post-break selection outcome that closes the sentence, and
the successor closed-tail selection emits another selection outcome whose
concrete stop-maximal candidate is visible, legal, selectable, and terminating.
-/
structure OpenThenStopSelectionCertificate
    (horizon : DecodeHorizon)
    (closeCandidates stopCandidates : CandidateSet)
    (openTokens stopTokens : List ConcreteTokenCandidate)
    (openSelected stopSelected : ConcreteTokenCandidate)
    [Decidable closeCandidates.hasSentenceClose]
    [Decidable stopCandidates.hasSentenceClose] : Prop where
  openSelectionEvent :
    (selectionTelemetry horizon TailState.openClause).event =
      SelectionEvent.selectionOutcome
  openDirective :
    (selectionTelemetry horizon TailState.openClause).trace.directive =
      WrapDirective.chooseSentenceClose
  openCloses :
    nextTailState TailState.openClause openSelected.role =
      TailState.sentenceClosed
  successorBreak : reynoldsPhiBreak (successorHorizon horizon)
  closedSelectionEvent :
    (selectionTelemetry (successorHorizon horizon)
      TailState.sentenceClosed).event = SelectionEvent.selectionOutcome
  closedDirective :
    (selectionTelemetry (successorHorizon horizon)
      TailState.sentenceClosed).trace.directive =
        WrapDirective.chooseStop
  stopVisible : concreteHasStopCandidate stopTokens
  stopSelectable :
    concreteSelectableByGatedScore (successorHorizon horizon)
      TailState.sentenceClosed stopCandidates stopTokens stopSelected
  stopLegal :
    legalSelectedRole (successorHorizon horizon) TailState.sentenceClosed
      stopCandidates stopSelected.role
  stopScoreKept :
    gatedAdjustedScore (successorHorizon horizon) TailState.sentenceClosed
      stopCandidates TokenRole.stop stopSelected.rawLogit =
        some (adjustedScore (successorHorizon horizon)
          TailState.sentenceClosed TokenRole.stop stopSelected.rawLogit)
  stopKeepsTailClosed :
    nextTailState TailState.sentenceClosed stopSelected.role =
      TailState.sentenceClosed
  stopRole : stopSelected.role = TokenRole.stop
  stopAllowed :
    stopAllowed (successorHorizon horizon) TailState.sentenceClosed
      stopCandidates

/-- Wrap pressure is positive from the first decode step. -/
theorem wrap_pressure_positive (horizon : DecodeHorizon) :
    0 < wrapPressure horizon := by
  unfold wrapPressure reynoldsCriticalMilli
  exact Nat.mul_pos (Nat.succ_pos horizon.emitted) (by decide)

/-- Emitting more tokens never lowers wrap pressure. -/
theorem wrap_pressure_monotone
    {earlier later maxTokens : Nat}
    (hStep : earlier <= later) :
    wrapPressure { emitted := earlier, maxTokens := maxTokens } <=
      wrapPressure { emitted := later, maxTokens := maxTokens } := by
  unfold wrapPressure
  exact Nat.mul_le_mul_right reynoldsCriticalMilli (Nat.succ_le_succ hStep)

/-- The next decode step cannot raise the wrap threshold. -/
theorem wrap_threshold_successor_le (horizon : DecodeHorizon) :
    wrapThreshold (successorHorizon horizon) <= wrapThreshold horizon := by
  unfold wrapThreshold remaining successorHorizon
  have hRemaining :
      horizon.maxTokens - (horizon.emitted + 1) <=
        horizon.maxTokens - horizon.emitted := by
    exact Nat.sub_le_sub_left (Nat.le_succ horizon.emitted) horizon.maxTokens
  exact Nat.mul_le_mul_right phiMilli (Nat.succ_le_succ hRemaining)

/-- Once the Reynolds/Phi break has fired, the next decode horizon stays past it. -/
theorem reynolds_phi_break_successor
    {horizon : DecodeHorizon}
    (hBreak : reynoldsPhiBreak horizon) :
    reynoldsPhiBreak (successorHorizon horizon) := by
  unfold reynoldsPhiBreak at hBreak ⊢
  have hPressure :
      wrapPressure horizon <= wrapPressure (successorHorizon horizon) := by
    cases horizon with
    | mk emitted maxTokens =>
        unfold successorHorizon
        exact wrap_pressure_monotone
          (earlier := emitted)
          (later := emitted + 1)
          (maxTokens := maxTokens)
          (Nat.le_succ emitted)
  exact Nat.le_trans (wrap_threshold_successor_le horizon)
    (Nat.le_trans hBreak hPressure)

/-- At the hard final token, the Reynolds/Phi break has necessarily occurred. -/
theorem final_token_crosses_reynolds_phi (maxTokens : Nat) :
    reynoldsPhiBreak { emitted := maxTokens, maxTokens := maxTokens } := by
  unfold reynoldsPhiBreak wrapPressure wrapThreshold remaining
  unfold phiMilli reynoldsCriticalMilli
  simp
  have hPhiBelowReynolds : 1618 <= 1 * 2300 := by decide
  have hOneLe : 1 <= maxTokens + 1 :=
    Nat.succ_le_succ (Nat.zero_le maxTokens)
  have hReynoldsScales : 1 * 2300 <= (maxTokens + 1) * 2300 :=
    Nat.mul_le_mul_right 2300 hOneLe
  exact Nat.le_trans hPhiBelowReynolds hReynoldsScales

/-- Crossing the break starts wrap-up instead of neutral continuation. -/
theorem reynolds_phi_break_starts_wrap
    {horizon : DecodeHorizon}
    {tail : TailState}
    (hBreak : reynoldsPhiBreak horizon) :
    Not (wrapDirective horizon tail = WrapDirective.continue) := by
  unfold wrapDirective
  rw [if_pos hBreak]
  cases tail <;> simp

/-- At the break, an open clause prefers a sentence-close token. -/
theorem open_break_prefers_sentence_close
    {horizon : DecodeHorizon}
    (hBreak : reynoldsPhiBreak horizon) :
  terminalBias horizon TailState.openClause TokenRole.continuation <
      terminalBias horizon TailState.openClause TokenRole.sentenceClose := by
  unfold terminalBias
  rw [if_pos hBreak]
  rw [if_pos hBreak]
  simp

/--
At the break, terminal pressure can flip a narrow baseline stop winner into an
adjusted sentence-close winner. This is the formal counterpart of runtime
`selection-outcome.argmaxChanged` when both candidates are visible.
-/
theorem open_break_argmax_flips_stop_to_sentence_close
    {horizon : DecodeHorizon}
    (hBreak : reynoldsPhiBreak horizon)
    {sentenceCloseLogit stopLogit : Nat}
    (hBaselineStopWins : sentenceCloseLogit < stopLogit)
    (hStopWithinCloseBiasWindow : stopLogit < sentenceCloseLogit + 2) :
    sentenceCloseLogit < stopLogit ∧
      adjustedScore horizon TailState.openClause TokenRole.stop stopLogit <
        adjustedScore horizon TailState.openClause TokenRole.sentenceClose
          sentenceCloseLogit := by
  constructor
  · exact hBaselineStopWins
  · unfold adjustedScore terminalBias
    rw [if_pos hBreak]
    rw [if_pos hBreak]
    exact Nat.add_lt_add_right hStopWithinCloseBiasWindow 1

/--
At the break, a visible sentence-close candidate removes stop from the sampler
surface for an open clause, rather than merely lowering its score.
-/
theorem open_break_close_candidate_gates_stop_score
    {horizon : DecodeHorizon}
    {candidates : CandidateSet}
    [Decidable candidates.hasSentenceClose]
    (hBreak : reynoldsPhiBreak horizon)
    (hClose : candidates.hasSentenceClose)
    (stopLogit : Nat) :
    gatedAdjustedScore horizon TailState.openClause candidates
      TokenRole.stop stopLogit = none := by
  unfold gatedAdjustedScore
  rw [if_pos hBreak]
  rw [if_pos hClose]

/-- The hard stop gate does not remove the sentence-close candidate itself. -/
theorem open_break_close_candidate_keeps_sentence_close_score
    {horizon : DecodeHorizon}
    {candidates : CandidateSet}
    [Decidable candidates.hasSentenceClose]
    (sentenceCloseLogit : Nat) :
    gatedAdjustedScore horizon TailState.openClause candidates
      TokenRole.sentenceClose sentenceCloseLogit =
        some (adjustedScore horizon TailState.openClause
          TokenRole.sentenceClose sentenceCloseLogit) := by
  unfold gatedAdjustedScore
  by_cases hBreak : reynoldsPhiBreak horizon
  · rw [if_pos hBreak]
  · rw [if_neg hBreak]

/-- At the break, an open clause directs the sampler toward sentence closure. -/
theorem open_break_directs_sentence_close
    {horizon : DecodeHorizon}
    (hBreak : reynoldsPhiBreak horizon) :
  wrapDirective horizon TailState.openClause =
      WrapDirective.chooseSentenceClose := by
  unfold wrapDirective
  rw [if_pos hBreak]

/-- At the break, an open clause with a close candidate cannot choose stop. -/
theorem open_break_with_close_candidate_blocks_stop
    {horizon : DecodeHorizon}
    {candidates : CandidateSet}
    (hBreak : reynoldsPhiBreak horizon)
    (hClose : candidates.hasSentenceClose) :
    Not (stopAllowed horizon TailState.openClause candidates) := by
  unfold stopAllowed
  rw [if_pos hBreak]
  simp [hClose]

/-- At the break, a sentence-closed tail prefers a stop token. -/
theorem closed_break_prefers_stop
    {horizon : DecodeHorizon}
    (hBreak : reynoldsPhiBreak horizon) :
  terminalBias horizon TailState.sentenceClosed TokenRole.continuation <
      terminalBias horizon TailState.sentenceClosed TokenRole.stop := by
  unfold terminalBias
  rw [if_pos hBreak]
  rw [if_pos hBreak]
  simp

/--
At the break, terminal pressure can flip a narrow baseline sentence-close
winner into an adjusted stop winner once the tail is already sentence-closed.
-/
theorem closed_break_argmax_flips_sentence_close_to_stop
    {horizon : DecodeHorizon}
    (hBreak : reynoldsPhiBreak horizon)
    {sentenceCloseLogit stopLogit : Nat}
    (hBaselineCloseWins : stopLogit < sentenceCloseLogit)
    (hCloseWithinStopBiasWindow : sentenceCloseLogit < stopLogit + 2) :
    stopLogit < sentenceCloseLogit ∧
      adjustedScore horizon TailState.sentenceClosed TokenRole.sentenceClose
          sentenceCloseLogit <
        adjustedScore horizon TailState.sentenceClosed TokenRole.stop
          stopLogit := by
  constructor
  · exact hBaselineCloseWins
  · unfold adjustedScore terminalBias
    rw [if_pos hBreak]
    rw [if_pos hBreak]
    exact Nat.add_lt_add_right hCloseWithinStopBiasWindow 1

/-- At the break, a sentence-closed tail directs the sampler toward stop. -/
theorem closed_break_directs_stop
    {horizon : DecodeHorizon}
    (hBreak : reynoldsPhiBreak horizon) :
  wrapDirective horizon TailState.sentenceClosed = WrapDirective.chooseStop := by
  unfold wrapDirective
  rw [if_pos hBreak]

/-- At the break, a sentence-closed tail allows stop. -/
theorem closed_break_allows_stop
    {horizon : DecodeHorizon}
    {candidates : CandidateSet}
    (hBreak : reynoldsPhiBreak horizon) :
    stopAllowed horizon TailState.sentenceClosed candidates := by
  unfold stopAllowed
  rw [if_pos hBreak]
  simp

/-- A sentence-closed tail keeps stop selectable after the break. -/
theorem closed_break_keeps_stop_score
    {horizon : DecodeHorizon}
    {candidates : CandidateSet}
    [Decidable candidates.hasSentenceClose]
    (hBreak : reynoldsPhiBreak horizon)
    (stopLogit : Nat) :
    gatedAdjustedScore horizon TailState.sentenceClosed candidates
      TokenRole.stop stopLogit =
        some (adjustedScore horizon TailState.sentenceClosed
          TokenRole.stop stopLogit) := by
  unfold gatedAdjustedScore
  rw [if_pos hBreak]

/-- The gate never removes continuation from the finite selector surface. -/
theorem gated_score_keeps_continuation_role
    {horizon : DecodeHorizon}
    {tail : TailState}
    {candidates : CandidateSet}
    {logits : RoleLogits}
    [Decidable candidates.hasSentenceClose] :
    gatedAdjustedScore horizon tail candidates TokenRole.continuation
      (roleRawLogit logits TokenRole.continuation) =
        some (roleAdjustedScore horizon tail logits TokenRole.continuation) := by
  unfold gatedAdjustedScore roleAdjustedScore
  by_cases hBreak : reynoldsPhiBreak horizon
  · rw [if_pos hBreak]
    cases tail <;> rfl
  · rw [if_neg hBreak]

/-- The gate never removes sentence-close from the finite selector surface. -/
theorem gated_score_keeps_sentence_close_role
    {horizon : DecodeHorizon}
    {tail : TailState}
    {candidates : CandidateSet}
    {logits : RoleLogits}
    [Decidable candidates.hasSentenceClose] :
    gatedAdjustedScore horizon tail candidates TokenRole.sentenceClose
      (roleRawLogit logits TokenRole.sentenceClose) =
        some (roleAdjustedScore horizon tail logits TokenRole.sentenceClose) := by
  unfold gatedAdjustedScore roleAdjustedScore
  by_cases hBreak : reynoldsPhiBreak horizon
  · rw [if_pos hBreak]
    cases tail <;> rfl
  · rw [if_neg hBreak]

/-- Before the break, Rust-style gated selection is just ordinary adjusted selection. -/
theorem pre_break_gated_score_keeps_selected_role
    {horizon : DecodeHorizon}
    {tail : TailState}
    {candidates : CandidateSet}
    {selected : TokenRole}
    [Decidable candidates.hasSentenceClose]
    (hNoBreak : Not (reynoldsPhiBreak horizon))
    (rawLogit : Nat) :
    gatedAdjustedScore horizon tail candidates selected
      rawLogit = some (adjustedScore horizon tail selected rawLogit) := by
  unfold gatedAdjustedScore
  rw [if_neg hNoBreak]

/--
If Rust-style selection chooses a role by Lean's gated score surface, that role
is legal under the hard stop gate.
-/
theorem rust_select_terminal_token_matches_gated_score
    {horizon : DecodeHorizon}
    {tail : TailState}
    {candidates : CandidateSet}
    {logits : RoleLogits}
    {selected : TokenRole}
    [Decidable candidates.hasSentenceClose]
    (hSelected : selectableByGatedScore horizon tail candidates logits selected) :
    legalSelectedRole horizon tail candidates selected := by
  rcases hSelected with ⟨selectedScore, hSome, _hMax⟩
  cases selected with
  | continuation =>
      unfold legalSelectedRole
      trivial
  | sentenceClose =>
      unfold legalSelectedRole
      trivial
  | stop =>
      unfold legalSelectedRole stopAllowed
      by_cases hBreak : reynoldsPhiBreak horizon
      · rw [if_pos hBreak]
        cases tail with
        | openClause =>
            by_cases hClose : candidates.hasSentenceClose
            · have hNone :
                gatedAdjustedScore horizon TailState.openClause candidates
                  TokenRole.stop (roleRawLogit logits TokenRole.stop) = none :=
                open_break_close_candidate_gates_stop_score
                  hBreak hClose (roleRawLogit logits TokenRole.stop)
              rw [hNone] at hSome
              cases hSome
            · exact hClose
        | sentenceClosed =>
            trivial
      · rw [if_neg hBreak]
        trivial

/-- At an open-tail break with a visible close candidate, Rust-style selection cannot choose stop. -/
theorem open_break_visible_close_gated_selection_not_stop
    {horizon : DecodeHorizon}
    {candidates : CandidateSet}
    {logits : RoleLogits}
    [Decidable candidates.hasSentenceClose]
    (hBreak : reynoldsPhiBreak horizon)
    (hClose : candidates.hasSentenceClose) :
    Not (selectableByGatedScore horizon TailState.openClause candidates
      logits TokenRole.stop) := by
  intro hSelected
  rcases hSelected with ⟨selectedScore, hSome, _hMax⟩
  have hNone :
      gatedAdjustedScore horizon TailState.openClause candidates TokenRole.stop
        (roleRawLogit logits TokenRole.stop) = none :=
    open_break_close_candidate_gates_stop_score
      hBreak hClose (roleRawLogit logits TokenRole.stop)
  rw [hNone] at hSome
  cases hSome

/-- At an open-tail break without a visible close candidate, the Rust gate leaves stop scored. -/
theorem open_break_without_close_candidate_keeps_stop_score
    {horizon : DecodeHorizon}
    {candidates : CandidateSet}
    [Decidable candidates.hasSentenceClose]
    (hBreak : reynoldsPhiBreak horizon)
    (hNoClose : Not candidates.hasSentenceClose)
    (stopLogit : Nat) :
    gatedAdjustedScore horizon TailState.openClause candidates
      TokenRole.stop stopLogit =
        some (adjustedScore horizon TailState.openClause
          TokenRole.stop stopLogit) := by
  unfold gatedAdjustedScore
  rw [if_pos hBreak]
  rw [if_neg hNoClose]

/--
The finite Rust-style selector is total: because continuation and
sentence-close are never removed, at least one maximal surviving role always
exists even when the stop role is gated out.
-/
theorem selectable_by_gated_score_exists
    (horizon : DecodeHorizon)
    (tail : TailState)
    (candidates : CandidateSet)
    (logits : RoleLogits)
    [Decidable candidates.hasSentenceClose] :
    ∃ selected, selectableByGatedScore horizon tail candidates logits selected := by
  let continuationScore :=
    roleAdjustedScore horizon tail logits TokenRole.continuation
  let closeScore :=
    roleAdjustedScore horizon tail logits TokenRole.sentenceClose
  have hContinuation :
      gatedAdjustedScore horizon tail candidates TokenRole.continuation
        (roleRawLogit logits TokenRole.continuation) =
          some continuationScore := by
    dsimp [continuationScore]
    exact gated_score_keeps_continuation_role
  have hClose :
      gatedAdjustedScore horizon tail candidates TokenRole.sentenceClose
        (roleRawLogit logits TokenRole.sentenceClose) =
          some closeScore := by
    dsimp [closeScore]
    exact gated_score_keeps_sentence_close_role
  cases hStop :
      gatedAdjustedScore horizon tail candidates TokenRole.stop
        (roleRawLogit logits TokenRole.stop) with
  | none =>
      by_cases hContinuationClose : continuationScore <= closeScore
      · refine ⟨TokenRole.sentenceClose, closeScore, hClose, ?_⟩
        intro role score hRole
        cases role with
        | continuation =>
            rw [hContinuation] at hRole
            cases hRole
            exact hContinuationClose
        | sentenceClose =>
            rw [hClose] at hRole
            cases hRole
            exact Nat.le_refl closeScore
        | stop =>
            rw [hStop] at hRole
            cases hRole
      · have hCloseContinuation : closeScore <= continuationScore :=
          Nat.le_of_lt (Nat.lt_of_not_le hContinuationClose)
        refine ⟨TokenRole.continuation, continuationScore, hContinuation, ?_⟩
        intro role score hRole
        cases role with
        | continuation =>
            rw [hContinuation] at hRole
            cases hRole
            exact Nat.le_refl continuationScore
        | sentenceClose =>
            rw [hClose] at hRole
            cases hRole
            exact hCloseContinuation
        | stop =>
            rw [hStop] at hRole
            cases hRole
  | some stopScore =>
      by_cases hContinuationClose : continuationScore <= closeScore
      · by_cases hCloseStop : closeScore <= stopScore
        · refine ⟨TokenRole.stop, stopScore, hStop, ?_⟩
          intro role score hRole
          cases role with
          | continuation =>
              rw [hContinuation] at hRole
              cases hRole
              exact Nat.le_trans hContinuationClose hCloseStop
          | sentenceClose =>
              rw [hClose] at hRole
              cases hRole
              exact hCloseStop
          | stop =>
              rw [hStop] at hRole
              cases hRole
              exact Nat.le_refl stopScore
        · have hStopClose : stopScore <= closeScore :=
            Nat.le_of_lt (Nat.lt_of_not_le hCloseStop)
          refine ⟨TokenRole.sentenceClose, closeScore, hClose, ?_⟩
          intro role score hRole
          cases role with
          | continuation =>
              rw [hContinuation] at hRole
              cases hRole
              exact hContinuationClose
          | sentenceClose =>
              rw [hClose] at hRole
              cases hRole
              exact Nat.le_refl closeScore
          | stop =>
              rw [hStop] at hRole
              cases hRole
              exact hStopClose
      · have hCloseContinuation : closeScore <= continuationScore :=
          Nat.le_of_lt (Nat.lt_of_not_le hContinuationClose)
        by_cases hContinuationStop : continuationScore <= stopScore
        · refine ⟨TokenRole.stop, stopScore, hStop, ?_⟩
          intro role score hRole
          cases role with
          | continuation =>
              rw [hContinuation] at hRole
              cases hRole
              exact hContinuationStop
          | sentenceClose =>
              rw [hClose] at hRole
              cases hRole
              exact Nat.le_trans hCloseContinuation hContinuationStop
          | stop =>
              rw [hStop] at hRole
              cases hRole
              exact Nat.le_refl stopScore
        · have hStopContinuation : stopScore <= continuationScore :=
            Nat.le_of_lt (Nat.lt_of_not_le hContinuationStop)
          refine ⟨TokenRole.continuation, continuationScore, hContinuation, ?_⟩
          intro role score hRole
          cases role with
          | continuation =>
              rw [hContinuation] at hRole
              cases hRole
              exact Nat.le_refl continuationScore
          | sentenceClose =>
              rw [hClose] at hRole
              cases hRole
              exact hCloseContinuation
          | stop =>
              rw [hStop] at hRole
              cases hRole
              exact hStopContinuation

/-- Stop-token membership has precedence over sentence-close membership. -/
theorem classify_token_id_stop_precedes_sentence_close
    {sentenceCloseToken stopToken : Nat -> Bool}
    {tokenId : Nat}
    (hStop : stopToken tokenId = true) :
    classifyTokenId sentenceCloseToken stopToken tokenId = TokenRole.stop := by
  simp [classifyTokenId, hStop]

/-- Without stop membership, sentence-close membership classifies the token. -/
theorem classify_token_id_sentence_close_without_stop
    {sentenceCloseToken stopToken : Nat -> Bool}
    {tokenId : Nat}
    (hNoStop : stopToken tokenId = false)
    (hClose : sentenceCloseToken tokenId = true) :
    classifyTokenId sentenceCloseToken stopToken tokenId =
      TokenRole.sentenceClose := by
  simp [classifyTokenId, hNoStop, hClose]

/-- Tokens in neither configured set classify as ordinary continuation. -/
theorem classify_token_id_continuation_without_terminal_membership
    {sentenceCloseToken stopToken : Nat -> Bool}
    {tokenId : Nat}
    (hNoStop : stopToken tokenId = false)
    (hNoClose : sentenceCloseToken tokenId = false) :
    classifyTokenId sentenceCloseToken stopToken tokenId =
      TokenRole.continuation := by
  simp [classifyTokenId, hNoStop, hNoClose]

/-- Candidate construction preserves the Rust token-id classifier. -/
theorem concrete_candidate_from_token_id_role
    (sentenceCloseToken stopToken : Nat -> Bool)
    (tokenId rawLogit : Nat) :
    (concreteCandidateFromTokenId sentenceCloseToken stopToken
      tokenId rawLogit).role =
        classifyTokenId sentenceCloseToken stopToken tokenId := by
  rfl

/--
A token id present in both terminal sets is a stop candidate, not a visible
sentence-close candidate. This matches Rust stop-token precedence.
-/
theorem concrete_candidate_from_overlapping_terminal_sets_is_stop
    {sentenceCloseToken stopToken : Nat -> Bool}
    {tokenId rawLogit : Nat}
    (hStop : stopToken tokenId = true) :
    (concreteCandidateFromTokenId sentenceCloseToken stopToken
      tokenId rawLogit).role = TokenRole.stop := by
  rw [concrete_candidate_from_token_id_role]
  exact classify_token_id_stop_precedes_sentence_close hStop

/-- A matched abstract candidate set exposes the concrete close-candidate witness. -/
theorem matched_candidate_set_has_concrete_sentence_close
    {candidates : CandidateSet}
    {tokens : List ConcreteTokenCandidate}
    (hMatches :
      candidateSetMatchesConcreteCandidates candidates tokens)
    (hClose : candidates.hasSentenceClose) :
    concreteHasSentenceCloseCandidate tokens :=
  hMatches.mp hClose

/-- Without a classified concrete close candidate, the matched abstract predicate is false. -/
theorem matched_candidate_set_without_concrete_sentence_close
    {candidates : CandidateSet}
    {tokens : List ConcreteTokenCandidate}
    (hMatches :
      candidateSetMatchesConcreteCandidates candidates tokens)
    (hNoConcreteClose : Not (concreteHasSentenceCloseCandidate tokens)) :
    Not candidates.hasSentenceClose := by
  intro hClose
  exact hNoConcreteClose
    (matched_candidate_set_has_concrete_sentence_close hMatches hClose)

/--
Rust stop deferral against a matched candidate set implies that an actually
classified sentence-close token candidate is visible.
-/
theorem rust_default_stop_deferred_has_concrete_sentence_close
    {emittedTokens maxTokens : Nat}
    {tail : TailState}
    {candidates : CandidateSet}
    {tokens : List ConcreteTokenCandidate}
    (hMatches :
      candidateSetMatchesConcreteCandidates candidates tokens)
    (hDeferred :
      rustDefaultStopDeferred emittedTokens maxTokens tail candidates) :
    concreteHasSentenceCloseCandidate tokens :=
  matched_candidate_set_has_concrete_sentence_close hMatches hDeferred.right

/-- A stop-maximal concrete candidate is a visible concrete stop candidate. -/
theorem concrete_stop_maximal_has_stop_candidate
    {horizon : DecodeHorizon}
    {tail : TailState}
    {candidates : CandidateSet}
    {tokens : List ConcreteTokenCandidate}
    {selectedToken : ConcreteTokenCandidate}
    [Decidable candidates.hasSentenceClose]
    (hStopMax :
      concreteStopMaximalByGatedScore horizon tail candidates
        tokens selectedToken) :
    concreteHasStopCandidate tokens := by
  rcases hStopMax with ⟨hMem, hRole, _selectedScore, _hSome, _hMax⟩
  exact ⟨selectedToken, hMem, hRole⟩

/-- A stop-maximal concrete candidate satisfies the concrete selector contract. -/
theorem concrete_stop_maximal_selection_is_selectable
    {horizon : DecodeHorizon}
    {tail : TailState}
    {candidates : CandidateSet}
    {tokens : List ConcreteTokenCandidate}
    {selectedToken : ConcreteTokenCandidate}
    [Decidable candidates.hasSentenceClose]
    (hStopMax :
      concreteStopMaximalByGatedScore horizon tail candidates
        tokens selectedToken) :
    concreteSelectableByGatedScore horizon tail candidates
      tokens selectedToken := by
  rcases hStopMax with ⟨hMem, _hRole, selectedScore, hSome, hMax⟩
  exact ⟨hMem, selectedScore, hSome, hMax⟩

/--
If a concrete token-id argmax is backed by a complete three-role projection,
then its selected role satisfies the abstract Rust-style gated selector
contract.
-/
theorem concrete_token_selection_refines_role_selection
    {horizon : DecodeHorizon}
    {tail : TailState}
    {candidates : CandidateSet}
    {tokens : List ConcreteTokenCandidate}
    {logits : RoleLogits}
    {selectedToken : ConcreteTokenCandidate}
    {selectedRole : TokenRole}
    [Decidable candidates.hasSentenceClose]
    (hCovered :
      roleLogitsCoveredByConcreteCandidates tokens logits)
    (hSelectedRole : selectedToken.role = selectedRole)
    (hSelectedRaw :
      selectedToken.rawLogit = roleRawLogit logits selectedRole)
    (hConcrete :
      concreteSelectableByGatedScore horizon tail candidates
        tokens selectedToken) :
    selectableByGatedScore horizon tail candidates logits selectedRole := by
  rcases hConcrete with ⟨_hSelectedMem, selectedScore, hSome, hMax⟩
  refine ⟨selectedScore, ?_, ?_⟩
  · have hSelectedRawForRole :
        selectedToken.rawLogit =
          roleRawLogit logits selectedToken.role := by
      rw [hSelectedRole]
      exact hSelectedRaw
    rw [← hSelectedRole, ← hSelectedRawForRole]
    exact hSome
  · intro role score hRoleScore
    rcases hCovered role with
      ⟨token, hTokenMem, hTokenRole, hTokenRaw⟩
    exact hMax token score hTokenMem (by
      rw [hTokenRole, hTokenRaw]
      exact hRoleScore)

/--
When the Rust pressure directive says to close an open clause and a close
candidate is visible, the Lean gate removes stop from the score surface.
-/
theorem rust_default_stop_deferred_gates_stop_score
    {emittedTokens maxTokens stopLogit : Nat}
    {candidates : CandidateSet}
    [Decidable candidates.hasSentenceClose]
    (hDeferred :
      rustDefaultStopDeferred emittedTokens maxTokens
        TailState.openClause candidates) :
    gatedAdjustedScore
      { emitted := emittedTokens, maxTokens := maxTokens }
      TailState.openClause candidates TokenRole.stop stopLogit = none := by
  rcases hDeferred with ⟨hDirective, hClose⟩
  unfold rustWrapDirective at hDirective
  by_cases hLt :
      rustWrapPressure emittedTokens <
        rustWrapThreshold emittedTokens maxTokens
  · rw [if_pos hLt] at hDirective
    cases hDirective
  · have hBreak :
        reynoldsPhiBreak
          { emitted := emittedTokens, maxTokens := maxTokens } := by
      unfold reynoldsPhiBreak wrapPressure wrapThreshold remaining
      unfold rustWrapPressure rustWrapThreshold rustRemainingTokens at hLt
      exact Nat.le_of_not_gt hLt
    exact open_break_close_candidate_gates_stop_score hBreak hClose stopLogit

/-- Before the break, an intervention operation emits no terminal event. -/
theorem pre_break_intervention_event_none
    {horizon : DecodeHorizon}
    {evidence : InterventionEvidence}
    [Decidable evidence.omittedSentenceClose]
    [Decidable evidence.deferredStop]
    [Decidable evidence.adjustedLogits]
    (hNoBreak : Not (reynoldsPhiBreak horizon)) :
    interventionEvent horizon evidence =
      InterventionEvent.noIntervention := by
  unfold interventionEvent
  rw [if_neg hNoBreak]

/-- After the break, projection evidence is classified as close injection. -/
theorem break_omitted_close_event_injected
    {horizon : DecodeHorizon}
    {evidence : InterventionEvidence}
    [Decidable evidence.omittedSentenceClose]
    [Decidable evidence.deferredStop]
    [Decidable evidence.adjustedLogits]
    (hBreak : reynoldsPhiBreak horizon)
    (hOmitted : evidence.omittedSentenceClose) :
    interventionEvent horizon evidence =
      InterventionEvent.closeCandidateInjected := by
  unfold interventionEvent
  rw [if_pos hBreak]
  rw [if_pos hOmitted]

/-- After the break, non-injection stop evidence is classified as deferral. -/
theorem break_deferred_stop_event
    {horizon : DecodeHorizon}
    {evidence : InterventionEvidence}
    [Decidable evidence.omittedSentenceClose]
    [Decidable evidence.deferredStop]
    [Decidable evidence.adjustedLogits]
    (hBreak : reynoldsPhiBreak horizon)
    (hNoOmitted : Not evidence.omittedSentenceClose)
    (hDeferred : evidence.deferredStop) :
    interventionEvent horizon evidence =
      InterventionEvent.stopDeferred := by
  unfold interventionEvent
  rw [if_pos hBreak]
  rw [if_neg hNoOmitted]
  rw [if_pos hDeferred]

/-- After the break, non-deferral adjustment evidence is classified as logits adjustment. -/
theorem break_logits_adjusted_event
    {horizon : DecodeHorizon}
    {evidence : InterventionEvidence}
    [Decidable evidence.omittedSentenceClose]
    [Decidable evidence.deferredStop]
    [Decidable evidence.adjustedLogits]
    (hBreak : reynoldsPhiBreak horizon)
    (hNoOmitted : Not evidence.omittedSentenceClose)
    (hNoDeferred : Not evidence.deferredStop)
    (hAdjusted : evidence.adjustedLogits) :
    interventionEvent horizon evidence =
      InterventionEvent.logitsAdjusted := by
  unfold interventionEvent
  rw [if_pos hBreak]
  rw [if_neg hNoOmitted]
  rw [if_neg hNoDeferred]
  rw [if_pos hAdjusted]

/-- The intervention classifier is total over the observable intervention event set. -/
theorem intervention_event_complete
    (horizon : DecodeHorizon)
    (evidence : InterventionEvidence)
    [Decidable evidence.omittedSentenceClose]
    [Decidable evidence.deferredStop]
    [Decidable evidence.adjustedLogits] :
    interventionEvent horizon evidence = InterventionEvent.noIntervention ∨
      interventionEvent horizon evidence = InterventionEvent.closeCandidateInjected ∨
      interventionEvent horizon evidence = InterventionEvent.stopDeferred ∨
      interventionEvent horizon evidence = InterventionEvent.logitsAdjusted := by
  unfold interventionEvent
  by_cases hBreak : reynoldsPhiBreak horizon
  · rw [if_pos hBreak]
    by_cases hOmitted : evidence.omittedSentenceClose
    · rw [if_pos hOmitted]
      exact Or.inr (Or.inl rfl)
    · rw [if_neg hOmitted]
      by_cases hDeferred : evidence.deferredStop
      · rw [if_pos hDeferred]
        exact Or.inr (Or.inr (Or.inl rfl))
      · rw [if_neg hDeferred]
        by_cases hAdjusted : evidence.adjustedLogits
        · rw [if_pos hAdjusted]
          exact Or.inr (Or.inr (Or.inr rfl))
        · rw [if_neg hAdjusted]
          exact Or.inl rfl
  · rw [if_neg hBreak]
    exact Or.inl rfl

/-- Before the break, selection-stage telemetry is silent. -/
theorem pre_break_selection_event_none
    {horizon : DecodeHorizon}
    (hNoBreak : Not (reynoldsPhiBreak horizon)) :
    selectionEvent horizon = SelectionEvent.noSelectionOutcome := by
  unfold selectionEvent
  rw [if_neg hNoBreak]

/-- After the break, selection-stage telemetry is active. -/
theorem break_selection_event_outcome
    {horizon : DecodeHorizon}
    (hBreak : reynoldsPhiBreak horizon) :
    selectionEvent horizon = SelectionEvent.selectionOutcome := by
  unfold selectionEvent
  rw [if_pos hBreak]

/-- The selection classifier is total over the observable selection event set. -/
theorem selection_event_complete (horizon : DecodeHorizon) :
    selectionEvent horizon = SelectionEvent.noSelectionOutcome ∨
      selectionEvent horizon = SelectionEvent.selectionOutcome := by
  unfold selectionEvent
  by_cases hBreak : reynoldsPhiBreak horizon
  · rw [if_pos hBreak]
    exact Or.inr rfl
  · rw [if_neg hBreak]
    exact Or.inl rfl

/-- The shared pressure trace records exactly the finite horizon fields. -/
theorem pressure_trace_fields
    (horizon : DecodeHorizon)
    (tail : TailState) :
    (pressureTrace horizon tail).emitted = horizon.emitted ∧
      (pressureTrace horizon tail).maxTokens = horizon.maxTokens ∧
      (pressureTrace horizon tail).remainingTokens = remaining horizon ∧
      (pressureTrace horizon tail).pressure = wrapPressure horizon ∧
      (pressureTrace horizon tail).threshold = wrapThreshold horizon ∧
      (pressureTrace horizon tail).directive = wrapDirective horizon tail := by
  unfold pressureTrace
  simp

/-- Rust remaining-token arithmetic is the canonical finite horizon remainder. -/
theorem rust_remaining_tokens_matches
    (emittedTokens maxTokens : Nat) :
    rustRemainingTokens emittedTokens maxTokens =
      remaining { emitted := emittedTokens, maxTokens := maxTokens } := by
  rfl

/-- Rust wrap pressure is the canonical Reynolds-scaled pressure. -/
theorem rust_wrap_pressure_matches
    (emittedTokens maxTokens : Nat) :
    rustWrapPressure emittedTokens =
      wrapPressure { emitted := emittedTokens, maxTokens := maxTokens } := by
  rfl

/-- Rust wrap threshold is the canonical Phi-scaled remaining budget. -/
theorem rust_wrap_threshold_matches
    (emittedTokens maxTokens : Nat) :
    rustWrapThreshold emittedTokens maxTokens =
      wrapThreshold { emitted := emittedTokens, maxTokens := maxTokens } := by
  rfl

/-- Rust's less-than branch form selects the same directive as the canonical model. -/
theorem rust_wrap_directive_matches
    (emittedTokens maxTokens : Nat)
    (tail : TailState) :
    rustWrapDirective emittedTokens maxTokens tail =
      wrapDirective { emitted := emittedTokens, maxTokens := maxTokens } tail := by
  unfold rustWrapDirective wrapDirective reynoldsPhiBreak
  unfold rustWrapPressure rustWrapThreshold rustRemainingTokens
  unfold wrapPressure wrapThreshold remaining
  by_cases hLt :
      (emittedTokens + 1) * reynoldsCriticalMilli <
        (maxTokens - emittedTokens + 1) * phiMilli
  · have hNoBreak :
        ¬ (emittedTokens + 1) * reynoldsCriticalMilli >=
          (maxTokens - emittedTokens + 1) * phiMilli :=
      Nat.not_le_of_gt hLt
    rw [if_pos hLt, if_neg hNoBreak]
  · have hBreak :
        (emittedTokens + 1) * reynoldsCriticalMilli >=
          (maxTokens - emittedTokens + 1) * phiMilli :=
      Nat.le_of_not_gt hLt
    rw [if_neg hLt, if_pos hBreak]

/-- Rust pressure telemetry carries the same finite fields as `pressureTrace`. -/
theorem rust_pressure_trace_matches_pressure_trace
    (emittedTokens maxTokens : Nat)
    (tail : TailState) :
    let horizon : DecodeHorizon :=
      { emitted := emittedTokens, maxTokens := maxTokens }
    (rustPressureTrace emittedTokens maxTokens tail).emittedTokens =
        (pressureTrace horizon tail).emitted ∧
      (rustPressureTrace emittedTokens maxTokens tail).maxTokens =
        (pressureTrace horizon tail).maxTokens ∧
      (rustPressureTrace emittedTokens maxTokens tail).remainingTokens =
        (pressureTrace horizon tail).remainingTokens ∧
      (rustPressureTrace emittedTokens maxTokens tail).pressure =
        (pressureTrace horizon tail).pressure ∧
      (rustPressureTrace emittedTokens maxTokens tail).threshold =
        (pressureTrace horizon tail).threshold ∧
      (rustPressureTrace emittedTokens maxTokens tail).directive =
        (pressureTrace horizon tail).directive := by
  intro horizon
  unfold rustPressureTrace pressureTrace
  simp [
    horizon,
    rustRemainingTokens,
    rustWrapPressure,
    rustWrapThreshold,
    remaining,
    wrapPressure,
    wrapThreshold,
    rust_wrap_directive_matches,
  ]

/--
Intervention and selection telemetry produced for the same decode step carry
the same pressure trace, so they can be joined without recomputing the model
state.
-/
theorem same_step_intervention_selection_trace_coherent
    (horizon : DecodeHorizon)
    (tail : TailState)
    (evidence : InterventionEvidence)
    [Decidable evidence.omittedSentenceClose]
    [Decidable evidence.deferredStop]
    [Decidable evidence.adjustedLogits] :
    (interventionTelemetry horizon tail evidence).trace =
      (selectionTelemetry horizon tail).trace := by
  rfl

/-- Changing the event classifier does not change the pressure trace. -/
theorem intervention_trace_independent_of_evidence
    (horizon : DecodeHorizon)
    (tail : TailState)
    (left right : InterventionEvidence)
    [Decidable left.omittedSentenceClose]
    [Decidable left.deferredStop]
    [Decidable left.adjustedLogits]
    [Decidable right.omittedSentenceClose]
    [Decidable right.deferredStop]
    [Decidable right.adjustedLogits] :
    (interventionTelemetry horizon tail left).trace =
      (interventionTelemetry horizon tail right).trace := by
  rfl

/-- Under an open-tail break with a visible close candidate, stop cannot be legally selected. -/
theorem open_break_visible_close_no_legal_stop_selection
    {horizon : DecodeHorizon}
    {candidates : CandidateSet}
    (hBreak : reynoldsPhiBreak horizon)
    (hClose : candidates.hasSentenceClose) :
    Not (legalSelectedRole horizon TailState.openClause candidates TokenRole.stop) := by
  unfold legalSelectedRole
  exact open_break_with_close_candidate_blocks_stop hBreak hClose

/--
After the break, an open tail with a visible close candidate either closes by
selecting sentence-close, or remains open while stop is still gated. Therefore
the decode loop has no legal stop-before-closure transition.
-/
theorem open_break_visible_close_progress_or_stop_gated
    {horizon : DecodeHorizon}
    {candidates : CandidateSet}
    {selected : TokenRole}
    (hBreak : reynoldsPhiBreak horizon)
    (hClose : candidates.hasSentenceClose)
    (hLegal : legalSelectedRole horizon TailState.openClause candidates selected) :
    nextTailState TailState.openClause selected = TailState.sentenceClosed ∨
      (nextTailState TailState.openClause selected = TailState.openClause ∧
        Not (legalSelectedRole horizon TailState.openClause candidates TokenRole.stop)) := by
  have hNoLegalStop :
      Not (legalSelectedRole horizon TailState.openClause candidates TokenRole.stop) :=
    open_break_visible_close_no_legal_stop_selection hBreak hClose
  cases selected with
  | continuation =>
      right
      constructor
      · rfl
      · exact hNoLegalStop
  | sentenceClose =>
      left
      rfl
  | stop =>
      exact False.elim (hNoLegalStop hLegal)

/--
Concrete token-id selection at an open-tail break cannot select a stop role
when the matched concrete candidate set contains a classified sentence-close
candidate.
-/
theorem concrete_open_break_visible_close_selection_not_stop
    {horizon : DecodeHorizon}
    {candidates : CandidateSet}
    {tokens : List ConcreteTokenCandidate}
    {logits : RoleLogits}
    {selectedToken : ConcreteTokenCandidate}
    [Decidable candidates.hasSentenceClose]
    (hBreak : reynoldsPhiBreak horizon)
    (hMatches :
      candidateSetMatchesConcreteCandidates candidates tokens)
    (hConcreteClose : concreteHasSentenceCloseCandidate tokens)
    (hCovered :
      roleLogitsCoveredByConcreteCandidates tokens logits)
    (hSelectedRaw :
      selectedToken.rawLogit = roleRawLogit logits selectedToken.role)
    (hConcrete :
      concreteSelectableByGatedScore horizon TailState.openClause
        candidates tokens selectedToken) :
    Not (selectedToken.role = TokenRole.stop) := by
  have hClose : candidates.hasSentenceClose :=
    hMatches.mpr hConcreteClose
  have hSelected :
      selectableByGatedScore horizon TailState.openClause
        candidates logits selectedToken.role :=
    concrete_token_selection_refines_role_selection
      (hCovered := hCovered)
      (hSelectedRole := rfl)
      (hSelectedRaw := hSelectedRaw)
      (hConcrete := hConcrete)
  have hLegal :
      legalSelectedRole horizon TailState.openClause
        candidates selectedToken.role :=
    rust_select_terminal_token_matches_gated_score hSelected
  have hNoLegalStop :
      Not (legalSelectedRole horizon TailState.openClause
        candidates TokenRole.stop) :=
    open_break_visible_close_no_legal_stop_selection hBreak hClose
  intro hStop
  rw [hStop] at hLegal
  exact hNoLegalStop hLegal

/--
Concrete token-id selection inherits the decode-loop progress invariant: after
the Reynolds/Phi break, a matched visible sentence-close candidate prevents
stop-before-closure. The selected token either closes the sentence or leaves
the tail open while stop remains gated.
-/
theorem concrete_open_break_visible_close_progress_or_stop_gated
    {horizon : DecodeHorizon}
    {candidates : CandidateSet}
    {tokens : List ConcreteTokenCandidate}
    {logits : RoleLogits}
    {selectedToken : ConcreteTokenCandidate}
    [Decidable candidates.hasSentenceClose]
    (hBreak : reynoldsPhiBreak horizon)
    (hMatches :
      candidateSetMatchesConcreteCandidates candidates tokens)
    (hConcreteClose : concreteHasSentenceCloseCandidate tokens)
    (hCovered :
      roleLogitsCoveredByConcreteCandidates tokens logits)
    (hSelectedRaw :
      selectedToken.rawLogit = roleRawLogit logits selectedToken.role)
    (hConcrete :
      concreteSelectableByGatedScore horizon TailState.openClause
        candidates tokens selectedToken) :
    nextTailState TailState.openClause selectedToken.role =
        TailState.sentenceClosed ∨
      (nextTailState TailState.openClause selectedToken.role =
          TailState.openClause ∧
        Not (legalSelectedRole horizon TailState.openClause
          candidates TokenRole.stop)) := by
  have hClose : candidates.hasSentenceClose :=
    hMatches.mpr hConcreteClose
  have hSelected :
      selectableByGatedScore horizon TailState.openClause
        candidates logits selectedToken.role :=
    concrete_token_selection_refines_role_selection
      (hCovered := hCovered)
      (hSelectedRole := rfl)
      (hSelectedRaw := hSelectedRaw)
      (hConcrete := hConcrete)
  have hLegal :
      legalSelectedRole horizon TailState.openClause
        candidates selectedToken.role :=
    rust_select_terminal_token_matches_gated_score hSelected
  exact open_break_visible_close_progress_or_stop_gated
    hBreak hClose hLegal

/--
Concrete two-step closure: if the first post-break concrete selection closes
the open tail, the successor horizon stays past the break and the closed-tail
controller directs and permits stop. If it does not close yet, stop remains
gated at the open tail.
-/
theorem concrete_open_break_close_or_next_closed_stop_ready
    {horizon : DecodeHorizon}
    {candidates : CandidateSet}
    {tokens : List ConcreteTokenCandidate}
    {logits : RoleLogits}
    {selectedToken : ConcreteTokenCandidate}
    [Decidable candidates.hasSentenceClose]
    (hBreak : reynoldsPhiBreak horizon)
    (hMatches :
      candidateSetMatchesConcreteCandidates candidates tokens)
    (hConcreteClose : concreteHasSentenceCloseCandidate tokens)
    (hCovered :
      roleLogitsCoveredByConcreteCandidates tokens logits)
    (hSelectedRaw :
      selectedToken.rawLogit = roleRawLogit logits selectedToken.role)
    (hConcrete :
      concreteSelectableByGatedScore horizon TailState.openClause
        candidates tokens selectedToken) :
    (nextTailState TailState.openClause selectedToken.role =
        TailState.sentenceClosed ∧
      reynoldsPhiBreak (successorHorizon horizon) ∧
      wrapDirective (successorHorizon horizon) TailState.sentenceClosed =
        WrapDirective.chooseStop ∧
      stopAllowed (successorHorizon horizon)
        TailState.sentenceClosed candidates ∧
      gatedAdjustedScore (successorHorizon horizon)
        TailState.sentenceClosed candidates TokenRole.stop
          (roleRawLogit logits TokenRole.stop) =
        some (adjustedScore (successorHorizon horizon)
          TailState.sentenceClosed TokenRole.stop
          (roleRawLogit logits TokenRole.stop))) ∨
    (nextTailState TailState.openClause selectedToken.role =
        TailState.openClause ∧
      Not (legalSelectedRole horizon TailState.openClause
        candidates TokenRole.stop)) := by
  have hProgress :=
    concrete_open_break_visible_close_progress_or_stop_gated
      (horizon := horizon)
      (candidates := candidates)
      (tokens := tokens)
      (logits := logits)
      (selectedToken := selectedToken)
      hBreak hMatches hConcreteClose hCovered hSelectedRaw hConcrete
  cases hProgress with
  | inl hClosed =>
      left
      have hNextBreak : reynoldsPhiBreak (successorHorizon horizon) :=
        reynolds_phi_break_successor hBreak
      refine ⟨hClosed, hNextBreak, ?_, ?_, ?_⟩
      · exact closed_break_directs_stop hNextBreak
      · exact closed_break_allows_stop hNextBreak
      · exact closed_break_keeps_stop_score hNextBreak
          (roleRawLogit logits TokenRole.stop)
  | inr hOpenStopGated =>
      right
      exact hOpenStopGated

/--
Closed-tail concrete stop selection: after the Reynolds/Phi break, a concrete
stop-maximal candidate is visible, selectable, legal, keeps the tail closed,
and follows the controller's stop directive.
-/
theorem concrete_closed_break_stop_maximal_selection_terminates
    {horizon : DecodeHorizon}
    {candidates : CandidateSet}
    {tokens : List ConcreteTokenCandidate}
    {selectedToken : ConcreteTokenCandidate}
    [Decidable candidates.hasSentenceClose]
    (hBreak : reynoldsPhiBreak horizon)
    (hStopMax :
      concreteStopMaximalByGatedScore horizon TailState.sentenceClosed
        candidates tokens selectedToken) :
    concreteHasStopCandidate tokens ∧
      concreteSelectableByGatedScore horizon TailState.sentenceClosed
        candidates tokens selectedToken ∧
      legalSelectedRole horizon TailState.sentenceClosed
        candidates selectedToken.role ∧
      gatedAdjustedScore horizon TailState.sentenceClosed candidates
        TokenRole.stop selectedToken.rawLogit =
          some (adjustedScore horizon TailState.sentenceClosed
            TokenRole.stop selectedToken.rawLogit) ∧
      nextTailState TailState.sentenceClosed selectedToken.role =
        TailState.sentenceClosed ∧
      selectedToken.role = TokenRole.stop ∧
      stopAllowed horizon TailState.sentenceClosed candidates ∧
      wrapDirective horizon TailState.sentenceClosed =
        WrapDirective.chooseStop := by
  have hHasStop : concreteHasStopCandidate tokens :=
    concrete_stop_maximal_has_stop_candidate hStopMax
  have hSelectable :
      concreteSelectableByGatedScore horizon TailState.sentenceClosed
        candidates tokens selectedToken :=
    concrete_stop_maximal_selection_is_selectable hStopMax
  have hSelectedRole : selectedToken.role = TokenRole.stop := by
    rcases hStopMax with ⟨_hMem, hRole, _selectedScore, _hSome, _hMax⟩
    exact hRole
  have hLegal :
      legalSelectedRole horizon TailState.sentenceClosed
        candidates selectedToken.role := by
    rw [hSelectedRole]
    unfold legalSelectedRole
    exact closed_break_allows_stop hBreak
  have hStopScore :
      gatedAdjustedScore horizon TailState.sentenceClosed candidates
        TokenRole.stop selectedToken.rawLogit =
          some (adjustedScore horizon TailState.sentenceClosed
            TokenRole.stop selectedToken.rawLogit) :=
    closed_break_keeps_stop_score hBreak selectedToken.rawLogit
  have hNextTail :
      nextTailState TailState.sentenceClosed selectedToken.role =
        TailState.sentenceClosed := by
    rw [hSelectedRole]
    rfl
  exact ⟨
    hHasStop,
    hSelectable,
    hLegal,
    hStopScore,
    hNextTail,
    hSelectedRole,
    closed_break_allows_stop hBreak,
    closed_break_directs_stop hBreak,
  ⟩

/--
The closed-tail stop-maximal theorem applies at the successor horizon reached
after an open-tail sentence-close selection, because the Reynolds/Phi break is
monotone across decode successors.
-/
theorem concrete_successor_closed_break_stop_maximal_selection_terminates
    {horizon : DecodeHorizon}
    {candidates : CandidateSet}
    {tokens : List ConcreteTokenCandidate}
    {selectedToken : ConcreteTokenCandidate}
    [Decidable candidates.hasSentenceClose]
    (hBreak : reynoldsPhiBreak horizon)
    (hStopMax :
      concreteStopMaximalByGatedScore (successorHorizon horizon)
        TailState.sentenceClosed candidates tokens selectedToken) :
    concreteHasStopCandidate tokens ∧
      concreteSelectableByGatedScore (successorHorizon horizon)
        TailState.sentenceClosed candidates tokens selectedToken ∧
      legalSelectedRole (successorHorizon horizon) TailState.sentenceClosed
        candidates selectedToken.role ∧
      gatedAdjustedScore (successorHorizon horizon) TailState.sentenceClosed
        candidates TokenRole.stop selectedToken.rawLogit =
          some (adjustedScore (successorHorizon horizon)
            TailState.sentenceClosed TokenRole.stop selectedToken.rawLogit) ∧
      nextTailState TailState.sentenceClosed selectedToken.role =
        TailState.sentenceClosed ∧
      selectedToken.role = TokenRole.stop ∧
      stopAllowed (successorHorizon horizon) TailState.sentenceClosed
        candidates ∧
      wrapDirective (successorHorizon horizon) TailState.sentenceClosed =
        WrapDirective.chooseStop := by
  exact concrete_closed_break_stop_maximal_selection_terminates
    (horizon := successorHorizon horizon)
    (hBreak := reynolds_phi_break_successor hBreak)
    hStopMax

/--
Concrete open-then-stop termination: when the first post-break concrete
selection actually closes the open clause, the successor horizon remains past
the Reynolds/Phi break and any closed-tail stop-maximal concrete selection on
the next sampler surface is legal, selectable, and terminating.
-/
theorem concrete_open_then_closed_stop_terminates
    {horizon : DecodeHorizon}
    {closeCandidates stopCandidates : CandidateSet}
    {openTokens stopTokens : List ConcreteTokenCandidate}
    {openSelected stopSelected : ConcreteTokenCandidate}
    {logits : RoleLogits}
    [Decidable closeCandidates.hasSentenceClose]
    [Decidable stopCandidates.hasSentenceClose]
    (hBreak : reynoldsPhiBreak horizon)
    (hMatches :
      candidateSetMatchesConcreteCandidates closeCandidates openTokens)
    (hConcreteClose : concreteHasSentenceCloseCandidate openTokens)
    (hCovered :
      roleLogitsCoveredByConcreteCandidates openTokens logits)
    (hOpenSelectedRaw :
      openSelected.rawLogit = roleRawLogit logits openSelected.role)
    (hOpenConcrete :
      concreteSelectableByGatedScore horizon TailState.openClause
        closeCandidates openTokens openSelected)
    (hOpenCloses :
      nextTailState TailState.openClause openSelected.role =
        TailState.sentenceClosed)
    (hStopMax :
      concreteStopMaximalByGatedScore (successorHorizon horizon)
        TailState.sentenceClosed stopCandidates stopTokens stopSelected) :
    nextTailState TailState.openClause openSelected.role =
        TailState.sentenceClosed ∧
      reynoldsPhiBreak (successorHorizon horizon) ∧
      wrapDirective (successorHorizon horizon) TailState.sentenceClosed =
        WrapDirective.chooseStop ∧
      concreteHasStopCandidate stopTokens ∧
      concreteSelectableByGatedScore (successorHorizon horizon)
        TailState.sentenceClosed stopCandidates stopTokens stopSelected ∧
      legalSelectedRole (successorHorizon horizon) TailState.sentenceClosed
        stopCandidates stopSelected.role ∧
      gatedAdjustedScore (successorHorizon horizon) TailState.sentenceClosed
        stopCandidates TokenRole.stop stopSelected.rawLogit =
          some (adjustedScore (successorHorizon horizon)
            TailState.sentenceClosed TokenRole.stop stopSelected.rawLogit) ∧
      nextTailState TailState.sentenceClosed stopSelected.role =
        TailState.sentenceClosed ∧
      stopSelected.role = TokenRole.stop ∧
      stopAllowed (successorHorizon horizon) TailState.sentenceClosed
        stopCandidates := by
  have hReady :=
    concrete_open_break_close_or_next_closed_stop_ready
      (horizon := horizon)
      (candidates := closeCandidates)
      (tokens := openTokens)
      (logits := logits)
      (selectedToken := openSelected)
      hBreak hMatches hConcreteClose hCovered hOpenSelectedRaw hOpenConcrete
  cases hReady with
  | inl hClosedReady =>
      rcases hClosedReady with
        ⟨hClosed, hNextBreak, hDirective, _hStopAllowed, _hStopScore⟩
      have hStopTerminates :=
        concrete_successor_closed_break_stop_maximal_selection_terminates
          (horizon := horizon)
          (candidates := stopCandidates)
          (tokens := stopTokens)
          (selectedToken := stopSelected)
          hBreak hStopMax
      rcases hStopTerminates with
        ⟨hHasStop, hSelectable, hLegal, hScore, hNextTail, hStopRole,
          hClosedStopAllowed, _hClosedDirective⟩
      exact ⟨
        hClosed,
        hNextBreak,
        hDirective,
        hHasStop,
        hSelectable,
        hLegal,
        hScore,
        hNextTail,
        hStopRole,
        hClosedStopAllowed,
      ⟩
  | inr hOpenStopGated =>
      rcases hOpenStopGated with ⟨hStillOpen, _hStopGated⟩
      rw [hOpenCloses] at hStillOpen
      cases hStillOpen

/--
The composed open-then-stop proof packages the telemetry-facing certificate the
runtime needs to justify two consecutive `selection-outcome` events: first the
open-tail closure under Reynolds/Phi pressure, then the successor closed-tail
stop selection.
-/
theorem concrete_open_then_closed_stop_selection_certificate
    {horizon : DecodeHorizon}
    {closeCandidates stopCandidates : CandidateSet}
    {openTokens stopTokens : List ConcreteTokenCandidate}
    {openSelected stopSelected : ConcreteTokenCandidate}
    {logits : RoleLogits}
    [Decidable closeCandidates.hasSentenceClose]
    [Decidable stopCandidates.hasSentenceClose]
    (hBreak : reynoldsPhiBreak horizon)
    (hMatches :
      candidateSetMatchesConcreteCandidates closeCandidates openTokens)
    (hConcreteClose : concreteHasSentenceCloseCandidate openTokens)
    (hCovered :
      roleLogitsCoveredByConcreteCandidates openTokens logits)
    (hOpenSelectedRaw :
      openSelected.rawLogit = roleRawLogit logits openSelected.role)
    (hOpenConcrete :
      concreteSelectableByGatedScore horizon TailState.openClause
        closeCandidates openTokens openSelected)
    (hOpenCloses :
      nextTailState TailState.openClause openSelected.role =
        TailState.sentenceClosed)
    (hStopMax :
      concreteStopMaximalByGatedScore (successorHorizon horizon)
        TailState.sentenceClosed stopCandidates stopTokens stopSelected) :
    OpenThenStopSelectionCertificate horizon closeCandidates stopCandidates
      openTokens stopTokens openSelected stopSelected := by
  have hTerminates :=
    concrete_open_then_closed_stop_terminates
      (horizon := horizon)
      (closeCandidates := closeCandidates)
      (stopCandidates := stopCandidates)
      (openTokens := openTokens)
      (stopTokens := stopTokens)
      (openSelected := openSelected)
      (stopSelected := stopSelected)
      (logits := logits)
      hBreak hMatches hConcreteClose hCovered hOpenSelectedRaw
      hOpenConcrete hOpenCloses hStopMax
  rcases hTerminates with
    ⟨hClosed, hNextBreak, hDirective, hHasStop, hSelectable, hLegal,
      hScore, hStopTail, hStopRole, hClosedStopAllowed⟩
  refine {
    openSelectionEvent := ?_,
    openDirective := ?_,
    openCloses := hClosed,
    successorBreak := hNextBreak,
    closedSelectionEvent := ?_,
    closedDirective := ?_,
    stopVisible := hHasStop,
    stopSelectable := hSelectable,
    stopLegal := hLegal,
    stopScoreKept := hScore,
    stopKeepsTailClosed := hStopTail,
    stopRole := hStopRole,
    stopAllowed := hClosedStopAllowed,
  }
  · exact break_selection_event_outcome hBreak
  · exact open_break_directs_sentence_close hBreak
  · exact break_selection_event_outcome hNextBreak
  · exact hDirective

/-- The final step of an open clause must try to close the sentence. -/
theorem final_open_clause_directs_sentence_close (maxTokens : Nat) :
    wrapDirective { emitted := maxTokens, maxTokens := maxTokens }
      TailState.openClause = WrapDirective.chooseSentenceClose := by
  exact open_break_directs_sentence_close
    (final_token_crosses_reynolds_phi maxTokens)

/-- The final step of a closed sentence must try to stop. -/
theorem final_closed_sentence_directs_stop (maxTokens : Nat) :
    wrapDirective { emitted := maxTokens, maxTokens := maxTokens }
      TailState.sentenceClosed = WrapDirective.chooseStop := by
  exact closed_break_directs_stop
    (final_token_crosses_reynolds_phi maxTokens)

/-- Rust final-token open clauses direct sentence closure, matching the canonical theorem. -/
theorem rust_final_open_clause_directs_sentence_close (maxTokens : Nat) :
    (rustPressureTrace maxTokens maxTokens TailState.openClause).directive =
      WrapDirective.chooseSentenceClose := by
  change rustWrapDirective maxTokens maxTokens TailState.openClause =
    WrapDirective.chooseSentenceClose
  rw [rust_wrap_directive_matches]
  exact final_open_clause_directs_sentence_close maxTokens

/-- Rust final-token closed sentences direct stop, matching the canonical theorem. -/
theorem rust_final_closed_sentence_directs_stop (maxTokens : Nat) :
    (rustPressureTrace maxTokens maxTokens TailState.sentenceClosed).directive =
      WrapDirective.chooseStop := by
  change rustWrapDirective maxTokens maxTokens TailState.sentenceClosed =
    WrapDirective.chooseStop
  rw [rust_wrap_directive_matches]
  exact final_closed_sentence_directs_stop maxTokens

/-- The final open-clause step blocks stop if a close candidate is visible. -/
theorem final_open_clause_with_close_candidate_blocks_stop
    (maxTokens : Nat)
    {candidates : CandidateSet}
    (hClose : candidates.hasSentenceClose) :
    Not (stopAllowed
      { emitted := maxTokens, maxTokens := maxTokens }
      TailState.openClause
      candidates) := by
  exact open_break_with_close_candidate_blocks_stop
    (final_token_crosses_reynolds_phi maxTokens)
    hClose

/-- There is a finite horizon witness where the wrap controller is active. -/
theorem terminal_pressure_has_wrap_witness :
    Exists reynoldsPhiBreak := by
  exact Exists.intro { emitted := 0, maxTokens := 0 }
    (final_token_crosses_reynolds_phi 0)

end TerminalProsody
