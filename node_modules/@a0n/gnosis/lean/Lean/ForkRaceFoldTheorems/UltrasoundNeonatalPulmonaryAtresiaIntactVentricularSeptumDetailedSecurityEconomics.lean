/-!
# UltrasoundNeonatalPulmonaryAtresiaIntactVentricularSeptumDetailedSecurityEconomics

Neonatal Pulmonary Atresia with Intact Ventricular Septum (PA-IVS): complete
obstruction of the right ventricular outflow tract with no VSD, resulting in
right ventricular hypoplasia of variable severity, tricuspid regurgitation, and
potential right ventricular-to-coronary artery sinusoidal connections (RVCAS).
Five security-economics gap theorems for clinical imaging gaps that constitute
missed-diagnosis risk — each with measurable economic (medico-legal /
readmission) cost.

Anti-thesis pattern: structure posits the ABSENCE of an imaging assessment,
theorem derives strictly-positive risk. Zero sorry — all close by exact.
-/

namespace ForkRaceFoldTheorems

-- ── Theorem 1 ────────────────────────────────────────────────────────────────
-- Anti-thesis: right ventricular inlet, trabecular, and infundibular component
-- lengths NOT measured (RV tripartite morphology NOT assessed) AND tricuspid
-- valve annulus Z-score NOT calculated → incorrect RV adequacy classification
-- (biventricular repair vs. univentricular palliation) risk is strictly
-- positive.

structure PAIVSRVMorphologyTricuspidAnnulusGapAssumptions where
  rvTripartiteMorphologyAssessed : Bool
  tricuspidAnnulusZScoreCalculated : Bool
  rvAdequacyClassificationRisk : Nat
  gapFromUnassessedRVMorphologyAndTricuspid :
    rvTripartiteMorphologyAssessed = false →
    tricuspidAnnulusZScoreCalculated = false →
    0 < rvAdequacyClassificationRisk

theorem paivs_rv_morphology_tricuspid_annulus_gap_exists
    (a : PAIVSRVMorphologyTricuspidAnnulusGapAssumptions)
    (hRV : a.rvTripartiteMorphologyAssessed = false)
    (hTV : a.tricuspidAnnulusZScoreCalculated = false) :
    0 < a.rvAdequacyClassificationRisk :=
  a.gapFromUnassessedRVMorphologyAndTricuspid hRV hTV

-- ── Theorem 2 ────────────────────────────────────────────────────────────────
-- Anti-thesis: right ventricular-to-coronary artery sinusoidal connections
-- (RVCAS) NOT excluded by colour Doppler AND coronary artery dominance NOT
-- mapped → RV-dependent coronary circulation mismanagement / decompression
-- ventriculotomy contraindication missed risk is strictly positive.

structure PAIVSRVCASCoronaryDominanceGapAssumptions where
  rvcasExcludedByColorDoppler : Bool
  coronaryDominanceMapped : Bool
  rvDependentCoronaryRisk : Nat
  gapFromUnexcludedRVCASAndCoronary :
    rvcasExcludedByColorDoppler = false →
    coronaryDominanceMapped = false →
    0 < rvDependentCoronaryRisk

theorem paivs_rvcas_coronary_dominance_gap_exists
    (a : PAIVSRVCASCoronaryDominanceGapAssumptions)
    (hRVCAS : a.rvcasExcludedByColorDoppler = false)
    (hDom : a.coronaryDominanceMapped = false) :
    0 < a.rvDependentCoronaryRisk :=
  a.gapFromUnexcludedRVCASAndCoronary hRVCAS hDom

-- ── Theorem 3 ────────────────────────────────────────────────────────────────
-- Anti-thesis: pulmonary valve morphology NOT characterised (membranous vs.
-- muscular atresia NOT distinguished) AND pulmonary valve annulus diameter
-- NOT measured → RF catheter perforation candidacy assessment missed risk
-- is strictly positive.

structure PAIVSPulmonaryValveMorphologyGapAssumptions where
  pulmonaryValveMorphologyCharacterised : Bool
  pulmonaryAnnulusDiameterMeasured : Bool
  catheterPerforationCandidacyRisk : Nat
  gapFromUncharacterisedPVAndAnnulus :
    pulmonaryValveMorphologyCharacterised = false →
    pulmonaryAnnulusDiameterMeasured = false →
    0 < catheterPerforationCandidacyRisk

theorem paivs_pulmonary_valve_morphology_gap_exists
    (a : PAIVSPulmonaryValveMorphologyGapAssumptions)
    (hPV : a.pulmonaryValveMorphologyCharacterised = false)
    (hAnn : a.pulmonaryAnnulusDiameterMeasured = false) :
    0 < a.catheterPerforationCandidacyRisk :=
  a.gapFromUncharacterisedPVAndAnnulus hPV hAnn

-- ── Theorem 4 ────────────────────────────────────────────────────────────────
-- Anti-thesis: ductal patency and direction of ductal flow NOT assessed AND
-- PGE1 continuation indication NOT documented → duct-closure / acute
-- cyanosis / cardiovascular collapse risk is strictly positive.

structure PAIVSDuctalPatencyPGE1GapAssumptions where
  ductalPatencyAndFlowAssessed : Bool
  pge1IndicationDocumented : Bool
  cardiovascularCollapseRisk : Nat
  gapFromUnassessedDuctalAndPGE1 :
    ductalPatencyAndFlowAssessed = false →
    pge1IndicationDocumented = false →
    0 < cardiovascularCollapseRisk

theorem paivs_ductal_patency_pge1_gap_exists
    (a : PAIVSDuctalPatencyPGE1GapAssumptions)
    (hDuct : a.ductalPatencyAndFlowAssessed = false)
    (hPGE : a.pge1IndicationDocumented = false) :
    0 < a.cardiovascularCollapseRisk :=
  a.gapFromUnassessedDuctalAndPGE1 hDuct hPGE

-- ── Theorem 5 ────────────────────────────────────────────────────────────────
-- Anti-thesis: tricuspid regurgitation severity NOT graded AND right atrial
-- size NOT quantified → elevated RA pressure / foramen ovale restriction /
-- inadequate mixing risk is strictly positive.

structure PAIVSTricuspidRegurgitationRAGapAssumptions where
  tricuspidRegurgitationGraded : Bool
  rightAtrialSizeQuantified : Bool
  foramenOvaleRestrictionRisk : Nat
  gapFromUngradedTRAndRA :
    tricuspidRegurgitationGraded = false →
    rightAtrialSizeQuantified = false →
    0 < foramenOvaleRestrictionRisk

theorem paivs_tricuspid_regurgitation_ra_gap_exists
    (a : PAIVSTricuspidRegurgitationRAGapAssumptions)
    (hTR : a.tricuspidRegurgitationGraded = false)
    (hRA : a.rightAtrialSizeQuantified = false) :
    0 < a.foramenOvaleRestrictionRisk :=
  a.gapFromUngradedTRAndRA hTR hRA

end ForkRaceFoldTheorems
