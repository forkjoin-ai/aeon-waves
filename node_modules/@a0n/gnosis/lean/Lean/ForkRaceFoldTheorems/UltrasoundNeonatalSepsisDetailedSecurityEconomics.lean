namespace ForkRaceFoldTheorems

structure NeonatalSepsisFocusInfectionUltrasoundGapAssumptions where
  systematicSonographicInfectionSourceSearchDone : Bool
  focusDocumentedInReport : Bool
  missedFocusRisk : Nat
  gapFromMissingFocusSearch : systematicSonographicInfectionSourceSearchDone = false → focusDocumentedInReport = false → 0 < missedFocusRisk

theorem neonatal_sepsis_focus_infection_ultrasound_gap_exists (a : NeonatalSepsisFocusInfectionUltrasoundGapAssumptions)
    (hSearch : a.systematicSonographicInfectionSourceSearchDone = false) (hDoc : a.focusDocumentedInReport = false) : 0 < a.missedFocusRisk :=
  a.gapFromMissingFocusSearch hSearch hDoc

structure NeonatalSepticArthritisOsteomyelitisDopplerGapAssumptions where
  jointEffusionAssessed : Bool
  metaphysealDopplerPerformed : Bool
  delayedDrainageRisk : Nat
  gapFromMissingJointDoppler : jointEffusionAssessed = false → metaphysealDopplerPerformed = false → 0 < delayedDrainageRisk

theorem neonatal_septic_arthritis_osteomyelitis_doppler_gap_exists (a : NeonatalSepticArthritisOsteomyelitisDopplerGapAssumptions)
    (hJoint : a.jointEffusionAssessed = false) (hDoppler : a.metaphysealDopplerPerformed = false) : 0 < a.delayedDrainageRisk :=
  a.gapFromMissingJointDoppler hJoint hDoppler

structure NeonatalSepticNephritisEchogenicityGapAssumptions where
  renalCorticalEchogenicityDocumented : Bool
  kidneyLengthZScoreRecorded : Bool
  nephritisProgressionRisk : Nat
  gapFromUnassessedKidney : renalCorticalEchogenicityDocumented = false → kidneyLengthZScoreRecorded = false → 0 < nephritisProgressionRisk

theorem neonatal_septic_nephritis_echogenicity_gap_exists (a : NeonatalSepticNephritisEchogenicityGapAssumptions)
    (hEcho : a.renalCorticalEchogenicityDocumented = false) (hZScore : a.kidneyLengthZScoreRecorded = false) : 0 < a.nephritisProgressionRisk :=
  a.gapFromUnassessedKidney hEcho hZScore

structure NeonatalSepsisCardiacEndocarditisGapAssumptions where
  echocardiogramPerformedForSepsis : Bool
  endocarditisVegetationAssessed : Bool
  cardiacComplicationRisk : Nat
  gapFromMissingEcho : echocardiogramPerformedForSepsis = false → endocarditisVegetationAssessed = false → 0 < cardiacComplicationRisk

theorem neonatal_sepsis_cardiac_endocarditis_gap_exists (a : NeonatalSepsisCardiacEndocarditisGapAssumptions)
    (hEcho : a.echocardiogramPerformedForSepsis = false) (hVeg : a.endocarditisVegetationAssessed = false) : 0 < a.cardiacComplicationRisk :=
  a.gapFromMissingEcho hEcho hVeg

structure NeonatalSepsisMDTAntibioticStewardshipGapAssumptions where
  paediatricInfectiousDiseaseConsulted : Bool
  antibioticDurationProtocolFollowed : Bool
  resistanceOrRelapsedSepsisRisk : Nat
  gapFromMissingMDTAndProtocol : paediatricInfectiousDiseaseConsulted = false → antibioticDurationProtocolFollowed = false → 0 < resistanceOrRelapsedSepsisRisk

theorem neonatal_sepsis_mdt_antibiotic_stewardship_gap_exists (a : NeonatalSepsisMDTAntibioticStewardshipGapAssumptions)
    (hID : a.paediatricInfectiousDiseaseConsulted = false) (hProtocol : a.antibioticDurationProtocolFollowed = false) : 0 < a.resistanceOrRelapsedSepsisRisk :=
  a.gapFromMissingMDTAndProtocol hID hProtocol

end ForkRaceFoldTheorems
