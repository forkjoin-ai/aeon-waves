/-!
# UltrasoundNeonatalBronchopulmonarySequestrationDetailedSecurityEconomics

Anti-thesis: neonatal fetal ultrasound reliably characterizes bronchopulmonary
sequestration (BPS) by classifying intralobar/extralobar type and location,
identifying the systemic feeding artery on Doppler, characterizing
pleural/pericardial effusion, calculating CVR/intervention candidacy, and
planning postnatal CTA or hybrid-lesion workup. Management decisions based on
these assessments are clinically sound.

Refutation: each failure mode below proves that the ABSENCE of a systematic
assessment control implies a strictly positive clinical and economic risk.
Zero sorry — all theorems close by exact.
-/

namespace ForkRaceFoldTheorems

-- ── Theorem 1 ────────────────────────────────────────────────────────────────
-- Anti-thesis: BPS type (intralobar vs. extralobar) and anatomical location are
-- NOT systematically classified → surgical planning risk is strictly positive.

structure BPSClassificationLocationGapAssumptions where
  typeClassified : Bool
  locationDocumented : Bool
  surgicalPlanningRisk : Nat
  gapFromMissingClassificationAndLocation :
    typeClassified = false →
    locationDocumented = false →
    0 < surgicalPlanningRisk

theorem bps_classification_location_gap_exists
    (a : BPSClassificationLocationGapAssumptions)
    (hType : a.typeClassified = false)
    (hLoc : a.locationDocumented = false) :
    0 < a.surgicalPlanningRisk :=
  a.gapFromMissingClassificationAndLocation hType hLoc

-- ── Theorem 2 ────────────────────────────────────────────────────────────────
-- Anti-thesis: color Doppler is NOT used to identify and characterize the
-- systemic feeding artery from the aorta → misdiagnosis risk is strictly
-- positive.

structure BPSSystemicFeedingArteryDopplerGapAssumptions where
  dopplerPerformed : Bool
  feedingArteryCharacterized : Bool
  misdiagnosisRisk : Nat
  gapFromMissingDopplerAndArtery :
    dopplerPerformed = false →
    feedingArteryCharacterized = false →
    0 < misdiagnosisRisk

theorem bps_systemic_feeding_artery_doppler_gap_exists
    (a : BPSSystemicFeedingArteryDopplerGapAssumptions)
    (hDoppler : a.dopplerPerformed = false)
    (hArtery : a.feedingArteryCharacterized = false) :
    0 < a.misdiagnosisRisk :=
  a.gapFromMissingDopplerAndArtery hDoppler hArtery

-- ── Theorem 3 ────────────────────────────────────────────────────────────────
-- Anti-thesis: pleural or pericardial effusion secondary to BPS is NOT assessed
-- AND hydrops is NOT evaluated → fetal intervention risk is strictly positive.

structure BPSPleuralEffusionHydropsGapAssumptions where
  pleuralEffusionAssessed : Bool
  hydropsEvaluated : Bool
  interventionRisk : Nat
  gapFromMissingEffusionAndHydrops :
    pleuralEffusionAssessed = false →
    hydropsEvaluated = false →
    0 < interventionRisk

theorem bps_pleural_effusion_hydrops_gap_exists
    (a : BPSPleuralEffusionHydropsGapAssumptions)
    (hEffusion : a.pleuralEffusionAssessed = false)
    (hHydrops : a.hydropsEvaluated = false) :
    0 < a.interventionRisk :=
  a.gapFromMissingEffusionAndHydrops hEffusion hHydrops

-- ── Theorem 4 ────────────────────────────────────────────────────────────────
-- Anti-thesis: CVR is NOT calculated AND fetal intervention candidacy (sclerotherapy
-- or thoracoamniotic shunting) is NOT assessed → delivery-plan risk is strictly
-- positive.

structure BPSCVRInterventionCandidacyGapAssumptions where
  cvrCalculated : Bool
  interventionCandidacyAssessed : Bool
  deliveryPlanRisk : Nat
  gapFromMissingCVRAndCandidacy :
    cvrCalculated = false →
    interventionCandidacyAssessed = false →
    0 < deliveryPlanRisk

theorem bps_cvr_intervention_candidacy_gap_exists
    (a : BPSCVRInterventionCandidacyGapAssumptions)
    (hCVR : a.cvrCalculated = false)
    (hCandidacy : a.interventionCandidacyAssessed = false) :
    0 < a.deliveryPlanRisk :=
  a.gapFromMissingCVRAndCandidacy hCVR hCandidacy

-- ── Theorem 5 ────────────────────────────────────────────────────────────────
-- Anti-thesis: postnatal CTA to confirm the feeding artery is NOT planned AND
-- hybrid sequestration-CPAM lesion workup is NOT coordinated → postnatal
-- management risk is strictly positive.

structure BPSPostnatalCTAHybridLesionGapAssumptions where
  postnatalCTAPlanned : Bool
  hybridLesionWorkupCoordinated : Bool
  managementRisk : Nat
  gapFromMissingCTAAndHybridWorkup :
    postnatalCTAPlanned = false →
    hybridLesionWorkupCoordinated = false →
    0 < managementRisk

theorem bps_postnatal_cta_hybrid_lesion_gap_exists
    (a : BPSPostnatalCTAHybridLesionGapAssumptions)
    (hCTA : a.postnatalCTAPlanned = false)
    (hHybrid : a.hybridLesionWorkupCoordinated = false) :
    0 < a.managementRisk :=
  a.gapFromMissingCTAAndHybridWorkup hCTA hHybrid

end ForkRaceFoldTheorems
