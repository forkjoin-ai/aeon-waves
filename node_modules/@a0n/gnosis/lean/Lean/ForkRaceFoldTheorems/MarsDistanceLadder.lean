import Init

/-!
# Mars distance ladder: monotonicity and the dominance theorem

Formal backing for "anything that works for Mars works for somewhere less than
Mars". Distance is monotone in everything that matters: free-space path loss
(proxy d^2), one-way light time (d / c), and the round-trip the cache-key teleport
avoids (2 * d / c). Therefore a link that closes at a far rung closes at every
nearer rung -- we prove the hard rung and relay the proof down the ladder.

Modeled over `Nat` distances / `Int` margins so the file stays `Init`-only
(no mathlib), mirroring the runtime sweep in `rtlsdr-mock-sim/distance-ladder.ts`
(`marginMonotoneNonIncreasing`, `savingMonotoneNonDecreasing`).
-/

namespace ForkRaceFoldTheorems
namespace MarsDistanceLadder

/-- One-way light time `d / c` is monotone (non-decreasing) in distance. -/
theorem light_time_monotone_in_distance (c d1 d2 : Nat) (h : d1 â‰¤ d2) :
    d1 / c â‰¤ d2 / c :=
  Nat.div_le_div_right h

/-- The round-trip `2 * (d / c)` the teleport avoids is monotone in distance. -/
theorem round_trip_monotone_in_distance (c d1 d2 : Nat) (h : d1 â‰¤ d2) :
    2 * (d1 / c) â‰¤ 2 * (d2 / c) :=
  Nat.mul_le_mul (Nat.le_refl 2) (Nat.div_le_div_right h)

/-- Teleport saving = the avoided round-trip; non-decreasing in distance. -/
theorem teleport_savings_monotone_in_distance (c d1 d2 : Nat) (h : d1 â‰¤ d2) :
    2 * (d1 / c) â‰¤ 2 * (d2 / c) :=
  round_trip_monotone_in_distance c d1 d2 h

/-- Free-space path-loss proxy `d^2` is monotone increasing in distance. -/
theorem friis_loss_monotone_in_distance (d1 d2 : Nat) (h : d1 â‰¤ d2) :
    d1 * d1 â‰¤ d2 * d2 :=
  Nat.mul_le_mul h h

/-- Link margin: a fixed budget minus a distance-dependent loss. -/
def margin (budget : Int) (loss : Nat â†’ Nat) (d : Nat) : Int :=
  budget - (loss d : Int)

/-- The link "closes" at distance `d` when its margin is non-negative. -/
def closes (budget : Int) (loss : Nat â†’ Nat) (d : Nat) : Prop :=
  margin budget loss d â‰¥ 0

/-- If loss is monotone increasing in distance, margin is antitone in distance. -/
theorem margin_antitone_of_loss_monotone
    (budget : Int) (loss : Nat â†’ Nat)
    (mono : âˆ€ a b, a â‰¤ b â†’ loss a â‰¤ loss b)
    (d1 d2 : Nat) (h : d1 â‰¤ d2) :
    margin budget loss d2 â‰¤ margin budget loss d1 := by
  have hm : loss d1 â‰¤ loss d2 := mono d1 d2 h
  unfold margin
  exact Int.sub_le_sub_left (Int.ofNat_le.mpr hm) budget

/-- The dominance theorem: if the link closes at `dmax` (loss monotone), it closes
    at every nearer rung `d â‰¤ dmax`. "Works at Mars â‡’ works at everything nearer." -/
theorem margin_closes_at_dmax_implies_closes_below
    (budget : Int) (loss : Nat â†’ Nat)
    (mono : âˆ€ a b, a â‰¤ b â†’ loss a â‰¤ loss b)
    (dmax d : Nat) (hle : d â‰¤ dmax)
    (hclose : closes budget loss dmax) :
    closes budget loss d := by
  have hanti := margin_antitone_of_loss_monotone budget loss mono d dmax hle
  unfold closes at hclose âŠ¢
  exact Int.le_trans hclose hanti

end MarsDistanceLadder
end ForkRaceFoldTheorems
