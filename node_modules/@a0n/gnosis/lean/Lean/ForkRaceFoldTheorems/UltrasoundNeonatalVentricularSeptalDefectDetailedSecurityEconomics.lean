/-!
# UltrasoundNeonatalVentricularSeptalDefectDetailedSecurityEconomics

Neonatal ventricular septal defect (VSD): left-to-right shunt at the
ventricular level, ranging from restrictive perimembranous VSD to large
malalignment, inlet, or muscular defects. Five security-economics gap
theorems for clinical imaging gaps that constitute missed-diagnosis risk —
each with measurable economic (medico-legal / readmission) cost.

Anti-thesis pattern: structure posits the ABSENCE of an imaging assessment,
theorem derives strictly-positive risk. Zero sorry — all close by exact.
-/

namespace ForkRaceFoldTheorems

-- ── Theorem 1 ────────────────────────────────────────────────────────────────
-- Anti-thesis: VSD anatomical subtype NOT classified (perimembranous / inlet /
-- outlet / muscular) AND defect size NOT measured relative to aortic annulus
-- → incorrect interventional approach risk is strictly positive.

structure VSDSubtypeSizeGapAssumptions where
  subtypeClassified : Bool
  defectSizeRelativeToAorticAnnulusMeasured : Bool
  interventionalApproachRisk : Nat
  gapFromUnclassifiedSubtypeAndSize :
    subtypeClassified = false →
    defectSizeRelativeToAorticAnnulusMeasured = false →
    0 < interventionalApproachRisk

theorem vsd_subtype_size_gap_exists
    (a : VSDSubtypeSizeGapAssumptions)
    (hSubtype : a.subtypeClassified = false)
    (hSize : a.defectSizeRelativeToAorticAnnulusMeasured = false) :
    0 < a.interventionalApproachRisk :=
  a.gapFromUnclassifiedSubtypeAndSize hSubtype hSize

-- ── Theorem 2 ────────────────────────────────────────────────────────────────
-- Anti-thesis: pulmonary-to-systemic flow ratio (Qp:Qs) NOT measured AND
-- pulmonary artery pressure NOT estimated from VSD peak Doppler gradient →
-- haemodynamic significance misclassification risk is strictly positive.

structure VSDQpQsPAPressureGapAssumptions where
  qpQsMeasured : Bool
  paPressureEstimatedFromVSD : Bool
  haemodynamicSignificanceRisk : Nat
  gapFromUnmeasuredQpQsAndPressure :
    qpQsMeasured = false →
    paPressureEstimatedFromVSD = false →
    0 < haemodynamicSignificanceRisk

theorem vsd_qpqs_pa_pressure_gap_exists
    (a : VSDQpQsPAPressureGapAssumptions)
    (hQpQs : a.qpQsMeasured = false)
    (hPA : a.paPressureEstimatedFromVSD = false) :
    0 < a.haemodynamicSignificanceRisk :=
  a.gapFromUnmeasuredQpQsAndPressure hQpQs hPA

-- ── Theorem 3 ────────────────────────────────────────────────────────────────
-- Anti-thesis: aortic valve prolapse associated with outlet VSD NOT assessed
-- AND aortic regurgitation severity NOT graded → post-repair aortic
-- insufficiency risk is strictly positive.

structure AorticProlapsARGradingGapAssumptions where
  aorticProlapsAssessed : Bool
  arSeverityGraded : Bool
  postRepairAorticInsufficiencyRisk : Nat
  gapFromUnassessedProlapsAndAR :
    aorticProlapsAssessed = false →
    arSeverityGraded = false →
    0 < postRepairAorticInsufficiencyRisk

theorem aortic_prolaps_ar_grading_gap_exists
    (a : AorticProlapsARGradingGapAssumptions)
    (hProlaps : a.aorticProlapsAssessed = false)
    (hAR : a.arSeverityGraded = false) :
    0 < a.postRepairAorticInsufficiencyRisk :=
  a.gapFromUnassessedProlapsAndAR hProlaps hAR

-- ── Theorem 4 ────────────────────────────────────────────────────────────────
-- Anti-thesis: left ventricular volume overload NOT quantified by LV
-- end-diastolic dimension Z-score AND left atrial enlargement NOT measured →
-- failure-to-thrive readmission risk is strictly positive.

structure LVVolumeOverloadLAEnlargementGapAssumptions where
  lvEddzScoreCalculated : Bool
  leftAtrialEnlargementMeasured : Bool
  readmissionRisk : Nat
  gapFromUncalculatedLVAndLAE :
    lvEddzScoreCalculated = false →
    leftAtrialEnlargementMeasured = false →
    0 < readmissionRisk

theorem lv_volume_overload_la_enlargement_gap_exists
    (a : LVVolumeOverloadLAEnlargementGapAssumptions)
    (hLV : a.lvEddzScoreCalculated = false)
    (hLAE : a.leftAtrialEnlargementMeasured = false) :
    0 < a.readmissionRisk :=
  a.gapFromUncalculatedLVAndLAE hLV hLAE

-- ── Theorem 5 ────────────────────────────────────────────────────────────────
-- Anti-thesis: associated conotruncal anomalies (DORV alignment, TOF-type
-- malalignment) NOT excluded AND right ventricular outflow tract obstruction
-- NOT quantified → unrecognised complex CHD risk is strictly positive.

structure ConotruncalAnomalyRVOTGapAssumptions where
  conotruncalAnomalyExcluded : Bool
  rvotObstructionQuantified : Bool
  unrecognisedComplexCHDRisk : Nat
  gapFromUnexcludedConotruncalAndRVOT :
    conotruncalAnomalyExcluded = false →
    rvotObstructionQuantified = false →
    0 < unrecognisedComplexCHDRisk

theorem conotruncal_anomaly_rvot_gap_exists
    (a : ConotruncalAnomalyRVOTGapAssumptions)
    (hCono : a.conotruncalAnomalyExcluded = false)
    (hRVOT : a.rvotObstructionQuantified = false) :
    0 < a.unrecognisedComplexCHDRisk :=
  a.gapFromUnexcludedConotruncalAndRVOT hCono hRVOT

end ForkRaceFoldTheorems
