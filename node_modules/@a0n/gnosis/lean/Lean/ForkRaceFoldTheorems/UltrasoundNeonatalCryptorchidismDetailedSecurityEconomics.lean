/-!
# UltrasoundNeonatalCryptorchidismDetailedSecurityEconomics

Neonatal scrotal/inguinal ultrasound — cryptorchidism (undescended testis).
Security-economics gap theorems derived from absent diagnostic controls.

Anti-thesis pattern: each structure posits the ABSENCE of a required
measurement or finding, then derives a positive risk quantity.
Zero sorry — all theorems close by exact.
-/

namespace ForkRaceFoldTheorems

-- ── Theorem 1 ────────────────────────────────────────────────────────────────
-- Anti-thesis: testicular position, length, width, and depth are NOT measured
-- AND the inguinal canal and scrotum are not systematically surveyed →
-- localisation gap is strictly positive.

structure CryptorchidismLocalisationGapAssumptions where
  testisPositionMeasured : Bool
  inguinalCanalSurveyed : Bool
  localisationGap : Nat
  gapFromMissingLocalisation :
    testisPositionMeasured = false →
    inguinalCanalSurveyed = false →
    0 < localisationGap

theorem cryptorchidism_localisation_gap_exists
    (a : CryptorchidismLocalisationGapAssumptions)
    (hPos : a.testisPositionMeasured = false)
    (hCanal : a.inguinalCanalSurveyed = false) :
    0 < a.localisationGap :=
  a.gapFromMissingLocalisation hPos hCanal

-- ── Theorem 2 ────────────────────────────────────────────────────────────────
-- Anti-thesis: testicular echogenicity and parenchymal texture are NOT compared
-- to the contralateral descended testis AND volume discrepancy is not quantified
-- → atrophy-risk assessment gap is strictly positive.

structure CryptorchidismAtrophyRiskGapAssumptions where
  echogenicityCompared : Bool
  volumeDiscrepancyQuantified : Bool
  atrophyRiskGap : Nat
  gapFromMissingAtrophyData :
    echogenicityCompared = false →
    volumeDiscrepancyQuantified = false →
    0 < atrophyRiskGap

theorem cryptorchidism_atrophy_risk_gap_exists
    (a : CryptorchidismAtrophyRiskGapAssumptions)
    (hEcho : a.echogenicityCompared = false)
    (hVol : a.volumeDiscrepancyQuantified = false) :
    0 < a.atrophyRiskGap :=
  a.gapFromMissingAtrophyData hEcho hVol

-- ── Theorem 3 ────────────────────────────────────────────────────────────────
-- Anti-thesis: colour Doppler testicular blood flow is NOT assessed AND torsion
-- risk indicators are not documented → torsion-risk gap is strictly positive.

structure CryptorchidismTorsionRiskGapAssumptions where
  colorDopplerAssessed : Bool
  torsionRiskDocumented : Bool
  torsionRiskGap : Nat
  gapFromMissingTorsionData :
    colorDopplerAssessed = false →
    torsionRiskDocumented = false →
    0 < torsionRiskGap

theorem cryptorchidism_torsion_risk_gap_exists
    (a : CryptorchidismTorsionRiskGapAssumptions)
    (hDoppler : a.colorDopplerAssessed = false)
    (hTorsion : a.torsionRiskDocumented = false) :
    0 < a.torsionRiskGap :=
  a.gapFromMissingTorsionData hDoppler hTorsion

-- ── Theorem 4 ────────────────────────────────────────────────────────────────
-- Anti-thesis: associated inguinal hernia, epididymis morphology, and vas
-- deferens continuity are NOT documented → anatomical-completeness gap is
-- strictly positive.

structure CryptorchidismAnatomicalCompletenessGapAssumptions where
  inguinalHerniaExcluded : Bool
  epididymisDocumented : Bool
  anatomicalCompletenessGap : Nat
  gapFromMissingAnatomicalData :
    inguinalHerniaExcluded = false →
    epididymisDocumented = false →
    0 < anatomicalCompletenessGap

theorem cryptorchidism_anatomical_completeness_gap_exists
    (a : CryptorchidismAnatomicalCompletenessGapAssumptions)
    (hHernia : a.inguinalHerniaExcluded = false)
    (hEpididymis : a.epididymisDocumented = false) :
    0 < a.anatomicalCompletenessGap :=
  a.gapFromMissingAnatomicalData hHernia hEpididymis

-- ── Theorem 5 ────────────────────────────────────────────────────────────────
-- Anti-thesis: no orchidopexy referral timeline is documented AND no follow-up
-- ultrasound interval for non-palpable testis is specified → surgical-referral
-- gap is strictly positive.

structure CryptorchidismSurgicalReferralGapAssumptions where
  orchidopexyReferralDocumented : Bool
  followUpIntervalSpecified : Bool
  surgicalReferralGap : Nat
  gapFromMissingReferral :
    orchidopexyReferralDocumented = false →
    followUpIntervalSpecified = false →
    0 < surgicalReferralGap

theorem cryptorchidism_surgical_referral_gap_exists
    (a : CryptorchidismSurgicalReferralGapAssumptions)
    (hReferral : a.orchidopexyReferralDocumented = false)
    (hInterval : a.followUpIntervalSpecified = false) :
    0 < a.surgicalReferralGap :=
  a.gapFromMissingReferral hReferral hInterval

end ForkRaceFoldTheorems
