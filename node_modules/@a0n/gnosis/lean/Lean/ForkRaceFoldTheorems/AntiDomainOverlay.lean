namespace ForkRaceFoldTheorems
namespace AntiDomainOverlay

/-- A spatial region of positive size. -/
structure Region where
  size : Nat
  hPositive : 0 < size

/-- An overlay of non-negative size. -/
structure Overlay where
  size : Nat

/-- Every point in the region is guaranteed to be hit. -/
def enclosedHitCount (r : Region) : Nat :=
  r.size

/-- Net hits after applying an overlay is `r.size - ov.size` with Nat-truncation. -/
def netHitCount (r : Region) (ov : Overlay) : Nat :=
  r.size - ov.size

/-- The property that an overlay cancels locally. -/
theorem overlayCancelsLocally (r : Region) (ov : Overlay) :
    netHitCount r ov = r.size - ov.size := by
  rfl

/-- Two overlays with additive-disjoint supports compose by summing sizes. -/
def stackOverlays (ov1 ov2 : Overlay) : Overlay :=
  { size := ov1.size + ov2.size }

/-- Orthogonal overlays stack additively. -/
theorem orthogonalOverlaysStackAdditively (ov1 ov2 : Overlay) :
    (stackOverlays ov1 ov2).size = ov1.size + ov2.size := by
  rfl

end AntiDomainOverlay
end ForkRaceFoldTheorems
