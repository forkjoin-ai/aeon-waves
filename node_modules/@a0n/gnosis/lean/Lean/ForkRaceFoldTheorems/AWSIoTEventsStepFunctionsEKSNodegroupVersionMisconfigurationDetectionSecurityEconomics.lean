/-!
# AWSIoTEventsStepFunctionsEKSNodegroupVersionMisconfigurationDetectionSecurityEconomics

EKS managed node group Kubernetes version management misconfiguration
detection security-economics. Five gap theorems: each proves that absence of
a specific control creates strictly-positive compliance or revenue-at-risk
exposure.

Anti-thesis pattern: structure posits absence of a control, theorem derives
strictly-positive risk. Zero sorry — all close by exact.
-/

namespace ForkRaceFoldTheorems

-- ── Theorem 1 ────────────────────────────────────────────────────────────────
-- Anti-thesis: EKS nodegroup Kubernetes version is NOT pinned to the cluster
-- control-plane version AND no customer-managed KMS key governs the encrypted
-- launch template → version-skew compliance gap is strictly positive.

structure NodegroupVersionPinCMKGapAssumptions where
  versionPinnedToControlPlane : Bool
  launchTemplateCMKEncrypted : Bool
  complianceRisk : Nat
  gapFromUnpinnedVersionAndCMK :
    versionPinnedToControlPlane = false →
    launchTemplateCMKEncrypted = false →
    0 < complianceRisk

theorem nodegroup_version_pin_cmk_gap_exists
    (a : NodegroupVersionPinCMKGapAssumptions)
    (hPin : a.versionPinnedToControlPlane = false)
    (hCMK : a.launchTemplateCMKEncrypted = false) :
    0 < a.complianceRisk :=
  a.gapFromUnpinnedVersionAndCMK hPin hCMK

-- ── Theorem 2 ────────────────────────────────────────────────────────────────
-- Anti-thesis: end-of-life Kubernetes version is still running on the
-- nodegroup AND no automated upgrade pipeline exists → CVE-exposure revenue
-- risk is strictly positive.

structure EOLVersionUpgradePipelineGapAssumptions where
  versionCurrentlySupported : Bool
  automatedUpgradePipelineExists : Bool
  cveExposureRisk : Nat
  gapFromEOLVersionAndMissingPipeline :
    versionCurrentlySupported = false →
    automatedUpgradePipelineExists = false →
    0 < cveExposureRisk

theorem eol_version_upgrade_pipeline_gap_exists
    (a : EOLVersionUpgradePipelineGapAssumptions)
    (hEOL : a.versionCurrentlySupported = false)
    (hPipeline : a.automatedUpgradePipelineExists = false) :
    0 < a.cveExposureRisk :=
  a.gapFromEOLVersionAndMissingPipeline hEOL hPipeline

-- ── Theorem 3 ────────────────────────────────────────────────────────────────
-- Anti-thesis: the IAM role authorising nodegroup version updates is NOT
-- scoped to the specific cluster and node group → cross-cluster version
-- downgrade risk is strictly positive.

structure NodegroupVersionIAMScopeGapAssumptions where
  iamRoleScopedToClusterAndNodegroup : Bool
  crossClusterDowngradeRisk : Nat
  gapFromUnscopedRole :
    iamRoleScopedToClusterAndNodegroup = false → 0 < crossClusterDowngradeRisk

theorem nodegroup_version_iam_scope_gap_exists
    (a : NodegroupVersionIAMScopeGapAssumptions)
    (h : a.iamRoleScopedToClusterAndNodegroup = false) :
    0 < a.crossClusterDowngradeRisk :=
  a.gapFromUnscopedRole h

-- ── Theorem 4 ────────────────────────────────────────────────────────────────
-- Anti-thesis: no CloudWatch alarm fires when nodegroup Kubernetes version
-- diverges from the control-plane version by more than one minor version AND
-- the SOC has no runbook for version-skew → SOC gap is strictly positive.

structure VersionSkewAlarmSOCGapAssumptions where
  versionSkewAlarmConfigured : Bool
  socRunbookExists : Bool
  socGap : Nat
  gapFromMissingSkewAlarmAndRunbook :
    versionSkewAlarmConfigured = false →
    socRunbookExists = false →
    0 < socGap

theorem version_skew_alarm_soc_gap_exists
    (a : VersionSkewAlarmSOCGapAssumptions)
    (hAlarm : a.versionSkewAlarmConfigured = false)
    (hRunbook : a.socRunbookExists = false) :
    0 < a.socGap :=
  a.gapFromMissingSkewAlarmAndRunbook hAlarm hRunbook

-- ── Theorem 5 ────────────────────────────────────────────────────────────────
-- Anti-thesis: AWS X-Ray active tracing is NOT enabled on the EKS version-
-- update API call path AND version-update events are not logged to CloudTrail
-- → observability gap is strictly positive.

structure NodegroupVersionXRayGapAssumptions where
  xRayTracingEnabled : Bool
  cloudTrailLoggingEnabled : Bool
  observabilityGap : Nat
  gapFromMissingXRayAndCloudTrail :
    xRayTracingEnabled = false →
    cloudTrailLoggingEnabled = false →
    0 < observabilityGap

theorem nodegroup_version_xray_gap_exists
    (a : NodegroupVersionXRayGapAssumptions)
    (hXRay : a.xRayTracingEnabled = false)
    (hTrail : a.cloudTrailLoggingEnabled = false) :
    0 < a.observabilityGap :=
  a.gapFromMissingXRayAndCloudTrail hXRay hTrail

end ForkRaceFoldTheorems
