namespace ForkRaceFoldTheorems

structure VPCEndpointPolicyEncryptionGapAssumptions where
  vpcEndpointPolicyScopedToPrincipal : Bool
  complianceRisk : Nat
  gapFromUnscopedEndpointPolicy : vpcEndpointPolicyScopedToPrincipal = false → 0 < complianceRisk

theorem vpc_endpoint_policy_encryption_gap_exists (a : VPCEndpointPolicyEncryptionGapAssumptions)
    (h : a.vpcEndpointPolicyScopedToPrincipal = false) : 0 < a.complianceRisk :=
  a.gapFromUnscopedEndpointPolicy h

structure VPCEndpointSCPConfigDeletionGapAssumptions where
  scpBlocksEndpointDeletion : Bool
  configDetectsEndpointChange : Bool
  dataExfiltrationRisk : Nat
  gapFromMissingSCPAndConfig : scpBlocksEndpointDeletion = false → configDetectsEndpointChange = false → 0 < dataExfiltrationRisk

theorem vpc_endpoint_scp_config_deletion_gap_exists (a : VPCEndpointSCPConfigDeletionGapAssumptions)
    (hSCP : a.scpBlocksEndpointDeletion = false) (hConfig : a.configDetectsEndpointChange = false) : 0 < a.dataExfiltrationRisk :=
  a.gapFromMissingSCPAndConfig hSCP hConfig

structure VPCEndpointIAMScopeGapAssumptions where
  endpointIAMScopedToVPC : Bool
  crossAccountEndpointAudited : Bool
  serviceHijackRisk : Nat
  gapFromUnscopedEndpointIAM : endpointIAMScopedToVPC = false → crossAccountEndpointAudited = false → 0 < serviceHijackRisk

theorem vpc_endpoint_iam_scope_gap_exists (a : VPCEndpointIAMScopeGapAssumptions)
    (hScope : a.endpointIAMScopedToVPC = false) (hAudit : a.crossAccountEndpointAudited = false) : 0 < a.serviceHijackRisk :=
  a.gapFromUnscopedEndpointIAM hScope hAudit

structure VPCEndpointPolicyChangeAlarmSOCGapAssumptions where
  endpointPolicyChangeAlarmConfigured : Bool
  socRunbookExists : Bool
  socGap : Nat
  gapFromMissingAlarmAndRunbook : endpointPolicyChangeAlarmConfigured = false → socRunbookExists = false → 0 < socGap

theorem vpc_endpoint_policy_change_alarm_soc_gap_exists (a : VPCEndpointPolicyChangeAlarmSOCGapAssumptions)
    (hAlarm : a.endpointPolicyChangeAlarmConfigured = false) (hRunbook : a.socRunbookExists = false) : 0 < a.socGap :=
  a.gapFromMissingAlarmAndRunbook hAlarm hRunbook

structure VPCEndpointXRayCloudTrailGapAssumptions where
  xRayTracingEnabled : Bool
  cloudTrailEndpointEventsEnabled : Bool
  observabilityGap : Nat
  gapFromMissingXRayAndCloudTrail : xRayTracingEnabled = false → cloudTrailEndpointEventsEnabled = false → 0 < observabilityGap

theorem vpc_endpoint_xray_cloudtrail_gap_exists (a : VPCEndpointXRayCloudTrailGapAssumptions)
    (hXRay : a.xRayTracingEnabled = false) (hCT : a.cloudTrailEndpointEventsEnabled = false) : 0 < a.observabilityGap :=
  a.gapFromMissingXRayAndCloudTrail hXRay hCT

end ForkRaceFoldTheorems
