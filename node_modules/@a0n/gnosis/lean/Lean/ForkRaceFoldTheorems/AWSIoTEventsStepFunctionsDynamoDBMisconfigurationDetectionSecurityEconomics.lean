/-!
# AWSIoTEventsStepFunctionsDynamoDBMisconfigurationDetectionSecurityEconomics

AWS IoT Events + Step Functions → DynamoDB misconfiguration detection.
Security-economics gap theorems: five proofs that absence of controls
creates measurable revenue-at-risk or compliance exposure.

Anti-thesis pattern: each structure posits the ABSENCE of a control, then
derives a positive risk quantity. Zero sorry — all theorems close by exact.
-/

namespace ForkRaceFoldTheorems

-- ── Theorem 1 ────────────────────────────────────────────────────────────────
-- Anti-thesis: DynamoDB table is NOT encrypted at rest with a customer-managed
-- KMS key → compliance gap is strictly positive.

structure DynamoDBCMKGapAssumptions where
  tableEncryptedWithCMK : Bool
  complianceRisk : Nat
  gapFromMissingCMK : tableEncryptedWithCMK = false → 0 < complianceRisk

theorem dynamodb_cmk_gap_exists
    (a : DynamoDBCMKGapAssumptions)
    (h : a.tableEncryptedWithCMK = false) :
    0 < a.complianceRisk :=
  a.gapFromMissingCMK h

-- ── Theorem 2 ────────────────────────────────────────────────────────────────
-- Anti-thesis: DynamoDB Point-in-Time Recovery is NOT enabled AND no SCP
-- prevents table deletion → data-loss risk is strictly positive.

structure DynamoDBPITRSCPGapAssumptions where
  pitrEnabled : Bool
  scpPreventsDeletion : Bool
  dataLossRisk : Nat
  riskFromMissingRecovery :
    pitrEnabled = false →
    scpPreventsDeletion = false →
    0 < dataLossRisk

theorem dynamodb_pitr_scp_gap_exists
    (a : DynamoDBPITRSCPGapAssumptions)
    (hPITR : a.pitrEnabled = false)
    (hSCP : a.scpPreventsDeletion = false) :
    0 < a.dataLossRisk :=
  a.riskFromMissingRecovery hPITR hSCP

-- ── Theorem 3 ────────────────────────────────────────────────────────────────
-- Anti-thesis: Step Functions state-machine IAM role is not scoped to the
-- specific DynamoDB table ARN → role-poisoning gap is strictly positive.

structure DynamoDBIAMRoleScopeGapAssumptions where
  iamRoleScopedToTable : Bool
  poisoningRisk : Nat
  gapFromUnscopedRole : iamRoleScopedToTable = false → 0 < poisoningRisk

theorem dynamodb_iam_role_scope_gap_exists
    (a : DynamoDBIAMRoleScopeGapAssumptions)
    (h : a.iamRoleScopedToTable = false) :
    0 < a.poisoningRisk :=
  a.gapFromUnscopedRole h

-- ── Theorem 4 ────────────────────────────────────────────────────────────────
-- Anti-thesis: no CloudWatch alarm fires on DynamoDB throttled-requests AND
-- the SOC has no runbook for capacity breach remediation → SOC gap is strictly
-- positive.

structure DynamoDBThrottleAlarmSOCGapAssumptions where
  throttleAlarmConfigured : Bool
  socRunbookExists : Bool
  socGap : Nat
  gapFromMissingAlarmAndRunbook :
    throttleAlarmConfigured = false →
    socRunbookExists = false →
    0 < socGap

theorem dynamodb_throttle_alarm_soc_gap_exists
    (a : DynamoDBThrottleAlarmSOCGapAssumptions)
    (hAlarm : a.throttleAlarmConfigured = false)
    (hRunbook : a.socRunbookExists = false) :
    0 < a.socGap :=
  a.gapFromMissingAlarmAndRunbook hAlarm hRunbook

-- ── Theorem 5 ────────────────────────────────────────────────────────────────
-- Anti-thesis: AWS X-Ray active tracing is NOT enabled on the Step Functions →
-- DynamoDB access path AND DynamoDB Streams changes are not captured in
-- CloudTrail → observability gap is strictly positive.

structure DynamoDBXRayStreamsGapAssumptions where
  xRayTracingEnabled : Bool
  dynamoDBStreamsCloudTrailEnabled : Bool
  observabilityGap : Nat
  gapFromMissingXRayAndStreams :
    xRayTracingEnabled = false →
    dynamoDBStreamsCloudTrailEnabled = false →
    0 < observabilityGap

theorem dynamodb_xray_streams_gap_exists
    (a : DynamoDBXRayStreamsGapAssumptions)
    (hXRay : a.xRayTracingEnabled = false)
    (hStreams : a.dynamoDBStreamsCloudTrailEnabled = false) :
    0 < a.observabilityGap :=
  a.gapFromMissingXRayAndStreams hXRay hStreams

end ForkRaceFoldTheorems
