namespace ForkRaceFoldTheorems

structure DirectConnectVirtualInterfaceCMKGapAssumptions where
  dxTrafficEncryptedWithMACsec : Bool
  complianceRisk : Nat
  gapFromMissingMACsec : dxTrafficEncryptedWithMACsec = false → 0 < complianceRisk

theorem direct_connect_virtual_interface_cmk_gap_exists (a : DirectConnectVirtualInterfaceCMKGapAssumptions)
    (h : a.dxTrafficEncryptedWithMACsec = false) : 0 < a.complianceRisk :=
  a.gapFromMissingMACsec h

structure DirectConnectSCPConfigDeletionGapAssumptions where
  scpBlocksDXConnectionDeletion : Bool
  configDetectsDXChange : Bool
  connectivityLossRisk : Nat
  gapFromMissingSCPAndConfig : scpBlocksDXConnectionDeletion = false → configDetectsDXChange = false → 0 < connectivityLossRisk

theorem direct_connect_scp_config_deletion_gap_exists (a : DirectConnectSCPConfigDeletionGapAssumptions)
    (hSCP : a.scpBlocksDXConnectionDeletion = false) (hConfig : a.configDetectsDXChange = false) : 0 < a.connectivityLossRisk :=
  a.gapFromMissingSCPAndConfig hSCP hConfig

structure DirectConnectVIFIAMScopeGapAssumptions where
  dxIAMScopedToAccount : Bool
  crossAccountVIFAudited : Bool
  unauthorisedPeeringRisk : Nat
  gapFromUnscopedDXIAM : dxIAMScopedToAccount = false → crossAccountVIFAudited = false → 0 < unauthorisedPeeringRisk

theorem direct_connect_vif_iam_scope_gap_exists (a : DirectConnectVIFIAMScopeGapAssumptions)
    (hScope : a.dxIAMScopedToAccount = false) (hAudit : a.crossAccountVIFAudited = false) : 0 < a.unauthorisedPeeringRisk :=
  a.gapFromUnscopedDXIAM hScope hAudit

structure DirectConnectBGPFlappingAlarmSOCGapAssumptions where
  bgpFlappingAlarmConfigured : Bool
  socRunbookExists : Bool
  socGap : Nat
  gapFromMissingAlarmAndRunbook : bgpFlappingAlarmConfigured = false → socRunbookExists = false → 0 < socGap

theorem direct_connect_bgp_flapping_alarm_soc_gap_exists (a : DirectConnectBGPFlappingAlarmSOCGapAssumptions)
    (hAlarm : a.bgpFlappingAlarmConfigured = false) (hRunbook : a.socRunbookExists = false) : 0 < a.socGap :=
  a.gapFromMissingAlarmAndRunbook hAlarm hRunbook

structure DirectConnectXRayCloudTrailGapAssumptions where
  xRayTracingEnabled : Bool
  cloudTrailDXEventsEnabled : Bool
  observabilityGap : Nat
  gapFromMissingXRayAndCloudTrail : xRayTracingEnabled = false → cloudTrailDXEventsEnabled = false → 0 < observabilityGap

theorem direct_connect_xray_cloudtrail_gap_exists (a : DirectConnectXRayCloudTrailGapAssumptions)
    (hXRay : a.xRayTracingEnabled = false) (hCT : a.cloudTrailDXEventsEnabled = false) : 0 < a.observabilityGap :=
  a.gapFromMissingXRayAndCloudTrail hXRay hCT

end ForkRaceFoldTheorems
