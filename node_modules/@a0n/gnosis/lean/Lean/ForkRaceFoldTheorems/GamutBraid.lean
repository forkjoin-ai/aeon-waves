    (h : pressureCertifiedExecutionPathCertified path cycle) :
    path.pressureWeightedInterferenceTotal = 2586 /\
      path.informationMassTotal = 1560 /\
      path.leakageTotal = 96 := by
  exact And.intro h.weightedTotalValue
    (And.intro h.informationMassValue h.leakageValue)

/-- Certified execution paths force the 30210 SPa closure-family checksum. -/
