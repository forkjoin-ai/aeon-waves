/--
The distance from exact 43/55 admission is exactly the local bucket stride
multiplied by the number of closure-family steps after the first member.
-/
theorem indexed_interfere_closure_distance_from_exact_admission
    (closureIndex : Nat) :
    indexedInterfereClosureDistanceFromExactAdmission closureIndex =
      (closureIndex - firstInterfereClosureFamilyIndex) * bucketSize := by
  have hshape :
      indexedInterfereClosureDistanceFromExactAdmission closureIndex =
        (43 + closureIndex * bucketSize) - 55 := by
    unfold indexedInterfereClosureDistanceFromExactAdmission indexedInterfereClosureCoordinate
    rw [show interferePortCoordinate = 43 from rfl,
      show interferePortClosureCoordinate = 55 from rfl]
  rw [hshape, show firstInterfereClosureFamilyIndex = 1 from rfl]
  rw [show bucketSize = 12 from rfl]
  cases closureIndex with
  | zero =>
    rfl
  | succ k =>
    rw [Nat.succ_mul k 12]
    rw [← Nat.add_assoc 43]
    rw [Nat.add_comm 43 (k * 12)]
    rw [Nat.add_assoc (k * 12)]
    rw [show 43 + 12 = 55 from rfl]
    rw [Nat.add_comm (k * 12) 55]
    rw [Nat.add_sub_cancel_left]
    simp only [Nat.succ_sub_succ, Nat.sub_zero]

/-- Later closure-family members have positive distance from exact 43/55 admission. -/
theorem indexed_interfere_closure_distance_positive_for_later
    {closureIndex : Nat}
    (h : firstInterfereClosureFamilyIndex < closureIndex) :
    0 < indexedInterfereClosureDistanceFromExactAdmission closureIndex := by
  have hd :=
    indexed_interfere_closure_distance_from_exact_admission closureIndex
  rw [hd]
  have hk : 0 < closureIndex - firstInterfereClosureFamilyIndex := by
    unfold firstInterfereClosureFamilyIndex at h ⊢
    exact Nat.sub_pos_of_lt h
  exact Nat.mul_pos hk (Nat.succ_pos 11)

