/-- Predicate alias for pressure-certified execution path certification. -/
def pressureCertifiedExecutionPathCertified
    (path : PressureCertifiedExecutionPath)
    (cycle : Nat) : Prop :=
  PressureCertifiedExecutionPathCertificate path cycle

/-- The exact runtime payload carries the complete pressure certificate. -/
theorem exact_pressure_certified_execution_path (cycle : Nat) :
    pressureCertifiedExecutionPathCertified
      (exactPressureCertifiedExecutionPath cycle)
      cycle := by
  unfold pressureCertifiedExecutionPathCertified
  exact
    { closedLoop := exact_closed_loop_certified cycle
      runtimeMetadata := exact_closed_loop_runtime_metadata_certified cycle
      benchmark :=
        exact_pressure_weighted_closed_loop_benchmark_report_certified cycle
      versionValue := rfl
      identityValue := rfl
      runtimeValue := rfl
      hostValue := rfl
      topologyValue := rfl
      gateValue := exact_natural_port_coordinates
      decompositionValue := rfl
      interfereValue := rfl
      closureValue := exact_interfere_port_closure_coordinate
      strideValue := rfl
      leakageTraceValue := rfl
      weightedTraceValue :=
        exact_pressure_weighted_interference_stride_trace cycle
      weightedTotalValue := exact_pressure_weighted_interference_total cycle
      closureFamilyChecksum :=
        exact_bounded_indexed_interfere_closure_family_audit_pressure_total cycle
      informationMassValue := exact_braid_packet_total_information_mass cycle
      leakageValue := exact_braid_packet_total_leakage cycle
      massUnitValue := rfl
      pressureUnitValue := rfl
      theoremLineageValue := rfl }

/-- Certified execution paths force the 10/12/17/22/43 topology. -/
theorem pressure_certified_execution_path_forces_topology
    (path : PressureCertifiedExecutionPath)
    (cycle : Nat)
    (h : pressureCertifiedExecutionPathCertified path cycle) :
    path.topologyCoordinates = [10, 12, 17, 22, 43] := by
  exact h.topologyValue

/-- Certified execution paths force the 43/55 interfere port. -/
theorem pressure_certified_execution_path_forces_interfere_port
    (path : PressureCertifiedExecutionPath)
    (cycle : Nat)
    (h : pressureCertifiedExecutionPathCertified path cycle) :
    path.interferePortCoordinate = 43 /\
      path.interfereClosureCoordinate = 55 := by
  exact And.intro h.interfereValue h.closureValue

/-- Certified execution paths force the exact metrology and pressure totals. -/
theorem pressure_certified_execution_path_pressure_totals
    (path : PressureCertifiedExecutionPath)
