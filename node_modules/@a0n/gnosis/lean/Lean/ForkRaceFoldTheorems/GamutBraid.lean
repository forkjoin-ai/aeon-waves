  weightedTotalValue : path.pressureWeightedInterferenceTotal = 2586
  closureFamilyChecksum : path.closureFamilyPressureTotal = 30210
  informationMassValue : path.informationMassTotal = 1560
  leakageValue : path.leakageTotal = 96
