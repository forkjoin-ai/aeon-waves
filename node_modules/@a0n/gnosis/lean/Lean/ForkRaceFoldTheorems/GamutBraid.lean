/-!
## Closed-loop representative workload

The runtime shortcut for the closed-loop probe is intentionally narrow. It can
replace a repeated unit-increment workload with direct representative weight
accumulation only when each unit of work contributes exactly one increment.
-/

/-- The only unit increment admitted by the representative workload shortcut. -/
def closedLoopWeightAccumulationUnitIncrement : Nat :=
  1

/-- Work performed by adding the unit increment `weight` times. -/
def repeatedUnitIncrementWork : Nat -> Nat
  | 0 => 0
  | Nat.succ weight =>
      repeatedUnitIncrementWork weight +
        closedLoopWeightAccumulationUnitIncrement

/-- Direct representative accumulation of finite workload weights. -/
def representativeWeightAccumulationSum : List Nat -> Nat
  | [] => 0
  | weight :: rest => weight + representativeWeightAccumulationSum rest

/-- Repeated unit-increment work over each finite workload weight. -/
def repeatedUnitIncrementWorkloadSum : List Nat -> Nat
  | [] => 0
  | weight :: rest =>
      repeatedUnitIncrementWork weight +
        repeatedUnitIncrementWorkloadSum rest

/-- The certified workload shape required by the runtime single-run probe. -/
def closedLoopRepeatedUnitWorkloadCertified
    (weights : List Nat) : Prop :=
  representativeWeightAccumulationSum weights =
    repeatedUnitIncrementWorkloadSum weights

/-- Repeating the admitted unit increment `weight` times recovers `weight`. -/
theorem repeated_unit_increment_work_matches_weight (weight : Nat) :
    repeatedUnitIncrementWork weight = weight := by
  induction weight with
  | zero => rfl
  | succ weight ih =>
      simp [repeatedUnitIncrementWork,
        closedLoopWeightAccumulationUnitIncrement, ih]

/--
Representative weight accumulation matches the repeated unit-increment
workload for every finite list of weights.
-/
theorem closed_loop_weight_accumulation_representative_matches_repeated_unit_workload
    (weights : List Nat) :
    representativeWeightAccumulationSum weights =
      repeatedUnitIncrementWorkloadSum weights := by
  induction weights with
  | nil => rfl
  | cons weight rest ih =>
      simp [representativeWeightAccumulationSum,
        repeatedUnitIncrementWorkloadSum,
        repeated_unit_increment_work_matches_weight, ih]

/-- The exact closed-loop trace admits direct representative accumulation. -/
theorem exact_closed_loop_weight_accumulation_representative_shortcut :
    closedLoopRepeatedUnitWorkloadCertified closedLoopTrace := by
  unfold closedLoopRepeatedUnitWorkloadCertified
  exact
    closed_loop_weight_accumulation_representative_matches_repeated_unit_workload
      closedLoopTrace

/-- Runtime-facing alias for the exact repeated-unit workload certificate. -/
theorem exact_closed_loop_repeated_unit_workload_certified :
    closedLoopRepeatedUnitWorkloadCertified closedLoopTrace := by
  exact exact_closed_loop_weight_accumulation_representative_shortcut

