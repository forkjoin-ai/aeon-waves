/--
For the exact fourth-aeon transition, indexed interference-port admission
forces the same 43/55 coordinates consumed by native route admission.
-/
theorem indexed_interfere_port_admission_forces_exact_coordinates
    {portCoordinate closureCoordinate : Nat}
    (h :
      indexedInterferePortAdmissionCertified
        exactFortyThreePrimeTransition
        portCoordinate
        closureCoordinate) :
    portCoordinate = 43 /\ closureCoordinate = 55 := by
  unfold indexedInterferePortAdmissionCertified at h
  unfold indexedInterferePortClosureFamilyCertified at h
  exact And.intro
    (by
      calc
        portCoordinate = exactFortyThreePrimeTransition.terminal := h.2.1.symm
        _ = 43 := rfl)
    (by
      calc
        closureCoordinate =
            indexedInterfereClosureCoordinate
              portCoordinate
              firstInterfereClosureFamilyIndex := h.2.2.1
        _ =
            indexedInterfereClosureCoordinate
              exactFortyThreePrimeTransition.terminal
              firstInterfereClosureFamilyIndex := by
          rw [← h.2.1]
        _ = 55 := rfl)

