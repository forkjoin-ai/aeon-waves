/-!
# Gamut braid

This module makes the braid reading finite and proof-bearing. A braid cycle is
not a random traversal from 10 to 22; it is a closed witness spanning the whole
10/12/17/22 gate stack while returning to the same readiness base.
-/

/-- Gate labels for the finite gamut braid. -/
inductive BraidGate where
  | kenomaGate
  | aeonGate
  | primeGate
  | doubleGate
deriving DecidableEq, Repr

/-- Runtime actions carried by the natural 10/12/17/22 port map. -/
inductive BraidPortAction where
  | fork
  | race
  | fold
  | vent
  | interfere
deriving DecidableEq, Repr

/-- Gate labels mapped back to the cosmic layer stack. -/
def gateLayer : BraidGate -> CosmosLayer
  | BraidGate.kenomaGate => CosmosLayer.kenoma
  | BraidGate.aeonGate => CosmosLayer.localAeon
  | BraidGate.primeGate => CosmosLayer.primeKeystone
  | BraidGate.doubleGate => CosmosLayer.doubleKeystone

/-- Gate coordinates inherit the cosmic layer coordinates. -/
def gateCoordinate (gate : BraidGate) : Nat :=
  layerCoordinate (gateLayer gate)

/-- The exact four-gate braid stack. -/
def braidGateStack : List BraidGate :=
  [BraidGate.kenomaGate, BraidGate.aeonGate,
    BraidGate.primeGate, BraidGate.doubleGate]

/-- Numeric trace of the braid gates. -/
def braidGateCoordinates : List Nat :=
  braidGateStack.map gateCoordinate

/-- Port-action coordinates inherit the same closed 10/12/17/22 stack. -/
def portActionCoordinate : BraidPortAction -> Nat
  | BraidPortAction.fork => layerCoordinate CosmosLayer.kenoma
  | BraidPortAction.race => layerCoordinate CosmosLayer.localAeon
  | BraidPortAction.fold => layerCoordinate CosmosLayer.primeKeystone
  | BraidPortAction.vent => layerCoordinate CosmosLayer.doubleKeystone
  | BraidPortAction.interfere => 43

/-- One complete fork/race/fold/vent pass through the natural ports. -/
def portActionTrace : List BraidPortAction :=
  [BraidPortAction.fork, BraidPortAction.race,
    BraidPortAction.fold, BraidPortAction.vent]

/-- Numeric trace of one complete natural port pass. -/
def naturalPortCoordinates : List Nat :=
  portActionTrace.map portActionCoordinate

/-- Partial inverse from exact port coordinates to runtime actions. -/
def portActionForCoordinate : Nat -> Option BraidPortAction
  | 10 => some BraidPortAction.fork
  | 12 => some BraidPortAction.race
  | 17 => some BraidPortAction.fold
  | 22 => some BraidPortAction.vent
  | 43 => some BraidPortAction.interfere
  | _ => none

/--
Successor relation for the recursive fork/race/fold/vent port pump.
`interfere` is an off-cycle terminal/native port, so it is stable under
successor and does not alter the four-port natural stream.
-/
def nextPortAction : BraidPortAction -> BraidPortAction
  | BraidPortAction.fork => BraidPortAction.race
  | BraidPortAction.race => BraidPortAction.fold
  | BraidPortAction.fold => BraidPortAction.vent
  | BraidPortAction.vent => BraidPortAction.fork
  | BraidPortAction.interfere => BraidPortAction.interfere

/-- Iterate the natural port successor from a supplied action. -/
def iteratePortAction : Nat -> BraidPortAction -> BraidPortAction
  | 0, action => action
  | Nat.succ stage, action => iteratePortAction stage (nextPortAction action)

/-- Infinite fork/race/fold/vent action stream, indexed by stage. -/
def infiniteForkRaceFoldVentAction (stage : Nat) : BraidPortAction :=
  iteratePortAction stage BraidPortAction.fork

/-- Infinite fork/race/fold/vent coordinate stream, indexed by stage. -/
def infiniteForkRaceFoldVentCoordinate (stage : Nat) : Nat :=
  portActionCoordinate (infiniteForkRaceFoldVentAction stage)

/-- The first four coordinates exposed by the infinite port stream. -/
def firstInfinitePortCycleCoordinates : List Nat :=
  [infiniteForkRaceFoldVentCoordinate 0,
    infiniteForkRaceFoldVentCoordinate 1,
    infiniteForkRaceFoldVentCoordinate 2,
    infiniteForkRaceFoldVentCoordinate 3]

/-- A named boundary where one port cycle vents and the next cycle forks. -/
structure PortCycleBoundary where
  outgoingStage : Nat
  incomingStage : Nat
  outgoingAction : BraidPortAction
  incomingAction : BraidPortAction
  outgoingCoordinate : Nat
  incomingCoordinate : Nat
deriving DecidableEq, Repr

/-- The exact boundary between stage 3 (vent) and stage 4 (fork). -/
def exactVentToForkBoundary : PortCycleBoundary :=
  { outgoingStage := 3
    incomingStage := 4
    outgoingAction := BraidPortAction.vent
    incomingAction := BraidPortAction.fork
    outgoingCoordinate := 22
    incomingCoordinate := 10 }

/-- A port-cycle boundary is valid when vent advances directly to fork. -/
def portCycleBoundaryValid (boundary : PortCycleBoundary) : Prop :=
  boundary.outgoingStage + 1 = boundary.incomingStage /\
    boundary.outgoingAction = BraidPortAction.vent /\
    boundary.incomingAction = BraidPortAction.fork /\
    boundary.incomingAction = nextPortAction boundary.outgoingAction /\
    boundary.outgoingCoordinate = portActionCoordinate boundary.outgoingAction /\
    boundary.incomingCoordinate = portActionCoordinate boundary.incomingAction

/-- Saturation readings anchored by the braid. -/
def braidSaturationTrace : List Nat :=
  admittedSaturations

/--
A braid packet packages one natural port pass with the accounting traces needed
to authorize runtime allocation against the same finite mass checksum.
-/
structure BraidPacket where
  cycle : Nat
  actionTrace : List BraidPortAction
  portCoordinates : List Nat
  saturationTrace : List Nat
  informationMassTrace : List Nat
  leakageTrace : List Nat
  totalInformationMass : Nat
  totalLeakage : Nat
  boundary : PortCycleBoundary
deriving DecidableEq, Repr

/-- The exact braid packet for any finite cycle. -/
def exactBraidPacket (cycle : Nat) : BraidPacket :=
  { cycle
    actionTrace := portActionTrace
    portCoordinates := naturalPortCoordinates
    saturationTrace := braidSaturationTrace
    informationMassTrace := informationMassTrace exactReconstructionWitness.omega
    leakageTrace := leakageTrace exactReconstructionWitness.omega
    totalInformationMass := totalInformationMass exactReconstructionWitness.omega
    totalLeakage := totalLeakage exactReconstructionWitness.omega
    boundary := exactVentToForkBoundary }

/-- Packet-level certificate tying the port pass to the finite accounting mass. -/
def braidPacketCertified (packet : BraidPacket) : Prop :=
  packet.actionTrace =
      [BraidPortAction.fork, BraidPortAction.race,
        BraidPortAction.fold, BraidPortAction.vent] /\
    packet.portCoordinates = [10, 12, 17, 22] /\
    packet.saturationTrace = [10, 30, 90] /\
    packet.informationMassTrace = [120, 360, 1080] /\
    packet.leakageTrace = [0, 18, 78] /\
    packet.totalInformationMass = 1560 /\
    packet.totalLeakage = 96 /\
    portCycleBoundaryValid packet.boundary

/-- A finite cycle of the same closed braid witness. -/
structure GamutBraid where
  cycle : Nat
  witness : ReconstructionWitness
deriving DecidableEq, Repr

/-- The exact braid at an arbitrary finite cycle. -/
def exactGamutBraid (cycle : Nat) : GamutBraid :=
  { cycle
    witness := exactReconstructionWitness }

/-- The braid spans all gates when its traces and closure agree. -/
def spansAllGates (braid : GamutBraid) : Prop :=
  cosmicArchitectureClosed braid.witness /\
    braidGateCoordinates = [10, 12, 17, 22] /\
    braidSaturationTrace = [10, 30, 90] /\
    layerHandshake braid.witness

/-- The same strand links the low and high endpoints through closure. -/
def endpointsLinked (braid : GamutBraid) : Prop :=
  expectedLayerForSaturation 10 = some CosmosLayer.kenoma /\
    expectedLayerForSaturation 90 = some CosmosLayer.doubleKeystone /\
    cosmicArchitectureClosed braid.witness

/-- The prime-to-double section has a finite crossing count. -/
def primeDoubleCrossings (braid : GamutBraid) : Nat :=
  keystoneGap braid.witness.omega

/-- A folded carrier packs the double keystone into two half-carrier spans. -/
def foldedCarrierFits (halfCarrier : Nat) (omega : HarmonicFrequency) : Prop :=
  halfCarrier + halfCarrier = omega.doubleKeystone

/--
A 7/17/22 decomposition triple: decompose at the lower gate, race at the prime
anchor, and fold at the double anchor.
-/
structure DecompositionTriple where
  decompositionGate : Nat
  raceAnchor : Nat
  foldAnchor : Nat
deriving DecidableEq, Repr

/-- The exact 7/17/22 decomposition-race-fold triple. -/
def exactDecompositionTriple : DecompositionTriple :=
  { decompositionGate := 7
    raceAnchor := 17
    foldAnchor := 22 }

/-- Numeric trace of a decomposition triple. -/
def decompositionTripleCoordinates (triple : DecompositionTriple) : List Nat :=
  [triple.decompositionGate, triple.raceAnchor, triple.foldAnchor]

/--
The decomposition gate feeds the prime race anchor by exactly the kenoma span.
For the exact triple this is `7 + 10 = 17`.
-/
def decompositionFeedsKenomaSpan (triple : DecompositionTriple) : Prop :=
  triple.raceAnchor = triple.decompositionGate + layerCoordinate CosmosLayer.kenoma

/-- The race/fold anchors coincide with the prime and double keystones. -/
def decompositionAnchorsKeystones
    (triple : DecompositionTriple)
    (omega : HarmonicFrequency) : Prop :=
  triple.raceAnchor = omega.primeKeystone /\
    triple.foldAnchor = omega.doubleKeystone

/-- A proof-backed braid pass packages forked gates, raced crossings, and folded return. -/
def forkRaceFoldBraidPass (braid : GamutBraid) : Prop :=
  spansAllGates braid /\
    endpointsLinked braid /\
    primeDoubleCrossings braid = 5 /\
    baseReady braid.witness

/--
A proof-backed 7/17/22 pass first decomposes by the kenoma span, then reuses the
existing braid pass to race the prime anchor and fold at the double anchor.
-/
def decompositionForkRaceFoldPass
    (triple : DecompositionTriple)
    (braid : GamutBraid) : Prop :=
  decompositionTripleCoordinates triple = [7, 17, 22] /\
    decompositionFeedsKenomaSpan triple /\
    decompositionAnchorsKeystones triple braid.witness.omega /\
    triple.foldAnchor = triple.raceAnchor + primeDoubleCrossings braid /\
    forkRaceFoldBraidPass braid

/-- The exact gate stack has the 10/12/17/22 trace. -/
theorem exact_braid_gate_coordinates :
    braidGateCoordinates = [10, 12, 17, 22] := by
  rfl

/-- One exact fork/race/fold/vent action pass has the expected action trace. -/
theorem exact_port_action_trace :
    portActionTrace =
      [BraidPortAction.fork, BraidPortAction.race,
        BraidPortAction.fold, BraidPortAction.vent] := by
  rfl

/-- The natural fork/race/fold/vent ports have the 10/12/17/22 trace. -/
theorem exact_natural_port_coordinates :
    naturalPortCoordinates = [10, 12, 17, 22] := by
  rfl

/-- The natural port coordinates coincide with the braid gate coordinates. -/
theorem natural_port_coordinates_match_braid_gates :
    naturalPortCoordinates = braidGateCoordinates := by
  rfl

/-- Exact coordinates recover their fork/race/fold/vent actions. -/
theorem exact_port_action_mapping :
    portActionForCoordinate 10 = some BraidPortAction.fork /\
      portActionForCoordinate 12 = some BraidPortAction.race /\
      portActionForCoordinate 17 = some BraidPortAction.fold /\
      portActionForCoordinate 22 = some BraidPortAction.vent := by
  exact And.intro rfl
    (And.intro rfl
      (And.intro rfl rfl))

/-- The extended native coordinate recovers the interference action. -/
theorem exact_interfere_port_action_mapping :
    portActionForCoordinate 43 = some BraidPortAction.interfere := by
  rfl

/-- The vent action hands the recursive port stream back to fork. -/
theorem vent_hands_off_to_fork :
    nextPortAction BraidPortAction.vent = BraidPortAction.fork := by
  rfl

/-- The interference action is terminal and does not enter the four-port stream. -/
theorem interfere_port_is_terminal :
    nextPortAction BraidPortAction.interfere = BraidPortAction.interfere := by
  rfl

/-- Four successor steps return every port action to itself. -/
theorem iterate_port_action_four_cycle
    (stage : Nat)
    (action : BraidPortAction) :
    iteratePortAction (stage + 4) action = iteratePortAction stage action := by
  induction stage generalizing action with
  | zero =>
      cases action
      · rfl
      · rfl
      · rfl
      · rfl
      · rfl
  | succ stage ih =>
      exact ih (nextPortAction action)

/-- The infinite fork/race/fold/vent action stream repeats every four stages. -/
theorem infinite_port_action_four_cycle (stage : Nat) :
    infiniteForkRaceFoldVentAction (stage + 4) =
      infiniteForkRaceFoldVentAction stage := by
  exact iterate_port_action_four_cycle stage BraidPortAction.fork

/-- The infinite fork/race/fold/vent coordinate stream repeats every four stages. -/
theorem infinite_port_coordinate_four_cycle (stage : Nat) :
    infiniteForkRaceFoldVentCoordinate (stage + 4) =
      infiniteForkRaceFoldVentCoordinate stage := by
  unfold infiniteForkRaceFoldVentCoordinate
  rw [infinite_port_action_four_cycle]

/-- Runtime-facing alias: the infinite port coordinate stream is periodic. -/
theorem infinite_port_stream_periodic (stage : Nat) :
    infiniteForkRaceFoldVentCoordinate (stage + 4) =
      infiniteForkRaceFoldVentCoordinate stage := by
  exact infinite_port_coordinate_four_cycle stage

/-- The first cycle of the infinite port stream is the natural 10/12/17/22 trace. -/
theorem exact_first_infinite_port_cycle :
    firstInfinitePortCycleCoordinates = [10, 12, 17, 22] := by
  rfl

/-- Runtime-facing alias: the first port cycle is the natural stack. -/
theorem first_cycle_is_natural_stack :
    firstInfinitePortCycleCoordinates = [10, 12, 17, 22] := by
  exact exact_first_infinite_port_cycle

/-- Every finite stage in the infinite port stream has a concrete action. -/
theorem infinite_port_stage_has_action (stage : Nat) :
    Exists fun action => infiniteForkRaceFoldVentAction stage = action := by
  exact Exists.intro (infiniteForkRaceFoldVentAction stage) rfl

/-- The exact vent-to-fork boundary satisfies the boundary contract. -/
theorem exact_vent_to_fork_boundary :
    portCycleBoundaryValid exactVentToForkBoundary := by
  exact And.intro rfl
    (And.intro rfl
      (And.intro rfl
        (And.intro rfl
          (And.intro rfl rfl))))

/-- Stage 3 vents at 22 and stage 4 forks at 10. -/
theorem exact_vent_stage_hands_to_next_fork_stage :
    infiniteForkRaceFoldVentAction 3 = BraidPortAction.vent /\
      infiniteForkRaceFoldVentAction 4 = BraidPortAction.fork /\
      infiniteForkRaceFoldVentCoordinate 3 = 22 /\
      infiniteForkRaceFoldVentCoordinate 4 = 10 := by
  exact And.intro rfl
    (And.intro rfl
      (And.intro rfl rfl))

/-- The exact braid packet carries the natural fork/race/fold/vent action trace. -/
theorem exact_braid_packet_action_trace (cycle : Nat) :
    (exactBraidPacket cycle).actionTrace =
      [BraidPortAction.fork, BraidPortAction.race,
        BraidPortAction.fold, BraidPortAction.vent] := by
  rfl

/-- The exact braid packet carries the natural 10/12/17/22 port trace. -/
theorem exact_braid_packet_port_coordinates (cycle : Nat) :
    (exactBraidPacket cycle).portCoordinates = [10, 12, 17, 22] := by
  rfl

/-- The exact braid packet carries the 10/30/90 saturation trace. -/
theorem exact_braid_packet_saturation_trace (cycle : Nat) :
    (exactBraidPacket cycle).saturationTrace = [10, 30, 90] := by
  rfl

/-- The exact braid packet carries the 120/360/1080 mass trace. -/
theorem exact_braid_packet_information_mass_trace (cycle : Nat) :
    (exactBraidPacket cycle).informationMassTrace = [120, 360, 1080] := by
  exact exact_information_mass_trace

/-- The exact braid packet carries the 0/18/78 pressure trace. -/
theorem exact_braid_packet_leakage_trace (cycle : Nat) :
    (exactBraidPacket cycle).leakageTrace = [0, 18, 78] := by
  exact exact_leakage_trace

/-- The exact braid packet has total information mass 1560. -/
theorem exact_braid_packet_total_information_mass (cycle : Nat) :
    (exactBraidPacket cycle).totalInformationMass = 1560 := by
  exact exact_total_information_mass

/-- The exact braid packet has total leakage pressure 96. -/
theorem exact_braid_packet_total_leakage (cycle : Nat) :
    (exactBraidPacket cycle).totalLeakage = 96 := by
  exact exact_total_leakage

/-- The exact braid packet carries the exact vent-to-fork boundary. -/
theorem exact_braid_packet_boundary_valid (cycle : Nat) :
    portCycleBoundaryValid (exactBraidPacket cycle).boundary := by
  exact exact_vent_to_fork_boundary

/-- The exact braid packet is certified against the port and mass traces. -/
theorem exact_braid_packet_certified (cycle : Nat) :
    braidPacketCertified (exactBraidPacket cycle) := by
  exact And.intro (exact_braid_packet_action_trace cycle)
    (And.intro (exact_braid_packet_port_coordinates cycle)
      (And.intro (exact_braid_packet_saturation_trace cycle)
        (And.intro (exact_braid_packet_information_mass_trace cycle)
          (And.intro (exact_braid_packet_leakage_trace cycle)
            (And.intro (exact_braid_packet_total_information_mass cycle)
              (And.intro (exact_braid_packet_total_leakage cycle)
                (exact_braid_packet_boundary_valid cycle)))))))

/-!
## Extended Aeon transition

The 43-prime-transition reading is kept finite here. The module certifies the
candidate coordinate as the fourth-aeon `42 + 1` terminal and records the 55
closure multiple; it does not import an external primality theory.
-/

/-- Named rows in the extended dark-aeon stack. -/
inductive ExtendedAeon where
  | first
  | second
  | third
  | fourth
  | finalClosure
deriving DecidableEq, Repr

/-- Finite extended-aeon rows inspected by the 43-transition candidate. -/
def extendedAeonStack : List ExtendedAeon :=
  [ExtendedAeon.first, ExtendedAeon.second, ExtendedAeon.third,
    ExtendedAeon.fourth, ExtendedAeon.finalClosure]

/-- Start coordinate for each extended-aeon row. -/
def extendedAeonStart : ExtendedAeon -> Nat
  | ExtendedAeon.first => 1
  | ExtendedAeon.second => 10
  | ExtendedAeon.third => 20
  | ExtendedAeon.fourth => 30
  | ExtendedAeon.finalClosure => 50

/-- End coordinate for each extended-aeon row. -/
def extendedAeonEnd : ExtendedAeon -> Nat
  | ExtendedAeon.first => 12
  | ExtendedAeon.second => 22
  | ExtendedAeon.third => 32
  | ExtendedAeon.fourth => 43
  | ExtendedAeon.finalClosure => 55

/-- Fold keystone for each extended-aeon row. -/
def extendedAeonFoldKeystone : ExtendedAeon -> Nat
  | ExtendedAeon.first => 7
  | ExtendedAeon.second => 17
  | ExtendedAeon.third => 27
  | ExtendedAeon.fourth => 37
  | ExtendedAeon.finalClosure => 55

/-- Vent keystone for each extended-aeon row. -/
def extendedAeonVentKeystone : ExtendedAeon -> Nat
  | ExtendedAeon.first => 11
  | ExtendedAeon.second => 22
  | ExtendedAeon.third => 32
  | ExtendedAeon.fourth => 43
  | ExtendedAeon.finalClosure => 55

/-- Start/end trace for the extended-aeon rows. -/
def extendedAeonRanges : List (Nat × Nat) :=
  extendedAeonStack.map
    (fun aeon => (extendedAeonStart aeon, extendedAeonEnd aeon))

/-- Fold/vent keystone trace for the extended-aeon rows. -/
def extendedAeonKeystoneTrace : List (Nat × Nat) :=
  extendedAeonStack.map
    (fun aeon =>
      (extendedAeonFoldKeystone aeon, extendedAeonVentKeystone aeon))

/-- Linear fourth-aeon terminal before the clinamen lift. -/
def fourthAeonLinearTerminal : Nat :=
  42

/-- Candidate terminal after the one-step fourth-aeon clinamen lift. -/
def fortyThreePrimeTerminalCandidate : Nat :=
  43

/-- Five eleven-carrier spans close at 55. -/
def fiftyFiveOuroborosClosure : Nat :=
  55

/-- Runtime-facing interference port carried by the fourth-aeon terminal. -/
def interferePortCoordinate : Nat :=
  portActionCoordinate BraidPortAction.interfere

/-- Closure coordinate paired with the interference port. -/
def interferePortClosureCoordinate : Nat :=
  fiftyFiveOuroborosClosure

/-- Coordinate deltas from the interference anchor back to the natural port cycle. -/
def pressureWeightedBenchmarkInterferenceStrideTraceFor
    (interfereCoordinate : Nat) : List Nat :=
  naturalPortCoordinates.map (fun coordinate => interfereCoordinate - coordinate)

/-- Runtime topology coordinates for a candidate pressure benchmark axis. -/
def pressureWeightedBenchmarkTopologyCoordinatesFor
    (interfereCoordinate : Nat) : List Nat :=
  naturalPortCoordinates ++ [interfereCoordinate]

/-- Coordinate deltas from the exact interference anchor back to the natural port cycle. -/
def interferenceStrideTrace : List Nat :=
  pressureWeightedBenchmarkInterferenceStrideTraceFor interferePortCoordinate

/-- Pairwise product of two finite accounting traces, truncating at the shorter trace. -/
def pressureWeightedTrace : List Nat -> List Nat -> List Nat
  | stride :: strides, pressure :: pressures =>
      stride * pressure :: pressureWeightedTrace strides pressures
  | _, _ => []

/-- Candidate pressure-weighted stride trace for a benchmark axis and packet. -/
def pressureWeightedBenchmarkWeightedStrideTraceFor
    (interfereCoordinate : Nat)
    (packet : BraidPacket) : List Nat :=
  pressureWeightedTrace
    (pressureWeightedBenchmarkInterferenceStrideTraceFor interfereCoordinate)
    packet.leakageTrace

/-- Candidate pressure-weighted total for a benchmark axis and packet. -/
def pressureWeightedBenchmarkTotalFor
    (interfereCoordinate : Nat)
    (packet : BraidPacket) : Nat :=
  (pressureWeightedBenchmarkWeightedStrideTraceFor interfereCoordinate packet).foldl
    (fun acc value => acc + value) 0

/--
Pressure-weighted interference trace: coordinate stride multiplied by leakage
pressure. The natural port trace has four coordinates while the accounting
pressure trace has three noise bands, so the pairwise product stops at brown.
-/
def pressureWeightedInterferenceStrideTrace (packet : BraidPacket) : List Nat :=
  pressureWeightedTrace interferenceStrideTrace packet.leakageTrace

/-- Total pressure-weighted interference across the admitted leakage bands. -/
def pressureWeightedInterferenceTotal (packet : BraidPacket) : Nat :=
  (pressureWeightedInterferenceStrideTrace packet).foldl
    (fun acc value => acc + value) 0

/-- A finite transition candidate for the 43 terminal. -/
structure ExtendedAeonTransition where
  aeon : ExtendedAeon
  linearTerminal : Nat
  clinamen : Nat
  terminal : Nat
  foldKeystone : Nat
  ventKeystone : Nat
deriving DecidableEq, Repr

/-- The exact fourth-aeon 42+1 terminal candidate. -/
def exactFortyThreePrimeTransition : ExtendedAeonTransition :=
  { aeon := ExtendedAeon.fourth
    linearTerminal := fourthAeonLinearTerminal
    clinamen := 1
    terminal := fortyThreePrimeTerminalCandidate
    foldKeystone := 37
    ventKeystone := 43 }

/-- The transition contract for the 43 candidate. -/
def extendedAeonTransitionCertified
    (transition : ExtendedAeonTransition) : Prop :=
  transition.aeon = ExtendedAeon.fourth /\
    transition.linearTerminal + transition.clinamen = transition.terminal /\
    transition.clinamen = 1 /\
    transition.terminal = 43 /\
    transition.terminal = extendedAeonEnd transition.aeon /\
    transition.foldKeystone = extendedAeonFoldKeystone transition.aeon /\
    transition.ventKeystone = extendedAeonVentKeystone transition.aeon

/-- Candidate closure coordinate for an indexed interference-port family member. -/
def indexedInterfereClosureCoordinate
    (portCoordinate closureIndex : Nat) : Nat :=
  portCoordinate + closureIndex * bucketSize

/-- Distance from the exact 43/55 admission member for a closure-family index. -/
def indexedInterfereClosureDistanceFromExactAdmission
    (closureIndex : Nat) : Nat :=
  indexedInterfereClosureCoordinate
    interferePortCoordinate
    closureIndex -
    interferePortClosureCoordinate

/-- The first non-local closure family member advances by one local bucket. -/
def firstInterfereClosureFamilyIndex : Nat :=
  1

/-- The next bounded closure family member advances by two local buckets. -/
def secondInterfereClosureFamilyIndex : Nat :=
  2

/-- The checked runtime audit keeps a finite window of closure-family members. -/
def maxBoundedInterfereClosureFamilyIndex : Nat :=
  5

/-- Indexed interference-port closure family for a finite transition. -/
def indexedInterferePortClosureFamilyCertified
    (transition : ExtendedAeonTransition)
    (portCoordinate closureCoordinate closureIndex : Nat) : Prop :=
  extendedAeonTransitionCertified transition /\
    transition.terminal = portCoordinate /\
    closureCoordinate =
      indexedInterfereClosureCoordinate portCoordinate closureIndex /\
    transition.ventKeystone = portCoordinate /\
    nextPortAction BraidPortAction.interfere = BraidPortAction.interfere

/-- Indexed interference-port admission for the first closure family member. -/
def indexedInterferePortAdmissionCertified
    (transition : ExtendedAeonTransition)
    (portCoordinate closureCoordinate : Nat) : Prop :=
  indexedInterferePortClosureFamilyCertified
    transition
    portCoordinate
    closureCoordinate
    firstInterfereClosureFamilyIndex

/-- Interference-port contract used by native route admission metadata. -/
def interferePortCertified
    (transition : ExtendedAeonTransition) : Prop :=
  indexedInterferePortAdmissionCertified
      transition
      interferePortCoordinate
      interferePortClosureCoordinate /\
    interferePortCoordinate = 43 /\
    interferePortClosureCoordinate = 55

/-- A packet is interference-anchor admissible when the external port is stable against its mass. -/
def interferenceAnchorPacketCertified
    (packet : BraidPacket) : Prop :=
  braidPacketCertified packet /\
    interferePortCertified exactFortyThreePrimeTransition /\
    interferePortCoordinate ∉ packet.portCoordinates /\
    packet.totalInformationMass = 1560 /\
    packet.totalLeakage = 96

/--
Pressure-weighted interference admission: the external 43 anchor is certified
against both the topology packet and the finite 0/18/78 leakage pressure trace.
-/
def pressureWeightedInterferenceAnchorPacketCertified
    (packet : BraidPacket) : Prop :=
  interferenceAnchorPacketCertified packet /\
    packet.leakageTrace = [0, 18, 78] /\
    pressureWeightedInterferenceStrideTrace packet = [0, 558, 2028] /\
    pressureWeightedInterferenceTotal packet = 2586

/--
Pressure-weighted closure-family admission composes an indexed interfere
closure member with the existing 2586 SPa packet lineage.
-/
def pressureWeightedInterferePortClosureFamilyCertified
    (transition : ExtendedAeonTransition)
    (packet : BraidPacket)
    (portCoordinate closureCoordinate closureIndex : Nat) : Prop :=
  indexedInterferePortClosureFamilyCertified
    transition
    portCoordinate
    closureCoordinate
    closureIndex /\
    pressureWeightedInterferenceAnchorPacketCertified packet /\
    pressureWeightedBenchmarkTotalFor portCoordinate packet = 2586

/-- Runtime-facing finite audit row for one indexed closure-family member. -/
structure IndexedInterfereClosureFamilyAuditRow where
  portCoordinate : Nat
  closureCoordinate : Nat
  closureIndex : Nat
  closureStride : Nat
  closureDistanceFromExactAdmission : Nat
  closureAxisPressureWeightedTotal : Nat
  closureAxisPressureGrowthFromInterferencePort : Nat
  closureAxisPressureGrowthFromExactClosure : Nat
  exactAdmissionCompatible : Bool
deriving DecidableEq, Repr

/-- Deterministic audit row for one indexed closure-family member. -/
def indexedInterfereClosureFamilyAuditRow
    (cycle closureIndex : Nat) : IndexedInterfereClosureFamilyAuditRow :=
  { portCoordinate := interferePortCoordinate
    closureCoordinate :=
      indexedInterfereClosureCoordinate interferePortCoordinate closureIndex
    closureIndex
    closureStride := bucketSize
    closureDistanceFromExactAdmission :=
      indexedInterfereClosureDistanceFromExactAdmission closureIndex
    closureAxisPressureWeightedTotal :=
      pressureWeightedBenchmarkTotalFor
        (indexedInterfereClosureCoordinate interferePortCoordinate closureIndex)
        (exactBraidPacket cycle)
    closureAxisPressureGrowthFromInterferencePort :=
      closureIndex * 1152
    closureAxisPressureGrowthFromExactClosure :=
      (closureIndex - firstInterfereClosureFamilyIndex) * 1152
    exactAdmissionCompatible :=
      closureIndex == firstInterfereClosureFamilyIndex }

/-- Audit rows for an arbitrary listed set of indexed closure-family members. -/
def indexedInterfereClosureFamilyAuditTrace
    (cycle : Nat)
    (closureIndices : List Nat) :
    List IndexedInterfereClosureFamilyAuditRow :=
  closureIndices.map (indexedInterfereClosureFamilyAuditRow cycle)

/-- Pressure checksum over finite closure-family audit rows. -/
def closureFamilyAuditPressureTotal
    (rows : List IndexedInterfereClosureFamilyAuditRow) : Nat :=
  rows.foldl
    (fun total row => total + row.closureAxisPressureWeightedTotal)
    0

/-- Formula checksum over finite closure-family audit indices. -/
def closureFamilyAuditPressureFormulaTotal
    (closureIndices : List Nat) : Nat :=
  closureIndices.foldl
    (fun total closureIndex => total + (2586 + closureIndex * 1152))
    0

/-- Runtime fixture window for bounded closure-family audit rows. -/
def boundedInterfereClosureFamilyAuditIndices : List Nat :=
  [1, 2, 3, 4, 5]

/-- Runtime fixture audit trace for bounded closure-family rows. -/
def boundedIndexedInterfereClosureFamilyAuditTrace
    (cycle : Nat) : List IndexedInterfereClosureFamilyAuditRow :=
  indexedInterfereClosureFamilyAuditTrace
    cycle
    boundedInterfereClosureFamilyAuditIndices

/-!
## Spherical information accounting

The spherical reading is encoded as finite accounting metadata. The labels
record how the exact 120/360/1080 mass trace is packed against rotation counts;
they do not import analytic geometry or an external topology library.
-/

/-- Finite packed-geometry layers over the braid accounting stack. -/
inductive PackedGeometryLayer where
  | kenomaCore
  | pinkShell
  | brownAura
deriving DecidableEq, Repr

/-- Finite topology-shape labels used as accounting annotations. -/
inductive PackedTopologyShape where
  | trianglePlane
  | informationSphere
  | toroidalBraid
  | closedManifold
deriving DecidableEq, Repr

/-- A finite accounting layer with saturation, mass, and rotation metadata. -/
structure SphericalAccountingLayer where
  layer : PackedGeometryLayer
  shape : PackedTopologyShape
  saturation : Nat
  informationMass : Nat
  rotationDegrees : Nat
  wrapCount : Nat
deriving DecidableEq, Repr

/-- Kenoma core: saturation 10, mass 120, trine rotation 120. -/
def exactKenomaSphericalLayer : SphericalAccountingLayer :=
  { layer := PackedGeometryLayer.kenomaCore
    shape := PackedTopologyShape.trianglePlane
    saturation := 10
    informationMass := 120
    rotationDegrees := 120
    wrapCount := 1 }

/-- Pink shell: saturation 30, mass 360, one full finite rotation. -/
def exactPinkSphericalLayer : SphericalAccountingLayer :=
  { layer := PackedGeometryLayer.pinkShell
    shape := PackedTopologyShape.informationSphere
    saturation := 30
    informationMass := 360
    rotationDegrees := 360
    wrapCount := 1 }

/-- Brown aura: saturation 90, mass 1080, triple finite wrap. -/
def exactBrownSphericalLayer : SphericalAccountingLayer :=
  { layer := PackedGeometryLayer.brownAura
    shape := PackedTopologyShape.toroidalBraid
    saturation := 90
    informationMass := 1080
    rotationDegrees := 1080
    wrapCount := 3 }

/-- Exact packed-geometry layer trace over the braid accounting stack. -/
def sphericalAccountingTrace : List SphericalAccountingLayer :=
  [exactKenomaSphericalLayer, exactPinkSphericalLayer, exactBrownSphericalLayer]

/-- Saturation trace recovered from the packed-geometry layer witnesses. -/
def sphericalSaturationTrace : List Nat :=
  sphericalAccountingTrace.map SphericalAccountingLayer.saturation

/-- Information-mass trace recovered from the packed-geometry layer witnesses. -/
def sphericalInformationMassTrace : List Nat :=
  sphericalAccountingTrace.map SphericalAccountingLayer.informationMass

/-- Rotation-degree trace recovered from the packed-geometry layer witnesses. -/
def sphericalRotationTrace : List Nat :=
  sphericalAccountingTrace.map SphericalAccountingLayer.rotationDegrees

/-- Wrap-count trace recovered from the packed-geometry layer witnesses. -/
def sphericalWrapTrace : List Nat :=
  sphericalAccountingTrace.map SphericalAccountingLayer.wrapCount

/-- Total packed mass in the exact spherical accounting stack. -/
def packedGeometryTotalMass : Nat :=
  exactKenomaSphericalLayer.informationMass +
    exactPinkSphericalLayer.informationMass +
    exactBrownSphericalLayer.informationMass

/-- Exact per-bucket weight of the 1560-mass stack over the 12-row aperture. -/
def packedGeometryBucketWeight : Nat :=
  1560 / bucketSize

/-- The two high-latitude natural ports are the prime and double keystones. -/
def highLatitudePortCoordinates : List Nat :=
  [portActionCoordinate BraidPortAction.fold,
    portActionCoordinate BraidPortAction.vent]

/-- A finite antipodal symmetry certificate for a rotation layer. -/
def antipodalSymmetryCertified
    (halfRotation : Nat)
    (layer : SphericalAccountingLayer) : Prop :=
  halfRotation + halfRotation = layer.rotationDegrees

/-- A finite harmonic quotient records the mirrored half-rotation shortcut. -/
structure FiniteSphericalHarmonicShortcut where
  layer : SphericalAccountingLayer
  fullRotationDegrees : Nat
  sampledDegrees : Nat
  mirroredDegrees : Nat
  quotientFactor : Nat
deriving DecidableEq, Repr

/-- Quadratic work for a full finite rotation surface. -/
def fullQuadraticRotationWork (degrees : Nat) : Nat :=
  degrees * degrees

/-- Quadratic work after computing one mirrored half against the full surface. -/
def quotientQuadraticRotationWork
    (shortcut : FiniteSphericalHarmonicShortcut) : Nat :=
  shortcut.sampledDegrees * shortcut.fullRotationDegrees

/-- The exact finite harmonic shortcut for the pink shell. -/
def exactPinkHarmonicShortcut : FiniteSphericalHarmonicShortcut :=
  { layer := exactPinkSphericalLayer
    fullRotationDegrees := exactPinkSphericalLayer.rotationDegrees
    sampledDegrees := 180
    mirroredDegrees := 180
    quotientFactor := 2 }

/-- The exact finite harmonic shortcut for the brown triple-wrap layer. -/
def exactBrownHarmonicShortcut : FiniteSphericalHarmonicShortcut :=
  { layer := exactBrownSphericalLayer
    fullRotationDegrees := exactBrownSphericalLayer.rotationDegrees
    sampledDegrees := 540
    mirroredDegrees := 540
    quotientFactor := 2 }

/--
Finite harmonic quotient certificate. It records a mirrored half-rotation whose
quadratic work is exactly half of the full finite rotation work.
-/
def finiteHarmonicQuotientCertified
    (shortcut : FiniteSphericalHarmonicShortcut) : Prop :=
  shortcut.fullRotationDegrees = shortcut.layer.rotationDegrees /\
    shortcut.sampledDegrees + shortcut.mirroredDegrees =
      shortcut.fullRotationDegrees /\
    shortcut.sampledDegrees = shortcut.mirroredDegrees /\
    shortcut.quotientFactor = 2 /\
    quotientQuadraticRotationWork shortcut +
      quotientQuadraticRotationWork shortcut =
      fullQuadraticRotationWork shortcut.fullRotationDegrees /\
    quotientQuadraticRotationWork shortcut <
      fullQuadraticRotationWork shortcut.fullRotationDegrees

/-- Packet-level spherical accounting certificate for the finite braid packet. -/
def sphericalAccountingCertified
    (packet : BraidPacket) : Prop :=
  braidPacketCertified packet /\
    sphericalSaturationTrace = packet.saturationTrace /\
    sphericalInformationMassTrace = packet.informationMassTrace /\
    sphericalRotationTrace = [120, 360, 1080] /\
    sphericalWrapTrace = [1, 1, 3] /\
    exactPinkSphericalLayer.rotationDegrees = 360 /\
    exactBrownSphericalLayer.rotationDegrees = 3 * 360 /\
    exactBrownSphericalLayer.rotationDegrees =
      3 * exactPinkSphericalLayer.rotationDegrees /\
    packedGeometryTotalMass = packet.totalInformationMass /\
    packedGeometryTotalMass = 1560 /\
    interferePortCoordinate = 43 /\
    naturalPortCoordinates = [10, 12, 17, 22] /\
    highLatitudePortCoordinates = [17, 22] /\
    packet.totalLeakage = 96 /\
    1560 / bucketSize = 130 /\
    packedGeometryBucketWeight = 130 /\
    130 = 13 * 10 /\
    antipodalSymmetryCertified 180 exactPinkSphericalLayer /\
    antipodalSymmetryCertified 540 exactBrownSphericalLayer /\
    finiteHarmonicQuotientCertified exactPinkHarmonicShortcut /\
    finiteHarmonicQuotientCertified exactBrownHarmonicShortcut /\
    quotientQuadraticRotationWork exactPinkHarmonicShortcut * 2 =
      fullQuadraticRotationWork exactPinkSphericalLayer.rotationDegrees /\
    quotientQuadraticRotationWork exactBrownHarmonicShortcut * 2 =
      fullQuadraticRotationWork exactBrownSphericalLayer.rotationDegrees

/-- The exact packed-geometry layer trace is fixed. -/
theorem exact_spherical_accounting_trace :
    sphericalAccountingTrace =
      [exactKenomaSphericalLayer, exactPinkSphericalLayer,
        exactBrownSphericalLayer] := by
