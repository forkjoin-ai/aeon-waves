/--
Any certified later closure-family member remains outside exact first-member
admission. Exact Forge admission accepts only `closureIndex = 1`.
-/
theorem indexed_interfere_port_later_closure_family_rejected_by_exact_admission
    {closureCoordinate closureIndex : Nat}
    (family :
      indexedInterferePortClosureFamilyCertified
        exactFortyThreePrimeTransition
        43
        closureCoordinate
        closureIndex)
    (later : firstInterfereClosureFamilyIndex < closureIndex) :
    ¬ indexedInterferePortAdmissionCertified
      exactFortyThreePrimeTransition
      43
      closureCoordinate := by
  intro admitted
  have forced :=
    indexed_interfere_port_admission_forces_exact_coordinates admitted
  unfold indexedInterferePortClosureFamilyCertified at family
  have familyClosure :
      closureCoordinate =
        indexedInterfereClosureCoordinate 43 closureIndex := family.2.2.1
  have exactClosure :
      indexedInterfereClosureCoordinate 43 closureIndex = 55 := by
    calc
      indexedInterfereClosureCoordinate 43 closureIndex = closureCoordinate :=
        familyClosure.symm
      _ = 55 := forced.2
  have notExact :
      indexedInterfereClosureCoordinate 43 closureIndex ≠ 55 := by
    unfold indexedInterfereClosureCoordinate
    unfold firstInterfereClosureFamilyIndex at later
    simp only [bucketSize, visibleRowBudget, layerCoordinate]
    intro hEq
    have h2 : 2 ≤ closureIndex := Nat.succ_le_of_lt later
    have hgt : 55 < 43 + closureIndex * 12 := by
      have fiftyfive : 55 < 43 + 2 * 12 := by decide
      have h67 : 43 + 2 * 12 ≤ 43 + closureIndex * 12 :=
        Nat.add_le_add_left (Nat.mul_le_mul_right 12 h2) 43
      exact Nat.lt_of_lt_of_le fiftyfive h67
    rw [hEq] at hgt
    exact Nat.lt_irrefl 55 hgt
  exact notExact exactClosure

