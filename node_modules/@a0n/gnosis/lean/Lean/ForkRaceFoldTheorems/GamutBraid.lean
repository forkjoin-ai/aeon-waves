    pressureWeightedInterferenceTotal (exactBraidPacket cycle) = 2586 := by
  rfl

/--
Using an indexed closure coordinate as the benchmark axis increases pressure
by one 1152-unit leakage block per closure-family index.
-/
theorem indexed_interfere_closure_axis_pressure_total
    (cycle closureIndex : Nat) :
    pressureWeightedBenchmarkTotalFor
        (indexedInterfereClosureCoordinate 43 closureIndex)
        (exactBraidPacket cycle) =
      2586 + closureIndex * 1152 := by
  unfold pressureWeightedBenchmarkTotalFor
  unfold pressureWeightedBenchmarkWeightedStrideTraceFor
  rw [exact_braid_packet_leakage_trace cycle]
  unfold pressureWeightedBenchmarkInterferenceStrideTraceFor
  unfold indexedInterfereClosureCoordinate
  simp [pressureWeightedTrace, naturalPortCoordinates, portActionTrace,
    portActionCoordinate, bucketSize, visibleRowBudget, layerCoordinate]
  -- `x = 43 + k·12`; expand strides `x - 12`, `x - 17`.
  have hx12 :
      43 + closureIndex * 12 - 12 = 31 + closureIndex * 12 := by
    have rearr :
        43 + closureIndex * 12 = 12 + (31 + closureIndex * 12) := by
      rw [← Nat.add_assoc, show 12 + 31 = 43 from rfl]
    rw [rearr, Nat.add_sub_cancel_left]
  have hx17 :
      43 + closureIndex * 12 - 17 = 26 + closureIndex * 12 := by
    have rearr :
        43 + closureIndex * 12 = 17 + (26 + closureIndex * 12) := by
      rw [← Nat.add_assoc, show 17 + 26 = 43 from rfl]
    rw [rearr, Nat.add_sub_cancel_left]
  rw [hx12, hx17]
  rw [Nat.add_mul 31 (closureIndex * 12) 18, Nat.add_mul 26 (closureIndex * 12) 78]
  have hstrideSwap :
      31 * 18 + closureIndex * 12 * 18 + 26 * 78 =
        31 * 18 + 26 * 78 + closureIndex * 12 * 18 := by
    rw [Nat.add_assoc (31 * 18), Nat.add_comm (closureIndex * 12 * 18) (26 * 78),
      ← Nat.add_assoc (31 * 18)]
  rw [← Nat.add_assoc ((31 * 18) + (closureIndex * 12 * 18))]
  rw [hstrideSwap]
  rw [Nat.add_assoc ((31 * 18) + (26 * 78))]
  rw [← Nat.mul_add (closureIndex * 12) 18 78, show 18 + 78 = 96 from rfl]
  have h96 : 96 * (closureIndex * 12) = closureIndex * 1152 := by
    calc
      96 * (closureIndex * 12) = (96 * closureIndex) * 12 := by
        rw [← Nat.mul_assoc 96 closureIndex 12]
      _ = (closureIndex * 96) * 12 := by rw [Nat.mul_comm 96 closureIndex]
      _ = closureIndex * (96 * 12) := by rw [Nat.mul_assoc closureIndex 96 12]
      _ = closureIndex * 1152 := rfl
  have hconst : 31 * 18 + 26 * 78 = 2586 := rfl
  rw [hconst]
  rw [Nat.mul_comm (closureIndex * 12) 96]
  rw [h96]

