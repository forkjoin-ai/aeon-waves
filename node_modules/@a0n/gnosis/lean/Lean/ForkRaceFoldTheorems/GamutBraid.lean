/-- Runtime-facing pressure-certified execution path payload. -/
structure PressureCertifiedExecutionPath where
  certificateVersion : String
  pressureIdentity : String
  runtime : String
  host : String
  topologyCoordinates : List Nat
  gateCoordinates : List Nat
  decompositionCoordinates : List Nat
  interferePortCoordinate : Nat
  interfereClosureCoordinate : Nat
  interferenceStrideTrace : List Nat
  leakagePressureTrace : List Nat
  pressureWeightedInterferenceStrideTrace : List Nat
  pressureWeightedInterferenceTotal : Nat
  closureFamilyPressureTotal : Nat
  informationMassTotal : Nat
  leakageTotal : Nat
  massUnit : String
  pressureUnit : String
  theoremIds : List String
deriving DecidableEq, Repr

/-- Exact pressure-certified execution path payload mirrored by runtimes. -/
def exactPressureCertifiedExecutionPath (cycle : Nat) :
    PressureCertifiedExecutionPath :=
  { certificateVersion := pressureCertifiedExecutionPathCertificateVersion
    pressureIdentity := pressureCertifiedExecutionPathPressureIdentity
    runtime := "gnosis"
    host := "gnosis-uring"
    topologyCoordinates := (exactPressureWeightedClosedLoopBenchmarkReport cycle).topologyCoordinates
    gateCoordinates := naturalPortCoordinates
    decompositionCoordinates := [7, 17, 22]
    interferePortCoordinate := interferePortCoordinate
    interfereClosureCoordinate := interferePortClosureCoordinate
    interferenceStrideTrace :=
      pressureWeightedBenchmarkInterferenceStrideTraceFor interferePortCoordinate
    leakagePressureTrace := (exactBraidPacket cycle).leakageTrace
    pressureWeightedInterferenceStrideTrace :=
      pressureWeightedInterferenceStrideTrace (exactBraidPacket cycle)
    pressureWeightedInterferenceTotal :=
      pressureWeightedInterferenceTotal (exactBraidPacket cycle)
    closureFamilyPressureTotal :=
      closureFamilyAuditPressureTotal
        (boundedIndexedInterfereClosureFamilyAuditTrace cycle)
    informationMassTotal := (exactBraidPacket cycle).totalInformationMass
    leakageTotal := (exactBraidPacket cycle).totalLeakage
    massUnit := "gG"
    pressureUnit := "SPa"
    theoremIds := pressureCertifiedExecutionPathTheoremIds }

/--
The pressure-certified execution path is valid when every runtime-facing field
is forced by existing closed-loop, pressure, closure-audit, and benchmark
certificates.
-/
structure PressureCertifiedExecutionPathCertificate
    (path : PressureCertifiedExecutionPath)
    (cycle : Nat) : Prop where
  closedLoop :
    closedLoopCertified (exactGamutBraid cycle) (exactBraidPacket cycle)
  runtimeMetadata :
    closedLoopRuntimeMetadataCertified
      (exactClosedLoopRuntimeMetadata cycle)
      (exactGamutBraid cycle)
      (exactBraidPacket cycle)
  benchmark :
    pressureWeightedClosedLoopBenchmarkReportCertified
      (exactPressureWeightedClosedLoopBenchmarkReport cycle)
      (exactBraidPacket cycle)
  versionValue :
    path.certificateVersion = pressureCertifiedExecutionPathCertificateVersion
  identityValue :
    path.pressureIdentity = pressureCertifiedExecutionPathPressureIdentity
  runtimeValue : path.runtime = "gnosis"
  hostValue : path.host = "gnosis-uring"
  topologyValue : path.topologyCoordinates = [10, 12, 17, 22, 43]
  gateValue : path.gateCoordinates = [10, 12, 17, 22]
  decompositionValue : path.decompositionCoordinates = [7, 17, 22]
  interfereValue : path.interferePortCoordinate = 43
  closureValue : path.interfereClosureCoordinate = 55
  strideValue : path.interferenceStrideTrace = [33, 31, 26, 21]
  leakageTraceValue : path.leakagePressureTrace = [0, 18, 78]
  weightedTraceValue :
