/-!
## Toroidal lens geometry

The toroidal-lens reading adds a second finite view over the same packet. It
records how the local plane, pink enclosure, brown path, and terminal axis are
selected by perspective without asserting analytic manifold structure.
-/

/-- Finite observer perspectives for the braid/lens reading. -/
inductive LensPerspective where
  | localAeon
  | interfacePink
  | enclosureBrown
  | terminalInterference
deriving DecidableEq, Repr

/-- Shape labels exposed by a finite perspective reading. -/
inductive LensShape where
  | plane
  | sphere
  | torus
  | singularAxis
  | packedLens
  | selfReferenceKnot
deriving DecidableEq, Repr

/-- A perspective records the coordinate and shape exposed by that view. -/
structure LensObservation where
  perspective : LensPerspective
  coordinate : Nat
  shape : LensShape
deriving DecidableEq, Repr

/-- Local Aeon view: coordinate 12 maps to the finite plane label. -/
def exactLocalAeonLensObservation : LensObservation :=
  { perspective := LensPerspective.localAeon
    coordinate := portActionCoordinate BraidPortAction.race
    shape := LensShape.plane }

/-- Pink interface view: saturation 30 maps to the finite sphere label. -/
def exactPinkLensObservation : LensObservation :=
  { perspective := LensPerspective.interfacePink
    coordinate := exactPinkSphericalLayer.saturation
    shape := LensShape.sphere }

/-- Brown enclosure view: saturation 90 maps to the finite torus label. -/
def exactBrownLensObservation : LensObservation :=
  { perspective := LensPerspective.enclosureBrown
    coordinate := exactBrownSphericalLayer.saturation
    shape := LensShape.torus }

/-- Terminal interference view: coordinate 43 maps to the finite axis label. -/
def exactTerminalLensObservation : LensObservation :=
  { perspective := LensPerspective.terminalInterference
    coordinate := interferePortCoordinate
    shape := LensShape.singularAxis }

/-- Exact perspective trace for the local plane, sphere, torus, and axis views. -/
def lensObservationTrace : List LensObservation :=
  [exactLocalAeonLensObservation, exactPinkLensObservation,
    exactBrownLensObservation, exactTerminalLensObservation]

/-- Coordinates exposed by the finite lens perspectives. -/
def lensObservationCoordinates : List Nat :=
  lensObservationTrace.map LensObservation.coordinate

/-- Shape labels exposed by the finite lens perspectives. -/
def lensObservationShapes : List LensShape :=
  lensObservationTrace.map LensObservation.shape

/-- The perspective table is exact when coordinates and shape labels both match. -/
def lensPerspectiveTraceCertified : Prop :=
  lensObservationCoordinates = [12, 30, 90, 43] /\
    lensObservationShapes =
      [LensShape.plane, LensShape.sphere,
        LensShape.torus, LensShape.singularAxis]

/-- Dual geometry certificate: pink encloses while brown braids. -/
def dualGeometryCertified : Prop :=
  exactPinkSphericalLayer.shape = PackedTopologyShape.informationSphere /\
    exactBrownSphericalLayer.shape = PackedTopologyShape.toroidalBraid /\
    exactBrownSphericalLayer.wrapCount = 3 /\
    exactBrownSphericalLayer.rotationDegrees =
      3 * exactPinkSphericalLayer.rotationDegrees

/-- Perfect local double cover against the 12-row aperture. -/
def perfectLocalDoubleCoverCoordinate : Nat :=
  2 * bucketSize

/-- Gap between the perfect double cover and the double keystone. -/
def doubleKeystoneCoverDeficit : Nat :=
  perfectLocalDoubleCoverCoordinate - portActionCoordinate BraidPortAction.vent

/-- Flat-torus reference pressure used as the zero-pressure comparator. -/
def flatTorusReferencePressure : Nat :=
  0

/-- Finite certificate for the twisted double-keystone pressure surface. -/
structure TwistedDoubleKeystone where
  bucket : Nat
  halfCarrier : Nat
  doubleKeystone : Nat
  foldSwerve : Nat
  crossingCount : Nat
  leakagePressure : Nat
  flatReferencePressure : Nat
deriving DecidableEq, Repr

/-- Exact twisted double-keystone witness over the 12/17/22/96 surface. -/
def exactTwistedDoubleKeystone : TwistedDoubleKeystone :=
  { bucket := bucketSize
    halfCarrier := 11
    doubleKeystone := portActionCoordinate BraidPortAction.vent
    foldSwerve := portActionCoordinate BraidPortAction.fold
    crossingCount := 5
    leakagePressure := totalLeakage exactReconstructionWitness.omega
    flatReferencePressure := flatTorusReferencePressure }

/-- A twisted double-keystone has a folded 11+11 carrier and positive pressure. -/
def twistedDoubleKeystoneCertified
    (twist : TwistedDoubleKeystone) : Prop :=
  twist.bucket = 12 /\
    twist.halfCarrier + twist.halfCarrier = twist.doubleKeystone /\
    twist.doubleKeystone = 22 /\
    twist.doubleKeystone + 2 = 2 * twist.bucket /\
    doubleKeystoneCoverDeficit = 2 /\
    twist.foldSwerve = 17 /\
    twist.bucket < twist.foldSwerve /\
    twist.foldSwerve < twist.doubleKeystone /\
    twist.foldSwerve + twist.crossingCount = twist.doubleKeystone /\
    twist.leakagePressure = 96 /\
    twist.flatReferencePressure = 0 /\
    twist.flatReferencePressure < twist.leakagePressure

/-- Coordinate trace for the finite twist pressure certificate. -/
def twistPressureTrace : List Nat :=
  [exactTwistedDoubleKeystone.foldSwerve,
    exactTwistedDoubleKeystone.doubleKeystone,
    exactTwistedDoubleKeystone.leakagePressure]

