/-!
## Finite cyclic quotient compiler

The quotient compiler is the computational surface of the spherical/toroidal
reading. It names the representative arc, proves that finite cyclic repetition
reconstructs the full rotation, and records the exact quadratic work reduction.
-/

/-- Finite cyclic quotient modes used by the compiler. -/
inductive CyclicQuotientMode where
  | antipodal
  | tripleWrap
  | sixfoldWrap
deriving DecidableEq, Repr

/-- A quotient certificate over one finite rotation layer. -/
structure FiniteCyclicQuotient where
  mode : CyclicQuotientMode
  layer : SphericalAccountingLayer
  quotientFactor : Nat
  representativeDegrees : Nat
  orbitDegrees : Nat
  reconstructedDegrees : Nat
  fullWork : Nat
  representativeWork : Nat
deriving DecidableEq, Repr

/-- A finite quotient reconstructs the full orbit and reduces quadratic work. -/
def finiteCyclicQuotientCertified
    (quotient : FiniteCyclicQuotient) : Prop :=
  quotient.orbitDegrees = quotient.layer.rotationDegrees /\
    quotient.representativeDegrees * quotient.quotientFactor =
      quotient.orbitDegrees /\
    quotient.reconstructedDegrees =
      quotient.representativeDegrees * quotient.quotientFactor /\
    quotient.reconstructedDegrees = quotient.orbitDegrees /\
    quotient.fullWork = fullQuadraticRotationWork quotient.orbitDegrees /\
    quotient.representativeWork =
      quotient.representativeDegrees * quotient.orbitDegrees /\
    quotient.representativeWork * quotient.quotientFactor =
      quotient.fullWork /\
    quotient.representativeWork < quotient.fullWork

/-- Pink antipodal quotient: 180 repeated twice reconstructs 360. -/
def exactPinkAntipodalCyclicQuotient : FiniteCyclicQuotient :=
  { mode := CyclicQuotientMode.antipodal
    layer := exactPinkSphericalLayer
    quotientFactor := 2
    representativeDegrees := 180
    orbitDegrees := 360
    reconstructedDegrees := 360
    fullWork := 129600
    representativeWork := 64800 }

/-- Brown triple-wrap quotient: 360 repeated three times reconstructs 1080. -/
def exactBrownTripleWrapCyclicQuotient : FiniteCyclicQuotient :=
  { mode := CyclicQuotientMode.tripleWrap
    layer := exactBrownSphericalLayer
    quotientFactor := 3
    representativeDegrees := 360
    orbitDegrees := 1080
    reconstructedDegrees := 1080
    fullWork := 1166400
    representativeWork := 388800 }

/-- Brown antipodal quotient: 540 repeated twice reconstructs 1080. -/
def exactBrownAntipodalCyclicQuotient : FiniteCyclicQuotient :=
  { mode := CyclicQuotientMode.antipodal
    layer := exactBrownSphericalLayer
    quotientFactor := 2
    representativeDegrees := 540
    orbitDegrees := 1080
    reconstructedDegrees := 1080
    fullWork := 1166400
    representativeWork := 583200 }

/--
Brown sixfold quotient: combine triple wrap and antipodal symmetry so one
180-degree representative reconstructs the full 1080-degree orbit.
-/
def exactBrownSixfoldCyclicQuotient : FiniteCyclicQuotient :=
  { mode := CyclicQuotientMode.sixfoldWrap
    layer := exactBrownSphericalLayer
    quotientFactor := 6
    representativeDegrees := 180
    orbitDegrees := 1080
    reconstructedDegrees := 1080
    fullWork := 1166400
    representativeWork := 194400 }

/-- A compiler packages the exact quotients used by the braid packet. -/
structure CyclicQuotientCompiler where
  pinkAntipodal : FiniteCyclicQuotient
  brownTripleWrap : FiniteCyclicQuotient
  brownAntipodal : FiniteCyclicQuotient
  brownSixfold : FiniteCyclicQuotient
deriving DecidableEq, Repr

/-- Exact quotient compiler for the Pink/Brown finite rotation surfaces. -/
def exactCyclicQuotientCompiler : CyclicQuotientCompiler :=
  { pinkAntipodal := exactPinkAntipodalCyclicQuotient
    brownTripleWrap := exactBrownTripleWrapCyclicQuotient
    brownAntipodal := exactBrownAntipodalCyclicQuotient
    brownSixfold := exactBrownSixfoldCyclicQuotient }

/-- Full orbit degrees consumed by the compiler. -/
def cyclicCompilerFullOrbitTrace
    (compiler : CyclicQuotientCompiler) : List Nat :=
  [compiler.pinkAntipodal.orbitDegrees,
    compiler.brownSixfold.orbitDegrees]

/-- Representative degrees that the compiler actually evaluates. -/
def cyclicCompilerRepresentativeTrace
    (compiler : CyclicQuotientCompiler) : List Nat :=
  [compiler.pinkAntipodal.representativeDegrees,
    compiler.brownSixfold.representativeDegrees]

/-- Degrees reconstructed from representative repetition. -/
def cyclicCompilerReconstructedTrace
    (compiler : CyclicQuotientCompiler) : List Nat :=
  [compiler.pinkAntipodal.reconstructedDegrees,
    compiler.brownSixfold.reconstructedDegrees]

/-- Full finite quadratic work over the Pink/Brown surfaces. -/
def cyclicCompilerFullWork
    (compiler : CyclicQuotientCompiler) : Nat :=
  compiler.pinkAntipodal.fullWork + compiler.brownSixfold.fullWork

/-- Representative finite quadratic work after cyclic quotienting. -/
def cyclicCompilerRepresentativeWork
    (compiler : CyclicQuotientCompiler) : Nat :=
  compiler.pinkAntipodal.representativeWork +
    compiler.brownSixfold.representativeWork

/-- Exact packet-level compiler certificate for the cyclic quotient shortcut. -/
def cyclicQuotientCompilerCertified
    (compiler : CyclicQuotientCompiler)
    (packet : BraidPacket) : Prop :=
  sphericalAccountingCertified packet /\
    finiteCyclicQuotientCertified compiler.pinkAntipodal /\
    finiteCyclicQuotientCertified compiler.brownTripleWrap /\
    finiteCyclicQuotientCertified compiler.brownAntipodal /\
    finiteCyclicQuotientCertified compiler.brownSixfold /\
    compiler.pinkAntipodal.mode = CyclicQuotientMode.antipodal /\
    compiler.brownTripleWrap.mode = CyclicQuotientMode.tripleWrap /\
    compiler.brownAntipodal.mode = CyclicQuotientMode.antipodal /\
    compiler.brownSixfold.mode = CyclicQuotientMode.sixfoldWrap /\
    cyclicCompilerFullOrbitTrace compiler = [360, 1080] /\
    cyclicCompilerRepresentativeTrace compiler = [180, 180] /\
    cyclicCompilerReconstructedTrace compiler = [360, 1080] /\
    cyclicCompilerFullWork compiler = 1296000 /\
    cyclicCompilerRepresentativeWork compiler = 259200 /\
    cyclicCompilerRepresentativeWork compiler * 5 =
      cyclicCompilerFullWork compiler /\
    cyclicCompilerRepresentativeWork compiler <
      cyclicCompilerFullWork compiler /\
    packet.totalInformationMass = 1560

/-- The exact pink antipodal quotient is certified. -/
theorem exact_pink_antipodal_cyclic_quotient_certified :
    finiteCyclicQuotientCertified exactPinkAntipodalCyclicQuotient := by
