    {cycle : Nat}
    {closureIndices : List Nat}
    {row : IndexedInterfereClosureFamilyAuditRow}
    (member :
      row ∈ indexedInterfereClosureFamilyAuditTrace cycle closureIndices) :
    ∃ closureIndex,
      closureIndex ∈ closureIndices ∧
        row = indexedInterfereClosureFamilyAuditRow cycle closureIndex ∧
        indexedInterferePortClosureFamilyCertified
          exactFortyThreePrimeTransition
          row.portCoordinate
          row.closureCoordinate
          row.closureIndex ∧
        row.closureAxisPressureWeightedTotal =
          2586 + closureIndex * 1152 := by
  unfold indexedInterfereClosureFamilyAuditTrace at member
  rcases List.mem_map.mp member with ⟨closureIndex, listed, row_eq⟩
  refine ⟨closureIndex, listed, row_eq.symm, ?_, ?_⟩
  · rw [← row_eq]
    exact indexed_interfere_closure_family_audit_row_certified
      cycle
      closureIndex
  · rw [← row_eq]
    exact indexed_interfere_closure_family_audit_row_pressure_total
      cycle
