/-!
# AWSIoTEventsStepFunctionsEKSNodegroupReleaseVersionMisconfigurationDetectionSecurityEconomics

EKS managed node group release-version (AMI version) misconfiguration
detection security-economics. Five gap theorems: each proves that absence of
a specific control creates strictly-positive compliance or revenue-at-risk
exposure.

Anti-thesis pattern: structure posits absence of a control, theorem derives
strictly-positive risk. Zero sorry — all close by exact.
-/

namespace ForkRaceFoldTheorems

-- ── Theorem 1 ────────────────────────────────────────────────────────────────
-- Anti-thesis: EKS nodegroup releaseVersion (AMI) is NOT pinned to a
-- FIPS-validated image AND the EBS root volume is NOT encrypted with a
-- customer-managed KMS key → compliance gap is strictly positive.

structure NodegroupReleaseVersionFIPSCMKGapAssumptions where
  releaseVersionFIPSPinned : Bool
  ebsEncryptedWithCMK : Bool
  complianceRisk : Nat
  gapFromUnpinnedFIPSAndMissingCMK :
    releaseVersionFIPSPinned = false →
    ebsEncryptedWithCMK = false →
    0 < complianceRisk

theorem nodegroup_release_version_fips_cmk_gap_exists
    (a : NodegroupReleaseVersionFIPSCMKGapAssumptions)
    (hFIPS : a.releaseVersionFIPSPinned = false)
    (hCMK : a.ebsEncryptedWithCMK = false) :
    0 < a.complianceRisk :=
  a.gapFromUnpinnedFIPSAndMissingCMK hFIPS hCMK

-- ── Theorem 2 ────────────────────────────────────────────────────────────────
-- Anti-thesis: releaseVersion is set to LATEST (floating) AND no approval
-- workflow gates new AMI adoption → supply-chain attack risk is strictly
-- positive.

structure ReleaseVersionFloatingApprovalGapAssumptions where
  releaseVersionPinned : Bool
  approvalWorkflowExists : Bool
  supplyChainRisk : Nat
  gapFromFloatingVersionAndMissingApproval :
    releaseVersionPinned = false →
    approvalWorkflowExists = false →
    0 < supplyChainRisk

theorem release_version_floating_approval_gap_exists
    (a : ReleaseVersionFloatingApprovalGapAssumptions)
    (hPinned : a.releaseVersionPinned = false)
    (hApproval : a.approvalWorkflowExists = false) :
    0 < a.supplyChainRisk :=
  a.gapFromFloatingVersionAndMissingApproval hPinned hApproval

-- ── Theorem 3 ────────────────────────────────────────────────────────────────
-- Anti-thesis: the IAM role attached to the nodegroup is NOT scoped to AMI
-- pull operations only → lateral movement risk is strictly positive.

structure NodegroupReleaseVersionIAMScopeGapAssumptions where
  iamRoleScopedToAMIPull : Bool
  lateralMovementRisk : Nat
  gapFromUnscopedRole : iamRoleScopedToAMIPull = false → 0 < lateralMovementRisk

theorem nodegroup_release_version_iam_scope_gap_exists
    (a : NodegroupReleaseVersionIAMScopeGapAssumptions)
    (h : a.iamRoleScopedToAMIPull = false) :
    0 < a.lateralMovementRisk :=
  a.gapFromUnscopedRole h

-- ── Theorem 4 ────────────────────────────────────────────────────────────────
-- Anti-thesis: no CloudWatch alarm fires when the nodegroup AMI drifts from
-- the approved baseline AND the SOC has no runbook for AMI drift → SOC gap
-- is strictly positive.

structure NodegroupReleaseVersionAlarmSOCGapAssumptions where
  amiDriftAlarmConfigured : Bool
  socRunbookExists : Bool
  socGap : Nat
  gapFromMissingDriftAlarmAndRunbook :
    amiDriftAlarmConfigured = false →
    socRunbookExists = false →
    0 < socGap

theorem nodegroup_release_version_alarm_soc_gap_exists
    (a : NodegroupReleaseVersionAlarmSOCGapAssumptions)
    (hAlarm : a.amiDriftAlarmConfigured = false)
    (hRunbook : a.socRunbookExists = false) :
    0 < a.socGap :=
  a.gapFromMissingDriftAlarmAndRunbook hAlarm hRunbook

-- ── Theorem 5 ────────────────────────────────────────────────────────────────
-- Anti-thesis: AWS X-Ray active tracing is NOT enabled on the AMI-update
-- lifecycle path AND AMI update events are not logged to CloudTrail →
-- observability gap is strictly positive.

structure NodegroupReleaseVersionXRayGapAssumptions where
  xRayTracingEnabled : Bool
  cloudTrailLoggingEnabled : Bool
  observabilityGap : Nat
  gapFromMissingXRayAndCloudTrail :
    xRayTracingEnabled = false →
    cloudTrailLoggingEnabled = false →
    0 < observabilityGap

theorem nodegroup_release_version_xray_gap_exists
    (a : NodegroupReleaseVersionXRayGapAssumptions)
    (hXRay : a.xRayTracingEnabled = false)
    (hTrail : a.cloudTrailLoggingEnabled = false) :
    0 < a.observabilityGap :=
  a.gapFromMissingXRayAndCloudTrail hXRay hTrail

end ForkRaceFoldTheorems
