import Init

namespace ForkRaceFoldTheorems
namespace FoilLoserPolicy

/-- Runtime policy for work that loses the current race. -/
inductive RaceLoserPolicy where
  | cancel
  | drain
  | drainAndCache
  | integration
  deriving DecidableEq, Repr

/-- A pure race candidate with a measured cost and deterministic result. -/
structure RaceCandidate (Result : Type) where
  id : Nat
  cost : Nat
  result : Result
  cacheable : Bool
  deriving Repr

/-- Stable lower-cost comparator: equal costs keep the left candidate. -/
def lowerCost {Result : Type}
    (left right : RaceCandidate Result) : RaceCandidate Result :=
  if left.cost <= right.cost then left else right

/-- Select the current winner from a known seed and remaining candidates. -/
def selectWinnerFrom {Result : Type}
    (seed : RaceCandidate Result) :
    List (RaceCandidate Result) -> RaceCandidate Result
  | [] => seed
  | candidate :: rest => selectWinnerFrom (lowerCost seed candidate) rest

/-- Select the winner from a finite race, if any candidate exists. -/
def selectWinner {Result : Type} :
    List (RaceCandidate Result) -> Option (RaceCandidate Result)
  | [] => none
  | candidate :: rest => some (selectWinnerFrom candidate rest)

/--
Loser residue retained after the current winner has been chosen. `drain` keeps
only the fact that the work completed; `drainAndCache` keeps cacheable results.
-/
def retainedResidue {Result : Type}
    (policy : RaceLoserPolicy)
    (winner : RaceCandidate Result)
    (candidates : List (RaceCandidate Result)) :
    List (Nat × Result) :=
  match policy with
  | RaceLoserPolicy.cancel => []
  | RaceLoserPolicy.drain =>
      candidates.filterMap (fun candidate =>
        if candidate.id = winner.id then none else some (candidate.id, candidate.result))
  | RaceLoserPolicy.drainAndCache | RaceLoserPolicy.integration =>
      candidates.filterMap (fun candidate =>
        if candidate.id = winner.id then
          none
        else if candidate.cacheable then
          some (candidate.id, candidate.result)
        else
          none)

/--
Bounded admission for integration residue. Runtime integration uses a finite
resident queue; this pure model keeps the first `capacity` residue entries and
drops the rest instead of blocking the present winner.
-/
def admittedIntegrationResidue {Result : Type}
    (capacity : Nat)
    (winner : RaceCandidate Result)
    (candidates : List (RaceCandidate Result)) :
    List (Nat × Result) :=
  (retainedResidue RaceLoserPolicy.integration winner candidates).take capacity

/--
Telemetry projected from bounded integration admission. The counters observe how
much future-facing residue was admitted or dropped; they do not feed back into
winner selection.
-/
structure IntegrationTelemetry where
  admitted : Nat
  dropped : Nat
  capacity : Nat
  deriving Repr

/-- Runtime-facing telemetry projection for bounded integration residue. -/
def integrationTelemetry {Result : Type}
    (capacity : Nat)
    (winner : RaceCandidate Result)
    (candidates : List (RaceCandidate Result)) :
    IntegrationTelemetry :=
  let residue := retainedResidue RaceLoserPolicy.integration winner candidates
  let admitted := (admittedIntegrationResidue capacity winner candidates).length
  { admitted
    dropped := residue.length - admitted
    capacity }

/-- Full race report: current winner plus any future-facing residue. -/
structure RaceReport (Result : Type) where
  winner : Option (RaceCandidate Result)
  residue : List (Nat × Result)
  policy : RaceLoserPolicy

/-- Run a race under a loser policy. -/
def runRace {Result : Type}
    (policy : RaceLoserPolicy)
    (candidates : List (RaceCandidate Result)) :
    RaceReport Result :=
  match selectWinner candidates with
  | none => { winner := none, residue := [], policy }
  | some winner =>
      { winner := some winner
        residue := retainedResidue policy winner candidates
        policy }

/-- Minimal cache status for winner reuse. `stale` covers expiry, shape mismatch,
or any resident cache entry the current request cannot soundly reuse. -/
inductive CacheStatus where
  | fresh
  | stale
  deriving DecidableEq, Repr

/--
Pure cache recovery model. Fresh cache reuses the previous race report; stale
cache reruns the current race and rebuilds residue from current candidates.
-/
def recoverRace {Result : Type}
    (policy : RaceLoserPolicy)
    (status : CacheStatus)
    (cached current : List (RaceCandidate Result)) :
    RaceReport Result :=
  match status with
  | CacheStatus.fresh => runRace policy cached
  | CacheStatus.stale => runRace policy current

/--
Changing loser policy cannot change the current winner. This theorem gives the formal
boundary that lets FOIL default pure hot paths to `integration`: the future
may receive cached residue, but the present winner is selected by the same
finite lower-cost race.
-/
theorem loser_policy_does_not_change_winner {Result : Type}
    (leftPolicy rightPolicy : RaceLoserPolicy)
    (candidates : List (RaceCandidate Result)) :
    (runRace leftPolicy candidates).winner =
      (runRace rightPolicy candidates).winner := by
  unfold runRace
  cases selectWinner candidates <;> rfl

/-- Cancel policy retains no loser residue. -/
theorem cancel_retains_no_residue {Result : Type}
    (candidates : List (RaceCandidate Result)) :
    (runRace RaceLoserPolicy.cancel candidates).residue = [] := by
  unfold runRace
  cases selectWinner candidates <;> rfl

/--
The integration policy has the same current winner as cancel. Integration may
admit future-facing residue, but the selected result for the present race is
unchanged.
-/
theorem integration_preserves_cancel_winner {Result : Type}
    (candidates : List (RaceCandidate Result)) :
    (runRace RaceLoserPolicy.integration candidates).winner =
      (runRace RaceLoserPolicy.cancel candidates).winner := by
  exact loser_policy_does_not_change_winner
    RaceLoserPolicy.integration RaceLoserPolicy.cancel candidates

/--
When the current winner exists, `drainAndCache` residue is bounded by the
candidate list it came from: every retained id/result pair came from a listed
cacheable non-winner candidate.
-/
theorem drain_and_cache_residue_from_cacheable_losers {Result : Type}
    (winner : RaceCandidate Result)
    (id : Nat)
    (result : Result)
    (candidates : List (RaceCandidate Result))
    (hMem : (id, result) ∈
      retainedResidue RaceLoserPolicy.drainAndCache winner candidates) :
    ∃ candidate, candidate ∈ candidates /\
      candidate.id = id /\
      candidate.result = result /\
      candidate.id ≠ winner.id /\
      candidate.cacheable = true := by
  unfold retainedResidue at hMem
  rw [List.mem_filterMap] at hMem
  rcases hMem with ⟨source, hSourceMem, hSource⟩
  by_cases hWinner : source.id = winner.id
  · simp [hWinner] at hSource
  · cases hCache : source.cacheable
    · simp [hWinner, hCache] at hSource
    · simp [hWinner, hCache] at hSource
      rcases hSource with ⟨hId, hResult⟩
      exact ⟨source, hSourceMem, hId, hResult, hWinner, hCache⟩

/--
Integration residue has the same cacheability boundary as drain-and-cache:
every retained id/result pair comes from a listed cacheable non-winner
candidate.
-/
theorem integration_residue_from_cacheable_losers {Result : Type}
    (winner : RaceCandidate Result)
    (id : Nat)
    (result : Result)
    (candidates : List (RaceCandidate Result))
    (hMem : (id, result) ∈
      retainedResidue RaceLoserPolicy.integration winner candidates) :
    ∃ candidate, candidate ∈ candidates /\
      candidate.id = id /\
      candidate.result = result /\
      candidate.id ≠ winner.id /\
      candidate.cacheable = true := by
  exact drain_and_cache_residue_from_cacheable_losers
    winner id result candidates hMem

/--
Integration admission is bounded by queue capacity. Overflow can be dropped,
which models the runtime `try_send` path: no synchronous wait is introduced to
clone loser work into the future cache.
-/
theorem admitted_integration_residue_bounded {Result : Type}
    (capacity : Nat)
    (winner : RaceCandidate Result)
    (candidates : List (RaceCandidate Result)) :
    (admittedIntegrationResidue capacity winner candidates).length <= capacity := by
  unfold admittedIntegrationResidue
  exact List.length_take_le capacity
    (retainedResidue RaceLoserPolicy.integration winner candidates)

/-- Telemetry admitted count is bounded by the same resident queue capacity. -/
theorem integration_telemetry_admitted_bounded {Result : Type}
    (capacity : Nat)
    (winner : RaceCandidate Result)
    (candidates : List (RaceCandidate Result)) :
    (integrationTelemetry capacity winner candidates).admitted <= capacity := by
  unfold integrationTelemetry
  exact admitted_integration_residue_bounded capacity winner candidates

/--
Telemetry is a projection over the bounded residue calculation: admitted plus
dropped accounts for the full integration residue length.
-/
theorem integration_telemetry_accounts_for_residue {Result : Type}
    (capacity : Nat)
    (winner : RaceCandidate Result)
    (candidates : List (RaceCandidate Result)) :
    (integrationTelemetry capacity winner candidates).admitted +
        (integrationTelemetry capacity winner candidates).dropped =
      (retainedResidue RaceLoserPolicy.integration winner candidates).length := by
  unfold integrationTelemetry admittedIntegrationResidue
  let residue := retainedResidue RaceLoserPolicy.integration winner candidates
  have hTakeLe : (residue.take capacity).length <= residue.length :=
    by
      rw [List.length_take]
      exact Nat.min_le_right capacity residue.length
  exact Nat.add_sub_of_le hTakeLe

/--
Telemetry projection cannot change the present winner. Counters observe bounded
future-facing admission; the current result remains the cancel-policy winner.
-/
theorem integration_telemetry_preserves_cancel_winner {Result : Type}
    (capacity : Nat)
    (winner : RaceCandidate Result)
    (candidates : List (RaceCandidate Result)) :
    (runRace RaceLoserPolicy.integration candidates).winner =
        (runRace RaceLoserPolicy.cancel candidates).winner /\
      (integrationTelemetry capacity winner candidates).admitted <= capacity := by
  constructor
  · exact integration_preserves_cancel_winner candidates
  · exact integration_telemetry_admitted_bounded capacity winner candidates

/--
Bounded integration admission cannot change the present winner; capacity only
limits future-facing residue.
-/
theorem admitted_integration_preserves_cancel_winner {Result : Type}
    (capacity : Nat)
    (candidates : List (RaceCandidate Result)) :
    (runRace RaceLoserPolicy.integration candidates).winner =
      (runRace RaceLoserPolicy.cancel candidates).winner /\
    ∀ winner,
      (admittedIntegrationResidue capacity winner candidates).length <= capacity := by
  constructor
  · exact integration_preserves_cancel_winner candidates
  · intro winner
    exact admitted_integration_residue_bounded capacity winner candidates

/--
Every bounded admitted integration entry keeps the same source boundary as
full integration residue: it came from a listed cacheable non-winner candidate.
-/
theorem admitted_integration_residue_from_cacheable_losers {Result : Type}
    (capacity : Nat)
    (winner : RaceCandidate Result)
    (id : Nat)
    (result : Result)
    (candidates : List (RaceCandidate Result))
    (hMem : (id, result) ∈
      admittedIntegrationResidue capacity winner candidates) :
    ∃ candidate, candidate ∈ candidates /\
      candidate.id = id /\
      candidate.result = result /\
      candidate.id ≠ winner.id /\
      candidate.cacheable = true := by
  unfold admittedIntegrationResidue at hMem
  exact integration_residue_from_cacheable_losers winner id result candidates
    (List.mem_of_mem_take hMem)

/--
Stale cache recovery ignores the old race and selects the current winner. This
is the formal boundary for expiry or shape mismatch: stale cache data cannot
change the present result.
-/
theorem stale_recovery_uses_current_winner {Result : Type}
    (policy : RaceLoserPolicy)
    (cached current : List (RaceCandidate Result)) :
    (recoverRace policy CacheStatus.stale cached current).winner =
      (runRace policy current).winner := by
  rfl

/--
Stale integration recovery preserves the same present winner as cancel on the
current candidates.
-/
theorem stale_integration_recovery_preserves_cancel_winner {Result : Type}
    (cached current : List (RaceCandidate Result)) :
    (recoverRace RaceLoserPolicy.integration CacheStatus.stale cached current).winner =
      (runRace RaceLoserPolicy.cancel current).winner := by
  exact integration_preserves_cancel_winner current

/--
After stale recovery, bounded integration admission is still capacity-bounded
and sourced only from the current rebuilt race.
-/
theorem stale_recovery_admitted_residue_bounded {Result : Type}
    (capacity : Nat)
    (cached current : List (RaceCandidate Result)) :
    (recoverRace RaceLoserPolicy.integration CacheStatus.stale cached current).winner =
      (runRace RaceLoserPolicy.integration current).winner /\
    ∀ winner,
      (admittedIntegrationResidue capacity winner current).length <= capacity := by
  constructor
  · rfl
  · intro winner
    exact admitted_integration_residue_bounded capacity winner current

/-- Runtime transport used to expose the same attestation over distinct paths. -/
inductive RuntimeAttestationTransport where
  | http
  | flowUdp
  deriving DecidableEq, Repr

/--
Transport-level runtime attestation wrapper. The transport label changes the
delivery path; the certificate payload, theorem id projection, and client-facing
summary are carried unchanged. Optional entropy certificates are carried as
payload evidence when a runtime has resident entropy-harvest output.
-/
structure RuntimeAttestationEnvelope (Certificate Summary Entropy : Type) where
  transport : RuntimeAttestationTransport
  certificate : Certificate
  theoremIds : List String
  summary : Summary
  entropyCertificate : Option Entropy
  deriving Repr

/-- Build a runtime attestation envelope for a concrete transport. -/
def runtimeAttestationEnvelope {Certificate : Type}
    {Summary : Type}
    {Entropy : Type}
    (transport : RuntimeAttestationTransport)
    (certificate : Certificate)
    (theoremIds : List String)
    (summary : Summary)
    (entropyCertificate : Option Entropy) :
    RuntimeAttestationEnvelope Certificate Summary Entropy :=
  { transport, certificate, theoremIds, summary, entropyCertificate }

/--
Changing only the attestation transport preserves the certificate payload. This
is the formal transport boundary for HTTP and Flow/UDP runtime attestation.
-/
theorem runtime_attestation_transport_preserves_certificate {Certificate : Type}
    {Summary : Type}
    {Entropy : Type}
    (leftTransport rightTransport : RuntimeAttestationTransport)
    (certificate : Certificate)
    (theoremIds : List String)
    (summary : Summary)
    (entropyCertificate : Option Entropy) :
    (runtimeAttestationEnvelope leftTransport certificate theoremIds summary
      entropyCertificate).certificate =
      (runtimeAttestationEnvelope rightTransport certificate theoremIds summary
        entropyCertificate).certificate := by
  rfl

/--
Changing only the attestation transport preserves the theorem id projection.
The runtime HTTP and Flow/UDP surfaces may wrap bytes differently, but cite the
same formal obligations.
-/
theorem runtime_attestation_transport_preserves_theorem_ids {Certificate : Type}
    {Summary : Type}
    {Entropy : Type}
    (leftTransport rightTransport : RuntimeAttestationTransport)
    (certificate : Certificate)
    (theoremIds : List String)
    (summary : Summary)
    (entropyCertificate : Option Entropy) :
    (runtimeAttestationEnvelope leftTransport certificate theoremIds summary
      entropyCertificate).theoremIds =
      (runtimeAttestationEnvelope rightTransport certificate theoremIds summary
        entropyCertificate).theoremIds := by
  rfl

/--
Changing only the attestation transport preserves the summary projection seen by
dashboards and probes. Summary computation may compress certificate detail, but
transport selection cannot alter that projection.
-/
theorem runtime_attestation_transport_preserves_summary {Certificate : Type}
    {Summary : Type}
    {Entropy : Type}
    (leftTransport rightTransport : RuntimeAttestationTransport)
    (certificate : Certificate)
    (theoremIds : List String)
    (summary : Summary)
    (entropyCertificate : Option Entropy) :
    (runtimeAttestationEnvelope leftTransport certificate theoremIds summary
      entropyCertificate).summary =
      (runtimeAttestationEnvelope rightTransport certificate theoremIds summary
        entropyCertificate).summary := by
  rfl

/--
Changing only the attestation transport preserves the optional entropy
certificate payload. `none` and `some certificate` are both transport-stable:
Flow/UDP cannot silently drop resident entropy evidence that HTTP would expose.
-/
theorem runtime_attestation_transport_preserves_entropy_certificate
    {Certificate : Type}
    {Summary : Type}
    {Entropy : Type}
    (leftTransport rightTransport : RuntimeAttestationTransport)
    (certificate : Certificate)
    (theoremIds : List String)
    (summary : Summary)
    (entropyCertificate : Option Entropy) :
    (runtimeAttestationEnvelope leftTransport certificate theoremIds summary
      entropyCertificate).entropyCertificate =
      (runtimeAttestationEnvelope rightTransport certificate theoremIds summary
        entropyCertificate).entropyCertificate := by
  rfl

/-- Fingerprint equality is the cache freshness boundary for attestation reuse. -/
def entropyCacheFresh (cachedFingerprint currentFingerprint : String) : Bool :=
  cachedFingerprint == currentFingerprint

/--
Entropy-dependent attestation reuse is admitted only when the cached and current
entropy fingerprints are equal. If the fingerprints differ, cached bytes are
stale for the current attestation projection.
-/
theorem entropy_cache_freshness_admits_reuse_only_on_equal_fingerprint
    (cachedFingerprint currentFingerprint : String)
    (hFresh : entropyCacheFresh cachedFingerprint currentFingerprint = true) :
    cachedFingerprint = currentFingerprint := by
  unfold entropyCacheFresh at hFresh
  exact beq_iff_eq.mp hFresh

/--
Equal entropy fingerprints are sufficient for the cache freshness predicate used
by entropy-dependent runtime attestation reuse.
-/
theorem equal_entropy_fingerprint_admits_cache_reuse
    (fingerprint : String) :
    entropyCacheFresh fingerprint fingerprint = true := by
  unfold entropyCacheFresh
  exact beq_self_eq_true fingerprint

end FoilLoserPolicy
end ForkRaceFoldTheorems
