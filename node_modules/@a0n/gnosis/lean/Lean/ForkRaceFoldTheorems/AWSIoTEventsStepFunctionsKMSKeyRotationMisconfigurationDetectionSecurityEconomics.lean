namespace ForkRaceFoldTheorems

structure KMSAutomaticRotationGapAssumptions where
  automaticRotationEnabled : Bool
  longTermKeyExposureRisk : Nat
  gapFromMissingRotation : automaticRotationEnabled = false → 0 < longTermKeyExposureRisk

theorem kms_automatic_rotation_gap_exists (a : KMSAutomaticRotationGapAssumptions)
    (h : a.automaticRotationEnabled = false) : 0 < a.longTermKeyExposureRisk :=
  a.gapFromMissingRotation h

structure KMSKeyDeletionSCPGapAssumptions where
  scpBlocksScheduledDeletion : Bool
  configDetectsPendingDeletion : Bool
  keyLossRisk : Nat
  gapFromMissingSCPAndConfig : scpBlocksScheduledDeletion = false → configDetectsPendingDeletion = false → 0 < keyLossRisk

theorem kms_key_deletion_scp_gap_exists (a : KMSKeyDeletionSCPGapAssumptions)
    (hSCP : a.scpBlocksScheduledDeletion = false) (hConfig : a.configDetectsPendingDeletion = false) : 0 < a.keyLossRisk :=
  a.gapFromMissingSCPAndConfig hSCP hConfig

structure KMSKeyPolicyIAMScopeGapAssumptions where
  keyPolicyScopedToWorkload : Bool
  crossAccountGrantsAudited : Bool
  privilegeEscalationRisk : Nat
  gapFromUnscopedKeyPolicy : keyPolicyScopedToWorkload = false → crossAccountGrantsAudited = false → 0 < privilegeEscalationRisk

theorem kms_key_policy_iam_scope_gap_exists (a : KMSKeyPolicyIAMScopeGapAssumptions)
    (hScope : a.keyPolicyScopedToWorkload = false) (hAudit : a.crossAccountGrantsAudited = false) : 0 < a.privilegeEscalationRisk :=
  a.gapFromUnscopedKeyPolicy hScope hAudit

structure KMSRotationFailureAlarmSOCGapAssumptions where
  rotationFailureAlarmConfigured : Bool
  socRunbookExists : Bool
  socGap : Nat
  gapFromMissingAlarmAndRunbook : rotationFailureAlarmConfigured = false → socRunbookExists = false → 0 < socGap

theorem kms_rotation_failure_alarm_soc_gap_exists (a : KMSRotationFailureAlarmSOCGapAssumptions)
    (hAlarm : a.rotationFailureAlarmConfigured = false) (hRunbook : a.socRunbookExists = false) : 0 < a.socGap :=
  a.gapFromMissingAlarmAndRunbook hAlarm hRunbook

structure KMSKeyUsageCloudTrailGapAssumptions where
  cloudTrailKMSDataEventsEnabled : Bool
  keyUsageAnomalyDetectionEnabled : Bool
  observabilityGap : Nat
  gapFromMissingCloudTrailAndDetection : cloudTrailKMSDataEventsEnabled = false → keyUsageAnomalyDetectionEnabled = false → 0 < observabilityGap

theorem kms_key_usage_cloudtrail_gap_exists (a : KMSKeyUsageCloudTrailGapAssumptions)
    (hCT : a.cloudTrailKMSDataEventsEnabled = false) (hDetect : a.keyUsageAnomalyDetectionEnabled = false) : 0 < a.observabilityGap :=
  a.gapFromMissingCloudTrailAndDetection hCT hDetect

end ForkRaceFoldTheorems
