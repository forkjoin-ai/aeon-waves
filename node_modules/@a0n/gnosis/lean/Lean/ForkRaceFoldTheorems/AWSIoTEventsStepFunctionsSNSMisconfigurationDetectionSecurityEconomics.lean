/-!
# AWSIoTEventsStepFunctionsSNSMisconfigurationDetectionSecurityEconomics

Security-economics gap theorems for AWS IoT Events → Step Functions → SNS
pipeline misconfiguration detection. Five proofs that absence of controls
creates measurable revenue-at-risk or compliance exposure.

Anti-thesis pattern: each structure posits the ABSENCE of a control, then
derives a positive risk quantity. Zero sorry — all theorems close by exact.
-/

namespace ForkRaceFoldTheorems

-- ── Theorem 1 ────────────────────────────────────────────────────────────────
-- Anti-thesis: SNS topic messages are NOT encrypted with a customer-managed KMS
-- key → compliance gap is strictly positive.

structure SNSCMKGapAssumptions where
  topicEncryptedWithCMK : Bool
  complianceRisk : Nat
  gapFromMissingCMK : topicEncryptedWithCMK = false → 0 < complianceRisk

theorem sns_cmk_gap_exists
    (a : SNSCMKGapAssumptions)
    (h : a.topicEncryptedWithCMK = false) :
    0 < a.complianceRisk :=
  a.gapFromMissingCMK h

-- ── Theorem 2 ────────────────────────────────────────────────────────────────
-- Anti-thesis: no SCP denies creation of public SNS subscriptions AND no
-- topic access policy restricts cross-account subscriptions → topic-hijack risk
-- is strictly positive.

structure SNSSCPAndTopicPolicyGapAssumptions where
  scpDeniesPublicSubscriptions : Bool
  topicPolicyRestrictsXAccount : Bool
  hijackRisk : Nat
  gapFromMissingSCPAndPolicy :
    scpDeniesPublicSubscriptions = false →
    topicPolicyRestrictsXAccount = false →
    0 < hijackRisk

theorem sns_scp_and_topic_policy_gap_exists
    (a : SNSSCPAndTopicPolicyGapAssumptions)
    (hSCP : a.scpDeniesPublicSubscriptions = false)
    (hPolicy : a.topicPolicyRestrictsXAccount = false) :
    0 < a.hijackRisk :=
  a.gapFromMissingSCPAndPolicy hSCP hPolicy

-- ── Theorem 3 ────────────────────────────────────────────────────────────────
-- Anti-thesis: the Step Functions IAM role grants SNS Publish to all topics
-- instead of the specific topic ARN → IAM scope gap is strictly positive.

structure SNSIAMRoleScopeGapAssumptions where
  iamRoleScopedToSpecificTopic : Bool
  iamScopeGap : Nat
  gapFromBroadRole : iamRoleScopedToSpecificTopic = false → 0 < iamScopeGap

theorem sns_iam_role_scope_gap_exists
    (a : SNSIAMRoleScopeGapAssumptions)
    (h : a.iamRoleScopedToSpecificTopic = false) :
    0 < a.iamScopeGap :=
  a.gapFromBroadRole h

-- ── Theorem 4 ────────────────────────────────────────────────────────────────
-- Anti-thesis: no CloudWatch alarm fires on SNS NumberOfNotificationsFailed
-- exceeding threshold AND the SOC has no delivery-failure runbook → SOC gap is
-- strictly positive.

structure SNSAlarmSOCGapAssumptions where
  cloudWatchAlarmConfigured : Bool
  deliveryFailureRunbookExists : Bool
  socGap : Nat
  gapFromMissingAlarmAndRunbook :
    cloudWatchAlarmConfigured = false →
    deliveryFailureRunbookExists = false →
    0 < socGap

theorem sns_alarm_soc_gap_exists
    (a : SNSAlarmSOCGapAssumptions)
    (hAlarm : a.cloudWatchAlarmConfigured = false)
    (hRunbook : a.deliveryFailureRunbookExists = false) :
    0 < a.socGap :=
  a.gapFromMissingAlarmAndRunbook hAlarm hRunbook

-- ── Theorem 5 ────────────────────────────────────────────────────────────────
-- Anti-thesis: AWS X-Ray active tracing is NOT enabled on the Step Functions
-- state machine that publishes to SNS AND message-attribute tracing propagation
-- is absent → observability gap is strictly positive.

structure SNSXRayGapAssumptions where
  xRayTracingEnabled : Bool
  messageAttributeTracingEnabled : Bool
  observabilityGap : Nat
  gapFromMissingXRay :
    xRayTracingEnabled = false →
    messageAttributeTracingEnabled = false →
    0 < observabilityGap

theorem sns_xray_gap_exists
    (a : SNSXRayGapAssumptions)
    (hXRay : a.xRayTracingEnabled = false)
    (hTrace : a.messageAttributeTracingEnabled = false) :
    0 < a.observabilityGap :=
  a.gapFromMissingXRay hXRay hTrace

end ForkRaceFoldTheorems
