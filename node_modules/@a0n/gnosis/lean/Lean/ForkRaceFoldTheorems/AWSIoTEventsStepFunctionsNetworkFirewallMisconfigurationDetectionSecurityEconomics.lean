namespace ForkRaceFoldTheorems

structure NetworkFirewallTLSCMKGapAssumptions where
  tlsInspectionEnabledWithCMK : Bool
  complianceRisk : Nat
  gapFromMissingTLSCMK : tlsInspectionEnabledWithCMK = false → 0 < complianceRisk

theorem network_firewall_tls_cmk_gap_exists (a : NetworkFirewallTLSCMKGapAssumptions)
    (h : a.tlsInspectionEnabledWithCMK = false) : 0 < a.complianceRisk :=
  a.gapFromMissingTLSCMK h

structure NetworkFirewallSCPConfigDeletionGapAssumptions where
  scpBlocksFirewallDeletion : Bool
  configDetectsFirewallChange : Bool
  firewallLossRisk : Nat
  gapFromMissingSCPAndConfig : scpBlocksFirewallDeletion = false → configDetectsFirewallChange = false → 0 < firewallLossRisk

theorem network_firewall_scp_config_deletion_gap_exists (a : NetworkFirewallSCPConfigDeletionGapAssumptions)
    (hSCP : a.scpBlocksFirewallDeletion = false) (hConfig : a.configDetectsFirewallChange = false) : 0 < a.firewallLossRisk :=
  a.gapFromMissingSCPAndConfig hSCP hConfig

structure NetworkFirewallIAMScopeGapAssumptions where
  firewallIAMScopedToVPC : Bool
  crossAccountRuleAccessAudited : Bool
  privilegeEscalationRisk : Nat
  gapFromUnscopedFirewallIAM : firewallIAMScopedToVPC = false → crossAccountRuleAccessAudited = false → 0 < privilegeEscalationRisk

theorem network_firewall_iam_scope_gap_exists (a : NetworkFirewallIAMScopeGapAssumptions)
    (hScope : a.firewallIAMScopedToVPC = false) (hAudit : a.crossAccountRuleAccessAudited = false) : 0 < a.privilegeEscalationRisk :=
  a.gapFromUnscopedFirewallIAM hScope hAudit

structure NetworkFirewallDroppedPacketAlarmSOCGapAssumptions where
  droppedPacketAlarmConfigured : Bool
  socRunbookExists : Bool
  socGap : Nat
  gapFromMissingAlarmAndRunbook : droppedPacketAlarmConfigured = false → socRunbookExists = false → 0 < socGap

theorem network_firewall_dropped_packet_alarm_soc_gap_exists (a : NetworkFirewallDroppedPacketAlarmSOCGapAssumptions)
    (hAlarm : a.droppedPacketAlarmConfigured = false) (hRunbook : a.socRunbookExists = false) : 0 < a.socGap :=
  a.gapFromMissingAlarmAndRunbook hAlarm hRunbook

structure NetworkFirewallXRayCloudTrailGapAssumptions where
  xRayTracingEnabled : Bool
  cloudTrailFirewallEventsEnabled : Bool
  observabilityGap : Nat
  gapFromMissingXRayAndCloudTrail : xRayTracingEnabled = false → cloudTrailFirewallEventsEnabled = false → 0 < observabilityGap

theorem network_firewall_xray_cloudtrail_gap_exists (a : NetworkFirewallXRayCloudTrailGapAssumptions)
    (hXRay : a.xRayTracingEnabled = false) (hCT : a.cloudTrailFirewallEventsEnabled = false) : 0 < a.observabilityGap :=
  a.gapFromMissingXRayAndCloudTrail hXRay hCT

end ForkRaceFoldTheorems
