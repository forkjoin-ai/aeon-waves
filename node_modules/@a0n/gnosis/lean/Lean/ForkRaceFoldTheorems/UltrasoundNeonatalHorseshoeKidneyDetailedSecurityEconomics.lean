/-!
# UltrasoundNeonatalHorseshoeKidneyDetailedSecurityEconomics

Neonatal renal ultrasound — horseshoe kidney.
Security-economics gap theorems derived from absent diagnostic controls.

Anti-thesis pattern: each structure posits the ABSENCE of a required
measurement or finding, then derives a positive risk quantity.
Zero sorry — all theorems close by exact.
-/

namespace ForkRaceFoldTheorems

-- ── Theorem 1 ────────────────────────────────────────────────────────────────
-- Anti-thesis: isthmus position, thickness, and parenchymal echogenicity are
-- NOT documented AND renal axis orientation is not recorded →
-- fusion-morphology classification gap is strictly positive.

structure HorseshoeKidneyFusionMorphologyGapAssumptions where
  isthmusDocumented : Bool
  renalAxisRecorded : Bool
  fusionMorphologyGap : Nat
  gapFromMissingMorphology :
    isthmusDocumented = false →
    renalAxisRecorded = false →
    0 < fusionMorphologyGap

theorem horseshoe_kidney_fusion_morphology_gap_exists
    (a : HorseshoeKidneyFusionMorphologyGapAssumptions)
    (hIsthmus : a.isthmusDocumented = false)
    (hAxis : a.renalAxisRecorded = false) :
    0 < a.fusionMorphologyGap :=
  a.gapFromMissingMorphology hIsthmus hAxis

-- ── Theorem 2 ────────────────────────────────────────────────────────────────
-- Anti-thesis: bilateral collecting system dilatation is NOT graded AND
-- ureteropelvic junction obstruction is not assessed → UPJ obstruction
-- assessment gap is strictly positive.

structure HorseshoeKidneyUPJObstructionGapAssumptions where
  collectingSystemGraded : Bool
  upjObstructionAssessed : Bool
  upjObstructionGap : Nat
  gapFromMissingUPJData :
    collectingSystemGraded = false →
    upjObstructionAssessed = false →
    0 < upjObstructionGap

theorem horseshoe_kidney_upj_obstruction_gap_exists
    (a : HorseshoeKidneyUPJObstructionGapAssumptions)
    (hGraded : a.collectingSystemGraded = false)
    (hUPJ : a.upjObstructionAssessed = false) :
    0 < a.upjObstructionGap :=
  a.gapFromMissingUPJData hGraded hUPJ

-- ── Theorem 3 ────────────────────────────────────────────────────────────────
-- Anti-thesis: colour Doppler renal artery variants and accessory vessels
-- arising from the aorta are NOT mapped → vascular anomaly gap is strictly
-- positive.

structure HorseshoeKidneyVascularAnomalyGapAssumptions where
  renalArteryVariantsMapped : Bool
  accessoryVesselsDopplered : Bool
  vascularAnomalyGap : Nat
  gapFromMissingVascularData :
    renalArteryVariantsMapped = false →
    accessoryVesselsDopplered = false →
    0 < vascularAnomalyGap

theorem horseshoe_kidney_vascular_anomaly_gap_exists
    (a : HorseshoeKidneyVascularAnomalyGapAssumptions)
    (hVariants : a.renalArteryVariantsMapped = false)
    (hAccessory : a.accessoryVesselsDopplered = false) :
    0 < a.vascularAnomalyGap :=
  a.gapFromMissingVascularData hVariants hAccessory

-- ── Theorem 4 ────────────────────────────────────────────────────────────────
-- Anti-thesis: associated anomalies — VSD, skeletal, spinal — are NOT excluded
-- AND Turner syndrome or trisomy 18 screen is not documented →
-- syndromic-association gap is strictly positive.

structure HorseshoeKidneySyndromicAssociationGapAssumptions where
  associatedAnomaliesExcluded : Bool
  chromosomalScreenDocumented : Bool
  syndromicAssociationGap : Nat
  gapFromMissingSyndromicData :
    associatedAnomaliesExcluded = false →
    chromosomalScreenDocumented = false →
    0 < syndromicAssociationGap

theorem horseshoe_kidney_syndromic_association_gap_exists
    (a : HorseshoeKidneySyndromicAssociationGapAssumptions)
    (hAnomalies : a.associatedAnomaliesExcluded = false)
    (hChromosomal : a.chromosomalScreenDocumented = false) :
    0 < a.syndromicAssociationGap :=
  a.gapFromMissingSyndromicData hAnomalies hChromosomal

-- ── Theorem 5 ────────────────────────────────────────────────────────────────
-- Anti-thesis: no follow-up renal ultrasound interval is specified AND no DMSA
-- or MAG3 referral decision is documented → surveillance gap is strictly
-- positive.

structure HorseshoeKidneySurveillancePlanGapAssumptions where
  followUpIntervalSpecified : Bool
  nuclearMedicineReferralDocumented : Bool
  surveillanceGap : Nat
  gapFromMissingSurveillancePlan :
    followUpIntervalSpecified = false →
    nuclearMedicineReferralDocumented = false →
    0 < surveillanceGap

theorem horseshoe_kidney_surveillance_plan_gap_exists
    (a : HorseshoeKidneySurveillancePlanGapAssumptions)
    (hInterval : a.followUpIntervalSpecified = false)
    (hNuclear : a.nuclearMedicineReferralDocumented = false) :
    0 < a.surveillanceGap :=
  a.gapFromMissingSurveillancePlan hInterval hNuclear

end ForkRaceFoldTheorems
