/-!
# AWSIoTEventsStepFunctionsLambdaMisconfigurationDetectionSecurityEconomics

Lambda function misconfiguration scanner driven by IoT Events + Step
Functions. Five security-economics gap theorems: each proves that the ABSENCE
of a control on the Lambda surface creates a measurable compliance or
attack-surface cost.

Anti-thesis pattern: structure posits the ABSENCE of a control, theorem
derives strictly-positive gap. Zero sorry — all close by exact.
-/

namespace ForkRaceFoldTheorems

-- ── Theorem 1 ────────────────────────────────────────────────────────────────
-- Anti-thesis: the Lambda function's environment variables are NOT encrypted
-- with a customer-managed KMS key → compliance gap is strictly positive,
-- exposing secrets in the execution environment.

structure LambdaEnvVarCMKGapAssumptions where
  envVarsEncryptedWithCMK : Bool
  complianceGap : Nat
  gapFromMissingCMK : envVarsEncryptedWithCMK = false → 0 < complianceGap

theorem lambda_env_var_cmk_gap_exists
    (a : LambdaEnvVarCMKGapAssumptions)
    (h : a.envVarsEncryptedWithCMK = false) :
    0 < a.complianceGap :=
  a.gapFromMissingCMK h

-- ── Theorem 2 ────────────────────────────────────────────────────────────────
-- Anti-thesis: the Lambda function is NOT deployed inside a VPC AND an SCP
-- does not require VPC attachment for functions handling sensitive data →
-- network exposure risk is strictly positive.

structure LambdaVPCSCPGapAssumptions where
  lambdaInVPC : Bool
  scpRequiresVPCForSensitive : Bool
  networkExposureRisk : Nat
  gapFromMissingVPCAndSCP :
    lambdaInVPC = false →
    scpRequiresVPCForSensitive = false →
    0 < networkExposureRisk

theorem lambda_vpc_scp_gap_exists
    (a : LambdaVPCSCPGapAssumptions)
    (hVPC : a.lambdaInVPC = false)
    (hSCP : a.scpRequiresVPCForSensitive = false) :
    0 < a.networkExposureRisk :=
  a.gapFromMissingVPCAndSCP hVPC hSCP

-- ── Theorem 3 ────────────────────────────────────────────────────────────────
-- Anti-thesis: the Lambda execution role's resource-based policy is NOT
-- scoped to the specific invoking principal → privilege escalation risk is
-- strictly positive.

structure LambdaExecutionRoleScopeGapAssumptions where
  resourcePolicyScopedToPrincipal : Bool
  privilegeEscalationRisk : Nat
  gapFromUnscopedRole : resourcePolicyScopedToPrincipal = false → 0 < privilegeEscalationRisk

theorem lambda_execution_role_scope_gap_exists
    (a : LambdaExecutionRoleScopeGapAssumptions)
    (h : a.resourcePolicyScopedToPrincipal = false) :
    0 < a.privilegeEscalationRisk :=
  a.gapFromUnscopedRole h

-- ── Theorem 4 ────────────────────────────────────────────────────────────────
-- Anti-thesis: no CloudWatch alarm is configured on Lambda error rate or
-- throttle count AND the SOC has no runbook for function failure → SOC
-- blind-spot risk is strictly positive.

structure LambdaErrorAlarmSOCGapAssumptions where
  errorRateAlarmConfigured : Bool
  socRunbookForFailure : Bool
  socBlindSpotRisk : Nat
  gapFromMissingAlarmAndRunbook :
    errorRateAlarmConfigured = false →
    socRunbookForFailure = false →
    0 < socBlindSpotRisk

theorem lambda_error_alarm_soc_gap_exists
    (a : LambdaErrorAlarmSOCGapAssumptions)
    (hAlarm : a.errorRateAlarmConfigured = false)
    (hRunbook : a.socRunbookForFailure = false) :
    0 < a.socBlindSpotRisk :=
  a.gapFromMissingAlarmAndRunbook hAlarm hRunbook

-- ── Theorem 5 ────────────────────────────────────────────────────────────────
-- Anti-thesis: AWS X-Ray active tracing is NOT enabled on the Lambda function
-- AND the Step Functions state machine that invokes it also lacks X-Ray →
-- observability gap is strictly positive.

structure LambdaXRayGapAssumptions where
  lambdaXRayEnabled : Bool
  stateMachineXRayEnabled : Bool
  observabilityGap : Nat
  gapFromMissingXRay :
    lambdaXRayEnabled = false →
    stateMachineXRayEnabled = false →
    0 < observabilityGap

theorem lambda_xray_gap_exists
    (a : LambdaXRayGapAssumptions)
    (hLambda : a.lambdaXRayEnabled = false)
    (hSFN : a.stateMachineXRayEnabled = false) :
    0 < a.observabilityGap :=
  a.gapFromMissingXRay hLambda hSFN

end ForkRaceFoldTheorems
