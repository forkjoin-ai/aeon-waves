/-!
# UltrasoundNeonatalOmphalitisDetailedSecurityEconomics

Neonatal omphalitis: five security-economics gap theorems proving that absence
of ultrasound-guided detection and monitoring controls creates measurable
patient-safety risk or compliance exposure.

Anti-thesis pattern: structure posits the ABSENCE of a control, theorem
derives strictly-positive gap. Zero sorry — all close by exact.
-/

namespace ForkRaceFoldTheorems

-- ── Theorem 1 ────────────────────────────────────────────────────────────────
-- Anti-thesis: periumbilical soft-tissue ultrasound is NOT performed to
-- distinguish superficial omphalitis from necrotizing fasciitis in neonates
-- → patient-safety risk is strictly positive.

structure OmphalitisUSFasciitisGapAssumptions where
  periumbilicalUSPerformed : Bool
  patientSafetyRisk : Nat
  gapFromMissingUS : periumbilicalUSPerformed = false → 0 < patientSafetyRisk

theorem omphalitis_us_fasciitis_gap_exists
    (a : OmphalitisUSFasciitisGapAssumptions)
    (h : a.periumbilicalUSPerformed = false) :
    0 < a.patientSafetyRisk :=
  a.gapFromMissingUS h

-- ── Theorem 2 ────────────────────────────────────────────────────────────────
-- Anti-thesis: Doppler ultrasound of umbilical vessels is NOT performed to
-- assess portal vein extension of infection AND early anticoagulation is not
-- considered → portal vein thrombosis risk is strictly positive.

structure OmphalitisDopplerPortalGapAssumptions where
  dopplerUSPerformed : Bool
  anticoagulationConsidered : Bool
  portalThrombosisRisk : Nat
  gapFromMissingDopplerAndAnticoag :
    dopplerUSPerformed = false →
    anticoagulationConsidered = false →
    0 < portalThrombosisRisk

theorem omphalitis_doppler_portal_gap_exists
    (a : OmphalitisDopplerPortalGapAssumptions)
    (hDoppler : a.dopplerUSPerformed = false)
    (hAnticoag : a.anticoagulationConsidered = false) :
    0 < a.portalThrombosisRisk :=
  a.gapFromMissingDopplerAndAnticoag hDoppler hAnticoag

-- ── Theorem 3 ────────────────────────────────────────────────────────────────
-- Anti-thesis: hepatic ultrasound is NOT performed to detect hepatic abscess
-- complicating omphalitis-related portal pyaemia → hepatic complication
-- detection gap is strictly positive.

structure OmphalitisHepaticAbscessUSGapAssumptions where
  hepaticUSPerformed : Bool
  hepaticComplicationDetectionGap : Nat
  gapFromMissingHepaticUS : hepaticUSPerformed = false → 0 < hepaticComplicationDetectionGap

theorem omphalitis_hepatic_abscess_us_gap_exists
    (a : OmphalitisHepaticAbscessUSGapAssumptions)
    (h : a.hepaticUSPerformed = false) :
    0 < a.hepaticComplicationDetectionGap :=
  a.gapFromMissingHepaticUS h

-- ── Theorem 4 ────────────────────────────────────────────────────────────────
-- Anti-thesis: cardiac echocardiography is NOT performed to rule out septic
-- emboli in omphalitis bacteraemia AND no cardiology referral is made →
-- cardiac complication risk is strictly positive.

structure OmphalitisCardiacEchoGapAssumptions where
  echocardiographyPerformed : Bool
  cardiologyReferralMade : Bool
  cardiacComplicationRisk : Nat
  gapFromMissingEchoAndReferral :
    echocardiographyPerformed = false →
    cardiologyReferralMade = false →
    0 < cardiacComplicationRisk

theorem omphalitis_cardiac_echo_gap_exists
    (a : OmphalitisCardiacEchoGapAssumptions)
    (hEcho : a.echocardiographyPerformed = false)
    (hRef : a.cardiologyReferralMade = false) :
    0 < a.cardiacComplicationRisk :=
  a.gapFromMissingEchoAndReferral hEcho hRef

-- ── Theorem 5 ────────────────────────────────────────────────────────────────
-- Anti-thesis: periumbilical wound follow-up ultrasound is NOT scheduled after
-- discharge AND umbilical granuloma ultrasound assessment is absent →
-- long-term wound outcome risk is strictly positive.

structure OmphalitisFollowUpUSGapAssumptions where
  woundFollowUpUSScheduled : Bool
  granulomaAssessmentPerformed : Bool
  longTermWoundOutcomeRisk : Nat
  gapFromMissingFollowUp :
    woundFollowUpUSScheduled = false →
    granulomaAssessmentPerformed = false →
    0 < longTermWoundOutcomeRisk

theorem omphalitis_follow_up_us_gap_exists
    (a : OmphalitisFollowUpUSGapAssumptions)
    (hWound : a.woundFollowUpUSScheduled = false)
    (hGranuloma : a.granulomaAssessmentPerformed = false) :
    0 < a.longTermWoundOutcomeRisk :=
  a.gapFromMissingFollowUp hWound hGranuloma

end ForkRaceFoldTheorems
