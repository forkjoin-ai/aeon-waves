/-!
# UltrasoundNeonatalBranchialCleftCystDetailedSecurityEconomics

Anti-thesis: neonatal fetal ultrasound reliably characterizes branchial cleft
cyst (BCC) by classifying type (first, second, third, or fourth) and anatomical
triangle location, measuring cyst dimensions and assessing wall complexity,
evaluating sinus tract or fistula communication, assessing airway compression
and vascular displacement, and coordinating postnatal excision planning and MDT
referral. Management decisions based on these assessments are clinically sound.

Refutation: each failure mode below proves that the ABSENCE of a systematic
assessment control implies a strictly positive clinical and economic risk.
Zero sorry — all theorems close by exact.
-/

namespace ForkRaceFoldTheorems

-- ── Theorem 1 ────────────────────────────────────────────────────────────────
-- Anti-thesis: the branchial cleft cyst type (first vs. second vs. third/fourth)
-- is NOT classified AND the anatomical triangle location is NOT mapped →
-- surgical approach risk is strictly positive.

structure BCCTypeLocationGapAssumptions where
  typeClassified : Bool
  locationMapped : Bool
  surgicalApproachRisk : Nat
  gapFromMissingTypeAndLocation :
    typeClassified = false →
    locationMapped = false →
    0 < surgicalApproachRisk

theorem bcc_type_location_gap_exists
    (a : BCCTypeLocationGapAssumptions)
    (hType : a.typeClassified = false)
    (hLocation : a.locationMapped = false) :
    0 < a.surgicalApproachRisk :=
  a.gapFromMissingTypeAndLocation hType hLocation

-- ── Theorem 2 ────────────────────────────────────────────────────────────────
-- Anti-thesis: cyst dimensions (AP, transverse, cranio-caudal) are NOT measured
-- AND wall complexity (unilocular vs. septated vs. complex) is NOT assessed →
-- infection/malignancy risk stratification gap is strictly positive.

structure BCCDimensionsWallComplexityGapAssumptions where
  dimensionsMeasured : Bool
  wallComplexityAssessed : Bool
  riskStratificationGap : Nat
  gapFromMissingDimensionsAndWall :
    dimensionsMeasured = false →
    wallComplexityAssessed = false →
    0 < riskStratificationGap

theorem bcc_dimensions_wall_complexity_gap_exists
    (a : BCCDimensionsWallComplexityGapAssumptions)
    (hDimensions : a.dimensionsMeasured = false)
    (hWall : a.wallComplexityAssessed = false) :
    0 < a.riskStratificationGap :=
  a.gapFromMissingDimensionsAndWall hDimensions hWall

-- ── Theorem 3 ────────────────────────────────────────────────────────────────
-- Anti-thesis: sinus tract or fistula communication with the pharynx or skin
-- is NOT evaluated AND third/fourth branchial cleft piriform sinus connection
-- is NOT assessed → recurrence risk gap is strictly positive.

structure BCCSinusTractFistulaGapAssumptions where
  sinusTractEvaluated : Bool
  piriformSinusAssessed : Bool
  recurrenceRisk : Nat
  gapFromMissingSinusAndFistula :
    sinusTractEvaluated = false →
    piriformSinusAssessed = false →
    0 < recurrenceRisk

theorem bcc_sinus_tract_fistula_gap_exists
    (a : BCCSinusTractFistulaGapAssumptions)
    (hSinus : a.sinusTractEvaluated = false)
    (hPiriform : a.piriformSinusAssessed = false) :
    0 < a.recurrenceRisk :=
  a.gapFromMissingSinusAndFistula hSinus hPiriform

-- ── Theorem 4 ────────────────────────────────────────────────────────────────
-- Anti-thesis: airway compression degree is NOT graded AND vascular displacement
-- (carotid artery, internal jugular vein) is NOT documented with Doppler →
-- perioperative risk gap is strictly positive.

structure BCCAirwayVascularDisplacementGapAssumptions where
  airwayCompressionGraded : Bool
  vascularDisplacementDocumented : Bool
  perioperativeRisk : Nat
  gapFromMissingAirwayAndVascular :
    airwayCompressionGraded = false →
    vascularDisplacementDocumented = false →
    0 < perioperativeRisk

theorem bcc_airway_vascular_displacement_gap_exists
    (a : BCCAirwayVascularDisplacementGapAssumptions)
    (hAirway : a.airwayCompressionGraded = false)
    (hVascular : a.vascularDisplacementDocumented = false) :
    0 < a.perioperativeRisk :=
  a.gapFromMissingAirwayAndVascular hAirway hVascular

-- ── Theorem 5 ────────────────────────────────────────────────────────────────
-- Anti-thesis: postnatal surgical excision candidacy is NOT evaluated AND
-- multidisciplinary team (MDT) referral to a paediatric head-and-neck surgeon
-- is NOT initiated → postnatal management gap is strictly positive.

structure BCCExcisionMDTReferralGapAssumptions where
  excisionCandidacyEvaluated : Bool
  mdtReferralInitiated : Bool
  postnatalManagementGap : Nat
  gapFromMissingExcisionAndMDT :
    excisionCandidacyEvaluated = false →
    mdtReferralInitiated = false →
    0 < postnatalManagementGap

theorem bcc_excision_mdt_referral_gap_exists
    (a : BCCExcisionMDTReferralGapAssumptions)
    (hExcision : a.excisionCandidacyEvaluated = false)
    (hMDT : a.mdtReferralInitiated = false) :
    0 < a.postnatalManagementGap :=
  a.gapFromMissingExcisionAndMDT hExcision hMDT

end ForkRaceFoldTheorems
