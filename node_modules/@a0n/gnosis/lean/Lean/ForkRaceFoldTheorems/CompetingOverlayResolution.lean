namespace ForkRaceFoldTheorems
namespace CompetingOverlayResolution

/-- Competing overlays. -/
structure CompetingOverlays where
  regionSize : Nat
  ov1Size : Nat
  ov2Size : Nat
  overlap : Nat

/-- Total cancellation. -/
def totalCancellation (c : CompetingOverlays) : Nat :=
  c.ov1Size + c.ov2Size - c.overlap

/-- Net hits after competing. -/
def netHitsAfterCompeting (c : CompetingOverlays) : Nat :=
  c.regionSize - totalCancellation c

end CompetingOverlayResolution
end ForkRaceFoldTheorems
