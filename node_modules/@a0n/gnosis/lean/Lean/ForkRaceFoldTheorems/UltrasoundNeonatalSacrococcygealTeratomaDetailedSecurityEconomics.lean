/-!
# UltrasoundNeonatalSacrococcygealTeratomaDetailedSecurityEconomics

Neonatal abdominal/pelvic/perineal ultrasound — sacrococcygeal teratoma (SCT).
Security-economics gap theorems derived from absent diagnostic controls.

Anti-thesis pattern: each structure posits the ABSENCE of a required
measurement or finding, then derives a positive risk quantity.
Zero sorry — all theorems close by exact.
-/

namespace ForkRaceFoldTheorems

-- ── Theorem 1 ────────────────────────────────────────────────────────────────
-- Anti-thesis: SCT three-dimensional measurements, Altman classification
-- (I–IV), and presacral component depth are NOT documented → mass
-- characterisation gap is strictly positive.

structure SCTMassCharacterisationGapAssumptions where
  altmanClassificationDocumented : Bool
  presacralComponentMeasured : Bool
  massCharacterisationGap : Nat
  gapFromMissingCharacterisation :
    altmanClassificationDocumented = false →
    presacralComponentMeasured = false →
    0 < massCharacterisationGap

theorem sct_mass_characterisation_gap_exists
    (a : SCTMassCharacterisationGapAssumptions)
    (hAltman : a.altmanClassificationDocumented = false)
    (hPresacral : a.presacralComponentMeasured = false) :
    0 < a.massCharacterisationGap :=
  a.gapFromMissingCharacterisation hAltman hPresacral

-- ── Theorem 2 ────────────────────────────────────────────────────────────────
-- Anti-thesis: colour Doppler internal vascularity is NOT assessed AND high-
-- velocity feeding vessel pedicle identification is not performed → vascular
-- steal/cardiac-output gap is strictly positive.

structure SCTVascularStealGapAssumptions where
  colorDopplerAssessed : Bool
  feedingVesselIdentified : Bool
  vascularStealGap : Nat
  gapFromMissingVascularData :
    colorDopplerAssessed = false →
    feedingVesselIdentified = false →
    0 < vascularStealGap

theorem sct_vascular_steal_gap_exists
    (a : SCTVascularStealGapAssumptions)
    (hDoppler : a.colorDopplerAssessed = false)
    (hVessel : a.feedingVesselIdentified = false) :
    0 < a.vascularStealGap :=
  a.gapFromMissingVascularData hDoppler hVessel

-- ── Theorem 3 ────────────────────────────────────────────────────────────────
-- Anti-thesis: solid vs cystic component ratio and calcification pattern are
-- NOT quantified AND alpha-fetoprotein correlation is not referenced →
-- malignancy-risk characterisation gap is strictly positive.

structure SCTMalignancyRiskGapAssumptions where
  solidCysticRatioQuantified : Bool
  afpCorrelationReferenced : Bool
  malignancyRiskGap : Nat
  gapFromMissingMalignancyData :
    solidCysticRatioQuantified = false →
    afpCorrelationReferenced = false →
    0 < malignancyRiskGap

theorem sct_malignancy_risk_gap_exists
    (a : SCTMalignancyRiskGapAssumptions)
    (hRatio : a.solidCysticRatioQuantified = false)
    (hAFP : a.afpCorrelationReferenced = false) :
    0 < a.malignancyRiskGap :=
  a.gapFromMissingMalignancyData hRatio hAFP

-- ── Theorem 4 ────────────────────────────────────────────────────────────────
-- Anti-thesis: bladder displacement, hydronephrosis grading, and rectal
-- compression are NOT assessed → visceral-obstruction gap is strictly positive.

structure SCTVisceralObstructionGapAssumptions where
  bladderDisplacementAssessed : Bool
  hydronephrosisGraded : Bool
  visceralObstructionGap : Nat
  gapFromMissingObstructionData :
    bladderDisplacementAssessed = false →
    hydronephrosisGraded = false →
    0 < visceralObstructionGap

theorem sct_visceral_obstruction_gap_exists
    (a : SCTVisceralObstructionGapAssumptions)
    (hBladder : a.bladderDisplacementAssessed = false)
    (hHydro : a.hydronephrosisGraded = false) :
    0 < a.visceralObstructionGap :=
  a.gapFromMissingObstructionData hBladder hHydro

-- ── Theorem 5 ────────────────────────────────────────────────────────────────
-- Anti-thesis: sacral bony involvement and spinal canal extension are NOT
-- evaluated AND no neurosurgery/oncology referral threshold is documented →
-- surgical-planning gap is strictly positive.

structure SCTSurgicalPlanningGapAssumptions where
  sacralBonyInvolvementEvaluated : Bool
  surgicalReferralDocumented : Bool
  surgicalPlanningGap : Nat
  gapFromMissingSurgicalData :
    sacralBonyInvolvementEvaluated = false →
    surgicalReferralDocumented = false →
    0 < surgicalPlanningGap

theorem sct_surgical_planning_gap_exists
    (a : SCTSurgicalPlanningGapAssumptions)
    (hSacral : a.sacralBonyInvolvementEvaluated = false)
    (hReferral : a.surgicalReferralDocumented = false) :
    0 < a.surgicalPlanningGap :=
  a.gapFromMissingSurgicalData hSacral hReferral

end ForkRaceFoldTheorems
