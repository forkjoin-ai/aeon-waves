namespace ForkRaceFoldTheorems

structure CloudFormationCMKSecretsGapAssumptions where
  stackParamsEncryptedWithCMK : Bool
  sensitiveOutputsMasked : Bool
  secretsExposureGap : Nat
  gapFromMissingCMKAndMasking : stackParamsEncryptedWithCMK = false → sensitiveOutputsMasked = false → 0 < secretsExposureGap

theorem cloudformation_cmk_secrets_gap_exists (a : CloudFormationCMKSecretsGapAssumptions)
    (hCMK : a.stackParamsEncryptedWithCMK = false) (hMask : a.sensitiveOutputsMasked = false) : 0 < a.secretsExposureGap :=
  a.gapFromMissingCMKAndMasking hCMK hMask

structure CloudFormationSCPDriftGapAssumptions where
  scpTerminationProtectionEnabled : Bool
  configDriftDetectionEnforced : Bool
  accidentalDeletionRisk : Nat
  gapFromMissingSCPAndDrift : scpTerminationProtectionEnabled = false → configDriftDetectionEnforced = false → 0 < accidentalDeletionRisk

theorem cloudformation_scp_drift_gap_exists (a : CloudFormationSCPDriftGapAssumptions)
    (hSCP : a.scpTerminationProtectionEnabled = false) (hDrift : a.configDriftDetectionEnforced = false) : 0 < a.accidentalDeletionRisk :=
  a.gapFromMissingSCPAndDrift hSCP hDrift

structure CloudFormationIAMScopeGapAssumptions where
  executionRoleScopedToStackARN : Bool
  crossAccountRoleLeastPrivilege : Bool
  privilegeEscalationRisk : Nat
  gapFromUnscopedIAM : executionRoleScopedToStackARN = false → crossAccountRoleLeastPrivilege = false → 0 < privilegeEscalationRisk

theorem cloudformation_iam_scope_gap_exists (a : CloudFormationIAMScopeGapAssumptions)
    (hScope : a.executionRoleScopedToStackARN = false) (hCross : a.crossAccountRoleLeastPrivilege = false) : 0 < a.privilegeEscalationRisk :=
  a.gapFromUnscopedIAM hScope hCross

structure CloudFormationDriftRollbackAlarmSOCGapAssumptions where
  driftAlarmConfigured : Bool
  socRunbookExists : Bool
  socGap : Nat
  gapFromMissingAlarmAndRunbook : driftAlarmConfigured = false → socRunbookExists = false → 0 < socGap

theorem cloudformation_drift_rollback_alarm_soc_gap_exists (a : CloudFormationDriftRollbackAlarmSOCGapAssumptions)
    (hAlarm : a.driftAlarmConfigured = false) (hRunbook : a.socRunbookExists = false) : 0 < a.socGap :=
  a.gapFromMissingAlarmAndRunbook hAlarm hRunbook

structure CloudFormationXRayCloudTrailGapAssumptions where
  xRayTracingEnabled : Bool
  cloudTrailCFNCorrelationEnabled : Bool
  observabilityGap : Nat
  gapFromMissingXRayAndCloudTrail : xRayTracingEnabled = false → cloudTrailCFNCorrelationEnabled = false → 0 < observabilityGap

theorem cloudformation_xray_cloudtrail_gap_exists (a : CloudFormationXRayCloudTrailGapAssumptions)
    (hXRay : a.xRayTracingEnabled = false) (hCloudTrail : a.cloudTrailCFNCorrelationEnabled = false) : 0 < a.observabilityGap :=
  a.gapFromMissingXRayAndCloudTrail hXRay hCloudTrail

end ForkRaceFoldTheorems
