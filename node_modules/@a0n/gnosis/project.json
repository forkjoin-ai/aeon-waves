{
  "name": "@a0n/gnosis",
  "projectType": "library",
  "sourceRoot": "open-source/gnosis/src",
  "tags": [
    "scope:open-source",
    "type:lib",
    "npm:public"
  ],
  "implicitDependencies": [],
  "targets": {
    "build": {
      "dependsOn": ["typecheck"],
      "executor": "a0:run-commands",
      "options": {
        "command": "pnpm run build",
        "cwd": "open-source/gnosis"
      },
      "outputs": [
        "{projectRoot}/dist"
      ]
    },
    "test": {
      "executor": "a0:run-commands",
      "options": {
        "command": "pnpm run test:quality-surface && pnpm run validate:ledger-mcp",
        "cwd": "open-source/gnosis"
      }
    },
    "validate:ledger-mcp": {
      "executor": "a0:run-commands",
      "options": {
        "command": "pnpm run validate:ledger-mcp",
        "cwd": "open-source/gnosis"
      }
    },
    "betti:wasm:emit": {
      "executor": "a0:run-commands",
      "options": {
        "command": "pnpm run betti:wasm:emit",
        "cwd": "open-source/gnosis"
      },
      "outputs": ["{projectRoot}/dist/betti-wasm"]
    },
    "typecheck": {
      "executor": "a0:run-commands",
      "options": {
        "command": "pnpm exec tsc -p tsconfig.typecheck.json --noEmit",
        "cwd": "open-source/gnosis"
      },
      "outputs": ["{projectRoot}/.tsbuildinfo-typecheck"]
    },
    "lint": {
      "executor": "a0:run-commands",
      "options": {
        "command": "pnpm exec eslint src --ext .ts",
        "cwd": "open-source/gnosis"
      }
    },
    "validate:mutation-theorem-map": {
      "executor": "a0:run-commands",
      "options": {
        "command": "pnpm run validate:mutation-theorem-map",
        "cwd": "open-source/gnosis"
      }
    },
    "validate:mechanization-release-gate": {
      "executor": "a0:run-commands",
      "options": {
        "command": "pnpm run validate:mechanization-release-gate",
        "cwd": "open-source/gnosis"
      }
    },
    "validate:physics-sandbox": {
      "executor": "a0:run-commands",
      "options": {
        "command": "pnpm run validate:physics-sandbox",
        "cwd": "open-source/gnosis"
      }
    },
    "validate:seismic-stress-toy": {
      "executor": "a0:run-commands",
      "options": {
        "command": "pnpm run validate:seismic-stress-toy",
        "cwd": "open-source/gnosis"
      }
    },
    "validate:math-sandbox": {
      "executor": "a0:run-commands",
      "options": {
        "command": "pnpm run validate:math-sandbox",
        "cwd": "open-source/gnosis"
      }
    },
    "validate:lean-minimal": {
      "executor": "a0:run-commands",
      "options": {
        "command": "pnpm run validate:lean-minimal",
        "cwd": "open-source/gnosis"
      }
    },
    "validate:init-only-imports": {
      "executor": "a0:run-commands",
      "options": {
        "command": "pnpm run validate:init-only-imports",
        "cwd": "open-source/gnosis"
      }
    },
    "validate:init-only-imports:x10": {
      "executor": "a0:run-commands",
      "options": {
        "command": "pnpm run validate:init-only-imports:x10",
        "cwd": "open-source/gnosis"
      }
    },
    "validate:math-sandbox-imports": {
      "executor": "a0:run-commands",
      "options": {
        "command": "./bin/monster scripts/validate-math-sandbox-imports.mjs",
        "cwd": "open-source/gnosis"
      }
    },
    "test:mesh-rtlsdr": {
      "executor": "a0:run-commands",
      "options": {
        "command": "pnpm run mesh:smoke:local-gates",
        "cwd": "open-source/gnosis"
      }
    },
    "validate:rtl-sim": {
      "executor": "a0:run-commands",
      "options": {
        "command": "pnpm run validate:rtl-sim",
        "cwd": "open-source/gnosis"
      }
    },
    "validate:rtl-formal": {
      "executor": "a0:run-commands",
      "options": {
        "command": "pnpm run validate:rtl-formal",
        "cwd": "open-source/gnosis"
      }
    },
    "validate:liquid-shard-smoke": {
      "executor": "a0:run-commands",
      "options": {
        "command": "pnpm run validate:liquid-shard-smoke",
        "cwd": "open-source/gnosis"
      }
    },
    "validate:arena-stack": {
      "executor": "a0:run-commands",
      "options": {
        "command": "pnpm run validate:arena-stack",
        "cwd": "open-source/gnosis"
      }
    },
    "validate:arena-stack-ts": {
      "executor": "a0:run-commands",
      "options": {
        "command": "pnpm run validate:arena-stack-ts",
        "cwd": "open-source/gnosis"
      }
    },
    "validate:socio-sandbox": {
      "executor": "a0:run-commands",
      "options": {
        "command": "pnpm run validate:socio-sandbox",
        "cwd": "open-source/gnosis"
      }
    },
    "report:mathlib-import-fan-in": {
      "executor": "a0:run-commands",
      "options": {
        "command": "pnpm run report:mathlib-import-fan-in",
        "cwd": "open-source/gnosis"
      }
    },
    "evaluate:arena-merge-gate": {
      "executor": "a0:run-commands",
      "options": {
        "command": "pnpm run evaluate:arena-merge-gate",
        "cwd": "open-source/gnosis"
      }
    },
    "validate:ecology-snapshot": {
      "executor": "a0:run-commands",
      "options": {
        "command": "pnpm run validate:ecology-snapshot",
        "cwd": "open-source/gnosis"
      }
    },
    "bench:runtime-shootout": {
      "executor": "a0:run-commands",
      "options": {
        "command": "node gnode/benchmarks/runtime-shootout.mjs",
        "cwd": "open-source/gnosis",
        "forwardAllArgs": true
      }
    },
    "bench:where-time": {
      "executor": "a0:run-commands",
      "options": {
        "command": "node gnode/benchmarks/where-does-time-go.mjs",
        "cwd": "open-source/gnosis",
        "forwardAllArgs": true
      }
    },
    "github:push": {
      "executor": "a0:run-commands",
      "options": {
        "command": "pnpm run monster -- scripts/open-source-repo-target.mjs github-push open-source/gnosis",
        "cwd": "."
      }
    },
    "forge:push": {
      "executor": "a0:run-commands",
      "options": {
        "command": "pnpm run monster -- scripts/open-source-repo-target.mjs forge-push open-source/gnosis",
        "cwd": "."
      }
    },
    "push": {
      "executor": "a0:run-commands",
      "options": {
        "command": "pnpm run monster -- scripts/open-source-repo-target.mjs push open-source/gnosis",
        "cwd": "."
      }
    },
    "submodule:update-reference": {
      "executor": "a0:run-commands",
      "options": {
        "command": "pnpm run monster -- scripts/open-source-repo-target.mjs submodule-update-reference open-source/gnosis",
        "cwd": "."
      }
    },
    "pr:list": {
      "executor": "a0:run-commands",
      "options": {
        "command": "pnpm run monster -- scripts/open-source-repo-target.mjs pr-list open-source/gnosis",
        "cwd": "."
      }
    },
    "pr:merge-all": {
      "executor": "a0:run-commands",
      "options": {
        "command": "pnpm run monster -- scripts/open-source-repo-target.mjs pr-merge-all open-source/gnosis",
        "cwd": "."
      }
    }
  }
}
