{
  "name": "polyglot",
  "projectType": "application",
  "sourceRoot": "open-source/gnosis/polyglot/src",
  "tags": [
    "scope:gnosis",
    "type:rust",
    "platform:cli"
  ],
  "targets": {
    "build": {
      "executor": "a0:run-commands",
      "options": {
        "command": "cargo build --release",
        "cwd": "open-source/gnosis/polyglot"
      },
      "outputs": [
        "{projectRoot}/target/release/gnosis-polyglot",
        "{projectRoot}/target/release/monster",
        "{projectRoot}/target/release/gnexec"
      ]
    },
    "check": {
      "executor": "a0:run-commands",
      "options": {
        "command": "cargo check",
        "cwd": "open-source/gnosis/polyglot"
      }
    },
    "test": {
      "executor": "a0:run-commands",
      "options": {
        "command": "cargo test",
        "cwd": "open-source/gnosis/polyglot"
      }
    },
    "format-check": {
      "executor": "a0:run-commands",
      "options": {
        "command": "cargo fmt --check",
        "cwd": "open-source/gnosis/polyglot"
      }
    },
    "format": {
      "executor": "a0:run-commands",
      "options": {
        "command": "cargo fmt",
        "cwd": "open-source/gnosis/polyglot"
      }
    },
    "lint": {
      "executor": "a0:run-commands",
      "options": {
        "command": "cargo clippy -- -D warnings",
        "cwd": "open-source/gnosis/polyglot"
      }
    },
    "test-wasm": {
      "executor": "a0:run-commands",
      "options": {
        "command": "cargo test --lib aot_wasm && cargo test --test wasm_correctness && cargo test --test gnexec_runtime emit_wasm",
        "cwd": "open-source/gnosis/polyglot"
      }
    }
  }
}
