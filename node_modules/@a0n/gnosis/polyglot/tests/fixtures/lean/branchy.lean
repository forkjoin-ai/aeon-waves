namespace LeanPolyglot

def ifBranch (n : Nat) : Nat := by
  if h : n = 0 then
    exact 0
  else
    exact n

theorem branchy (n : Nat) : n = n := by
  by_cases h : n = 0
  · have hn : n = 0 := h
    calc
      n = 0 := hn
      _ = n := by simpa using hn.symm
  · match n with
    | 0 => rfl
    | Nat.succ k =>
        have hk : Nat.succ k = Nat.succ k := rfl
        exact hk

end LeanPolyglot
