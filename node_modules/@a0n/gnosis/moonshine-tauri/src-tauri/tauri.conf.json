{
  "$schema": "https://schema.tauri.app/config/2.0.0",
  "productName": "Moonshine",
  "version": "0.1.0",
  "identifier": "ai.forkjoin.moonshine",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1422",
    "beforeBuildCommand": "pnpm build && node scripts/prepare-sidecars.mjs",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Moonshine",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "decorations": true,
        "transparent": false,
        "visible": true,
        "center": true,
        "focus": true
      }
    ],
    "security": {
      "csp": null,
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "Affectively",
    "category": "DeveloperTool",
    "shortDescription": "Sovereign guarded terminal for Moonshine shells.",
    "longDescription": "Moonshine is a Tauri desktop terminal for guarded fork/race/fold shell sessions with local identity and monster-guard admission.",
    "resources": [
      "binaries/moonshine",
      "binaries/monster-guard",
      "binaries/wall",
      "binaries/gnexec",
      "binaries/gnosis-polyglot",
      "binaries/monster",
      "binaries/fat-station",
      "binaries/rip",
      "binaries/bw"
    ],
    "fileAssociations": [
      {
        "ext": ["iso", "img"],
        "name": "Disk Image",
        "description": "Boot a Linux .iso/.img as a VM in Moonshine",
        "mimeType": "application/x-iso9660-image",
        "role": "Viewer"
      }
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "iOS": {
      "minimumSystemVersion": "15.0"
    },
    "android": {
      "minSdkVersion": 29
    },
    "macOS": {
      "minimumSystemVersion": "11.0"
    },
    "linux": {
      "appimage": {
        "bundleMediaFramework": true
      }
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["moonshine", "aeon"]
      }
    },
    "shell": {
      "open": true
    }
  }
}
