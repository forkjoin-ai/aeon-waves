# The PUPPET — moonshine as a sovereign fat-client node on Alpine.
#
# Replaces the CF browser-fleet (headless browsers in a sandbox) with a real OS +
# native fork/race/fold compute. A puppet:
#   • is moonshine (the sovereign shell) compiled to a static musl binary,
#   • pulls its model/work from OUR sovereign registry (edgework.ai/v2),
#   • runs distributed inference over aeon Flow + DashRelay (the same fork/race/fold
#     `frf` that frffmpeg proved — fork the prompt, race the nodes, fold the logits),
#   • shares a protocol69-gated sovereign inference cache (via the bundled
#     `distributed-inference` dep — already in moonshine's Cargo.toml),
#   • persists its KV-cache/session as a streaming-disk checkout (resume-anywhere),
#   • and is fully transparent on forgo.cloud.
#
# Build context is the MONOREPO ROOT (moonshine has path deps across the tree):
#   podman build -f open-source/gnosis/moonshine/Containerfile.puppet -t aeon-puppet .
#   a0 xr / our registry:  push to edgework.ai/v2/<did>/puppet:latest
#
# Why it compiles cleanly to musl: moonshine uses reqwest + rustls-tls (NO OpenSSL,
# the usual musl blocker is gone); the `vcpu` VZ boot SHELLS OUT to the macOS
# swerve-vz-bridge at runtime (not a compile-time link), so it builds for Linux and
# simply no-ops there — on Linux the real-OCI-exec path (swerve linux.rs namespaces)
# is the container runtime instead.

# ---------------------------------------------------------------- build (musl) --
FROM rust:1.83-alpine AS build
# Alpine's rust toolchain is musl-native, so `cargo build` yields a static binary.
# build-base/musl-dev give the C compiler the C deps (tree-sitter, ring) need.
RUN apk add --no-cache build-base musl-dev pkgconf git perl
WORKDIR /src
COPY . .
# Build just the moonshine binary; cargo resolves its path deps from the workspace.
RUN cargo build --release --bin moonshine \
      --manifest-path open-source/gnosis/moonshine/Cargo.toml \
 && strip target/release/moonshine

# ----------------------------------------------------------------- the puppet ---
FROM alpine:3.21
RUN apk add --no-cache ca-certificates libgcc
COPY --from=build /src/target/release/moonshine /usr/local/bin/moonshine
# Mark this process as a meshed puppet (vs an interactive shell).
ENV AEON_PUPPET=1
# A puppet runs headless. There is no `mesh join` subcommand on the moonshine
# binary yet (the SubCommand enum is Init/Doctor/Benchmark), and a bare invocation
# drops into the interactive rustyline REPL which needs a TTY a container lacks. The
# real, headless distributed-inference path IS `--oneoff -c <prompt>` (it calls
# agent_runtime::run_oneoff): one real fork/race/fold generation over the sovereign
# inference cache + aeon Flow, then exit -- the puppet's smallest honest unit of
# meshed work. The orchestrator re-invokes the image per work item / model ref.
# (When a long-lived `moonshine mesh join` loop lands, repoint CMD at it.)
ENTRYPOINT ["/usr/local/bin/moonshine"]
CMD ["--oneoff", "-c", "The sovereign mesh is"]
