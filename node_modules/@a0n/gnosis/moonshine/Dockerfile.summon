# Moonshine builder with a0 summon protocol enabled
# Build: docker build -f Dockerfile.summon -t gnosis-summon:latest .
# Run: docker run -e A0_FORGE_URL=... -v ~/.a0:/home/builder/.a0 gnosis-summon:latest

FROM ubuntu:22.04 as builder

# Install Node.js + pnpm
RUN apt-get update && apt-get install -y \
    curl \
    git \
    build-essential \
    ca-certificates \
    && curl -fsSL https://deb.nodesource.com/setup_22.x | bash - \
    && apt-get install -y nodejs \
    && npm install -g pnpm

# Create non-root user
RUN useradd -m -d /home/builder builder
WORKDIR /home/builder

# Copy summon init script
COPY summon-init.sh /usr/local/bin/summon-init
RUN chmod +x /usr/local/bin/summon-init

# Volume for shared .a0 cache across containers
VOLUME ["/home/builder/.a0"]

# Environment defaults (override at runtime)
ENV A0_FORGE_URL=https://registry.forgo.cloud
ENV A0_PREFETCH_ENABLED=1
ENV A0_WORKERS=2
ENV NODE_OPTIONS=--max-old-space-size=2048

# Initialize summon on container start
ENTRYPOINT ["/bin/bash", "-c", "summon-init && exec \"$@\""]
CMD ["/bin/bash"]

# ──────────────────────────────────────────────────────────────────────────
# Multi-stage: production image without build tools
# ──────────────────────────────────────────────────────────────────────────

FROM ubuntu:22.04 as runtime

# Install only runtime dependencies
RUN apt-get update && apt-get install -y \
    curl \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

RUN useradd -m -d /home/app app
WORKDIR /home/app

# Copy built artifacts from builder (if needed)
COPY --from=builder --chown=app:app /home/builder/.a0 /home/app/.a0

# Volume for shared cache
VOLUME ["/home/app/.a0"]

ENV A0_CACHE_DIR=/home/app/.a0
ENV A0_FORGE_URL=https://registry.forgo.cloud

# For runtime environments that need the cache
USER app
CMD ["/bin/bash"]
