// AI Hello World - A Functional Gnosis Transformer
// This model loads weights from weights.toml and computes a forward pass.

// 1. Model Definitions
(input: Source { data: '[0.1, 0.5, -0.2]' })
(encoder: Linear { weights: 'weights.toml', section: 'l1' })
(relu: Activation { type: 'relu' })

// Multi-Head Attention Superposition
(head1: Attention { section: 'attention' })
(head2: Attention { section: 'attention' })
(residual: Attention { section: 'residual' })

(decoder: Linear { weights: 'weights.toml', section: 'l2' })
(output: Softmax)
(telemetry: Trace)
(prediction: Sink)

// 2. The AI Topology
(input)-[:PROCESS]->(encoder)-[:PROCESS]->(relu)
(relu)-[:FORK]->(head1 | head2 | residual)
(head1|head2|residual)-[:RACE { strategy: 'merge-all', request_compression: 'middle-out/request/ai-hello', reuse_scope: 'corridor', corridor_mode: 'readonly' }]->(context)
(context)-[:PROCESS]->(decoder)-[:PROCESS]->(output)
(output)-[:PROCESS]->(prediction | telemetry)
(telemetry)-[:PROCESS]->(prediction)
(prediction)-[:TUNNEL { condition: 'bounded-reject' }]->(ai_hello_gg_trace:Trace)
(prediction)-[:MEASURE { reason: 'topology-audit' }]->(ai_hello_gg_trace:Trace)
