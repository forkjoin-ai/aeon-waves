// binder.gg -- Forkjoin.ai binder registration for open-source/gnosis
// curated 2026-05-17 (originally auto-classified 2026-05-17)
// Spec: scripts/binder-registration.gg.md

(self: BinderProject {
  layer: 'kernel',
  cluster: 'gnosis-kernel',
  status: 'live',
  one_line: 'A graph-first language and toolchain -- every .gg program is a topology',
  chapter_anchor: '60'
})

(self) -[:CLAIM { id: 'gnosis-formal-ledger' }]-> (claim_ledger: Evidence {
  text: 'The Gnosis kernel maintains a formal ledger of Lean-verified primitives that compile to running services.',
  evidence: 'open-source/gnosis/FORMAL_LEDGER.md'
})

(self) -[:CLAIM { id: 'gnosis-theorem-ledger' }]-> (claim_theorem: Evidence {
  text: 'Bridge from gnosis-math theorems into the gnosis runtime documented here.',
  evidence: 'open-source/gnosis/THEOREM_LEDGER.md'
})

(self) -[:CLAIM { id: 'distributed-inference-host' }]-> (claim_di: Evidence {
  text: 'Unified, scale-invariant holographic transport and monitoring for the Forkjoin monorepo distributed-inference fabric.',
  evidence: 'open-source/gnosis/distributed-inference/README.md'
})

(self) -[:DEPENDS_ON { reason: 'gnosis lowers Lean-proven invariants into running services' }]-> (dep_gm: BinderProjectRef {
  path: 'open-source/gnosis-math'
})
