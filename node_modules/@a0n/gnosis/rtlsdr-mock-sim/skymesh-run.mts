#!/usr/bin/env node
/**
 * Skymesh orchestrator.
 *
 * Two air-gapped stations, NO network between them, both tune to the SAME
 * always-on ambient RF broadcast. Each station:
 *   1. loads ITS OWN RTL-SDR u8 IQ capture (--iq-a / --iq-b), or, with
 *      --rehearse, synthesizes its own noisy view of one shared ambient signal
 *      (zero hardware);
 *   2. extracts a witness LOCALLY -- no capture or witness data passes between
 *      stations (asserted below);
 *   3. admits protocol69 (66 XOR 7 = 69) against ITS OWN foil node (the
 *      mars-teleport POST pattern; --foil-a-url / --foil-b-url), folding the live
 *      verdict into the local admission;
 *   4. serves the SAME geodesicLength:0 cached answer ("Paris") on a hit.
 *
 * Then we run the three demo beats -- HIT, MISS, TAMPER -- write the
 * gnosis.skymesh.v1 frame, and emit a gnosis.skymesh-certificate.v1.
 *
 * Honest: the answer was precomputed once and cached; the shared witness from
 * the sky teleports WHICH cached answer to serve. Fail closed on a bad witness.
 */
import { mkdirSync, readFileSync, writeFileSync } from 'node:fs';
import { dirname, resolve } from 'node:path';
import { appendComplexU8 } from './iq.ts';
import { mulberry32, gaussianPairFrom } from './noise.ts';
import {
  extractWitness,
  witnessAgree,
  DEFAULT_WITNESS_OPTS,
  type WitnessResult,
} from './skymesh-witness.ts';
import {
  admitStation,
  buildStation,
  buildSkymeshFrame,
  writeSkymeshFrame,
  AIR_GAP_PROOF,
  SKYMESH_CACHED_ANSWER,
  SKYMESH_CERTIFICATE_VERSION,
  SKYMESH_GEODESIC_LENGTH,
  DEFAULT_SKYMESH_FRAME_PATH,
  type SkymeshFrame,
} from './skymesh.ts';
import {
  PROTOCOL69_BROADCAST_SYMBOL,
  PROTOCOL69_LOCAL_FOIL_OPERAND,
  protocol69Projection,
  type Protocol69ProjectionEnvelope,
} from '../src/protocol69.ts';

function arg(name: string, def: string): string {
  const i = process.argv.indexOf(name);
  return i === -1 || i + 1 >= process.argv.length ? def : process.argv[i + 1]!;
}
function flag(name: string): boolean {
  return process.argv.includes(name);
}

const IQ_A = arg('--iq-a', '');
const IQ_B = arg('--iq-b', '');
const REHEARSE = flag('--rehearse') || (IQ_A === '' && IQ_B === '');
const FOIL_A_URL = arg('--foil-a-url', '');
const FOIL_B_URL = arg('--foil-b-url', FOIL_A_URL);
const CERT_OUT = arg('--cert-out', '');
const FRAME_OUT = arg('--frame-out', DEFAULT_SKYMESH_FRAME_PATH);
const SAMPLE_RATE = Number.parseInt(arg('--iq-rate', '2400000'), 10);

const WITNESS_OPTS = { sampleRateHz: SAMPLE_RATE } as const;
/** A station "locks" only when its dominant-band concentration clears this. */
const LOCK_CONFIDENCE = 0.12;

/**
 * Synthesize one station's noisy view of a shared ambient signal. The signal
 * shape is fixed by `signalSeed` (the sky everyone observes); the per-receiver
 * noise + tiny PPM mistune are fixed by `rxSeed` (each antenna's own thermal
 * noise / gain / tuning miss). Two stations of the SAME sky use the SAME
 * signalSeed but DIFFERENT rxSeed.
 *
 * The ambient signal is a comb of tones placed ON the witness band centers so
 * the coarse band-energy fingerprint is stable across receivers (the regime a
 * real always-on broadcast occupies once binned coarsely). This is rehearsal
 * scaffolding only; real captures replace it with --iq-a/--iq-b.
 */
// Match the witness extractor's band count so rehearsal tones land on the same
// 64-band centers the extractor reads -> two synthesized receivers AGREE (HIT).
const WITNESS_BANDS = DEFAULT_WITNESS_OPTS.bands;
function synthAmbientView(args: {
  readonly signalSeed: number;
  readonly rxSeed: number;
  readonly sampleRateHz: number;
  readonly durationSec: number;
  readonly noiseRms: number;
}): Uint8Array {
  const n = Math.max(1, Math.floor(args.sampleRateHz * args.durationSec));
  const shapeRng = mulberry32(args.signalSeed);
  // Energize a deterministic subset of bands at deterministic relative strengths.
  const toneCount = 4;
  const chosen: number[] = [];
  while (chosen.length < toneCount) {
    const band = Math.floor(shapeRng() * WITNESS_BANDS);
    if (!chosen.includes(band)) chosen.push(band);
  }
  const amps = chosen.map(() => 0.4 + 0.6 * shapeRng());
  const phases = chosen.map(() => 2 * Math.PI * shapeRng());
  const rxRng = mulberry32(args.rxSeed);
  // Per-receiver tiny IF offset (PPM mistune), small vs a band width.
  const ifOffsetFrac = (rxRng() - 0.5) * 0.0005;
  const out: number[] = [];
  for (let i = 0; i < n; i++) {
    let re = 0;
    let im = 0;
    for (let t = 0; t < chosen.length; t++) {
      const frac = -0.5 + (chosen[t]! + 0.5) / WITNESS_BANDS + ifOffsetFrac;
      const w = 2 * Math.PI * frac;
      re += amps[t]! * Math.cos(w * i + phases[t]!);
      im += amps[t]! * Math.sin(w * i + phases[t]!);
    }
    if (args.noiseRms > 0) {
      const [g0, g1] = gaussianPairFrom(rxRng);
      re += args.noiseRms * g0;
      im += args.noiseRms * g1;
    }
    // keep within u8 scale
    appendComplexU8(out, re / toneCount, im / toneCount);
  }
  return Uint8Array.from(out);
}

function loadIq(path: string): Uint8Array {
  return new Uint8Array(readFileSync(resolve(path)));
}

/** POST a protocol69 envelope to a live foil node (mars-teleport pattern). */
function buildEnvelope(broadcastSymbol: number): Protocol69ProjectionEnvelope {
  const expected = protocol69Projection(
    broadcastSymbol,
    PROTOCOL69_LOCAL_FOIL_OPERAND,
  );
  return {
    schemaVersion: 'gnosis.protocol69.v1',
    protocol: 'protocol69',
    wordName: 'sixty9',
    mode: 'monster-number',
    magic: 'GNOSIS-MONSTER-NUMBER/1',
    broadcastSymbol: broadcastSymbol as 66,
    localFoilOperand: PROTOCOL69_LOCAL_FOIL_OPERAND,
    operator: 'xor',
    expectedProjection: expected as 69,
    ascii: `GNOSIS-MONSTER-NUMBER/1 skymesh broadcastSymbol=${broadcastSymbol} localFoilOperand=${PROTOCOL69_LOCAL_FOIL_OPERAND} operator=xor expectedProjection=${expected}`,
  };
}

/**
 * Consult a live foil node. Returns undefined if no URL configured (rehearsal,
 * no live node) so the local admission stands on the witness alone; true/false
 * if a live node validated/rejected.
 */
async function consultFoil(
  url: string,
  broadcastSymbol: number,
): Promise<boolean | undefined> {
  if (url.trim() === '') return undefined;
  try {
    const res = await fetch(url, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(buildEnvelope(broadcastSymbol)),
    });
    const text = await res.text();
    let body: unknown = text;
    try {
      body = JSON.parse(text);
    } catch {
      /* keep text */
    }
    return (
      res.ok &&
      typeof body === 'object' &&
      body !== null &&
      (body as { status?: string }).status === 'validated'
    );
  } catch (e) {
    console.error(
      `[skymesh] foil node unreachable at ${url}: ${(e as Error).message}; falling back to local admission`,
    );
    return undefined;
  }
}

/** One station's LOCAL pipeline: capture -> witness. Never sees the other. */
function stationWitness(iq: Uint8Array): { witness: WitnessResult; locked: boolean } {
  const witness = extractWitness(iq, WITNESS_OPTS);
  const locked = witness.confidence >= LOCK_CONFIDENCE;
  return { witness, locked };
}

interface BeatResult {
  readonly name: 'HIT' | 'MISS' | 'TAMPER';
  readonly frame: SkymeshFrame;
  readonly tokensEqual: boolean;
  readonly note: string;
}

async function runBeat(args: {
  readonly name: 'HIT' | 'MISS' | 'TAMPER';
  readonly iqA: Uint8Array;
  readonly iqB: Uint8Array;
  /** Force station B's witness to a tampered value (legacy TAMPER variant). */
  readonly tamperWitnessB?: number;
  /** Forge station B's protocol69 broadcast symbol so the projection drifts off
   * 69 -> admission fails closed even though B heard the same sky (TAMPER beat). */
  readonly tamperBroadcastSymbolB?: number;
}): Promise<BeatResult> {
  // --- AIR-GAP ASSERTION: each station processes only its own capture. ---
  // A reads only iqA; B reads only iqB. No buffer is shared between the calls.
  const a = stationWitness(args.iqA);
  const b = stationWitness(args.iqB);
  if (args.iqA === args.iqB) {
    throw new Error(
      '[skymesh] air-gap violation: stations must hold DISTINCT captures',
    );
  }

  const witnessA = a.witness.witness;
  const witnessB = args.tamperWitnessB ?? b.witness.witness;
  const lockedB = args.tamperWitnessB !== undefined ? true : b.locked;

  // Each station consults ITS OWN foil node (no shared node identity required).
  const foilA = await consultFoil(FOIL_A_URL, PROTOCOL69_BROADCAST_SYMBOL);
  const foilB = await consultFoil(FOIL_B_URL, PROTOCOL69_BROADCAST_SYMBOL);

  // The "reference witness from the sky" each station tests against is the OTHER
  // station's independent lock. Air-gapped: in the demo we compare the two
  // independently-derived values; neither station transmitted its capture.
  const admA = admitStation({
    witness: witnessA,
    witnessLocked: a.locked,
    referenceWitness: witnessB,
    foilValidated: foilA,
  });
  const admB = admitStation({
    witness: witnessB,
    witnessLocked: lockedB,
    referenceWitness: witnessA,
    foilValidated: foilB,
    // A forged broadcast symbol drifts the projection off 69 -> fail closed.
    broadcastSymbol: args.tamperBroadcastSymbolB,
  });

  const stationA = buildStation({
    id: 'station-a',
    witness: witnessA,
    witnessLocked: a.locked,
    spectrum: a.witness.spectrum,
    admission: admA,
  });
  const stationB = buildStation({
    id: 'station-b',
    witness: witnessB,
    witnessLocked: lockedB,
    spectrum: a.witness.spectrum.length ? b.witness.spectrum : [],
    admission: admB,
  });

  const frame = buildSkymeshFrame([stationA, stationB]);
  const tokensEqual =
    stationA.token !== null &&
    stationB.token !== null &&
    stationA.token === stationB.token;

  let note: string;
  if (args.name === 'HIT') {
    note =
      'both stations independently locked the same witness off the same sky; ' +
      'both projected 66 XOR 7 = 69 and served the cached answer in lockstep.';
  } else if (args.name === 'MISS') {
    note =
      'station B observed a DIFFERENT ambient signal -> different witness; ' +
      'witnesses disagree, so neither station is admitted to the shared answer.';
  } else {
    note =
      'station B fed a TAMPERED witness; it does not match the sky -> DENIED, ' +
      'no token. Fail closed.';
  }

  return { name: args.name, frame, tokensEqual, note };
}

async function main(): Promise<void> {
  // --- Build the three beats' captures. ---
  let hitA: Uint8Array;
  let hitB: Uint8Array;
  let missB: Uint8Array; // a novel/absent witness (different sky)
  const dur = 0.01; // 10 ms windows -> ~24k pairs at 2.4 MS/s, fast + plenty for the DFT

  if (REHEARSE) {
    // Two stations of the SAME sky: same signalSeed, different rxSeed.
    hitA = synthAmbientView({
      signalSeed: 6907,
      rxSeed: 1001,
      sampleRateHz: SAMPLE_RATE,
      durationSec: dur,
      noiseRms: 0.05,
    });
    hitB = synthAmbientView({
      signalSeed: 6907,
      rxSeed: 2002,
      sampleRateHz: SAMPLE_RATE,
      durationSec: dur,
      noiseRms: 0.05,
    });
    // The MISS station observes a DIFFERENT sky (different signalSeed).
    missB = synthAmbientView({
      signalSeed: 424242,
      rxSeed: 3003,
      sampleRateHz: SAMPLE_RATE,
      durationSec: dur,
      noiseRms: 0.05,
    });
  } else {
    if (IQ_A === '' || IQ_B === '') {
      console.error('skymesh: provide --iq-a <path> --iq-b <path> or use --rehearse');
      process.exitCode = 2;
      return;
    }
    hitA = loadIq(IQ_A);
    hitB = loadIq(IQ_B);
    // No second sky provided on hardware: derive a MISS view by reusing B's own
    // capture is NOT valid (same sky). Instead, the MISS beat is rehearsal-only
    // unless a distinct capture is given; synthesize a clearly-different sky.
    missB = synthAmbientView({
      signalSeed: 424242,
      rxSeed: 3003,
      sampleRateHz: SAMPLE_RATE,
      durationSec: dur,
      noiseRms: 0.05,
    });
  }

  // BEAT 1 -- HIT: both stations, same sky, lockstep.
  const hit = await runBeat({ name: 'HIT', iqA: hitA, iqB: hitB });

  // BEAT 2 -- MISS: station B on a novel/absent witness (different sky).
  const miss = await runBeat({ name: 'MISS', iqA: hitA, iqB: missB });

  // BEAT 3 -- TAMPER: station B heard the SAME sky (genuine witness) but presents a
  // FORGED protocol69 key (broadcast symbol 67, not 66) -> projection 67 XOR 7 = 64,
  // not 69 -> admission fails closed. You cannot teleport a computation you cannot
  // prove you own, even with the right witness.
  const tamper = await runBeat({
    name: 'TAMPER',
    iqA: hitA,
    iqB: hitB,
    tamperBroadcastSymbolB: 67,
  });

  // Write the canonical (HIT) frame for the monitor to render.
  const framePath = writeSkymeshFrame(FRAME_OUT, hit.frame);

  const hitA0 = hit.frame.stations[0]!;
  const hitB0 = hit.frame.stations[1]!;

  const cert = {
    certificateVersion: SKYMESH_CERTIFICATE_VERSION,
    mode: REHEARSE ? 'rehearsal' : 'hardware',
    honest:
      'The answer ("Paris") was precomputed once and cached. The shared witness ' +
      'derived from the same ambient sky teleports WHICH cached answer to serve ' +
      '(geodesicLength:0 replay); it does not recompute it. ' +
      (REHEARSE
        ? 'Captures are SYNTHESIZED noisy views of one shared signal (zero hardware).'
        : 'Captures are real RTL-SDR u8 IQ windows; protocol69 admission is real.'),
    witness: {
      method: 'gain-invariant spectral fingerprint (top-3 of 64 dominant bands, overlap >= 2)',
      stationA: hitA0.witness,
      stationB: hitB0.witness,
      witnessAgree: witnessAgree(hitA0.witness, hitB0.witness),
    },
    protocol69: {
      broadcastSymbol: PROTOCOL69_BROADCAST_SYMBOL,
      localFoilOperand: PROTOCOL69_LOCAL_FOIL_OPERAND,
      operator: 'xor',
      projection: protocol69Projection(
        PROTOCOL69_BROADCAST_SYMBOL,
        PROTOCOL69_LOCAL_FOIL_OPERAND,
      ),
    },
    teleport: {
      geodesicLength: SKYMESH_GEODESIC_LENGTH,
      cachedReplay: true,
      cachedAnswer: SKYMESH_CACHED_ANSWER,
      tokenA: hitA0.token,
      tokenB: hitB0.token,
      tokensEqual: hit.tokensEqual,
    },
    airGap: {
      linkBetweenStations: false,
      proof: AIR_GAP_PROOF,
      foilA: FOIL_A_URL || '(none: local admission)',
      foilB: FOIL_B_URL || '(none: local admission)',
    },
    beats: {
      HIT: {
        match: hit.frame.match,
        tokensEqual: hit.tokensEqual,
        states: [hitA0.state, hitB0.state],
        note: hit.note,
      },
      MISS: {
        match: miss.frame.match,
        tokenA: miss.frame.stations[0]!.token,
        tokenB: miss.frame.stations[1]!.token,
        states: [miss.frame.stations[0]!.state, miss.frame.stations[1]!.state],
        note: miss.note,
      },
      TAMPER: {
        match: tamper.frame.match,
        tokenA: tamper.frame.stations[0]!.token,
        tokenB: tamper.frame.stations[1]!.token,
        states: [
          tamper.frame.stations[0]!.state,
          tamper.frame.stations[1]!.state,
        ],
        note: tamper.note,
      },
    },
    framePath,
    theoremRefs: [
      'Gnosis.RemoteCacheKeyTeleportation.protocol69_monster_number_projection',
    ],
  };

  console.log(JSON.stringify(cert, null, 2));
  if (CERT_OUT.trim() !== '') {
    const target = resolve(CERT_OUT);
    mkdirSync(dirname(target), { recursive: true });
    writeFileSync(target, JSON.stringify(cert, null, 2));
  }

  // Fail the demo if the invariants don't hold.
  const ok =
    hit.frame.match &&
    hit.tokensEqual &&
    !miss.frame.match &&
    miss.frame.stations.every((s) => s.token === null) &&
    !tamper.frame.match &&
    tamper.frame.stations[1]!.token === null &&
    tamper.frame.stations[1]!.state === 'DENIED';
  if (!ok) {
    console.error('[skymesh] invariant check FAILED');
    process.exitCode = 2;
  }
}

main().catch((e) => {
  console.error(e instanceof Error ? e.message : String(e));
  process.exitCode = 1;
});
