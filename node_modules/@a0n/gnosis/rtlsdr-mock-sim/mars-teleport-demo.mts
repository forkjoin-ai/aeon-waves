#!/usr/bin/env node
/**
 * Full interplanetary cache-key teleport demo (Layer B + C).
 *
 * The cache key recovered over the air (broadcastSymbol 66) is admitted by the
 * LIVE gnosis-foil-control protocol69 validator (66 XOR 7 = 69). On admission the
 * station does a geodesicLength:0 replay of cached compute LOCALLY -- it never
 * round-trips the interplanetary link. We A/B that local replay against the cold
 * round-trip (modeled light-time) per ladder rung, then relay one key through a
 * multi-hop chain, and emit a teleport certificate.
 *
 * Real: protocol69 validation (live foil-control), light-time physics, the local
 * replay timing. Emulated: the interplanetary distance (light-time, scaled).
 */
import { performance } from 'node:perf_hooks';
import { writeFileSync, mkdirSync } from 'node:fs';
import { dirname, resolve } from 'node:path';
import {
  PROTOCOL69_BROADCAST_SYMBOL,
  PROTOCOL69_LOCAL_FOIL_OPERAND,
  protocol69Projection,
  type Protocol69ProjectionEnvelope,
} from '../src/protocol69.js';
import { buildMonsterRfCacheKeyEnvelope } from './rf-cache-key.js';
import { LADDER, type LadderRung } from './distance-ladder.js';
import { modelColdRoundTrip } from './mars-cold-roundtrip.js';

function arg(name: string, def: string): string {
  const i = process.argv.indexOf(name);
  return i === -1 || i + 1 >= process.argv.length ? def : process.argv[i + 1]!;
}

const FOIL_URL = arg('--foil-url', 'http://127.0.0.1:8787/.aeon/protocol69');
const RECOVERED = Number.parseInt(arg('--recovered-symbol', String(PROTOCOL69_BROADCAST_SYMBOL)), 10);
const OPERAND = PROTOCOL69_LOCAL_FOIL_OPERAND;
const DELAY_SCALE = Number.parseFloat(arg('--delay-scale', '0.0')); // 0 = model only, don't wait
const CERT_OUT = arg('--cert-out', '');

function buildEnvelope(broadcastSymbol: number): Protocol69ProjectionEnvelope {
  const expected = protocol69Projection(broadcastSymbol, OPERAND);
  return {
    schemaVersion: 'gnosis.protocol69.v1',
    protocol: 'protocol69',
    wordName: 'sixty9',
    mode: 'monster-number',
    magic: 'GNOSIS-MONSTER-NUMBER/1',
    broadcastSymbol: broadcastSymbol as 66,
    localFoilOperand: OPERAND,
    operator: 'xor',
    expectedProjection: expected as 69,
    ascii: `GNOSIS-MONSTER-NUMBER/1 recoveredOverTheAir broadcastSymbol=${broadcastSymbol} localFoilOperand=${OPERAND} operator=xor expectedProjection=${expected}`,
  };
}

async function admit(broadcastSymbol: number): Promise<{ ok: boolean; status: number; body: unknown }> {
  const res = await fetch(FOIL_URL, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify(buildEnvelope(broadcastSymbol)),
  });
  const text = await res.text();
  let body: unknown = text;
  try {
    body = JSON.parse(text);
  } catch {
    /* keep text */
  }
  const validated =
    typeof body === 'object' && body !== null && (body as { status?: string }).status === 'validated';
  return { ok: res.ok && validated, status: res.status, body };
}

/** Local geodesicLength:0 replay: a cached compute hit, no compute-space traversal. */
function localReplay(): { micros: number; geodesicLength: number } {
  const t0 = performance.now();
  const env = buildMonsterRfCacheKeyEnvelope({ transport: 'simulated', symbolMode: 'monster-number' });
  const t1 = performance.now();
  return {
    micros: (t1 - t0) * 1000,
    geodesicLength: env.monsterRfCacheKey.replayContract.geodesicLength,
  };
}

function pickRung(name: string): LadderRung {
  const r = LADDER.find((x) => x.name === name);
  if (!r) throw new Error(`no rung ${name}`);
  return r;
}

async function main(): Promise<void> {
  // 1. Admit the over-the-air-recovered cache key via the live foil node.
  const admitGood = await admit(RECOVERED);
  const projection = protocol69Projection(RECOVERED, OPERAND);
  // Sanity: a wrong recovered symbol must be rejected (fail-closed teleport).
  const admitWrong = await admit((RECOVERED ^ 1) >>> 0);

  // 2. Local replay timing (the geodesicLength:0 cache hit).
  const replay = localReplay();
  const replaySec = replay.micros / 1e6;

  // 3. Per-rung A/B: teleport (local, constant) vs cold round-trip (modeled).
  const rungNames = [
    'Moon',
    'Mars (opposition)',
    'Mars (mean)',
    'Mars (conjunction)',
    'Jupiter (mean)',
    'Neptune (mean)',
    'Voyager 1',
  ];
  const perRung = rungNames.map((n) => {
    const rung = pickRung(n);
    const cold = modelColdRoundTrip(rung.rangeKm, DELAY_SCALE);
    return {
      rung: n,
      roundTripSec: Number(cold.roundTripSec.toFixed(1)),
      teleportReplaySec: Number(replaySec.toFixed(9)),
      speedupVsRoundTrip: Math.round(cold.roundTripSec / replaySec),
      dtnTtlSec: cold.recommendedTtlSec,
    };
  });

  // 4. Relay chain (store-carry-forward through landmarks); teleport at the far
  //    station avoids the cumulative round-trip back to Earth.
  const chain = ['Moon', 'Mars (mean)', 'Jupiter (mean)'];
  let cumOneWay = 0;
  const hops = chain.map((n) => {
    const rung = pickRung(n);
    const oneWay = modelColdRoundTrip(rung.rangeKm).oneWaySec;
    cumOneWay += oneWay; // store-carry-forward accumulates one-way legs
    return { hop: n, hopOneWaySec: Number(oneWay.toFixed(1)), cumulativeOneWaySec: Number(cumOneWay.toFixed(1)) };
  });
  const relayRoundTripAvoidedSec = Number((cumOneWay * 2).toFixed(1));

  const cert = {
    certificateVersion: 'gnosis.mars-teleport.v1',
    foilUrl: FOIL_URL,
    overTheAir: {
      recoveredBroadcastSymbol: RECOVERED,
      localFoilOperand: OPERAND,
      projection,
      admittedByLiveFoil: admitGood.ok,
      wrongSymbolRejected: !admitWrong.ok,
    },
    teleportReplay: {
      geodesicLength: replay.geodesicLength,
      cachedReplay: true,
      replayMicros: Number(replay.micros.toFixed(2)),
      note: 'local amplituhedron cache-hit class: cached compute replays without traversing compute space',
    },
    latencyAB: perRung,
    relayChain: { hops, relayRoundTripAvoidedSec },
    theoremRefs: [
      'Gnosis.RemoteCacheKeyTeleportation.protocol69_monster_number_projection',
      'Gnosis.RemoteCacheKeyTeleportation.protocol69_braids_integer_projection_with_fano_parity',
      'MarsDistanceLadder.margin_closes_at_dmax_implies_closes_below',
      'MarsDistanceLadder.teleport_savings_monotone_in_distance',
    ],
    honest:
      'protocol69 admission + local replay are real; interplanetary distance/latency is modeled. ' +
      'The teleport avoids the round-trip; the cache key crosses the link, the compute does not.',
  };

  console.log(JSON.stringify(cert, null, 2));
  if (CERT_OUT.trim() !== '') {
    mkdirSync(dirname(resolve(CERT_OUT)), { recursive: true });
    writeFileSync(resolve(CERT_OUT), JSON.stringify(cert, null, 2));
  }
  if (!admitGood.ok || admitWrong.ok) process.exitCode = 2;
}

main().catch((e) => {
  console.error(e instanceof Error ? e.message : String(e));
  process.exitCode = 1;
});
