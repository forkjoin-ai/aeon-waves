// failure_composition.test.gg — Native Gnosis witnesses for THM-FAIL-COMPOSITION
//
// These theorem-shaped `.gg` modules cover:
//   - a multi-stage vent-paid collapse
//   - a multi-stage repair-paid collapse
//   - a free prefix that still hits the collapse boundary
//   - a contagious recovery chain with a paid stage

(test_suite: TestSuite { name: 'failure-composition' })

(paid_vent_stage: Verify { module: './failure_composition_paid_vent_stage.gg', beta1_max: '8' })
(paid_repair_stage: Verify { module: './failure_composition_paid_repair_stage.gg', beta1_max: '8' })
(free_prefix_blocked: Verify { module: './failure_composition_free_prefix_blocked.gg', beta1_max: '8' })
(contagious_paid_stage: Verify { module: './failure_composition_contagious_paid_stage.gg', beta1_max: '8' })

(test_suite)-[:FORK]->(paid_vent_stage | paid_repair_stage | free_prefix_blocked | contagious_paid_stage)

(paid_vent_stage)-[:RACE { expect: 'safe' }]->(paid_vent_result: Result)
(paid_repair_stage)-[:RACE { expect: 'safe' }]->(paid_repair_result: Result)
(free_prefix_blocked)-[:RACE { expect: 'safe' }]->(free_prefix_result: Result)
(contagious_paid_stage)-[:RACE { expect: 'safe' }]->(contagious_paid_result: Result)

(paid_vent_result | paid_repair_result | free_prefix_result | contagious_paid_result)-[:FOLD { strategy: 'all-pass' }]->(verdict: Verdict)
(verdict)-[:TUNNEL { condition: 'bounded-reject' }]->(failure_composition_test_gg_trace:Trace)
(verdict)-[:MEASURE { reason: 'topology-audit' }]->(failure_composition_test_gg_trace:Trace)
