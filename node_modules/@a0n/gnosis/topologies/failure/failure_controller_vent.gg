// failure_controller_vent.gg — THM-FAILURE-CONTROLLER witness (vent when cheapest)
//
// When the cost of venting a branch is less than both keep cost and
// repair cost, the optimal controller action is vent. The controller
// pays the vent tax and collapses to a single survivor.
// Example: keep_cost=6, vent_cost=1, repair_cost=4 -> action=vent.

(frontier: FailureFrontier { theorem: 'THM-FAILURE-CONTROLLER', live_branches: '3' })
(keep_option: ActionCost { action: 'keep', cost: '6' })
(vent_option: ActionCost { action: 'vent', cost: '1' })
(repair_option: ActionCost { action: 'repair', cost: '4' })
(controller: Controller { strategy: 'min-cost' })
(decision: Decision { action: 'vent', cost: '1', reason: 'cheapest' })
(vented: Vent { paid_cost: '1-branch' })
(result: Result { theorem: 'vent-when-cheapest' })

(frontier)-[:FORK]->(keep_option | vent_option | repair_option)
(keep_option | vent_option | repair_option)-[:RACE { expect: 'costs-computed' }]->(controller)
(controller)-[:PROCESS { strategy: 'select-minimum-cost' }]->(decision)
(decision)-[:VENT { condition: 'vent-is-cheapest' }]->(vented)
(vented)-[:PROCESS]->(result)
(result)-[:MEASURE { reason: 'topology-audit' }]->(failure_controller_vent_gg_trace:Trace)
