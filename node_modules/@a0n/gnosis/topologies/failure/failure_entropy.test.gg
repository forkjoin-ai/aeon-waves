// failure_entropy.test.gg — Native Gnosis witnesses for THM-FAILURE-ENTROPY
//
// These theorem-shaped `.gg` modules cover:
//   - frontier > 1 implies positive entropy
//   - single survivor implies zero entropy
//   - more branches implies more entropy (monotone)

(test_suite: TestSuite { name: 'failure-entropy' })

(positive: Verify { module: './failure_entropy_positive.gg', beta1_max: '6' })
(zero: Verify { module: './failure_entropy_zero.gg', beta1_max: '6' })
(monotone: Verify { module: './failure_entropy_monotone.gg', beta1_max: '6' })

(test_suite)-[:FORK]->(positive | zero | monotone)

(positive)-[:RACE { expect: 'safe' }]->(positive_result: Result)
(zero)-[:RACE { expect: 'safe' }]->(zero_result: Result)
(monotone)-[:RACE { expect: 'safe' }]->(monotone_result: Result)

(positive_result | zero_result | monotone_result)-[:FOLD { strategy: 'all-pass' }]->(verdict: Verdict)
(verdict)-[:TUNNEL { condition: 'bounded-reject' }]->(failure_entropy_test_gg_trace:Trace)
(verdict)-[:MEASURE { reason: 'topology-audit' }]->(failure_entropy_test_gg_trace:Trace)
