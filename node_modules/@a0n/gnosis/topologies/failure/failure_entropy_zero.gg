// failure_entropy_zero.gg — THM-FAILURE-ENTROPY witness (single survivor implies zero entropy)
//
// A frontier that has already collapsed to a single survivor has zero
// entropy. There is no uncertainty -- the outcome is determined.
// Example: frontier=1, weight=1.0 -> S = -1*log2(1) = 0 bits.

(frontier: FailureFrontier { theorem: 'THM-FAILURE-ENTROPY', live_branches: '1' })
(survivor: Branch { id: '1', weight: '1.0', survives: 'true' })
(entropy: EntropyMeasure { value: '0', formula: '-1*(1.0*log2(1.0))', unit: 'bits' })
(zero_check: Invariant { claim: 'single survivor implies entropy = 0', branches: '1', entropy: '0' })
(result: Result { theorem: 'single-survivor-zero-entropy' })

(frontier)-[:PROCESS]->(survivor)
(survivor)-[:PROCESS { expect: 'entropy-computed' }]->(entropy)
(entropy)-[:PROCESS]->(zero_check)
(zero_check)-[:PROCESS { strategy: 'verify-zero' }]->(result)
