// failure_universality_free_prefix_blocked.gg — No finite prefix realizes free deterministic collapse
//
// THM-FAIL-UNIVERSAL:
// even a finite prefix of an arbitrary-depth trajectory cannot beat the
// no-free-collapse boundary.

(origin: ForkedFrontier { theorem: 'THM-FAIL-UNIVERSAL', live_branches: '3', depth: '2' })
(left_0: Branch { stage: '0', output: 'left' })
(middle_0: Branch { stage: '0', output: 'middle' })
(right_0: Branch { stage: '0', output: 'right' })
(left_1: Branch { stage: '1', output: 'left' })
(middle_1: Branch { stage: '1', output: 'middle' })
(right_1: Branch { stage: '1', output: 'right' })
(boundary: Impossibility { reason: 'no free prefix collapse at any depth' })
(finish: Survivor { survivors: '1', cost: 'unpaid' })
(result: Result { theorem: 'no-depth-realizes-free-collapse' })

(origin)-[:FORK]->(left_0 | middle_0 | right_0)
(left_0)-[:PROCESS]->(left_1)
(middle_0)-[:PROCESS]->(middle_1)
(right_0)-[:PROCESS]->(right_1)
(left_1 | middle_1 | right_1)-[:FOLD { strategy: 'single-survivor', request_compression: 'middle-out/request/failure-universality-free-prefix-blocked', reuse_scope: 'corridor', corridor_mode: 'readonly' }]->(finish)
(finish)-[:PROCESS]->(boundary)
(boundary)-[:PROCESS]->(result)
(result)-[:TUNNEL { condition: 'bounded-reject' }]->(failure_universality_free_prefix_blocked_gg_trace:Trace)
(result)-[:MEASURE { reason: 'topology-audit' }]->(failure_universality_free_prefix_blocked_gg_trace:Trace)
