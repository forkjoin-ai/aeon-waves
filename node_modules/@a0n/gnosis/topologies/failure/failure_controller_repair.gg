// failure_controller_repair.gg — THM-FAILURE-CONTROLLER witness (repair when cheapest)
//
// When the cost of repair debt is less than both keep cost and vent cost,
// the optimal controller action is repair. The controller absorbs repair
// debt into the surviving branch.
// Example: keep_cost=9, vent_cost=5, repair_cost=3 -> action=repair.

(frontier: FailureFrontier { theorem: 'THM-FAILURE-CONTROLLER', live_branches: '3' })
(keep_option: ActionCost { action: 'keep', cost: '9' })
(vent_option: ActionCost { action: 'vent', cost: '5' })
(repair_option: ActionCost { action: 'repair', cost: '3' })
(controller: Controller { strategy: 'min-cost' })
(decision: Decision { action: 'repair', cost: '3', reason: 'cheapest' })
(repair_debt: RepairDebt { units: '3' })
(result: Result { theorem: 'repair-when-cheapest' })

(frontier)-[:FORK]->(keep_option | vent_option | repair_option)
(keep_option | vent_option | repair_option)-[:RACE { expect: 'costs-computed' }]->(controller)
(controller)-[:PROCESS { strategy: 'select-minimum-cost' }]->(decision)
(decision)-[:SLIVER { mode: 'repair' }]->(repair_debt)
(repair_debt)-[:PROCESS]->(result)
(result)-[:MEASURE { reason: 'topology-audit' }]->(failure_controller_repair_gg_trace:Trace)
