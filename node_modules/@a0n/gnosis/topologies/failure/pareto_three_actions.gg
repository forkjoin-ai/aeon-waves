// pareto_three_actions.gg — THM-FAILURE-PARETO witness (keep/vent/repair are Pareto-optimal)
//
// The three failure actions (keep, vent, repair) each occupy a distinct
// point on the Pareto frontier. No other action strictly dominates
// any of the three across all objectives.
// Example: keep(cost=0, multiplicity=3), vent(cost=1, multiplicity=1), repair(cost=2, multiplicity=3).

(frontier: ParetoFrontier { theorem: 'THM-FAILURE-PARETO', actions: '3' })
(keep: Action { id: 'keep', cost: '0', multiplicity: '3', repair_debt: '0' })
(vent: Action { id: 'vent', cost: '1', multiplicity: '1', repair_debt: '0' })
(repair: Action { id: 'repair', cost: '2', multiplicity: '3', repair_debt: '0' })
(pareto: ParetoSet { members: '[keep, vent, repair]', size: '3' })
(invariant: Invariant { claim: 'all_three_pareto_optimal', frontier_size: '3' })
(result: Result { theorem: 'three-actions-pareto-optimal' })

(frontier)-[:FORK]->(keep | vent | repair)
(keep | vent | repair)-[:RACE { expect: 'non-dominated' }]->(pareto)
(pareto)-[:PROCESS]->(invariant)
(invariant)-[:PROCESS { strategy: 'verify-equality' }]->(result)
(result)-[:MEASURE { reason: 'topology-audit' }]->(pareto_three_actions_gg_trace:Trace)
