// failure_pareto.test.gg — Native Gnosis witnesses for THM-FAILURE-PARETO
//
// These theorem-shaped `.gg` modules cover:
//   - keep/vent/repair are Pareto-optimal (three_actions)
//   - no action dominates all others (no_domination)
//   - cost vs multiplicity tradeoff (cost_tradeoff)

(test_suite: TestSuite { name: 'failure-pareto' })

(three_actions: Verify { module: './pareto_three_actions.gg', beta1_max: '6' })
(no_domination: Verify { module: './pareto_no_domination.gg', beta1_max: '6' })
(cost_tradeoff: Verify { module: './pareto_cost_tradeoff.gg', beta1_max: '6' })

(test_suite)-[:FORK]->(three_actions | no_domination | cost_tradeoff)

(three_actions)-[:RACE { expect: 'safe' }]->(actions_result: Result)
(no_domination)-[:RACE { expect: 'safe' }]->(domination_result: Result)
(cost_tradeoff)-[:RACE { expect: 'safe' }]->(tradeoff_result: Result)

(actions_result | domination_result | tradeoff_result)-[:FOLD { strategy: 'all-pass' }]->(verdict: Verdict)
(verdict)-[:TUNNEL { condition: 'bounded-reject' }]->(failure_pareto_test_gg_trace:Trace)
(verdict)-[:MEASURE { reason: 'topology-audit' }]->(failure_pareto_test_gg_trace:Trace)
