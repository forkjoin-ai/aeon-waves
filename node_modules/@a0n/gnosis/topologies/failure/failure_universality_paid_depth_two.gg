// failure_universality_paid_depth_two.gg — A deeper trajectory still pays the floor
//
// THM-FAIL-UNIVERSAL / THM-FAIL-MINCOST:
// the arbitrary-depth normalization keeps the same lower bound across a finite
// prefix; here the payment is spread over a deeper trajectory.

(origin: ForkedFrontier { theorem: 'THM-FAIL-UNIVERSAL', live_branches: '4', depth: '2' })
(a0: Branch { output: 'a' })
(b0: Branch { output: 'b' })
(c0: Branch { output: 'c' })
(d0: Branch { output: 'd' })
(a1: Branch { stage: '1', output: 'a' })
(b1: Branch { stage: '1', output: 'b' })
(c1: Branch { stage: '1', output: 'c' })
(d1: Branch { stage: '1', output: 'd' })
(vent_c: VentedLoss { stage: '2', cost: '1' })
(vent_d: VentedLoss { stage: '2', cost: '1' })
(repair_b: RepairDebt { stage: '2', debt: '1' })
(finish: Survivor { survivors: '1', total_cost: '3' })
(result: Result { theorem: 'depth-two-paid-floor' })

(origin)-[:FORK]->(a0 | b0 | c0 | d0)
(a0)-[:PROCESS]->(a1)
(b0)-[:PROCESS]->(b1)
(c0)-[:PROCESS]->(c1)
(d0)-[:PROCESS]->(d1)
(c1)-[:VENT { stage: '2', condition: 'depth-two-vent-c' }]->(vent_c)
(d1)-[:VENT { stage: '2', condition: 'depth-two-vent-d' }]->(vent_d)
(b1)-[:SLIVER { stage: '2', debt: '1' }]->(repair_b)
(a1 | repair_b | vent_c | vent_d)-[:FOLD { strategy: 'single-survivor-after-payment' }]->(finish)
(finish)-[:PROCESS]->(result)
(result)-[:MEASURE { reason: 'topology-audit' }]->(failure_universality_paid_depth_two_gg_trace:Trace)
