// failure_universality_contagious_depth.gg — Contagious repair pressure survives normalization
//
// THM-FAIL-UNIVERSAL:
// persistent branch identity and arbitrary depth do not remove the need to pay
// repair debt when zero-vent collapse pressure propagates.

(origin: ForkedFrontier { theorem: 'THM-FAIL-UNIVERSAL', live_branches: '3', depth: '3' })
(left_0: Branch { stage: '0', output: 'left' })
(middle_0: Branch { stage: '0', output: 'middle' })
(right_0: Branch { stage: '0', output: 'right' })
(left_1: Branch { stage: '1', output: 'left' })
(middle_1: Branch { stage: '1', output: 'middle' })
(right_1: Branch { stage: '1', output: 'right' })
(repair_2: RepairDebt { stage: '2', debt: '2', mode: 'contagious' })
(finish: Survivor { survivors: '1' })
(result: Result { theorem: 'contagious-depth-paid-repair' })

(origin)-[:FORK]->(left_0 | middle_0 | right_0)
(left_0)-[:PROCESS]->(left_1)
(middle_0)-[:PROCESS]->(middle_1)
(right_0)-[:PROCESS]->(right_1)
(left_1 | middle_1)-[:SLIVER { stage: '2', debt: '2', mode: 'contagious' }]->(repair_2)
(repair_2 | right_1)-[:FOLD { strategy: 'single-survivor-after-payment' }]->(finish)
(finish)-[:PROCESS]->(result)
(result)-[:TUNNEL { condition: 'bounded-reject' }]->(failure_universality_contagious_depth_gg_trace:Trace)
(result)-[:MEASURE { reason: 'topology-audit' }]->(failure_universality_contagious_depth_gg_trace:Trace)
