// reynolds_turbulent.gg — THM-REYNOLDS-BFT witness (C < N implies positive idle)
//
// In the turbulent regime, channel capacity C is less than node count N.
// Some nodes must wait -- positive idle stages are unavoidable.
// Re = N/C > 1 implies turbulent flow with contention.

(network: BFTNetwork { theorem: 'THM-REYNOLDS-BFT', nodes: '8', capacity: '3' })
(round_1: CommRound { active_nodes: '3', idle_nodes: '5', round: '1' })
(round_2: CommRound { active_nodes: '3', idle_nodes: '5', round: '2' })
(round_3: CommRound { active_nodes: '2', idle_nodes: '6', round: '3' })
(reynolds: ReynoldsNumber { value: '2.67', regime: 'turbulent', threshold: '1.0' })
(idle: Invariant { claim: 'C < N implies idle_stages > 0', total_idle: '16' })
(result: Result { theorem: 'turbulent-positive-idle' })

(network)-[:FORK]->(round_1 | round_2 | round_3)
(round_1)-[:PROCESS]->(round_2)
(round_2)-[:PROCESS]->(round_3)
(round_1 | round_2 | round_3)-[:RACE { expect: 'idle-detected' }]->(reynolds)
(reynolds)-[:PROCESS]->(idle)
(idle)-[:PROCESS { strategy: 'verify-positive' }]->(result)
(result)-[:MEASURE { reason: 'topology-audit' }]->(reynolds_turbulent_gg_trace:Trace)
