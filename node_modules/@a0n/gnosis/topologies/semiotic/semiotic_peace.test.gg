// semiotic_peace.test.gg — Native Gnosis witnesses for THM-SEMIOTIC-PEACE
//
// These theorem-shaped `.gg` modules cover:
//   - confusion is irreducible (semiotic deficit > 0)
//   - confusion generates heat (Landauer cost)
//   - war is cumulative heat (monotone accumulation)
//   - context is peace (shared context reduces deficit)

(test_suite: TestSuite { name: 'semiotic-peace' })

(confusion_irreducible: Verify { module: './semiotic_confusion_irreducible.gg', beta1_max: '6' })
(confusion_heat: Verify { module: './semiotic_confusion_heat.gg', beta1_max: '6' })
(war_cumulative: Verify { module: './semiotic_war_cumulative.gg', beta1_max: '6' })
(context_is_peace: Verify { module: './semiotic_context_peace.gg', beta1_max: '6' })

(test_suite)-[:FORK]->(confusion_irreducible | confusion_heat | war_cumulative | context_is_peace)

(confusion_irreducible)-[:RACE { expect: 'safe' }]->(irred_result: Result)
(confusion_heat)-[:RACE { expect: 'safe' }]->(heat_result: Result)
(war_cumulative)-[:RACE { expect: 'safe' }]->(war_result: Result)
(context_is_peace)-[:RACE { expect: 'safe' }]->(peace_result: Result)

(irred_result | heat_result | war_result | peace_result)-[:FOLD { strategy: 'all-pass' }]->(verdict: Verdict)
(verdict)-[:TUNNEL { condition: 'bounded-reject' }]->(semiotic_peace_test_gg_trace:Trace)
(verdict)-[:MEASURE { reason: 'topology-audit' }]->(semiotic_peace_test_gg_trace:Trace)
