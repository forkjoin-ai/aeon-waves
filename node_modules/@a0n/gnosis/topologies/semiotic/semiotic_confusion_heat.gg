// semiotic_confusion_heat.gg — THM-CONFUSION-GENERATES-HEAT witness
//
// The semiotic fold is a many-to-one coarsening (5 paths -> 1 stream).
// By Landauer's principle, this generates irreducible heat >= kT ln 2.

(fold: SemioticFold { theorem: 'THM-CONFUSION-GENERATES-HEAT', paths: '5', streams: '1' })
(collision: Collision { paths_sharing_stream: '5', description: 'all paths map to stream 0' })
(heat: LandauerHeat { lower_bound: 'kT * ln2 * log2(5)', positive: 'true' })
(result: Result { theorem: 'confusion-generates-physical-heat' })

(fold)-[:PROCESS]->(collision)
(collision)-[:PROCESS { expect: 'collision-exists' }]->(heat)
(heat)-[:PROCESS { strategy: 'verify-positive-heat' }]->(result)
