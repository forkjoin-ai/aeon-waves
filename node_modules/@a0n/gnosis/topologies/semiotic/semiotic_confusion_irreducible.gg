// semiotic_confusion_irreducible.gg — THM-CONFUSION-IRREDUCIBILITY witness
//
// Standard speech (1 articulation stream) with 5 semantic paths.
// Semiotic deficit = 5 - 1 = 4. Four dimensions of meaning are lost.
// The deficit is a topological invariant of the channel.

(channel: SemioticChannel { theorem: 'THM-CONFUSION-IRREDUCIBILITY', semantic_paths: '5', streams: '1' })
(path_1: SemanticPath { meaning: 'denotation' })
(path_2: SemanticPath { meaning: 'connotation' })
(path_3: SemanticPath { meaning: 'implicature' })
(path_4: SemanticPath { meaning: 'prosody' })
(path_5: SemanticPath { meaning: 'gesture' })
(speech: ArticulationStream { width: '1' })
(deficit: Deficit { value: '4', formula: '5 - 1' })
(result: Result { theorem: 'confusion-irreducible' })

(channel)-[:FORK]->(path_1 | path_2 | path_3 | path_4 | path_5)
(path_1 | path_2 | path_3 | path_4 | path_5)-[:FOLD { strategy: 'single-stream' }]->(speech)
(speech)-[:PROCESS]->(deficit)
(deficit)-[:PROCESS { strategy: 'verify-positive-deficit' }]->(result)
(result)-[:TUNNEL { condition: 'bounded-reject' }]->(semiotic_confusion_irreducible_gg_trace:Trace)
(result)-[:MEASURE { reason: 'topology-audit' }]->(semiotic_confusion_irreducible_gg_trace:Trace)
