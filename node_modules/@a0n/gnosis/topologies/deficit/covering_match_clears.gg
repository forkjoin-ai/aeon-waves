// covering_match_clears.gg — THM-COVERING-SPACE-CAUSALITY witness (matched -> no blocking)
//
// When the covering space topology matches the base space exactly,
// every causal path lifts without obstruction. Blocking count = 0.
// Example: base has 3 sheets, cover has 3 matched sheets -> 0 blocked.

(space: CoveringSpace { theorem: 'THM-COVERING-SPACE-CAUSALITY', base_sheets: '3', cover_sheets: '3' })
(sheet_a: Sheet { id: 'a', matched: 'true' })
(sheet_b: Sheet { id: 'b', matched: 'true' })
(sheet_c: Sheet { id: 'c', matched: 'true' })
(lifted: LiftResult { paths_lifted: '3', blocked: '0' })
(invariant: Invariant { claim: 'match_implies_no_blocking', blocked_count: '0' })
(result: Result { theorem: 'matched-topology-clears' })

(space)-[:FORK]->(sheet_a | sheet_b | sheet_c)
(sheet_a | sheet_b | sheet_c)-[:RACE { expect: 'all-lifted' }]->(lifted)
(lifted)-[:PROCESS]->(invariant)
(invariant)-[:PROCESS { strategy: 'verify-zero' }]->(result)
(result)-[:MEASURE { reason: 'topology-audit' }]->(covering_match_clears_gg_trace:Trace)
