// staged_expansion.test.gg — Native Gnosis witnesses for THM-STAGED-EXPANSION
//
// These theorem-shaped `.gg` modules cover:
//   - staged area equals naive area (frontier_conserved)
//   - shoulders fill before widening (shoulder_fill)
//   - balanced stages produce zero waste (wallace_zero)

(test_suite: TestSuite { name: 'staged-expansion' })

(frontier_conserved: Verify { module: './staged_frontier_conserved.gg', beta1_max: '6' })
(shoulder_fill: Verify { module: './staged_shoulder_fill.gg', beta1_max: '6' })
(wallace_zero: Verify { module: './staged_wallace_zero.gg', beta1_max: '6' })

(test_suite)-[:FORK]->(frontier_conserved | shoulder_fill | wallace_zero)

(frontier_conserved)-[:RACE { expect: 'safe' }]->(conserved_result: Result)
(shoulder_fill)-[:RACE { expect: 'safe' }]->(fill_result: Result)
(wallace_zero)-[:RACE { expect: 'safe' }]->(wallace_result: Result)

(conserved_result | fill_result | wallace_result)-[:FOLD { strategy: 'all-pass' }]->(verdict: Verdict)
(verdict)-[:TUNNEL { condition: 'bounded-reject' }]->(staged_expansion_test_gg_trace:Trace)
(verdict)-[:MEASURE { reason: 'topology-audit' }]->(staged_expansion_test_gg_trace:Trace)
