// staged_wallace_zero.gg — THM-STAGED-EXPANSION witness (balanced stages -> zero waste)
//
// When stages are perfectly balanced (equal area), the Wallace waste
// metric is zero. No expansion effort is wasted on redundant coverage.
// Example: 3 balanced stages of area 4 each, waste = 0.

(expansion: StagedExpansion { theorem: 'THM-STAGED-EXPANSION', stages: '3', balanced: 'true' })
(stage_1: Stage { id: '1', area: '4' })
(stage_2: Stage { id: '2', area: '4' })
(stage_3: Stage { id: '3', area: '4' })
(waste: WallaceMetric { imbalance: '0', waste: '0' })
(invariant: Invariant { claim: 'balanced_implies_zero_waste', waste: '0' })
(result: Result { theorem: 'wallace-zero-waste' })

(expansion)-[:FORK]->(stage_1 | stage_2 | stage_3)
(stage_1 | stage_2 | stage_3)-[:RACE { expect: 'balanced' }]->(waste)
(waste)-[:PROCESS]->(invariant)
(invariant)-[:PROCESS { strategy: 'verify-zero' }]->(result)
(result)-[:MEASURE { reason: 'topology-audit' }]->(staged_wallace_zero_gg_trace:Trace)
