// frontier_positive_below.gg — THM-AMERICAN-FRONTIER witness (below match implies positive waste)
//
// When the frontier diversity is strictly below the match point,
// waste is strictly positive. The gap represents unrealized potential.
// Example: match=6, diversity=3 -> waste = max(0, 6-3) = 3 > 0.

(frontier: AmericanFrontier { theorem: 'THM-AMERICAN-FRONTIER', match_point: '6' })
(supply: DiversityLevel { diversity: '3', required: '6' })
(waste: WasteMeasure { value: '3', formula: 'max(0, 6 - 3)' })
(positivity: Invariant { claim: 'below match implies positive waste', diversity: '3', match: '6', waste: '3' })
(result: Result { theorem: 'positive-waste-below-match' })

(frontier)-[:PROCESS]->(supply)
(supply)-[:PROCESS]->(waste)
(waste)-[:PROCESS { expect: 'waste-is-positive' }]->(positivity)
(positivity)-[:PROCESS { strategy: 'verify-positive' }]->(result)
