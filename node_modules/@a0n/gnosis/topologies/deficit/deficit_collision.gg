// deficit_collision.gg — THM-DEFICIT-CAPACITY witness (paths > streams -> collision)
//
// When the number of active paths exceeds the number of available
// streams, at least one collision occurs. The deficit equals the
// excess paths that cannot be assigned unique streams.
// Example: 5 paths, 3 streams -> 2 collisions, deficit = 2.

(capacity: DeficitCapacity { theorem: 'THM-DEFICIT-CAPACITY', paths: '5', streams: '3' })
(path_1: Path { id: '1', stream: '1' })
(path_2: Path { id: '2', stream: '2' })
(path_3: Path { id: '3', stream: '3' })
(path_4: Path { id: '4', stream: 'collision' })
(path_5: Path { id: '5', stream: 'collision' })
(deficit: Deficit { collisions: '2', excess: '2' })
(invariant: Invariant { claim: 'excess_paths_cause_collision', paths: '5', streams: '3', deficit: '2' })
(result: Result { theorem: 'paths-exceed-streams-collision' })

(capacity)-[:FORK]->(path_1 | path_2 | path_3 | path_4 | path_5)
(path_4)-[:VENT { condition: 'no-stream-available' }]->(vent_4: VentedPath)
(path_5)-[:VENT { condition: 'no-stream-available' }]->(vent_5: VentedPath)
(vent_4 | vent_5)-[:RACE { expect: 'collision-counted' }]->(deficit)
(deficit)-[:PROCESS]->(invariant)
(invariant)-[:PROCESS { strategy: 'verify-positive' }]->(result)
(result)-[:MEASURE { reason: 'topology-audit' }]->(deficit_collision_gg_trace:Trace)
