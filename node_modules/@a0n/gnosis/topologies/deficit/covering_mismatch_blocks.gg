// covering_mismatch_blocks.gg — THM-COVERING-SPACE-CAUSALITY witness (topology mismatch -> blocking)
//
// When the covering space topology does not match the base space,
// causal paths are blocked. A fiber mismatch at any sheet forces
// the lift to stall, producing nonzero blocking count.
// Example: base has 3 sheets, cover has 2 -> 1 blocked path.

(space: CoveringSpace { theorem: 'THM-COVERING-SPACE-CAUSALITY', base_sheets: '3', cover_sheets: '2' })
(sheet_a: Sheet { id: 'a', matched: 'true' })
(sheet_b: Sheet { id: 'b', matched: 'true' })
(sheet_c: Sheet { id: 'c', matched: 'false' })
(blocked: BlockedPath { sheet: 'c', reason: 'no-covering-fiber' })
(invariant: Invariant { claim: 'mismatch_implies_blocking', blocked_count: '1' })
(result: Result { theorem: 'topology-mismatch-blocks' })

(space)-[:FORK]->(sheet_a | sheet_b | sheet_c)
(sheet_c)-[:VENT { condition: 'fiber-mismatch' }]->(blocked)
(sheet_a | sheet_b)-[:RACE { expect: 'lifted' }]->(lifted: LiftResult)
(blocked)-[:PROCESS]->(invariant)
(invariant)-[:PROCESS { strategy: 'verify-positive' }]->(result)
(result)-[:MEASURE { reason: 'topology-audit' }]->(covering_mismatch_blocks_gg_trace:Trace)
