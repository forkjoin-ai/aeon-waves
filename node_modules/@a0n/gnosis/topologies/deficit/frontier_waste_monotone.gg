// frontier_waste_monotone.gg — THM-AMERICAN-FRONTIER witness (more diversity implies less waste)
//
// As the diversity of the frontier increases toward the match point,
// waste decreases monotonically. Waste = max(0, match - diversity).
// Example: match=5, diversity=[2, 3, 4, 5] -> waste=[3, 2, 1, 0].

(frontier: AmericanFrontier { theorem: 'THM-AMERICAN-FRONTIER', match_point: '5' })
(diversity_2: DiversityLevel { diversity: '2', waste: '3' })
(diversity_3: DiversityLevel { diversity: '3', waste: '2' })
(diversity_4: DiversityLevel { diversity: '4', waste: '1' })
(diversity_5: DiversityLevel { diversity: '5', waste: '0' })
(monotone: Invariant { claim: 'waste decreases as diversity increases', waste_sequence: '[3, 2, 1, 0]' })
(result: Result { theorem: 'waste-monotone-decreasing' })

(frontier)-[:FORK]->(diversity_2 | diversity_3 | diversity_4 | diversity_5)
(diversity_2 | diversity_3 | diversity_4 | diversity_5)-[:RACE { expect: 'non-increasing-waste' }]->(monotone)
(monotone)-[:PROCESS { strategy: 'verify-ordering' }]->(result)
(result)-[:MEASURE { reason: 'topology-audit' }]->(frontier_waste_monotone_gg_trace:Trace)
