// deficit_matched_zero.gg — THM-DEFICIT-CAPACITY witness (matched streams -> zero deficit)
//
// When the number of streams equals the number of paths, every path
// gets a unique stream and the deficit is exactly zero.
// Example: 4 paths, 4 streams -> deficit = 0, all matched.

(capacity: DeficitCapacity { theorem: 'THM-DEFICIT-CAPACITY', paths: '4', streams: '4' })
(path_1: Path { id: '1', stream: '1' })
(path_2: Path { id: '2', stream: '2' })
(path_3: Path { id: '3', stream: '3' })
(path_4: Path { id: '4', stream: '4' })
(matched: MatchResult { all_matched: 'true', deficit: '0' })
(invariant: Invariant { claim: 'matched_streams_zero_deficit', deficit: '0' })
(result: Result { theorem: 'matched-zero-deficit' })

(capacity)-[:FORK]->(path_1 | path_2 | path_3 | path_4)
(path_1 | path_2 | path_3 | path_4)-[:RACE { expect: 'all-matched' }]->(matched)
(matched)-[:PROCESS]->(invariant)
(invariant)-[:PROCESS { strategy: 'verify-zero' }]->(result)
(result)-[:MEASURE { reason: 'topology-audit' }]->(deficit_matched_zero_gg_trace:Trace)
