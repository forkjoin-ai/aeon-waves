// frontier_zero_at_match.gg — THM-AMERICAN-FRONTIER witness (matched diversity implies zero waste)
//
// When the frontier diversity exactly matches the required diversity,
// waste is zero. No resources are wasted on redundant or missing branches.
// Example: match=4, diversity=4 -> waste = max(0, 4-4) = 0.

(frontier: AmericanFrontier { theorem: 'THM-AMERICAN-FRONTIER', match_point: '4' })
(supply: DiversityLevel { diversity: '4', required: '4' })
(waste: WasteMeasure { value: '0', formula: 'max(0, 4 - 4)' })
(zero_check: Invariant { claim: 'matched diversity implies zero waste', diversity: '4', match: '4', waste: '0' })
(result: Result { theorem: 'zero-waste-at-match' })

(frontier)-[:PROCESS]->(supply)
(supply)-[:PROCESS]->(waste)
(waste)-[:PROCESS { expect: 'waste-is-zero' }]->(zero_check)
(zero_check)-[:PROCESS { strategy: 'verify-zero' }]->(result)
