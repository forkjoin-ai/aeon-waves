// deficit_capacity.test.gg — Native Gnosis witnesses for THM-DEFICIT-CAPACITY
//
// These theorem-shaped `.gg` modules cover:
//   - paths exceeding streams causes collision (collision)
//   - more streams reduces deficit (decreasing_streams)
//   - matched streams yield zero deficit (matched_zero)

(test_suite: TestSuite { name: 'deficit-capacity' })

(collision: Verify { module: './deficit_collision.gg', beta1_max: '6' })
(decreasing_streams: Verify { module: './deficit_decreasing_streams.gg', beta1_max: '6' })
(matched_zero: Verify { module: './deficit_matched_zero.gg', beta1_max: '6' })

(test_suite)-[:FORK]->(collision | decreasing_streams | matched_zero)

(collision)-[:RACE { expect: 'safe' }]->(collision_result: Result)
(decreasing_streams)-[:RACE { expect: 'safe' }]->(streams_result: Result)
(matched_zero)-[:RACE { expect: 'safe' }]->(matched_result: Result)

(collision_result | streams_result | matched_result)-[:FOLD { strategy: 'all-pass' }]->(verdict: Verdict)
(verdict)-[:TUNNEL { condition: 'bounded-reject' }]->(deficit_capacity_test_gg_trace:Trace)
(verdict)-[:MEASURE { reason: 'topology-audit' }]->(deficit_capacity_test_gg_trace:Trace)
