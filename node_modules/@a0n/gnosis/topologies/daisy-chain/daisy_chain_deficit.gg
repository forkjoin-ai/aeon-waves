// daisy_chain_deficit.gg — THM-DAISY-CHAIN-MOA witness (ensemble deficit = k-1)
//
// An ensemble of k agents selects one winner and vents k-1 losers.
// The ensemble deficit (wasted computation) is exactly k-1.
// This is the minimum possible deficit for a k-way fork that
// produces a single output.
// Example: k=4 agents, 1 winner, deficit = 3 = k-1.

(ensemble: DaisyChainMoA { theorem: 'THM-DAISY-CHAIN-MOA', agents: '4' })
(agent_1: Agent { id: '1', selected: 'false' })
(agent_2: Agent { id: '2', selected: 'true' })
(agent_3: Agent { id: '3', selected: 'false' })
(agent_4: Agent { id: '4', selected: 'false' })
(winner: Winner { agent: '2' })
(deficit: Deficit { vented: '3', k_minus_1: '3' })
(invariant: Invariant { claim: 'ensemble_deficit_equals_k_minus_1', deficit: '3', k: '4' })
(result: Result { theorem: 'ensemble-deficit-k-minus-1' })

(ensemble)-[:FORK]->(agent_1 | agent_2 | agent_3 | agent_4)
(agent_1 | agent_2 | agent_3 | agent_4)-[:RACE { expect: 'one-winner' }]->(winner)
(agent_1)-[:VENT { condition: 'not-selected' }]->(vent_1: VentedPath)
(agent_3)-[:VENT { condition: 'not-selected' }]->(vent_3: VentedPath)
(agent_4)-[:VENT { condition: 'not-selected' }]->(vent_4: VentedPath)
(vent_1 | vent_3 | vent_4)-[:FOLD { strategy: 'count-vented' }]->(deficit)
(deficit)-[:PROCESS]->(invariant)
(invariant)-[:PROCESS]->(result)
(result)-[:MEASURE { reason: 'topology-audit' }]->(daisy_chain_deficit_gg_trace:Trace)
