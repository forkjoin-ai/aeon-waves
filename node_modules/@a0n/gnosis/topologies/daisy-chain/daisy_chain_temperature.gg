// daisy_chain_temperature.gg — THM-DAISY-CHAIN-MOA witness (temperature ensemble as fork/race/fold)
//
// A temperature ensemble forks k agents at different temperatures,
// races them to produce outputs, and folds with complement voting.
// The ensemble structure is isomorphic to fork/race/fold.
// Example: k=3 agents at temps [0.3, 0.7, 1.0] -> fork 3, race, fold.

(ensemble: DaisyChainMoA { theorem: 'THM-DAISY-CHAIN-MOA', agents: '3' })
(agent_cold: Agent { id: 'cold', temperature: '0.3', output: 'precise' })
(agent_warm: Agent { id: 'warm', temperature: '0.7', output: 'balanced' })
(agent_hot: Agent { id: 'hot', temperature: '1.0', output: 'creative' })
(raced: RaceResult { outputs: '[precise, balanced, creative]', count: '3' })
(invariant: Invariant { claim: 'ensemble_is_fork_race_fold', fork_width: '3', raced: '3' })
(result: Result { theorem: 'temperature-ensemble-frf' })

(ensemble)-[:FORK]->(agent_cold | agent_warm | agent_hot)
(agent_cold | agent_warm | agent_hot)-[:RACE { expect: 'all-complete' }]->(raced)
(raced)-[:PROCESS]->(invariant)
(invariant)-[:PROCESS { strategy: 'verify-equality' }]->(result)
(result)-[:MEASURE { reason: 'topology-audit' }]->(daisy_chain_temperature_gg_trace:Trace)
