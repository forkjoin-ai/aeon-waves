// daisy_chain_moa.test.gg — Native Gnosis witnesses for THM-DAISY-CHAIN-MOA
//
// These theorem-shaped `.gg` modules cover:
//   - temperature ensemble as fork/race/fold (temperature)
//   - complement voting selects best (voting)
//   - ensemble deficit equals k-1 (deficit)

(test_suite: TestSuite { name: 'daisy-chain-moa' })

(temperature: Verify { module: './daisy_chain_temperature.gg', beta1_max: '6' })
(voting: Verify { module: './daisy_chain_voting.gg', beta1_max: '6' })
(deficit: Verify { module: './daisy_chain_deficit.gg', beta1_max: '6' })

(test_suite)-[:FORK]->(temperature | voting | deficit)

(temperature)-[:RACE { expect: 'safe' }]->(temp_result: Result)
(voting)-[:RACE { expect: 'safe' }]->(voting_result: Result)
(deficit)-[:RACE { expect: 'safe' }]->(deficit_result: Result)

(temp_result | voting_result | deficit_result)-[:FOLD { strategy: 'all-pass' }]->(verdict: Verdict)
(verdict)-[:TUNNEL { condition: 'bounded-reject' }]->(daisy_chain_moa_test_gg_trace:Trace)
(verdict)-[:MEASURE { reason: 'topology-audit' }]->(daisy_chain_moa_test_gg_trace:Trace)
