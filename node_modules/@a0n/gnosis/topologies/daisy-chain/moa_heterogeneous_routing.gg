// moa_heterogeneous_routing.gg — THM-HETERO-MOA-FABRIC witness (different backends -> routing diversity)
//
// A mixture-of-agents fabric with heterogeneous backends produces
// diverse routing paths. Each backend type contributes a distinct
// routing strategy, and the union covers more of the input space.
// Example: 3 backends (fast, accurate, cheap) -> 3 distinct routes.

(fabric: MoAFabric { theorem: 'THM-HETERO-MOA-FABRIC', backends: '3' })
(backend_fast: Backend { id: 'fast', latency: '1', accuracy: '0.7' })
(backend_accurate: Backend { id: 'accurate', latency: '5', accuracy: '0.99' })
(backend_cheap: Backend { id: 'cheap', latency: '3', accuracy: '0.85' })
(routes: RoutingTable { distinct_routes: '3', coverage: '0.95' })
(invariant: Invariant { claim: 'hetero_backends_diverse_routes', routes: '3', backends: '3' })
(result: Result { theorem: 'heterogeneous-routing-diversity' })

(fabric)-[:FORK]->(backend_fast | backend_accurate | backend_cheap)
(backend_fast | backend_accurate | backend_cheap)-[:RACE { expect: 'diverse-routes' }]->(routes)
(routes)-[:PROCESS]->(invariant)
(invariant)-[:PROCESS { strategy: 'verify-positive' }]->(result)
(result)-[:MEASURE { reason: 'topology-audit' }]->(moa_heterogeneous_routing_gg_trace:Trace)
