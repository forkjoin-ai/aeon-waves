// hetero_moa_fabric.test.gg — Native Gnosis witnesses for THM-HETERO-MOA-FABRIC
//
// These theorem-shaped `.gg` modules cover:
//   - different backends produce routing diversity (heterogeneous_routing)
//   - acyclic fabric has spectral stability (nilpotent_spectral)
//   - mirrored kernels inherit stability (mirrored_pair)

(test_suite: TestSuite { name: 'hetero-moa-fabric' })

(heterogeneous_routing: Verify { module: './moa_heterogeneous_routing.gg', beta1_max: '6' })
(nilpotent_spectral: Verify { module: './moa_nilpotent_spectral.gg', beta1_max: '6' })
(mirrored_pair: Verify { module: './moa_mirrored_pair.gg', beta1_max: '6' })

(test_suite)-[:FORK]->(heterogeneous_routing | nilpotent_spectral | mirrored_pair)

(heterogeneous_routing)-[:RACE { expect: 'safe' }]->(routing_result: Result)
(nilpotent_spectral)-[:RACE { expect: 'safe' }]->(spectral_result: Result)
(mirrored_pair)-[:RACE { expect: 'safe' }]->(mirror_result: Result)

(routing_result | spectral_result | mirror_result)-[:FOLD { strategy: 'all-pass' }]->(verdict: Verdict)
(verdict)-[:TUNNEL { condition: 'bounded-reject' }]->(hetero_moa_fabric_test_gg_trace:Trace)
(verdict)-[:MEASURE { reason: 'topology-audit' }]->(hetero_moa_fabric_test_gg_trace:Trace)
