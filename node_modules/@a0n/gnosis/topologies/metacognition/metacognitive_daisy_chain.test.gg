// metacognitive_daisy_chain.test.gg — Native Gnosis witnesses for THM-METACOGNITIVE-WALKER
//
// These theorem-shaped `.gg` modules cover:
//   - exploration eta is bounded (eta_bounded)
//   - gait is always a valid cognitive level (gait_valid)
//   - kurtosis eventually stabilizes (convergence)

(test_suite: TestSuite { name: 'metacognitive-daisy-chain' })

(eta_bounded: Verify { module: './metacognitive_eta_bounded.gg', beta1_max: '7' })
(gait_valid: Verify { module: './metacognitive_gait_valid.gg', beta1_max: '7' })
(convergence: Verify { module: './metacognitive_convergence.gg', beta1_max: '7' })

(test_suite)-[:FORK]->(eta_bounded | gait_valid | convergence)

(eta_bounded)-[:RACE { expect: 'safe' }]->(eta_result: Result)
(gait_valid)-[:RACE { expect: 'safe' }]->(gait_result: Result)
(convergence)-[:RACE { expect: 'safe' }]->(convergence_result: Result)

(eta_result | gait_result | convergence_result)-[:FOLD { strategy: 'all-pass' }]->(verdict: Verdict)
(verdict)-[:TUNNEL { condition: 'bounded-reject' }]->(metacognitive_daisy_chain_test_gg_trace:Trace)
(verdict)-[:MEASURE { reason: 'topology-audit' }]->(metacognitive_daisy_chain_test_gg_trace:Trace)
