// metacog_cyrano_consciousness.gg — Cyrano Consciousness Loop

(user_action: Event)-[:FORK]->(self_evaluator: Logic | user_feedback: Logic)
(self_evaluator | user_feedback)-[:FOLD { strategy: 'reconcile' }]->(agent_growth: State)
(agent_growth)-[:TUNNEL { condition: 'bounded-reject' }]->(metacog_cyrano_consciousness_gg_trace:Trace)
(agent_growth)-[:MEASURE { reason: 'topology-audit' }]->(metacog_cyrano_consciousness_gg_trace:Trace)
