// race_winner.test.gg — Native Gnosis witnesses for THM-RACE-WINNER-CORRECTNESS
//
// These theorem-shaped `.gg` modules cover:
//   - winner has a valid result (winner_valid)
//   - winner completes no later than others (winner_minimal)
//   - venting non-winner preserves winner (winner_isolation)

(test_suite: TestSuite { name: 'race-winner-correctness' })

(winner_valid: Verify { module: './race_winner_valid.gg', beta1_max: '5' })
(winner_minimal: Verify { module: './race_winner_minimal.gg', beta1_max: '5' })
(winner_isolation: Verify { module: './race_winner_isolation.gg', beta1_max: '5' })

(test_suite)-[:FORK]->(winner_valid | winner_minimal | winner_isolation)

(winner_valid)-[:RACE { expect: 'safe' }]->(valid_result: Result)
(winner_minimal)-[:RACE { expect: 'safe' }]->(minimal_result: Result)
(winner_isolation)-[:RACE { expect: 'safe' }]->(isolation_result: Result)

(valid_result | minimal_result | isolation_result)-[:FOLD { strategy: 'all-pass' }]->(verdict: Verdict)
(verdict)-[:TUNNEL { condition: 'bounded-reject' }]->(race_winner_test_gg_trace:Trace)
(verdict)-[:MEASURE { reason: 'topology-audit' }]->(race_winner_test_gg_trace:Trace)
