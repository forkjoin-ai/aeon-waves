// diversity_optimality_matched.gg — THM-DIVERSITY-OPTIMALITY witness (matched = zero deficit)
//
// When the number of branches exactly equals beta1, the deficit is zero.
// Every hole has exactly one branch covering it. No redundancy, no collision.
// This is the optimal configuration: minimum branches for maximum coverage.

(space: DiversitySpace { theorem: 'THM-DIVERSITY-OPTIMALITY', beta1: '4', rounds: '12' })
(branch_1: Branch { id: '1', covers_hole: '1', void_count: '3', weight: '10' })
(branch_2: Branch { id: '2', covers_hole: '2', void_count: '5', weight: '8' })
(branch_3: Branch { id: '3', covers_hole: '3', void_count: '7', weight: '6' })
(branch_4: Branch { id: '4', covers_hole: '4', void_count: '9', weight: '4' })
(optimality: Invariant { claim: 'branches == beta1 => deficit == 0', branches: '4', beta1: '4', deficit: '0' })
(result: Result { theorem: 'matched-is-zero-deficit' })

(space)-[:FORK]->(branch_1 | branch_2 | branch_3 | branch_4)
(branch_1 | branch_2 | branch_3 | branch_4)-[:RACE { expect: 'all-holes-covered' }]->(optimality)
(optimality)-[:PROCESS { strategy: 'verify-zero-deficit' }]->(result)
(result)-[:MEASURE { reason: 'topology-audit' }]->(diversity_optimality_matched_gg_trace:Trace)
