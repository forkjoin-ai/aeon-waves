// race_winner_isolation.gg — THM-RACE-WINNER-CORRECTNESS witness (venting non-winner preserves winner)
//
// After the race, venting (cancelling) non-winning branches does not
// affect the winner's result. The winner is isolated from losers.
// Example: winner B, vent A and C -> B's output unchanged.

(race: Race { theorem: 'THM-RACE-WINNER-CORRECTNESS', racers: '3' })
(racer_a: Racer { id: 'A', finish_time: '5' })
(racer_b: Racer { id: 'B', finish_time: '2', output: 'result-42' })
(racer_c: Racer { id: 'C', finish_time: '7' })
(winner: Winner { racer: 'B', output: 'result-42' })
(result: Result { theorem: 'vent-preserves-winner' })

(race)-[:FORK]->(racer_a | racer_b | racer_c)
(racer_a | racer_b | racer_c)-[:RACE { expect: 'first-wins' }]->(winner)
(racer_a)-[:VENT { condition: 'non-winner' }]->(vent_a: VentedPath)
(racer_c)-[:VENT { condition: 'non-winner' }]->(vent_c: VentedPath)
(winner | vent_a | vent_c)-[:FOLD { strategy: 'winner-unchanged' }]->(isolated: Invariant { claim: 'winner_isolated', output: 'result-42' })
(isolated)-[:PROCESS]->(result)
(result)-[:MEASURE { reason: 'topology-audit' }]->(race_winner_isolation_gg_trace:Trace)
