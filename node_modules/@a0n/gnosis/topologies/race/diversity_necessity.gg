// diversity_necessity.gg — THM-DIVERSITY-OPTIMALITY witness (reducing below beta1 forces collision)
//
// If the number of surviving branches drops below beta1 (the number of
// topological holes), at least two branches must share a hole.
// This forces a collision in the fold, destroying information.

(space: DiversitySpace { theorem: 'THM-DIVERSITY-OPTIMALITY', beta1: '3', rounds: '10' })
(config_sufficient: ForkConfig { branches: '5', surviving: '4', collisions: '0', deficit: '0' })
(config_matched: ForkConfig { branches: '3', surviving: '3', collisions: '0', deficit: '0' })
(config_deficient: ForkConfig { branches: '2', surviving: '2', collisions: '1', deficit: '1' })
(config_minimal: ForkConfig { branches: '1', surviving: '1', collisions: '2', deficit: '2' })
(necessity: Invariant { claim: 'branches < beta1 forces collisions', threshold: '3' })
(result: Result { theorem: 'reducing-below-beta1-forces-collision' })

(space)-[:FORK]->(config_sufficient | config_matched | config_deficient | config_minimal)
(config_deficient)-[:VENT { condition: 'collision-forced' }]->(collision_1: VentedInformation)
(config_minimal)-[:VENT { condition: 'collision-forced' }]->(collision_2: VentedInformation)
(config_sufficient | config_matched | config_deficient | config_minimal)-[:RACE { expect: 'deficit-computed' }]->(necessity)
(necessity)-[:PROCESS { strategy: 'verify-threshold' }]->(result)
(result)-[:MEASURE { reason: 'topology-audit' }]->(diversity_necessity_gg_trace:Trace)
