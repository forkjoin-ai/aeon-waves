// codec_race_monotone.gg — THM-CODEC-RACING witness (adding codecs never increases wire size)
//
// Racing over {A, B} produces total T_2. Adding codec C gives racing over
// {A, B, C} with total T_3 <= T_2. More codecs can only help.
// Example: race({A,B}) = [3,2,2] = 7. C has sizes [1,5,3].
// race({A,B,C}) = [1,2,2] = 5 <= 7.

(race_2: CodecRace { theorem: 'THM-CODEC-RACING', codecs: '2', total: '7' })
(codec_c: Codec { id: 'C', sizes: '[1, 5, 3]', total: '9' })
(race_3: CodecRace { codecs: '3', total: '5' })
(monotonicity: Invariant { claim: 'race_3_total <= race_2_total', race_2: '7', race_3: '5' })
(result: Result { theorem: 'codec-race-monotone' })

(race_2)-[:PROCESS]->(codec_c)
(codec_c)-[:PROCESS { expect: 'wire-size-reduced' }]->(race_3)
(race_2 | race_3)-[:RACE { expect: 'monotone-decreasing' }]->(monotonicity)
(monotonicity)-[:PROCESS { strategy: 'verify-inequality' }]->(result)
(result)-[:MEASURE { reason: 'topology-audit' }]->(codec_race_monotone_gg_trace:Trace)
