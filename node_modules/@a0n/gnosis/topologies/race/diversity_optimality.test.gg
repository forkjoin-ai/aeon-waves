// diversity_optimality.test.gg — Native Gnosis witnesses for THM-DIVERSITY-OPTIMALITY
//
// These theorem-shaped `.gg` modules cover:
//   - more branches never hurt (monotone)
//   - diversity contains monoculture (subsumption)
//   - reducing below beta1 forces collision (necessity)
//   - matched = zero deficit (optimality matched)

(test_suite: TestSuite { name: 'diversity-optimality' })

(monotone: Verify { module: './diversity_monotone.gg', beta1_max: '6' })
(subsumption: Verify { module: './diversity_subsumption.gg', beta1_max: '6' })
(necessity: Verify { module: './diversity_necessity.gg', beta1_max: '6' })
(optimality_matched: Verify { module: './diversity_optimality_matched.gg', beta1_max: '6' })

(test_suite)-[:FORK]->(monotone | subsumption | necessity | optimality_matched)

(monotone)-[:RACE { expect: 'safe' }]->(mono_result: Result)
(subsumption)-[:RACE { expect: 'safe' }]->(sub_result: Result)
(necessity)-[:RACE { expect: 'safe' }]->(nec_result: Result)
(optimality_matched)-[:RACE { expect: 'safe' }]->(opt_result: Result)

(mono_result | sub_result | nec_result | opt_result)-[:FOLD { strategy: 'all-pass' }]->(verdict: Verdict)
(verdict)-[:TUNNEL { condition: 'bounded-reject' }]->(diversity_optimality_test_gg_trace:Trace)
(verdict)-[:MEASURE { reason: 'topology-audit' }]->(diversity_optimality_test_gg_trace:Trace)
