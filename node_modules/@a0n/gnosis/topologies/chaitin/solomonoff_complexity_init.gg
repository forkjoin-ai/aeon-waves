// solomonoff_complexity_init.gg — THM-SOLOMONOFF-BULEYEAN witness (complexity = initial void boundary)
//
// Kolmogorov complexity K(x) maps to the initial void boundary:
// a program of length L starts with L bits already "rejected" from the
// space of all possible programs. The initial void count formalizes the complexity.

(space: SolomonoffSpace { theorem: 'THM-SOLOMONOFF-BULEYEAN', max_length: '8' })
(simple: Hypothesis { description: 'short program', length: '2', initial_void: '2', weight: '7' })
(medium: Hypothesis { description: 'medium program', length: '5', initial_void: '5', weight: '4' })
(complex: Hypothesis { description: 'long program', length: '8', initial_void: '8', weight: '1' })
(mapping: Invariant { claim: 'K(x) = initial void count', lengths: '[2, 5, 8]', voids: '[2, 5, 8]' })
(result: Result { theorem: 'complexity-is-initial-boundary' })

(space)-[:FORK]->(simple | medium | complex)
(simple | medium | complex)-[:RACE { expect: 'void-equals-length' }]->(mapping)
(mapping)-[:PROCESS { strategy: 'verify-equality' }]->(result)
(result)-[:MEASURE { reason: 'topology-audit' }]->(solomonoff_complexity_init_gg_trace:Trace)
