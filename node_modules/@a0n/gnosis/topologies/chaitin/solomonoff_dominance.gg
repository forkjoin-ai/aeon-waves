// solomonoff_dominance.gg — THM-SOLOMONOFF-BULEYEAN witness (informed > uniform)
//
// A Solomonoff-weighted predictor (complexity-aware) assigns more mass
// to the true hypothesis than a uniform prior. After observing data,
// the informed predictor's entropy is strictly lower.

(space: SolomonoffSpace { theorem: 'THM-SOLOMONOFF-BULEYEAN', hypotheses: '4', rounds: '10' })
(informed: Predictor { type: 'solomonoff', weights: '[9, 7, 3, 1]', entropy: '1.58' })
(uniform: Predictor { type: 'uniform', weights: '[5, 5, 5, 5]', entropy: '2.00' })
(gap: Invariant { claim: 'entropy_solomonoff < entropy_uniform', difference: '0.42' })
(result: Result { theorem: 'informed-dominates-uniform' })

(space)-[:FORK]->(informed | uniform)
(informed | uniform)-[:RACE { expect: 'informed-lower-entropy' }]->(gap)
(gap)-[:PROCESS { strategy: 'verify-inequality' }]->(result)
(result)-[:MEASURE { reason: 'topology-audit' }]->(solomonoff_dominance_gg_trace:Trace)
