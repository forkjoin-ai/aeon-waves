// solomonoff_buleyean.test.gg — Native Gnosis witnesses for THM-SOLOMONOFF-BULEYEAN
//
// These theorem-shaped `.gg` modules cover:
//   - complexity = initial void boundary (complexity init)
//   - simpler = heavier (concentration)
//   - informed > uniform (dominance)
//   - data dominates prior (washout)

(test_suite: TestSuite { name: 'solomonoff-buleyean' })

(complexity_init: Verify { module: './solomonoff_complexity_init.gg', beta1_max: '6' })
(concentration: Verify { module: './solomonoff_concentration.gg', beta1_max: '6' })
(dominance: Verify { module: './solomonoff_dominance.gg', beta1_max: '6' })
(washout: Verify { module: './solomonoff_washout.gg', beta1_max: '6' })

(test_suite)-[:FORK]->(complexity_init | concentration | dominance | washout)

(complexity_init)-[:RACE { expect: 'safe' }]->(init_result: Result)
(concentration)-[:RACE { expect: 'safe' }]->(conc_result: Result)
(dominance)-[:RACE { expect: 'safe' }]->(dom_result: Result)
(washout)-[:RACE { expect: 'safe' }]->(wash_result: Result)

(init_result | conc_result | dom_result | wash_result)-[:FOLD { strategy: 'all-pass' }]->(verdict: Verdict)
(verdict)-[:TUNNEL { condition: 'bounded-reject' }]->(solomonoff_buleyean_test_gg_trace:Trace)
(verdict)-[:MEASURE { reason: 'topology-audit' }]->(solomonoff_buleyean_test_gg_trace:Trace)
