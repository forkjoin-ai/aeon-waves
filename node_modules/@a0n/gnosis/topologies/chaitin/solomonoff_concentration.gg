// solomonoff_concentration.gg — THM-SOLOMONOFF-BULEYEAN witness (simpler = heavier)
//
// Shorter programs have lower initial void counts and therefore higher
// Buleyean weight. This is Occam's razor as a theorem: simplicity
// concentrates probability mass.

(space: SolomonoffSpace { theorem: 'THM-SOLOMONOFF-BULEYEAN', rounds: '8' })
(hyp_1bit: Hypothesis { length: '1', void_count: '1', weight: '8' })
(hyp_3bit: Hypothesis { length: '3', void_count: '3', weight: '6' })
(hyp_5bit: Hypothesis { length: '5', void_count: '5', weight: '4' })
(hyp_8bit: Hypothesis { length: '8', void_count: '8', weight: '1' })
(ordering: Invariant { claim: 'shorter => heavier', weights: '[8, 6, 4, 1]' })
(result: Result { theorem: 'simpler-is-heavier' })

(space)-[:FORK]->(hyp_1bit | hyp_3bit | hyp_5bit | hyp_8bit)
(hyp_1bit | hyp_3bit | hyp_5bit | hyp_8bit)-[:RACE { expect: 'ordered-by-length' }]->(ordering)
(ordering)-[:PROCESS { strategy: 'verify-ordering' }]->(result)
(result)-[:MEASURE { reason: 'topology-audit' }]->(solomonoff_concentration_gg_trace:Trace)
