// traced_yanking.gg — THM-TRACED-MONOIDAL witness (swap trace = identity)
//
// The yanking axiom: tracing the swap morphism sigma_{X,X} : X*X -> X*X
// over X yields the identity on X. A feedback loop through a swap
// straightens out to the identity wire.

(trace_op: TraceOperator { theorem: 'THM-TRACED-MONOIDAL', axiom: 'yanking', trace_dim: '3' })
(swap: Morphism { id: 'sigma_X_X', domain: 'X*X', codomain: 'X*X', dim_X: '3' })
(input_vector: Vector { values: '[7, 11, 13]', dim: '3' })
(trace_result: Morphism { id: 'Tr_X(sigma)', domain: 'X', codomain: 'X', dim: '3' })
(identity: Morphism { id: 'id_X', domain: 'X', codomain: 'X', dim: '3' })
(output_vector: Vector { values: '[7, 11, 13]', dim: '3' })
(yanking: Invariant { claim: 'Tr_X(sigma_{X,X}) = id_X', input: '[7, 11, 13]', output: '[7, 11, 13]' })
(result: Result { theorem: 'yanking-axiom-holds' })

(trace_op)-[:PROCESS]->(swap)
(swap)-[:PROCESS { strategy: 'trace-over-X' }]->(trace_result)
(input_vector)-[:PROCESS]->(identity)
(trace_result | identity)-[:RACE { expect: 'morphisms-equal' }]->(yanking)
(yanking)-[:PROCESS { strategy: 'verify-equality' }]->(result)
(result)-[:MEASURE { reason: 'topology-audit' }]->(traced_yanking_gg_trace:Trace)
