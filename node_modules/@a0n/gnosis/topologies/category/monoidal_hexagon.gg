// monoidal_hexagon.gg — THM-MONOIDAL-COHERENCE witness (braiding commutes with associator)
//
// The hexagon identity: for objects A, B, C, the braiding sigma and
// associator alpha satisfy the hexagon axiom. Two paths around the
// hexagon from (A*B)*C to B*(A*C) must agree.
// Path 1: (A*B)*C -> A*(B*C) -> (B*C)*A -> B*(C*A)
// Path 2: (A*B)*C -> (B*A)*C -> B*(A*C) -> B*(C*A)

(coherence: MonoidalCoherence { theorem: 'THM-MONOIDAL-COHERENCE', identity: 'hexagon' })
(start: TensorProduct { shape: '(A*B)*C', id: 'start' })
(path_1_a: TensorProduct { shape: 'A*(B*C)', via: 'alpha' })
(path_1_b: TensorProduct { shape: '(B*C)*A', via: 'sigma_A_BC' })
(path_1_c: TensorProduct { shape: 'B*(C*A)', via: 'alpha_inv' })
(path_2_a: TensorProduct { shape: '(B*A)*C', via: 'sigma_A_B_tensor_id' })
(path_2_b: TensorProduct { shape: 'B*(A*C)', via: 'alpha' })
(path_2_c: TensorProduct { shape: 'B*(C*A)', via: 'id_tensor_sigma_A_C' })
(agreement: Invariant { claim: 'path_1 == path_2 at B*(C*A)', target: 'B*(C*A)' })
(result: Result { theorem: 'hexagon-identity-holds' })

(coherence)-[:PROCESS]->(start)
(start)-[:FORK]->(path_1_a | path_2_a)
(path_1_a)-[:PROCESS]->(path_1_b)
(path_1_b)-[:PROCESS]->(path_1_c)
(path_2_a)-[:PROCESS]->(path_2_b)
(path_2_b)-[:PROCESS]->(path_2_c)
(path_1_c | path_2_c)-[:FOLD { strategy: 'verify-equality' }]->(agreement)
(agreement)-[:PROCESS]->(result)
(result)-[:TUNNEL { condition: 'bounded-reject' }]->(monoidal_hexagon_gg_trace:Trace)
(result)-[:MEASURE { reason: 'topology-audit' }]->(monoidal_hexagon_gg_trace:Trace)
