// traced_superposing.gg — THM-TRACED-MONOIDAL witness (trace preserves parallel structure)
//
// The superposing axiom: for f: A*U -> B*U and g: C -> D,
// Tr_U(f tensor g) = Tr_U(f) tensor g.
// Tracing a feedback loop on one component does not affect a parallel component.

(trace_op: TraceOperator { theorem: 'THM-TRACED-MONOIDAL', axiom: 'superposing', trace_dim: '2' })
(morphism_f: Morphism { id: 'f', domain: 'A*U', codomain: 'B*U', dim_A: '3', dim_B: '4', dim_U: '2' })
(morphism_g: Morphism { id: 'g', domain: 'C', codomain: 'D', dim_C: '5', dim_D: '5' })
(parallel: Morphism { id: 'f_tensor_g', domain: '(A*U)*C', codomain: '(B*U)*D' })
(traced_parallel: Morphism { id: 'Tr_U(f_tensor_g)', domain: 'A*C', codomain: 'B*D' })
(traced_then_par: Morphism { id: 'Tr_U(f)_tensor_g', domain: 'A*C', codomain: 'B*D' })
(superposing: Invariant { claim: 'Tr_U(f tensor g) = Tr_U(f) tensor g' })
(result: Result { theorem: 'superposing-axiom-holds' })

(trace_op)-[:FORK]->(morphism_f | morphism_g)
(morphism_f | morphism_g)-[:FOLD { strategy: 'tensor-product' }]->(parallel)
(parallel)-[:PROCESS { strategy: 'trace-over-U' }]->(traced_parallel)
(morphism_f)-[:PROCESS { strategy: 'trace-over-U' }]->(traced_then_par)
(traced_parallel | traced_then_par)-[:RACE { expect: 'morphisms-equal' }]->(superposing)
(superposing)-[:PROCESS { strategy: 'verify-equality' }]->(result)
(result)-[:TUNNEL { condition: 'bounded-reject' }]->(traced_superposing_gg_trace:Trace)
(result)-[:MEASURE { reason: 'topology-audit' }]->(traced_superposing_gg_trace:Trace)
