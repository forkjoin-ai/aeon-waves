// monoidal_pentagon.gg — THM-MONOIDAL-COHERENCE witness (two associator paths agree)
//
// The pentagon identity: for four objects A, B, C, D, the two ways of
// re-associating ((A*B)*C)*D to A*(B*(C*D)) via the associator give
// the same result. This is the fundamental coherence condition.
// Path 1: ((AB)C)D -> (AB)(CD) -> A(B(CD))
// Path 2: ((AB)C)D -> (A(BC))D -> A((BC)D) -> A(B(CD))

(coherence: MonoidalCoherence { theorem: 'THM-MONOIDAL-COHERENCE', objects: '4', identity: 'pentagon' })
(start: TensorProduct { shape: '((A*B)*C)*D', id: 'start' })
(path_1_step_1: TensorProduct { shape: '(A*B)*(C*D)', via: 'alpha_AB_C_D' })
(path_1_step_2: TensorProduct { shape: 'A*(B*(C*D))', via: 'alpha_A_B_CD' })
(path_2_step_1: TensorProduct { shape: '(A*(B*C))*D', via: 'alpha_A_BC_id' })
(path_2_step_2: TensorProduct { shape: 'A*((B*C)*D)', via: 'alpha_A_BC_D' })
(path_2_step_3: TensorProduct { shape: 'A*(B*(C*D))', via: 'id_alpha_B_C_D' })
(agreement: Invariant { claim: 'path_1 == path_2 at target', target: 'A*(B*(C*D))' })
(result: Result { theorem: 'pentagon-identity-holds' })

(coherence)-[:PROCESS]->(start)
(start)-[:FORK]->(path_1_step_1 | path_2_step_1)
(path_1_step_1)-[:PROCESS]->(path_1_step_2)
(path_2_step_1)-[:PROCESS]->(path_2_step_2)
(path_2_step_2)-[:PROCESS]->(path_2_step_3)
(path_1_step_2 | path_2_step_3)-[:FOLD { strategy: 'verify-equality' }]->(agreement)
(agreement)-[:PROCESS]->(result)
(result)-[:TUNNEL { condition: 'bounded-reject' }]->(monoidal_pentagon_gg_trace:Trace)
(result)-[:MEASURE { reason: 'topology-audit' }]->(monoidal_pentagon_gg_trace:Trace)
