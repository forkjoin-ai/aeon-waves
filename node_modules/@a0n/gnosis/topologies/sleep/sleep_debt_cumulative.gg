// sleep_debt_cumulative.gg — THM-SLEEP-DEBT witness (repeated truncation strictly increases debt)
//
// Each night of truncated recovery adds to the cumulative debt.
// The debt sequence is strictly increasing under repeated truncation.
// Example: 3 nights, deficit/night=2 -> debt=[2, 4, 6].

(system: RecoverySystem { theorem: 'THM-SLEEP-DEBT', nights: '3', deficit_per_night: '2' })
(night_1: RecoveryNight { id: '1', required: '8', actual: '6', nightly_deficit: '2', cumulative_debt: '2' })
(night_2: RecoveryNight { id: '2', required: '8', actual: '6', nightly_deficit: '2', cumulative_debt: '4' })
(night_3: RecoveryNight { id: '3', required: '8', actual: '6', nightly_deficit: '2', cumulative_debt: '6' })
(monotone: Invariant { claim: 'debt strictly increases under repeated truncation', debt_sequence: '[2, 4, 6]' })
(result: Result { theorem: 'cumulative-debt-strictly-increasing' })

(system)-[:PROCESS]->(night_1)
(night_1)-[:PROCESS]->(night_2)
(night_2)-[:PROCESS]->(night_3)
(night_1 | night_2 | night_3)-[:RACE { expect: 'strictly-increasing' }]->(monotone)
(monotone)-[:PROCESS { strategy: 'verify-ordering' }]->(result)
(result)-[:MEASURE { reason: 'topology-audit' }]->(sleep_debt_cumulative_gg_trace:Trace)
