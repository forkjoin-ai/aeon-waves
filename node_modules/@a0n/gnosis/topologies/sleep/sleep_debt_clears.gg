// sleep_debt_clears.gg — THM-SLEEP-DEBT witness (full recovery implies zero debt)
//
// When recovery meets or exceeds the required amount, debt is fully
// cleared. Debt = max(0, required - actual) = 0 when actual >= required.
// Example: required=8, actual=8 -> debt = max(0, 8-8) = 0.

(system: RecoverySystem { theorem: 'THM-SLEEP-DEBT', required_recovery: '8' })
(debt_before: DebtMeasure { value: '6', source: 'accumulated' })
(full_recovery: RecoveryActual { hours: '14', covers_debt: 'true' })
(debt_after: DebtMeasure { value: '0', formula: 'max(0, 6 - (14 - 8))' })
(cleared: Invariant { claim: 'full recovery zeroes debt', debt_before: '6', recovery_surplus: '6', debt_after: '0' })
(result: Result { theorem: 'full-recovery-clears-debt' })

(system)-[:FORK]->(debt_before | full_recovery)
(debt_before | full_recovery)-[:FOLD { strategy: 'apply-recovery' }]->(debt_after)
(debt_after)-[:PROCESS { expect: 'debt-is-zero' }]->(cleared)
(cleared)-[:PROCESS { strategy: 'verify-zero' }]->(result)
(result)-[:TUNNEL { condition: 'bounded-reject' }]->(sleep_debt_clears_gg_trace:Trace)
(result)-[:MEASURE { reason: 'topology-audit' }]->(sleep_debt_clears_gg_trace:Trace)
