// warmup_invert_structural_amortized.gg — Amortization decays into debt
//
// Inversion: the structure never finishes compacting, so each later read must
// merge fragments across too many runs instead of using one settled layout.

(write_stream: Stream { mode: 'append-only' })
(memtable: Buffer { level: 'L0' })
(run_a: Segment { level: 'spill-a' })
(run_b: Segment { level: 'spill-b' })
(compaction_backlog: Debt { level: 'high' })
(point_query: Query { key: 'emotion:grief' })
(probe_a: Probe { scope: 'spill-a' })
(probe_b: Probe { scope: 'spill-b' })
(probe_log: Probe { scope: 'memtable' })
(fragmented_answer: Candidate)
(delayed_answer: Result)

(write_stream)-[:PROCESS]->(memtable)
(memtable)-[:PROCESS]->(run_a)
(memtable)-[:PROCESS]->(run_b)
(point_query)-[:FORK]->(probe_a | probe_b | probe_log)
(run_a)-[:PROCESS]->(probe_a)
(run_b)-[:PROCESS]->(probe_b)
(memtable)-[:PROCESS]->(probe_log)
(probe_a | probe_b | probe_log)-[:FOLD { strategy: 'merge-fragments' }]->(fragmented_answer)
(fragmented_answer | compaction_backlog)-[:PROCESS { mode: 'destructive' }]->(delayed_answer)
(delayed_answer)-[:TUNNEL { condition: 'bounded-reject' }]->(warmup_invert_structural_amortized_gg_trace:Trace)
(delayed_answer)-[:MEASURE { reason: 'topology-audit' }]->(warmup_invert_structural_amortized_gg_trace:Trace)
