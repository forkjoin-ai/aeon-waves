// warmup_cache_reuse.gg — Exact reuse after the first request
//
// Warm-up mechanism: the first request pays to compute and store a result.
// Later requests collapse quickly because the exact artifact is reusable.

(request: Query { workload: 'emotion-lookup' })
(index_lookup: Cache { mode: 'lookup', artifact: 'ranked-result' })
(cold_compute: Compute { mode: 'embed-rank' })
(cache_write: Cache { mode: 'store', artifact: 'ranked-result' })

(request)-[:FORK]->(index_lookup | cold_compute)
(index_lookup | cold_compute)-[:RACE { expect: 'first-valid' }]->(answer: Result)
(answer)-[:PROCESS]->(cache_write)
(cache_write)-[:MEASURE { reason: 'topology-audit' }]->(warmup_cache_reuse_gg_trace:Trace)
