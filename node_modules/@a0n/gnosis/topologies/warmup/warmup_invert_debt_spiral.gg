// warmup_invert_debt_spiral.gg — Local rescue compounds into future debt
//
// Semantic void witness: the system keeps finding a serviceable fallback, but
// each rescue spends future slack and pushes the next request deeper into debt.

(request: Workload { shape: 'bursty' })
(warmed_plan: Plan { mode: 'optimistic' })
(stable_fallback: Plan { mode: 'safe' })
(repair_backlog: Debt { units: '1' })
(local_rescue: Candidate)
(next_cycle: Workload { inherited: 'true' })
(global_debt: Debt { units: 'compounding' })
(result: Result { quality: 'served-now-pay-later' })

(request)-[:FORK]->(warmed_plan | stable_fallback | repair_backlog)
(warmed_plan | stable_fallback)-[:PROCESS { expect: 'first-arrival' }]->(local_rescue)
(local_rescue | repair_backlog)-[:PROCESS { mode: 'destructive' }]->(global_debt)
(global_debt)-[:PROCESS]->(next_cycle)
(next_cycle | stable_fallback | repair_backlog)-[:FOLD { strategy: 'serve-now-pay-later' }]->(result)
(result)-[:TUNNEL { condition: 'bounded-reject' }]->(warmup_invert_debt_spiral_gg_trace:Trace)
(result)-[:MEASURE { reason: 'topology-audit' }]->(warmup_invert_debt_spiral_gg_trace:Trace)
