// warmup_physical_athletic_warmup.gg — Physical / Biological Warm-up: Athletic performance warm-up
//
// Classification: Physical / Biological Warm-up
//
// Models the structural flow where an initial input forks between a fast
// "warmed up" path and a slow fallback path.

(input: Workload { type: 'request' })
(fast_path: State { name: 'stiff_tissue' })
(slow_path: State { name: 'increased_blood_flow' })
(chosen_path: Plan)
(result: Result)

(input)-[:FORK]->(fast_path | slow_path)
(fast_path | slow_path)-[:RACE { expect: 'fastest-safe' }]->(chosen_path)
(chosen_path)-[:PROCESS]->(result)
(result)-[:MEASURE { reason: 'topology-audit' }]->(warmup_physical_athletic_warmup_gg_trace:Trace)
