// warmup_precompute_prefetch.gg — Stage work ahead of demand
//
// Warm-up mechanism: predict the next request, prefetch its parts, and race
// the warmed bundle against the cold origin fetch.

(nav_context: Session { route: '/journal' })
(route_predictor: Predictor { horizon: '1-hop' })
(css_prefetch: Fetch { asset: 'editor.css' })
(data_prefetch: Fetch { asset: 'emotion-wheel.json' })
(font_prefetch: Fetch { asset: 'editor.woff2' })
(warmed_bundle: Bundle { mode: 'prefetched' })
(route_request: Request { target: '/journal' })
(origin_fetch: Fetch { asset: 'journal-route' })

(nav_context)-[:PROCESS]->(route_predictor)
(route_predictor)-[:FORK]->(css_prefetch | data_prefetch | font_prefetch)
(css_prefetch | data_prefetch | font_prefetch)-[:FOLD { strategy: 'bundle' }]->(warmed_bundle)
(route_request)-[:FORK]->(warmed_bundle | origin_fetch)
(warmed_bundle | origin_fetch)-[:RACE { expect: 'ready' }]->(route_ready: Ready)
(route_ready)-[:TUNNEL { condition: 'bounded-reject' }]->(warmup_precompute_prefetch_gg_trace:Trace)
(route_ready)-[:MEASURE { reason: 'topology-audit' }]->(warmup_precompute_prefetch_gg_trace:Trace)
