// warmup_social_crowd_dynamics.gg — Human / Social Entrainment: Crowd dynamics
//
// Classification: Human / Social Entrainment
//
// Models the structural flow where an initial input forks between a fast
// "warmed up" path and a slow fallback path.

(input: Workload { type: 'request' })
(fast_path: State { name: 'chaotic_flow' })
(slow_path: State { name: 'synchronized_lanes' })
(chosen_path: Plan)
(result: Result)

(input)-[:FORK]->(fast_path | slow_path)
(fast_path | slow_path)-[:RACE { expect: 'fastest-safe' }]->(chosen_path)
(chosen_path)-[:PROCESS]->(result)
(result)-[:MEASURE { reason: 'topology-audit' }]->(warmup_social_crowd_dynamics_gg_trace:Trace)
