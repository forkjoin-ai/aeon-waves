// warmup_mixed_branch_prediction.gg — Mixed Membership: Branch Prediction
//
// Primary: Approximate / probabilistic acceleration
// Secondary: Adaptive optimization / online learning
// Predicts future control flow using recent history.

(instruction: Workload)
(fallback_pipeline: Pipeline { type: 'stall_and_fetch' })
(branch_history: Telemetry { metric: 'taken_vs_not' })
(predictor_model: Learner { method: 'two_bit_counter' })
(speculative_path: Speculation { type: 'branch_target' })
(executed_branch: Plan)
(commit_stage: Result)
(next_history: ModelState)

(instruction)-[:FORK]->(fallback_pipeline | branch_history)
(branch_history)-[:PROCESS]->(predictor_model)-[:PROCESS]->(speculative_path)
(instruction)-[:PROCESS]->(speculative_path)

(fallback_pipeline | speculative_path)-[:PROCESS { expect: 'fastest-safe' }]->(executed_branch)
(executed_branch)-[:PROCESS]->(commit_stage)
(commit_stage | predictor_model)-[:FOLD { strategy: 'update-policy' }]->(next_history)
(next_history)-[:TUNNEL { condition: 'bounded-reject' }]->(warmup_mixed_branch_prediction_gg_trace:Trace)
(next_history)-[:MEASURE { reason: 'topology-audit' }]->(warmup_mixed_branch_prediction_gg_trace:Trace)
