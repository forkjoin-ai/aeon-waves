// warmup_mixed_materialized_view.gg — Mixed Membership: Materialized Views
//
// Primary: Precompute / prefetch
// Secondary: Cache / index reuse
// Results are computed ahead of time and then reused directly.

(query_request: Workload)
(base_tables: Source { type: 'raw_data' })
(view_compiler: Precompute { type: 'aggregation' })
(materialized_cache: Cache { type: 'query_result' })
(fast_query: Runner { mode: 'index_scan' })
(slow_query: Runner { mode: 'table_scan' })
(chosen_plan: Plan)
(result: Result)

(query_request)-[:FORK]->(fast_query | slow_query)
(base_tables)-[:PROCESS]->(view_compiler)-[:PROCESS]->(materialized_cache)

(materialized_cache)-[:PROCESS]->(fast_query)
(base_tables)-[:PROCESS]->(slow_query)

(slow_query | fast_query)-[:RACE { expect: 'fastest-safe' }]->(chosen_plan)
(chosen_plan)-[:PROCESS]->(result)
(result)-[:MEASURE { reason: 'topology-audit' }]->(warmup_mixed_materialized_view_gg_trace:Trace)
