// warmup_controller_over_redline_tie.gg — Overprovisioned controller boundary tie
//
// Boundary case:
//   underDeficit = 0
//   overDeficit > 0
//   BurdenScalar = deficitWeight + shedPenalty
// so `constrain` ties `shed-load`, and the stable tie-break keeps `constrain`.

(case: ControllerCase { theorem: 'THM-S7-WARM-CTRL', mismatch: 'overprovisioned', burden_regime: 'redline-tie' })
(over_deficit: OverDeficit { units: '3' })
(redline: Redline { deficit_weight: '4', shed_penalty: '2' })
(burden: BurdenScalar { relation: '= redline' })

(expand: Expand { action: 'expand' })
(constrain: Constrain { action: 'constrain' })
(shed_load: ShedLoad { action: 'shed-load' })

(expand_drag: Penalty { reason: 'still dominated by deficit weight' })
(constrain_tie: ScoreBoundary { relation: 'tie-with-shed-load' })
(shed_tie: ScoreBoundary { relation: 'tie-with-constrain' })

(case)-[:PROCESS]->(over_deficit)
(over_deficit)-[:PROCESS]->(redline)
(redline)-[:PROCESS]->(burden)
(burden)-[:FORK]->(expand | constrain | shed_load)
(expand)-[:PROCESS { reason: 'wrong-direction repair remains worse' }]->(expand_drag)
(constrain)-[:PROCESS]->(constrain_tie)
(shed_load)-[:PROCESS]->(shed_tie)
(expand_drag | constrain_tie | shed_tie)-[:FOLD { strategy: 'stable-constrain-on-tie' }]->(decision: Decision { chosen: 'constrain', tie_with: 'shed-load' })
(decision)-[:PROCESS]->(verdict: Result)
(verdict)-[:TUNNEL { condition: 'bounded-reject' }]->(warmup_controller_over_redline_tie_gg_trace:Trace)
(verdict)-[:MEASURE { reason: 'topology-audit' }]->(warmup_controller_over_redline_tie_gg_trace:Trace)
