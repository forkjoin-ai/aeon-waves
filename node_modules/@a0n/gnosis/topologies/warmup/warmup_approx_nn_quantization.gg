// warmup_approx_nn_quantization.gg — Approximate / Probabilistic Acceleration: Neural network inference (quantization / pruning)
//
// Classification: Approximate / Probabilistic Acceleration
//
// Models the structural flow where an initial input forks between a fast
// "warmed up" path and a slow fallback path.

(input: Workload { type: 'request' })
(fast_path: State { name: 'quantized_model' })
(slow_path: State { name: 'full_precision_model' })
(chosen_path: Plan)
(result: Result)

(input)-[:FORK]->(fast_path | slow_path)
(fast_path | slow_path)-[:RACE { expect: 'fastest-safe' }]->(chosen_path)
(chosen_path)-[:PROCESS]->(result)
(result)-[:MEASURE { reason: 'topology-audit' }]->(warmup_approx_nn_quantization_gg_trace:Trace)
