// warmup_cache_query_plan.gg — Cache / Index Reuse: Database query plan memoization
//
// Classification: Cache / Index Reuse
//
// Models the structural flow where an initial input forks between a fast
// "warmed up" path and a slow fallback path.

(input: Workload { type: 'request' })
(fast_path: State { name: 'plan_cache' })
(slow_path: State { name: 'query_optimizer' })
(chosen_path: Plan)
(result: Result)

(input)-[:FORK]->(fast_path | slow_path)
(fast_path | slow_path)-[:RACE { expect: 'fastest-safe' }]->(chosen_path)
(chosen_path)-[:PROCESS]->(result)
(result)-[:MEASURE { reason: 'topology-audit' }]->(warmup_cache_query_plan_gg_trace:Trace)
