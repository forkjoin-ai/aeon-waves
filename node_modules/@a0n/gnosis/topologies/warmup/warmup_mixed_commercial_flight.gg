// warmup_mixed_commercial_flight.gg — Mixed Membership: Commercial Flight
//
// Primary: Physical / biological warm-up
// Secondary: Structural / amortized optimization
// Takeoff is an expensive front-loaded cost that buys efficient cruise, 
// while engines physically reach thermal efficiency.

(flight_request: Journey)
(takeoff_burn: SetupCost { type: 'high_fuel_burn' })
(cruising_altitude: StructuralState { status: 'low_drag' })
(engine_thermal_state: PhysicalState { status: 'cold' })
(engine_optimum: PhysicalState { status: 'warm_efficient' })
(flight_phase: Phase)
(arrival: Result)

(flight_request)-[:FORK]->(takeoff_burn | engine_thermal_state)

(takeoff_burn)-[:PROCESS]->(cruising_altitude)
(engine_thermal_state)-[:PROCESS]->(engine_optimum)

(cruising_altitude | engine_optimum)-[:SLIVER { mode: 'constructive' }]->(flight_phase)
(flight_phase)-[:PROCESS]->(arrival)