// warmup_physical_biological.gg — Stabilize the substrate before peak output
//
// Warm-up mechanism: circulation, temperature, and coordination all rise to a
// usable state before the system can deliver efficient work.

(body: System { mode: 'sprinter' })
(circulation: Physiology { metric: 'blood-flow' })
(temperature: Physiology { metric: 'muscle-temp' })
(coordination: Motor { metric: 'recruitment' })
(heat_loss: Sink { medium: 'waste-heat', capacity: '1' })
(readiness: State { phase: 'warmed' })

(body)-[:FORK]->(circulation | temperature | coordination)
(circulation | temperature | coordination)-[:FOLD { strategy: 'readiness', request_compression: 'middle-out/request/warmup-physical-biological', reuse_scope: 'corridor', corridor_mode: 'readonly' }]->(readiness)
(readiness)-[:PROCESS]->(performance: Output)
(performance)-[:PROCESS { condition: 'cooldown', drift_coefficient: '2', repair_debt: '0' }]->(heat_loss)
(heat_loss)-[:TUNNEL { condition: 'bounded-reject' }]->(warmup_physical_biological_gg_trace:Trace)
(heat_loss)-[:MEASURE { reason: 'topology-audit' }]->(warmup_physical_biological_gg_trace:Trace)
