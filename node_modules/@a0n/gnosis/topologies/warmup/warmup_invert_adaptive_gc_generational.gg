// warmup_invert_adaptive_gc_generational.gg — Inverted Adaptive Optimization / Online Learning: Garbage collection generational hypothesis
//
// Classification: Adaptive Optimization / Online Learning
//
// Models the structural subversion where the fast path is poisoned or drifted,
// forcing a fallback fold to a slower, stable baseline.

(input: Workload { type: 'request' })
(fast_path: State { name: 'nursery_generation' })
(slow_path: State { name: 'old_generation' })
(poison_event: Event { type: 'entropy_or_drift' })
(chosen_path: Plan)
(fallback: Plan)
(result: Result)

(input)-[:FORK]->(fast_path | slow_path | poison_event)
(poison_event)-[:SLIVER { mode: 'destructive' }]->(fast_path)
(fast_path | slow_path)-[:RACE { expect: 'fastest-now' }]->(chosen_path)
(chosen_path | poison_event)-[:FOLD { strategy: 'fallback-stable' }]->(fallback)
(fallback)-[:PROCESS]->(result)
(result)-[:TUNNEL { condition: 'bounded-reject' }]->(warmup_invert_adaptive_gc_generational_gg_trace:Trace)
(result)-[:MEASURE { reason: 'topology-audit' }]->(warmup_invert_adaptive_gc_generational_gg_trace:Trace)
