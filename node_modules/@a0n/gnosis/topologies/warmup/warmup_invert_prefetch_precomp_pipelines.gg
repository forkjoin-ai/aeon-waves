// warmup_invert_prefetch_precomp_pipelines.gg — Inverted Precompute / Prefetch: Pre-computation pipelines
//
// Classification: Precompute / Prefetch
//
// Models the structural subversion where the fast path is poisoned or drifted,
// forcing a fallback fold to a slower, stable baseline.

(input: Workload { type: 'request' })
(fast_path: State { name: 'precalc_pipeline' })
(slow_path: State { name: 'on_demand_calc' })
(poison_event: Event { type: 'entropy_or_drift' })
(chosen_path: Plan)
(fallback: Plan)
(result: Result)

(input)-[:FORK]->(fast_path | slow_path | poison_event)
(poison_event)-[:SLIVER { mode: 'destructive' }]->(fast_path)
(fast_path | slow_path)-[:RACE { expect: 'fastest-now' }]->(chosen_path)
(chosen_path | poison_event)-[:FOLD { strategy: 'fallback-stable' }]->(fallback)
(fallback)-[:PROCESS]->(result)
(result)-[:TUNNEL { condition: 'bounded-reject' }]->(warmup_invert_prefetch_precomp_pipelines_gg_trace:Trace)
(result)-[:MEASURE { reason: 'topology-audit' }]->(warmup_invert_prefetch_precomp_pipelines_gg_trace:Trace)
