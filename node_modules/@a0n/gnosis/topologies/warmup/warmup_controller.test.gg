// warmup_controller.test.gg — Native Gnosis witnesses for the warm-up controller theorem
//
// These are theorem-shaped `.gg` cases, not an external calculator:
//   - underfilled below redline  -> expand
//   - overprovisioned below redline -> constrain
//   - above redline -> shed-load
//   - redline tie -> stable tie-break on the repair branch

(test_suite: TestSuite { name: 'warmup-controller' })

(under_below: Verify { module: './warmup_controller_under_below_redline.gg', beta1_max: '6' })
(over_below: Verify { module: './warmup_controller_over_below_redline.gg', beta1_max: '6' })
(under_above: Verify { module: './warmup_controller_under_above_redline.gg', beta1_max: '6' })
(over_above: Verify { module: './warmup_controller_over_above_redline.gg', beta1_max: '6' })
(under_tie: Verify { module: './warmup_controller_under_redline_tie.gg', beta1_max: '6' })
(over_tie: Verify { module: './warmup_controller_over_redline_tie.gg', beta1_max: '6' })

(test_suite)-[:PROCESS]->(under_below | over_below | under_above | over_above | under_tie | over_tie)

(under_below)-[:PROCESS { expect: 'safe' }]->(under_below_result: Result)
(over_below)-[:PROCESS { expect: 'safe' }]->(over_below_result: Result)
(under_above)-[:PROCESS { expect: 'safe' }]->(under_above_result: Result)
(over_above)-[:PROCESS { expect: 'safe' }]->(over_above_result: Result)
(under_tie)-[:PROCESS { expect: 'safe' }]->(under_tie_result: Result)
(over_tie)-[:PROCESS { expect: 'safe' }]->(over_tie_result: Result)

(under_below_result | over_below_result | under_above_result | over_above_result | under_tie_result | over_tie_result)-[:PROCESS { strategy: 'all-pass' }]->(verdict: Verdict)
