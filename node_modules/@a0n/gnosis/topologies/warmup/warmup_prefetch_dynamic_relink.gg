// warmup_prefetch_dynamic_relink.gg — Precompute / Prefetch: Dynamic re-linking
//
// Classification: Precompute / Prefetch
//
// Models the structural flow where an initial input forks between a fast
// "warmed up" path and a slow fallback path.

(input: Workload { type: 'request' })
(fast_path: State { name: 'plt_got' })
(slow_path: State { name: 'dynamic_linker' })
(chosen_path: Plan)
(result: Result)

(input)-[:FORK]->(fast_path | slow_path)
(fast_path | slow_path)-[:RACE { expect: 'fastest-safe' }]->(chosen_path)
(chosen_path)-[:PROCESS]->(result)
(result)-[:MEASURE { reason: 'topology-audit' }]->(warmup_prefetch_dynamic_relink_gg_trace:Trace)
