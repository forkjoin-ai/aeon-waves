// warmup_approx_heuristic_pruning.gg — Approximate / Probabilistic Acceleration: Heuristic pruning
//
// Classification: Approximate / Probabilistic Acceleration
//
// Models the structural flow where an initial input forks between a fast
// "warmed up" path and a slow fallback path.

(input: Workload { type: 'request' })
(fast_path: State { name: 'heuristic_evaluator' })
(slow_path: State { name: 'exhaustive_search' })
(chosen_path: Plan)
(result: Result)

(input)-[:FORK]->(fast_path | slow_path)
(fast_path | slow_path)-[:RACE { expect: 'fastest-safe' }]->(chosen_path)
(chosen_path)-[:PROCESS]->(result)
(result)-[:MEASURE { reason: 'topology-audit' }]->(warmup_approx_heuristic_pruning_gg_trace:Trace)
