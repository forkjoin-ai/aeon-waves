// void_walking_coherence.gg — THM-VOID-COHERENCE witness
//
// Two independent void walkers with the same rejection history
// produce the same complement distribution. Coherence is objective.

(walker_a: VoidWalker { theorem: 'THM-VOID-COHERENCE', id: 'A' })
(walker_b: VoidWalker { theorem: 'THM-VOID-COHERENCE', id: 'B' })
(shared_history: RejectionHistory { rejections: '[0, 2, 1, 0]', rounds: '3' })
(dist_a: ComplementDistribution { source: 'A' })
(dist_b: ComplementDistribution { source: 'B' })
(agreement: Invariant { claim: 'dist_a == dist_b' })
(result: Result { theorem: 'independent-walkers-converge' })

(shared_history)-[:FORK]->(walker_a | walker_b)
(walker_a)-[:PROCESS { expect: 'distribution-computed' }]->(dist_a)
(walker_b)-[:PROCESS { expect: 'distribution-computed' }]->(dist_b)
(dist_a | dist_b)-[:FOLD { strategy: 'verify-equality' }]->(agreement)
(agreement)-[:PROCESS]->(result)
(result)-[:TUNNEL { condition: 'bounded-reject' }]->(void_walking_coherence_gg_trace:Trace)
(result)-[:MEASURE { reason: 'topology-audit' }]->(void_walking_coherence_gg_trace:Trace)
