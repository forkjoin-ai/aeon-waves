// beauty_monotone_cost.gg — THM-BEAUTY-OPTIMALITY witness (more deficit -> more cost)
//
// Increasing the deficit on any branch strictly increases the total cost.
// Example: deficit 0 -> cost 3, deficit 2 -> cost 5, deficit 4 -> cost 7.
// The cost function is monotone non-decreasing in deficit.

(config_low: BeautyConfig { theorem: 'THM-BEAUTY-OPTIMALITY', deficit: '0', cost: '3' })
(config_mid: BeautyConfig { deficit: '2', cost: '5' })
(config_high: BeautyConfig { deficit: '4', cost: '7' })
(monotone_low_mid: Invariant { claim: 'cost(d=0) <= cost(d=2)', low: '3', high: '5' })
(monotone_mid_high: Invariant { claim: 'cost(d=2) <= cost(d=4)', low: '5', high: '7' })
(result: Result { theorem: 'deficit-monotone-cost' })

(config_low)-[:PROCESS]->(config_mid)
(config_mid)-[:PROCESS]->(config_high)
(config_low | config_mid)-[:RACE { expect: 'monotone-increasing' }]->(monotone_low_mid)
(config_mid | config_high)-[:RACE { expect: 'monotone-increasing' }]->(monotone_mid_high)
(monotone_low_mid | monotone_mid_high)-[:FOLD { strategy: 'verify-inequality' }]->(result)
(result)-[:MEASURE { reason: 'topology-audit' }]->(beauty_monotone_cost_gg_trace:Trace)
