// speculative_ui_render.gg — Speculative UI Rendering

(intent: Action)-[:FORK]->(render_spec: UI | fetch_data: API)
(render_spec | fetch_data)-[:FOLD { strategy: 'verify' }]->(final_ui: UI)
(final_ui)-[:TUNNEL { condition: 'bounded-reject' }]->(speculative_ui_render_gg_trace:Trace)
(final_ui)-[:MEASURE { reason: 'topology-audit' }]->(speculative_ui_render_gg_trace:Trace)
