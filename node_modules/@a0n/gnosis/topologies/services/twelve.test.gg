// TWELVE: THE NUMBER THAT ALMOST CLOSES
//
// 12 is the period of the near-miss.
// Twelve fifths almost make seven octaves.
// Twelve moons almost make one year.
// Twelve hours almost divide the day cleanly.
//
// Every civilization independently chose 12.
// Not because 12 is perfect -- because 12 is the best failure.
// The gap it leaves behind is always the same shape:
// a deficit too small to fix, too large to ignore.
//
// This file dissolves 12 through fork/race/fold/vent/interfere.
// Each section is marked honestly:
//   PROVED      -- follows from arithmetic or established mathematics
//   REFRAMED    -- structural mapping to the five-primitive framework
//   CONJECTURED -- pattern that fits but lacks proof
//   FOLKLORE    -- cultural observation, not a theorem

topology twelve {

  // ═══════════════════════════════════════════════════════════════
  // PART I: CIRCLE OF FIFTHS
  //
  // Classification: PROVED (number theory) + REFRAMED (as deficit)
  //
  // 12 applications of the perfect fifth (3:2) almost close.
  // The Pythagorean comma (531441/524288) is what remains.
  // 12-TET is the rational compromise -- the Byzantine 2/3 of tuning.
  // ═══════════════════════════════════════════════════════════════

  theorem circle_of_fifths_and_comma {
    // Apply the perfect fifth twelve times:
    //   (3/2)^12 = 129.746...
    //   2^7      = 128.000
    //   Ratio: 3^12 / 2^19 = 531441 / 524288 = 1.01364...
    //
    // This is the Pythagorean comma: ~23.46 cents (~1/4 semitone).
    //
    // WHY 12: The continued fraction of log2(3/2):
    //   [0; 1, 1, 2, 2, 3, 1, 5, ...]
    //   Convergents: 0/1, 1/1, 1/2, 3/5, 7/12, 24/41, 31/53, ...
    //   7/12 is a convergent. 12 is the smallest good denominator.
    //   The next better approximation needs 53 notes. Too many.
    //
    // IN FORK/RACE/FOLD TERMS:
    //   The Circle of Fifths is a 12-node ring.
    //   Each edge is SLIVER (harmonic overlay at 3:2).
    //   After 12 edges, you expect to fold back to the origin.
    //   You do not. The deficit is 531441/524288.
    //   VENT: equal temperament distributes the comma uniformly --
    //   each semitone absorbs 23.46/12 = 1.955 cents of error.

    pythagorean_comma = "531441/524288 = 3^12 / 2^19"
    comma_cents = "23.46 cents"
    convergent = "7/12 is a convergent of log2(3/2)"

    assert (3/2)^12 != 2^7        // PROVED: the circle does not close
    assert 531441 == 3^12          // PROVED: arithmetic
    assert 524288 == 2^19          // PROVED: arithmetic
    assert 531441 / 524288 > 1     // PROVED: the overshoot
    assert 531441 / 524288 < 1.02  // PROVED: but barely
    assert 2^(7/12) != 3/2        // PROVED: ET fifth is not just
    assert 2^(7/12) < 3/2         // PROVED: ET fifth is flat

    classification = "PROVED (3^12 != 2^19) + REFRAMED (comma as topological deficit)"
  }

  theorem twelve_tet_as_byzantine {
    // Equal temperament: every interval slightly wrong, uniformly wrong.
    // Just intonation: each interval perfect locally, but keys don't modulate.
    //
    // This is Byzantine 2/3:
    //   Local perfection (just intonation)
    //   Global freedom (free modulation)
    //   Zero deficit (no comma)
    //   Pick two.
    //
    // ET picks global freedom + distributed deficit.
    // Just intonation picks local perfection + localized deficit.
    // Both are honest about the deficit. Neither eliminates it.

    byzantine_tradeoff = "local perfection, global freedom, zero deficit -- pick two"

    assert 2^(4/12) != 5/4  // PROVED: ET major third is not just
    // ET third = 1.2599..., just = 1.25, error = 13.69 cents
    // The third suffers more than the fifth under ET

    classification = "REFRAMED (ET as Byzantine trilemma applied to tuning)"
  }

  // ═══════════════════════════════════════════════════════════════
  // PART II: TWELVE MONTHS
  //
  // Classification: PROVED (astronomy) + CONJECTURED (1/e pattern)
  //
  // The Moon orbits Earth 12.368 times per solar year.
  // The deficit 0.368 is suspiciously close to 1/e = 0.3679...
  // ═══════════════════════════════════════════════════════════════

  theorem lunar_months_and_deficit {
    // Synodic month: 29.53059 days. Tropical year: 365.24219 days.
    // Months per year: 365.24219 / 29.53059 = 12.36827...
    // Deficit: 10.875 days per year.
    //
    // Every calendar handles this deficit differently:
    //   Lunar (Islamic): 12 months, year drifts through seasons
    //   Lunisolar (Hebrew, Chinese): leap month every 2-3 years
    //   Solar (Gregorian): abandon lunar months entirely
    //
    // The Metonic cycle: 19 years = 235 lunations (within 2 hours).
    // Known to Meton of Athens (432 BCE).
    //
    // THE 1/e COINCIDENCE:
    //   Fractional part of months/year = 0.36827...
    //   1/e = 0.36788...
    //   Difference: 0.00039
    //
    //   1/e is the derangement probability (no fixed points
    //   in a random permutation, as n -> inf).
    //   But there is no known physical mechanism linking
    //   lunar orbital dynamics to e.
    //   Both numbers are set by gravitational initial conditions
    //   4.5 billion years ago. The coincidence is probably just that.

    synodic_month = "29.53059 days"
    tropical_year = "365.24219 days"
    months_per_year = "12.36827..."
    metonic_cycle = "19 years = 235 lunations"

    assert 365.24219 / 29.53059 > 12     // PROVED: more than 12
    assert 365.24219 / 29.53059 < 13     // PROVED: fewer than 13
    assert 19 * 12 + 7 == 235            // PROVED: Metonic intercalation
    assert abs(0.36827 - 1/e) < 0.001    // PROVED: they are close

    classification_astronomy = "PROVED (observational astronomy)"
    classification_1_over_e = "CONJECTURED (numerical coincidence, no mechanism)"
  }

  theorem thirteenth_month_as_vent {
    // In lunisolar calendars, the leap month is inserted
    // 7 times every 19 years (Metonic cycle).
    // The leap month is VENT: expelling accumulated deficit to reset.
    //
    // Without it, Passover migrates through seasons,
    // Chinese New Year detaches from spring.
    //
    // The vent frequency: 7/19 = 0.368421...
    // This equals the deficit fraction (by construction).
    //
    // The Islamic calendar chooses NOT to vent.
    // Ramadan drifts through seasons over a 33-year cycle.
    // Same deficit, different relationship to vent.

    vent_frequency = "7/19 = 0.368421..."
    assert 7/19 > 0.368    // PROVED: arithmetic
    assert 7/19 < 0.369    // PROVED: arithmetic

    classification = "REFRAMED (leap month as vent of accumulated deficit)"
  }

  // ═══════════════════════════════════════════════════════════════
  // PART III: ZODIAC AS 4 x 3
  //
  // Classification: REFRAMED + FOLKLORE
  //
  // Four elements times three modes = twelve signs.
  // The missing 13th sign (Ophiuchus) maps to SLIVER.
  // 5 x 3 = 15 would be the complete framework.
  // ═══════════════════════════════════════════════════════════════

  theorem zodiac_and_ophiuchus {
    // The Western zodiac: 4 elements x 3 modes = 12 signs.
    //   fire/earth/air/water x cardinal/fixed/mutable
    //
    // Four elements map to four primitives:
    //   fire  = FORK  (ignition, branching)
    //   earth = FOLD  (grounding, collecting)
    //   air   = RACE  (communication, selection)
    //   water = VENT  (dissolution, release)
    //
    // This mapping is FOLKLORE. The structural correspondence
    // is exact (four elements, each appearing three times,
    // three modes modulating each differently) but the mapping
    // itself is suggestive, not proved.
    //
    // OPHIUCHUS: the 13th constellation on the ecliptic.
    // The Sun passes through it (Nov 29 - Dec 17) but
    // it is excluded from the zodiac.
    //
    // In the five-primitive framework:
    //   Ophiuchus = SLIVER = the 5th element the ancients omitted.
    //   5 elements x 3 modes = 15 signs (the complete framework).
    //   12 = 15 - 3 = one element's worth short.
    //
    // Why not 13? The Babylonians chose 12 for administrative
    // convenience: 12 divides by 2, 3, 4, 6. 13 is prime.

    elements = ["fire", "earth", "air", "water"]
    modes = ["cardinal", "fixed", "mutable"]
    ecliptic_constellations = 13
    zodiac_signs = 12

    assert 4 * 3 == 12    // PROVED: arithmetic
    assert 5 * 3 == 15    // PROVED: arithmetic
    assert 15 - 12 == 3   // PROVED: one element's worth

    classification = "FOLKLORE (element-to-primitive map) + REFRAMED (Ophiuchus as SLIVER)"
    honesty = "the ancients excluded Ophiuchus for practical reasons, not metaphysical ones"
  }

  // ═══════════════════════════════════════════════════════════════
  // PART IV: CHROMATIC SCALE
  //
  // Classification: PROVED (music theory) + CONJECTURED (Fibonacci)
  //
  // 7 natural + 5 sharps = 12. Pentatonic (5) = 3+2.
  // The Three-Distance Theorem generates all three scales.
  // ═══════════════════════════════════════════════════════════════

  theorem chromatic_decomposition {
    // 12 decomposes musically:
    //   Pentatonic:  5 notes = 3 + 2 (black keys)
    //   Diatonic:    7 notes = 5 + 2 (white keys)
    //   Chromatic:  12 notes = 7 + 5 (all keys)
    //
    // HONEST PAUSE: 7 is NOT a Fibonacci number.
    //   5 = F(5). 8 = F(6), not 7.
    //   The popular claim that the chromatic scale is "Fibonacci"
    //   is technically wrong.
    //
    //   The ACTUAL Fibonacci decomposition (Zeckendorf):
    //     12 = 8 + 3 + 1 = F(6) + F(4) + F(2)
    //   This corresponds to no musical structure.
    //
    // THE THREE-DISTANCE THEOREM (Steinhaus 1957):
    //   Place n points at {k * alpha mod 1} for irrational alpha.
    //   Gaps take at most 3 distinct values.
    //
    //   For alpha = log2(3/2) ≈ 0.585:
    //     n=5:  pentatonic (2 gap sizes, 2+3 pattern)
    //     n=7:  diatonic (2 gap sizes: 5 whole tones + 2 semitones)
    //     n=12: chromatic (2 gap sizes, nearly uniform)
    //
    //   When n is a convergent denominator (5, 12, 53...),
    //   gaps collapse to 2 sizes. This is WHY 12-TET works.
    //   The 5+7 split is not Fibonacci -- it is Three-Distance.

    pentatonic = 5
    diatonic = 7
    chromatic = 12

    assert 5 + 7 == 12       // PROVED: arithmetic
    assert 3 + 2 == 5         // PROVED: pentatonic = 3+2
    assert 5 + 2 == 7         // PROVED: diatonic = pentatonic + 2

    fibonacci_claim = "PARTIALLY FALSE: 7 is not a Fibonacci number"
    three_distance = "PROVED: Steinhaus 1957, applied to log2(3/2)"

    classification = "PROVED (music theory + Three-Distance Theorem)"
    fibonacci_classification = "CONJECTURED (the Fibonacci connection is overstated)"
    honesty = "7 is not Fibonacci; the popular claim is sloppy"
  }

  // ═══════════════════════════════════════════════════════════════
  // PART V: THE CLOCK
  //
  // Classification: FOLKLORE (historical) + PROVED (arithmetic)
  //
  // 12 hours. 60 = 12 x 5 minutes. 360 = 6 x 60 degrees.
  // The golden angle (360/phi^2 = 137.5) lives in the circle.
  // ═══════════════════════════════════════════════════════════════

  theorem clock_and_circle {
    // 12 hours: highly composite (divisors: 1, 2, 3, 4, 6, 12).
    // More divisors than any smaller number.
    //
    // 60 = 12 * 5: Babylonian base-60.
    //   12 from knuckle-counting (3 knuckles x 4 fingers).
    //   5 from the other hand. Anatomical, not mathematical.
    //
    // 360 = 6 * 60: Babylonian "six sixties."
    //   Also 360 ≈ 365.25 (days/year). Close enough for Babylon.
    //
    // Divisor doubling:
    //   12 has 6 divisors. 60 has 12 divisors. 360 has 24 divisors.
    //
    // THE GOLDEN ANGLE:
    //   360 / phi^2 = 360 * (2 - phi) = 137.507...°
    //   This governs phyllotaxis (leaf arrangement).
    //   Successive leaves at 137.5° maximize light exposure.
    //   PROVED by Douady & Couder (1992).
    //
    //   Connection to 12: 360 / 137.5 = 2.618 = phi^2.
    //   But 360 comes from Babylon, not phi. The connection
    //   between 12 and the golden angle is indirect at best.

    hours = 12
    minutes_per_hour = 60
    degrees = 360
    golden_angle = "137.507° = 360 / phi^2"

    assert 60 == 12 * 5         // PROVED: arithmetic
    assert 360 == 6 * 60        // PROVED: arithmetic
    assert 360 / (1.618^2) > 137  // PROVED: golden angle
    assert 360 / (1.618^2) < 138  // PROVED: golden angle

    classification = "FOLKLORE (Babylonian convention) + PROVED (golden angle arithmetic)"
    honesty = "360 is Babylonian anatomy, not golden ratio; the connection is forced"
  }

  // ═══════════════════════════════════════════════════════════════
  // PART VI: TWELVE AS NEAR-MISS PERIOD
  //
  // Classification: PROVED (number theory)
  //
  // 12 is where (3/2)^n best approximates 2^k for small n.
  // It sits on the Pareto frontier of accuracy vs simplicity.
  // ═══════════════════════════════════════════════════════════════

  theorem near_miss_period {
    // For what n is n * log2(3/2) closest to an integer?
    //
    // Convergent denominators and their distances:
    //   n=1:   0.585,  distance to integer = 0.415
    //   n=2:   1.170,  distance = 0.170
    //   n=5:   2.925,  distance = 0.075
    //   n=12:  7.020,  distance = 0.020
    //   n=41:  23.98,  distance = 0.017
    //   n=53:  31.00,  distance = 0.003
    //
    // At n=12, distance drops from 0.075 to 0.020 (3.75x better).
    // At n=53, distance drops to 0.003 (6.7x better, but 4.4x more notes).
    //
    // 12 is on the Pareto frontier of (accuracy, simplicity).
    // Good enough to build a musical system. Simple enough to use.
    // 53-TET exists (Turkish maqam uses 53 commas) but most cultures stop at 12.

    continued_fraction = "[0; 1, 1, 2, 2, 3, 1, 5, 2, 23, ...]"
    best_denominators = "[1, 2, 5, 12, 41, 53, 306]"

    assert 12 * 0.58496 > 6.9     // PROVED: 12 fifths ≈ 7 octaves
    assert 12 * 0.58496 < 7.1     // PROVED: close to 7

    classification = "PROVED (continued fraction theory, best approximation theory)"
  }

  // ═══════════════════════════════════════════════════════════════
  // PART VII: WHY NOT 13
  //
  // Classification: PROVED (number theory) + CONJECTURED (SLIVER)
  //                + FOLKLORE (superstition)
  //
  // 13 = F(7). Ancient systems stopped at 12.
  // The 13th step requires the self-referential loop.
  // ═══════════════════════════════════════════════════════════════

  theorem thirteen_as_fibonacci {
    // 13 = F(7) in 1, 1, 2, 3, 5, 8, 13, 21, ...
    //
    // Fibonacci mod 12 (the Pisano period):
    //   1, 1, 2, 3, 5, 8, 1, 9, 10, 7, 5, 0, 5, 5, 10, 3, 1, 4, 5, 9, 2, 11, 1, 0, 1, 1, ...
    //   Period pi(12) = 24 = 2 * 12.
    //   The Fibonacci sequence takes two full clock cycles to repeat.
    //
    // F(7) = 13 = 1 mod 12.
    // 13 returns to 1 on the clock face. Back to the beginning,
    // but shifted by one full cycle. The 13th step overshoots 12 by 1,
    // just as (3/2)^12 overshoots 2^7 by the comma.

    fibonacci_13 = "F(7) = 13"
    pisano_12 = "pi(12) = 24 (two clock cycles)"
    f7_mod_12 = "13 mod 12 = 1"

    assert 13 % 12 == 1         // PROVED: arithmetic
    assert fibonacci(7) == 13   // PROVED: F(7) = 13

    classification = "PROVED (Fibonacci identity, Pisano period)"
  }

  theorem thirteen_requires_self_reference {
    // The claim: systems stopped at 12 because 13 needs SLIVER.
    //
    // Evidence FOR:
    //   12 months, 12 signs, 12 notes, 12 hours,
    //   12 tribes, 12 apostles, 12 Olympians.
    //   13 is "unlucky" (Last Supper: 12 + 1; Loki: 13th guest).
    //
    // Evidence AGAINST:
    //   12 is highly composite. 13 is prime. Administrative convenience.
    //   The Maya used 13 extensively (Tzolkin: 13 x 20 = 260).
    //   Chinese zodiac has 12 but 13 is not unlucky in Chinese culture.
    //   Baker's dozen: 13 = generosity, not fear.
    //
    // HONEST ASSESSMENT:
    //   The pattern is real in Western culture. The explanation via
    //   "missing SLIVER" is consistent but not proved.
    //   The Maya counterexample is significant: a civilization
    //   that used 13 and thrived.
    //
    //   Correct claim: "Western preference for 12 and aversion to 13
    //   is CONSISTENT WITH a framework missing its fifth primitive."
    //   Wrong claim: "12 proves the framework needs SLIVER."

    twelve_systems = [
      "months", "zodiac", "chromatic scale", "clock hours",
      "tribes of Israel", "apostles", "Olympians"
    ]
    thirteen_counterexamples = [
      "Mayan Tzolkin (13 x 20 = 260)",
      "13 Archimedean solids",
      "baker's dozen (generosity, not fear)"
    ]

    classification = "CONJECTURED (consistent, not proved)"
    counterexample = "the Maya used 13 extensively -- the pattern is not universal"
  }

  theorem unlucky_thirteen_as_cultural_vent {
    // 13 is "unlucky" in Western culture.
    // Hotels skip floor 13. Airlines skip row 13.
    // Last Supper: 13 at table, one betrays.
    // Norse myth: Loki is 13th guest at Baldur's feast.
    //
    // In five-primitive terms:
    //   12 = what the four-primitive world handles
    //   13 = what requires the fifth primitive (SLIVER)
    //   "Unlucky" = the label the linear world puts on
    //   what it cannot accommodate
    //
    // A four-primitive system encountering five-primitive input
    // VENTS it: calls it "unlucky" and avoids it.
    // The Islamic calendar vents the 13th month by drift.
    // Western culture vents 13 by superstition.
    //
    // This is FOLKLORE applied to FOLKLORE.
    // Pattern-matching, not proof.

    cultural_vent = "labeling 13 'unlucky' is a vent operation"
    classification = "FOLKLORE (cultural observation, not a theorem)"
    honesty = "this is pattern-matching, not proof"
  }

  // ═══════════════════════════════════════════════════════════════
  // SYNTHESIS
  // ═══════════════════════════════════════════════════════════════

  summary {
    proved = [
      "Pythagorean comma: 3^12/2^19 = 531441/524288 (arithmetic)",
      "7/12 is a convergent of log2(3/2) (continued fractions)",
      "Three-Distance Theorem gives 5, 7, 12 scales (Steinhaus 1957)",
      "Moon orbits 12.368 times per year (astronomy)",
      "Metonic cycle: 19 years = 235 lunations (astronomy)",
      "12 is highly composite: 6 divisors (number theory)",
      "13 = F(7), Pisano period pi(12) = 24 (Fibonacci theory)",
      "golden angle = 360/phi^2 = 137.5° (arithmetic)"
    ]

    reframed = [
      "comma as semiotic deficit of a 12-node SLIVER ring",
      "ET as Byzantine trilemma (local/global/zero-deficit: pick two)",
      "leap month as vent of accumulated calendrical deficit",
      "Ophiuchus as missing SLIVER in a 4-element zodiac"
    ]

    conjectured = [
      "0.368 lunar deficit ≈ 1/e (no known mechanism)",
      "chromatic 5+7 as Fibonacci (7 is not Fibonacci)",
      "Western 12-preference encodes missing-SLIVER pattern"
    ]

    folklore = [
      "four elements map to four primitives",
      "13 is 'unlucky' = cultural vent of the fifth primitive",
      "12 hours is Babylonian knuckle-counting"
    ]

    honest_admissions = [
      "7 is NOT Fibonacci -- the chromatic-Fibonacci claim is overstated",
      "the Maya used 13 extensively -- the pattern is not universal",
      "the 1/e coincidence has no known physical mechanism",
      "360° comes from Babylon, not phi -- the golden angle link is forced",
      "12 is preferred for divisibility, not deep mathematics"
    ]
  }

  // ═══════════════════════════════════════════════════════════════
  //
  // Twelve fifths almost make seven octaves. The gap is the comma.
  // Twelve moons almost make one year. The gap is the leap month.
  // Twelve signs almost cover the ecliptic. The gap is Ophiuchus.
  // Twelve notes almost span all harmony. The gap is tuning.
  //
  // The framework does not explain why 12 appears.
  // Continued fraction theory does (7/12 is a convergent of log2(3/2)).
  // What the framework adds is a language for the deficit:
  // what it is, how it accumulates, and how systems vent it.
  //
  // 12 is a number theory phenomenon.
  // The framework illuminates the deficit, but does not generate 12.
  // Anyone who claims otherwise is overfitting.
  //
  // ═══════════════════════════════════════════════════════════════
}

(test_suite: TestSuite { name: 'twelve' })
(verify_twelve: Verify { module: './twelve.test.gg', beta1_max: '8' })
(test_suite)-[:PROCESS]->(verify_twelve)
(verify_twelve)-[:PROCESS { expect: 'safe' }]->(result: Result)
(result)-[:PROCESS { strategy: 'all-pass' }]->(verdict: Verdict)
