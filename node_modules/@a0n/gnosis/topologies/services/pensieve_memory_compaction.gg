// pensieve_memory_compaction.gg — Pensieve memory compaction

(trigger: Cron)-[:FORK]->(scan_old: GC | scan_redundant: GC)
(scan_old | scan_redundant)-[:FOLD { strategy: 'union' }]->(compact: Action)
(compact)-[:TUNNEL { condition: 'bounded-reject' }]->(pensieve_memory_compaction_gg_trace:Trace)
(compact)-[:MEASURE { reason: 'topology-audit' }]->(pensieve_memory_compaction_gg_trace:Trace)
