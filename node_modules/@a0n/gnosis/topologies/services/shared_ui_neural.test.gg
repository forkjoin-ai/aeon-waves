// shared_ui_neural.test.gg — Verification harness for shared ui neural
(test_suite: TestSuite { name: 'shared_ui_neural' })

(neural_optimal_self: Verify { module: './neural_optimal_self.gg', beta1_max: '6' })
(neural_goal_achievement: Verify { module: './neural_goal_achievement.gg', beta1_max: '6' })
(neural_stress_response: Verify { module: './neural_stress_response.gg', beta1_max: '6' })
(neural_live_word: Verify { module: './neural_live_word.gg', beta1_max: '6' })

(test_suite)-[:FORK]->(neural_optimal_self | neural_goal_achievement | neural_stress_response | neural_live_word)

(neural_optimal_self)-[:RACE { expect: 'safe' }]->(neural_optimal_self_res: Result)
(neural_goal_achievement)-[:RACE { expect: 'safe' }]->(neural_goal_achievement_res: Result)
(neural_stress_response)-[:RACE { expect: 'safe' }]->(neural_stress_response_res: Result)
(neural_live_word)-[:RACE { expect: 'safe' }]->(neural_live_word_res: Result)

(neural_optimal_self_res | neural_goal_achievement_res | neural_stress_response_res | neural_live_word_res)-[:FOLD { strategy: 'all-pass' }]->(verdict: Verdict)
(verdict)-[:TUNNEL { condition: 'bounded-reject' }]->(shared_ui_neural_test_gg_trace:Trace)
(verdict)-[:MEASURE { reason: 'topology-audit' }]->(shared_ui_neural_test_gg_trace:Trace)
