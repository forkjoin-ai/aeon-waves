// pty_process_manager.gg — PTY Process management

(spawn_cmd: Command)-[:FORK]->(pty_stdout: Stream | pty_stderr: Stream)
(pty_stdout | pty_stderr)-[:FOLD { strategy: 'multiplex' }]->(terminal: TTY)
(terminal)-[:TUNNEL { condition: 'bounded-reject' }]->(pty_process_manager_gg_trace:Trace)
(terminal)-[:MEASURE { reason: 'topology-audit' }]->(pty_process_manager_gg_trace:Trace)
