// agent_mesh_gossip.gg — Agent mesh gossip protocol

(event: Gossip)-[:FORK]->(peer_1: Agent | peer_2: Agent)
(peer_1 | peer_2)-[:FOLD { strategy: 'consensus' }]->(global_state: State)
(global_state)-[:TUNNEL { condition: 'bounded-reject' }]->(agent_mesh_gossip_gg_trace:Trace)
(global_state)-[:MEASURE { reason: 'topology-audit' }]->(agent_mesh_gossip_gg_trace:Trace)
