// flux_client_sync.gg — Aeon Flux Client Sync

(ui_mutation: Event)-[:FORK]->(optimistic_update: DOM | server_sync: WSS)
(server_sync)-[:PROCESS]->(ack: Network)
(optimistic_update | ack)-[:FOLD { strategy: 'reconcile' }]->(confirmed_ui: DOM)
(confirmed_ui)-[:TUNNEL { condition: 'bounded-reject' }]->(flux_client_sync_gg_trace:Trace)
(confirmed_ui)-[:MEASURE { reason: 'topology-audit' }]->(flux_client_sync_gg_trace:Trace)
