// shared_ui_pensieve.test.gg — Verification harness for shared ui pensieve
(test_suite: TestSuite { name: 'shared_ui_pensieve' })

(pensieve_offline_sync: Verify { module: './pensieve_offline_sync.gg', beta1_max: '6' })
(pensieve_ucan_protection: Verify { module: './pensieve_ucan_protection.gg', beta1_max: '6' })
(pensieve_narrative_curation: Verify { module: './pensieve_narrative_curation.gg', beta1_max: '6' })
(pensieve_social_energy: Verify { module: './pensieve_social_energy.gg', beta1_max: '6' })

(test_suite)-[:FORK]->(pensieve_offline_sync | pensieve_ucan_protection | pensieve_narrative_curation | pensieve_social_energy)

(pensieve_offline_sync)-[:RACE { expect: 'safe' }]->(pensieve_offline_sync_res: Result)
(pensieve_ucan_protection)-[:RACE { expect: 'safe' }]->(pensieve_ucan_protection_res: Result)
(pensieve_narrative_curation)-[:RACE { expect: 'safe' }]->(pensieve_narrative_curation_res: Result)
(pensieve_social_energy)-[:RACE { expect: 'safe' }]->(pensieve_social_energy_res: Result)

(pensieve_offline_sync_res | pensieve_ucan_protection_res | pensieve_narrative_curation_res | pensieve_social_energy_res)-[:FOLD { strategy: 'all-pass' }]->(verdict: Verdict)
(verdict)-[:TUNNEL { condition: 'bounded-reject' }]->(shared_ui_pensieve_test_gg_trace:Trace)
(verdict)-[:MEASURE { reason: 'topology-audit' }]->(shared_ui_pensieve_test_gg_trace:Trace)
