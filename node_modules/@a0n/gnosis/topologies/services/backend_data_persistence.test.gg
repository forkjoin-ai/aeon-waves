// backend_data_persistence.test.gg — Verification harness for backend data persistence
(test_suite: TestSuite { name: 'backend_data_persistence' })

(firestore_client: Verify { module: './firestore_client.gg', beta1_max: '6' })
(user_profile_repository: Verify { module: './user_profile_repository.gg', beta1_max: '6' })
(log_repository: Verify { module: './log_repository.gg', beta1_max: '6' })

(test_suite)-[:FORK]->(firestore_client | user_profile_repository | log_repository)

(firestore_client)-[:RACE { expect: 'safe' }]->(firestore_client_res: Result)
(user_profile_repository)-[:RACE { expect: 'safe' }]->(user_profile_repository_res: Result)
(log_repository)-[:RACE { expect: 'safe' }]->(log_repository_res: Result)

(firestore_client_res | user_profile_repository_res | log_repository_res)-[:FOLD { strategy: 'all-pass' }]->(verdict: Verdict)
(verdict)-[:TUNNEL { condition: 'bounded-reject' }]->(backend_data_persistence_test_gg_trace:Trace)
(verdict)-[:MEASURE { reason: 'topology-audit' }]->(backend_data_persistence_test_gg_trace:Trace)
