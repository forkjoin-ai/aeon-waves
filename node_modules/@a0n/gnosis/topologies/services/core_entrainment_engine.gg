// core_entrainment_engine.gg — Binaural Entrainment Engine

(target_hz: Number)-[:FORK]->(left_ear: Audio | right_ear: Audio)
(left_ear | right_ear)-[:FOLD { strategy: 'stereo-mix' }]->(brainwave_sync: Output)
(brainwave_sync)-[:TUNNEL { condition: 'bounded-reject' }]->(core_entrainment_engine_gg_trace:Trace)
(brainwave_sync)-[:MEASURE { reason: 'topology-audit' }]->(core_entrainment_engine_gg_trace:Trace)
