// publisher_content_syndication.gg — Content Syndication for Aeon Publisher

(post: Article)-[:FORK]->(twitter: API | linkedin: API | blog: DB)
(twitter | linkedin | blog)-[:FOLD { strategy: 'all-settled' }]->(publish_receipt: Status)
(publish_receipt)-[:TUNNEL { condition: 'bounded-reject' }]->(publisher_content_syndication_gg_trace:Trace)
(publish_receipt)-[:MEASURE { reason: 'topology-audit' }]->(publisher_content_syndication_gg_trace:Trace)
