// agent_store_provisioner.gg — Agent Store Provisioning

(install: Cmd)-[:FORK]->(fetch_wasm: Net | alloc_storage: Disk)
(fetch_wasm | alloc_storage)-[:FOLD { strategy: 'all-ready' }]->(ready: Agent)
(ready)-[:TUNNEL { condition: 'bounded-reject' }]->(agent_store_provisioner_gg_trace:Trace)
(ready)-[:MEASURE { reason: 'topology-audit' }]->(agent_store_provisioner_gg_trace:Trace)
