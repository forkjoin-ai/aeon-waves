// grandfather_self_referential.gg — THM-SELF-REFERENTIAL-FOLD-IMPOSSIBLE witness
//
// A fold that would eliminate the root of its own causal chain
// is impossible. Both root and tip have positive existence weight.

(fold: SelfReferentialFold { theorem: 'THM-SELF-REFERENTIAL-FOLD-IMPOSSIBLE' })
(root: Event { name: 'ancestor', role: 'root', weight_positive: 'true' })
(tip: Event { name: 'traveler', role: 'tip', weight_positive: 'true' })
(attempt: FoldAttempt { target: 'root', goal: 'set weight to 0' })
(blocked: Impossibility { reason: 'buleyean_positivity: weight >= 1' })
(result: Result { theorem: 'self-referential-fold-impossible' })

(fold)-[:FORK]->(root | tip)
(root)-[:PROCESS { strategy: 'attempt-elimination' }]->(attempt)
(attempt)-[:PROCESS]->(blocked)
(blocked)-[:PROCESS { strategy: 'verify-impossibility' }]->(result)
