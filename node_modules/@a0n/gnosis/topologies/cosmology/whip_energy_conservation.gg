// whip_energy_conservation.gg — THM-WHIP-WAVE-DUALITY witness (total energy conserved)
//
// The total kinetic energy across all whip segments is conserved.
// Energy transfers from heavy base to light tip but the sum is constant.
// Example: E_base=4, E_mid1=3, E_mid2=2, E_tip=1. Total=10 before and after.

(whip: Whip { theorem: 'THM-WHIP-WAVE-DUALITY', segments: '4' })
(before: EnergyState { distribution: '[4, 3, 2, 1]', total: '10' })
(after: EnergyState { distribution: '[1, 2, 3, 4]', total: '10' })
(conservation: Invariant { claim: 'total_energy_conserved', before: '10', after: '10' })
(result: Result { theorem: 'energy-conserved' })

(whip)-[:FORK]->(before | after)
(before | after)-[:RACE { expect: 'energy-equal' }]->(conservation)
(conservation)-[:PROCESS { strategy: 'verify-equality' }]->(result)
(result)-[:MEASURE { reason: 'topology-audit' }]->(whip_energy_conservation_gg_trace:Trace)
