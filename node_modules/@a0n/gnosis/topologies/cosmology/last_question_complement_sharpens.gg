// last_question_complement_sharpens.gg — THM-LAST-QUESTION witness (complement distribution concentrates)
//
// As rounds progress, the complement distribution (over unresolved
// dimensions) concentrates: its entropy strictly decreases.
// Fewer unresolved dimensions means less uncertainty.
// Example: entropy=[2.32, 1.58, 1.0, 0] over 4 rounds.

(protocol: LastQuestionProtocol { theorem: 'THM-LAST-QUESTION', initial_deficit: '4' })
(round_1: ComplementState { round: '1', unresolved: '4', entropy_bits: '2.0' })
(round_2: ComplementState { round: '2', unresolved: '3', entropy_bits: '1.58' })
(round_3: ComplementState { round: '3', unresolved: '2', entropy_bits: '1.0' })
(round_4: ComplementState { round: '4', unresolved: '1', entropy_bits: '0' })
(sharpening: Invariant { claim: 'complement entropy strictly decreases', entropy_sequence: '[2.0, 1.58, 1.0, 0]' })
(result: Result { theorem: 'complement-distribution-concentrates' })

(protocol)-[:PROCESS]->(round_1)
(round_1)-[:PROCESS]->(round_2)
(round_2)-[:PROCESS]->(round_3)
(round_3)-[:PROCESS]->(round_4)
(round_1 | round_2 | round_3 | round_4)-[:RACE { expect: 'strictly-decreasing' }]->(sharpening)
(sharpening)-[:PROCESS { strategy: 'verify-ordering' }]->(result)
(result)-[:MEASURE { reason: 'topology-audit' }]->(last_question_complement_sharpens_gg_trace:Trace)
