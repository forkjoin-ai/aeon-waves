// whip_taper_speedup.gg — THM-WHIP-WAVE-DUALITY witness (taper accelerates tip)
//
// A tapered whip transfers energy from base to tip. As cross-section
// decreases, wave speed increases. The tip velocity exceeds the base.
// Example: base speed 1, taper ratio 4:1 -> tip speed 4.

(whip: Whip { theorem: 'THM-WHIP-WAVE-DUALITY', segments: '4', taper_ratio: '4' })
(base: Segment { id: 'base', cross_section: '4', speed: '1' })
(mid_1: Segment { id: 'mid-1', cross_section: '3', speed: '1.33' })
(mid_2: Segment { id: 'mid-2', cross_section: '2', speed: '2' })
(tip: Segment { id: 'tip', cross_section: '1', speed: '4' })
(speedup: Invariant { claim: 'tip_speed_gt_base_speed', base: '1', tip: '4' })
(result: Result { theorem: 'taper-accelerates-tip' })

(whip)-[:FORK]->(base | mid_1 | mid_2 | tip)
(base | mid_1 | mid_2 | tip)-[:RACE { expect: 'speed-increasing' }]->(speedup)
(speedup)-[:PROCESS { strategy: 'verify-inequality' }]->(result)
(result)-[:MEASURE { reason: 'topology-audit' }]->(whip_taper_speedup_gg_trace:Trace)
