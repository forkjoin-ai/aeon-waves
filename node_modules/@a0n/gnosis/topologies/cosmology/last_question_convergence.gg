// last_question_convergence.gg — THM-LAST-QUESTION witness (deficit reaches zero at d rounds)
//
// With initial deficit d, the protocol converges to zero deficit in
// exactly d rounds. After d rounds, all dimensions are resolved.
// Example: d=4, deficit=[4, 3, 2, 1, 0] -> zero at round 4.

(protocol: LastQuestionProtocol { theorem: 'THM-LAST-QUESTION', initial_deficit: '4' })
(round_0: Round { id: '0', deficit: '4' })
(round_1: Round { id: '1', deficit: '3' })
(round_2: Round { id: '2', deficit: '2' })
(round_3: Round { id: '3', deficit: '1' })
(round_4: Round { id: '4', deficit: '0' })
(convergence: Invariant { claim: 'deficit reaches zero at round d', initial_deficit: '4', final_round: '4', final_deficit: '0' })
(result: Result { theorem: 'convergence-at-d-rounds' })

(protocol)-[:PROCESS]->(round_0)
(round_0)-[:PROCESS]->(round_1)
(round_1)-[:PROCESS]->(round_2)
(round_2)-[:PROCESS]->(round_3)
(round_3)-[:PROCESS]->(round_4)
(round_4)-[:PROCESS { expect: 'deficit-is-zero' }]->(convergence)
(convergence)-[:PROCESS { strategy: 'verify-zero' }]->(result)
