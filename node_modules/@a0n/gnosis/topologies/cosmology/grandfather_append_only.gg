// grandfather_append_only.gg — THM-VOID-APPEND-ONLY witness
//
// Once an event is recorded in the void boundary, it cannot be removed.
// The ancestor's existence is a permanent fact.

(chain: CausalChain { theorem: 'THM-VOID-APPEND-ONLY', events: '3' })
(ancestor: Event { name: 'ancestor', weight: '1', recorded: 'true' })
(parent: Event { name: 'parent', weight: '1', recorded: 'true' })
(traveler: Event { name: 'traveler', weight: '1', recorded: 'true' })
(boundary: VoidBoundary { entries: '[ancestor, parent, traveler]', append_only: 'true' })
(invariant: Invariant { claim: 'all events recorded, none removable' })
(result: Result { theorem: 'void-boundary-append-only' })

(chain)-[:FORK]->(ancestor | parent | traveler)
(ancestor | parent | traveler)-[:PROCESS]->(boundary)
(boundary)-[:PROCESS { expect: 'append-only-verified' }]->(invariant)
(invariant)-[:PROCESS { strategy: 'verify-permanence' }]->(result)
