// wallace_complement.gg — THM-WALLACE witness (frontier + waste = envelope)
//
// The Wallace decomposition: the total envelope of a pipeline equals
// the productive frontier plus the waste. E = F + W.
// This is a conservation law -- nothing is created or destroyed.
// Example: envelope=10, frontier=7, waste=3 -> 7 + 3 = 10.

(pipeline: WallacePipeline { theorem: 'THM-WALLACE', stages: '4' })
(envelope: Envelope { value: '10', unit: 'throughput' })
(frontier: Frontier { value: '7', unit: 'throughput' })
(waste: Waste { value: '3', unit: 'throughput' })
(conservation: Invariant { claim: 'frontier + waste = envelope', frontier: '7', waste: '3', envelope: '10', holds: 'true' })
(result: Result { theorem: 'frontier-waste-envelope-conservation' })

(pipeline)-[:FORK]->(frontier | waste)
(frontier | waste)-[:RACE { expect: 'sum-computed' }]->(conservation)
(conservation)-[:PROCESS { strategy: 'verify-equality' }]->(envelope)
(envelope)-[:PROCESS]->(result)
(result)-[:MEASURE { reason: 'topology-audit' }]->(wallace_complement_gg_trace:Trace)
