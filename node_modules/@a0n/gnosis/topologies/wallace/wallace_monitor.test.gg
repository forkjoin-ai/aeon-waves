// wallace_monitor.test.gg
// Formal harness for the Wallace boundary-walker monitor topologies.

(test_suite: TestSuite { name: "wallace-monitor" })
(aligned_monitor: Verify { module: "./wallace_monitor.gg", beta1_max: "8" })
(drifted_monitor: Verify { module: "./wallace_monitor_drift.gg", beta1_max: "8" })

(test_suite)-[:FORK]->(aligned_monitor | drifted_monitor)
(aligned_monitor | drifted_monitor)-[:FOLD { strategy: "all-pass" }]->(verdict:Verdict)
(verdict)-[:TUNNEL { condition: 'bounded-reject' }]->(wallace_monitor_test_gg_trace:Trace)
(verdict)-[:MEASURE { reason: 'topology-audit' }]->(wallace_monitor_test_gg_trace:Trace)
