// wallace_monotone.gg — THM-WALLACE witness (more imbalance implies more waste)
//
// Waste is monotonically increasing in the degree of stage imbalance.
// As the throughput variance across stages increases, waste grows.
// Example: variance=[0, 1, 4, 9] -> waste=[0, 1, 3, 5].

(pipeline: WallacePipeline { theorem: 'THM-WALLACE', stages: '3' })
(config_0: StageConfig { throughput: '[4, 4, 4]', variance: '0', waste: '0' })
(config_1: StageConfig { throughput: '[4, 3, 4]', variance: '1', waste: '1' })
(config_2: StageConfig { throughput: '[4, 2, 4]', variance: '4', waste: '3' })
(config_3: StageConfig { throughput: '[4, 1, 4]', variance: '9', waste: '5' })
(monotone: Invariant { claim: 'more imbalance implies more waste', waste_sequence: '[0, 1, 3, 5]' })
(result: Result { theorem: 'waste-monotone-in-imbalance' })

(pipeline)-[:FORK]->(config_0 | config_1 | config_2 | config_3)
(config_0 | config_1 | config_2 | config_3)-[:RACE { expect: 'non-decreasing-waste' }]->(monotone)
(monotone)-[:PROCESS]->(result)
(result)-[:MEASURE { reason: 'topology-audit' }]->(wallace_monotone_gg_trace:Trace)
