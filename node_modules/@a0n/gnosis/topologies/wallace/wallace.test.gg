// wallace.test.gg — Native Gnosis witnesses for THM-WALLACE
//
// These theorem-shaped `.gg` modules cover:
//   - waste=0 iff balanced stages
//   - frontier + waste = envelope
//   - more imbalance implies more waste (monotone)

(test_suite: TestSuite { name: 'wallace' })

(zero_iff_balanced: Verify { module: './wallace_zero_iff_balanced.gg', beta1_max: '6' })
(complement: Verify { module: './wallace_complement.gg', beta1_max: '6' })
(monotone: Verify { module: './wallace_monotone.gg', beta1_max: '6' })

(test_suite)-[:FORK]->(zero_iff_balanced | complement | monotone)

(zero_iff_balanced)-[:RACE { expect: 'safe' }]->(balanced_result: Result)
(complement)-[:RACE { expect: 'safe' }]->(complement_result: Result)
(monotone)-[:RACE { expect: 'safe' }]->(monotone_result: Result)

(balanced_result | complement_result | monotone_result)-[:FOLD { strategy: 'all-pass' }]->(verdict: Verdict)
(verdict)-[:TUNNEL { condition: 'bounded-reject' }]->(wallace_test_gg_trace:Trace)
(verdict)-[:MEASURE { reason: 'topology-audit' }]->(wallace_test_gg_trace:Trace)
