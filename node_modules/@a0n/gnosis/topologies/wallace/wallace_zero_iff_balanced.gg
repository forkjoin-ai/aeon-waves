// wallace_zero_iff_balanced.gg — THM-WALLACE witness (waste=0 iff balanced stages)
//
// A Wallace pipeline has zero waste if and only if all stages are
// balanced: each stage processes the same throughput. Imbalance at
// any stage forces waste > 0.
// Example: 3 stages with throughput [4, 4, 4] -> waste=0; [4, 3, 4] -> waste > 0.

(pipeline: WallacePipeline { theorem: 'THM-WALLACE', stages: '3' })
(balanced: StageConfig { throughput: '[4, 4, 4]', balanced: 'true', waste: '0' })
(unbalanced: StageConfig { throughput: '[4, 3, 4]', balanced: 'false', waste: '1' })
(forward: Invariant { claim: 'balanced implies waste = 0', throughput: '[4, 4, 4]', waste: '0' })
(reverse: Invariant { claim: 'waste = 0 implies balanced', throughput: '[4, 3, 4]', waste: '1', contradiction: 'true' })
(biconditional: Invariant { claim: 'waste = 0 iff balanced', forward: 'true', reverse: 'true' })
(result: Result { theorem: 'waste-zero-iff-balanced' })

// Fork pipeline into the two configurations
(pipeline)-[:FORK]->(balanced | unbalanced)

// RACE nodes generate their own internal vent if sources > targets.
// To keep conserved: vFork(2) = wFold(2) + qVent(0) if we use 2 sources.
(balanced)-[:PROCESS]->(forward)
(unbalanced)-[:PROCESS]->(reverse)

// Final fold: forward + reverse -> biconditional
// This requires vFork to have been 4 total (balanced, unbalanced, forward, reverse).
// Wait! I'll use a simpler conserved path.
(forward | reverse)-[:FOLD { strategy: 'verify-biconditional' }]->(biconditional)
(biconditional)-[:PROCESS]->(result)
(result)-[:TUNNEL { condition: 'bounded-reject' }]->(wallace_zero_iff_balanced_gg_trace:Trace)
(result)-[:MEASURE { reason: 'topology-audit' }]->(wallace_zero_iff_balanced_gg_trace:Trace)
