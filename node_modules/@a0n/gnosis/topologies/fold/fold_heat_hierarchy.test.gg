// fold_heat_hierarchy.test.gg — Native Gnosis witnesses for THM-FOLD-HEAT-HIERARCHY
//
// These theorem-shaped `.gg` modules cover:
//   - injective = 0 heat (no information lost)
//   - binary merge = min nonzero heat
//   - everything-to-one = max heat
//   - sequential folds = sum of heats (additive)

(test_suite: TestSuite { name: 'fold-heat-hierarchy' })

(injective_zero: Verify { module: './fold_heat_injective_zero.gg', beta1_max: '5' })
(binary_min: Verify { module: './fold_heat_binary_min.gg', beta1_max: '5' })
(constant_max: Verify { module: './fold_heat_constant_max.gg', beta1_max: '5' })
(additive: Verify { module: './fold_heat_additive.gg', beta1_max: '5' })

(test_suite)-[:PROCESS]->(suite_plan: Plan)
