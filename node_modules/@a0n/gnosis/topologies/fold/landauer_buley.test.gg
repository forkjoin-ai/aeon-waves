// landauer_buley.test.gg — Native Gnosis witnesses for THM-LANDAUER-BULEY
//
// These theorem-shaped `.gg` modules cover:
//   - finite entropy is non-negative (finite entropy)
//   - non-injective map implies positive heat (heat positive)
//   - frontier of N implies failure tax of N-1 (failure tax)

(test_suite: TestSuite { name: 'landauer-buley' })

(finite_entropy: Verify { module: './landauer_finite_entropy.gg', beta1_max: '5' })
(heat_positive: Verify { module: './landauer_heat_positive.gg', beta1_max: '5' })
(failure_tax: Verify { module: './landauer_failure_tax.gg', beta1_max: '5' })

(test_suite)-[:FORK]->(finite_entropy | heat_positive | failure_tax)

(finite_entropy)-[:RACE { expect: 'safe' }]->(entropy_result: Result)
(heat_positive)-[:RACE { expect: 'safe' }]->(heat_result: Result)
(failure_tax)-[:RACE { expect: 'safe' }]->(tax_result: Result)

(entropy_result | heat_result | tax_result)-[:FOLD { strategy: 'all-pass' }]->(verdict: Verdict)
(verdict)-[:TUNNEL { condition: 'bounded-reject' }]->(landauer_buley_test_gg_trace:Trace)
(verdict)-[:MEASURE { reason: 'topology-audit' }]->(landauer_buley_test_gg_trace:Trace)
