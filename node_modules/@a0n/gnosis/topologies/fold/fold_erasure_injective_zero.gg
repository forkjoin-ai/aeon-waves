// fold_erasure_injective_zero.gg — THM-FOLD-ERASURE witness (injective implies zero info loss)
//
// An injective fold preserves all input distinctions. No two inputs
// map to the same output, so no information is erased. Info loss = 0.
// Example: 3 inputs -> 3 outputs, each unique. Zero erasure.

(fold_op: FoldOperator { theorem: 'THM-FOLD-ERASURE', type: 'injective', inputs: '3', outputs: '3' })
(input_a: FoldInput { id: 'A', value: '10', maps_to: '1' })
(input_b: FoldInput { id: 'B', value: '20', maps_to: '2' })
(input_c: FoldInput { id: 'C', value: '30', maps_to: '3' })
(output_1: FoldOutput { id: '1', sources: '[A]', count: '1' })
(output_2: FoldOutput { id: '2', sources: '[B]', count: '1' })
(output_3: FoldOutput { id: '3', sources: '[C]', count: '1' })
(info_loss: Invariant { claim: 'injective implies info_loss = 0', loss_bits: '0', collisions: '0' })
(result: Result { theorem: 'injective-zero-info-loss' })

(fold_op)-[:FORK]->(input_a | input_b | input_c)
(input_a)-[:PROCESS { strategy: 'injective' }]->(output_1)
(input_b)-[:PROCESS { strategy: 'injective' }]->(output_2)
(input_c)-[:PROCESS { strategy: 'injective' }]->(output_3)
(output_1 | output_2 | output_3)-[:RACE { expect: 'no-collisions' }]->(info_loss)
(info_loss)-[:PROCESS { strategy: 'verify-zero' }]->(result)
(result)-[:MEASURE { reason: 'topology-audit' }]->(fold_erasure_injective_zero_gg_trace:Trace)
