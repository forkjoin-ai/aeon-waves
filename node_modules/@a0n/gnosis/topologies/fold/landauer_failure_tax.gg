// landauer_failure_tax.gg — THM-LANDAUER-BULEY witness (frontier N implies failure tax N-1)
//
// A computation frontier with N candidate paths must vent N-1 paths
// to select a single survivor. Each vented path is an irreversible
// erasure. The failure tax = N-1 erasure events.
// Example: N=5 frontier -> 4 paths vented, failure_tax = 4.

(frontier: ComputationFrontier { theorem: 'THM-LANDAUER-BULEY', candidates: '5' })
(candidate_1: Branch { id: '1', survives: 'true' })
(candidate_2: Branch { id: '2', survives: 'false' })
(candidate_3: Branch { id: '3', survives: 'false' })
(candidate_4: Branch { id: '4', survives: 'false' })
(candidate_5: Branch { id: '5', survives: 'false' })
(vented: VentedPaths { count: '4', ids: '[2, 3, 4, 5]' })
(failure_tax: Invariant { claim: 'failure_tax = N - 1', N: '5', tax: '4', formula: '5 - 1 = 4' })
(result: Result { theorem: 'frontier-failure-tax' })

(frontier)-[:FORK]->(candidate_1 | candidate_2 | candidate_3 | candidate_4 | candidate_5)
(candidate_2)-[:VENT { condition: 'not-selected' }]->(vent_2: VentedPath)
(candidate_3)-[:VENT { condition: 'not-selected' }]->(vent_3: VentedPath)
(candidate_4)-[:VENT { condition: 'not-selected' }]->(vent_4: VentedPath)
(candidate_5)-[:VENT { condition: 'not-selected' }]->(vent_5: VentedPath)
(candidate_1)-[:PROCESS { strategy: 'single-survivor' }]->(survivor: Survivor)
(vent_2 | vent_3 | vent_4 | vent_5)-[:FOLD { strategy: 'count-vented' }]->(vented)
(vented)-[:PROCESS { expect: 'tax-equals-N-minus-1' }]->(failure_tax)
(failure_tax)-[:PROCESS { strategy: 'verify-equality' }]->(result)
(result)-[:MEASURE { reason: 'topology-audit' }]->(landauer_failure_tax_gg_trace:Trace)
