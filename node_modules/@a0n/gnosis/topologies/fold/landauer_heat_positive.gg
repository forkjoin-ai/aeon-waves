// landauer_heat_positive.gg — THM-LANDAUER-BULEY witness (non-injective implies positive heat)
//
// A non-injective computation erases information. By Landauer's principle,
// each erased bit dissipates kT*ln(2) heat. The Buley extension: this
// heat is the irreducible cost of choosing one path over alternatives.
// Example: 6 states -> 2 states, erased = log2(3) = 1.58 bits per output.

(computation: Computation { theorem: 'THM-LANDAUER-BULEY', type: 'non-injective' })
(input_space: StateSpace { cardinality: '6', entropy_bits: '2.58' })
(output_space: StateSpace { cardinality: '2', entropy_bits: '1' })
(erasure: ErasureEvent { bits_erased: '1.58', temperature_K: '300' })
(heat: HeatDissipation { minimum_joules: '4.54e-21', formula: '1.58 * kT * ln(2)' })
(positivity: Invariant { claim: 'non-injective -> heat > 0', erased_bits: '1.58', heat: '4.54e-21' })
(result: Result { theorem: 'noninjective-positive-heat' })

(computation)-[:FORK]->(input_space | output_space)
(input_space)-[:PROCESS { strategy: 'non-injective-map' }]->(output_space)
(output_space)-[:PROCESS]->(erasure)
(erasure)-[:PROCESS { expect: 'heat-computed' }]->(heat)
(heat)-[:PROCESS]->(positivity)
(positivity)-[:PROCESS { strategy: 'verify-positive' }]->(result)
