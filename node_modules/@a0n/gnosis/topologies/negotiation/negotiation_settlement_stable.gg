// negotiation_settlement_stable.gg — THM-SETTLEMENT-STABILITY witness
//
// A settlement tolerates perturbation: one additional rejection
// changes any weight by at most 1. The settlement is Lyapunov-stable.

(settlement: Settlement { theorem: 'THM-SETTLEMENT-STABILITY', terms: '3', rounds: '10' })
(agreed_weights: WeightVector { values: '[8, 4, 6]', description: 'at settlement' })
(perturbation: Perturbation { term: 'price', additional_rejections: '1' })
(perturbed_weights: WeightVector { values: '[7, 4, 6]', description: 'after perturbation' })
(lipschitz: Invariant { claim: '|agreed - perturbed| <= 1', max_change: '1' })
(still_positive: Invariant { claim: 'all perturbed weights >= 1' })
(result: Result { theorem: 'settlement-lyapunov-stable' })

(settlement)-[:FORK]->(agreed_weights | perturbation)
(perturbation)-[:PROCESS]->(perturbed_weights)
(agreed_weights | perturbed_weights)-[:RACE { expect: 'bounded-change' }]->(lipschitz)
(lipschitz)-[:PROCESS]->(still_positive)
(still_positive)-[:PROCESS { strategy: 'verify-stability' }]->(result)
(result)-[:MEASURE { reason: 'topology-audit' }]->(negotiation_settlement_stable_gg_trace:Trace)
