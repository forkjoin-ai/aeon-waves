// negotiation_deficit_positive.gg — THM-NEGOTIATION-DEFICIT witness
//
// Party A: 5 interest dimensions. Party B: 4 interest dimensions.
// Single offer stream. Deficit = 5 + 4 - 1 = 8.
// Negotiations are hard because the channel is narrower than the interests.

(channel: NegotiationChannel { theorem: 'THM-NEGOTIATION-DEFICIT', partyA_dims: '5', partyB_dims: '4', streams: '1' })
(party_a: Party { name: 'Buyer', dimensions: '5' })
(party_b: Party { name: 'Seller', dimensions: '4' })
(offer_stream: Stream { width: '1' })
(deficit: Deficit { value: '8', formula: '5 + 4 - 1' })
(result: Result { theorem: 'negotiation-deficit-positive' })

(channel)-[:FORK]->(party_a | party_b)
(party_a | party_b)-[:FOLD { strategy: 'single-stream', streams: '1' }]->(offer_stream)
(offer_stream)-[:PROCESS]->(deficit)
(deficit)-[:PROCESS]->(result)
(result)-[:TUNNEL { condition: 'bounded-reject' }]->(negotiation_deficit_positive_gg_trace:Trace)
(result)-[:MEASURE { reason: 'topology-audit' }]->(negotiation_deficit_positive_gg_trace:Trace)
