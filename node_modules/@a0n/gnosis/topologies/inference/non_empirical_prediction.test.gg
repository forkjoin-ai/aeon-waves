// non_empirical_prediction.test.gg — Native Gnosis witnesses for THM-NON-EMPIRICAL-PREDICTION
//
// These theorem-shaped `.gg` modules cover:
//   - holes have positive weight (absence is evidence)
//   - structure beats guessing (informed dominates uninformed)
//   - interpolation = complement (Mendeleev prediction)
//   - same lattice = same prediction (coherence)

(test_suite: TestSuite { name: 'non-empirical-prediction' })

(hole_positive: Verify { module: './nei_hole_positive.gg', beta1_max: '5' })
(dominates_uninformed: Verify { module: './nei_dominates_uninformed.gg', beta1_max: '5' })
(mendeleev: Verify { module: './nei_mendeleev.gg', beta1_max: '5' })
(coherent: Verify { module: './nei_coherent.gg', beta1_max: '5' })

(test_suite)-[:PROCESS]->(suite_plan: Plan)
