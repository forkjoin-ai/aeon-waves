// teleportation_concentration.gg — THM-STATISTICAL-TELEPORTATION witness (rejection sharpens teleport)
//
// Applying rejection sampling to the teleported distribution
// concentrates it closer to the target. Each rejection round
// reduces the KL divergence between teleport and target.
// Example: KL before = 0.5, after 1 rejection = 0.3, after 2 = 0.1.

(teleport: StatTeleport { theorem: 'THM-STATISTICAL-TELEPORTATION', rejections: '2' })
(round_0: TeleportState { round: '0', kl_divergence: '0.5' })
(round_1: TeleportState { round: '1', kl_divergence: '0.3' })
(round_2: TeleportState { round: '2', kl_divergence: '0.1' })
(concentration: Invariant { claim: 'rejection_reduces_kl', kl_0: '0.5', kl_2: '0.1' })
(result: Result { theorem: 'rejection-sharpens-teleport' })

(teleport)-[:FORK]->(round_0 | round_1 | round_2)
(round_0)-[:PROCESS]->(round_1)
(round_1)-[:PROCESS]->(round_2)
(round_0 | round_2)-[:RACE { expect: 'kl-decreasing' }]->(concentration)
(concentration)-[:PROCESS { strategy: 'verify-inequality' }]->(result)
(result)-[:MEASURE { reason: 'topology-audit' }]->(teleportation_concentration_gg_trace:Trace)
