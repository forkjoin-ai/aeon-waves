// retrocausal_count_recovery.gg — THM-RETROCAUSAL-BOUND witness (terminal determines trajectory)
//
// Given a terminal state (final void boundary), the entire trajectory of
// rejection counts can be recovered backward. The terminal state is a
// sufficient statistic for the path that produced it.

(process: RetrocausalProcess { theorem: 'THM-RETROCAUSAL-BOUND', choices: '3', rounds: '5' })
(terminal: TerminalState { void_counts: '[2, 4, 1]', total_rounds: '5' })
(trajectory_step_5: TrajectoryStep { step: '5', counts: '[2, 4, 1]' })
(trajectory_step_4: TrajectoryStep { step: '4', counts: '[2, 3, 1]' })
(trajectory_step_3: TrajectoryStep { step: '3', counts: '[1, 3, 1]' })
(trajectory_step_2: TrajectoryStep { step: '2', counts: '[1, 2, 0]' })
(trajectory_step_1: TrajectoryStep { step: '1', counts: '[0, 1, 0]' })
(recovery: Invariant { claim: 'terminal uniquely determines backward path', steps_recovered: '5' })
(result: Result { theorem: 'terminal-determines-trajectory' })

(process)-[:PROCESS]->(terminal)
(terminal)-[:PROCESS { expect: 'backward-trace' }]->(trajectory_step_5)
(trajectory_step_5)-[:PROCESS]->(trajectory_step_4)
(trajectory_step_4)-[:PROCESS]->(trajectory_step_3)
(trajectory_step_3)-[:PROCESS]->(trajectory_step_2)
(trajectory_step_2)-[:PROCESS]->(trajectory_step_1)
(trajectory_step_1)-[:PROCESS { strategy: 'verify-complete-recovery' }]->(recovery)
(recovery)-[:PROCESS]->(result)
