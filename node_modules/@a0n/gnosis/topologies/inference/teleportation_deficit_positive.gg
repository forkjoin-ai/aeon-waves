// teleportation_deficit_positive.gg — THM-STATISTICAL-TELEPORTATION witness (teleport deficit > 0)
//
// Statistical teleportation always incurs a positive deficit.
// The teleported distribution cannot perfectly match the target;
// some information is lost in the boundary crossing.
// Example: source entropy 5, target entropy 4, deficit = 1 > 0.

(teleport: StatTeleport { theorem: 'THM-STATISTICAL-TELEPORTATION', source_entropy: '5', target_entropy: '4' })
(source: Distribution { id: 'source', entropy: '5' })
(target: Distribution { id: 'target', entropy: '4' })
(deficit: TeleportDeficit { value: '1', positive: 'true' })
(invariant: Invariant { claim: 'teleport_deficit_positive', deficit: '1' })
(result: Result { theorem: 'deficit-positive' })

(teleport)-[:FORK]->(source | target)
(source | target)-[:RACE { expect: 'deficit-computed' }]->(deficit)
(deficit)-[:PROCESS]->(invariant)
(invariant)-[:PROCESS { strategy: 'verify-positive' }]->(result)
(result)-[:MEASURE { reason: 'topology-audit' }]->(teleportation_deficit_positive_gg_trace:Trace)
