// retrocausal_ordering.gg — THM-RETROCAUSAL-BOUND witness (ordering preserved backward)
//
// If choice A was rejected more than choice B at termination,
// then A was rejected more at every prior step where both existed.
// The dominance ordering is monotone under backward inference.

(space: RetrocausalSpace { theorem: 'THM-RETROCAUSAL-BOUND', choices: '3', rounds: '8' })
(terminal: TerminalState { void_counts: '[6, 3, 1]' })
(step_8: Snapshot { step: '8', counts: '[6, 3, 1]', order: 'A > B > C' })
(step_5: Snapshot { step: '5', counts: '[4, 2, 1]', order: 'A > B > C' })
(step_2: Snapshot { step: '2', counts: '[2, 1, 0]', order: 'A > B > C' })
(monotone: Invariant { claim: 'rejection ordering preserved at all steps', order: 'A > B > C' })
(result: Result { theorem: 'ordering-preserved-backward' })

(terminal)-[:FORK]->(step_8 | step_5 | step_2)
(step_8 | step_5 | step_2)-[:RACE { expect: 'ordering-consistent' }]->(monotone)
(monotone)-[:PROCESS { strategy: 'verify-ordering' }]->(result)
(result)-[:MEASURE { reason: 'topology-audit' }]->(retrocausal_ordering_gg_trace:Trace)
