// retrocausal_bound.test.gg — Native Gnosis witnesses for THM-RETROCAUSAL-BOUND
//
// These theorem-shaped `.gg` modules cover:
//   - terminal determines trajectory (count recovery)
//   - ordering preserved backward (retrocausal ordering)
//   - all terminal weights positive (positivity)
//   - same terminal = same inference (coherence)

(test_suite: TestSuite { name: 'retrocausal-bound' })

(count_recovery: Verify { module: './retrocausal_count_recovery.gg', beta1_max: '6' })
(ordering: Verify { module: './retrocausal_ordering.gg', beta1_max: '6' })
(positive: Verify { module: './retrocausal_positive.gg', beta1_max: '6' })
(coherence: Verify { module: './retrocausal_coherence.gg', beta1_max: '6' })

(test_suite)-[:FORK]->(count_recovery | ordering | positive | coherence)

(count_recovery)-[:RACE { expect: 'safe' }]->(recovery_result: Result)
(ordering)-[:RACE { expect: 'safe' }]->(order_result: Result)
(positive)-[:RACE { expect: 'safe' }]->(pos_result: Result)
(coherence)-[:RACE { expect: 'safe' }]->(coher_result: Result)

(recovery_result | order_result | pos_result | coher_result)-[:FOLD { strategy: 'all-pass' }]->(verdict: Verdict)
(verdict)-[:TUNNEL { condition: 'bounded-reject' }]->(retrocausal_bound_test_gg_trace:Trace)
(verdict)-[:MEASURE { reason: 'topology-audit' }]->(retrocausal_bound_test_gg_trace:Trace)
