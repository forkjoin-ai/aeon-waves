// dpi_nonincrease.gg — THM-DATA-PROCESSING-INEQUALITY witness (processing cannot increase info)
//
// For any Markov chain X -> Y -> Z, mutual information satisfies
// I(X; Z) <= I(X; Y). Processing through Y cannot create new
// information about X. Each stage can only preserve or lose.
// Example: I(X;Y)=3.0 bits, after processing I(X;Z)=2.1 bits <= 3.0.

(chain: MarkovChain { theorem: 'THM-DATA-PROCESSING-INEQUALITY', stages: '3' })
(source: Variable { name: 'X', entropy_bits: '4.0' })
(intermediate: Variable { name: 'Y', mutual_info_XY: '3.0' })
(output: Variable { name: 'Z', mutual_info_XZ: '2.1' })
(inequality: Invariant { claim: 'I(X;Z) <= I(X;Y)', lhs: '2.1', rhs: '3.0', holds: 'true' })
(result: Result { theorem: 'processing-cannot-increase-info' })

(chain)-[:PROCESS]->(source)
(source)-[:PROCESS]->(intermediate)
(intermediate)-[:PROCESS]->(output)
(source | intermediate | output)-[:RACE { expect: 'inequality-holds' }]->(inequality)
(inequality)-[:PROCESS { strategy: 'verify-leq' }]->(result)
(result)-[:MEASURE { reason: 'topology-audit' }]->(dpi_nonincrease_gg_trace:Trace)
