// dpi_identity_preserves.gg — THM-DATA-PROCESSING-INEQUALITY witness (identity preserves all info)
//
// The identity function is injective (bijective). It maps each input
// to itself, losing no information. I(X; id(X)) = H(X).
// Example: 8 states, identity map -> I(X;Y) = 3.0 = H(X). Zero loss.

(chain: MarkovChain { theorem: 'THM-DATA-PROCESSING-INEQUALITY', type: 'identity' })
(input_space: StateSpace { cardinality: '8', entropy_bits: '3.0' })
(identity_map: ProcessingStep { type: 'identity', input_card: '8', output_card: '8', ratio: '1:1' })
(output_space: StateSpace { cardinality: '8', entropy_bits: '3.0' })
(preservation: Invariant { claim: 'identity preserves all info', info_before: '3.0', info_after: '3.0', lost: '0' })
(result: Result { theorem: 'identity-preserves-info' })

(chain)-[:PROCESS]->(input_space)
(input_space)-[:PROCESS]->(identity_map)
(identity_map)-[:PROCESS]->(output_space)
(input_space | output_space)-[:RACE { expect: 'info-preserved' }]->(preservation)
(preservation)-[:PROCESS { strategy: 'verify-equality' }]->(result)
(result)-[:MEASURE { reason: 'topology-audit' }]->(dpi_identity_preserves_gg_trace:Trace)
