// forgo_cloud_playwright_paths.gg -- browser test path topology for forgo.cloud
// Each path maps a verified user story to a future Playwright spec.

(path_root: Source { suite: 'forgo_cloud_playwright_paths' })

(path_onboard: PlaywrightPath { story: 'onboard-workspace', spec: 'onboard-workspace.spec.ts', start: '/', end: '/ide/:owner/:repo' })
(path_scan_public_url: PlaywrightPath { story: 'scan-public-url', spec: 'scan-public-url.spec.ts', start: '/scanner', api: 'POST /api/scans/public-url' })
(path_repo_to_ide: PlaywrightPath { story: 'repo-to-ide', spec: 'repo-to-ide.spec.ts', start: '/:owner/:repo', end: '/ide/:owner/:repo' })
(path_review_trace: PlaywrightPath { story: 'review-trace', spec: 'review-trace.spec.ts', start: '/:owner/:repo', end: '/runs/:runId' })
(path_control_delivery: PlaywrightPath { story: 'control-delivery', spec: 'control-delivery.spec.ts', start: '/orchestration', end: '/cd' })
(path_promote_canary: PlaywrightPath { story: 'promote-canary', spec: 'promote-canary.spec.ts', start: '/cd', api: 'POST /api/projects/:projectId/canary/promote' })
(path_manage_org: PlaywrightPath { story: 'manage-org', spec: 'manage-org.spec.ts', start: '/members', end: '/settings' })
(path_verify_trust: PlaywrightPath { story: 'verify-trust', spec: 'verify-trust.spec.ts', start: '/audit', end: '/nexus' })
(path_handle_notifications: PlaywrightPath { story: 'handle-notifications', spec: 'handle-notifications.spec.ts', start: '/notifications', api: 'POST /api/notifications/:id/read' })
(path_recover_errors: PlaywrightPath { story: 'recover-errors', spec: 'recover-errors.spec.ts', start: '*', assertion: 'recoverable error state visible' })

(path_root)-[:FORK]->(
  path_onboard | path_scan_public_url | path_repo_to_ide |
  path_review_trace | path_control_delivery | path_promote_canary |
  path_manage_org | path_verify_trust | path_handle_notifications |
  path_recover_errors
)

(
  path_onboard | path_scan_public_url | path_repo_to_ide |
  path_review_trace | path_control_delivery | path_promote_canary |
  path_manage_org | path_verify_trust | path_handle_notifications |
  path_recover_errors
)-[:FOLD { strategy: 'all-playwright-paths-covered' }]->(playwright_path_coverage_complete: Sink)
(playwright_path_coverage_complete)-[:TUNNEL { condition: 'bounded-reject' }]->(forgo_cloud_playwright_paths_gg_trace:Trace)
(playwright_path_coverage_complete)-[:MEASURE { reason: 'topology-audit' }]->(forgo_cloud_playwright_paths_gg_trace:Trace)
