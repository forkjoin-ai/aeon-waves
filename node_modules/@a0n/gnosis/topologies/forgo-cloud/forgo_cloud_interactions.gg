// forgo_cloud_interactions.gg -- click and user-flow topology for Forgo.zip
// Every clickable prototype affordance must land on a screen, feedback state,
// or declared future API contract before implementation.

(interaction_source: Source)
(interaction_trace: Trace)
(interaction_user_path: Trace)
(interaction_root: Trace { void_density: '1' })
(user: User)
(toast_feedback: Feedback { kind: 'toast' })

// Flow roots keep interactions acyclic: screen destinations are outcomes, not
// additional dispatch points.
(onboarding_flow: Flow { name: 'onboarding' })
(repo_workspace_flow: Flow { name: 'repo workspace' })
(delivery_flow: Flow { name: 'delivery' })
(admin_social_flow: Flow { name: 'admin social' })
(command_flow: Flow { name: 'command palette' })
(auth_flow: Flow { name: 'auth' })
(interaction_rejected: Feedback { reason: 'invalid or unavailable interaction path' })

(interaction_source)-[:PROCESS { strategy: 'prototype-affordance-scan' }]->(interaction_user_path)
(interaction_user_path)-[:PROCESS]->(interaction_trace)
(interaction_trace)-[:PROCESS { strategy: 'validated-affordance-inventory' }]->(interaction_root)
(interaction_root)-[:PROCESS]->(user)
(interaction_root)-[:PROCESS { condition: 'invalid-or-unavailable-path' }]->(interaction_rejected)
(user)-[:PROCESS]->(onboarding_flow)
(onboarding_flow)-[:PROCESS]->(repo_workspace_flow)
(repo_workspace_flow)-[:PROCESS]->(delivery_flow)
(delivery_flow)-[:PROCESS]->(admin_social_flow)
(admin_social_flow)-[:PROCESS]->(command_flow)
(command_flow)-[:PROCESS]->(auth_flow)

// Primary onboarding funnel
(open_workspace: Click { label: 'open workspace' })
(start_workspace: Click { label: 'start free workspace' })
(install_cli: Click { label: 'curl install' })
(scan_public_url: Click { label: 'scan public URL' })
(enable_repo_scan: Click { label: 'enable on a repo' })
(deploy_first_fold: Click { label: 'deploy first fold' })

(open_workspace)-[:PROCESS]->(ide_target: Target { screen: 'ide' })
(start_workspace)-[:PROCESS]->(import_target: Target { screen: 'import' })
(install_cli)-[:PROCESS]->(scanner_target: Target { screen: 'scanner' })
(scan_public_url)-[:PROCESS]->(scanner_scan_contract: ApiNeed { endpoint: 'POST /api/scans/public-url' })
(enable_repo_scan)-[:PROCESS]->(import_target)
(deploy_first_fold)-[:PROCESS]->(orchestration_target: Target { screen: 'orchestration' })
(onboarding_flow)-[:PROCESS]->(open_workspace)
(onboarding_flow)-[:PROCESS]->(start_workspace)
(onboarding_flow)-[:PROCESS]->(install_cli)
(onboarding_flow)-[:PROCESS]->(scan_public_url)
(onboarding_flow)-[:PROCESS]->(enable_repo_scan)
(onboarding_flow)-[:PROCESS]->(deploy_first_fold)

// Repo/workspace interactions
(star_repo: Click { label: 'star repo' })
(fork_repo: Click { label: 'fork repo' })
(repo_open_workspace: Click { label: 'repo open workspace' })
(view_trace: Click { label: 'view trace' })
(auto_fix_preview: Click { label: 'auto-fix preview' })
(commit_button: Click { label: 'commit' })
(forge_fold_button: Click { label: 'forge fold' })

(star_repo)-[:PROCESS]->(toast_feedback)
(fork_repo)-[:PROCESS]->(toast_feedback)
(repo_open_workspace)-[:PROCESS]->(ide_target)
(view_trace)-[:PROCESS]->(run_detail_target: Target { screen: 'run-detail' })
(auto_fix_preview)-[:PROCESS]->(scanner_fix_contract: ApiNeed { endpoint: 'POST /api/scans/:scanId/fix-preview' })
(commit_button)-[:PROCESS]->(run_detail_target)
(forge_fold_button)-[:PROCESS]->(orchestration_target)
(repo_workspace_flow)-[:PROCESS]->(star_repo)
(repo_workspace_flow)-[:PROCESS]->(fork_repo)
(repo_workspace_flow)-[:PROCESS]->(repo_open_workspace)
(repo_workspace_flow)-[:PROCESS]->(view_trace)
(repo_workspace_flow)-[:PROCESS]->(auto_fix_preview)
(repo_workspace_flow)-[:PROCESS]->(commit_button)
(repo_workspace_flow)-[:PROCESS]->(forge_fold_button)

// Delivery interactions
(pause_sync: Click { label: 'pause sync' })
(resume_sync: Click { label: 'resume sync' })
(open_diff: Click { label: 'open diff' })
(rerun_workflow: Click { label: 're-run workflow' })
(cancel_workflow: Click { label: 'cancel workflow' })
(open_horizon: Click { label: 'open horizon' })
(promote_canary: Click { label: 'promote canary' })
(open_policy: Click { label: 'open policy' })
(open_vents: Click { label: 'open vents' })

(pause_sync)-[:PROCESS]->(toast_feedback)
(resume_sync)-[:PROCESS]->(toast_feedback)
(open_diff)-[:PROCESS]->(toast_feedback)
(rerun_workflow)-[:PROCESS]->(workflow_run_contract: ApiNeed { endpoint: 'POST /api/runs/:runId/rerun' })
(cancel_workflow)-[:PROCESS]->(workflow_cancel_contract: ApiNeed { endpoint: 'POST /api/runs/:runId/cancel' })
(open_horizon)-[:PROCESS]->(orchestration_target)
(promote_canary)-[:PROCESS]->(promote_contract: ApiNeed { endpoint: 'POST /api/projects/:projectId/canary/promote' })
(open_policy)-[:PROCESS]->(settings_target)
(open_vents)-[:PROCESS]->(audit_target: Target { screen: 'audit' })
(delivery_flow)-[:PROCESS]->(pause_sync)
(delivery_flow)-[:PROCESS]->(resume_sync)
(delivery_flow)-[:PROCESS]->(open_diff)
(delivery_flow)-[:PROCESS]->(rerun_workflow)
(delivery_flow)-[:PROCESS]->(cancel_workflow)
(delivery_flow)-[:PROCESS]->(open_horizon)
(delivery_flow)-[:PROCESS]->(promote_canary)
(delivery_flow)-[:PROCESS]->(open_policy)
(delivery_flow)-[:PROCESS]->(open_vents)

// Admin/social interactions
(download_artifact: Click { label: 'download artifact' })
(rotate_secret: Click { label: 'rotate secret' })
(invite_member: Click { label: 'invite member' })
(change_plan: Click { label: 'change plan' })
(export_audit: Click { label: 'export audit' })
(verify_root: Click { label: 'verify root' })
(verify_domain: Click { label: 'verify domain' })
(mark_notification_read: Click { label: 'mark notification read' })
(save_settings: Click { label: 'save settings' })

(download_artifact)-[:PROCESS]->(artifact_download_contract: ApiNeed { endpoint: 'GET /api/artifacts/:artifactId/download' })
(rotate_secret)-[:PROCESS]->(secret_rotation_contract: ApiNeed { endpoint: 'POST /api/repos/:repoId/secrets/:secretId/rotate' })
(invite_member)-[:PROCESS]->(invite_contract: ApiNeed { endpoint: 'POST /api/orgs/:orgId/invites' })
(change_plan)-[:PROCESS]->(billing_contract: ApiNeed { endpoint: 'POST /api/billing/plan' })
(export_audit)-[:PROCESS]->(audit_export_contract: ApiNeed { endpoint: 'GET /api/orgs/:orgId/ops/export' })
(verify_root)-[:PROCESS]->(audit_verify_contract: ApiNeed { endpoint: 'POST /api/audit/verify-root' })
(verify_domain)-[:PROCESS]->(domain_verify_contract: ApiNeed { endpoint: 'POST /api/orgs/:orgId/nexus/domains/:domain/verify' })
(mark_notification_read)-[:PROCESS]->(notification_contract: ApiNeed { endpoint: 'POST /api/notifications/:id/read' })
(save_settings)-[:PROCESS]->(settings_contract: ApiNeed { endpoint: 'PUT /api/settings/profile' })
(admin_social_flow)-[:PROCESS]->(download_artifact)
(admin_social_flow)-[:PROCESS]->(rotate_secret)
(admin_social_flow)-[:PROCESS]->(invite_member)
(admin_social_flow)-[:PROCESS]->(change_plan)
(admin_social_flow)-[:PROCESS]->(export_audit)
(admin_social_flow)-[:PROCESS]->(verify_root)
(admin_social_flow)-[:PROCESS]->(verify_domain)
(admin_social_flow)-[:PROCESS]->(mark_notification_read)
(admin_social_flow)-[:PROCESS]->(save_settings)

// Command palette destinations are modeled as direct resolved targets.
(command_search: Interaction { kind: 'keyboard', shortcut: 'cmd-k' })
(command_repo: Target { screen: 'repo' })
(command_scanner: Target { screen: 'scanner' })
(command_orchestration: Target { screen: 'orchestration' })
(command_settings: Target { screen: 'settings' })
(command_repo_rejected: Feedback { reason: 'command alternative not selected' })
(command_scanner_rejected: Feedback { reason: 'command alternative not selected' })
(command_orchestration_rejected: Feedback { reason: 'command alternative not selected' })
(command_settings_rejected: Feedback { reason: 'command alternative not selected' })

(command_flow)-[:PROCESS]->(command_search)
(command_search)-[:PROCESS]->(command_repo)
(command_repo)-[:PROCESS]->(command_repo_rejected)
(command_scanner)-[:PROCESS]->(command_scanner_rejected)
(command_orchestration)-[:PROCESS]->(command_orchestration_rejected)
(command_settings)-[:PROCESS]->(command_settings_rejected)

// Authentication interactions are shell-level and provider ordered:
// GitHub is primary for repository ownership, Google is secondary fallback.
(sign_in_github: Click { label: 'continue with GitHub' })
(sign_in_google: Click { label: 'continue with Google' })
(auth_callback: Interaction { kind: 'redirect', label: 'Fractal IAM callback' })
(sign_out: Click { label: 'sign out' })

(sign_in_github)-[:PROCESS]->(github_auth_start: ApiExisting { method: 'POST', path: '/api/auth/browser/start' })
(sign_in_google)-[:PROCESS]->(google_auth_start: ApiExisting { method: 'POST', path: '/api/auth/browser/start' })
(auth_callback)-[:PROCESS]->(auth_exchange_contract: ApiExisting { method: 'POST', path: '/api/auth/session/exchange' })
(sign_out)-[:PROCESS]->(auth_logout_contract: ApiExisting { method: 'POST', path: '/api/auth/session/logout' })
(auth_logout_contract)-[:PROCESS]->(toast_feedback)
(auth_flow)-[:PROCESS]->(sign_in_github)
(auth_flow)-[:PROCESS]->(sign_in_google)
(auth_flow)-[:PROCESS]->(auth_callback)
(auth_flow)-[:PROCESS]->(sign_out)
(interaction_root)-[:FORK { strategy: 'resolved-affordance-frontier' }]->(ide_target | import_target | scanner_target | orchestration_target | run_detail_target | settings_target | audit_target | scanner_scan_contract | scanner_fix_contract | workflow_run_contract | workflow_cancel_contract | promote_contract | artifact_download_contract | secret_rotation_contract | invite_contract | billing_contract | audit_export_contract | audit_verify_contract | domain_verify_contract | notification_contract | settings_contract | github_auth_start | google_auth_start | auth_exchange_contract | toast_feedback)
(ide_target | import_target | scanner_target | orchestration_target | run_detail_target | settings_target | audit_target | scanner_scan_contract | scanner_fix_contract | workflow_run_contract | workflow_cancel_contract | promote_contract | artifact_download_contract | secret_rotation_contract | invite_contract | billing_contract | audit_export_contract | audit_verify_contract | domain_verify_contract | notification_contract | settings_contract | github_auth_start | google_auth_start | auth_exchange_contract | toast_feedback)-[:FOLD { strategy: 'all-affordances-resolved' }]->(interaction_coverage_complete: Sink)
(interaction_coverage_complete)-[:VENT { condition: 'coverage-boundary-closed' }]->(interaction_rejected)
(interaction_rejected)-[:MEASURE { reason: 'topology-audit' }]->(forgo_cloud_interactions_gg_trace:Trace)
