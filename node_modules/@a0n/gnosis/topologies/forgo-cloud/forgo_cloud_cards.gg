// forgo_cloud_cards.gg -- recursive card/panel component topology
// Purpose: validate panel composition before screen-specific repository/admin layouts.

(card_group: ComponentGroup { name: 'ForgoCardGroup', recursive: true, role: 'groups cards and nested panel groups' })
(card_grid_group: ComponentGroup { name: 'ForgoCardGridGroup', parent: 'ForgoCardGroup', role: 'dashboard grids and dense summaries' })
(card_stack_group: ComponentGroup { name: 'ForgoCardStackGroup', parent: 'ForgoCardGroup', role: 'vertical inspector and detail stacks' })
(card_split_group: ComponentGroup { name: 'ForgoCardSplitGroup', parent: 'ForgoCardGroup', role: 'master/detail and sidebar layouts' })
(card_section: Component { name: 'ForgoCardSection', parent: 'ForgoCardGroup' })

(card)-[:MEMBER_OF { slot: 'leaf' }]->(card_group)
(card_section)-[:MEMBER_OF { slot: 'leaf' }]->(card_group)
(card_grid_group)-[:SUBGROUP_OF { recursive: true }]->(card_group)
(card_stack_group)-[:SUBGROUP_OF { recursive: true }]->(card_group)
(card_split_group)-[:SUBGROUP_OF { recursive: true }]->(card_group)
(card_grid_group)-[:MAY_CONTAIN]->(card | card_section | card_stack_group | card_split_group)
(card_stack_group)-[:MAY_CONTAIN]->(card | card_section | card_grid_group | card_split_group)
(card_split_group)-[:MAY_CONTAIN]->(card | card_section | card_grid_group | card_stack_group)
(card_group)-[:CHECK { law: 'acyclic-recursive-containment', status: 'verified' }]->(card_group_law: TopologyLaw)
(card_group_law)-[:PROCESS { strategy: 'card-topology-closed' }]->(component_inventory)
