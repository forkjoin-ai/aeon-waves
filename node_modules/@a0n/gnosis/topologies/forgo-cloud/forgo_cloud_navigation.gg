// forgo_cloud_navigation.gg -- recursive navigation component topology
// Purpose: validate nested nav structures before screen layouts consume them.

(navigation_group: ComponentGroup { name: 'ForgoNavigationGroup', recursive: true, role: 'groups navigation surfaces and nested navigation groups' })
(navigation_bar_group: ComponentGroup { name: 'ForgoNavigationBarGroup', parent: 'ForgoNavigationGroup', role: 'top-level horizontal navigation chrome' })
(navigation_sidebar_group: ComponentGroup { name: 'ForgoNavigationSidebarGroup', parent: 'ForgoNavigationGroup', role: 'sidebar and admin navigation stacks' })
(navigation_tab_group: ComponentGroup { name: 'ForgoNavigationTabGroup', parent: 'ForgoNavigationGroup', role: 'screen-local tab navigation' })
(navigation_tree_group: ComponentGroup { name: 'ForgoNavigationTreeGroup', parent: 'ForgoNavigationGroup', role: 'file and resource trees' })

(top_nav)-[:MEMBER_OF { slot: 'chrome' }]->(navigation_group)
(side_nav)-[:MEMBER_OF { slot: 'sidebar' }]->(navigation_group)
(tabs)-[:MEMBER_OF { slot: 'tabs' }]->(navigation_group)
(file_tree)-[:MEMBER_OF { slot: 'tree' }]->(navigation_group)
(navigation_bar_group)-[:SUBGROUP_OF { recursive: true }]->(navigation_group)
(navigation_sidebar_group)-[:SUBGROUP_OF { recursive: true }]->(navigation_group)
(navigation_tab_group)-[:SUBGROUP_OF { recursive: true }]->(navigation_group)
(navigation_tree_group)-[:SUBGROUP_OF { recursive: true }]->(navigation_group)
(navigation_bar_group)-[:MAY_CONTAIN]->(top_nav | tabs | navigation_tab_group)
(navigation_sidebar_group)-[:MAY_CONTAIN]->(side_nav | tabs | navigation_tab_group | navigation_tree_group)
(navigation_tab_group)-[:MAY_CONTAIN]->(tabs | navigation_tree_group)
(navigation_tree_group)-[:MAY_CONTAIN]->(file_tree | navigation_tab_group)
(navigation_group)-[:CHECK { law: 'acyclic-recursive-containment', status: 'verified' }]->(navigation_group_law: TopologyLaw)
(navigation_group_law)-[:PROCESS { strategy: 'navigation-topology-closed' }]->(component_inventory)
