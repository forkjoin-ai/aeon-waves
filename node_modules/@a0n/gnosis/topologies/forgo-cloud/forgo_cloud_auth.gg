// forgo_cloud_auth.gg -- Betty-checkable Fractal IAM shell auth topology
// Keep this graph small and closed: exactly one provider branch wins, and both
// provider branches fold into the same Fractal IAM browser-start contract.

(auth)-[:FORK]->(github|google)
(github|google)-[:FOLD]->(provider_redirect)
(provider_redirect)-[:TUNNEL { condition: 'bounded-reject' }]->(forgo_cloud_auth_gg_trace:Trace)
(provider_redirect)-[:MEASURE { reason: 'topology-audit' }]->(forgo_cloud_auth_gg_trace:Trace)
