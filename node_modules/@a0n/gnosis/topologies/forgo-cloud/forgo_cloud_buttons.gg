// forgo_cloud_buttons.gg -- recursive button component topology
// Purpose: validate button leaves and nested button groups before screen work.

(button_group: ComponentGroup { name: 'ForgoButtonGroup', recursive: true, role: 'groups buttons and nested button groups' })
(button_action_group: ComponentGroup { name: 'ForgoButtonActionGroup', parent: 'ForgoButtonGroup', role: 'primary and secondary actions' })
(button_toolbar_group: ComponentGroup { name: 'ForgoButtonToolbarGroup', parent: 'ForgoButtonGroup', role: 'dense tool commands' })
(button_choice_group: ComponentGroup { name: 'ForgoButtonChoiceGroup', parent: 'ForgoButtonGroup', role: 'exclusive or multi-select choices' })
(button_icon: Component { name: 'ForgoIconButton', parent: 'ForgoButtonGroup' })
(button_split: Component { name: 'ForgoSplitButton', parent: 'ForgoButtonGroup' })
(button_toggle: Component { name: 'ForgoToggleButton', parent: 'ForgoButtonGroup' })

(button)-[:MEMBER_OF { slot: 'leaf' }]->(button_group)
(button_icon)-[:MEMBER_OF { slot: 'leaf' }]->(button_group)
(button_split)-[:MEMBER_OF { slot: 'leaf' }]->(button_group)
(button_toggle)-[:MEMBER_OF { slot: 'leaf' }]->(button_group)
(button_action_group)-[:SUBGROUP_OF { recursive: true }]->(button_group)
(button_toolbar_group)-[:SUBGROUP_OF { recursive: true }]->(button_group)
(button_choice_group)-[:SUBGROUP_OF { recursive: true }]->(button_group)
(button_action_group)-[:MAY_CONTAIN]->(button | button_icon | button_split | button_toggle | button_toolbar_group | button_choice_group)
(button_toolbar_group)-[:MAY_CONTAIN]->(button | button_icon | button_toggle | button_choice_group)
(button_choice_group)-[:MAY_CONTAIN]->(button_toggle | button_icon)
(button_group)-[:CHECK { law: 'acyclic-recursive-containment', status: 'verified' }]->(button_group_law: TopologyLaw)
(button_group_law)-[:PROCESS { strategy: 'button-topology-closed' }]->(component_inventory)
