// forgo_cloud.test.gg -- verification harness for forgo.cloud app topology

(suite: TestSuite { name: 'forgo_cloud_reskin' })
(app_topology: Verify { module: './forgo_cloud_app.gg', beta1_max: '256', law_status: 'verified' })
(component_topology: Verify { module: './forgo_cloud_components.gg', beta1_max: '512', law_status: 'verified' })
(interaction_topology: Verify { module: './forgo_cloud_interactions.gg', beta1_max: '512', law_status: 'violated' })
(interaction_proof_topology: Verify { module: './forgo_cloud_interactions_proof.gg', beta1_max: '8', law_status: 'verified' })
(data_topology: Verify { module: './forgo_cloud_data_contracts.gg', beta1_max: '512', law_status: 'verified' })
(error_topology: Verify { module: './forgo_cloud_errors.gg', beta1_max: '128', law_status: 'verified' })
(user_story_topology: Verify { module: './forgo_cloud_user_stories.gg', beta1_max: '128', law_status: 'verified' })
(playwright_path_topology: Verify { module: './forgo_cloud_playwright_paths.gg', beta1_max: '128', law_status: 'verified' })
(generation_topology: Verify { module: './forgo_cloud_generation.gg', beta1_max: '128', law_status: 'verified' })
(verdict: Verdict)

(suite)-[:FORK]->(
  app_topology | component_topology | interaction_topology | interaction_proof_topology |
  data_topology | error_topology | user_story_topology |
  playwright_path_topology | generation_topology
)

(
  app_topology | component_topology | interaction_topology | interaction_proof_topology |
  data_topology | error_topology | user_story_topology |
  playwright_path_topology | generation_topology
)-[:FOLD { strategy: 'all-topologies-green' }]->(verdict)
(verdict)-[:TUNNEL { condition: 'bounded-reject' }]->(forgo_cloud_test_gg_trace:Trace)
(verdict)-[:MEASURE { reason: 'topology-audit' }]->(forgo_cloud_test_gg_trace:Trace)
