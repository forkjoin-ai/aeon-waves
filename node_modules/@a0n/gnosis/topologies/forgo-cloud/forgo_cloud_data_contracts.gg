// forgo_cloud_data_contracts.gg -- API/data topology for prototype screens
// Existing endpoints are marked ApiExisting. New contracts are marked ApiNeeded.

(data_audit: Source { source: 'forgo-cloud-worker' })

// Existing public/bootstrap contracts
(public_landing: ApiNeeded { method: 'GET', path: '/api/public/landing' })
(owner_public: ApiExisting { method: 'GET', path: '/api/public/owners/:owner' })
(repo_public: ApiExisting { method: 'GET', path: '/api/public/repos/:owner/:repo' })
(repo_ide_bootstrap: ApiExisting { method: 'GET', path: '/api/public/repos/:owner/:repo/ide-bootstrap' })
(auth_providers: ApiExisting { method: 'GET', path: '/api/auth/providers' })
(auth_browser_start: ApiExisting { method: 'POST', path: '/api/auth/browser/start' })
(auth_browser_status: ApiExisting { method: 'GET', path: '/api/auth/browser/status' })
(auth_session: ApiExisting { method: 'GET', path: '/api/auth/session' })
(auth_session_exchange: ApiExisting { method: 'POST', path: '/api/auth/session/exchange' })
(auth_session_refresh: ApiExisting { method: 'POST', path: '/api/auth/session/refresh' })
(auth_session_logout: ApiExisting { method: 'POST', path: '/api/auth/session/logout' })

// Existing control-plane contracts
(repo_create: ApiExisting { method: 'POST', path: '/api/repos' })
(scan_start: ApiExisting { method: 'POST', path: '/api/vfs-scan' })
(scan_job: ApiExisting { method: 'GET', path: '/api/scan-jobs/:id' })
(repo_ops: ApiExisting { method: 'GET', path: '/api/repos/:repoId/ops' })
(org_ops: ApiExisting { method: 'GET', path: '/api/orgs/:orgId/ops' })
(org_export: ApiExisting { method: 'GET', path: '/api/orgs/:orgId/ops/export' })
(repo_secrets: ApiExisting { method: 'GET', path: '/api/repos/:repoId/secrets' })
(repo_secret_recipients: ApiExisting { method: 'POST', path: '/api/repos/:repoId/secrets/recipients' })
(repo_remotes: ApiExisting { method: 'GET', path: '/api/repos/:repoId/remotes' })
(repo_modules: ApiExisting { method: 'GET', path: '/api/repos/:repoId/modules' })
(org_members: ApiExisting { method: 'GET', path: '/api/orgs/:orgId/members' })
(org_invites: ApiExisting { method: 'GET', path: '/api/orgs/:orgId/invites' })
(org_nexus: ApiExisting { method: 'GET', path: '/api/orgs/:orgId/nexus' })
(runtime_session: ApiExisting { method: 'GET', path: '/api/runtime/session/:sessionId' })

// Needed dashboard contracts exposed by topology before page work.
(github_import_sources: ApiNeeded { method: 'GET', path: '/api/import/github/repos' })
(import_preview: ApiNeeded { method: 'POST', path: '/api/import/github/preview' })
(project_summary: ApiNeeded { method: 'GET', path: '/api/projects/:projectId' })
(project_deployments: ApiNeeded { method: 'GET', path: '/api/projects/:projectId/deployments' })
(workflow_runs: ApiNeeded { method: 'GET', path: '/api/projects/:projectId/runs' })
(workflow_run_detail: ApiNeeded { method: 'GET', path: '/api/runs/:runId' })
(workflow_rerun: ApiNeeded { method: 'POST', path: '/api/runs/:runId/rerun' })
(workflow_cancel: ApiNeeded { method: 'POST', path: '/api/runs/:runId/cancel' })
(horizon_state: ApiNeeded { method: 'GET', path: '/api/projects/:projectId/horizon' })
(horizon_action: ApiNeeded { method: 'POST', path: '/api/projects/:projectId/horizon/actions' })
(artifact_inventory: ApiNeeded { method: 'GET', path: '/api/projects/:projectId/artifacts' })
(artifact_download: ApiNeeded { method: 'GET', path: '/api/artifacts/:artifactId/download' })
(env_inventory: ApiNeeded { method: 'GET', path: '/api/projects/:projectId/env' })
(secret_rotation: ApiNeeded { method: 'POST', path: '/api/repos/:repoId/secrets/:secretId/rotate' })
(ucan_boundaries: ApiNeeded { method: 'GET', path: '/api/orgs/:orgId/ucan-boundaries' })
(billing_usage: ApiNeeded { method: 'GET', path: '/api/billing/edgework' })
(billing_plan: ApiNeeded { method: 'POST', path: '/api/billing/plan' })
(audit_verify_root: ApiNeeded { method: 'POST', path: '/api/audit/verify-root' })
(domain_inventory: ApiNeeded { method: 'GET', path: '/api/orgs/:orgId/nexus/domains' })
(domain_verify: ApiNeeded { method: 'POST', path: '/api/orgs/:orgId/nexus/domains/:domain/verify' })
(notification_inbox: ApiNeeded { method: 'GET', path: '/api/notifications' })
(notification_read: ApiNeeded { method: 'POST', path: '/api/notifications/:id/read' })
(settings_profile: ApiNeeded { method: 'PUT', path: '/api/settings/profile' })
(phyle_state: ApiNeeded { method: 'GET', path: '/api/phyles/:slug' })

(data_audit)-[:FORK]->(
  public_landing | owner_public | repo_public | repo_ide_bootstrap |
  auth_providers | auth_browser_start | auth_browser_status | auth_session |
  auth_session_exchange | auth_session_refresh | auth_session_logout |
  repo_create | scan_start | scan_job | repo_ops | org_ops |
  org_export | repo_secrets | repo_secret_recipients | repo_remotes |
  repo_modules | org_members | org_invites | org_nexus | runtime_session |
  github_import_sources | import_preview | project_summary |
  project_deployments | workflow_runs | workflow_run_detail |
  workflow_rerun | workflow_cancel | horizon_state | horizon_action |
  artifact_inventory | artifact_download | env_inventory | secret_rotation |
  ucan_boundaries | billing_usage | billing_plan | audit_verify_root |
  domain_inventory | domain_verify | notification_inbox | notification_read |
  settings_profile | phyle_state
)

(
  public_landing | owner_public | repo_public | repo_ide_bootstrap |
  auth_providers | auth_browser_start | auth_browser_status | auth_session |
  auth_session_exchange | auth_session_refresh | auth_session_logout |
  repo_create | scan_start | scan_job | repo_ops | org_ops |
  org_export | repo_secrets | repo_secret_recipients | repo_remotes |
  repo_modules | org_members | org_invites | org_nexus | runtime_session |
  github_import_sources | import_preview | project_summary |
  project_deployments | workflow_runs | workflow_run_detail |
  workflow_rerun | workflow_cancel | horizon_state | horizon_action |
  artifact_inventory | artifact_download | env_inventory | secret_rotation |
  ucan_boundaries | billing_usage | billing_plan | audit_verify_root |
  domain_inventory | domain_verify | notification_inbox | notification_read |
  settings_profile | phyle_state
)-[:FOLD { strategy: 'api-inventory' }]->(api_inventory: Inventory)

(api_inventory)-[:FORK]->(
  landing_data | scanner_data | import_data | repo_data | project_data |
  profile_data | phyle_data | orchestration_data | runs_data |
  run_detail_data | folds_data | canary_data | cd_data | docs_data |
  ide_data | artifacts_data | env_data |
  members_data | billing_data | audit_data | nexus_data |
  notifications_data | settings_data
)

(
  landing_data | scanner_data | import_data | repo_data | project_data |
  profile_data | phyle_data | orchestration_data | runs_data |
  run_detail_data | folds_data | canary_data | cd_data | docs_data |
  ide_data | artifacts_data | env_data |
  members_data | billing_data | audit_data | nexus_data |
  notifications_data | settings_data
)-[:FOLD { strategy: 'all-data-contracts-mapped' }]->(data_contracts_complete: Sink)
(data_contracts_complete)-[:TUNNEL { condition: 'bounded-reject' }]->(forgo_cloud_data_contracts_gg_trace:Trace)
(data_contracts_complete)-[:MEASURE { reason: 'topology-audit' }]->(forgo_cloud_data_contracts_gg_trace:Trace)
