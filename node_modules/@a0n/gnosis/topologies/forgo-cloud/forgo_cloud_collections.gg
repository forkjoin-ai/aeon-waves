// forgo_cloud_collections.gg -- recursive collection component topology
// Purpose: validate repeated data surfaces before repo, run, and admin screens.

(collection_group: ComponentGroup { name: 'ForgoCollectionGroup', recursive: true, role: 'groups lists, tables, and typed collections' })
(collection_table_group: ComponentGroup { name: 'ForgoCollectionTableGroup', parent: 'ForgoCollectionGroup', role: 'dense tabular data' })
(collection_feed_group: ComponentGroup { name: 'ForgoCollectionFeedGroup', parent: 'ForgoCollectionGroup', role: 'event feeds and activity streams' })
(collection_artifact_group: ComponentGroup { name: 'ForgoCollectionArtifactGroup', parent: 'ForgoCollectionGroup', role: 'artifacts, domains, notifications, findings' })

(list)-[:MEMBER_OF { slot: 'list' }]->(collection_group)
(table)-[:MEMBER_OF { slot: 'table' }]->(collection_group)
(filter_chips)-[:MEMBER_OF { slot: 'filter' }]->(collection_group)
(scan_findings)-[:MEMBER_OF { slot: 'finding-list' }]->(collection_group)
(artifact_list)-[:MEMBER_OF { slot: 'artifact-list' }]->(collection_group)
(domain_list)-[:MEMBER_OF { slot: 'domain-list' }]->(collection_group)
(notification_list)-[:MEMBER_OF { slot: 'notification-list' }]->(collection_group)
(collection_table_group)-[:SUBGROUP_OF { recursive: true }]->(collection_group)
(collection_feed_group)-[:SUBGROUP_OF { recursive: true }]->(collection_group)
(collection_artifact_group)-[:SUBGROUP_OF { recursive: true }]->(collection_group)
(collection_table_group)-[:MAY_CONTAIN]->(table | filter_chips | collection_feed_group)
(collection_feed_group)-[:MAY_CONTAIN]->(list | filter_chips | collection_artifact_group)
(collection_artifact_group)-[:MAY_CONTAIN]->(artifact_list | domain_list | notification_list | scan_findings | list)
(collection_group)-[:CHECK { law: 'acyclic-recursive-containment', status: 'verified' }]->(collection_group_law: TopologyLaw)
(collection_group_law)-[:PROCESS { strategy: 'collection-topology-closed' }]->(component_inventory)
