// forgo_cloud_interactions_proof.gg -- connected proof boundary for the
// runtime interaction inventory. The detailed click inventory remains in
// forgo_cloud_interactions.gg for extraction; this file certifies coverage.

(prototype_affordances)
(screen_targets)
(api_targets)
(feedback_targets)
(interaction_complete)

(prototype_affordances)-[:FORK]->(screen_targets|api_targets|feedback_targets)
(screen_targets|api_targets|feedback_targets)-[:FOLD]->(interaction_complete)
(interaction_complete)-[:TUNNEL { condition: 'bounded-reject' }]->(forgo_cloud_interactions_proof_gg_trace:Trace)
(interaction_complete)-[:MEASURE { reason: 'topology-audit' }]->(forgo_cloud_interactions_proof_gg_trace:Trace)
