// forgo_cloud_errors.gg -- error and recovery topology for Forgo.zip
// Error behavior is modeled explicitly so implementation has no hidden sad path.

(error_root: Source { suite: 'forgo_cloud_errors' })

// Cross-cutting failure classes.
(network_error: ErrorClass { kind: 'network' })
(auth_expired: ErrorClass { kind: 'auth-expired' })
(permission_denied: ErrorClass { kind: 'permission-denied' })
(validation_error: ErrorClass { kind: 'validation' })
(not_found: ErrorClass { kind: 'not-found' })
(rate_limited: ErrorClass { kind: 'rate-limited' })
(conflict_error: ErrorClass { kind: 'conflict' })
(worker_timeout: ErrorClass { kind: 'worker-timeout' })
(billing_required: ErrorClass { kind: 'billing-required' })
(audit_mismatch: ErrorClass { kind: 'audit-mismatch' })
(dns_unverified: ErrorClass { kind: 'dns-unverified' })
(secret_rotation_failed: ErrorClass { kind: 'secret-rotation-failed' })

// Screen-level recovery surfaces. Every prototype screen must own a visible
// loading, empty, or error recovery state before page implementation starts.
(landing_error: ScreenError { screen: 'landing', recovery: 'retry landing data' })
(scanner_error: ScreenError { screen: 'scanner', recovery: 'retry scan or edit target' })
(import_error: ScreenError { screen: 'import', recovery: 'reconnect provider' })
(repo_error: ScreenError { screen: 'repo', recovery: 'refresh repo metadata' })
(project_error: ScreenError { screen: 'project', recovery: 'refresh project graph' })
(profile_error: ScreenError { screen: 'profile', recovery: 'refresh identity' })
(phyle_error: ScreenError { screen: 'phyle', recovery: 'reload phyle proof' })
(orchestration_error: ScreenError { screen: 'orchestration', recovery: 'retry fold control' })
(runs_error: ScreenError { screen: 'runs', recovery: 'refresh runs' })
(run_detail_error: ScreenError { screen: 'run-detail', recovery: 'reload trace' })
(folds_error: ScreenError { screen: 'folds', recovery: 'retry fold ledger query' })
(canary_error: ScreenError { screen: 'canary', recovery: 'reload canary policy' })
(cd_error: ScreenError { screen: 'cd', recovery: 'retry deployment control' })
(docs_error: ScreenError { screen: 'docs', recovery: 'reload topology docs' })
(ide_error: ScreenError { screen: 'ide', recovery: 'reload workspace session' })
(artifacts_error: ScreenError { screen: 'artifacts', recovery: 'retry artifact fetch' })
(env_error: ScreenError { screen: 'env', recovery: 'retry secret operation' })
(members_error: ScreenError { screen: 'members', recovery: 'retry invite or role update' })
(billing_error: ScreenError { screen: 'billing', recovery: 'retry billing action' })
(audit_error: ScreenError { screen: 'audit', recovery: 'retry audit export or verify' })
(nexus_error: ScreenError { screen: 'nexus', recovery: 'retry domain verification' })
(notifications_error: ScreenError { screen: 'notifications', recovery: 'retry notification sync' })
(settings_error: ScreenError { screen: 'settings', recovery: 'retry settings save' })

(error_root)-[:FORK]->(
  network_error | auth_expired | permission_denied | validation_error |
  not_found | rate_limited | conflict_error | worker_timeout |
  billing_required | audit_mismatch | dns_unverified | secret_rotation_failed |
  landing_error | scanner_error | import_error | repo_error | project_error |
  profile_error | phyle_error | orchestration_error | runs_error |
  run_detail_error | folds_error | canary_error | cd_error | docs_error |
  ide_error | artifacts_error | env_error |
  members_error | billing_error | audit_error | nexus_error |
  notifications_error | settings_error
)

(
  network_error | auth_expired | permission_denied | validation_error |
  not_found | rate_limited | conflict_error | worker_timeout |
  billing_required | audit_mismatch | dns_unverified | secret_rotation_failed |
  landing_error | scanner_error | import_error | repo_error | project_error |
  profile_error | phyle_error | orchestration_error | runs_error |
  run_detail_error | folds_error | canary_error | cd_error | docs_error |
  ide_error | artifacts_error | env_error |
  members_error | billing_error | audit_error | nexus_error |
  notifications_error | settings_error
)-[:FOLD { strategy: 'all-errors-recoverable' }]->(error_coverage_complete: Sink)
(error_coverage_complete)-[:TUNNEL { condition: 'bounded-reject' }]->(forgo_cloud_errors_gg_trace:Trace)
(error_coverage_complete)-[:MEASURE { reason: 'topology-audit' }]->(forgo_cloud_errors_gg_trace:Trace)
