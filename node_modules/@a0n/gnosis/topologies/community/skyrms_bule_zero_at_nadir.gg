// skyrms_bule_zero_at_nadir.gg — THM-SKYRMS-NADIR-BULE witness (Bule = 0 at nadir)
//
// At the nadir point, the Bule deficit measure equals zero.
// The nadir is the point of perfect semiotic equilibrium where
// all interpretive paths are fully resolved.
// Bule = max(0, paths - streams - nadir_offset). At nadir, offset cancels deficit.

(game: SkyrmsGame { theorem: 'THM-SKYRMS-NADIR-BULE', strategies_a: '4', strategies_b: '3' })
(pre_nadir: BuleMeasure { dimension: '5', bule: '1', paths: '7', streams: '6' })
(at_nadir: BuleMeasure { dimension: '6', bule: '0', paths: '7', streams: '7' })
(post_nadir: BuleMeasure { dimension: '7', bule: '0', paths: '7', streams: '8' })
(zero_at_nadir: Invariant { claim: 'Bule = 0 at nadir dimension', nadir: '6', bule_at_nadir: '0' })
(result: Result { theorem: 'bule-zero-at-nadir' })

(game)-[:FORK]->(pre_nadir | at_nadir | post_nadir)
(pre_nadir)-[:PROCESS]->(at_nadir)
(at_nadir)-[:PROCESS]->(post_nadir)
(at_nadir)-[:PROCESS { expect: 'bule-is-zero' }]->(zero_at_nadir)
(zero_at_nadir)-[:PROCESS { strategy: 'verify-zero' }]->(result)
