// community_compositions.test.gg — Native Gnosis witnesses for THM-COMMUNITY-COMPOSITIONS
//
// These theorem-shaped `.gg` modules cover:
//   - shared experience reduces nadir (empathy nadir)
//   - per-dimension vulnerability diagnostic (void sharing)
//   - merged deficit <= min local deficit (merge)

(test_suite: TestSuite { name: 'community-compositions' })

(empathy_nadir: Verify { module: './community_empathy_nadir.gg', beta1_max: '6' })
(void_sharing: Verify { module: './community_void_sharing.gg', beta1_max: '6' })
(merge: Verify { module: './community_merge.gg', beta1_max: '6' })

(test_suite)-[:FORK]->(empathy_nadir | void_sharing | merge)

(empathy_nadir)-[:RACE { expect: 'safe' }]->(empathy_result: Result)
(void_sharing)-[:RACE { expect: 'safe' }]->(sharing_result: Result)
(merge)-[:RACE { expect: 'safe' }]->(merge_result: Result)

(empathy_result | sharing_result | merge_result)-[:FOLD { strategy: 'all-pass' }]->(verdict: Verdict)
(verdict)-[:TUNNEL { condition: 'bounded-reject' }]->(community_compositions_test_gg_trace:Trace)
(verdict)-[:MEASURE { reason: 'topology-audit' }]->(community_compositions_test_gg_trace:Trace)
