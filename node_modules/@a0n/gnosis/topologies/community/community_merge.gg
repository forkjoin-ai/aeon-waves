// community_merge.gg — THM-COMMUNITY-COMPOSITIONS witness (merged deficit <= min local)
//
// When two communities merge, the resulting deficit is at most the
// minimum of the two local deficits. Merging cannot make things worse
// than the best participant.
// Example: community X deficit=4, community Y deficit=6 -> merged deficit <= 4.

(merge_space: MergeSpace { theorem: 'THM-COMMUNITY-COMPOSITIONS', communities: '2' })
(community_x: Community { id: 'X', deficit: '4', members: '5' })
(community_y: Community { id: 'Y', deficit: '6', members: '3' })
(merged: Community { id: 'X+Y', deficit: '3', members: '8' })
(min_local: Invariant { claim: 'merged deficit <= min(local deficits)', deficit_x: '4', deficit_y: '6', merged: '3', min: '4' })
(result: Result { theorem: 'merged-deficit-leq-min-local' })

(merge_space)-[:FORK]->(community_x | community_y)
(community_x | community_y)-[:FOLD { strategy: 'merge-communities' }]->(merged)
(merged)-[:PROCESS { expect: 'deficit-bounded' }]->(min_local)
(min_local)-[:PROCESS { strategy: 'verify-leq' }]->(result)
(result)-[:TUNNEL { condition: 'bounded-reject' }]->(community_merge_gg_trace:Trace)
(result)-[:MEASURE { reason: 'topology-audit' }]->(community_merge_gg_trace:Trace)
