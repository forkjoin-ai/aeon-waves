// coarsening_repair_debt.gg — THM-SLIVERNCE-COARSENING witness (non-injective -> repair debt)
//
// When the quotient map is non-injective (multiple fine branches map to
// the same coarse class), repair debt is incurred proportional to the
// collision count. Each collision requires one unit of repair.
// Example: 4 branches -> 2 classes, 2 collisions -> repair debt = 2.

(fine: InterferenceModel { theorem: 'THM-SLIVERNCE-COARSENING', branches: '4', classes: '2' })
(class_1: QuotientClass { id: '1', members: '2', collisions: '1' })
(class_2: QuotientClass { id: '2', members: '2', collisions: '1' })
(debt: RepairDebt { total_collisions: '2', repair_cost: '2' })
(invariant: Invariant { claim: 'non_injective_implies_repair_debt', collisions: '2', debt: '2' })
(result: Result { theorem: 'non-injective-repair-debt' })

(fine)-[:FORK]->(class_1 | class_2)
(class_1 | class_2)-[:RACE { expect: 'collision-counted' }]->(debt)
(debt)-[:PROCESS]->(invariant)
(invariant)-[:PROCESS { strategy: 'verify-positive' }]->(result)
(result)-[:MEASURE { reason: 'topology-audit' }]->(coarsening_repair_debt_gg_trace:Trace)
