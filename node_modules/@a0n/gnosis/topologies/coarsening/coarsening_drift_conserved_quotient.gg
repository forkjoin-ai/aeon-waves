// coarsening_drift_conserved_quotient.gg — THM-RECURSIVE-COARSENING-SYNTHESIS witness (drift preserved under quotient)
//
// Under recursive coarsening, the total drift is preserved at each
// level of the quotient hierarchy. Coarsening redistributes drift
// among equivalence classes but the global sum is invariant.
// Example: fine drift [1,2,3,4]=10, coarse level 1 [3,7]=10, coarse level 2 [10]=10.

(synthesis: RecursiveCoarsening { theorem: 'THM-RECURSIVE-COARSENING-SYNTHESIS', levels: '3' })
(fine: DriftLevel { level: '0', drift: '[1, 2, 3, 4]', total: '10' })
(coarse_1: DriftLevel { level: '1', drift: '[3, 7]', total: '10' })
(coarse_2: DriftLevel { level: '2', drift: '[10]', total: '10' })
(invariant: Invariant { claim: 'drift_conserved_all_levels', fine: '10', coarse_1: '10', coarse_2: '10' })
(result: Result { theorem: 'drift-conserved-quotient' })

(synthesis)-[:FORK]->(fine | coarse_1 | coarse_2)
(fine)-[:PROCESS]->(coarse_1)
(coarse_1)-[:PROCESS]->(coarse_2)
(fine | coarse_1 | coarse_2)-[:RACE { expect: 'drift-equal' }]->(invariant)
(invariant)-[:PROCESS { strategy: 'verify-equality' }]->(result)
(result)-[:MEASURE { reason: 'topology-audit' }]->(coarsening_drift_conserved_quotient_gg_trace:Trace)
