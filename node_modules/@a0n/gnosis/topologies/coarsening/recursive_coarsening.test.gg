// recursive_coarsening.test.gg — Native Gnosis witnesses for THM-RECURSIVE-COARSENING-SYNTHESIS
//
// These theorem-shaped `.gg` modules cover:
//   - valid certificate from stable data (synthesis_sound)
//   - drift preserved under quotient (drift_conserved_quotient)
//   - fine stability transfers to coarse (stability_transfer)

(test_suite: TestSuite { name: 'recursive-coarsening-synthesis' })

(synthesis_sound: Verify { module: './coarsening_synthesis_sound.gg', beta1_max: '7' })
(drift_conserved_quotient: Verify { module: './coarsening_drift_conserved_quotient.gg', beta1_max: '7' })
(stability_transfer: Verify { module: './coarsening_stability_transfer.gg', beta1_max: '7' })

(test_suite)-[:FORK]->(synthesis_sound | drift_conserved_quotient | stability_transfer)

(synthesis_sound)-[:RACE { expect: 'safe' }]->(sound_result: Result)
(drift_conserved_quotient)-[:RACE { expect: 'safe' }]->(drift_result: Result)
(stability_transfer)-[:RACE { expect: 'safe' }]->(transfer_result: Result)

(sound_result | drift_result | transfer_result)-[:FOLD { strategy: 'all-pass' }]->(verdict: Verdict)
(verdict)-[:TUNNEL { condition: 'bounded-reject' }]->(recursive_coarsening_test_gg_trace:Trace)
(verdict)-[:MEASURE { reason: 'topology-audit' }]->(recursive_coarsening_test_gg_trace:Trace)
