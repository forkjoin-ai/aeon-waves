// coarsening_preserves_support.gg — THM-SLIVERNCE-COARSENING witness (quotient preserves live support)
//
// The quotient map merges interference classes but preserves the set of
// live (non-vented) branches. Every live branch in the fine model maps
// to a live equivalence class in the coarse model.
// Example: 4 branches, 2 live -> quotient has 2 live classes.

(fine: InterferenceModel { theorem: 'THM-SLIVERNCE-COARSENING', branches: '4', live: '2' })
(branch_a: Branch { id: 'a', live: 'true', class: '1' })
(branch_b: Branch { id: 'b', live: 'true', class: '2' })
(branch_c: Branch { id: 'c', live: 'false', class: '1' })
(branch_d: Branch { id: 'd', live: 'false', class: '2' })
(coarse: QuotientModel { classes: '2', live_classes: '2' })
(invariant: Invariant { claim: 'live_support_preserved', fine_live: '2', coarse_live: '2' })
(result: Result { theorem: 'quotient-preserves-support' })

(fine)-[:FORK]->(branch_a | branch_b | branch_c | branch_d)
(branch_c)-[:VENT { condition: 'interference-dead' }]->(vent_c: VentedPath)
(branch_d)-[:VENT { condition: 'interference-dead' }]->(vent_d: VentedPath)
(branch_a | branch_b)-[:RACE { expect: 'live-preserved' }]->(coarse)
(coarse)-[:PROCESS]->(invariant)
(invariant)-[:PROCESS { strategy: 'verify-equality' }]->(result)
(result)-[:MEASURE { reason: 'topology-audit' }]->(coarsening_preserves_support_gg_trace:Trace)
