// coarsening_synthesis_sound.gg — THM-RECURSIVE-COARSENING-SYNTHESIS witness (valid certificate from stable data)
//
// When the fine-grained data is stable (all branches converged),
// the recursive coarsening synthesis produces a valid convergence
// certificate. The certificate attests that the quotient is sound.
// Example: 4 stable branches -> 2 classes -> valid certificate.

(synthesis: RecursiveCoarsening { theorem: 'THM-RECURSIVE-COARSENING-SYNTHESIS', branches: '4', classes: '2' })
(branch_a: Branch { id: 'a', stable: 'true', class: '1' })
(branch_b: Branch { id: 'b', stable: 'true', class: '1' })
(branch_c: Branch { id: 'c', stable: 'true', class: '2' })
(branch_d: Branch { id: 'd', stable: 'true', class: '2' })
(certificate: ConvergenceCertificate { valid: 'true', classes: '2', source_stable: 'true' })
(invariant: Invariant { claim: 'stable_data_yields_valid_certificate', valid: 'true' })
(result: Result { theorem: 'synthesis-sound' })

(synthesis)-[:FORK]->(branch_a | branch_b | branch_c | branch_d)
(branch_a | branch_b | branch_c | branch_d)-[:RACE { expect: 'all-stable' }]->(certificate)
(certificate)-[:PROCESS]->(invariant)
(invariant)-[:PROCESS { strategy: 'verify-valid' }]->(result)
(result)-[:MEASURE { reason: 'topology-audit' }]->(coarsening_synthesis_sound_gg_trace:Trace)
