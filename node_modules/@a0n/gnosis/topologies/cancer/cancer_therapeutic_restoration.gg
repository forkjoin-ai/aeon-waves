// cancer_therapeutic_restoration.gg — THM-CANCER-TOPOLOGY witness (one vent restores learning)
//
// A cancer cell (beta1=0) treated with a checkpoint-restoring therapy
// regains the ability to vent damaged paths. Even restoring a single
// checkpoint (beta1: 0 -> 1) restores topological learning.

(cancer_cell: CellCycle { theorem: 'THM-CANCER-TOPOLOGY', checkpoints: '0', beta1_before: '0' })
(before_treatment: State { beta1: '0', all_paths_survive: 'true', learning: 'false' })
(therapy: Intervention { type: 'checkpoint-restoration', restores: 'p53', cost: '1' })
(after_treatment: State { beta1: '1', damaged_vented: 'true', learning: 'true' })
(healthy_branch: Branch { survives: 'true', weight: '8' })
(damaged_branch: Branch { survives: 'false', weight: '0' })
(restoration: Invariant { claim: 'beta1 >= 1 restores learning', beta1_after: '1' })
(result: Result { theorem: 'one-vent-restores-learning' })

(cancer_cell)-[:PROCESS]->(before_treatment)
(before_treatment)-[:PROCESS]->(therapy)
(therapy)-[:FORK]->(healthy_branch | damaged_branch)
(damaged_branch)-[:VENT { condition: 'p53-checkpoint-restored' }]->(vented: VentedPath)
(healthy_branch)-[:PROCESS { expect: 'survivor' }]->(after_treatment)
(vented)-[:PROCESS]->(after_treatment)
(after_treatment)-[:PROCESS { strategy: 'verify-positive-beta1' }]->(restoration)
(restoration)-[:PROCESS]->(result)
(result)-[:MEASURE { reason: 'topology-audit' }]->(cancer_therapeutic_restoration_gg_trace:Trace)
