// molecular_topology.test.gg — Native Gnosis witnesses for THM-MOLECULAR-TOPOLOGY
//
// These theorem-shaped `.gg` modules cover:
//   - pipeline isomorphic to molecule if same Betti numbers
//   - enzyme as reusable fork
//   - evolution as self-modifying pipeline

(test_suite: TestSuite { name: 'molecular-topology' })

(betti_isomorphism: Verify { module: './molecular_betti_isomorphism.gg', beta1_max: '6' })
(enzyme_fork: Verify { module: './molecular_enzyme_fork.gg', beta1_max: '6' })
(evolution_self_modify: Verify { module: './molecular_evolution_self_modify.gg', beta1_max: '6' })

(test_suite)-[:FORK]->(betti_isomorphism | enzyme_fork | evolution_self_modify)

(betti_isomorphism)-[:RACE { expect: 'safe' }]->(betti_result: Result)
(enzyme_fork)-[:RACE { expect: 'safe' }]->(enzyme_result: Result)
(evolution_self_modify)-[:RACE { expect: 'safe' }]->(evolution_result: Result)

(betti_result | enzyme_result | evolution_result)-[:FOLD { strategy: 'all-pass' }]->(verdict: Verdict)
(verdict)-[:TUNNEL { condition: 'bounded-reject' }]->(molecular_topology_test_gg_trace:Trace)
(verdict)-[:MEASURE { reason: 'topology-audit' }]->(molecular_topology_test_gg_trace:Trace)
