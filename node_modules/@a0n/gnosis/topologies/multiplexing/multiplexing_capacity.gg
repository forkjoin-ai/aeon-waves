// multiplexing_capacity.gg — THM-MULTIPLEXING witness (shared resources can only help)
//
// Multiplexing shared resources across multiple streams never decreases
// total throughput compared to dedicated allocation. The multiplexed
// throughput >= sum of individual dedicated throughputs.
// Example: 3 streams, dedicated total = 9, multiplexed = 12 >= 9.

(mux: Multiplexer { theorem: 'THM-MULTIPLEXING', streams: '3' })
(dedicated_a: Stream { id: 'a', throughput: '3', mode: 'dedicated' })
(dedicated_b: Stream { id: 'b', throughput: '3', mode: 'dedicated' })
(dedicated_c: Stream { id: 'c', throughput: '3', mode: 'dedicated' })
(multiplexed: MultiplexedResult { throughput: '12', streams: '3' })
(invariant: Invariant { claim: 'mux_throughput_gte_dedicated', mux: '12', dedicated: '9' })
(result: Result { theorem: 'shared-resources-help' })

(mux)-[:FORK]->(dedicated_a | dedicated_b | dedicated_c)
(dedicated_a | dedicated_b | dedicated_c)-[:RACE { expect: 'multiplexed' }]->(multiplexed)
(multiplexed)-[:PROCESS]->(invariant)
(invariant)-[:PROCESS { strategy: 'verify-gte' }]->(result)
(result)-[:MEASURE { reason: 'topology-audit' }]->(multiplexing_capacity_gg_trace:Trace)
