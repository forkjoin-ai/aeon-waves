// multiplexing_turbulent.gg — THM-MULTIPLEXING witness (turbulent regime = positive idle)
//
// In the turbulent regime (Re > critical), the idle fraction is
// strictly positive but bounded. Resources are never fully utilized
// due to bursty traffic patterns.
// Example: Re = 100 (turbulent), idle = 0.01 > 0, bounded by 1/100.

(mux: Multiplexer { theorem: 'THM-MULTIPLEXING', reynolds: '100', regime: 'turbulent' })
(flow: TrafficFlow { reynolds: '100', critical: '50' })
(idle: IdleFraction { measured: '0.01', positive: 'true' })
(invariant: Invariant { claim: 'turbulent_idle_positive', idle: '0.01', re: '100' })
(result: Result { theorem: 'turbulent-positive-idle' })

(mux)-[:PROCESS]->(flow)
(flow)-[:PROCESS { expect: 'turbulent-regime' }]->(idle)
(idle)-[:PROCESS]->(invariant)
(invariant)-[:PROCESS { strategy: 'verify-positive' }]->(result)
