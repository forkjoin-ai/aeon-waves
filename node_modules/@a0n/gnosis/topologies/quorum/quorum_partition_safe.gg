// quorum_partition_safe.gg — THM-QUORUM-VISIBILITY witness (safety under minority partition)
//
// When a minority partition separates fewer than quorum-size replicas,
// the majority side retains quorum and safety is preserved.
// Example: 5 replicas, 2 partitioned -> majority = 3 >= write_q = 3.

(cluster: QuorumCluster { theorem: 'THM-QUORUM-VISIBILITY', replicas: '5', partitioned: '2' })
(majority: Partition { side: 'majority', size: '3' })
(minority: Partition { side: 'minority', size: '2' })
(safety: SafetyCheck { majority_size: '3', quorum_size: '3', safe: 'true' })
(invariant: Invariant { claim: 'minority_partition_preserves_safety', majority: '3', quorum: '3' })
(result: Result { theorem: 'partition-safe' })

(cluster)-[:FORK]->(majority | minority)
(minority)-[:VENT { condition: 'partitioned-away' }]->(vented: VentedPartition)
(majority)-[:PROCESS { expect: 'quorum-retained' }]->(safety)
(safety)-[:PROCESS]->(invariant)
(invariant)-[:PROCESS { strategy: 'verify-gte' }]->(result)
(result)-[:MEASURE { reason: 'topology-audit' }]->(quorum_partition_safe_gg_trace:Trace)
