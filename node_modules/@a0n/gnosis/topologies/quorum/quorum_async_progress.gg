// quorum_async_progress.gg — THM-QUORUM-VISIBILITY witness (async progress under fairness)
//
// Under fair scheduling, an asynchronous quorum system makes progress:
// eventually a quorum forms and the pending write commits.
// Example: 5 replicas, fair scheduler, write commits after 3 acks.

(cluster: QuorumCluster { theorem: 'THM-QUORUM-VISIBILITY', replicas: '5', scheduler: 'fair' })
(ack_1: Ack { replica: '1', round: '1' })
(ack_2: Ack { replica: '3', round: '2' })
(ack_3: Ack { replica: '5', round: '3' })
(quorum_formed: QuorumEvent { acks: '3', quorum_size: '3', committed: 'true' })
(invariant: Invariant { claim: 'fair_async_makes_progress', rounds_to_commit: '3' })
(result: Result { theorem: 'async-progress-under-fairness' })

(cluster)-[:FORK]->(ack_1 | ack_2 | ack_3)
(ack_1 | ack_2 | ack_3)-[:RACE { expect: 'quorum-formed' }]->(quorum_formed)
(quorum_formed)-[:PROCESS]->(invariant)
(invariant)-[:PROCESS { strategy: 'verify-positive' }]->(result)
(result)-[:MEASURE { reason: 'topology-audit' }]->(quorum_async_progress_gg_trace:Trace)
