// evidence_guilty_zero_deficit.gg — THM-BULEYEAN-EVIDENCE witness (guilty iff zero deficit)
//
// The Buleyean verdict is "guilty" if and only if the deficit reaches
// zero -- all required dimensions are satisfied by evidence.
// Forward: deficit=0 -> guilty. Reverse: deficit > 0 -> not guilty.
// Example: deficit=0 -> guilty; deficit=2 -> insufficient.

(trial: BuleyeanTrial { theorem: 'THM-BULEYEAN-EVIDENCE', required_dimensions: '3' })
(satisfied: EvidenceState { evidence_count: '3', deficit: '0' })
(unsatisfied: EvidenceState { evidence_count: '1', deficit: '2' })
(guilty_verdict: BuleyeanVerdict { value: 'guilty', deficit: '0' })
(insufficient_verdict: BuleyeanVerdict { value: 'insufficient-data', deficit: '2' })
(biconditional: Invariant { claim: 'guilty iff deficit = 0', forward: 'deficit=0 -> guilty', reverse: 'deficit>0 -> not-guilty' })
(result: Result { theorem: 'guilty-iff-zero-deficit' })

(trial)-[:FORK]->(satisfied | unsatisfied)
(satisfied)-[:PROCESS { expect: 'guilty' }]->(guilty_verdict)
(unsatisfied)-[:PROCESS { expect: 'insufficient' }]->(insufficient_verdict)
(guilty_verdict | insufficient_verdict)-[:FOLD { strategy: 'verify-biconditional' }]->(biconditional)
(biconditional)-[:PROCESS]->(result)
(result)-[:TUNNEL { condition: 'bounded-reject' }]->(evidence_guilty_zero_deficit_gg_trace:Trace)
(result)-[:MEASURE { reason: 'topology-audit' }]->(evidence_guilty_zero_deficit_gg_trace:Trace)
