// evidence_presumption.gg — THM-BULEYEAN-EVIDENCE witness (initial verdict = insufficient data)
//
// Before any evidence is presented, the Buleyean verdict is "insufficient
// data" -- the deficit equals the total number of required dimensions.
// No evidence has been presented, so no dimension is satisfied.
// Example: 5 required dimensions, 0 evidence -> deficit=5, verdict=insufficient.

(trial: BuleyeanTrial { theorem: 'THM-BULEYEAN-EVIDENCE', required_dimensions: '5' })
(initial_state: EvidenceState { presented: '0', dimensions_satisfied: '0', deficit: '5' })
(verdict: BuleyeanVerdict { value: 'insufficient-data', deficit: '5', threshold: '0' })
(presumption: Invariant { claim: 'zero evidence implies insufficient data', deficit: '5', verdict: 'insufficient-data' })
(result: Result { theorem: 'initial-verdict-insufficient' })

(trial)-[:PROCESS]->(initial_state)
(initial_state)-[:PROCESS]->(verdict)
(verdict)-[:PROCESS { expect: 'insufficient-data' }]->(presumption)
(presumption)-[:PROCESS { strategy: 'verify-initial-state' }]->(result)
