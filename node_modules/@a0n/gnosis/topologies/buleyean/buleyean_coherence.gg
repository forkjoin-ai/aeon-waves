// buleyean_coherence.gg — THM-BULEYEAN-COHERENCE witness
//
// Two observers with identical void boundaries compute identical weights.
// The distribution is objective (observer-independent).

(observer_a: Observer { theorem: 'THM-BULEYEAN-COHERENCE', id: 'Alice' })
(observer_b: Observer { theorem: 'THM-BULEYEAN-COHERENCE', id: 'Bob' })
(shared_boundary: VoidBoundary { counts: '[3, 7, 1]', rounds: '10' })
(weights_a: WeightVector { source: 'Alice', values: '[8, 4, 10]' })
(weights_b: WeightVector { source: 'Bob', values: '[8, 4, 10]' })
(agreement: Invariant { claim: 'weights_alice == weights_bob' })
(result: Result { theorem: 'same-evidence-same-distribution' })

(shared_boundary)-[:FORK]->(observer_a | observer_b)
(observer_a)-[:PROCESS { expect: 'weights-computed' }]->(weights_a)
(observer_b)-[:PROCESS { expect: 'weights-computed' }]->(weights_b)
(weights_a | weights_b)-[:FOLD { strategy: 'verify-equality' }]->(agreement)
(agreement)-[:PROCESS]->(result)
(result)-[:TUNNEL { condition: 'bounded-reject' }]->(buleyean_coherence_gg_trace:Trace)
(result)-[:MEASURE { reason: 'topology-audit' }]->(buleyean_coherence_gg_trace:Trace)
