// aeon_shell_rhizome_projections.gg — Rhizome Interchangeable Cameras
//
// Document: aeon-shell/docs/rhizome-philosophy.md
// Layer: aeon-shell (Rhizome)
//
// The prior version formed a non-terminating self-referential collapse loop.
// This replacement preserves the projection-selection intent as a linear flow.

(shell_runtime: Workload { type: 'graph_snapshot' })
(projection_catalog: State { views: 'globe,constellation,mold' })
(active_projection: State { selected: 'mold' })
(locus_statement: Result)

(shell_runtime)-[:PROCESS]->(projection_catalog)
(projection_catalog)-[:PROCESS]->(active_projection)
(active_projection)-[:PROCESS]->(locus_statement)
