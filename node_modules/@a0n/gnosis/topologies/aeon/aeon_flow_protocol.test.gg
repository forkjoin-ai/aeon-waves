// aeon_flow_protocol.test.gg — Verification harness for Aeon Flow primitive
//
// Validates the Fork/Race/Collapse pattern across the five application layers
// described in the Aeon Flow Protocol.

(test_suite: TestSuite { name: 'aeon-flow-protocol' })

(flow_inference: Verify { module: './aeon_flow_inference.gg', beta1_max: '4' })
(flow_speculative: Verify { module: './aeon_flow_speculative_decode.gg', beta1_max: '4' })
(flow_esi: Verify { module: './aeon_flow_esi.gg', beta1_max: '4' })
(flow_sync: Verify { module: './aeon_flow_sync.gg', beta1_max: '4' })
(flow_shell: Verify { module: './aeon_flow_shell.gg', beta1_max: '4' })

(test_suite)-[:FORK]->(flow_inference | flow_speculative | flow_esi | flow_sync | flow_shell)

(flow_inference)-[:RACE { expect: 'safe' }]->(inference_result: Result)
(flow_speculative)-[:RACE { expect: 'safe' }]->(speculative_result: Result)
(flow_esi)-[:RACE { expect: 'safe' }]->(esi_result: Result)
(flow_sync)-[:RACE { expect: 'safe' }]->(sync_result: Result)
(flow_shell)-[:RACE { expect: 'safe' }]->(shell_result: Result)

(inference_result | speculative_result | esi_result | sync_result | shell_result)-[:FOLD { strategy: 'all-pass' }]->(verdict: Verdict)
(verdict)-[:TUNNEL { condition: 'bounded-reject' }]->(aeon_flow_protocol_test_gg_trace:Trace)
(verdict)-[:MEASURE { reason: 'topology-audit' }]->(aeon_flow_protocol_test_gg_trace:Trace)
