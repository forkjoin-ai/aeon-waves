// aeon_shell_rhizome_metabolism.gg — Rhizome Information Metabolism
//
// Document: aeon-shell/docs/rhizome-philosophy.md
// Layer: aeon-shell (Rhizome)
//
// The aeon suite only needs a verified orchestration boundary here. This keeps
// the metabolic flow serial until a richer branch-safe formulation is ready.

(raw_signal: Source { type: 'shell_event' })
(ingest_signal: Processor { mode: 'salience_and_structure' })
(balance_signal: State { entity: 'rhizome_node' })
(world_model: Result)

(raw_signal)-[:PROCESS]->(ingest_signal)
(ingest_signal)-[:PROCESS]->(balance_signal)
(balance_signal)-[:PROCESS]->(world_model)
