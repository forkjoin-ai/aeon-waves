// Aeon-Flux Gnosis Topology
// The core server loop redefined as a Wallington Rotation.

// 1. Server Component Definitions
(request: Source { path: '/manuscript/ch17' })
(router: Router)
(context: UserContext)
(tree: TreeBuilder)
(decision: Decision)
(render: Renderer { type: 'html' })

// 2. The Server Topology
(request)-[:PROCESS]->(router)

// Parallelize context extraction and tree construction
(router)-[:FORK]->(context | tree)

// Collapse into a personalized decision
(context | tree)-[:FOLD { strategy: 'merge-all' }]->(routed_request)
(routed_request)-[:PROCESS]->(decision)

// Final rendering
(decision)-[:PROCESS]->(render)
(render)-[:PROCESS]->(response)
(response)-[:TUNNEL { condition: 'bounded-reject' }]->(aeon_flux_gg_trace:Trace)
(response)-[:MEASURE { reason: 'topology-audit' }]->(aeon_flux_gg_trace:Trace)
