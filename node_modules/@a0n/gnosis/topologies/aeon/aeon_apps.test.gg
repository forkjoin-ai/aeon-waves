// aeon_apps.test.gg — Verification harness for aeon apps
(test_suite: TestSuite { name: 'aeon_apps' })
(cli_command_parser: Verify { module: './cli_command_parser.gg', beta1_max: '6' })
(forge_build_pipeline: Verify { module: './forge_build_pipeline.gg', beta1_max: '6' })
(foundation_did_resolver: Verify { module: './foundation_did_resolver.gg', beta1_max: '6' })
(inference_service_load_balancer: Verify { module: './inference_service_load_balancer.gg', beta1_max: '6' })
(publisher_content_syndication: Verify { module: './publisher_content_syndication.gg', beta1_max: '6' })
(flux_state_reconciliation: Verify { module: './flux_state_reconciliation.gg', beta1_max: '6' })
(logic_theorem_prover: Verify { module: './logic_theorem_prover.gg', beta1_max: '6' })
(verdict: Verdict)

(test_suite)-[:PROCESS]->(cli_command_parser)
(cli_command_parser)-[:PROCESS]->(forge_build_pipeline)
(forge_build_pipeline)-[:PROCESS]->(foundation_did_resolver)
(foundation_did_resolver)-[:PROCESS]->(inference_service_load_balancer)
(inference_service_load_balancer)-[:PROCESS]->(publisher_content_syndication)
(publisher_content_syndication)-[:PROCESS]->(flux_state_reconciliation)
(flux_state_reconciliation)-[:PROCESS]->(logic_theorem_prover)
(logic_theorem_prover)-[:PROCESS]->(verdict)
