// quantum_observer_qbism.gg — THM-QBISM-PRIOR witness
//
// QBist "state" = initialized void boundary (BayesianPrior).
// Two rational agents with the same evidence produce the same state.

(agent_alice: RationalAgent { theorem: 'THM-QBISM-PRIOR', id: 'Alice' })
(agent_bob: RationalAgent { theorem: 'THM-QBISM-PRIOR', id: 'Bob' })
(evidence: VoidBoundary { counts: '[2, 5, 1, 3]', rounds: '8' })
(state_alice: QuantumState { source: 'Alice', weights: '[7, 4, 8, 6]' })
(state_bob: QuantumState { source: 'Bob', weights: '[7, 4, 8, 6]' })
(coherence: Invariant { claim: 'state_alice == state_bob' })
(result: Result { theorem: 'qbism-coherence' })

(evidence)-[:FORK]->(agent_alice | agent_bob)
(agent_alice)-[:PROCESS { expect: 'state-computed' }]->(state_alice)
(agent_bob)-[:PROCESS { expect: 'state-computed' }]->(state_bob)
(state_alice | state_bob)-[:FOLD { strategy: 'verify-equality' }]->(coherence)
(coherence)-[:PROCESS]->(result)
(result)-[:TUNNEL { condition: 'bounded-reject' }]->(quantum_observer_qbism_gg_trace:Trace)
(result)-[:MEASURE { reason: 'topology-audit' }]->(quantum_observer_qbism_gg_trace:Trace)
