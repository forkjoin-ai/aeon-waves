// quantum_observer.test.gg — Native Gnosis witnesses for THM-QUANTUM-OBSERVER
//
// These theorem-shaped `.gg` modules cover:
//   - superposition is fork (beta1 = rootN - 1)
//   - measurement collapses beta1 to 0
//   - measurement deficit is exactly rootN - 1
//   - QBism: observer state = void boundary

(test_suite: TestSuite { name: 'quantum-observer' })

(superposition_fork: Verify { module: './quantum_observer_superposition.gg', beta1_max: '8' })
(measurement_collapse: Verify { module: './quantum_observer_collapse.gg', beta1_max: '8' })
(deficit_exact: Verify { module: './quantum_observer_deficit.gg', beta1_max: '8' })
(qbism_coherence: Verify { module: './quantum_observer_qbism.gg', beta1_max: '8' })

(test_suite)-[:FORK]->(superposition_fork | measurement_collapse | deficit_exact | qbism_coherence)

(superposition_fork)-[:RACE { expect: 'safe' }]->(fork_result: Result)
(measurement_collapse)-[:RACE { expect: 'safe' }]->(collapse_result: Result)
(deficit_exact)-[:RACE { expect: 'safe' }]->(deficit_result: Result)
(qbism_coherence)-[:RACE { expect: 'safe' }]->(qbism_result: Result)

(fork_result | collapse_result | deficit_result | qbism_result)-[:FOLD { strategy: 'all-pass' }]->(verdict: Verdict)
(verdict)-[:TUNNEL { condition: 'bounded-reject' }]->(quantum_observer_test_gg_trace:Trace)
(verdict)-[:MEASURE { reason: 'topology-audit' }]->(quantum_observer_test_gg_trace:Trace)
