// quantum_observer_collapse.gg — THM-OBSERVER-FOLD witness
//
// Measurement collapses beta1 from rootN-1 to 0.
// The fold selects one path and vents rootN-1 paths.

(system: QuantumSystem { theorem: 'THM-OBSERVER-FOLD', rootN: '4', pre_beta1: '3' })
(path_1: QuantumPath { survives: 'true' })
(path_2: QuantumPath { survives: 'false' })
(path_3: QuantumPath { survives: 'false' })
(path_4: QuantumPath { survives: 'false' })
(measurement: Measurement { observer: 'detector' })
(collapsed: CollapsedState { post_beta1: '0' })
(result: Result { theorem: 'measurement-collapses-beta1' })

(system)-[:FORK]->(path_1 | path_2 | path_3 | path_4)
(path_2)-[:VENT { condition: 'not-observed' }]->(vent_2: VentedPath)
(path_3)-[:VENT { condition: 'not-observed' }]->(vent_3: VentedPath)
(path_4)-[:VENT { condition: 'not-observed' }]->(vent_4: VentedPath)
(path_1)-[:PROCESS { strategy: 'measurement' }]->(measurement)
(measurement)-[:PROCESS]->(collapsed)
(collapsed)-[:PROCESS]->(result)
(result)-[:MEASURE { reason: 'topology-audit' }]->(quantum_observer_collapse_gg_trace:Trace)
