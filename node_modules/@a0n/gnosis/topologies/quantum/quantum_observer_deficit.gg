// quantum_observer_deficit.gg — THM-OBSERVER-DEFICIT witness
//
// The measurement deficit is exactly rootN - 1.
// Path conservation: 1 + (rootN - 1) = rootN.

(system: QuantumSystem { theorem: 'THM-OBSERVER-DEFICIT', rootN: '4' })
(pre: Topology { beta1: '3', description: 'before measurement' })
(post: Topology { beta1: '0', description: 'after measurement' })
(deficit: Deficit { value: '3', formula: 'rootN - 1' })
(conservation: Invariant { claim: '1 + 3 = 4', survived: '1', vented: '3', total: '4' })
(result: Result { theorem: 'deficit-exact-and-conserved' })

(system)-[:FORK]->(pre | post)
(pre | post)-[:RACE { expect: 'deficit-computed' }]->(deficit)
(deficit)-[:PROCESS]->(conservation)
(conservation)-[:PROCESS { strategy: 'verify-conservation' }]->(result)
(result)-[:MEASURE { reason: 'topology-audit' }]->(quantum_observer_deficit_gg_trace:Trace)
