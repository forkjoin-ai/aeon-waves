// evidence_monotone.gg — THM-BULEYEAN-EVIDENCE witness (each evidence reduces deficit)
//
// Each piece of evidence that satisfies a dimension reduces the deficit
// by exactly one. The deficit sequence is monotonically decreasing.
// Example: deficit starts at 4, each evidence -> deficit=[4, 3, 2, 1, 0].

(trial: BuleyeanTrial { theorem: 'THM-BULEYEAN-EVIDENCE', required_dimensions: '4' })
(state_0: EvidenceState { evidence_count: '0', deficit: '4' })
(state_1: EvidenceState { evidence_count: '1', deficit: '3' })
(state_2: EvidenceState { evidence_count: '2', deficit: '2' })
(state_3: EvidenceState { evidence_count: '3', deficit: '1' })
(state_4: EvidenceState { evidence_count: '4', deficit: '0' })
(monotone: Invariant { claim: 'each evidence reduces deficit by 1', deficit_sequence: '[4, 3, 2, 1, 0]' })
(result: Result { theorem: 'evidence-reduces-deficit-monotonically' })

(trial)-[:PROCESS]->(state_0)
(state_0)-[:PROCESS]->(state_1)
(state_1)-[:PROCESS]->(state_2)
(state_2)-[:PROCESS]->(state_3)
(state_3)-[:PROCESS]->(state_4)
(state_0 | state_1 | state_2 | state_3 | state_4)-[:RACE { expect: 'monotone-decreasing' }]->(monotone)
(monotone)-[:PROCESS { strategy: 'verify-ordering' }]->(result)
(result)-[:MEASURE { reason: 'topology-audit' }]->(evidence_monotone_gg_trace:Trace)
