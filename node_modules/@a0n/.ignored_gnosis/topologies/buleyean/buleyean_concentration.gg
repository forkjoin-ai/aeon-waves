// buleyean_concentration.gg — THM-BULEYEAN-CONCENTRATION witness
//
// Less rejected choices get higher weight.
// void_i <= void_j implies weight_i >= weight_j.

(space: BuleyeanSpace { theorem: 'THM-BULEYEAN-CONCENTRATION', choices: '3', rounds: '10' })
(choice_low: Choice { id: 'A', void_count: '2', weight: '9' })
(choice_mid: Choice { id: 'B', void_count: '5', weight: '6' })
(choice_high: Choice { id: 'C', void_count: '8', weight: '3' })
(ordering: Invariant { claim: 'weight_A >= weight_B >= weight_C', order: '[9, 6, 3]' })
(result: Result { theorem: 'less-rejected-higher-weight' })

(space)-[:FORK]->(choice_low | choice_mid | choice_high)
(choice_low | choice_mid | choice_high)-[:RACE { expect: 'ordered-by-rejection' }]->(ordering)
(ordering)-[:PROCESS { strategy: 'verify-ordering' }]->(result)
(result)-[:MEASURE { reason: 'topology-audit' }]->(buleyean_concentration_gg_trace:Trace)
