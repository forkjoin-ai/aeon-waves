// buleyean_probability.test.gg — Native Gnosis witnesses for THM-BULEYEAN-PROBABILITY
//
// These theorem-shaped `.gg` modules cover:
//   - positivity: every weight >= 1 (the sliver)
//   - normalization: total weight > 0
//   - concentration: less rejected -> higher weight
//   - coherence: same boundary -> same distribution

(test_suite: TestSuite { name: 'buleyean-probability' })

(positivity: Verify { module: './buleyean_positivity.gg', beta1_max: '4' })
(normalization: Verify { module: './buleyean_normalization.gg', beta1_max: '4' })
(concentration: Verify { module: './buleyean_concentration.gg', beta1_max: '4' })
(coherence: Verify { module: './buleyean_coherence.gg', beta1_max: '4' })

(test_suite)-[:FORK]->(positivity | normalization | concentration | coherence)

(positivity)-[:RACE { expect: 'safe' }]->(pos_result: Result)
(normalization)-[:RACE { expect: 'safe' }]->(norm_result: Result)
(concentration)-[:RACE { expect: 'safe' }]->(conc_result: Result)
(coherence)-[:RACE { expect: 'safe' }]->(coher_result: Result)

(pos_result | norm_result | conc_result | coher_result)-[:FOLD { strategy: 'all-pass' }]->(verdict: Verdict)
(verdict)-[:TUNNEL { condition: 'bounded-reject' }]->(buleyean_probability_test_gg_trace:Trace)
(verdict)-[:MEASURE { reason: 'topology-audit' }]->(buleyean_probability_test_gg_trace:Trace)
