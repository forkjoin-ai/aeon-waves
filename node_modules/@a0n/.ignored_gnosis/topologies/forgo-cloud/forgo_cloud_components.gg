// forgo_cloud_components.gg -- component coverage topology for Forgo.zip
// Purpose: expose missing component classes before page implementation.

(component_audit: Source { source: 'Forgo.zip' })
(shared_ui_scope: Package { path: 'shared-ui/src/components/forgo' })

// Primitive layer
(shell: Component { name: 'ForgoShell' })
(top_nav: Component { name: 'ForgoTopNav' })
(status_bar: Component { name: 'ForgoStatusBar' })
(button: Component { name: 'ForgoButton' })
(card: Component { name: 'ForgoCard' })
(pill: Component { name: 'ForgoPill' })
(key_value: Component { name: 'ForgoKeyValue' })
(metric: Component { name: 'ForgoMetric' })
(tabs: Component { name: 'ForgoTabs' })
(side_nav: Component { name: 'ForgoSideNav' })
(table: Component { name: 'ForgoTable' })
(terminal: Component { name: 'ForgoTerminal' })
(code_block: Component { name: 'ForgoCodeBlock' })
(file_tree: Component { name: 'ForgoFileTree' })
(list: Component { name: 'ForgoList' })
(sparkline: Component { name: 'ForgoSparkline' })
(avatar: Component { name: 'ForgoAvatar' })
(toast: Component { name: 'ForgoToast' })
(command_palette: Component { name: 'ForgoCommandPalette' })
(wave_rail: Component { name: 'ForgoWaveRail' })

// Prototype composite layer
(hero: Component { name: 'ForgoHero' })
(spec_grid: Component { name: 'ForgoSpecGrid' })
(segmented_progress: Component { name: 'ForgoSegmentedProgress' })
(filter_chips: Component { name: 'ForgoFilterChips' })
(scan_findings: Component { name: 'ForgoScanFindingList' })
(job_tree: Component { name: 'ForgoJobTree' })
(inspector: Component { name: 'ForgoInspector' })
(stepper: Component { name: 'ForgoStepper' })
(timeline: Component { name: 'ForgoTimeline' })
(domain_list: Component { name: 'ForgoDomainList' })
(artifact_list: Component { name: 'ForgoArtifactList' })
(notification_list: Component { name: 'ForgoNotificationList' })

(component_audit)-[:PROCESS]->(shared_ui_scope)
(shared_ui_scope)-[:FORK]->(
  shell | top_nav | status_bar | button | button_group | button_action_group |
  button_toolbar_group | button_choice_group | button_icon | button_split |
  button_toggle | card | card_group | card_grid_group | card_stack_group |
  card_split_group | card_section | pill | key_value | metric |
  tabs | side_nav | table | terminal | code_block | file_tree | list |
  sparkline | avatar | toast | command_palette | wave_rail | hero |
  spec_grid | segmented_progress | filter_chips | scan_findings | job_tree |
  inspector | stepper | timeline | domain_list | artifact_list |
  notification_list
)

(
  shell | top_nav | status_bar | button | button_group | button_action_group |
  button_toolbar_group | button_choice_group | button_icon | button_split |
  button_toggle | card | card_group | card_grid_group | card_stack_group |
  card_split_group | card_section | pill | key_value | metric |
  tabs | side_nav | table | terminal | code_block | file_tree | list |
  sparkline | avatar | toast | command_palette | wave_rail | hero |
  spec_grid | segmented_progress | filter_chips | scan_findings | job_tree |
  inspector | stepper | timeline | domain_list | artifact_list |
  notification_list
)-[:FOLD { strategy: 'component-inventory' }]->(component_inventory: Inventory)

// Screen-to-component obligations. If a screen introduces a new widget family,
// it must enter this graph before implementation.
(landing_components: Coverage { screen: 'landing' })
(scanner_components: Coverage { screen: 'scanner' })
(import_components: Coverage { screen: 'import' })
(repo_components: Coverage { screen: 'repo' })
(project_components: Coverage { screen: 'project' })
(profile_components: Coverage { screen: 'profile' })
(phyle_components: Coverage { screen: 'phyle' })
(orchestration_components: Coverage { screen: 'orchestration' })
(runs_components: Coverage { screen: 'runs' })
(run_detail_components: Coverage { screen: 'run-detail' })
(folds_components: Coverage { screen: 'folds' })
(canary_components: Coverage { screen: 'canary' })
(cd_components: Coverage { screen: 'cd' })
(docs_components: Coverage { screen: 'docs' })
(ide_components: Coverage { screen: 'ide' })
(artifacts_components: Coverage { screen: 'artifacts' })
(env_components: Coverage { screen: 'env' })
(members_components: Coverage { screen: 'members' })
(billing_components: Coverage { screen: 'billing' })
(audit_components: Coverage { screen: 'audit' })
(nexus_components: Coverage { screen: 'nexus' })
(notifications_components: Coverage { screen: 'notifications' })
(settings_components: Coverage { screen: 'settings' })

(component_inventory)-[:FORK]->(
  landing_components | scanner_components | import_components |
  repo_components | project_components | profile_components |
  phyle_components | orchestration_components | runs_components |
  run_detail_components | folds_components | canary_components |
  cd_components | docs_components | ide_components |
  artifacts_components | env_components | members_components |
  billing_components | audit_components | nexus_components |
  notifications_components | settings_components
)

(
  landing_components | scanner_components | import_components |
  repo_components | project_components | profile_components |
  phyle_components | orchestration_components | runs_components |
  run_detail_components | folds_components | canary_components |
  cd_components | docs_components | ide_components |
  artifacts_components | env_components | members_components |
  billing_components | audit_components | nexus_components |
  notifications_components | settings_components
)-[:FOLD { strategy: 'all-screens-covered' }]->(component_coverage_complete: Sink)
(component_coverage_complete)-[:TUNNEL { condition: 'bounded-reject' }]->(forgo_cloud_components_gg_trace:Trace)
(component_coverage_complete)-[:MEASURE { reason: 'topology-audit' }]->(forgo_cloud_components_gg_trace:Trace)
