// forgo_cloud_user_stories.gg -- executable user-story topology for forgo.cloud
// Stories are derived from verified route, interaction, data, and error modules.

(story_root: Source { suite: 'forgo_cloud_user_stories' })

(story_onboard: UserStory { id: 'onboard-workspace', actor: 'new operator', flow: 'onboarding', screens: 'landing,import,scanner,ide' })
(story_scan_public_url: UserStory { id: 'scan-public-url', actor: 'repo evaluator', flow: 'onboarding', screens: 'scanner', api: 'POST /api/scans/public-url' })
(story_repo_to_ide: UserStory { id: 'repo-to-ide', actor: 'maintainer', flow: 'repo workspace', screens: 'repo,ide' })
(story_review_trace: UserStory { id: 'review-trace', actor: 'maintainer', flow: 'repo workspace', screens: 'repo,run-detail' })
(story_control_delivery: UserStory { id: 'control-delivery', actor: 'release operator', flow: 'delivery', screens: 'orchestration,runs,run-detail,cd' })
(story_promote_canary: UserStory { id: 'promote-canary', actor: 'release operator', flow: 'delivery', screens: 'cd', api: 'POST /api/projects/:projectId/canary/promote' })
(story_manage_org: UserStory { id: 'manage-org', actor: 'admin', flow: 'admin social', screens: 'members,billing,settings' })
(story_verify_trust: UserStory { id: 'verify-trust', actor: 'security operator', flow: 'admin social', screens: 'audit,nexus', api: 'POST /api/audit/verify-root' })
(story_handle_notifications: UserStory { id: 'handle-notifications', actor: 'operator', flow: 'admin social', screens: 'notifications', api: 'POST /api/notifications/:id/read' })
(story_recover_errors: UserStory { id: 'recover-errors', actor: 'any operator', flow: 'error recovery', screens: 'all', recovery: 'retry or reconnect without losing context' })

(story_root)-[:FORK]->(
  story_onboard | story_scan_public_url | story_repo_to_ide |
  story_review_trace | story_control_delivery | story_promote_canary |
  story_manage_org | story_verify_trust | story_handle_notifications |
  story_recover_errors
)

(
  story_onboard | story_scan_public_url | story_repo_to_ide |
  story_review_trace | story_control_delivery | story_promote_canary |
  story_manage_org | story_verify_trust | story_handle_notifications |
  story_recover_errors
)-[:FOLD { strategy: 'all-user-stories-covered' }]->(user_story_coverage_complete: Sink)
(user_story_coverage_complete)-[:TUNNEL { condition: 'bounded-reject' }]->(forgo_cloud_user_stories_gg_trace:Trace)
(user_story_coverage_complete)-[:MEASURE { reason: 'topology-audit' }]->(forgo_cloud_user_stories_gg_trace:Trace)
