// forgo_cloud_generation.gg -- generation topology for implementation artifacts
// The checked app topology feeds screen tasks, user stories, and Playwright specs.

(checked_topology: Source { suite: 'forgo_cloud.test.gg' })
(screen_inventory: Artifact { kind: 'screens', count: '20' })
(component_inventory: Artifact { kind: 'components' })
(interaction_inventory: Artifact { kind: 'clicks' })
(api_inventory: Artifact { kind: 'api-contracts' })
(inventory_complete: Checkpoint { name: 'all inventories loaded' })
(screen_tasks: Generator { output: 'apps/aeon-forge screens' })
(component_gaps: Generator { output: 'shared-ui component gaps' })
(user_stories: Generator { output: 'user stories' })
(playwright_specs: Generator { output: 'playwright specs' })
(api_tasks: Generator { output: 'forgo-cloud-worker endpoints' })

(checked_topology)-[:FORK]->(screen_inventory | component_inventory | interaction_inventory | api_inventory)

(screen_inventory | component_inventory | interaction_inventory | api_inventory)-[:FOLD { strategy: 'inventory-check' }]->(inventory_complete)

(inventory_complete)-[:FORK]->(
  screen_tasks | component_gaps | user_stories | playwright_specs | api_tasks
)

(screen_tasks | component_gaps | user_stories | playwright_specs | api_tasks)-[:FOLD { strategy: 'implementation-plan' }]->(implementation_plan)
(implementation_plan)-[:PROCESS]->(execute_after_check: Sink { rule: 'no-pages-before-topology-green' })
(execute_after_check)-[:TUNNEL { condition: 'bounded-reject' }]->(forgo_cloud_generation_gg_trace:Trace)
(execute_after_check)-[:MEASURE { reason: 'topology-audit' }]->(forgo_cloud_generation_gg_trace:Trace)
