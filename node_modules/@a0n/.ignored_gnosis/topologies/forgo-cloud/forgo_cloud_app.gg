// forgo_cloud_app.gg -- route and screen topology for the forgo.cloud reskin
// Visual source of truth: /Users/buley/Downloads/Forgo.zip, Direction C.

(entry: AppRoot { product: 'forgo.cloud', source: 'Forgo.zip' })
(route_matcher: Router { op: 'match_route' })
(auth_state: State { op: 'resolve_session' })
(feature_flags: State { op: 'resolve_forgo_flags' })
(layout_shell: Component { name: 'ForgoShell' })
(top_nav: Component { name: 'ForgoTopNav' })
(status_bar: Component { name: 'ForgoStatusBar' })

(entry)-[:PROCESS]->(route_matcher)
(entry)-[:FORK]->(auth_state | feature_flags)
(auth_state | feature_flags)-[:FOLD { strategy: 'merge-all' }]->(layout_shell)
(layout_shell)-[:PROCESS]->(top_nav)
(top_nav)-[:PROCESS]->(status_bar)
(status_bar)-[:PROCESS]->(route_matcher)

// Public/product surfaces
(landing: Screen { slug: 'landing', route: '/', prototype: '01-landing.html' })
(scanner: Screen { slug: 'scanner', route: '/scanner', prototype: '02-scanner.html' })
(import_repo: Screen { slug: 'import', route: '/import', prototype: '03-import.html' })

// Org/repo/project/phyle surfaces
(repo: Screen { slug: 'repo', route: '/:owner/:repo', prototype: '04-repo.html' })
(project: Screen { slug: 'project', route: '/projects/:projectId', prototype: '05-project.html' })
(profile: Screen { slug: 'profile', route: '/:owner', prototype: '06-profile.html' })
(phyle: Screen { slug: 'phyle', route: '/phyle/:slug', prototype: '07-phyle.html' })

// Delivery/runtime surfaces
(orchestration: Screen { slug: 'orchestration', route: '/orchestration', prototype: '08-orchestration.html' })
(runs: Screen { slug: 'runs', route: '/runs', prototype: '09-runs.html' })
(run_detail: Screen { slug: 'run-detail', route: '/runs/:runId', prototype: '10-run-detail.html' })
(folds: Screen { slug: 'folds', route: '/folds', prototype: '21-folds.html' })
(canary: Screen { slug: 'canary', route: '/canary', prototype: '22-canary.html' })
(cd_dashboard: Screen { slug: 'cd', route: '/cd', prototype: '11-cd-dashboard.html' })
(docs: Screen { slug: 'docs', route: '/docs', prototype: '23-docs.html' })
(ide: Screen { slug: 'ide', route: '/ide/:owner/:repo', prototype: '12-ide.html' })

// Build/delivery/admin surfaces
(artifacts: Screen { slug: 'artifacts', route: '/artifacts', prototype: '13-artifacts.html' })
(env_secrets: Screen { slug: 'env', route: '/env', prototype: '14-env-secrets.html' })
(members: Screen { slug: 'members', route: '/members', prototype: '15-members.html' })
(billing: Screen { slug: 'billing', route: '/billing', prototype: '16-billing.html' })
(audit: Screen { slug: 'audit', route: '/audit', prototype: '17-audit.html' })
(nexus: Screen { slug: 'nexus', route: '/nexus', prototype: '18-nexus.html' })
(notifications: Screen { slug: 'notifications', route: '/notifications', prototype: '19-notifications.html' })
(settings: Screen { slug: 'settings', route: '/settings', prototype: '20-settings.html' })

// Route matching fans out to the exact prototype screens.
(route_matcher)-[:FORK]->(
  landing | scanner | import_repo | repo | project | profile | phyle |
  orchestration | runs | run_detail | folds | canary | cd_dashboard |
  docs | ide | artifacts |
  env_secrets | members | billing | audit | nexus | notifications | settings
)

// Each screen must collapse through a shared shell render path.
(
  landing | scanner | import_repo | repo | project | profile | phyle |
  orchestration | runs | run_detail | folds | canary | cd_dashboard |
  docs | ide | artifacts |
  env_secrets | members | billing | audit | nexus | notifications | settings
)-[:FOLD { strategy: 'screen-selected' }]->(screen_context: ScreenContext)

(screen_context)-[:PROCESS]->(component_contract: ComponentContract)
(component_contract)-[:PROCESS]->(data_contract: DataContract)
(data_contract)-[:PROCESS]->(render_plan: RenderPlan)
(render_plan)-[:PROCESS]->(app_ready: Sink { name: 'app_ready' })
(app_ready)-[:TUNNEL { condition: 'bounded-reject' }]->(forgo_cloud_app_gg_trace:Trace)
(app_ready)-[:MEASURE { reason: 'topology-audit' }]->(forgo_cloud_app_gg_trace:Trace)
