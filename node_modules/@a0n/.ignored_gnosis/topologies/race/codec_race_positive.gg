// codec_race_positive.gg — THM-CODEC-RACING witness (raceMin always positive)
//
// The minimum wire size from racing is always > 0. You cannot encode
// a non-trivial message in zero bits regardless of how many codecs race.
// Every codec must produce at least 1 bit per non-trivial message.

(race: CodecRace { theorem: 'THM-CODEC-RACING', codecs: '4', messages: '3' })
(codec_a: Codec { id: 'A', sizes: '[2, 3, 1]', min: '1' })
(codec_b: Codec { id: 'B', sizes: '[4, 1, 2]', min: '1' })
(codec_c: Codec { id: 'C', sizes: '[1, 5, 3]', min: '1' })
(codec_d: Codec { id: 'D', sizes: '[3, 2, 1]', min: '1' })
(race_min: RaceResult { per_message_min: '[1, 1, 1]', total: '3' })
(positivity: Invariant { claim: 'raceMin > 0 for non-trivial messages', minimum: '1' })
(result: Result { theorem: 'race-min-positive' })

(race)-[:FORK]->(codec_a | codec_b | codec_c | codec_d)
(codec_a | codec_b | codec_c | codec_d)-[:RACE { expect: 'per-message-minimum' }]->(race_min)
(race_min)-[:PROCESS]->(positivity)
(positivity)-[:PROCESS { strategy: 'verify-positive' }]->(result)
(result)-[:MEASURE { reason: 'topology-audit' }]->(codec_race_positive_gg_trace:Trace)
