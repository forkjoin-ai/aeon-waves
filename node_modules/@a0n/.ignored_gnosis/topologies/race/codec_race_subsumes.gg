// codec_race_subsumes.gg — THM-CODEC-RACING witness (racing <= any fixed codec)
//
// Given a set of codecs, the racing strategy picks the best codec per message.
// The wire size of racing is always <= the wire size of any single fixed codec.
// Example: codecs A (sizes [3,7,2]), B (sizes [5,2,4]). Race picks [3,2,2] = 7 total.
// Fixed A = 12, Fixed B = 11. Race = 7 <= min(12, 11).

(race: CodecRace { theorem: 'THM-CODEC-RACING', codecs: '2', messages: '3' })
(codec_a: Codec { id: 'A', sizes: '[3, 7, 2]', total: '12' })
(codec_b: Codec { id: 'B', sizes: '[5, 2, 4]', total: '11' })
(race_result: RaceResult { sizes: '[3, 2, 2]', total: '7' })
(subsumption: Invariant { claim: 'race_total <= min(codec_totals)', race: '7', min_fixed: '11' })
(result: Result { theorem: 'race-subsumes-fixed-codec' })

(race)-[:FORK]->(codec_a | codec_b)
(codec_a | codec_b)-[:RACE { expect: 'per-message-minimum' }]->(race_result)
(race_result)-[:PROCESS]->(subsumption)
(subsumption)-[:PROCESS { strategy: 'verify-inequality' }]->(result)
(result)-[:MEASURE { reason: 'topology-audit' }]->(codec_race_subsumes_gg_trace:Trace)
