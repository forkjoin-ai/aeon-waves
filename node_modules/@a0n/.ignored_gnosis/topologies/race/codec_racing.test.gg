// codec_racing.test.gg — Native Gnosis witnesses for THM-CODEC-RACING
//
// These theorem-shaped `.gg` modules cover:
//   - racing subsumes any fixed codec (race <= any)
//   - adding codecs never increases wire size (monotone)
//   - raceMin is always positive (positive)

(test_suite: TestSuite { name: 'codec-racing' })

(subsumes: Verify { module: './codec_race_subsumes.gg', beta1_max: '5' })
(monotone: Verify { module: './codec_race_monotone.gg', beta1_max: '5' })
(positive: Verify { module: './codec_race_positive.gg', beta1_max: '5' })

(test_suite)-[:FORK]->(subsumes | monotone | positive)

(subsumes)-[:RACE { expect: 'safe' }]->(subsumes_result: Result)
(monotone)-[:RACE { expect: 'safe' }]->(monotone_result: Result)
(positive)-[:RACE { expect: 'safe' }]->(positive_result: Result)

(subsumes_result | monotone_result | positive_result)-[:FOLD { strategy: 'all-pass' }]->(verdict: Verdict)
(verdict)-[:TUNNEL { condition: 'bounded-reject' }]->(codec_racing_test_gg_trace:Trace)
(verdict)-[:MEASURE { reason: 'topology-audit' }]->(codec_racing_test_gg_trace:Trace)
