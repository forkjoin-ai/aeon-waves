// race_winner_valid.gg — THM-RACE-WINNER-CORRECTNESS witness (winner has valid result)
//
// The race winner always produces a valid, non-error result.
// Among all competing branches, the first to finish yields
// a well-formed output that satisfies the result contract.
// Example: 3 racers, racer B finishes first with valid output.

(race: Race { theorem: 'THM-RACE-WINNER-CORRECTNESS', racers: '3' })
(racer_a: Racer { id: 'A', finish_time: '5', output: 'valid' })
(racer_b: Racer { id: 'B', finish_time: '2', output: 'valid' })
(racer_c: Racer { id: 'C', finish_time: '7', output: 'valid' })
(winner: Winner { racer: 'B', output: 'valid', time: '2' })
(invariant: Invariant { claim: 'winner_output_is_valid', winner: 'B', valid: 'true' })
(result: Result { theorem: 'race-winner-valid' })

(race)-[:FORK]->(racer_a | racer_b | racer_c)
(racer_a | racer_b | racer_c)-[:RACE { expect: 'first-valid-wins' }]->(winner)
(winner)-[:PROCESS]->(invariant)
(invariant)-[:PROCESS { strategy: 'verify-valid' }]->(result)
(result)-[:MEASURE { reason: 'topology-audit' }]->(race_winner_valid_gg_trace:Trace)
