// diversity_subsumption.gg — THM-DIVERSITY-OPTIMALITY witness (diversity contains monoculture)
//
// A diverse fork (N branches) strictly subsumes a monoculture (1 branch).
// The monoculture is a special case where N-1 branches are copies.
// The diverse fork's complement distribution includes the monoculture's
// single-point distribution as a degenerate case.

(space: DiversitySpace { theorem: 'THM-DIVERSITY-OPTIMALITY', rounds: '8' })
(monoculture: ForkConfig { branches: '1', strategies: '[A]', weights: '[9]', entropy: '0.00' })
(diverse: ForkConfig { branches: '4', strategies: '[A, B, C, D]', weights: '[9, 6, 3, 1]', entropy: '1.63' })
(subsumption: Invariant { claim: 'diverse contains monoculture as degenerate case', mono_entropy: '0.00', diverse_entropy: '1.63' })
(result: Result { theorem: 'diversity-subsumes-monoculture' })

(space)-[:FORK]->(monoculture | diverse)
(monoculture | diverse)-[:RACE { expect: 'diverse-dominates' }]->(subsumption)
(subsumption)-[:PROCESS { strategy: 'verify-subsumption' }]->(result)
(result)-[:MEASURE { reason: 'topology-audit' }]->(diversity_subsumption_gg_trace:Trace)
