// diversity_monotone.gg — THM-DIVERSITY-OPTIMALITY witness (more branches never hurt)
//
// Adding a branch to a fork can only increase or maintain the quality
// of the fold result. The void walker gains more rejection data.
// Performance with N+1 branches >= performance with N branches.

(space: DiversitySpace { theorem: 'THM-DIVERSITY-OPTIMALITY', rounds: '10' })
(fork_3: ForkConfig { branches: '3', best_weight: '8', total_information: '15' })
(fork_4: ForkConfig { branches: '4', best_weight: '8', total_information: '19' })
(fork_5: ForkConfig { branches: '5', best_weight: '9', total_information: '24' })
(fork_6: ForkConfig { branches: '6', best_weight: '9', total_information: '28' })
(monotone: Invariant { claim: 'info(N+1) >= info(N)', sequence: '[15, 19, 24, 28]' })
(result: Result { theorem: 'more-branches-never-hurt' })

(space)-[:FORK]->(fork_3 | fork_4 | fork_5 | fork_6)
(fork_3 | fork_4 | fork_5 | fork_6)-[:RACE { expect: 'non-decreasing' }]->(monotone)
(monotone)-[:PROCESS { strategy: 'verify-ordering' }]->(result)
(result)-[:MEASURE { reason: 'topology-audit' }]->(diversity_monotone_gg_trace:Trace)
