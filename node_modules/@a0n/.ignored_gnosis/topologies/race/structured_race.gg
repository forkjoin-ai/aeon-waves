// Structured concurrency: race losers are cancelled by rule.

(seed:Scalar { value: "0" })-[:FORK]->(fast:Delay { ms: "1", emit: "fast-path" } | slow:Delay { ms: "25", emit: "slow-path" })
(fast | slow)-[:RACE { timeoutMs: "20" }]->(sink:Sink)
(sink)-[:MEASURE { reason: 'topology-audit' }]->(structured_race_gg_trace:Trace)
