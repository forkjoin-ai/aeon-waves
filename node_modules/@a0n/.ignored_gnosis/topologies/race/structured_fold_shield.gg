// Structured concurrency: shielded folds preserve timed-out branches as values.

(seed:Scalar { value: "0" })-[:FORK]->(ready:Delay { ms: "1", emit: "ready-path" } | stalled:Delay { ms: "25", emit: "late-path" })
(ready | stalled)-[:FOLD { timeoutMs: "5", failure: "shield" }]->(sink:Sink)
(sink)-[:TUNNEL { condition: 'bounded-reject' }]->(structured_fold_shield_gg_trace:Trace)
(sink)-[:MEASURE { reason: 'topology-audit' }]->(structured_fold_shield_gg_trace:Trace)
