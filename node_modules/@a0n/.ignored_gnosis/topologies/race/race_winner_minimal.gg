// race_winner_minimal.gg — THM-RACE-WINNER-CORRECTNESS witness (winner completes no later than others)
//
// The race winner's completion time is <= every other racer's time.
// No racer finishes strictly before the winner.
// Example: times [5, 2, 7], winner time = 2 <= min(5, 7).

(race: Race { theorem: 'THM-RACE-WINNER-CORRECTNESS', racers: '3' })
(racer_a: Racer { id: 'A', finish_time: '5' })
(racer_b: Racer { id: 'B', finish_time: '2' })
(racer_c: Racer { id: 'C', finish_time: '7' })
(winner: Winner { racer: 'B', time: '2' })
(minimality: Invariant { claim: 'winner_time_le_all', winner_time: '2', other_min: '5' })
(result: Result { theorem: 'race-winner-minimal' })

(race)-[:FORK]->(racer_a | racer_b | racer_c)
(racer_a | racer_b | racer_c)-[:RACE { expect: 'minimum-time' }]->(winner)
(winner)-[:PROCESS]->(minimality)
(minimality)-[:PROCESS { strategy: 'verify-inequality' }]->(result)
(result)-[:MEASURE { reason: 'topology-audit' }]->(race_winner_minimal_gg_trace:Trace)
