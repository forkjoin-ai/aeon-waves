// quorum_visibility.test.gg — Native Gnosis witnesses for THM-QUORUM-VISIBILITY
//
// These theorem-shaped `.gg` modules cover:
//   - majority quorum sees all writes (majority_visible)
//   - safety under minority partition (partition_safe)
//   - async progress under fairness (async_progress)

(test_suite: TestSuite { name: 'quorum-visibility' })

(majority_visible: Verify { module: './quorum_majority_visible.gg', beta1_max: '6' })
(partition_safe: Verify { module: './quorum_partition_safe.gg', beta1_max: '6' })
(async_progress: Verify { module: './quorum_async_progress.gg', beta1_max: '6' })

(test_suite)-[:FORK]->(majority_visible | partition_safe | async_progress)

(majority_visible)-[:RACE { expect: 'safe' }]->(majority_result: Result)
(partition_safe)-[:RACE { expect: 'safe' }]->(partition_result: Result)
(async_progress)-[:RACE { expect: 'safe' }]->(progress_result: Result)

(majority_result | partition_result | progress_result)-[:FOLD { strategy: 'all-pass' }]->(verdict: Verdict)
(verdict)-[:TUNNEL { condition: 'bounded-reject' }]->(quorum_visibility_test_gg_trace:Trace)
(verdict)-[:MEASURE { reason: 'topology-audit' }]->(quorum_visibility_test_gg_trace:Trace)
