// quorum_majority_visible.gg — THM-QUORUM-VISIBILITY witness (majority quorum sees all writes)
//
// A quorum of ceil(n/2 + 1) replicas guarantees that every committed
// write is visible to at least one member of every read quorum.
// Example: 5 replicas, write quorum = 3, read quorum = 3 -> overlap >= 1.

(cluster: QuorumCluster { theorem: 'THM-QUORUM-VISIBILITY', replicas: '5', write_q: '3', read_q: '3' })
(replica_1: Replica { id: '1', has_write: 'true' })
(replica_2: Replica { id: '2', has_write: 'true' })
(replica_3: Replica { id: '3', has_write: 'true' })
(replica_4: Replica { id: '4', has_write: 'false' })
(replica_5: Replica { id: '5', has_write: 'false' })
(overlap: QuorumOverlap { write_q: '3', read_q: '3', overlap: '1', min_required: '1' })
(invariant: Invariant { claim: 'majority_quorum_sees_all_writes', overlap: '1' })
(result: Result { theorem: 'majority-quorum-visible' })

(cluster)-[:FORK]->(replica_1 | replica_2 | replica_3 | replica_4 | replica_5)
(replica_1 | replica_2 | replica_3)-[:RACE { expect: 'write-acknowledged' }]->(overlap)
(overlap)-[:PROCESS]->(invariant)
(invariant)-[:PROCESS { strategy: 'verify-positive' }]->(result)
(result)-[:MEASURE { reason: 'topology-audit' }]->(quorum_majority_visible_gg_trace:Trace)
