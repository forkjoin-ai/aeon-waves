// reynolds_bft.test.gg — Native Gnosis witnesses for THM-REYNOLDS-BFT
//
// These theorem-shaped `.gg` modules cover:
//   - laminar regime: C >= N implies 0 idle stages
//   - turbulent regime: C < N implies positive idle stages
//   - low Reynolds number implies quorum safety

(test_suite: TestSuite { name: 'reynolds-bft' })

(laminar: Verify { module: './reynolds_laminar.gg', beta1_max: '6' })
(turbulent: Verify { module: './reynolds_turbulent.gg', beta1_max: '6' })
(quorum_safe: Verify { module: './reynolds_quorum_safe.gg', beta1_max: '6' })

(test_suite)-[:FORK]->(laminar | turbulent | quorum_safe)

(laminar)-[:RACE { expect: 'safe' }]->(laminar_result: Result)
(turbulent)-[:RACE { expect: 'safe' }]->(turbulent_result: Result)
(quorum_safe)-[:RACE { expect: 'safe' }]->(quorum_result: Result)

(laminar_result | turbulent_result | quorum_result)-[:FOLD { strategy: 'all-pass' }]->(verdict: Verdict)
(verdict)-[:TUNNEL { condition: 'bounded-reject' }]->(reynolds_bft_test_gg_trace:Trace)
(verdict)-[:MEASURE { reason: 'topology-audit' }]->(reynolds_bft_test_gg_trace:Trace)
