// reynolds_laminar.gg — THM-REYNOLDS-BFT witness (C >= N implies 0 idle stages)
//
// In the laminar regime, channel capacity C meets or exceeds the number
// of nodes N. All nodes can communicate simultaneously -- zero idle stages.
// Re = N/C <= 1 implies laminar flow.

(network: BFTNetwork { theorem: 'THM-REYNOLDS-BFT', nodes: '4', capacity: '6' })
(node_1: BFTNode { id: '1', active: 'true', idle_stages: '0' })
(node_2: BFTNode { id: '2', active: 'true', idle_stages: '0' })
(node_3: BFTNode { id: '3', active: 'true', idle_stages: '0' })
(node_4: BFTNode { id: '4', active: 'true', idle_stages: '0' })
(reynolds: ReynoldsNumber { value: '0.67', regime: 'laminar', threshold: '1.0' })
(idle: Invariant { claim: 'C >= N implies idle_stages = 0', total_idle: '0' })
(result: Result { theorem: 'laminar-zero-idle' })

(network)-[:FORK]->(node_1 | node_2 | node_3 | node_4)
(node_1 | node_2 | node_3 | node_4)-[:RACE { expect: 'all-active' }]->(reynolds)
(reynolds)-[:PROCESS]->(idle)
(idle)-[:PROCESS { strategy: 'verify-zero' }]->(result)
(result)-[:MEASURE { reason: 'topology-audit' }]->(reynolds_laminar_gg_trace:Trace)
