// reynolds_quorum_safe.gg — THM-REYNOLDS-BFT witness (low Re implies quorum safe)
//
// When Re <= 1 (laminar), every communication round reaches all nodes.
// Quorum of 2f+1 out of 3f+1 nodes is guaranteed in a single round.
// Example: f=1, N=4, quorum=3. With C=5, Re=0.8, quorum reached in 1 round.

(network: BFTNetwork { theorem: 'THM-REYNOLDS-BFT', nodes: '4', capacity: '5', fault_tolerance: '1' })
(quorum_needed: QuorumThreshold { value: '3', formula: '2f+1', f: '1' })
(round_1: CommRound { active_nodes: '4', idle_nodes: '0', round: '1' })
(reynolds: ReynoldsNumber { value: '0.8', regime: 'laminar', threshold: '1.0' })
(safety: Invariant { claim: 'low Re -> quorum in 1 round', quorum: '3', reached_in_round: '1', nodes_reached: '4' })
(result: Result { theorem: 'low-re-quorum-safe' })

(network)-[:FORK]->(quorum_needed | round_1)
(round_1)-[:PROCESS { expect: 'quorum-reached' }]->(reynolds)
(quorum_needed | reynolds)-[:FOLD { strategy: 'verify-quorum' }]->(safety)
(safety)-[:PROCESS]->(result)
(result)-[:TUNNEL { condition: 'bounded-reject' }]->(reynolds_quorum_safe_gg_trace:Trace)
(result)-[:MEASURE { reason: 'topology-audit' }]->(reynolds_quorum_safe_gg_trace:Trace)
