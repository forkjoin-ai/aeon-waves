// staged_frontier_conserved.gg — THM-STAGED-EXPANSION witness (staged area = naive area)
//
// The total area covered by staged expansion equals the area of
// naive (all-at-once) expansion. Staging redistributes work but
// does not lose or gain coverage.
// Example: naive area = 12, staged [4, 4, 4] = 12.

(expansion: StagedExpansion { theorem: 'THM-STAGED-EXPANSION', stages: '3' })
(naive: NaiveExpansion { area: '12' })
(stage_1: Stage { id: '1', area: '4' })
(stage_2: Stage { id: '2', area: '4' })
(stage_3: Stage { id: '3', area: '4' })
(staged_total: StagedTotal { areas: '[4, 4, 4]', total: '12' })
(invariant: Invariant { claim: 'staged_equals_naive', staged: '12', naive: '12' })
(result: Result { theorem: 'frontier-area-conserved' })

(expansion)-[:FORK]->(stage_1 | stage_2 | stage_3)
(stage_1 | stage_2 | stage_3)-[:RACE { expect: 'area-summed' }]->(staged_total)
(naive | staged_total)-[:RACE { expect: 'equal-area' }]->(invariant)
(invariant)-[:PROCESS { strategy: 'verify-equality' }]->(result)
(result)-[:MEASURE { reason: 'topology-audit' }]->(staged_frontier_conserved_gg_trace:Trace)
