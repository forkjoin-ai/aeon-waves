// covering_space.test.gg — Native Gnosis witnesses for THM-COVERING-SPACE-CAUSALITY
//
// These theorem-shaped `.gg` modules cover:
//   - topology mismatch blocks progress (mismatch_blocks)
//   - matched topology clears blocking (match_clears)
//   - deficit quantifies latency inflation (deficit_inflation)

(test_suite: TestSuite { name: 'covering-space-causality' })

(mismatch_blocks: Verify { module: './covering_mismatch_blocks.gg', beta1_max: '6' })
(match_clears: Verify { module: './covering_match_clears.gg', beta1_max: '6' })
(deficit_inflation: Verify { module: './covering_deficit_inflation.gg', beta1_max: '6' })

(test_suite)-[:FORK]->(mismatch_blocks | match_clears | deficit_inflation)

(mismatch_blocks)-[:RACE { expect: 'safe' }]->(mismatch_result: Result)
(match_clears)-[:RACE { expect: 'safe' }]->(match_result: Result)
(deficit_inflation)-[:RACE { expect: 'safe' }]->(inflation_result: Result)

(mismatch_result | match_result | inflation_result)-[:FOLD { strategy: 'all-pass' }]->(verdict: Verdict)
(verdict)-[:TUNNEL { condition: 'bounded-reject' }]->(covering_space_test_gg_trace:Trace)
(verdict)-[:MEASURE { reason: 'topology-audit' }]->(covering_space_test_gg_trace:Trace)
