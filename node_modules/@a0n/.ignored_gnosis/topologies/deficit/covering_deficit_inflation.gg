// covering_deficit_inflation.gg — THM-COVERING-SPACE-CAUSALITY witness (deficit quantifies latency inflation)
//
// The covering deficit (base_sheets - cover_sheets) directly inflates
// the latency of causal lifts. Each missing fiber adds one unit of
// inflation to the worst-case lift time.
// Example: deficit = 2 -> latency inflated by factor 2.

(space: CoveringSpace { theorem: 'THM-COVERING-SPACE-CAUSALITY', base_sheets: '5', cover_sheets: '3' })
(deficit: Deficit { value: '2' })
(baseline_latency: Latency { matched: '1', inflated: '3' })
(invariant: Invariant { claim: 'inflation_equals_deficit_plus_one', deficit: '2', inflation: '3' })
(result: Result { theorem: 'deficit-quantifies-inflation' })

(space)-[:PROCESS]->(deficit)
(deficit)-[:PROCESS { expect: 'latency-inflated' }]->(baseline_latency)
(baseline_latency)-[:PROCESS]->(invariant)
(invariant)-[:PROCESS { strategy: 'verify-equality' }]->(result)
