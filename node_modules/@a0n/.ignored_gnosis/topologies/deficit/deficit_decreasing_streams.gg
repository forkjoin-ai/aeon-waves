// deficit_decreasing_streams.gg — THM-DEFICIT-CAPACITY witness (more streams -> less deficit)
//
// Increasing the number of available streams monotonically decreases
// the deficit. Each additional stream can absorb one excess path.
// Example: 5 paths with 3 streams -> deficit 2, with 4 streams -> deficit 1.

(capacity: DeficitCapacity { theorem: 'THM-DEFICIT-CAPACITY', paths: '5' })
(config_3: StreamConfig { streams: '3', deficit: '2' })
(config_4: StreamConfig { streams: '4', deficit: '1' })
(config_5: StreamConfig { streams: '5', deficit: '0' })
(monotone: Invariant { claim: 'more_streams_less_deficit', d_3: '2', d_4: '1', d_5: '0' })
(result: Result { theorem: 'deficit-decreasing-in-streams' })

(capacity)-[:FORK]->(config_3 | config_4 | config_5)
(config_3 | config_4 | config_5)-[:RACE { expect: 'monotone-decreasing' }]->(monotone)
(monotone)-[:PROCESS { strategy: 'verify-inequality' }]->(result)
(result)-[:MEASURE { reason: 'topology-audit' }]->(deficit_decreasing_streams_gg_trace:Trace)
