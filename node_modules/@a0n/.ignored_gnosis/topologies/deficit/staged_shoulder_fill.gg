// staged_shoulder_fill.gg — THM-STAGED-EXPANSION witness (shoulders fill before widening)
//
// In staged expansion, the shoulder regions (edges of each stage)
// must be completely filled before the frontier widens. No gaps
// are left at stage boundaries.
// Example: stage 1 fills [0,4], stage 2 fills [4,8] only after [0,4] complete.

(expansion: StagedExpansion { theorem: 'THM-STAGED-EXPANSION', stages: '2' })
(stage_1: Stage { id: '1', range: '[0,4]', filled: 'true' })
(stage_2: Stage { id: '2', range: '[4,8]', filled: 'true' })
(shoulder_1: Shoulder { stage: '1', boundary: '4', complete: 'true' })
(ordering: Invariant { claim: 'shoulder_filled_before_widen', stage_1_complete: 'true', stage_2_started: 'true' })
(result: Result { theorem: 'shoulders-fill-first' })

(expansion)-[:FORK]->(stage_1 | stage_2)
(stage_1)-[:PROCESS]->(shoulder_1)
(shoulder_1)-[:PROCESS { expect: 'complete-before-widen' }]->(ordering)
(stage_2)-[:PROCESS]->(ordering)
(ordering)-[:PROCESS { strategy: 'verify-ordering' }]->(result)
