// wallace_monitor_drift.gg
// Same monitor shape as wallace_monitor.gg, but with deliberate drift.
// Here occupancyDeficit = 3 while turbulentIdle = 2, so the invariant breaks.

(seed:Scalar { value: "0" })
(seq_cap:Parameter { value: "8" })
(busy_load:Gradient { value: "5" })
(occupancy_deficit_probe:Parameter)
(idle_probe:Scalar { value: "2" })
(seq_cap_probe:Scalar { value: "8" })
(busy_probe:Scalar { value: "5" })
(invariant_probe:Result { kind: "ok", value: "InvOccupancyDeficitEqualsTurbulentIdle" })
(occupancy_deficit:GradientStep { learningRate: "1", parameterKey: "seq_cap", gradientKey: "busy_load" })
(assembled:Destructure { fields: "occupancy_deficit_probe.value:occupancyDeficit,idle_probe.value:turbulentIdle,seq_cap_probe.value:seqCap,busy_probe.value:busy,invariant_probe.value:invariant" })
(residual:MeanSquaredError { predictionKey: "occupancyDeficit", targetKey: "turbulentIdle" })
(metrics:Destructure { fields: "invariant,seqCap,busy,occupancyDeficit,turbulentIdle" })
(verdict_input:Destructure { fields: "residual.value:residual,metrics.invariant:invariant,metrics.seqCap:seqCap,metrics.busy:busy,metrics.occupancyDeficit:occupancyDeficit,metrics.turbulentIdle:turbulentIdle" })
(boundary:Option { kindFrom: "residual", valueFrom: "residual" })
(context:Destructure { fields: "invariant,seqCap,busy,occupancyDeficit,turbulentIdle,residual" })
(status:Destructure { fields: "boundary.kind:boundaryKind,context:metrics" })
(classify:Variant { adt: "WallaceMonitorBoundary", cases: "none,some", caseFrom: "boundaryKind", valueFrom: "metrics" })
(holds:Result { kind: "ok", valueFrom: "value" })
(violates:Result { kind: "err", errorFrom: "value" })
(sink:Sink)

(seed)-[:FORK]->(seq_cap | busy_load | idle_probe | seq_cap_probe | busy_probe | invariant_probe)
(seq_cap | busy_load)-[:FOLD]->(occupancy_deficit)
(occupancy_deficit)-[:FORK]->(occupancy_deficit_probe | idle_probe | seq_cap_probe | busy_probe | invariant_probe)
(occupancy_deficit_probe | idle_probe | seq_cap_probe | busy_probe | invariant_probe)-[:FOLD]->(assembled)
(assembled)-[:FORK]->(residual | metrics)
(residual | metrics)-[:FOLD]->(verdict_input)
(verdict_input)-[:FORK]->(boundary | context)
(boundary | context)-[:FOLD]->(status)
(status)-[:PROCESS]->(classify)
(classify)-[:PROCESS { case: "none" }]->(holds)
(classify)-[:PROCESS { case: "some" }]->(violates)
(holds)-[:PROCESS]->(sink)
(violates)-[:PROCESS]->(sink)
(sink)-[:TUNNEL { condition: 'bounded-reject' }]->(wallace_monitor_drift_gg_trace:Trace)
(sink)-[:MEASURE { reason: 'topology-audit' }]->(wallace_monitor_drift_gg_trace:Trace)
