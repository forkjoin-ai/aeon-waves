// multiplexing_idle_fraction.gg — THM-MULTIPLEXING witness (idle bounded by Re)
//
// The idle fraction of a multiplexed system is bounded above by 1/Re
// where Re is the Reynolds number of the traffic flow. Higher Re
// (more turbulent) means less idle capacity is wasted.
// Example: Re = 10, idle fraction = 0.08 <= 1/10 = 0.1.

(mux: Multiplexer { theorem: 'THM-MULTIPLEXING', reynolds: '10' })
(traffic: TrafficFlow { reynolds: '10', regime: 'moderate' })
(idle: IdleFraction { measured: '0.08', bound: '0.1' })
(invariant: Invariant { claim: 'idle_le_one_over_Re', idle: '0.08', bound: '0.1' })
(result: Result { theorem: 'idle-bounded-by-reynolds' })

(mux)-[:PROCESS]->(traffic)
(traffic)-[:PROCESS { expect: 'idle-measured' }]->(idle)
(idle)-[:PROCESS]->(invariant)
(invariant)-[:PROCESS { strategy: 'verify-inequality' }]->(result)
