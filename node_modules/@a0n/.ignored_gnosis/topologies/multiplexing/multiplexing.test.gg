// multiplexing.test.gg — Native Gnosis witnesses for THM-MULTIPLEXING
//
// These theorem-shaped `.gg` modules cover:
//   - shared resources can only help (capacity)
//   - idle bounded by Reynolds number (idle_fraction)
//   - turbulent regime produces positive idle (turbulent)

(test_suite: TestSuite { name: 'multiplexing' })

(capacity: Verify { module: './multiplexing_capacity.gg', beta1_max: '6' })
(idle_fraction: Verify { module: './multiplexing_idle_fraction.gg', beta1_max: '6' })
(turbulent: Verify { module: './multiplexing_turbulent.gg', beta1_max: '6' })

(test_suite)-[:FORK]->(capacity | idle_fraction | turbulent)

(capacity)-[:RACE { expect: 'safe' }]->(capacity_result: Result)
(idle_fraction)-[:RACE { expect: 'safe' }]->(idle_result: Result)
(turbulent)-[:RACE { expect: 'safe' }]->(turbulent_result: Result)

(capacity_result | idle_result | turbulent_result)-[:FOLD { strategy: 'all-pass' }]->(verdict: Verdict)
(verdict)-[:TUNNEL { condition: 'bounded-reject' }]->(multiplexing_test_gg_trace:Trace)
(verdict)-[:MEASURE { reason: 'topology-audit' }]->(multiplexing_test_gg_trace:Trace)
