// sleep_debt_positive.gg — THM-SLEEP-DEBT witness (truncated recovery implies positive debt)
//
// When recovery is truncated (actual < required), the deficit between
// required and actual recovery accumulates as positive debt.
// Debt = required - actual. Truncation guarantees debt > 0.
// Example: required=8, actual=5 -> debt = 3 > 0.

(system: RecoverySystem { theorem: 'THM-SLEEP-DEBT', required_recovery: '8' })
(required: RecoveryTarget { hours: '8' })
(actual: RecoveryActual { hours: '5', truncated: 'true' })
(debt: DebtMeasure { value: '3', formula: '8 - 5' })
(positivity: Invariant { claim: 'truncated recovery implies positive debt', required: '8', actual: '5', debt: '3' })
(result: Result { theorem: 'truncated-recovery-positive-debt' })

(system)-[:FORK]->(required | actual)
(required | actual)-[:FOLD { strategy: 'compute-deficit' }]->(debt)
(debt)-[:PROCESS { expect: 'debt-positive' }]->(positivity)
(positivity)-[:PROCESS { strategy: 'verify-positive' }]->(result)
(result)-[:TUNNEL { condition: 'bounded-reject' }]->(sleep_debt_positive_gg_trace:Trace)
(result)-[:MEASURE { reason: 'topology-audit' }]->(sleep_debt_positive_gg_trace:Trace)
