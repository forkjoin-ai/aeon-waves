// sleep_debt.test.gg — Native Gnosis witnesses for THM-SLEEP-DEBT
//
// These theorem-shaped `.gg` modules cover:
//   - truncated recovery implies positive debt
//   - repeated truncation strictly increases debt (cumulative)
//   - full recovery implies zero debt (clears)

(test_suite: TestSuite { name: 'sleep-debt' })

(positive: Verify { module: './sleep_debt_positive.gg', beta1_max: '6' })
(cumulative: Verify { module: './sleep_debt_cumulative.gg', beta1_max: '6' })
(clears: Verify { module: './sleep_debt_clears.gg', beta1_max: '6' })

(test_suite)-[:FORK]->(positive | cumulative | clears)

(positive)-[:RACE { expect: 'safe' }]->(positive_result: Result)
(cumulative)-[:RACE { expect: 'safe' }]->(cumulative_result: Result)
(clears)-[:RACE { expect: 'safe' }]->(clears_result: Result)

(positive_result | cumulative_result | clears_result)-[:FOLD { strategy: 'all-pass' }]->(verdict: Verdict)
(verdict)-[:TUNNEL { condition: 'bounded-reject' }]->(sleep_debt_test_gg_trace:Trace)
(verdict)-[:MEASURE { reason: 'topology-audit' }]->(sleep_debt_test_gg_trace:Trace)
