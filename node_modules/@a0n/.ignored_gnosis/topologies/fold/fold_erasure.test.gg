// fold_erasure.test.gg — Native Gnosis witnesses for THM-FOLD-ERASURE
//
// These theorem-shaped `.gg` modules cover:
//   - non-injective fold implies positive information loss
//   - injective fold implies zero information loss
//   - information loss implies positive Landauer heat

(test_suite: TestSuite { name: 'fold-erasure' })

(noninjective: Verify { module: './fold_erasure_noninjective.gg', beta1_max: '5' })
(injective_zero: Verify { module: './fold_erasure_injective_zero.gg', beta1_max: '5' })
(landauer: Verify { module: './fold_erasure_landauer.gg', beta1_max: '5' })

(test_suite)-[:FORK]->(noninjective | injective_zero | landauer)

(noninjective)-[:RACE { expect: 'safe' }]->(noninjective_result: Result)
(injective_zero)-[:RACE { expect: 'safe' }]->(injective_result: Result)
(landauer)-[:RACE { expect: 'safe' }]->(landauer_result: Result)

(noninjective_result | injective_result | landauer_result)-[:FOLD { strategy: 'all-pass' }]->(verdict: Verdict)
(verdict)-[:TUNNEL { condition: 'bounded-reject' }]->(fold_erasure_test_gg_trace:Trace)
(verdict)-[:MEASURE { reason: 'topology-audit' }]->(fold_erasure_test_gg_trace:Trace)
