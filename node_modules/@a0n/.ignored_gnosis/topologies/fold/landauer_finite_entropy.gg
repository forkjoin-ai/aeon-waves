// landauer_finite_entropy.gg — THM-LANDAUER-BULEY witness (finite entropy >= 0)
//
// Any finite system with N distinguishable states has entropy S = log2(N) >= 0.
// Entropy is always non-negative. The minimum is 0 (single state, no uncertainty).
// Example: N=8 states -> S = log2(8) = 3 bits >= 0.

(system: ThermodynamicSystem { theorem: 'THM-LANDAUER-BULEY', states: '8' })
(state_space: StateSpace { cardinality: '8', entropy_bits: '3' })
(single_state: StateSpace { cardinality: '1', entropy_bits: '0' })
(dual_state: StateSpace { cardinality: '2', entropy_bits: '1' })
(nonnegativity: Invariant { claim: 'entropy >= 0 for all finite systems', examples: '[0, 1, 3]', all_nonneg: 'true' })
(result: Result { theorem: 'finite-entropy-nonnegative' })

(system)-[:FORK]->(state_space | single_state | dual_state)
(state_space | single_state | dual_state)-[:RACE { expect: 'all-nonnegative' }]->(nonnegativity)
(nonnegativity)-[:PROCESS { strategy: 'verify-nonnegative' }]->(result)
(result)-[:MEASURE { reason: 'topology-audit' }]->(landauer_finite_entropy_gg_trace:Trace)
