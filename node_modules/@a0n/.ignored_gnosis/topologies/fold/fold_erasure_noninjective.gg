// fold_erasure_noninjective.gg — THM-FOLD-ERASURE witness (non-injective implies positive info loss)
//
// A non-injective fold maps multiple inputs to the same output.
// The information about which input produced the output is erased.
// Example: 4 inputs -> 2 outputs, 2 collisions, info_loss = log2(2) = 1 bit per collision.

(fold_op: FoldOperator { theorem: 'THM-FOLD-ERASURE', type: 'non-injective', inputs: '4', outputs: '2' })
(input_a: FoldInput { id: 'A', value: '10', maps_to: '1' })
(input_b: FoldInput { id: 'B', value: '20', maps_to: '1' })
(input_c: FoldInput { id: 'C', value: '30', maps_to: '2' })
(input_d: FoldInput { id: 'D', value: '40', maps_to: '2' })
(output_1: FoldOutput { id: '1', sources: '[A, B]', count: '2' })
(output_2: FoldOutput { id: '2', sources: '[C, D]', count: '2' })
(info_loss: Invariant { claim: 'non-injective implies info_loss > 0', loss_bits: '2', collisions: '2' })
(result: Result { theorem: 'noninjective-positive-info-loss' })

(fold_op)-[:FORK]->(input_a | input_b | input_c | input_d)
(input_a | input_b)-[:FOLD { strategy: 'merge' }]->(output_1)
(input_c | input_d)-[:FOLD { strategy: 'merge' }]->(output_2)
(output_1 | output_2)-[:RACE { expect: 'collisions-detected' }]->(info_loss)
(info_loss)-[:PROCESS { strategy: 'verify-positive' }]->(result)
(result)-[:TUNNEL { condition: 'bounded-reject' }]->(fold_erasure_noninjective_gg_trace:Trace)
(result)-[:MEASURE { reason: 'topology-audit' }]->(fold_erasure_noninjective_gg_trace:Trace)
