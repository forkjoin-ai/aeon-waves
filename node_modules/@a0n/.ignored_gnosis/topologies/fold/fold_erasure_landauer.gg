// fold_erasure_landauer.gg — THM-FOLD-ERASURE witness (info loss implies positive heat)
//
// By Landauer's principle, every bit of information erased produces
// at least kT*ln(2) heat. A fold with info_loss = L bits produces
// heat >= L * kT * ln(2). Non-zero erasure -> non-zero heat.
// Example: L = 3 bits erased at T = 300K -> heat >= 3 * 2.87e-21 J.

(fold_op: FoldOperator { theorem: 'THM-FOLD-ERASURE', type: 'non-injective', inputs: '8', outputs: '1' })
(erasure: ErasureEvent { bits_erased: '3', temperature_K: '300' })
(kT_ln2: PhysicalConstant { value: '2.87e-21', unit: 'joules', formula: 'kT*ln(2)' })
(heat: HeatDissipation { minimum_joules: '8.61e-21', formula: '3 * 2.87e-21', bits: '3' })
(landauer_bound: Invariant { claim: 'info_loss > 0 implies heat > 0', erasure_bits: '3', heat_joules: '8.61e-21' })
(result: Result { theorem: 'erasure-implies-positive-heat' })

(fold_op)-[:PROCESS { strategy: 'many-to-one' }]->(erasure)
(erasure)-[:PROCESS]->(kT_ln2)
(kT_ln2)-[:PROCESS { expect: 'heat-computed' }]->(heat)
(heat)-[:PROCESS]->(landauer_bound)
(landauer_bound)-[:PROCESS { strategy: 'verify-positive' }]->(result)
