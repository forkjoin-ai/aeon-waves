// cancer_topology.test.gg — Native Gnosis witnesses for THM-CANCER-TOPOLOGY
//
// These theorem-shaped `.gg` modules cover:
//   - no checkpoints = beta1=0 (beta1 collapse)
//   - checkpoints shift distribution (checkpoint venting)
//   - one vent restores learning (therapeutic restoration)
//   - driver destroys vents, passenger silent (driver/passenger)

(test_suite: TestSuite { name: 'cancer-topology' })

(beta1_collapse: Verify { module: './cancer_beta1_collapse.gg', beta1_max: '8' })
(checkpoint_venting: Verify { module: './cancer_checkpoint_venting.gg', beta1_max: '8' })
(therapeutic_restoration: Verify { module: './cancer_therapeutic_restoration.gg', beta1_max: '8' })
(driver_passenger: Verify { module: './cancer_driver_passenger.gg', beta1_max: '8' })

(test_suite)-[:FORK]->(beta1_collapse | checkpoint_venting | therapeutic_restoration | driver_passenger)

(beta1_collapse)-[:RACE { expect: 'safe' }]->(collapse_result: Result)
(checkpoint_venting)-[:RACE { expect: 'safe' }]->(vent_result: Result)
(therapeutic_restoration)-[:RACE { expect: 'safe' }]->(restore_result: Result)
(driver_passenger)-[:RACE { expect: 'safe' }]->(driver_result: Result)

(collapse_result | vent_result | restore_result | driver_result)-[:FOLD { strategy: 'all-pass' }]->(verdict: Verdict)
(verdict)-[:TUNNEL { condition: 'bounded-reject' }]->(cancer_topology_test_gg_trace:Trace)
(verdict)-[:MEASURE { reason: 'topology-audit' }]->(cancer_topology_test_gg_trace:Trace)
