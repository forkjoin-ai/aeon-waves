// cancer_driver_passenger.gg — THM-CANCER-TOPOLOGY witness (driver destroys vents, passenger silent)
//
// A driver mutation disables a checkpoint (removes a vent from the topology).
// beta1 decreases by 1. A passenger mutation changes weight but preserves
// all vents. beta1 is unchanged. The topological test distinguishes them.

(cell: CellCycle { theorem: 'THM-CANCER-TOPOLOGY', checkpoints: '3', initial_beta1: '3' })
(driver_mutation: Mutation { type: 'driver', target: 'p53', effect: 'disables-G1/S-checkpoint' })
(passenger_mutation: Mutation { type: 'passenger', target: 'pigmentation', effect: 'changes-weight-only' })
(after_driver: TopologyState { beta1: '2', checkpoints_remaining: '2', vent_destroyed: 'G1/S' })
(after_passenger: TopologyState { beta1: '3', checkpoints_remaining: '3', vent_destroyed: 'none' })
(distinction: Invariant { claim: 'driver decreases beta1, passenger does not', driver_delta: '-1', passenger_delta: '0' })
(result: Result { theorem: 'driver-destroys-vents-passenger-silent' })

(cell)-[:FORK]->(driver_mutation | passenger_mutation)
(driver_mutation)-[:PROCESS { expect: 'beta1-decreased' }]->(after_driver)
(passenger_mutation)-[:PROCESS { expect: 'beta1-unchanged' }]->(after_passenger)
(after_driver | after_passenger)-[:FOLD { strategy: 'verify-distinction' }]->(distinction)
(distinction)-[:PROCESS]->(result)
(result)-[:TUNNEL { condition: 'bounded-reject' }]->(cancer_driver_passenger_gg_trace:Trace)
(result)-[:MEASURE { reason: 'topology-audit' }]->(cancer_driver_passenger_gg_trace:Trace)
