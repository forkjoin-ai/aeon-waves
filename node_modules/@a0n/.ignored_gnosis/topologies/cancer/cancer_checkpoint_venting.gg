// cancer_checkpoint_venting.gg — THM-CANCER-TOPOLOGY witness (checkpoints shift distribution)
//
// A healthy cell has checkpoints that VENT damaged paths. Each checkpoint
// adds a hole to the topology (increases beta1). The distribution shifts:
// damaged branches get higher void counts, healthy branches concentrate mass.

(cell: CellCycle { theorem: 'THM-CANCER-TOPOLOGY', checkpoints: '3', rounds: '10' })
(healthy_path: Branch { type: 'healthy', void_count: '1', weight: '10' })
(minor_damage: Branch { type: 'minor-damage', void_count: '4', weight: '7' })
(major_damage: Branch { type: 'major-damage', void_count: '8', weight: '3' })
(lethal_damage: Branch { type: 'lethal', void_count: '10', weight: '1' })
(g1_checkpoint: Checkpoint { name: 'G1/S', vents: 'lethal_damage' })
(g2_checkpoint: Checkpoint { name: 'G2/M', vents: 'major_damage' })
(spindle_checkpoint: Checkpoint { name: 'spindle', vents: 'minor_damage' })
(beta1: Invariant { claim: 'beta1 = number of active checkpoints', beta1: '3' })
(result: Result { theorem: 'checkpoints-shift-distribution' })

(cell)-[:FORK]->(healthy_path | minor_damage | major_damage | lethal_damage)
(lethal_damage)-[:VENT { condition: 'G1/S-checkpoint' }]->(vent_1: VentedPath)
(major_damage)-[:VENT { condition: 'G2/M-checkpoint' }]->(vent_2: VentedPath)
(minor_damage)-[:VENT { condition: 'spindle-checkpoint' }]->(vent_3: VentedPath)
(healthy_path)-[:PROCESS { expect: 'survivor' }]->(beta1)
(vent_1 | vent_2 | vent_3)-[:PROCESS]->(beta1)
(beta1)-[:PROCESS { strategy: 'verify-positive-beta1' }]->(result)
(result)-[:MEASURE { reason: 'topology-audit' }]->(cancer_checkpoint_venting_gg_trace:Trace)
