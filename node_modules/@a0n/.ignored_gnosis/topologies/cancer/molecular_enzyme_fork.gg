// molecular_enzyme_fork.gg — THM-MOLECULAR-TOPOLOGY witness (enzyme = reusable fork)
//
// An enzyme catalyzes a reaction without being consumed. In pipeline
// topology, this corresponds to a reusable fork node: the enzyme node
// participates in multiple fork events but retains its state across all.
// Example: enzyme node forks 3 substrates, emerges unchanged after each.

(space: TopologySpace { theorem: 'THM-MOLECULAR-TOPOLOGY', pattern: 'enzyme-catalysis' })
(enzyme: EnzymeNode { id: 'E', state: 'active', reusable: 'true' })
(substrate_1: Substrate { id: 'S1', input: 'A', output: 'P1' })
(substrate_2: Substrate { id: 'S2', input: 'B', output: 'P2' })
(substrate_3: Substrate { id: 'S3', input: 'C', output: 'P3' })
(fork_event: ForkEvent { catalyst: 'E', substrates: '3', enzyme_consumed: 'false' })
(reuse: Invariant { claim: 'enzyme state unchanged after fork', state_before: 'active', state_after: 'active', forks: '3' })
(result: Result { theorem: 'enzyme-is-reusable-fork' })

(enzyme)-[:FORK]->(substrate_1 | substrate_2 | substrate_3)
(substrate_1 | substrate_2 | substrate_3)-[:FOLD { strategy: 'catalytic-fold' }]->(fork_event)
(fork_event)-[:PROCESS { expect: 'enzyme-preserved' }]->(reuse)
(reuse)-[:PROCESS { strategy: 'verify-state-invariant' }]->(result)
(result)-[:TUNNEL { condition: 'bounded-reject' }]->(molecular_enzyme_fork_gg_trace:Trace)
(result)-[:MEASURE { reason: 'topology-audit' }]->(molecular_enzyme_fork_gg_trace:Trace)
