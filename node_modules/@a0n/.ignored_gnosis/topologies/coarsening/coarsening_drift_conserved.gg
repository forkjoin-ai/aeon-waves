// coarsening_drift_conserved.gg — THM-SLIVERNCE-COARSENING witness (total drift preserved)
//
// The total drift across all branches is conserved under the quotient map.
// Merging interference classes redistributes drift but does not create
// or destroy it.
// Example: fine drift [2, 3, 1, 4] = 10, coarse drift [5, 5] = 10.

(fine: InterferenceModel { theorem: 'THM-SLIVERNCE-COARSENING', drift: '[2, 3, 1, 4]', total: '10' })
(coarse: QuotientModel { drift: '[5, 5]', total: '10' })
(invariant: Invariant { claim: 'total_drift_conserved', fine_total: '10', coarse_total: '10' })
(result: Result { theorem: 'drift-conserved-under-quotient' })

(fine)-[:PROCESS]->(coarse)
(fine | coarse)-[:RACE { expect: 'drift-equal' }]->(invariant)
(invariant)-[:PROCESS { strategy: 'verify-equality' }]->(result)
(result)-[:MEASURE { reason: 'topology-audit' }]->(coarsening_drift_conserved_gg_trace:Trace)
