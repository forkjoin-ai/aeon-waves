// coarsening_stability_transfer.gg — THM-RECURSIVE-COARSENING-SYNTHESIS witness (fine stability -> coarse stability)
//
// If every branch in the fine model is stable, then every equivalence
// class in the coarse model is also stable. Stability transfers upward
// through the quotient hierarchy.
// Example: 4 fine branches all stable -> 2 coarse classes both stable.

(synthesis: RecursiveCoarsening { theorem: 'THM-RECURSIVE-COARSENING-SYNTHESIS', branches: '4', classes: '2' })
(fine_a: Branch { id: 'a', stable: 'true' })
(fine_b: Branch { id: 'b', stable: 'true' })
(fine_c: Branch { id: 'c', stable: 'true' })
(fine_d: Branch { id: 'd', stable: 'true' })
(coarse_1: QuotientClass { id: '1', stable: 'true', members: '[a, b]' })
(coarse_2: QuotientClass { id: '2', stable: 'true', members: '[c, d]' })
(invariant: Invariant { claim: 'fine_stable_implies_coarse_stable', fine_stable: '4', coarse_stable: '2' })
(result: Result { theorem: 'stability-transfers-upward' })

(synthesis)-[:FORK]->(fine_a | fine_b | fine_c | fine_d)
(fine_a | fine_b)-[:RACE { expect: 'class-stable' }]->(coarse_1)
(fine_c | fine_d)-[:RACE { expect: 'class-stable' }]->(coarse_2)
(coarse_1 | coarse_2)-[:FOLD { strategy: 'all-stable' }]->(invariant)
(invariant)-[:PROCESS]->(result)
(result)-[:TUNNEL { condition: 'bounded-reject' }]->(coarsening_stability_transfer_gg_trace:Trace)
(result)-[:MEASURE { reason: 'topology-audit' }]->(coarsening_stability_transfer_gg_trace:Trace)
