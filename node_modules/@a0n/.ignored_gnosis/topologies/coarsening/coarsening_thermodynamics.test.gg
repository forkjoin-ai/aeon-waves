// coarsening_thermodynamics.test.gg — Native Gnosis witnesses for THM-COARSENING-THERMODYNAMICS
//
// These theorem-shaped `.gg` modules cover:
//   - composed coarsening loss >= single coarsening loss (monotone)
//   - loss decomposes additively across stages (chain rule)
//   - identity map produces zero loss (identity zero)

(test_suite: TestSuite { name: 'coarsening-thermodynamics' })

(monotone: Verify { module: './coarsening_monotone.gg', beta1_max: '5' })
(chain_rule: Verify { module: './coarsening_chain_rule.gg', beta1_max: '5' })
(identity_zero: Verify { module: './coarsening_identity_zero.gg', beta1_max: '5' })

(test_suite)-[:PROCESS]->(suite_plan: Plan)
