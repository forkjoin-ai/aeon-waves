// interference_coarsening.test.gg — Native Gnosis witnesses for THM-SLIVERNCE-COARSENING
//
// These theorem-shaped `.gg` modules cover:
//   - quotient preserves live support (preserves_support)
//   - total drift preserved under coarsening (drift_conserved)
//   - non-injective quotient incurs repair debt (repair_debt)

(test_suite: TestSuite { name: 'interference-coarsening' })

(preserves_support: Verify { module: './coarsening_preserves_support.gg', beta1_max: '6' })
(drift_conserved: Verify { module: './coarsening_drift_conserved.gg', beta1_max: '6' })
(repair_debt: Verify { module: './coarsening_repair_debt.gg', beta1_max: '6' })

(test_suite)-[:FORK]->(preserves_support | drift_conserved | repair_debt)

(preserves_support)-[:RACE { expect: 'safe' }]->(support_result: Result)
(drift_conserved)-[:RACE { expect: 'safe' }]->(drift_result: Result)
(repair_debt)-[:RACE { expect: 'safe' }]->(debt_result: Result)

(support_result | drift_result | debt_result)-[:FOLD { strategy: 'all-pass' }]->(verdict: Verdict)
(verdict)-[:TUNNEL { condition: 'bounded-reject' }]->(interference_coarsening_test_gg_trace:Trace)
(verdict)-[:MEASURE { reason: 'topology-audit' }]->(interference_coarsening_test_gg_trace:Trace)
