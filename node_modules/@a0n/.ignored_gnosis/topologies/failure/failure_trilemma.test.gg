// failure_trilemma.test.gg — Native Gnosis witnesses for THM-FAIL-TRILEMMA
//
// These theorem-shaped `.gg` modules cover:
//   - free deterministic collapse is blocked
//   - collapse paid by vent
//   - collapse paid by repair debt
//   - contagious zero-vent recovery still forces debt

(test_suite: TestSuite { name: 'failure-trilemma' })

(keep_multiplicity: Verify { module: './failure_trilemma_keep_multiplicity.gg', beta1_max: '6' })
(paid_vent: Verify { module: './failure_trilemma_paid_vent.gg', beta1_max: '6' })
(paid_repair: Verify { module: './failure_trilemma_paid_repair.gg', beta1_max: '6' })
(contagious_zero_vent: Verify { module: './failure_trilemma_contagious_zero_vent.gg', beta1_max: '6' })

(test_suite)-[:FORK]->(keep_multiplicity | paid_vent | paid_repair | contagious_zero_vent)

(keep_multiplicity)-[:RACE { expect: 'safe' }]->(keep_multiplicity_result: Result)
(paid_vent)-[:RACE { expect: 'safe' }]->(paid_vent_result: Result)
(paid_repair)-[:RACE { expect: 'safe' }]->(paid_repair_result: Result)
(contagious_zero_vent)-[:RACE { expect: 'safe' }]->(contagious_zero_vent_result: Result)

(keep_multiplicity_result | paid_vent_result | paid_repair_result | contagious_zero_vent_result)-[:FOLD { strategy: 'all-pass' }]->(verdict: Verdict)
(verdict)-[:TUNNEL { condition: 'bounded-reject' }]->(failure_trilemma_test_gg_trace:Trace)
(verdict)-[:MEASURE { reason: 'topology-audit' }]->(failure_trilemma_test_gg_trace:Trace)
