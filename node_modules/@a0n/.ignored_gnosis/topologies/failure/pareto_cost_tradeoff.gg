// pareto_cost_tradeoff.gg — THM-FAILURE-PARETO witness (cost vs multiplicity tradeoff)
//
// Moving along the Pareto frontier trades cost for multiplicity.
// Reducing multiplicity (venting) increases cost, and reducing cost
// (keeping) increases multiplicity. The tradeoff is strict.
// Example: keep(cost=0, mult=3) -> vent(cost=1, mult=1): cost up, mult down.

(frontier: ParetoFrontier { theorem: 'THM-FAILURE-PARETO' })
(keep: Action { id: 'keep', cost: '0', multiplicity: '3' })
(vent: Action { id: 'vent', cost: '1', multiplicity: '1' })
(tradeoff: Tradeoff { cost_delta: '+1', mult_delta: '-2', strict: 'true' })
(invariant: Invariant { claim: 'cost_mult_tradeoff_strict', cost_increase: '1', mult_decrease: '2' })
(result: Result { theorem: 'cost-multiplicity-tradeoff' })

(frontier)-[:FORK]->(keep | vent)
(keep | vent)-[:RACE { expect: 'tradeoff-observed' }]->(tradeoff)
(tradeoff)-[:PROCESS]->(invariant)
(invariant)-[:PROCESS { strategy: 'verify-positive' }]->(result)
(result)-[:MEASURE { reason: 'topology-audit' }]->(pareto_cost_tradeoff_gg_trace:Trace)
