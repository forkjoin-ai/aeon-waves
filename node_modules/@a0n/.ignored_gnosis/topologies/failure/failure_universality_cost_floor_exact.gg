// failure_universality_cost_floor_exact.gg — The exact vent floor is attainable
//
// THM-FAIL-MINCOST / THM-FAIL-TIGHTNESS:
// collapsing from three live branches to one survivor costs exactly two units
// when every non-survivor is vented and repair debt stays at zero.

(origin: ForkedFrontier { theorem: 'THM-FAIL-TIGHTNESS', live_branches: '3', exact_floor: '2' })
(left: Branch { output: 'left' })
(middle: Branch { output: 'middle' })
(right: Branch { output: 'right' })
(vent_middle: VentedLoss { cost: '1' })
(vent_right: VentedLoss { cost: '1' })
(finish: Survivor { survivors: '1', total_cost: '2' })
(result: Result { theorem: 'exact-cost-floor-attained' })

(origin)-[:FORK]->(left | middle | right)
(middle)-[:VENT { floor_unit: '1', condition: 'exact-floor-middle' }]->(vent_middle)
(right)-[:VENT { floor_unit: '1', condition: 'exact-floor-right' }]->(vent_right)
(left | vent_middle | vent_right)-[:FOLD { strategy: 'single-survivor-after-vent', request_compression: 'middle-out/request/failure-universality-cost-floor-exact', reuse_scope: 'corridor', corridor_mode: 'readonly' }]->(finish)
(finish)-[:PROCESS]->(result)
(result)-[:MEASURE { reason: 'topology-audit' }]->(failure_universality_cost_floor_exact_gg_trace:Trace)
