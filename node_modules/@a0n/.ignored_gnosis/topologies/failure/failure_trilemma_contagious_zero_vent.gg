// failure_trilemma_contagious_zero_vent.gg — Zero-vent contagion still forces debt
//
// THM-FAIL-TRILEMMA:
// contagious failure can preserve branch mass when nothing is vented, but the
// system must still pay repair debt.

(origin: ForkedFrontier { theorem: 'THM-FAIL-TRILEMMA', live_branches: '2' })
(left: Branch { survives: 'true' })
(right: Branch { survives: 'true' })
(global_recovery: ContagiousFailure { zero_vent: 'true' })
(repair_debt: RepairDebt { units: '2' })
(branch_mass: BranchMass { preserved: 'true' })
(result: Result { theorem: 'zero-vent-contagion-forces-debt' })

(origin)-[:FORK]->(left | right)
(left | right)-[:SLIVER { mode: 'contagious' }]->(global_recovery)
(global_recovery)-[:PROCESS]->(repair_debt)
(global_recovery)-[:PROCESS]->(branch_mass)
(repair_debt | branch_mass)-[:FOLD { strategy: 'preserve-branch-mass' }]->(result)
(result)-[:TUNNEL { condition: 'bounded-reject' }]->(failure_trilemma_contagious_zero_vent_gg_trace:Trace)
(result)-[:MEASURE { reason: 'topology-audit' }]->(failure_trilemma_contagious_zero_vent_gg_trace:Trace)
