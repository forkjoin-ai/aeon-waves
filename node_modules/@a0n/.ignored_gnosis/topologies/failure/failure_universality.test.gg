// failure_universality.test.gg — Native Gnosis witnesses for THM-FAIL-UNIVERSAL / MINCOST / TIGHTNESS
//
// These theorem-shaped `.gg` modules cover:
//   - the exact minimum vent floor
//   - a deeper finite prefix that still pays the floor
//   - a free prefix blocked at arbitrary depth
//   - contagious repair pressure that survives normalization

(test_suite: TestSuite { name: 'failure-universality' })

(cost_floor_exact: Verify { module: './failure_universality_cost_floor_exact.gg', beta1_max: '8' })
(paid_depth_two: Verify { module: './failure_universality_paid_depth_two.gg', beta1_max: '8' })
(free_prefix_blocked: Verify { module: './failure_universality_free_prefix_blocked.gg', beta1_max: '8' })
(contagious_depth: Verify { module: './failure_universality_contagious_depth.gg', beta1_max: '8' })

(test_suite)-[:FORK]->(cost_floor_exact | paid_depth_two | free_prefix_blocked | contagious_depth)

(cost_floor_exact)-[:RACE { expect: 'safe' }]->(cost_floor_result: Result)
(paid_depth_two)-[:RACE { expect: 'safe' }]->(paid_depth_result: Result)
(free_prefix_blocked)-[:RACE { expect: 'safe' }]->(free_prefix_result: Result)
(contagious_depth)-[:RACE { expect: 'safe' }]->(contagious_depth_result: Result)

(cost_floor_result | paid_depth_result | free_prefix_result | contagious_depth_result)-[:FOLD { strategy: 'all-pass' }]->(verdict: Verdict)
(verdict)-[:TUNNEL { condition: 'bounded-reject' }]->(failure_universality_test_gg_trace:Trace)
(verdict)-[:MEASURE { reason: 'topology-audit' }]->(failure_universality_test_gg_trace:Trace)
