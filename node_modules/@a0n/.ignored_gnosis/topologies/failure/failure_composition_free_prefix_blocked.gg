// failure_composition_free_prefix_blocked.gg — An unpaid prefix cannot finish collapse for free
//
// THM-FAIL-COMPOSITION:
// zero vent and zero repair can persist for a prefix, but the composed
// pipeline still hits the no-free-collapse boundary when it tries to fold.

(origin: ForkedFrontier { theorem: 'THM-FAIL-COMPOSITION', stages: '2', live_branches: '2' })
(left_0: Branch { stage: '0', output: 'left' })
(right_0: Branch { stage: '0', output: 'right' })
(left_1: Branch { stage: '1', output: 'left' })
(right_1: Branch { stage: '1', output: 'right' })
(boundary: Impossibility { reason: 'unpaid collapse prefix' })
(finish: Survivor { survivors: '1', cost: 'unpaid' })
(result: Result { theorem: 'pipeline-free-prefix-blocked' })

(origin)-[:FORK]->(left_0 | right_0)
(left_0)-[:PROCESS]->(left_1)
(right_0)-[:PROCESS]->(right_1)
(left_1 | right_1)-[:FOLD { strategy: 'single-survivor', request_compression: 'middle-out/request/failure-composition-free-prefix-blocked', reuse_scope: 'corridor', corridor_mode: 'readonly' }]->(finish)
(finish)-[:PROCESS]->(boundary)
(boundary)-[:PROCESS]->(result)
(result)-[:TUNNEL { condition: 'bounded-reject' }]->(failure_composition_free_prefix_blocked_gg_trace:Trace)
(result)-[:MEASURE { reason: 'topology-audit' }]->(failure_composition_free_prefix_blocked_gg_trace:Trace)
