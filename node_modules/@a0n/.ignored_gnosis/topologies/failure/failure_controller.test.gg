// failure_controller.test.gg — Native Gnosis witnesses for THM-FAILURE-CONTROLLER
//
// These theorem-shaped `.gg` modules cover:
//   - keep when cheapest (keep dominates vent and repair)
//   - vent when cheapest (vent dominates keep and repair)
//   - repair when cheapest (repair dominates keep and vent)

(test_suite: TestSuite { name: 'failure-controller' })

(keep: Verify { module: './failure_controller_keep.gg', beta1_max: '6' })
(vent: Verify { module: './failure_controller_vent.gg', beta1_max: '6' })
(repair: Verify { module: './failure_controller_repair.gg', beta1_max: '6' })

(test_suite)-[:FORK]->(keep | vent | repair)

(keep)-[:RACE { expect: 'safe' }]->(keep_result: Result)
(vent)-[:RACE { expect: 'safe' }]->(vent_result: Result)
(repair)-[:RACE { expect: 'safe' }]->(repair_result: Result)

(keep_result | vent_result | repair_result)-[:FOLD { strategy: 'all-pass' }]->(verdict: Verdict)
(verdict)-[:TUNNEL { condition: 'bounded-reject' }]->(failure_controller_test_gg_trace:Trace)
(verdict)-[:MEASURE { reason: 'topology-audit' }]->(failure_controller_test_gg_trace:Trace)
