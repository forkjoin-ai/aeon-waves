// failure_trilemma_paid_repair.gg — Deterministic collapse paid by repair debt
//
// THM-FAIL-TRILEMMA:
// if no branch is vented, deterministic collapse still has to pay by carrying
// repair debt through the surviving branch image.

(origin: ForkedFrontier { theorem: 'THM-FAIL-TRILEMMA', live_branches: '2' })
(left: Branch { survives: 'true' })
(right: Branch { survives: 'true' })
(repair_debt: RepairDebt { units: '1' })
(aligned_survivor: SurvivorMask)
(collapse: DeterministicCollapse { paid_by: 'repair' })
(result: Result { theorem: 'collapse-paid-by-repair' })

(origin)-[:FORK]->(left | right)
(left)-[:SLIVER { mode: 'repair' }]->(repair_debt)
(repair_debt)-[:PROCESS]->(aligned_survivor)
(aligned_survivor | right)-[:FOLD { strategy: 'single-survivor-after-repair' }]->(collapse)
(collapse)-[:PROCESS]->(result)
(result)-[:TUNNEL { condition: 'bounded-reject' }]->(failure_trilemma_paid_repair_gg_trace:Trace)
(result)-[:MEASURE { reason: 'topology-audit' }]->(failure_trilemma_paid_repair_gg_trace:Trace)
