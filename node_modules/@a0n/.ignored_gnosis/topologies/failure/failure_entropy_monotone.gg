// failure_entropy_monotone.gg — THM-FAILURE-ENTROPY witness (more branches implies more entropy)
//
// Under uniform weighting, entropy is monotonically increasing in the
// number of live branches. S(N) = log2(N) < log2(N+1) = S(N+1).
// Example: S(2)=1, S(4)=2, S(8)=3 -- strictly increasing.

(space: EntropySpace { theorem: 'THM-FAILURE-ENTROPY', distribution: 'uniform' })
(frontier_2: FailureFrontier { branches: '2', entropy_bits: '1.0' })
(frontier_4: FailureFrontier { branches: '4', entropy_bits: '2.0' })
(frontier_8: FailureFrontier { branches: '8', entropy_bits: '3.0' })
(frontier_16: FailureFrontier { branches: '16', entropy_bits: '4.0' })
(monotone: Invariant { claim: 'S(N) < S(N+1) for uniform weights', sequence: '[1.0, 2.0, 3.0, 4.0]' })
(result: Result { theorem: 'entropy-monotone-in-branches' })

(space)-[:FORK]->(frontier_2 | frontier_4 | frontier_8 | frontier_16)
(frontier_2 | frontier_4 | frontier_8 | frontier_16)-[:RACE { expect: 'strictly-increasing' }]->(monotone)
(monotone)-[:PROCESS { strategy: 'verify-ordering' }]->(result)
(result)-[:MEASURE { reason: 'topology-audit' }]->(failure_entropy_monotone_gg_trace:Trace)
