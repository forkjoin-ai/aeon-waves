// failure_composition_paid_repair_stage.gg — A composed pipeline pays by repair debt
//
// THM-FAIL-COMPOSITION:
// deterministic collapse across stages may avoid venting, but then some stage
// must carry repair debt.

(origin: ForkedFrontier { theorem: 'THM-FAIL-COMPOSITION', stages: '2', live_branches: '2' })
(left_0: Branch { stage: '0', output: 'left' })
(right_0: Branch { stage: '0', output: 'right' })
(left_1: Branch { stage: '1', output: 'left' })
(right_1: Branch { stage: '1', output: 'right' })
(repair_stage: PaidStage { stage: '2', payment: 'repair' })
(repair_mesh: RepairDebt { cost: '1' })
(finish: Survivor { survivors: '1' })
(result: Result { theorem: 'pipeline-paid-by-repair' })

(origin)-[:FORK]->(left_0 | right_0)
(left_0)-[:PROCESS]->(left_1)
(right_0)-[:PROCESS]->(right_1)
(left_1)-[:SLIVER { stage: '2', debt: '1' }]->(repair_mesh)
(right_1)-[:PROCESS]->(repair_stage)
(repair_mesh | repair_stage)-[:FOLD { strategy: 'single-survivor' }]->(finish)
(finish)-[:PROCESS]->(result)
(result)-[:TUNNEL { condition: 'bounded-reject' }]->(failure_composition_paid_repair_stage_gg_trace:Trace)
(result)-[:MEASURE { reason: 'topology-audit' }]->(failure_composition_paid_repair_stage_gg_trace:Trace)
