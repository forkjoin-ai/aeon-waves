// failure_controller_keep.gg — THM-FAILURE-CONTROLLER witness (keep when cheapest)
//
// When the cost of keeping multiplicity is less than both vent cost and
// repair cost, the optimal controller action is keep. The controller
// selects the action with minimum cost.
// Example: keep_cost=2, vent_cost=5, repair_cost=7 -> action=keep.

(frontier: FailureFrontier { theorem: 'THM-FAILURE-CONTROLLER', live_branches: '3' })
(keep_option: ActionCost { action: 'keep', cost: '2' })
(vent_option: ActionCost { action: 'vent', cost: '5' })
(repair_option: ActionCost { action: 'repair', cost: '7' })
(controller: Controller { strategy: 'min-cost' })
(decision: Decision { action: 'keep', cost: '2', reason: 'cheapest' })
(result: Result { theorem: 'keep-when-cheapest' })

(frontier)-[:FORK]->(keep_option | vent_option | repair_option)
(keep_option | vent_option | repair_option)-[:RACE { expect: 'costs-computed' }]->(controller)
(controller)-[:PROCESS { strategy: 'select-minimum-cost' }]->(decision)
(decision)-[:PROCESS]->(result)
(result)-[:MEASURE { reason: 'topology-audit' }]->(failure_controller_keep_gg_trace:Trace)
