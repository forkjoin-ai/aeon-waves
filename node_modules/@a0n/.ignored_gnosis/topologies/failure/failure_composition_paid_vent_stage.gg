// failure_composition_paid_vent_stage.gg — A composed pipeline pays by venting at one stage
//
// THM-FAIL-COMPOSITION:
// once the pipeline starts from a nontrivial fork, deterministic collapse can
// only finish after some stage pays. Here the payment is one explicit vent.

(origin: ForkedFrontier { theorem: 'THM-FAIL-COMPOSITION', stages: '2', live_branches: '2' })
(left_0: Branch { stage: '0', output: 'left' })
(right_0: Branch { stage: '0', output: 'right' })
(left_1: Branch { stage: '1', output: 'left' })
(right_1: Branch { stage: '1', output: 'right' })
(vent_stage: PaidStage { stage: '2', payment: 'vent' })
(spill: VentedLoss { cost: '1' })
(finish: Survivor { survivors: '1' })
(result: Result { theorem: 'pipeline-paid-by-vent' })

(origin)-[:FORK]->(left_0 | right_0)
(left_0)-[:PROCESS]->(left_1)
(right_0)-[:PROCESS]->(right_1)
(right_1)-[:VENT { stage: '2', condition: 'vent-payment' }]->(spill)
(left_1)-[:PROCESS]->(vent_stage)
(vent_stage)-[:PROCESS { strategy: 'single-survivor', request_compression: 'middle-out/request/failure-composition-paid-vent-stage', reuse_scope: 'corridor', corridor_mode: 'readonly' }]->(finish)
(finish)-[:PROCESS]->(result)
(result)-[:MEASURE { reason: 'topology-audit' }]->(failure_composition_paid_vent_stage_gg_trace:Trace)
