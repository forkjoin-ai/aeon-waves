// pareto_no_domination.gg — THM-FAILURE-PARETO witness (no action dominates all others)
//
// For every pair of actions, neither strictly dominates the other
// across all objectives simultaneously. Each excels in at least
// one dimension where the other is worse.
// Example: keep has lower cost but higher multiplicity than vent.

(frontier: ParetoFrontier { theorem: 'THM-FAILURE-PARETO' })
(keep: Action { id: 'keep', cost: '0', multiplicity: '3' })
(vent: Action { id: 'vent', cost: '1', multiplicity: '1' })
(repair: Action { id: 'repair', cost: '2', multiplicity: '3' })
(pair_kv: DominanceCheck { a: 'keep', b: 'vent', a_dominates: 'false', b_dominates: 'false' })
(pair_kr: DominanceCheck { a: 'keep', b: 'repair', a_dominates: 'false', b_dominates: 'false' })
(pair_vr: DominanceCheck { a: 'vent', b: 'repair', a_dominates: 'false', b_dominates: 'false' })
(invariant: Invariant { claim: 'no_pairwise_domination', dominated_count: '0' })
(result: Result { theorem: 'no-domination' })

(frontier)-[:FORK]->(keep | vent | repair)
(keep | vent)-[:RACE { expect: 'no-domination' }]->(pair_kv)
(keep | repair)-[:RACE { expect: 'no-domination' }]->(pair_kr)
(vent | repair)-[:RACE { expect: 'no-domination' }]->(pair_vr)
(pair_kv | pair_kr | pair_vr)-[:FOLD { strategy: 'all-false' }]->(invariant)
(invariant)-[:PROCESS]->(result)
(result)-[:TUNNEL { condition: 'bounded-reject' }]->(pareto_no_domination_gg_trace:Trace)
(result)-[:MEASURE { reason: 'topology-audit' }]->(pareto_no_domination_gg_trace:Trace)
