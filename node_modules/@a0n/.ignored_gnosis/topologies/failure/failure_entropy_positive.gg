// failure_entropy_positive.gg — THM-FAILURE-ENTROPY witness (frontier > 1 implies positive entropy)
//
// A failure frontier with more than one live branch has positive
// Shannon entropy. The uncertainty over which branch survives is
// nonzero whenever multiplicity exists.
// Example: frontier=4 with uniform weights -> S = log2(4) = 2 bits > 0.

(frontier: FailureFrontier { theorem: 'THM-FAILURE-ENTROPY', live_branches: '4' })
(branch_1: Branch { id: '1', weight: '0.25' })
(branch_2: Branch { id: '2', weight: '0.25' })
(branch_3: Branch { id: '3', weight: '0.25' })
(branch_4: Branch { id: '4', weight: '0.25' })
(entropy: EntropyMeasure { value: '2.0', formula: '-4*(0.25*log2(0.25))', unit: 'bits' })
(positivity: Invariant { claim: 'frontier > 1 implies entropy > 0', branches: '4', entropy: '2.0' })
(result: Result { theorem: 'frontier-positive-entropy' })

(frontier)-[:FORK]->(branch_1 | branch_2 | branch_3 | branch_4)
(branch_1 | branch_2 | branch_3 | branch_4)-[:RACE { expect: 'entropy-computed' }]->(entropy)
(entropy)-[:PROCESS]->(positivity)
(positivity)-[:PROCESS { strategy: 'verify-positive' }]->(result)
(result)-[:MEASURE { reason: 'topology-audit' }]->(failure_entropy_positive_gg_trace:Trace)
