// failure_composition_contagious_paid_stage.gg — Contagious recovery still pays at one stage
//
// THM-FAIL-COMPOSITION:
// even with zero vent, the pipeline must surface a paid stage once repair
// propagates through the recovery chain.

(origin: ForkedFrontier { theorem: 'THM-FAIL-COMPOSITION', stages: '3', live_branches: '2' })
(left_0: Branch { stage: '0', output: 'left' })
(right_0: Branch { stage: '0', output: 'right' })
(left_1: Branch { stage: '1', output: 'left' })
(right_1: Branch { stage: '1', output: 'right' })
(repair_2: RepairDebt { stage: '2', debt: '1' })
(right_2: Branch { stage: '2', output: 'right' })
(finish: Survivor { survivors: '1' })
(result: Result { theorem: 'pipeline-contagious-paid-stage' })

(origin)-[:FORK]->(left_0 | right_0)
(left_0)-[:PROCESS]->(left_1)
(right_0)-[:PROCESS]->(right_1)
(left_1)-[:SLIVER { stage: '2', debt: '1' }]->(repair_2)
(right_1)-[:PROCESS]->(right_2)
(repair_2 | right_2)-[:FOLD { strategy: 'single-survivor' }]->(finish)
(finish)-[:PROCESS]->(result)
(result)-[:TUNNEL { condition: 'bounded-reject' }]->(failure_composition_contagious_paid_stage_gg_trace:Trace)
(result)-[:MEASURE { reason: 'topology-audit' }]->(failure_composition_contagious_paid_stage_gg_trace:Trace)
