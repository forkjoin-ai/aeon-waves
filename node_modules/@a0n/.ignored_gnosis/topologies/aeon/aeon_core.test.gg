// aeon_core.test.gg — Verification harness for aeon core
(test_suite: TestSuite { name: 'aeon_core' })
(esi_resolution: Verify { module: './esi_resolution.gg', beta1_max: '6' })
(tui_keyboard_dispatch: Verify { module: './tui_keyboard_dispatch.gg', beta1_max: '6' })
(tui_layout_engine: Verify { module: './tui_layout_engine.gg', beta1_max: '6' })
(pty_process_manager: Verify { module: './pty_process_manager.gg', beta1_max: '6' })
(pensieve_memory_compaction: Verify { module: './pensieve_memory_compaction.gg', beta1_max: '6' })
(background_daemon_telemetry: Verify { module: './background_daemon_telemetry.gg', beta1_max: '6' })
(agent_store_provisioner: Verify { module: './agent_store_provisioner.gg', beta1_max: '6' })
(speculative_ui_render: Verify { module: './speculative_ui_render.gg', beta1_max: '6' })
(memento_chain_anchor: Verify { module: './memento_chain_anchor.gg', beta1_max: '6' })
(reality_branch_fork: Verify { module: './reality_branch_fork.gg', beta1_max: '6' })
(verdict: Verdict)

(test_suite)-[:PROCESS]->(esi_resolution)
(esi_resolution)-[:PROCESS]->(tui_keyboard_dispatch)
(tui_keyboard_dispatch)-[:PROCESS]->(tui_layout_engine)
(tui_layout_engine)-[:PROCESS]->(pty_process_manager)
(pty_process_manager)-[:PROCESS]->(pensieve_memory_compaction)
(pensieve_memory_compaction)-[:PROCESS]->(background_daemon_telemetry)
(background_daemon_telemetry)-[:PROCESS]->(agent_store_provisioner)
(agent_store_provisioner)-[:PROCESS]->(speculative_ui_render)
(speculative_ui_render)-[:PROCESS]->(memento_chain_anchor)
(memento_chain_anchor)-[:PROCESS]->(reality_branch_fork)
(reality_branch_fork)-[:PROCESS]->(verdict)
