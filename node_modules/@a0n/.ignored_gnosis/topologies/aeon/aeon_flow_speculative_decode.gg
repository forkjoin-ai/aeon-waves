// aeon_flow_speculative_decode.gg — Speculative Decode Fork/Race/Collapse
//
// Layer: Speculative Decode
// FORK: Draft model generates K candidate branches
// RACE: All K branches enter the pipeline simultaneously
// COLLAPSE: Full model verifies branches; invalid branches pruned via poison

(context: Workload)
(draft_model: Model { type: 'small' })
(branch_1: Speculation { id: 'k1' })
(branch_2: Speculation { id: 'k2' })
(branch_3: Speculation { id: 'k3' })
(full_model: Model { type: 'large' })
(verified_tokens: Result)

(context)-[:PROCESS]->(draft_model)
(draft_model)-[:FORK]->(branch_1 | branch_2 | branch_3)

// All K branches race through the pipeline
(branch_1)-[:PROCESS]->(full_model)
(branch_2)-[:PROCESS]->(full_model)
(branch_3)-[:PROCESS]->(full_model)

// Full model collapses and prunes via POISON
(branch_1 | branch_2 | branch_3)-[:FOLD { strategy: 'verify_and_prune' }]->(verified_tokens)
(verified_tokens)-[:TUNNEL { condition: 'bounded-reject' }]->(aeon_flow_speculative_decode_gg_trace:Trace)
(verified_tokens)-[:MEASURE { reason: 'topology-audit' }]->(aeon_flow_speculative_decode_gg_trace:Trace)
