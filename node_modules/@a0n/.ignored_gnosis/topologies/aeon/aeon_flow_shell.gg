// aeon_flow_shell.gg — Shell (aeon-shell) Fork/Race/Collapse
//
// Layer: Shell (aeon-shell)
// FORK: Ghost operations fork/migrate/bequeath process snapshots; reality forks branch up to 5 timelines
// RACE: Federated processes race across devices with scoring
// COLLAPSE: Ghost merge + wisdom extraction collapse branches

(process_state: Workload)
(reality_fork_1: Ghost { timeline: 'a' })
(reality_fork_2: Ghost { timeline: 'b' })
(device_1: Compute { location: 'local' })
(device_2: Compute { location: 'remote' })
(scored_branch_1: State)
(scored_branch_2: State)
(wisdom_extraction: Result)

(process_state)-[:FORK]->(reality_fork_1 | reality_fork_2)

// Federated processes race across devices
(reality_fork_1 | device_1)-[:RACE { expect: 'highest_score' }]->(scored_branch_1)
(reality_fork_2 | device_2)-[:RACE { expect: 'highest_score' }]->(scored_branch_2)

// Ghost merge + wisdom extraction
(scored_branch_1 | scored_branch_2)-[:FOLD { strategy: 'ghost_merge' }]->(wisdom_extraction)
(wisdom_extraction)-[:TUNNEL { condition: 'bounded-reject' }]->(aeon_flow_shell_gg_trace:Trace)
(wisdom_extraction)-[:MEASURE { reason: 'topology-audit' }]->(aeon_flow_shell_gg_trace:Trace)
