// aeon_object.gg - Constitution for what an AEON object is
//
// Sources:
// - open-source/aeon/docs/ebooks/145-log-rolling-pipelined-prefill/ch14-aeon-flow-protocol.md
// - open-source/aeon/docs/ebooks/145-log-rolling-pipelined-prefill/ch21-topology-of-computation.md
// - open-source/aeon-shell/docs/rhizome-philosophy.md
// - open-source/aeon-shell/docs/rhizome-implementation-plan.md
// - open-source/x-gnosis/README.md
// - open-source/gnosis/src/auth/README.md
// - open-source/gnosis/src/capabilities/README.md
// - open-source/gnosis/src/runtime/README.md
//
// An AEON object is not just bytes and not just a URL.
// It is an address that folds identity, capability, witness, storage,
// replication, and projection into one proof-bearing materialization plan.
// Local witness wins first, remote witness fills gaps, and HTTP survives only
// as a document view rather than the substrate itself.

(address: Address { scheme: 'aeon://' })
(identity: Identity { canonical: 'aeon,did,lineage' })

(authority: Capability { contract: 'ucan+effects' })
(local_truth: Witness { source: 'rhizome_snapshot', precedence: 'primary' })
(cached_truth: Witness { source: 'community_cache', precedence: 'secondary' })
(remote_truth: Witness { source: 'x-gnosis', precedence: 'tertiary' })
(resolved_truth: Witness { policy: 'local_first' })

(storage_scope: Storage { scope: 'world,node,profile' })
(replication_policy: Replication { ladder: 'local,cache,peer,server,http' })

(constitution: Result { kind: 'materialization_plan' })

(document_view: Projection { kind: 'document', views: 'aeon,did,https' })
(app_view: Projection { kind: 'app' })
(agent_view: Projection { kind: 'agent' })
(stream_view: Projection { kind: 'stream' })
(selected_shape: Variant { adt: 'AeonShape', cases: 'document,app,agent,stream', caseFrom: 'shape' })

(document_runtime: Renderer { target: 'shell_browser' })
(app_runtime: Runtime { target: 'shell_panel' })
(agent_runtime: Runtime { target: 'kernel_daemon' })
(stream_runtime: Transport { target: 'aeon_flow' })

(aeon_object: Result { state: 'materialized' })

(address)-[:PROCESS]->(identity)

(identity)-[:FORK]->(authority | local_truth | cached_truth | remote_truth | storage_scope | replication_policy)
(local_truth | cached_truth | remote_truth)-[:RACE { expect: 'local_first' }]->(resolved_truth)

(identity | authority | resolved_truth | storage_scope | replication_policy)-[:FOLD { strategy: 'constitute_object' }]->(constitution)

(constitution)-[:FORK]->(document_view | app_view | agent_view | stream_view)
(document_view | app_view | agent_view | stream_view)-[:FOLD { strategy: 'select_requested_projection' }]->(selected_shape)

(selected_shape)-[:PROCESS { case: 'document' }]->(document_runtime)
(selected_shape)-[:PROCESS { case: 'app' }]->(app_runtime)
(selected_shape)-[:PROCESS { case: 'agent' }]->(agent_runtime)
(selected_shape)-[:PROCESS { case: 'stream' }]->(stream_runtime)

(document_runtime | app_runtime | agent_runtime | stream_runtime)-[:FOLD { strategy: 'active_shape_only' }]->(aeon_object)
(aeon_object)-[:TUNNEL { condition: 'bounded-reject' }]->(aeon_object_gg_trace:Trace)
(aeon_object)-[:MEASURE { reason: 'topology-audit' }]->(aeon_object_gg_trace:Trace)
