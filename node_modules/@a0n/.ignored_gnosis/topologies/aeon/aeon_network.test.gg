// aeon_network.test.gg — Verification harness for aeon network
(test_suite: TestSuite { name: 'aeon_network' })
(ucan_capability_auth: Verify { module: './ucan_capability_auth.gg', beta1_max: '6' })
(d1_database_sync: Verify { module: './d1_database_sync.gg', beta1_max: '6' })
(edge_cache_fallback: Verify { module: './edge_cache_fallback.gg', beta1_max: '6' })
(agent_mesh_gossip: Verify { module: './agent_mesh_gossip.gg', beta1_max: '6' })
(crdt_sync_conflict: Verify { module: './crdt_sync_conflict.gg', beta1_max: '6' })
(worker_failover_dist: Verify { module: './worker_failover_dist.gg', beta1_max: '6' })
(ucan_revocation_gossip: Verify { module: './ucan_revocation_gossip.gg', beta1_max: '6' })
(edge_queue_batcher: Verify { module: './edge_queue_batcher.gg', beta1_max: '6' })
(flux_client_sync: Verify { module: './flux_client_sync.gg', beta1_max: '6' })
(verdict: Verdict)

(test_suite)-[:PROCESS]->(ucan_capability_auth)
(ucan_capability_auth)-[:PROCESS]->(d1_database_sync)
(d1_database_sync)-[:PROCESS]->(edge_cache_fallback)
(edge_cache_fallback)-[:PROCESS]->(agent_mesh_gossip)
(agent_mesh_gossip)-[:PROCESS]->(crdt_sync_conflict)
(crdt_sync_conflict)-[:PROCESS]->(worker_failover_dist)
(worker_failover_dist)-[:PROCESS]->(ucan_revocation_gossip)
(ucan_revocation_gossip)-[:PROCESS]->(edge_queue_batcher)
(edge_queue_batcher)-[:PROCESS]->(flux_client_sync)
(flux_client_sync)-[:PROCESS]->(verdict)
