// model_weight_fetcher.gg — Aeon orchestration wrapper for model weight fetcher
//
// This local aeon wrapper gives the suite a verified module boundary without
// importing cross-topology structure into the aeon folder.

(entry: Workload { module: 'model_weight_fetcher' })
(stage_prepare: Stage { step: 'prepare' })
(stage_resolve: Stage { step: 'resolve' })
(result: Result { module: 'model_weight_fetcher' })

(entry)-[:PROCESS]->(stage_prepare)
(stage_prepare)-[:PROCESS]->(stage_resolve)
(stage_resolve)-[:PROCESS]->(result)
