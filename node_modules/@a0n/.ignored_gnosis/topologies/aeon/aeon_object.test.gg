// aeon_object.test.gg - Verification harness for the AEON object constitution

(test_suite: TestSuite { name: 'aeon-object' })
(aeon_object_model: Verify { module: './aeon_object.gg', beta1_max: '10' })

(test_suite)-[:PROCESS]->(aeon_object_model)
(aeon_object_model)-[:RACE { expect: 'safe' }]->(object_result: Result)
(object_result)-[:PROCESS]->(verdict: Verdict)
(verdict)-[:MEASURE { reason: 'topology-audit' }]->(aeon_object_test_gg_trace:Trace)
