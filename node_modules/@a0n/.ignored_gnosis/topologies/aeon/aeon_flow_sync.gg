// aeon_flow_sync.gg — Sync (aeon) Fork/Race/Collapse
//
// Layer: Sync (aeon)
// FORK: Multiple peers fork state via delta operations
// RACE: LWW / vector-clock / majority-vote race to establish canonical state
// COLLAPSE: Reconciler merges divergent states

(base_state: State)
(peer_1_delta: Operation { origin: 'peer_1' })
(peer_2_delta: Operation { origin: 'peer_2' })
(canonical_race_1: Protocol { strategy: 'lww' })
(canonical_race_2: Protocol { strategy: 'vector_clock' })
(divergent_1: State)
(divergent_2: State)
(merged_state: Result)

(base_state)-[:FORK]->(peer_1_delta | peer_2_delta)

// Race to establish canonical state
(peer_1_delta | canonical_race_1)-[:RACE { expect: 'fastest-safe' }]->(divergent_1)
(peer_2_delta | canonical_race_2)-[:RACE { expect: 'fastest-safe' }]->(divergent_2)

// Reconciler merges divergent states
(divergent_1 | divergent_2)-[:FOLD { strategy: 'crdt_merge' }]->(merged_state)
(merged_state)-[:TUNNEL { condition: 'bounded-reject' }]->(aeon_flow_sync_gg_trace:Trace)
(merged_state)-[:MEASURE { reason: 'topology-audit' }]->(aeon_flow_sync_gg_trace:Trace)
