// aeon_flow_esi.gg — ESI (Edge Side Includes) Fork/Race/Collapse
//
// Layer: ESI
// FORK: Two-phase rendering discovers parallel fragments
// RACE: Fragment requests race to resolve against cache/origin/inference
// COLLAPSE: Fragments collapse into final HTML page

(page_request: Workload)
(renderer: Parser { phase: 'discovery' })
(frag_header: Fragment { target: 'header' })
(frag_body: Fragment { target: 'body' })
(cache: Source { type: 'edge' })
(origin: Source { type: 'remote' })
(resolved_header: State)
(resolved_body: State)
(html_page: Result)

(page_request)-[:PROCESS]->(renderer)
(renderer)-[:FORK]->(frag_header | frag_body)

// Race against cache and origin
(frag_header | cache)-[:RACE { expect: 'fastest-safe' }]->(resolved_header)
(frag_body | origin)-[:RACE { expect: 'fastest-safe' }]->(resolved_body)

// Collapse fragments into the final HTML document
(resolved_header | resolved_body)-[:FOLD { strategy: 'assemble_html' }]->(html_page)
(html_page)-[:TUNNEL { condition: 'bounded-reject' }]->(aeon_flow_esi_gg_trace:Trace)
(html_page)-[:MEASURE { reason: 'topology-audit' }]->(aeon_flow_esi_gg_trace:Trace)
