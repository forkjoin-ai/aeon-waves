// aeon_shell_rhizome.test.gg — Verification harness for Rhizome topologies
//
// Validates the aeon-owned Rhizome wrappers without introducing extra result
// fan-out inside the suite topology.

(test_suite: TestSuite { name: 'aeon-shell-rhizome' })
(rhizome_metabolism: Verify { module: './aeon_shell_rhizome_metabolism.gg', beta1_max: '4' })
(rhizome_projections: Verify { module: './aeon_shell_rhizome_projections.gg', beta1_max: '4' })
(verdict: Verdict)

(test_suite)-[:PROCESS]->(rhizome_metabolism)
(rhizome_metabolism)-[:PROCESS]->(rhizome_projections)
(rhizome_projections)-[:PROCESS]->(verdict)
