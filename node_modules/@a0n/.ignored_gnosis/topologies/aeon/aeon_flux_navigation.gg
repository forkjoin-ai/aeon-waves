// Aeon-Flux Navigation Topology
// Redefining client-side routing as topological state transitions.

// 1. Navigation Components
(nav_event: Source { type: 'push_state' })
(url_parser: Logic { op: 'parse_url' })
(history_manager: Logic { op: 'update_history' })
(route_matcher: Logic { op: 'match_active_topology' })
(preloader: Logic { op: 'speculative_fetch' })
(site_renderer: Renderer { type: 'vdom' })

// 2. The Navigation Topology
(nav_event)-[:PROCESS]->(url_parser)

// Fork into history update and route matching
(url_parser)-[:FORK]->(history_manager | route_matcher)

// On a successful match, fork into preloading and rendering
(route_matcher)-[:FORK]->(preloader | site_renderer)

// Collapse once navigation is complete
(preloader | site_renderer)-[:FOLD { strategy: 'merge-all' }]->(nav_complete)
(history_manager | nav_complete)-[:SLIVER { mode: 'constructive' }]->(app_state)
(app_state)-[:TUNNEL { condition: 'bounded-reject' }]->(aeon_flux_navigation_gg_trace:Trace)
(app_state)-[:MEASURE { reason: 'topology-audit' }]->(aeon_flux_navigation_gg_trace:Trace)
