// AEON VOTING: COMMUNITY COVER + LOW REJECTION
//
// The candidate with minimum governance deficit wins.
// governance_deficit = rejections + uncovered_communities
//
// Example:
// - total communities = 3
// - River is approved in all 3 communities with 0 rejections
// - Slate is approved in 1 community and rejected once
// - Ember is approved in 2 communities and rejected twice
//
// Deficits:
// - River = 0 + (3 - 3) = 0
// - Slate = 1 + (3 - 1) = 3
// - Ember = 2 + (3 - 2) = 3
//
// River wins strictly.

topology aeon_voting {

  theorem community_cover_with_zero_rejection_is_optimal {
    total_communities = "3"
    deficit_formula = "rejections + uncovered_communities"
    tie_break = "approvals -> represented_communities -> candidate_id"
  }

  river {
    candidate = "River"
    approvals = "5"
    rejections = "0"
    represented_communities = "3"
    uncovered_communities = "0"
    deficit = "0"
  }

  slate {
    candidate = "Slate"
    approvals = "3"
    rejections = "1"
    represented_communities = "1"
    uncovered_communities = "2"
    deficit = "3"
  }

  ember {
    candidate = "Ember"
    approvals = "4"
    rejections = "2"
    represented_communities = "2"
    uncovered_communities = "1"
    deficit = "3"
  }

  result {
    theorem = "THM-AEON-VOTING"
    selected = "River"
    reason = "minimum-governance-deficit"
  }
}

(aeon_voting)-[:FORK]->(river | slate | ember)
(river | slate | ember)-[:RACE { expect: "ordered-by-deficit" }]->(result)
(result)-[:MEASURE { reason: 'topology-audit' }]->(aeon_voting_test_gg_trace:Trace)
