// aeon_flow_inference.gg — Inference Fork/Race/Collapse
//
// Layer: Inference
// FORK: Wallington Rotation chunks tokens across nodes
// RACE: Turbulent multiplexing fills idle slots with other requests
// COLLAPSE: Worthington Whip cross-shard attention correction

(prompt: Workload { type: 'tokens' })
(chunk_1: Compute { node: 'worker_a' })
(chunk_2: Compute { node: 'worker_b' })
(idle_slot: Scheduler { state: 'turbulent_multiplexing' })
(processed_1: State)
(processed_2: State)
(final_output: Result)

(prompt)-[:FORK]->(chunk_1 | chunk_2)

// Race to fill idle execution slots
(chunk_1 | idle_slot)-[:RACE { expect: 'fastest-safe' }]->(processed_1)
(chunk_2 | idle_slot)-[:RACE { expect: 'fastest-safe' }]->(processed_2)

// Collapse via Worthington Whip
(processed_1 | processed_2)-[:FOLD { strategy: 'worthington_whip' }]->(final_output)
(final_output)-[:TUNNEL { condition: 'bounded-reject' }]->(aeon_flow_inference_gg_trace:Trace)
(final_output)-[:MEASURE { reason: 'topology-audit' }]->(aeon_flow_inference_gg_trace:Trace)
