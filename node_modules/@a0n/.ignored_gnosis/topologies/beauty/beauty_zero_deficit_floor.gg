// beauty_zero_deficit_floor.gg — THM-BEAUTY-OPTIMALITY witness (zero deficit = cost floor)
//
// When every forked branch converges with zero deficit, the total cost
// equals the structural floor. No configuration can produce lower cost.
// Example: 3 branches, all matched, deficit = 0, cost = floor = 3.

(config: BeautyConfig { theorem: 'THM-BEAUTY-OPTIMALITY', branches: '3', deficit: '0' })
(branch_a: Branch { output: 'a', deficit: '0' })
(branch_b: Branch { output: 'b', deficit: '0' })
(branch_c: Branch { output: 'c', deficit: '0' })
(cost: CostMeasure { total: '3', floor: '3' })
(invariant: Invariant { claim: 'deficit_zero_implies_cost_equals_floor', cost: '3', floor: '3' })
(result: Result { theorem: 'zero-deficit-is-cost-floor' })

(config)-[:FORK]->(branch_a | branch_b | branch_c)
(branch_a | branch_b | branch_c)-[:RACE { expect: 'zero-deficit' }]->(cost)
(cost)-[:PROCESS]->(invariant)
(invariant)-[:PROCESS { strategy: 'verify-equality' }]->(result)
(result)-[:MEASURE { reason: 'topology-audit' }]->(beauty_zero_deficit_floor_gg_trace:Trace)
