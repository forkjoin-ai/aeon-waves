// beauty_optimality.test.gg — Native Gnosis witnesses for THM-BEAUTY-OPTIMALITY
//
// These theorem-shaped `.gg` modules cover:
//   - zero deficit is the cost floor (zero_deficit_floor)
//   - more deficit means more cost (monotone_cost)
//   - the minimizer at zero deficit is unique (strict_objective)

(test_suite: TestSuite { name: 'beauty-optimality' })

(zero_deficit_floor: Verify { module: './beauty_zero_deficit_floor.gg', beta1_max: '6' })
(monotone_cost: Verify { module: './beauty_monotone_cost.gg', beta1_max: '6' })
(strict_objective: Verify { module: './beauty_strict_objective.gg', beta1_max: '6' })

(test_suite)-[:FORK]->(zero_deficit_floor | monotone_cost | strict_objective)

(zero_deficit_floor)-[:RACE { expect: 'safe' }]->(zero_deficit_result: Result)
(monotone_cost)-[:RACE { expect: 'safe' }]->(monotone_cost_result: Result)
(strict_objective)-[:RACE { expect: 'safe' }]->(strict_objective_result: Result)

(zero_deficit_result | monotone_cost_result | strict_objective_result)-[:FOLD { strategy: 'all-pass' }]->(verdict: Verdict)
(verdict)-[:TUNNEL { condition: 'bounded-reject' }]->(beauty_optimality_test_gg_trace:Trace)
(verdict)-[:MEASURE { reason: 'topology-audit' }]->(beauty_optimality_test_gg_trace:Trace)
