// beauty_strict_objective.gg — THM-BEAUTY-OPTIMALITY witness (unique minimizer at zero deficit)
//
// The cost objective has a unique global minimizer at deficit = 0.
// Any nonzero deficit strictly increases cost, so no other configuration
// can tie with the zero-deficit solution.
// Example: deficit 0 -> cost 3, deficit 1 -> cost 4 > 3. Unique minimum.

(optimal: BeautyConfig { theorem: 'THM-BEAUTY-OPTIMALITY', deficit: '0', cost: '3' })
(perturbed: BeautyConfig { deficit: '1', cost: '4' })
(strict: Invariant { claim: 'cost(d=0) < cost(d>0)', optimal_cost: '3', perturbed_cost: '4' })
(unique: Invariant { claim: 'minimizer_unique_at_zero_deficit', minimizer_deficit: '0' })
(result: Result { theorem: 'unique-minimizer-zero-deficit' })

(optimal)-[:PROCESS]->(perturbed)
(optimal | perturbed)-[:RACE { expect: 'strict-inequality' }]->(strict)
(strict)-[:PROCESS]->(unique)
(unique)-[:PROCESS { strategy: 'verify-uniqueness' }]->(result)
(result)-[:MEASURE { reason: 'topology-audit' }]->(beauty_strict_objective_gg_trace:Trace)
