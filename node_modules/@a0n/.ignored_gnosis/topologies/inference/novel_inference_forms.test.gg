// novel_inference_forms.test.gg — Native Gnosis witnesses for THM-NOVEL-INFERENCE-FORMS
//
// These theorem-shaped `.gg` modules cover:
//   - generation by rejection accumulation (void inference)
//   - constrained from terminal (retrocausal decoding)
//   - skip by beta1 deficit (topological speculative decode)
//   - complement voting (semiotic ensemble)

(test_suite: TestSuite { name: 'novel-inference-forms' })

(void_inference: Verify { module: './novel_void_inference.gg', beta1_max: '6' })
(retrocausal_decoding: Verify { module: './novel_retrocausal_decoding.gg', beta1_max: '6' })
(topo_spec_decode: Verify { module: './novel_topo_spec_decode.gg', beta1_max: '6' })
(semiotic_ensemble: Verify { module: './novel_semiotic_ensemble.gg', beta1_max: '6' })

(test_suite)-[:FORK]->(void_inference | retrocausal_decoding | topo_spec_decode | semiotic_ensemble)

(void_inference)-[:RACE { expect: 'safe' }]->(void_result: Result)
(retrocausal_decoding)-[:RACE { expect: 'safe' }]->(retro_result: Result)
(topo_spec_decode)-[:RACE { expect: 'safe' }]->(topo_result: Result)
(semiotic_ensemble)-[:RACE { expect: 'safe' }]->(semi_result: Result)

(void_result | retro_result | topo_result | semi_result)-[:FOLD { strategy: 'all-pass' }]->(verdict: Verdict)
(verdict)-[:TUNNEL { condition: 'bounded-reject' }]->(novel_inference_forms_test_gg_trace:Trace)
(verdict)-[:MEASURE { reason: 'topology-audit' }]->(novel_inference_forms_test_gg_trace:Trace)
