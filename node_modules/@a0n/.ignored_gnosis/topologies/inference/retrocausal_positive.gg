// retrocausal_positive.gg — THM-RETROCAUSAL-BOUND witness (all terminal weights positive)
//
// At any terminal state, every choice retains positive weight.
// weight = rounds - min(void_count, rounds) + 1 >= 1.
// Even the most rejected choice has the sliver.

(space: RetrocausalSpace { theorem: 'THM-RETROCAUSAL-BOUND', choices: '4', rounds: '10' })
(choice_a: TerminalChoice { id: 'A', void_count: '0', weight: '11' })
(choice_b: TerminalChoice { id: 'B', void_count: '4', weight: '7' })
(choice_c: TerminalChoice { id: 'C', void_count: '9', weight: '2' })
(choice_d: TerminalChoice { id: 'D', void_count: '10', weight: '1' })
(sliver: Invariant { claim: 'all terminal weights >= 1', min_weight: '1' })
(result: Result { theorem: 'terminal-weights-positive' })

(space)-[:FORK]->(choice_a | choice_b | choice_c | choice_d)
(choice_a | choice_b | choice_c | choice_d)-[:RACE { expect: 'all-positive' }]->(sliver)
(sliver)-[:PROCESS { strategy: 'verify-minimum' }]->(result)
(result)-[:MEASURE { reason: 'topology-audit' }]->(retrocausal_positive_gg_trace:Trace)
