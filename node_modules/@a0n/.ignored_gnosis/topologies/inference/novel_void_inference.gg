// novel_void_inference.gg — THM-NOVEL-INFERENCE-FORMS witness (generation by rejection accumulation)
//
// Instead of generating by sampling from a distribution, generate by
// accumulating rejections until the complement collapses to a single token.
// The void walker rejects tokens round by round; the survivor formalizes the output.

(generator: VoidGenerator { theorem: 'THM-NOVEL-INFERENCE-FORMS', vocab_size: '5', rounds: '12' })
(token_a: Token { id: 'A', void_count: '12', weight: '1', status: 'barely-surviving' })
(token_b: Token { id: 'B', void_count: '10', weight: '3', status: 'weak' })
(token_c: Token { id: 'C', void_count: '2', weight: '11', status: 'dominant' })
(token_d: Token { id: 'D', void_count: '8', weight: '5', status: 'moderate' })
(token_e: Token { id: 'E', void_count: '11', weight: '2', status: 'nearly-vented' })
(selection: Invariant { claim: 'argmax complement = generated token', selected: 'C', weight: '11' })
(result: Result { theorem: 'generation-by-rejection-accumulation' })

(generator)-[:FORK]->(token_a | token_b | token_c | token_d | token_e)
(token_a)-[:VENT { condition: 'maximally-rejected' }]->(vented_a: VentedToken)
(token_e)-[:VENT { condition: 'nearly-rejected' }]->(vented_e: VentedToken)
(token_b | token_c | token_d)-[:RACE { expect: 'complement-computed' }]->(selection)
(selection)-[:PROCESS { strategy: 'verify-argmax' }]->(result)
(result)-[:MEASURE { reason: 'topology-audit' }]->(novel_void_inference_gg_trace:Trace)
