// novel_retrocausal_decoding.gg — THM-NOVEL-INFERENCE-FORMS witness (constrained from terminal)
//
// Decode a sequence by fixing the terminal token and inferring backward.
// The terminal constraint propagates retrocausally, narrowing the void
// boundary at each prior position. Tokens are selected in reverse order.

(decoder: RetrocausalDecoder { theorem: 'THM-NOVEL-INFERENCE-FORMS', seq_length: '4', vocab_size: '3' })
(terminal: FixedToken { position: '4', token: 'C', constraint: 'end-of-sequence' })
(pos_3: DecodedPosition { position: '3', candidates: '[A, B, C]', void_counts: '[1, 3, 0]', selected: 'A' })
(pos_2: DecodedPosition { position: '2', candidates: '[A, B, C]', void_counts: '[2, 0, 3]', selected: 'B' })
(pos_1: DecodedPosition { position: '1', candidates: '[A, B, C]', void_counts: '[0, 2, 2]', selected: 'A' })
(sequence: DecodedSequence { tokens: '[A, B, A, C]', direction: 'backward' })
(coherence: Invariant { claim: 'backward decode produces valid sequence', length: '4' })
(result: Result { theorem: 'constrained-from-terminal' })

(decoder)-[:PROCESS]->(terminal)
(terminal)-[:PROCESS { expect: 'backward-propagation' }]->(pos_3)
(pos_3)-[:PROCESS { expect: 'backward-propagation' }]->(pos_2)
(pos_2)-[:PROCESS { expect: 'backward-propagation' }]->(pos_1)
(pos_1)-[:PROCESS { strategy: 'assemble-sequence' }]->(sequence)
(sequence)-[:PROCESS]->(coherence)
(coherence)-[:PROCESS]->(result)
