// teleportation_coherent.gg — THM-STATISTICAL-TELEPORTATION witness (same boundary -> same teleport)
//
// Two teleportations sharing the same boundary condition produce
// identical teleported distributions. The teleport is a deterministic
// function of the boundary.
// Example: boundary B, teleport_1(B) = D, teleport_2(B) = D.

(teleport: StatTeleport { theorem: 'THM-STATISTICAL-TELEPORTATION', boundary: 'B' })
(teleport_1: TeleportResult { boundary: 'B', distribution: 'D', hash: '0xABCD' })
(teleport_2: TeleportResult { boundary: 'B', distribution: 'D', hash: '0xABCD' })
(coherence: Invariant { claim: 'same_boundary_same_teleport', hash_1: '0xABCD', hash_2: '0xABCD' })
(result: Result { theorem: 'teleport-coherent' })

(teleport)-[:FORK]->(teleport_1 | teleport_2)
(teleport_1 | teleport_2)-[:RACE { expect: 'identical-output' }]->(coherence)
(coherence)-[:PROCESS { strategy: 'verify-equality' }]->(result)
(result)-[:MEASURE { reason: 'topology-audit' }]->(teleportation_coherent_gg_trace:Trace)
