// novel_topo_spec_decode.gg — THM-NOVEL-INFERENCE-FORMS witness (skip by beta1 deficit)
//
// Speculative decoding accelerated by topology: if beta1 deficit at a
// position is zero (all holes covered), the draft token is accepted without
// verification. Positions with nonzero deficit require full verification.
// Skip rate = fraction of positions with zero deficit.

(decoder: TopoSpecDecoder { theorem: 'THM-NOVEL-INFERENCE-FORMS', positions: '6', beta1: '3' })
(pos_1: SpecPosition { position: '1', deficit: '0', action: 'skip', verified: 'false' })
(pos_2: SpecPosition { position: '2', deficit: '0', action: 'skip', verified: 'false' })
(pos_3: SpecPosition { position: '3', deficit: '2', action: 'verify', verified: 'true' })
(pos_4: SpecPosition { position: '4', deficit: '0', action: 'skip', verified: 'false' })
(pos_5: SpecPosition { position: '5', deficit: '1', action: 'verify', verified: 'true' })
(pos_6: SpecPosition { position: '6', deficit: '0', action: 'skip', verified: 'false' })
(speedup: Invariant { claim: 'skip_rate = zero_deficit / total', skipped: '4', verified: '2', skip_rate: '0.667' })
(result: Result { theorem: 'skip-by-beta1-deficit' })

(decoder)-[:FORK]->(pos_1 | pos_2 | pos_3 | pos_4 | pos_5 | pos_6)
(pos_3)-[:VENT { condition: 'deficit-nonzero' }]->(verify_3: VerificationRequired)
(pos_5)-[:VENT { condition: 'deficit-nonzero' }]->(verify_5: VerificationRequired)
(pos_1 | pos_2 | pos_4 | pos_6)-[:RACE { expect: 'zero-deficit-skip' }]->(speedup)
(verify_3 | verify_5)-[:PROCESS]->(speedup)
(speedup)-[:PROCESS { strategy: 'verify-skip-rate' }]->(result)
(result)-[:MEASURE { reason: 'topology-audit' }]->(novel_topo_spec_decode_gg_trace:Trace)
