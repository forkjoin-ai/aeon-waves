// novel_semiotic_ensemble.gg — THM-NOVEL-INFERENCE-FORMS witness (complement voting)
//
// Multiple models vote by complement: each model reports what it rejected.
// The ensemble prediction is the token with the lowest total rejection count
// across all voters. Complement voting is dual to probability voting.

(ensemble: SemioticEnsemble { theorem: 'THM-NOVEL-INFERENCE-FORMS', models: '3', vocab_size: '4' })
(model_1: Model { id: 'M1', rejections: '[2, 5, 1, 8]' })
(model_2: Model { id: 'M2', rejections: '[3, 4, 2, 7]' })
(model_3: Model { id: 'M3', rejections: '[1, 6, 3, 9]' })
(token_a: TokenVote { id: 'A', total_rejections: '6', rank: '2' })
(token_b: TokenVote { id: 'B', total_rejections: '15', rank: '3' })
(token_c: TokenVote { id: 'C', total_rejections: '6', rank: '1' })
(token_d: TokenVote { id: 'D', total_rejections: '24', rank: '4' })
(vote: Invariant { claim: 'argmin total rejections = ensemble prediction', selected: 'C', total: '6' })
(result: Result { theorem: 'complement-voting-ensemble' })

(ensemble)-[:FORK]->(model_1 | model_2 | model_3)
(model_1 | model_2 | model_3)-[:RACE { expect: 'rejections-tallied' }]->(token_a | token_b | token_c | token_d)
(token_a | token_b | token_c | token_d)-[:FOLD { strategy: 'argmin-rejection' }]->(vote)
(vote)-[:PROCESS]->(result)
(result)-[:TUNNEL { condition: 'bounded-reject' }]->(novel_semiotic_ensemble_gg_trace:Trace)
(result)-[:MEASURE { reason: 'topology-audit' }]->(novel_semiotic_ensemble_gg_trace:Trace)
