// statistical_teleportation.test.gg — Native Gnosis witnesses for THM-STATISTICAL-TELEPORTATION
//
// These theorem-shaped `.gg` modules cover:
//   - teleport deficit is always positive (deficit_positive)
//   - same boundary produces same teleport (coherent)
//   - rejection sharpens teleport precision (concentration)

(test_suite: TestSuite { name: 'statistical-teleportation' })

(deficit_positive: Verify { module: './teleportation_deficit_positive.gg', beta1_max: '6' })
(coherent: Verify { module: './teleportation_coherent.gg', beta1_max: '6' })
(concentration: Verify { module: './teleportation_concentration.gg', beta1_max: '6' })

(test_suite)-[:FORK]->(deficit_positive | coherent | concentration)

(deficit_positive)-[:RACE { expect: 'safe' }]->(deficit_result: Result)
(coherent)-[:RACE { expect: 'safe' }]->(coherent_result: Result)
(concentration)-[:RACE { expect: 'safe' }]->(concentration_result: Result)

(deficit_result | coherent_result | concentration_result)-[:FOLD { strategy: 'all-pass' }]->(verdict: Verdict)
(verdict)-[:TUNNEL { condition: 'bounded-reject' }]->(statistical_teleportation_test_gg_trace:Trace)
(verdict)-[:MEASURE { reason: 'topology-audit' }]->(statistical_teleportation_test_gg_trace:Trace)
