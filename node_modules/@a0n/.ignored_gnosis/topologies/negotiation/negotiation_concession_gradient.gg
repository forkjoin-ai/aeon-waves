// negotiation_concession_gradient.gg — THM-CONCESSION-GRADIENT witness
//
// Terms rejected less get higher concession weight.
// The void gradient naturally steers toward compromise.
// No term ever reaches zero weight (the sliver).

(state: NegotiationState { theorem: 'THM-CONCESSION-GRADIENT', terms: '3', rounds: '10' })
(term_price: Term { name: 'price', rejections: '7', weight: '4' })
(term_timeline: Term { name: 'timeline', rejections: '2', weight: '9' })
(term_warranty: Term { name: 'warranty', rejections: '5', weight: '6' })
(gradient: ConcessionGradient { order: 'timeline > warranty > price', min_weight: '4' })
(sliver: Invariant { claim: 'all weights >= 1', satisfied: 'true' })
(result: Result { theorem: 'gradient-steers-toward-compromise' })

(state)-[:FORK]->(term_price | term_timeline | term_warranty)
(term_price | term_timeline | term_warranty)-[:RACE { expect: 'gradient-ordered' }]->(gradient)
(gradient)-[:PROCESS]->(sliver)
(sliver)-[:PROCESS { strategy: 'verify-gradient-and-sliver' }]->(result)
(result)-[:MEASURE { reason: 'topology-audit' }]->(negotiation_concession_gradient_gg_trace:Trace)
