// negotiation_equilibrium.test.gg — Native Gnosis witnesses for THM-NEGOTIATION-EQUILIBRIUM
//
// These theorem-shaped `.gg` modules cover:
//   - negotiation deficit is positive (confusion is irreducible)
//   - BATNA is void boundary (rejected offers = rejection counts)
//   - concession gradient steers toward least-rejected
//   - settlement is Lyapunov-stable

(test_suite: TestSuite { name: 'negotiation-equilibrium' })

(deficit_positive: Verify { module: './negotiation_deficit_positive.gg', beta1_max: '6' })
(batna_is_void: Verify { module: './negotiation_batna_void.gg', beta1_max: '6' })
(concession_gradient: Verify { module: './negotiation_concession_gradient.gg', beta1_max: '6' })
(settlement_stable: Verify { module: './negotiation_settlement_stable.gg', beta1_max: '6' })

(test_suite)-[:FORK]->(deficit_positive | batna_is_void | concession_gradient | settlement_stable)

(deficit_positive)-[:RACE { expect: 'safe' }]->(deficit_result: Result)
(batna_is_void)-[:RACE { expect: 'safe' }]->(batna_result: Result)
(concession_gradient)-[:RACE { expect: 'safe' }]->(gradient_result: Result)
(settlement_stable)-[:RACE { expect: 'safe' }]->(stable_result: Result)

(deficit_result | batna_result | gradient_result | stable_result)-[:FOLD { strategy: 'all-pass' }]->(verdict: Verdict)
(verdict)-[:TUNNEL { condition: 'bounded-reject' }]->(negotiation_equilibrium_test_gg_trace:Trace)
(verdict)-[:MEASURE { reason: 'topology-audit' }]->(negotiation_equilibrium_test_gg_trace:Trace)
