// daisy_chain_voting.gg — THM-DAISY-CHAIN-MOA witness (complement voting selects best)
//
// Complement voting scores each output by how many other agents
// would NOT have produced it. The output with the highest complement
// score is selected as the best. Unique outputs score highest.
// Example: 3 agents, outputs [A, B, A]. B has complement score 2, A has 1.

(ensemble: DaisyChainMoA { theorem: 'THM-DAISY-CHAIN-MOA', agents: '3' })
(agent_1: Agent { id: '1', output: 'A', complement_score: '1' })
(agent_2: Agent { id: '2', output: 'B', complement_score: '2' })
(agent_3: Agent { id: '3', output: 'A', complement_score: '1' })
(winner: VotingResult { selected: 'B', score: '2', reason: 'highest-complement' })
(invariant: Invariant { claim: 'complement_voting_selects_best', winner: 'B', score: '2' })
(result: Result { theorem: 'complement-voting-best' })

(ensemble)-[:FORK]->(agent_1 | agent_2 | agent_3)
(agent_1 | agent_2 | agent_3)-[:RACE { expect: 'scored' }]->(winner)
(winner)-[:PROCESS]->(invariant)
(invariant)-[:PROCESS { strategy: 'verify-maximum' }]->(result)
(result)-[:MEASURE { reason: 'topology-audit' }]->(daisy_chain_voting_gg_trace:Trace)
