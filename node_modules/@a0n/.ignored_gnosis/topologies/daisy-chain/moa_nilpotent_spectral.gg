// moa_nilpotent_spectral.gg — THM-HETERO-MOA-FABRIC witness (acyclic fabric -> spectral stability)
//
// An acyclic MoA fabric has a nilpotent adjacency matrix. All eigenvalues
// are zero, guaranteeing spectral stability: no resonance or divergence.
// Example: 3-layer DAG fabric, spectral radius = 0.

(fabric: MoAFabric { theorem: 'THM-HETERO-MOA-FABRIC', layers: '3', acyclic: 'true' })
(layer_1: FabricLayer { id: '1', fanout: '2' })
(layer_2: FabricLayer { id: '2', fanout: '2' })
(layer_3: FabricLayer { id: '3', fanout: '1' })
(adjacency: AdjacencyMatrix { nilpotent: 'true', spectral_radius: '0' })
(invariant: Invariant { claim: 'acyclic_implies_spectral_stable', spectral_radius: '0' })
(result: Result { theorem: 'nilpotent-spectral-stability' })

(fabric)-[:FORK]->(layer_1 | layer_2 | layer_3)
(layer_1)-[:PROCESS]->(layer_2)
(layer_2)-[:PROCESS]->(layer_3)
(layer_1 | layer_2 | layer_3)-[:RACE { expect: 'nilpotent' }]->(adjacency)
(adjacency)-[:PROCESS]->(invariant)
(invariant)-[:PROCESS { strategy: 'verify-zero' }]->(result)
(result)-[:MEASURE { reason: 'topology-audit' }]->(moa_nilpotent_spectral_gg_trace:Trace)
