// moa_mirrored_pair.gg — THM-HETERO-MOA-FABRIC witness (mirrored kernels inherit stability)
//
// A mirrored pair of MoA kernels (forward and backward) inherits
// spectral stability from the original fabric. If the forward kernel
// is stable, its mirror is stable with the same spectral bound.
// Example: forward spectral radius = 0, mirror spectral radius = 0.

(fabric: MoAFabric { theorem: 'THM-HETERO-MOA-FABRIC', mirrored: 'true' })
(forward: Kernel { id: 'forward', spectral_radius: '0', stable: 'true' })
(mirror: Kernel { id: 'mirror', spectral_radius: '0', stable: 'true' })
(inheritance: Invariant { claim: 'mirror_inherits_stability', forward_stable: 'true', mirror_stable: 'true' })
(result: Result { theorem: 'mirrored-pair-stability' })

(fabric)-[:FORK]->(forward | mirror)
(forward | mirror)-[:RACE { expect: 'both-stable' }]->(inheritance)
(inheritance)-[:PROCESS { strategy: 'verify-equality' }]->(result)
(result)-[:MEASURE { reason: 'topology-audit' }]->(moa_mirrored_pair_gg_trace:Trace)
