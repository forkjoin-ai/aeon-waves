// dpi_strict_noninjective.gg — THM-DATA-PROCESSING-INEQUALITY witness (non-injective strictly loses)
//
// A non-injective processing step collapses distinct inputs to the
// same output, strictly reducing mutual information. The loss is
// irreversible -- erased distinctions cannot be recovered.
// Example: 8 inputs -> 4 outputs (2-to-1 map), I drops from 3.0 to 2.0.

(chain: MarkovChain { theorem: 'THM-DATA-PROCESSING-INEQUALITY', type: 'non-injective' })
(input_space: StateSpace { cardinality: '8', entropy_bits: '3.0' })
(map: ProcessingStep { type: 'non-injective', input_card: '8', output_card: '4', ratio: '2:1' })
(output_space: StateSpace { cardinality: '4', entropy_bits: '2.0' })
(strict_loss: Invariant { claim: 'non-injective implies strict info loss', info_before: '3.0', info_after: '2.0', lost: '1.0' })
(result: Result { theorem: 'noninjective-strict-loss' })

(chain)-[:PROCESS]->(input_space)
(input_space)-[:PROCESS { strategy: 'non-injective-map' }]->(map)
(map)-[:PROCESS]->(output_space)
(output_space)-[:PROCESS { expect: 'info-strictly-less' }]->(strict_loss)
(strict_loss)-[:PROCESS { strategy: 'verify-strict-inequality' }]->(result)
