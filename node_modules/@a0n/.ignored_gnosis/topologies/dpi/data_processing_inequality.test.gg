// data_processing_inequality.test.gg — Native Gnosis witnesses for THM-DATA-PROCESSING-INEQUALITY
//
// These theorem-shaped `.gg` modules cover:
//   - processing cannot increase information
//   - non-injective processing strictly loses information
//   - identity processing preserves all information

(test_suite: TestSuite { name: 'data-processing-inequality' })

(nonincrease: Verify { module: './dpi_nonincrease.gg', beta1_max: '6' })
(strict_noninjective: Verify { module: './dpi_strict_noninjective.gg', beta1_max: '6' })
(identity_preserves: Verify { module: './dpi_identity_preserves.gg', beta1_max: '6' })

(test_suite)-[:FORK]->(nonincrease | strict_noninjective | identity_preserves)

(nonincrease)-[:RACE { expect: 'safe' }]->(nonincrease_result: Result)
(strict_noninjective)-[:RACE { expect: 'safe' }]->(strict_result: Result)
(identity_preserves)-[:RACE { expect: 'safe' }]->(identity_result: Result)

(nonincrease_result | strict_result | identity_result)-[:FOLD { strategy: 'all-pass' }]->(verdict: Verdict)
(verdict)-[:TUNNEL { condition: 'bounded-reject' }]->(data_processing_inequality_test_gg_trace:Trace)
(verdict)-[:MEASURE { reason: 'topology-audit' }]->(data_processing_inequality_test_gg_trace:Trace)
