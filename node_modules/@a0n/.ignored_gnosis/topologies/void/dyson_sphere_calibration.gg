// dyson_sphere_calibration.gg — Self-Calibrating Exit Heads
//
// A GG agent topology deployed via aeon-forge that runs on a cron
// schedule (daily 3am UTC). The topology is fork/race/fold:
//
//   FORK: export rejection data from D1, launch calibration build
//   RACE: wait for build to complete (timeout 20 min)
//   FOLD: upload trained exit heads to KV, redeploy edge workers
//   VENT: log failures, track KL divergence trend
//
// The agent calibrates itself against its own rejection exhaust.
// Every day, the exit heads get better. The Dyson Sphere sharpens
// its own focus from the void it captures.
//
// Deploy: forge deploy dyson-sphere-calibration --kind agent --cron "0 3 * * *"

// ═══════════════════════════════════════════════════════════════════════
// Phase 1: Export Rejection Data
// ═══════════════════════════════════════════════════════════════════════

(export_rejections {
  kind: "task",
  label: "Export D1 Rejections",
  exec: "bash",
  args: ["-c", "curl -s -X POST https://edge.affectively.ai/foundational/export -H 'Content-Type: application/json' -d '{\"limit\": 50000, \"format\": \"jsonl\"}' > /tmp/rejections.jsonl && wc -l /tmp/rejections.jsonl"],
  timeout_ms: 30000,
  retry: 2
})

// ═══════════════════════════════════════════════════════════════════════
// Phase 2: FORK -- Launch Calibration Build
// ═══════════════════════════════════════════════════════════════════════

(fetch_credentials {
  kind: "task",
  label: "Fetch GCP Credentials",
  exec: "bash",
  args: ["-c", "gcloud secrets versions access latest --secret=huggingface-token > /tmp/hf_token && gcloud secrets versions access latest --secret=CLOUDFLARE_API_TOKEN > /tmp/cf_token && echo 'credentials fetched'"],
  timeout_ms: 15000
})

(upload_script {
  kind: "task",
  label: "Upload Calibration Script to GCS",
  exec: "bash",
  args: ["-c", "gsutil cp scripts/calibrate-exit-heads.py gs://neutral-418500_cloudbuild/scripts/calibrate-exit-heads.py"],
  timeout_ms: 15000
})

(launch_calibration {
  kind: "task",
  label: "Launch Cloud Build Calibration",
  exec: "bash",
  args: ["-c", "HF_TOKEN=$(cat /tmp/hf_token) CF_API_TOKEN=$(cat /tmp/cf_token) && gcloud builds submit --no-source --config=apps/mesh-workers/builds/cloudbuild-calibrate-exit-heads.yaml --substitutions=\"_HF_TOKEN=$HF_TOKEN,_CF_ACCOUNT_ID=0eaf6e54519378a2f608e8c982f020ed,_CF_KV_NAMESPACE_ID=270225c9e25e4721882c1b7193dd7a83,_CF_API_TOKEN=$CF_API_TOKEN\" --async --format='value(id)' > /tmp/build_id && cat /tmp/build_id"],
  timeout_ms: 60000
})

// ═══════════════════════════════════════════════════════════════════════
// Phase 3: RACE -- Wait for Build Completion
// ═══════════════════════════════════════════════════════════════════════

(wait_for_build {
  kind: "task",
  label: "Wait for Calibration Build",
  exec: "bash",
  args: ["-c", "BUILD_ID=$(cat /tmp/build_id) && for i in $(seq 1 20); do STATUS=$(gcloud builds describe $BUILD_ID --format='value(status)' 2>/dev/null); echo \"Poll $i: $STATUS\"; if [ \"$STATUS\" = 'SUCCESS' ]; then echo 'BUILD_SUCCESS'; exit 0; fi; if [ \"$STATUS\" = 'FAILURE' ] || [ \"$STATUS\" = 'TIMEOUT' ]; then echo 'BUILD_FAILED'; exit 1; fi; sleep 60; done; echo 'BUILD_TIMEOUT'; exit 1"],
  timeout_ms: 1260000
})

// ═══════════════════════════════════════════════════════════════════════
// Phase 4: FOLD -- Deploy Updated Exit Heads
// ═══════════════════════════════════════════════════════════════════════

(redeploy_edge {
  kind: "task",
  label: "Redeploy Edge Workers",
  exec: "bash",
  args: ["-c", "cd apps/edge-workers && npx wrangler deploy --env production 2>&1 | tail -3"],
  timeout_ms: 120000
})

(verify_health {
  kind: "task",
  label: "Verify Foundational Health",
  exec: "bash",
  args: ["-c", "curl -sf https://edge.affectively.ai/foundational/health | python3 -c 'import sys,json; d=json.load(sys.stdin); print(d.get(\"status\",\"unknown\"))'"],
  timeout_ms: 15000,
  retry: 3
})

(verify_inference {
  kind: "task",
  label: "Verify Inference Quality",
  exec: "bash",
  args: ["-c", "curl -sf -X POST https://edge.affectively.ai/ai/communicate -H 'Content-Type: application/json' -d '{\"prompt\":\"Hello\",\"model\":\"cog-360m\",\"max_tokens\":2,\"temperature\":0.5}' | python3 -c 'import sys,json; d=json.load(sys.stdin); print(f\"glossolalia={d.get(\\\"glossolalia\\\")}, response={d.get(\\\"response\\\",\\\"\\\")[:20]}\")'"],
  timeout_ms: 120000
})

// ═══════════════════════════════════════════════════════════════════════
// Phase 5: VENT -- Log Results
// ═══════════════════════════════════════════════════════════════════════

(log_results {
  kind: "task",
  label: "Log Calibration Results",
  exec: "bash",
  args: ["-c", "BUILD_ID=$(cat /tmp/build_id 2>/dev/null || echo 'unknown') && echo \"$(date -u +%Y-%m-%dT%H:%M:%SZ) calibration=$BUILD_ID\" >> .edgework/calibration.log && gcloud builds log $BUILD_ID 2>/dev/null | grep -E 'Epoch|KL|Layer|Done' | tail -10"],
  timeout_ms: 30000
})

// ═══════════════════════════════════════════════════════════════════════
// Topology: fork/race/fold pipeline
// ═══════════════════════════════════════════════════════════════════════

(export_rejections)-[:PROCESS]->(fetch_credentials)
(export_rejections)-[:PROCESS]->(upload_script)
(fetch_credentials)-[:PROCESS]->(launch_calibration)
(upload_script)-[:PROCESS]->(launch_calibration)
(launch_calibration)-[:PROCESS { timeout_ms: 1260000 }]->(wait_for_build)
(wait_for_build)-[:PROCESS]->(redeploy_edge)
(redeploy_edge)-[:PROCESS]->(verify_health)
(redeploy_edge)-[:PROCESS]->(verify_inference)
(verify_health)-[:PROCESS]->(log_results)
(verify_inference)-[:PROCESS]->(log_results)
