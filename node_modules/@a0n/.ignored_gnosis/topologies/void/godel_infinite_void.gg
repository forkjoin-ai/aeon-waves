// godel_infinite_void.gg — THM-ARROW-GODEL-CONSCIOUSNESS witness (undecidable = permanent void)
//
// A Godel sentence G asserts its own unprovability. In void walking terms:
// G is a branch that can never be vented (never proven false) and never
// reaches the fold (never proven true). It remains in the void permanently.
// The void has infinite residence time for undecidable propositions.

(system: FormalSystem { theorem: 'THM-ARROW-GODEL-CONSCIOUSNESS', axioms: '5', expressiveness: 'arithmetic' })
(provable_true: Branch { type: 'theorem', content: '2+2=4', void_residence: '0', status: 'folded' })
(provable_false: Branch { type: 'refuted', content: '2+2=5', void_residence: '0', status: 'vented' })
(godel_sentence: Branch { type: 'undecidable', content: 'G: I am not provable', void_residence: 'inf', status: 'permanent-void' })
(continuum_hyp: Branch { type: 'independent', content: 'CH', void_residence: 'inf', status: 'permanent-void' })
(permanence: Invariant { claim: 'undecidable sentences have infinite void residence', permanent_count: '2' })
(result: Result { theorem: 'undecidable-is-permanent-void' })

(system)-[:FORK]->(provable_true | provable_false | godel_sentence | continuum_hyp)
(provable_true)-[:PROCESS { strategy: 'proof-found' }]->(decided_true: Decided)
(provable_false)-[:VENT { condition: 'refutation-found' }]->(decided_false: Decided)
(godel_sentence | continuum_hyp)-[:RACE { expect: 'never-resolves' }]->(permanence)
(permanence)-[:PROCESS { strategy: 'verify-infinite-residence' }]->(result)
(result)-[:MEASURE { reason: 'topology-audit' }]->(godel_infinite_void_gg_trace:Trace)
