// boundary_probe_walk.gg — Boundary Walk Probing

(probe: Test)-[:FORK]->(model_a: Target | model_b: Target)
(model_a | model_b)-[:FOLD { strategy: 'compare-drift' }]->(report: Diff)
(report)-[:TUNNEL { condition: 'bounded-reject' }]->(boundary_probe_walk_gg_trace:Trace)
(report)-[:MEASURE { reason: 'topology-audit' }]->(boundary_probe_walk_gg_trace:Trace)
