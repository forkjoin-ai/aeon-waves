// void_walking_boundary_grows.gg — THM-VOID-BOUNDARY-MEASURABLE witness
//
// An N-way fork produces N-1 boundary cells per step.
// After T steps, the boundary rank = total vented paths.

(step: FoldStep { fork_width: '4', theorem: 'THM-VOID-BOUNDARY-MEASURABLE' })
(path_a: Branch { survives: 'true' })
(path_b: Branch { survives: 'false' })
(path_c: Branch { survives: 'false' })
(path_d: Branch { survives: 'false' })
(boundary: VoidBoundary { cells: '3', step_count: '1' })
(result: Result { theorem: 'boundary-rank-bounded-by-vented' })

(step)-[:FORK]->(path_a | path_b | path_c | path_d)
(path_b)-[:VENT { condition: 'not-selected' }]->(vent_b: VentedPath)
(path_c)-[:VENT { condition: 'not-selected' }]->(vent_c: VentedPath)
(path_d)-[:VENT { condition: 'not-selected' }]->(vent_d: VentedPath)
(path_a)-[:PROCESS { strategy: 'single-survivor' }]->(survivor: Survivor)
(vent_b | vent_c | vent_d)-[:PROCESS]->(boundary)
(boundary)-[:PROCESS]->(result)
(result)-[:MEASURE { reason: 'topology-audit' }]->(void_walking_boundary_grows_gg_trace:Trace)
