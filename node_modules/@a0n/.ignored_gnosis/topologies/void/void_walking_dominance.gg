// void_walking_dominance.gg — THM-VOID-DOMINANCE witness
//
// After T steps with fork width N, void volume = T*(N-1) >= T = active volume.
// The void formalizes the majority of computation history.

(computation: Computation { theorem: 'THM-VOID-DOMINANCE', fork_width: '3', steps: '5' })
(active_set: ActiveSet { volume: '5' })
(void_set: VoidSet { volume: '10' })
(dominance: Invariant { claim: 'void_volume >= active_volume', value: '10 >= 5' })
(result: Result { theorem: 'void-dominates-active' })

(computation)-[:FORK]->(active_set | void_set)
(active_set | void_set)-[:RACE { expect: 'void-larger' }]->(dominance)
(dominance)-[:PROCESS { strategy: 'verify-inequality' }]->(result)
(result)-[:MEASURE { reason: 'topology-audit' }]->(void_walking_dominance_gg_trace:Trace)
