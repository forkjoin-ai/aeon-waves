// monoidal_triangle.gg — THM-MONOIDAL-COHERENCE witness (unit insertion paths agree)
//
// The triangle identity: for objects A and B with unit I, the two ways of
// simplifying (A*I)*B agree: via associator then left-unitor, or via
// right-unitor on the left factor.
// Path 1: (A*I)*B -> A*(I*B) -> A*B  (associator then left-unitor)
// Path 2: (A*I)*B -> A*B             (right-unitor tensor id)

(coherence: MonoidalCoherence { theorem: 'THM-MONOIDAL-COHERENCE', identity: 'triangle' })
(start: TensorProduct { shape: '(A*I)*B', id: 'start' })
(path_1_mid: TensorProduct { shape: 'A*(I*B)', via: 'alpha_A_I_B' })
(path_1_end: TensorProduct { shape: 'A*B', via: 'id_tensor_lambda_B' })
(path_2_end: TensorProduct { shape: 'A*B', via: 'rho_A_tensor_id' })
(agreement: Invariant { claim: 'path_1 == path_2 at A*B', target: 'A*B' })
(result: Result { theorem: 'triangle-identity-holds' })

(coherence)-[:PROCESS]->(start)
(start)-[:FORK]->(path_1_mid | path_2_end)
(path_1_mid)-[:PROCESS]->(path_1_end)
(path_1_end | path_2_end)-[:FOLD { strategy: 'verify-equality' }]->(agreement)
(agreement)-[:PROCESS]->(result)
(result)-[:TUNNEL { condition: 'bounded-reject' }]->(monoidal_triangle_gg_trace:Trace)
(result)-[:MEASURE { reason: 'topology-audit' }]->(monoidal_triangle_gg_trace:Trace)
