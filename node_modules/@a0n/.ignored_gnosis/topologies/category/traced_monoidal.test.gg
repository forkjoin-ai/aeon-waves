// traced_monoidal.test.gg — Native Gnosis witnesses for THM-TRACED-MONOIDAL
//
// These theorem-shaped `.gg` modules cover:
//   - trivial feedback equals identity (vanishing)
//   - swap trace equals identity (yanking)
//   - trace preserves parallel structure (superposing)

(test_suite: TestSuite { name: 'traced-monoidal' })

(vanishing: Verify { module: './traced_vanishing.gg', beta1_max: '5' })
(yanking: Verify { module: './traced_yanking.gg', beta1_max: '5' })
(superposing: Verify { module: './traced_superposing.gg', beta1_max: '5' })

(test_suite)-[:FORK]->(vanishing | yanking | superposing)

(vanishing)-[:RACE { expect: 'safe' }]->(vanishing_result: Result)
(yanking)-[:RACE { expect: 'safe' }]->(yanking_result: Result)
(superposing)-[:RACE { expect: 'safe' }]->(superposing_result: Result)

(vanishing_result | yanking_result | superposing_result)-[:FOLD { strategy: 'all-pass' }]->(verdict: Verdict)
(verdict)-[:TUNNEL { condition: 'bounded-reject' }]->(traced_monoidal_test_gg_trace:Trace)
(verdict)-[:MEASURE { reason: 'topology-audit' }]->(traced_monoidal_test_gg_trace:Trace)
