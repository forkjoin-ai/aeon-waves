// monoidal_coherence.test.gg — Native Gnosis witnesses for THM-MONOIDAL-COHERENCE
//
// These theorem-shaped `.gg` modules cover:
//   - pentagon identity: two associator paths agree
//   - triangle identity: unit insertion paths agree
//   - hexagon identity: braiding commutes with associator

(test_suite: TestSuite { name: 'monoidal-coherence' })

(pentagon: Verify { module: './monoidal_pentagon.gg', beta1_max: '5' })
(triangle: Verify { module: './monoidal_triangle.gg', beta1_max: '5' })
(hexagon: Verify { module: './monoidal_hexagon.gg', beta1_max: '5' })

(test_suite)-[:FORK]->(pentagon | triangle | hexagon)

(pentagon)-[:RACE { expect: 'safe' }]->(pentagon_result: Result)
(triangle)-[:RACE { expect: 'safe' }]->(triangle_result: Result)
(hexagon)-[:RACE { expect: 'safe' }]->(hexagon_result: Result)

(pentagon_result | triangle_result | hexagon_result)-[:FOLD { strategy: 'all-pass' }]->(verdict: Verdict)
(verdict)-[:TUNNEL { condition: 'bounded-reject' }]->(monoidal_coherence_test_gg_trace:Trace)
(verdict)-[:MEASURE { reason: 'topology-audit' }]->(monoidal_coherence_test_gg_trace:Trace)
