// traced_vanishing.gg — THM-TRACED-MONOIDAL witness (trivial feedback = identity)
//
// The vanishing axiom: tracing over the unit object I yields the identity.
// Tr_I(f) = f when the traced dimension is trivial (1-dimensional).
// Feedback through a trivial wire does nothing.

(trace_op: TraceOperator { theorem: 'THM-TRACED-MONOIDAL', axiom: 'vanishing', trace_dim: '1' })
(morphism_f: Morphism { id: 'f', domain: 'A*I', codomain: 'B*I', dim_A: '4', dim_B: '3' })
(trace_result: Morphism { id: 'Tr_I(f)', domain: 'A', codomain: 'B', dim_A: '4', dim_B: '3' })
(identity_f: Morphism { id: 'f_reduced', domain: 'A', codomain: 'B', dim_A: '4', dim_B: '3' })
(vanishing: Invariant { claim: 'Tr_I(f) = f (trivial trace)', traced_dim: '1' })
(result: Result { theorem: 'vanishing-axiom-holds' })

(trace_op)-[:PROCESS]->(morphism_f)
(morphism_f)-[:PROCESS { strategy: 'trace-over-unit' }]->(trace_result)
(morphism_f)-[:PROCESS { strategy: 'strip-unit' }]->(identity_f)
(trace_result | identity_f)-[:RACE { expect: 'morphisms-equal' }]->(vanishing)
(vanishing)-[:PROCESS { strategy: 'verify-equality' }]->(result)
(result)-[:MEASURE { reason: 'topology-audit' }]->(traced_vanishing_gg_trace:Trace)
