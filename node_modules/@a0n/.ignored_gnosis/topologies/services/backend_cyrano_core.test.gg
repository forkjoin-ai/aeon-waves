// backend_cyrano_core.test.gg — Verification harness for backend cyrano core
(test_suite: TestSuite { name: 'backend_cyrano_core' })

(hologram_service: Verify { module: './hologram_service.gg', beta1_max: '6' })
(autonomous_action_engine: Verify { module: './autonomous_action_engine.gg', beta1_max: '6' })
(cyrano_workflow_orchestrator: Verify { module: './cyrano_workflow_orchestrator.gg', beta1_max: '6' })

(test_suite)-[:FORK]->(hologram_service | autonomous_action_engine | cyrano_workflow_orchestrator)

(hologram_service)-[:RACE { expect: 'safe' }]->(hologram_service_res: Result)
(autonomous_action_engine)-[:RACE { expect: 'safe' }]->(autonomous_action_engine_res: Result)
(cyrano_workflow_orchestrator)-[:RACE { expect: 'safe' }]->(cyrano_workflow_orchestrator_res: Result)

(hologram_service_res | autonomous_action_engine_res | cyrano_workflow_orchestrator_res)-[:FOLD { strategy: 'all-pass' }]->(verdict: Verdict)
(verdict)-[:TUNNEL { condition: 'bounded-reject' }]->(backend_cyrano_core_test_gg_trace:Trace)
(verdict)-[:MEASURE { reason: 'topology-audit' }]->(backend_cyrano_core_test_gg_trace:Trace)
