// context_rag_injector.gg — Context Injection

(prompt: Text)-[:FORK]->(fetch_history: RAG | fetch_profile: DB)
(fetch_history | fetch_profile)-[:FOLD { strategy: 'concat' }]->(enriched_prompt: Text)
(enriched_prompt)-[:TUNNEL { condition: 'bounded-reject' }]->(context_rag_injector_gg_trace:Trace)
(enriched_prompt)-[:MEASURE { reason: 'topology-audit' }]->(context_rag_injector_gg_trace:Trace)
