// backend_account_management.test.gg — Verification harness for backend account management
(test_suite: TestSuite { name: 'backend_account_management' })

(account_link_service: Verify { module: './account_link_service.gg', beta1_max: '6' })
(digital_twin_access_service: Verify { module: './digital_twin_access_service.gg', beta1_max: '6' })
(permission_audit_log: Verify { module: './permission_audit_log.gg', beta1_max: '6' })

(test_suite)-[:FORK]->(account_link_service | digital_twin_access_service | permission_audit_log)

(account_link_service)-[:RACE { expect: 'safe' }]->(account_link_service_res: Result)
(digital_twin_access_service)-[:RACE { expect: 'safe' }]->(digital_twin_access_service_res: Result)
(permission_audit_log)-[:RACE { expect: 'safe' }]->(permission_audit_log_res: Result)

(account_link_service_res | digital_twin_access_service_res | permission_audit_log_res)-[:FOLD { strategy: 'all-pass' }]->(verdict: Verdict)
(verdict)-[:TUNNEL { condition: 'bounded-reject' }]->(backend_account_management_test_gg_trace:Trace)
(verdict)-[:MEASURE { reason: 'topology-audit' }]->(backend_account_management_test_gg_trace:Trace)
