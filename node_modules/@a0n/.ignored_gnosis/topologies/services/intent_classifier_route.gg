// intent_classifier_route.gg — Intent Routing

(user_msg: Text)-[:PROCESS]->(classifier: LLM)-[:FORK]->(tool_a: Action | tool_b: Action | fallback: Action)
(tool_a | tool_b | fallback)-[:RACE { expect: 'highest-confidence' }]->(execution: Route)
(execution)-[:MEASURE { reason: 'topology-audit' }]->(intent_classifier_route_gg_trace:Trace)
