// crdt_sync_conflict.gg — CRDT synchronization and conflict resolution

(sync_event: Trigger)-[:FORK]->(apply_local: State | merge_remote: State)
(apply_local | merge_remote)-[:FOLD { strategy: 'lww' }]->(converged: State)
(converged)-[:TUNNEL { condition: 'bounded-reject' }]->(crdt_sync_conflict_gg_trace:Trace)
(converged)-[:MEASURE { reason: 'topology-audit' }]->(crdt_sync_conflict_gg_trace:Trace)
