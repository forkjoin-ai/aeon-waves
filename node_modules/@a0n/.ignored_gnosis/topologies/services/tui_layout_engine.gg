// tui_layout_engine.gg — TUI Layout engine recalculation

(resize: Event)-[:FORK]->(calc_sidebar: Layout | calc_main: Layout)
(calc_sidebar | calc_main)-[:FOLD { strategy: 'merge-rects' }]->(screen: View)
(screen)-[:TUNNEL { condition: 'bounded-reject' }]->(tui_layout_engine_gg_trace:Trace)
(screen)-[:MEASURE { reason: 'topology-audit' }]->(tui_layout_engine_gg_trace:Trace)
