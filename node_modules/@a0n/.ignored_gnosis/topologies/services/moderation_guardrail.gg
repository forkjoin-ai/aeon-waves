// moderation_guardrail.gg — Moderation Shield

(output: Text)-[:FORK]->(pii_check: Guard | toxicity_check: Guard)
(pii_check | toxicity_check)-[:FOLD { strategy: 'all-pass' }]->(safe_output: Text)
(safe_output)-[:TUNNEL { condition: 'bounded-reject' }]->(moderation_guardrail_gg_trace:Trace)
(safe_output)-[:MEASURE { reason: 'topology-audit' }]->(moderation_guardrail_gg_trace:Trace)
