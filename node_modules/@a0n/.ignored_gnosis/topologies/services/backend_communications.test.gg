// backend_communications.test.gg — Verification harness for backend communications
(test_suite: TestSuite { name: 'backend_communications' })

(email_service: Verify { module: './email_service.gg', beta1_max: '6' })
(sms_service: Verify { module: './sms_service.gg', beta1_max: '6' })

(test_suite)-[:FORK]->(email_service | sms_service)

(email_service)-[:RACE { expect: 'safe' }]->(email_service_res: Result)
(sms_service)-[:RACE { expect: 'safe' }]->(sms_service_res: Result)

(email_service_res | sms_service_res)-[:FOLD { strategy: 'all-pass' }]->(verdict: Verdict)
(verdict)-[:TUNNEL { condition: 'bounded-reject' }]->(backend_communications_test_gg_trace:Trace)
(verdict)-[:MEASURE { reason: 'topology-audit' }]->(backend_communications_test_gg_trace:Trace)
