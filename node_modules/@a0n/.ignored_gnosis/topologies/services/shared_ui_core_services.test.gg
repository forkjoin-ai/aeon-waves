// shared_ui_core_services.test.gg — Verification harness for shared ui core services
(test_suite: TestSuite { name: 'shared_ui_core_services' })

(core_entrainment_engine: Verify { module: './core_entrainment_engine.gg', beta1_max: '6' })
(core_hume_unified: Verify { module: './core_hume_unified.gg', beta1_max: '6' })
(core_generative_ui: Verify { module: './core_generative_ui.gg', beta1_max: '6' })
(core_zk_encryption: Verify { module: './core_zk_encryption.gg', beta1_max: '6' })

(test_suite)-[:FORK]->(core_entrainment_engine | core_hume_unified | core_generative_ui | core_zk_encryption)

(core_entrainment_engine)-[:RACE { expect: 'safe' }]->(core_entrainment_engine_res: Result)
(core_hume_unified)-[:RACE { expect: 'safe' }]->(core_hume_unified_res: Result)
(core_generative_ui)-[:RACE { expect: 'safe' }]->(core_generative_ui_res: Result)
(core_zk_encryption)-[:RACE { expect: 'safe' }]->(core_zk_encryption_res: Result)

(core_entrainment_engine_res | core_hume_unified_res | core_generative_ui_res | core_zk_encryption_res)-[:FOLD { strategy: 'all-pass' }]->(verdict: Verdict)
(verdict)-[:TUNNEL { condition: 'bounded-reject' }]->(shared_ui_core_services_test_gg_trace:Trace)
(verdict)-[:MEASURE { reason: 'topology-audit' }]->(shared_ui_core_services_test_gg_trace:Trace)
