// model_weight_fetcher.gg — Model Zoo Weight Fetch

(request_model: Intent)-[:FORK]->(local_cache: FS | huggingface: API | r2_bucket: Storage)
(local_cache | huggingface | r2_bucket)-[:RACE { expect: 'first-chunk' }]->(weights: Tensor)
(weights)-[:MEASURE { reason: 'topology-audit' }]->(model_weight_fetcher_gg_trace:Trace)
