// ucan_revocation_gossip.gg — UCAN Revocation Propagation

(revoke: Cmd)-[:FORK]->(edge_a: Cache | edge_b: Cache)
(edge_a | edge_b)-[:FOLD { strategy: 'gossip-sync' }]->(global_ban: List)
(global_ban)-[:TUNNEL { condition: 'bounded-reject' }]->(ucan_revocation_gossip_gg_trace:Trace)
(global_ban)-[:MEASURE { reason: 'topology-audit' }]->(ucan_revocation_gossip_gg_trace:Trace)
