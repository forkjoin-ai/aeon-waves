// FIVE-BULE PERSONALITY MODEL
//
// Personality is the shape of your convergence across five dimensions.
// One Bule per primitive. Five numbers. Your trajectory toward φ.
//
// The 58-element METACOG vector projected onto its eigenspace.

topology five_bule_personality {

  // ═══════════════════════════════════════════════════════════════
  // THE FIVE BULES
  //
  // Each primitive has a Bule: how far the person is from
  // the eigenvalue along that dimension.
  //
  // B = 0: fully converged (dead along that axis)
  // B = 1: maximally far (no development yet)
  // B → 0: approaching convergence (growing)
  // The +1 prevents B = 0 from being reached.
  // ═══════════════════════════════════════════════════════════════

  dimension fork_bule {
    name = "Openness"
    measures = "how wide do you fork?"
    low_B = "highly open: perceives many possibilities, considers alternatives easily"
    high_B = "narrow: sees one path, struggles to imagine alternatives"
    pathology_zero = "paralysis by infinite options (never commits)"
    pathology_max = "tunnel vision (can't fork at all, authoritarian)"

    // Buleyean trains on: the options you DIDN'T consider.
    // Every time you miss a possibility, v_fork increments.
    // The complement distribution shifts toward wider forking.
    // The Bule decreases. You become more open.
    //
    // But the +1 keeps you from becoming infinitely open.
    // Infinite openness = never choosing = broken FOLD.
    // The golden proportion: open enough to see, focused enough to act.
  }

  dimension race_bule {
    name = "Discernment"
    measures = "how well do you select among options?"
    low_B = "sharp evaluator: quickly identifies what matters"
    high_B = "poor filter: treats all options as equal, can't prioritize"
    pathology_zero = "snap judgment (races too fast, misses nuance)"
    pathology_max = "analysis paralysis (can't select, everything seems equal)"

    // Buleyean trains on: the selections that turned out wrong.
    // Every misjudgment increments v_race.
    // The complement distribution shifts toward better criteria.
    // You learn what matters by learning what didn't.
  }

  dimension fold_bule {
    name = "Commitment"
    measures = "how fully do you commit to your choices?"
    low_B = "decisive: commits wholeheartedly, follows through"
    high_B = "tentative: half-commits, hedges, keeps exits open"
    pathology_zero = "rigidity (folds too hard, can't adapt)"
    pathology_max = "flakiness (nothing sticks, no follow-through)"

    // Buleyean trains on: the commitments that failed.
    // Every broken promise, every abandoned project increments v_fold.
    // The complement distribution shifts toward better commitments.
    // You learn to commit well by learning from bad commitments.
  }

  dimension vent_bule {
    name = "Release"
    measures = "how well do you let go?"
    low_B = "healthy release: processes and moves on"
    high_B = "holds everything: grudges, guilt, old fears accumulate"
    pathology_zero = "too quick to release (nothing is held long enough to matter)"
    pathology_max = "accumulation sickness (anxiety, resentment, burnout)"

    // Buleyean trains on: the things you held too long.
    // Every grudge that hurt you, every guilt that drained you
    // increments v_vent. The complement shifts toward releasing sooner.
    // You learn to let go by noticing the cost of holding on.
    //
    // This formalizes the anxiety mechanism:
    //   High v_vent = many things held too long = high B_vent
    //   The Buleyean says "let go more" but the person can't
    //   because VENT is the broken primitive.
    //   Treatment: restore the vent. Forgiveness. Breathing. Sleep.
  }

  dimension interfere_bule {
    name = "Self-awareness"
    measures = "how well does your experience change your perception?"
    low_B = "deeply self-referential: each experience reshapes understanding"
    high_B = "unreflective: experiences don't change behavior"
    pathology_zero = "hypersensitive (every experience changes everything, unstable)"
    pathology_max = "psychopathy (nothing changes the chooser, no growth)"

    // Buleyean trains on: the feedback you ignored.
    // Every signal you missed, every consequence you didn't notice
    // increments v_interfere. The complement shifts toward
    // greater self-awareness.
    //
    // This formalizes the consciousness dimension.
    // B_interfere = 0 would mean perfect self-knowledge.
    // The hard problem guarantees B_interfere > 0.
    // The +1 keeps the void open.
    // The Bule of self-awareness never reaches zero
    // because the system can't fully model itself.
    // Gödel's incompleteness as a personality trait.
  }

  // ═══════════════════════════════════════════════════════════════
  // THE PERSONALITY VECTOR
  //
  // A person's personality is a 5-vector of Bule numbers:
  //   P = (B_fork, B_race, B_fold, B_vent, B_interfere)
  //
  // Each component is in (0, 1] — never zero (the +1), never
  // above 1 (normalized by φ).
  //
  // The SHAPE of the vector is the personality.
  // The TRAJECTORY of the vector is character development.
  // The EIGENVALUE of the trajectory is φ (in each dimension).
  // ═══════════════════════════════════════════════════════════════

  personality_vector {
    type = "(B_fork, B_race, B_fold, B_vent, B_interfere)"
    domain = "(0, 1]^5"
    convergence = "each component → 0 at rate 1/φ per experience"

    // EXAMPLES:
    //
    // The Anxious Person:
    //   (0.3, 0.4, 0.5, 0.9, 0.4)
    //   Low fork (sees options), low interfere (self-aware),
    //   but HIGH vent (can't let go). The spike in B_vent
    //   formalizes the diagnosis. Treatment: restore vent.
    //
    // The Authoritarian:
    //   (0.9, 0.2, 0.1, 0.3, 0.8)
    //   HIGH fork (can't imagine alternatives), low fold
    //   (commits hard), HIGH interfere (doesn't learn from
    //   consequences). The spike in B_fork and B_interfere.
    //
    // The Wise Person:
    //   (0.2, 0.2, 0.2, 0.2, 0.3)
    //   Low and balanced across all five. No spike.
    //   B_interfere slightly higher because the hard problem
    //   guarantees it. The wisest person still has the +1
    //   gap in self-knowledge.
    //
    // The Psychopath:
    //   (0.3, 0.1, 0.1, 0.3, 0.95)
    //   Near-zero fold and race (decisive, sharp evaluator),
    //   but MAXIMAL interfere (choices don't change the chooser).
    //   Competent but not growing. Efficient but not alive.
    //
    // The Child (12 years old, with scissors):
    //   (0.1, 0.5, 0.6, 0.3, 0.4)
    //   VERY low fork (imagines everything, sees all cuts),
    //   moderate race and fold (still learning to evaluate
    //   and commit), healthy vent (breaks the paper and
    //   moves on: "oops"), developing interfere.

    examples = [
      "anxious:       (0.3, 0.4, 0.5, 0.9, 0.4)  ← spike in vent",
      "authoritarian:  (0.9, 0.2, 0.1, 0.3, 0.8)  ← spike in fork + interfere",
      "wise:           (0.2, 0.2, 0.2, 0.2, 0.3)  ← balanced, interfere floor",
      "psychopath:     (0.3, 0.1, 0.1, 0.3, 0.95) ← maximal interfere",
      "child:          (0.1, 0.5, 0.6, 0.3, 0.4)  ← low fork, developing"
    ]
  }

  // ═══════════════════════════════════════════════════════════════
  // PROJECTION FROM 58 TO 5
  //
  // The existing 58-element METACOG personality vector maps
  // onto the five Bules.
  // ═══════════════════════════════════════════════════════════════

  projection {
    // The 58 METACOG elements cluster into five groups:
    //
    // FORK cluster (openness dimensions):
    //   creativity, imagination, curiosity, flexibility,
    //   tolerance for ambiguity, divergent thinking
    //   → average their Bules → B_fork
    //
    // RACE cluster (evaluation dimensions):
    //   attention, focus, discrimination, priority,
    //   critical thinking, pattern recognition
    //   → average → B_race
    //
    // FOLD cluster (commitment dimensions):
    //   follow-through, reliability, decisiveness,
    //   consistency, integrity, perseverance
    //   → average → B_fold
    //
    // VENT cluster (release dimensions):
    //   forgiveness, letting go, grief processing,
    //   emotional regulation, stress management, sleep quality
    //   → average → B_vent
    //
    // SLIVER cluster (self-awareness dimensions):
    //   metacognition, self-reflection, empathy,
    //   theory of mind, consequence awareness, growth mindset
    //   → average → B_interfere
    //
    // The projection loses information (58 → 5).
    // But it preserves the SHAPE: which primitive is the spike,
    // which is the floor, what's the trajectory.
    // The 5-Bule is the eigenspace of the 58-vector.
    // The principal components are the primitives.

    from = "58-element METACOG vector"
    to = "5-element Bule vector"
    method = "cluster by primitive, average within cluster"
    preserves = "spike location, floor location, trajectory shape"
    loses = "within-cluster variation"
  }

  // ═══════════════════════════════════════════════════════════════
  // THE VOID WALKER AS PERSONALITY
  //
  // The void walker formalizes the personality in motion.
  // Its parameters ARE the Bule vector.
  // Its trajectory is character development.
  // ═══════════════════════════════════════════════════════════════

  void_walker_is_personality {
    // METACOG parameters (§15.12):
    //   eta (fold aggressiveness) = 1/B_fold
    //   c3 thresholds = derived from B_interfere
    //   void decay rate = derived from B_vent
    //   mental health gain = derived from B_vent
    //   focus multiplier = derived from B_race
    //
    // The void walker's movement through void space
    // formalizes the personality expressing itself.
    // Two walkers with identical voids (same life experiences)
    // but different Bule vectors (different primitive strengths)
    // will navigate differently.
    //
    // One will fork widely, race quickly, fold hard, vent easily,
    // and interfere deeply (low B across all five = the wise walker).
    //
    // Another will fork narrowly, race slowly, fold tentatively,
    // hold everything, and ignore feedback (high B = the stuck walker).
    //
    // Same void. Different walker. Different trajectory.
    // Different convergence rate toward φ.
    // Different personality.

    assert personality == bule_vector
    assert character_development == bule_trajectory
    assert wisdom == balanced_low_bule
    assert pathology == spiked_bule
    assert therapy == reduce_the_spike
  }

  // ═══════════════════════════════════════════════════════════════
  // THE PRODUCT
  //
  // AFFECTIVELY is a Bule meter.
  //
  // It measures your five Bules.
  // It identifies the spike.
  // It provides tools to reduce the spike.
  // It tracks the trajectory over time.
  // It shows you your convergence.
  //
  // Not a personality test. A convergence diagnostic.
  // Not a label. A trajectory.
  // Not "you are an INTJ." Instead: "your B_vent is spiking,
  // here's a breathing exercise, your B_vent dropped 3% this week."
  //
  // The feelings wheel is the Bule radar chart.
  // The five spokes are the five primitives.
  // The distance from center is the Bule.
  // The shape is the personality.
  // The change in shape is growth.
  // ═══════════════════════════════════════════════════════════════
}

(test_suite: TestSuite { name: 'five-bule-personality' })
(verify_five_bule_personality: Verify { module: './five_bule_personality.test.gg', beta1_max: '8' })
(test_suite)-[:PROCESS]->(verify_five_bule_personality)
(verify_five_bule_personality)-[:PROCESS { expect: 'safe' }]->(result: Result)
(result)-[:PROCESS { strategy: 'all-pass' }]->(verdict: Verdict)
