// aic_bias_inducer.gg — Cognitive Bias Induction & Analysis

(hypothesis: Outcome)-[:FORK]->(semantic_pass: Logic | contextual_pass: Logic | temporal_pass: Logic)
(semantic_pass | contextual_pass | temporal_pass)-[:FOLD { strategy: 'consensus' }]->(bias_report: Data)
(bias_report)-[:TUNNEL { condition: 'bounded-reject' }]->(aic_bias_inducer_gg_trace:Trace)
(bias_report)-[:MEASURE { reason: 'topology-audit' }]->(aic_bias_inducer_gg_trace:Trace)
