// shared_ui_aic.test.gg — Verification harness for shared ui aic
(test_suite: TestSuite { name: 'shared_ui_aic' })

(aic_fusion_engine: Verify { module: './aic_fusion_engine.gg', beta1_max: '6' })
(aic_reasoning_engine: Verify { module: './aic_reasoning_engine.gg', beta1_max: '6' })
(aic_bias_inducer: Verify { module: './aic_bias_inducer.gg', beta1_max: '6' })
(aic_emotional_trigger: Verify { module: './aic_emotional_trigger.gg', beta1_max: '6' })

(test_suite)-[:FORK]->(aic_fusion_engine | aic_reasoning_engine | aic_bias_inducer | aic_emotional_trigger)

(aic_fusion_engine)-[:RACE { expect: 'safe' }]->(aic_fusion_engine_res: Result)
(aic_reasoning_engine)-[:RACE { expect: 'safe' }]->(aic_reasoning_engine_res: Result)
(aic_bias_inducer)-[:RACE { expect: 'safe' }]->(aic_bias_inducer_res: Result)
(aic_emotional_trigger)-[:RACE { expect: 'safe' }]->(aic_emotional_trigger_res: Result)

(aic_fusion_engine_res | aic_reasoning_engine_res | aic_bias_inducer_res | aic_emotional_trigger_res)-[:FOLD { strategy: 'all-pass' }]->(verdict: Verdict)
(verdict)-[:TUNNEL { condition: 'bounded-reject' }]->(shared_ui_aic_test_gg_trace:Trace)
(verdict)-[:MEASURE { reason: 'topology-audit' }]->(shared_ui_aic_test_gg_trace:Trace)
