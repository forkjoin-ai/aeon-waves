// background_daemon_telemetry.gg — Background Daemon Telemetry

(tick: Timer)-[:FORK]->(cpu_stat: Metric | mem_stat: Metric)
(cpu_stat | mem_stat)-[:FOLD { strategy: 'batch' }]->(log_sink: Storage)
(log_sink)-[:TUNNEL { condition: 'bounded-reject' }]->(background_daemon_telemetry_gg_trace:Trace)
(log_sink)-[:MEASURE { reason: 'topology-audit' }]->(background_daemon_telemetry_gg_trace:Trace)
