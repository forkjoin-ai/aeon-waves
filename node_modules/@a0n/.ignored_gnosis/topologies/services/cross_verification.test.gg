// cross_verification.test.gg — Cross-verification: proof + test catch what neither catches alone
//
// Discovered during void relativity hardening (NegotiationEquilibrium.lean):
// a Lean theorem "time_dilation = 2x WATNA shift" was provably correct via omega
// but semantically vacuous -- the hypotheses forced the interesting quantity to zero,
// making 0 = 2*0 trivially true. The proof assistant verified logical validity.
// Executable tests caught that the theorem was contentless.
//
// This topology encodes the cross-verification pattern as a GG primitive:
// FORK a property into both a logical check (proof) and a semantic check (test),
// RACE both checks, FOLD the results, and VENT properties that are
// sound-but-vacuous -- logically valid but semantically empty.
//
// The pattern: proof guarantees implication. Test guarantees content.
// Neither alone suffices. Both together catch vacuous truth.

(suite: TestSuite { name: 'cross_verification' })

// --- Phase 1: Fork into proof channel and test channel ---
// Each property gets checked twice: once for logical validity, once for semantic content.

(property: Property { name: 'target_property' })

(property)-[:FORK]->(proof_check: ProofCheck { kind: 'logical_validity', engine: 'aeon-logic' } | test_check: TestCheck { kind: 'semantic_content', engine: 'executable' })

// --- Phase 2: Race both checks ---
// The proof check verifies the invariant holds in all reachable states.
// The test check verifies the invariant has non-trivial semantic content
// (the predicate is exercised on interesting states, not vacuously satisfied).

(proof_check)-[:RACE { expect: 'invariant_holds' }]->(proof_result: CheckResult { field: 'logicalValidity' })
(test_check)-[:RACE { expect: 'content_positive' }]->(test_result: CheckResult { field: 'semanticContent' })

// --- Phase 3: Fold into cross-verification verdict ---
// Four possible outcomes:
//   sound-and-substantive:  proof passes, test passes  (best case)
//   sound-but-vacuous:      proof passes, test fails   (the bug we found)
//   violated:               proof fails                (standard bug)
//   indeterminate:          test inconclusive           (need more states)

(proof_result | test_result)-[:FOLD { strategy: 'cross-verify' }]->(verdict: CrossVerdict)

// --- Phase 4: Vent vacuous properties ---
// Properties that are sound-but-vacuous get vented with a diagnostic.
// They are not wrong -- they are empty. The vent carries the diagnosis.

(verdict)-[:VENT { condition: 'verdict.kind == sound-but-vacuous', diagnostic: 'vacuity_report' }]->(vacuous_log: VacuityLog)

// --- Test cases ---

// Case 1: A substantive property (should pass cross-verification)
(substantive: Property { name: 'interval_invariance', description: 'total vent count is frame-invariant' })
(substantive)-[:FORK]->(sub_proof: ProofCheck { kind: 'logical_validity' } | sub_test: TestCheck { kind: 'semantic_content' })
(sub_proof)-[:RACE { expect: 'invariant_holds' }]->(sub_proof_res: CheckResult)
(sub_test)-[:RACE { expect: 'content_positive' }]->(sub_test_res: CheckResult)
(sub_proof_res | sub_test_res)-[:FOLD { strategy: 'cross-verify' }]->(sub_verdict: CrossVerdict { expect: 'sound-and-substantive' })

// Case 2: A vacuous property (should be vented)
(vacuous: Property { name: 'time_dilation_2x', description: '0 = 2*0 is trivially true' })
(vacuous)-[:FORK]->(vac_proof: ProofCheck { kind: 'logical_validity' } | vac_test: TestCheck { kind: 'semantic_content' })
(vac_proof)-[:RACE { expect: 'invariant_holds' }]->(vac_proof_res: CheckResult)
(vac_test)-[:RACE { expect: 'content_zero' }]->(vac_test_res: CheckResult)
(vac_proof_res | vac_test_res)-[:FOLD { strategy: 'cross-verify' }]->(vac_verdict: CrossVerdict { expect: 'sound-but-vacuous' })
(vac_verdict)-[:VENT { condition: 'always', diagnostic: 'vacuity: hypotheses force WATNA shift to zero' }]->(vac_log: VacuityLog)

// Case 3: A corrected property (substantive replacement for the vacuous one)
(corrected: Property { name: 'score_lorentz_scalar', description: 'settlement score is frame-invariant' })
(corrected)-[:FORK]->(cor_proof: ProofCheck { kind: 'logical_validity' } | cor_test: TestCheck { kind: 'semantic_content' })
(cor_proof)-[:RACE { expect: 'invariant_holds' }]->(cor_proof_res: CheckResult)
(cor_test)-[:RACE { expect: 'content_positive' }]->(cor_test_res: CheckResult)
(cor_proof_res | cor_test_res)-[:FOLD { strategy: 'cross-verify' }]->(cor_verdict: CrossVerdict { expect: 'sound-and-substantive' })

// --- Fold all verdicts ---
(suite)-[:FORK]->(substantive | vacuous | corrected)
(sub_verdict | vac_verdict | cor_verdict)-[:FOLD { strategy: 'all-diagnosed' }]->(final: Verdict)
(final)-[:MEASURE { reason: 'topology-audit' }]->(cross_verification_test_gg_trace:Trace)
