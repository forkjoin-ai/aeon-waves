// forge_build_pipeline.gg — Aeon Forge Build Pipeline

(source: Source)-[:FORK]->(lint: Check | test: Check)
(lint | test)-[:FOLD { strategy: 'all-pass' }]->(artifact: Binary)
(artifact)-[:TUNNEL { condition: 'bounded-reject' }]->(forge_build_pipeline_gg_trace:Trace)
(artifact)-[:MEASURE { reason: 'topology-audit' }]->(forge_build_pipeline_gg_trace:Trace)
