// esi_resolution.gg — Edge Side Includes resolution and stitching

(req: Request)-[:FORK]->(frag_header: Fragment | frag_body: Fragment)
(frag_header | frag_body)-[:FOLD { strategy: 'stitch' }]->(page: RenderedPage)
(page)-[:TUNNEL { condition: 'bounded-reject' }]->(esi_resolution_gg_trace:Trace)
(page)-[:MEASURE { reason: 'topology-audit' }]->(esi_resolution_gg_trace:Trace)
