// Gnosis Isolation Runner for AFFECTIVELY
//
// Optimized covering space pipeline for test isolation.
//
// (discovery) -> FORK -> (execution) -> FOLD -> (verification) -> VENT

// 1. Discovery: Identify all test files
(discovery:System { 
    root: ".", 
    include: "**/*.test.ts",
    exclude: ["node_modules", "dist"] 
})

// 2. Parallel Isolation: Fork paths for each test file
// Uses Gnosis superposition to run tests in separate covering spaces.
(discovery)-[:PROCESS { 
    strategy: "isolation", 
    limit: 8,
    mode: "process" 
}]->(test_path:IsolatedPath)

// 3. Execution: Run Bun tests
(test_path)-[:PROCESS { 
    runner: "bun", 
    command: "test",
    preload: "./bun.preload.ts" 
}]->(raw_outcome:Outcome)

// 4. Aggregation: Fold results back into a singular state
(raw_outcome)-[:PROCESS { strategy: "sum" }]->(total_summary:Summary)

// 5. Formal Verification: Aeon Logic Invariant Check
// Invariant: Betti number must return to zero, proving no state leak (pollution).
(total_summary)-[:PROCESS { 
    plugin: "aeon-logic", 
    spec: "tests/specs/IsolationInvariant.tla",
    invariant: "IsolationInvariant"
}]->(verified_state:FinalState)

// 6. Report: Output the verified results
(verified_state)-[:VENT { condition: 'bounded-reject' }]->(exit:SystemExit)
(exit)-[:MEASURE { reason: 'topology-audit' }]->(isolation_tests_gg_trace:Trace)
