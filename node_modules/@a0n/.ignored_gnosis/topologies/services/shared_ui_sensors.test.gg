// shared_ui_sensors.test.gg — Verification harness for shared ui sensors
(test_suite: TestSuite { name: 'shared_ui_sensors' })

(sensor_context_intelligence: Verify { module: './sensor_context_intelligence.gg', beta1_max: '6' })
(sensor_ambient_light: Verify { module: './sensor_ambient_light.gg', beta1_max: '6' })
(sensor_digital_phenotyping: Verify { module: './sensor_digital_phenotyping.gg', beta1_max: '6' })
(sensor_morphcast_mapper: Verify { module: './sensor_morphcast_mapper.gg', beta1_max: '6' })

(test_suite)-[:FORK]->(sensor_context_intelligence | sensor_ambient_light | sensor_digital_phenotyping | sensor_morphcast_mapper)

(sensor_context_intelligence)-[:RACE { expect: 'safe' }]->(sensor_context_intelligence_res: Result)
(sensor_ambient_light)-[:RACE { expect: 'safe' }]->(sensor_ambient_light_res: Result)
(sensor_digital_phenotyping)-[:RACE { expect: 'safe' }]->(sensor_digital_phenotyping_res: Result)
(sensor_morphcast_mapper)-[:RACE { expect: 'safe' }]->(sensor_morphcast_mapper_res: Result)

(sensor_context_intelligence_res | sensor_ambient_light_res | sensor_digital_phenotyping_res | sensor_morphcast_mapper_res)-[:FOLD { strategy: 'all-pass' }]->(verdict: Verdict)
(verdict)-[:TUNNEL { condition: 'bounded-reject' }]->(shared_ui_sensors_test_gg_trace:Trace)
(verdict)-[:MEASURE { reason: 'topology-audit' }]->(shared_ui_sensors_test_gg_trace:Trace)
