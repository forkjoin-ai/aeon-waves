// skyrms_mediation_progress.gg — THM-SKYRMS-NADIR-BULE witness (each round reduces Bule by 1)
//
// In three-walker Skyrms mediation, each successful mediation round
// reduces the Bule measure by exactly 1. After D rounds (where D is
// the initial deficit), Bule reaches 0.

(mediation: SkyrmsMediation { theorem: 'THM-SKYRMS-NADIR-BULE', initial_bule: '4', rounds: '4' })
(round_0: MediationState { round: '0', bule: '4' })
(round_1: MediationState { round: '1', bule: '3' })
(round_2: MediationState { round: '2', bule: '2' })
(round_3: MediationState { round: '3', bule: '1' })
(round_4: MediationState { round: '4', bule: '0' })
(progress: Invariant { claim: 'Bule decreases by 1 per round', sequence: '[4, 3, 2, 1, 0]', step_size: '1' })
(result: Result { theorem: 'mediation-reduces-bule' })

(mediation)-[:PROCESS]->(round_0)
(round_0)-[:PROCESS]->(round_1)
(round_1)-[:PROCESS]->(round_2)
(round_2)-[:PROCESS]->(round_3)
(round_3)-[:PROCESS]->(round_4)
(round_0 | round_1 | round_2 | round_3 | round_4)-[:RACE { expect: 'bule-decreasing' }]->(progress)
(progress)-[:PROCESS { strategy: 'verify-unit-step' }]->(result)
(result)-[:MEASURE { reason: 'topology-audit' }]->(skyrms_mediation_progress_gg_trace:Trace)
