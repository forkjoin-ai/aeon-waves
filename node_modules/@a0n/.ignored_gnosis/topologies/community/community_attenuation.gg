// community_attenuation.gg — THM-COMMUNITY-DOMINANCE witness (context reduces deficit monotonically)
//
// Adding shared context C to a semiotic channel with deficit D produces
// deficit D' <= D. Each unit of context attenuates the deficit.
// Example: 5 paths over 3 streams, deficit = 2. Add 1 context -> deficit = 1.

(channel: SemioticChannel { theorem: 'THM-COMMUNITY-DOMINANCE', paths: '5', streams: '3', deficit: '2' })
(context_0: ContextLevel { shared_context: '0', deficit: '2' })
(context_1: ContextLevel { shared_context: '1', deficit: '1' })
(context_2: ContextLevel { shared_context: '2', deficit: '0' })
(monotone: Invariant { claim: 'deficit monotonically decreasing', sequence: '[2, 1, 0]' })
(result: Result { theorem: 'context-reduces-deficit-monotonically' })

(channel)-[:FORK]->(context_0 | context_1 | context_2)
(context_0)-[:PROCESS]->(context_1)
(context_1)-[:PROCESS]->(context_2)
(context_0 | context_1 | context_2)-[:RACE { expect: 'monotone-decreasing' }]->(monotone)
(monotone)-[:PROCESS { strategy: 'verify-monotone' }]->(result)
(result)-[:MEASURE { reason: 'topology-audit' }]->(community_attenuation_gg_trace:Trace)
