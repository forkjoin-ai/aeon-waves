// skyrms_nadir_algebraic.gg — THM-SKYRMS-NADIR-BULE witness (nadir = A + B - 1)
//
// In Skyrms signaling, two agents A and B with strategy counts |A| and |B|
// have a nadir (worst-case mutual information) at dimension A + B - 1.
// Example: |A| = 4, |B| = 3, nadir = 4 + 3 - 1 = 6.

(game: SkyrmsGame { theorem: 'THM-SKYRMS-NADIR-BULE', agent_a_strategies: '4', agent_b_strategies: '3' })
(agent_a: Agent { id: 'A', strategy_count: '4' })
(agent_b: Agent { id: 'B', strategy_count: '3' })
(nadir: NadirPoint { value: '6', formula: 'A + B - 1', a: '4', b: '3' })
(algebraic: Invariant { claim: 'nadir = A + B - 1 = 6', computed: '6', expected: '6' })
(result: Result { theorem: 'nadir-algebraic-identity' })

(game)-[:FORK]->(agent_a | agent_b)
(agent_a | agent_b)-[:FOLD { strategy: 'compute-nadir' }]->(nadir)
(nadir)-[:PROCESS { expect: 'nadir-computed' }]->(algebraic)
(algebraic)-[:PROCESS { strategy: 'verify-equality' }]->(result)
(result)-[:TUNNEL { condition: 'bounded-reject' }]->(skyrms_nadir_algebraic_gg_trace:Trace)
(result)-[:MEASURE { reason: 'topology-audit' }]->(skyrms_nadir_algebraic_gg_trace:Trace)
