// skyrms_nadir_bule.test.gg — Native Gnosis witnesses for THM-SKYRMS-NADIR-BULE
//
// These theorem-shaped `.gg` modules cover:
//   - nadir point equals A + B - 1 (algebraic)
//   - Bule equals 0 at the nadir (zero at nadir)
//   - each mediation round reduces Bule by 1 (progress)

(test_suite: TestSuite { name: 'skyrms-nadir-bule' })

(algebraic: Verify { module: './skyrms_nadir_algebraic.gg', beta1_max: '6' })
(bule_zero: Verify { module: './skyrms_bule_zero_at_nadir.gg', beta1_max: '6' })
(mediation_progress: Verify { module: './skyrms_mediation_progress.gg', beta1_max: '6' })

(test_suite)-[:FORK]->(algebraic | bule_zero | mediation_progress)

(algebraic)-[:RACE { expect: 'safe' }]->(algebraic_result: Result)
(bule_zero)-[:RACE { expect: 'safe' }]->(bule_zero_result: Result)
(mediation_progress)-[:RACE { expect: 'safe' }]->(progress_result: Result)

(algebraic_result | bule_zero_result | progress_result)-[:FOLD { strategy: 'all-pass' }]->(verdict: Verdict)
(verdict)-[:TUNNEL { condition: 'bounded-reject' }]->(skyrms_nadir_bule_test_gg_trace:Trace)
(verdict)-[:MEASURE { reason: 'topology-audit' }]->(skyrms_nadir_bule_test_gg_trace:Trace)
