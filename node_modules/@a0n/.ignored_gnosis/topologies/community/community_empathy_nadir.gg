// community_empathy_nadir.gg — THM-COMMUNITY-COMPOSITIONS witness (shared experience reduces nadir)
//
// When two agents share an experience, the nadir (worst-case deficit)
// of the composed community is strictly less than either individual nadir.
// Shared context attenuates the void floor.
// Example: agent A nadir=5, agent B nadir=4, shared experience=2 -> composed nadir=2.

(community: CommunitySpace { theorem: 'THM-COMMUNITY-COMPOSITIONS', agents: '2' })
(agent_a: Agent { id: 'A', nadir: '5', deficit: '5' })
(agent_b: Agent { id: 'B', nadir: '4', deficit: '4' })
(shared: SharedExperience { overlap: '2', dimensions: '3' })
(composed_nadir: NadirMeasure { value: '2', formula: 'min(5,4) - 2' })
(reduction: Invariant { claim: 'composed nadir < min individual nadir', nadir_a: '5', nadir_b: '4', composed: '2' })
(result: Result { theorem: 'shared-experience-reduces-nadir' })

(community)-[:FORK]->(agent_a | agent_b)
(agent_a | agent_b)-[:FOLD { strategy: 'compose-with-shared-context' }]->(shared)
(shared)-[:PROCESS]->(composed_nadir)
(composed_nadir)-[:PROCESS { expect: 'nadir-reduced' }]->(reduction)
(reduction)-[:PROCESS { strategy: 'verify-strict-inequality' }]->(result)
(result)-[:TUNNEL { condition: 'bounded-reject' }]->(community_empathy_nadir_gg_trace:Trace)
(result)-[:MEASURE { reason: 'topology-audit' }]->(community_empathy_nadir_gg_trace:Trace)
