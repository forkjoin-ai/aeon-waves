// community_bule_convergence.gg — THM-COMMUNITY-DOMINANCE witness (sufficient context zeroes Bule)
//
// When shared context C >= deficit D, the Bule measure reaches zero.
// Bule = max(0, D - C). With D=3 and C=3, Bule = 0.
// The community has enough shared understanding to eliminate semiotic debt.

(space: BuleyeanSpace { theorem: 'THM-COMMUNITY-DOMINANCE', paths: '7', streams: '4', deficit: '3' })
(context_applied: ContextLevel { shared_context: '3', deficit: '3' })
(bule_before: BuleMeasure { value: '3', deficit: '3', context: '0' })
(bule_after: BuleMeasure { value: '0', deficit: '3', context: '3' })
(convergence: Invariant { claim: 'Bule = max(0, D - C) = 0', deficit: '3', context: '3', bule: '0' })
(result: Result { theorem: 'sufficient-context-zeroes-bule' })

(space)-[:FORK]->(bule_before | context_applied)
(context_applied)-[:PROCESS]->(bule_after)
(bule_before | bule_after)-[:RACE { expect: 'bule-reaches-zero' }]->(convergence)
(convergence)-[:PROCESS { strategy: 'verify-zero' }]->(result)
(result)-[:MEASURE { reason: 'topology-audit' }]->(community_bule_convergence_gg_trace:Trace)
