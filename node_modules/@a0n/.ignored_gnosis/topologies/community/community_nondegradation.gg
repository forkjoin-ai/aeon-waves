// community_nondegradation.gg — THM-COMMUNITY-DOMINANCE witness (community never increases deficit)
//
// A community operation (merging two channels with shared context) produces
// a combined deficit that is at most the maximum of the individual deficits.
// Community context can only help, never hurt.

(community: CommunityMerge { theorem: 'THM-COMMUNITY-DOMINANCE', channels: '2' })
(channel_a: SemioticChannel { paths: '4', streams: '3', deficit: '1' })
(channel_b: SemioticChannel { paths: '6', streams: '4', deficit: '2' })
(merged: SemioticChannel { paths: '10', streams: '7', deficit: '2', shared_context: '1' })
(bound: Invariant { claim: 'merged_deficit <= max(deficit_a, deficit_b)', merged: '2', max_individual: '2' })
(result: Result { theorem: 'community-nondegradation' })

(community)-[:FORK]->(channel_a | channel_b)
(channel_a | channel_b)-[:FOLD { strategy: 'merge-channels' }]->(merged)
(merged)-[:PROCESS { expect: 'deficit-bounded' }]->(bound)
(bound)-[:PROCESS { strategy: 'verify-inequality' }]->(result)
(result)-[:TUNNEL { condition: 'bounded-reject' }]->(community_nondegradation_gg_trace:Trace)
(result)-[:MEASURE { reason: 'topology-audit' }]->(community_nondegradation_gg_trace:Trace)
