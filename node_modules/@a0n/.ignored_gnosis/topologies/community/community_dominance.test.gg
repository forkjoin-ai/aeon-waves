// community_dominance.test.gg — Native Gnosis witnesses for THM-COMMUNITY-DOMINANCE
//
// These theorem-shaped `.gg` modules cover:
//   - context reduces deficit monotonically (attenuation)
//   - community never increases deficit (nondegradation)
//   - sufficient context zeroes Bule (Bule convergence)

(test_suite: TestSuite { name: 'community-dominance' })

(attenuation: Verify { module: './community_attenuation.gg', beta1_max: '6' })
(nondegradation: Verify { module: './community_nondegradation.gg', beta1_max: '6' })
(bule_convergence: Verify { module: './community_bule_convergence.gg', beta1_max: '6' })

(test_suite)-[:FORK]->(attenuation | nondegradation | bule_convergence)

(attenuation)-[:RACE { expect: 'safe' }]->(attenuation_result: Result)
(nondegradation)-[:RACE { expect: 'safe' }]->(nondegradation_result: Result)
(bule_convergence)-[:RACE { expect: 'safe' }]->(convergence_result: Result)

(attenuation_result | nondegradation_result | convergence_result)-[:FOLD { strategy: 'all-pass' }]->(verdict: Verdict)
(verdict)-[:TUNNEL { condition: 'bounded-reject' }]->(community_dominance_test_gg_trace:Trace)
(verdict)-[:MEASURE { reason: 'topology-audit' }]->(community_dominance_test_gg_trace:Trace)
