// community_void_sharing.gg — THM-COMMUNITY-COMPOSITIONS witness (per-dimension vulnerability diagnostic)
//
// Void sharing exposes each dimension of the deficit vector independently.
// Each dimension is diagnosed: shared dimensions have deficit=0, unshared
// dimensions retain their original deficit value.
// Example: 4 dimensions, 2 shared -> deficit vector [0, 0, 3, 2].

(community: CommunitySpace { theorem: 'THM-COMMUNITY-COMPOSITIONS', dimensions: '4' })
(dim_1: Dimension { id: '1', shared: 'true', deficit: '0' })
(dim_2: Dimension { id: '2', shared: 'true', deficit: '0' })
(dim_3: Dimension { id: '3', shared: 'false', deficit: '3' })
(dim_4: Dimension { id: '4', shared: 'false', deficit: '2' })
(diagnostic: VoidDiagnostic { deficit_vector: '[0, 0, 3, 2]', total_deficit: '5', shared_dims: '2', unshared_dims: '2' })
(invariant: Invariant { claim: 'shared dims have zero deficit', shared_deficits: '[0, 0]', unshared_deficits: '[3, 2]' })
(result: Result { theorem: 'per-dimension-vulnerability-diagnostic' })

(community)-[:FORK]->(dim_1 | dim_2 | dim_3 | dim_4)
(dim_1 | dim_2 | dim_3 | dim_4)-[:RACE { expect: 'deficit-vector-computed' }]->(diagnostic)
(diagnostic)-[:PROCESS]->(invariant)
(invariant)-[:PROCESS { strategy: 'verify-shared-zero' }]->(result)
(result)-[:MEASURE { reason: 'topology-audit' }]->(community_void_sharing_gg_trace:Trace)
