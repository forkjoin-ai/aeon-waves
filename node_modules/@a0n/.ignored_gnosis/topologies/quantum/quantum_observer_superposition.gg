// quantum_observer_superposition.gg — THM-SUPERPOSITION-FORK witness
//
// A quantum superposition of rootN=4 paths has beta1 = 3.
// Superposition is fork: rootN-1 independent cycles.

(system: QuantumSystem { theorem: 'THM-SUPERPOSITION-FORK', rootN: '4' })
(path_1: QuantumPath { amplitude: 'a1' })
(path_2: QuantumPath { amplitude: 'a2' })
(path_3: QuantumPath { amplitude: 'a3' })
(path_4: QuantumPath { amplitude: 'a4' })
(topology: Invariant { claim: 'beta1 = rootN - 1 = 3', beta1: '3' })
(result: Result { theorem: 'superposition-is-fork' })

(system)-[:FORK]->(path_1 | path_2 | path_3 | path_4)
(path_1 | path_2 | path_3 | path_4)-[:RACE { expect: 'superposition-intact' }]->(topology)
(topology)-[:PROCESS { strategy: 'verify-beta1' }]->(result)
(result)-[:MEASURE { reason: 'topology-audit' }]->(quantum_observer_superposition_gg_trace:Trace)
