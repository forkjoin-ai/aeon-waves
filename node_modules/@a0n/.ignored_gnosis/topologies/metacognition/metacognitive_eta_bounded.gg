// metacognitive_eta_bounded.gg — THM-METACOGNITIVE-WALKER witness (exploration bounded)
//
// The exploration parameter eta is bounded above by a function of
// the cognitive depth. Deeper cognition reduces exploration, preventing
// unbounded wandering in the metacognitive space.
// Example: depth 1 -> eta <= 1.0, depth 3 -> eta <= 0.33.

(walker: MetacognitiveWalker { theorem: 'THM-METACOGNITIVE-WALKER', max_depth: '3' })
(level_1: CognitiveLevel { depth: '1', eta: '0.9', bound: '1.0' })
(level_2: CognitiveLevel { depth: '2', eta: '0.4', bound: '0.5' })
(level_3: CognitiveLevel { depth: '3', eta: '0.2', bound: '0.33' })
(bounded: Invariant { claim: 'eta_bounded_by_depth', max_eta: '0.9', max_bound: '1.0' })
(result: Result { theorem: 'exploration-bounded' })

(walker)-[:FORK]->(level_1 | level_2 | level_3)
(level_1 | level_2 | level_3)-[:RACE { expect: 'eta-within-bound' }]->(bounded)
(bounded)-[:PROCESS { strategy: 'verify-inequality' }]->(result)
(result)-[:MEASURE { reason: 'topology-audit' }]->(metacognitive_eta_bounded_gg_trace:Trace)
