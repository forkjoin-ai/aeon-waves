// metacognitive_gait_valid.gg — THM-METACOGNITIVE-WALKER witness (gait always valid cognitive level)
//
// At every step, the walker's gait maps to a valid cognitive level
// in the hierarchy. The gait function never produces an out-of-range
// level index.
// Example: hierarchy has 4 levels, gait outputs are all in {1,2,3,4}.

(walker: MetacognitiveWalker { theorem: 'THM-METACOGNITIVE-WALKER', levels: '4' })
(step_1: WalkerStep { step: '1', gait: '2', valid: 'true' })
(step_2: WalkerStep { step: '2', gait: '4', valid: 'true' })
(step_3: WalkerStep { step: '3', gait: '1', valid: 'true' })
(step_4: WalkerStep { step: '4', gait: '3', valid: 'true' })
(validity: Invariant { claim: 'gait_always_valid_level', steps_checked: '4', all_valid: 'true' })
(result: Result { theorem: 'gait-valid-cognitive-level' })

(walker)-[:FORK]->(step_1 | step_2 | step_3 | step_4)
(step_1 | step_2 | step_3 | step_4)-[:RACE { expect: 'all-valid' }]->(validity)
(validity)-[:PROCESS { strategy: 'verify-valid' }]->(result)
(result)-[:MEASURE { reason: 'topology-audit' }]->(metacognitive_gait_valid_gg_trace:Trace)
