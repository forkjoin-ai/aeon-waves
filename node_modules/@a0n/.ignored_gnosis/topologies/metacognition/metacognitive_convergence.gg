// metacognitive_convergence.gg — THM-METACOGNITIVE-WALKER witness (kurtosis eventually stabilizes)
//
// The kurtosis of the walker's trajectory distribution eventually
// stabilizes to a finite value. After sufficient steps, the kurtosis
// change per step drops below epsilon.
// Example: kurtosis at step 10 = 3.1, step 20 = 3.05, delta = 0.05 < 0.1.

(walker: MetacognitiveWalker { theorem: 'THM-METACOGNITIVE-WALKER', epsilon: '0.1' })
(early: KurtosisState { step: '10', kurtosis: '3.5' })
(mid: KurtosisState { step: '20', kurtosis: '3.1' })
(late: KurtosisState { step: '30', kurtosis: '3.05' })
(delta: KurtosisDelta { from_step: '20', to_step: '30', delta: '0.05' })
(convergence: Invariant { claim: 'kurtosis_stabilizes', delta: '0.05', epsilon: '0.1' })
(result: Result { theorem: 'kurtosis-converges' })

(walker)-[:FORK]->(early | mid | late)
(early)-[:PROCESS]->(mid)
(mid)-[:PROCESS]->(late)
(mid | late)-[:RACE { expect: 'delta-below-epsilon' }]->(delta)
(delta)-[:PROCESS]->(convergence)
(convergence)-[:PROCESS { strategy: 'verify-inequality' }]->(result)
(result)-[:MEASURE { reason: 'topology-audit' }]->(metacognitive_convergence_gg_trace:Trace)
