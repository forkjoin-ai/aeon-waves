// solomonoff_washout.gg — THM-SOLOMONOFF-BULEYEAN witness (data dominates prior)
//
// As evidence accumulates, the posterior concentrates on the true hypothesis
// regardless of the prior. Even a bad initial complexity assignment is washed
// out by enough data. The void boundary from data overwhelms the initial boundary.

(space: SolomonoffSpace { theorem: 'THM-SOLOMONOFF-BULEYEAN', hypotheses: '3' })
(prior_good: Prior { type: 'solomonoff', initial_weights: '[8, 4, 1]' })
(prior_bad: Prior { type: 'adversarial', initial_weights: '[1, 1, 8]' })
(after_10_rounds: Posterior { rounds: '10', good_weights: '[15, 6, 2]', bad_weights: '[8, 3, 10]' })
(after_50_rounds: Posterior { rounds: '50', good_weights: '[48, 12, 3]', bad_weights: '[45, 10, 5]' })
(after_100_rounds: Posterior { rounds: '100', good_weights: '[96, 18, 4]', bad_weights: '[93, 16, 6]' })
(washout: Invariant { claim: 'posteriors converge despite different priors', gap_at_100: '3' })
(result: Result { theorem: 'data-dominates-prior' })

(space)-[:FORK]->(prior_good | prior_bad)
(prior_good)-[:PROCESS { expect: 'posterior-computed' }]->(after_10_rounds)
(prior_bad)-[:PROCESS { expect: 'posterior-computed' }]->(after_50_rounds)
(after_10_rounds | after_50_rounds)-[:PROCESS]->(after_100_rounds)
(after_100_rounds)-[:PROCESS { strategy: 'verify-convergence' }]->(washout)
(washout)-[:PROCESS]->(result)
