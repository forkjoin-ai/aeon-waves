// chaitin_omega.test.gg — Native Gnosis witnesses for THM-CHAITIN-OMEGA
//
// These theorem-shaped `.gg` modules cover:
//   - UTM = universal fork (Chaitin's universal machine)
//   - execution partitions halting/non-halting (halting fold)
//   - halting probability > 0 (omega positive)
//   - finite prefix tightens bound (approximation monotone)

(test_suite: TestSuite { name: 'chaitin-omega' })

(universal_fork: Verify { module: './chaitin_universal_fork.gg', beta1_max: '7' })
(halting_fold: Verify { module: './chaitin_halting_fold.gg', beta1_max: '7' })
(omega_positive: Verify { module: './chaitin_omega_positive.gg', beta1_max: '7' })
(approx_monotone: Verify { module: './chaitin_approximation_monotone.gg', beta1_max: '7' })

(test_suite)-[:PROCESS]->(suite_plan: Plan)
