// warmup_controller_under_below_redline.gg — Underfilled controller case below redline
//
// The proved branch is:
//   underDeficit > 0
//   overDeficit = 0
//   BurdenScalar < deficitWeight + shedPenalty
// so `expand` is the unique argmin action.

(case: ControllerCase { theorem: 'THM-S7-WARM-CTRL', mismatch: 'underfilled', burden_regime: 'below-redline' })
(under_deficit: UnderDeficit { units: '3' })
(redline: Redline { deficit_weight: '4', shed_penalty: '2' })
(burden: BurdenScalar { relation: '< redline' })

(expand: Expand { action: 'expand' })
(constrain: Constrain { action: 'constrain' })
(shed_load: ShedLoad { action: 'shed-load' })

(expand_residual: Residual { units: '2', score_role: 'min' })
(constrain_drag: Penalty { reason: 'wrong-direction repair' })
(shed_drag: Penalty { reason: 'premature fixed shed penalty' })

(case)-[:PROCESS]->(under_deficit)
(under_deficit)-[:PROCESS]->(redline)
(redline)-[:PROCESS]->(burden)
(burden)-[:FORK]->(expand | constrain | shed_load)
(expand)-[:PROCESS]->(expand_residual)
(constrain)-[:PROCESS { reason: 'overprovision branch is dominated' }]->(constrain_drag)
(shed_load)-[:PROCESS { reason: 'fixed penalty arrives before redline' }]->(shed_drag)
(expand_residual | constrain_drag | shed_drag)-[:FOLD { strategy: 'pick-min-score' }]->(decision: Decision { chosen: 'expand' })
(decision)-[:PROCESS]->(verdict: Result)
(verdict)-[:TUNNEL { condition: 'bounded-reject' }]->(warmup_controller_under_below_redline_gg_trace:Trace)
(verdict)-[:MEASURE { reason: 'topology-audit' }]->(warmup_controller_under_below_redline_gg_trace:Trace)
