// warmup_adaptive_load_balancing.gg — Adaptive Optimization / Online Learning: Adaptive load balancing
//
// Classification: Adaptive Optimization / Online Learning
//
// Models the structural flow where an initial input forks between a fast
// "warmed up" path and a slow fallback path.

(input: Workload { type: 'request' })
(fast_path: State { name: 'backend_health_stats' })
(slow_path: State { name: 'routing_decision' })
(chosen_path: Plan)
(result: Result)

(input)-[:FORK]->(fast_path | slow_path)
(fast_path | slow_path)-[:RACE { expect: 'fastest-safe' }]->(chosen_path)
(chosen_path)-[:PROCESS]->(result)
(result)-[:MEASURE { reason: 'topology-audit' }]->(warmup_adaptive_load_balancing_gg_trace:Trace)
