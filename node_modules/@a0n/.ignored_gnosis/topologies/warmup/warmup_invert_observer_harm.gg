// warmup_invert_observer_harm.gg — Probing destroys the option it wants to exploit
//
// Semantic void witness: observing the latent fast path forces collapse, so
// the probe itself consumes the warm opportunity it tries to unlock. The
// poison event in this witness stands for the measurement itself.

(input: Workload { type: 'latent-opportunity' })
(fast_path: State)
(slow_path: State)
(poison_event: Event { type: 'entropy_or_drift' })
(chosen_path: Plan)
(fallback: Plan)
(result: Result)

(input)-[:FORK]->(fast_path | slow_path | poison_event)
(poison_event)-[:PROCESS { mode: 'destructive' }]->(fast_path)
(fast_path | slow_path)-[:PROCESS { expect: 'first-measured' }]->(chosen_path)
(chosen_path | poison_event | slow_path)-[:FOLD { strategy: 'collapse-on-read' }]->(fallback)
(fallback)-[:PROCESS]->(result)
(result)-[:TUNNEL { condition: 'bounded-reject' }]->(warmup_invert_observer_harm_gg_trace:Trace)
(result)-[:MEASURE { reason: 'topology-audit' }]->(warmup_invert_observer_harm_gg_trace:Trace)
