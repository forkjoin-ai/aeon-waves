// warmup_amortized_dictionary_compression.gg — Structural / Amortized Optimization: Dictionary-based compression (LZW, DEFLATE)
//
// Classification: Structural / Amortized Optimization
//
// Models the structural flow where an initial input forks between a fast
// "warmed up" path and a slow fallback path.

(input: Workload { type: 'request' })
(fast_path: State { name: 'dictionary_builder' })
(slow_path: State { name: 'compressed_output' })
(chosen_path: Plan)
(result: Result)

(input)-[:FORK]->(fast_path | slow_path)
(fast_path | slow_path)-[:RACE { expect: 'fastest-safe' }]->(chosen_path)
(chosen_path)-[:PROCESS]->(result)
(result)-[:MEASURE { reason: 'topology-audit' }]->(warmup_amortized_dictionary_compression_gg_trace:Trace)
