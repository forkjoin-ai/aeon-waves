// warmup_taxonomy.test.gg — Verification harness for warm-up mechanisms
//
// Each module is a toy topology for "improves after initial use".
// The harness keeps them comparable and ready for inversion work.

(test_suite: TestSuite { name: 'warmup-taxonomy' })

(cache_reuse: Verify { module: './warmup_cache_reuse.gg', beta1_max: '4' })
(prefetch: Verify { module: './warmup_precompute_prefetch.gg', beta1_max: '6' })
(adaptive: Verify { module: './warmup_adaptive_optimization.gg', beta1_max: '4' })
(probabilistic: Verify { module: './warmup_approximate_probabilistic.gg', beta1_max: '4' })
(amortized: Verify { module: './warmup_structural_amortized.gg', beta1_max: '4' })
(physical: Verify { module: './warmup_physical_biological.gg', beta1_max: '4' })
(entrainment: Verify { module: './warmup_human_social_entrainment.gg', beta1_max: '4' })
(bayesian_classifier: Verify { module: './warmup_bayesian_classifier.gg', beta1_max: '20' })
(mixed_jit: Verify { module: './warmup_mixed_jit_compiler.gg', beta1_max: '4' })
(mixed_flight: Verify { module: './warmup_mixed_commercial_flight.gg', beta1_max: '4' })
(mixed_branch: Verify { module: './warmup_mixed_branch_prediction.gg', beta1_max: '4' })
(mixed_cold: Verify { module: './warmup_mixed_cold_calling.gg', beta1_max: '4' })
(mixed_splay: Verify { module: './warmup_mixed_splay_tree.gg', beta1_max: '4' })
(mixed_matview: Verify { module: './warmup_mixed_materialized_view.gg', beta1_max: '4' })
(mixed_cdn: Verify { module: './warmup_mixed_cdn_edge.gg', beta1_max: '4' })

(test_suite)-[:PROCESS]->(cache_reuse | prefetch | adaptive | probabilistic | amortized | physical | entrainment | bayesian_classifier | mixed_jit | mixed_flight | mixed_branch | mixed_cold | mixed_splay | mixed_matview | mixed_cdn)

(cache_reuse)-[:PROCESS { expect: 'safe' }]->(cache_result: Result)
(prefetch)-[:PROCESS { expect: 'safe' }]->(prefetch_result: Result)
(adaptive)-[:PROCESS { expect: 'safe' }]->(adaptive_result: Result)
(probabilistic)-[:PROCESS { expect: 'safe' }]->(probabilistic_result: Result)
(amortized)-[:PROCESS { expect: 'safe' }]->(amortized_result: Result)
(physical)-[:PROCESS { expect: 'safe' }]->(physical_result: Result)
(entrainment)-[:PROCESS { expect: 'safe' }]->(entrainment_result: Result)
(bayesian_classifier)-[:PROCESS { expect: 'safe' }]->(bayesian_result: Result)
(mixed_jit)-[:PROCESS { expect: 'safe' }]->(mixed_jit_result: Result)
(mixed_flight)-[:PROCESS { expect: 'safe' }]->(mixed_flight_result: Result)
(mixed_branch)-[:PROCESS { expect: 'safe' }]->(mixed_branch_result: Result)
(mixed_cold)-[:PROCESS { expect: 'safe' }]->(mixed_cold_result: Result)
(mixed_splay)-[:PROCESS { expect: 'safe' }]->(mixed_splay_result: Result)
(mixed_matview)-[:PROCESS { expect: 'safe' }]->(mixed_matview_result: Result)
(mixed_cdn)-[:PROCESS { expect: 'safe' }]->(mixed_cdn_result: Result)

(cache_result | prefetch_result | adaptive_result | probabilistic_result | amortized_result | physical_result | entrainment_result | bayesian_result | mixed_jit_result | mixed_flight_result | mixed_branch_result | mixed_cold_result | mixed_splay_result | mixed_matview_result | mixed_cdn_result)-[:PROCESS { strategy: 'all-pass' }]->(verdict: Verdict)
