// warmup_adaptive_optimization.gg — Policy improves from observations
//
// Warm-up mechanism: early executions feed telemetry into an online learner.
// Once specialized, the optimized plan races and begins to win.

(request: Workload { shape: 'mixed-read-write' })
(generic_plan: Scheduler { policy: 'round-robin' })
(profile_collector: Telemetry { metric: 'latency' })
(policy_model: Learner { method: 'online-bandit' })
(specialized_plan: Scheduler { policy: 'hot-path-first' })
(chosen_plan: Plan)
(result: Result)
(next_epoch: ModelState)

(request)-[:FORK]->(generic_plan | profile_collector)
(profile_collector)-[:PROCESS]->(policy_model)-[:PROCESS]->(specialized_plan)
(request)-[:PROCESS]->(specialized_plan)
(generic_plan | specialized_plan)-[:PROCESS { expect: 'fastest-safe' }]->(chosen_plan)
(chosen_plan)-[:PROCESS]->(result)
(result | policy_model)-[:FOLD { strategy: 'update-policy' }]->(next_epoch)
(next_epoch)-[:TUNNEL { condition: 'bounded-reject' }]->(warmup_adaptive_optimization_gg_trace:Trace)
(next_epoch)-[:MEASURE { reason: 'topology-audit' }]->(warmup_adaptive_optimization_gg_trace:Trace)
