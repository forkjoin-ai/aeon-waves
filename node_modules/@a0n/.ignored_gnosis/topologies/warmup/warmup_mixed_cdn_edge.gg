// warmup_mixed_cdn_edge.gg — Mixed Membership: CDN / Edge Warming
//
// Primary: Precompute / prefetch
// Secondary: Cache / index reuse
// The warm-up step is predictive, but the serving path is cache hit reuse.

(client_request: Workload)
(predictive_engine: Precompute { type: 'asset_popularity' })
(origin_server: Source { location: 'remote' })
(edge_cache: Cache { location: 'local' })
(cache_hit: Runner { mode: 'edge_serve' })
(cache_miss: Runner { mode: 'origin_fetch' })
(response_plan: Plan)
(delivered_asset: Result)

(predictive_engine)-[:PROCESS]->(origin_server)-[:PROCESS]->(edge_cache)

(client_request)-[:FORK]->(cache_hit | cache_miss)
(edge_cache)-[:PROCESS]->(cache_hit)
(origin_server)-[:PROCESS]->(cache_miss)

(cache_hit | cache_miss)-[:RACE { expect: 'fastest-safe' }]->(response_plan)
(response_plan)-[:PROCESS]->(delivered_asset)
(delivered_asset)-[:MEASURE { reason: 'topology-audit' }]->(warmup_mixed_cdn_edge_gg_trace:Trace)
