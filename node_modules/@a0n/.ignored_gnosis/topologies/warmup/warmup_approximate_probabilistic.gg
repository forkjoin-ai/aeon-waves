// warmup_approximate_probabilistic.gg — Reject most misses before exact work
//
// Warm-up mechanism: a probabilistic gate narrows the frontier, so exact work
// only runs when the sketch says "maybe". False positives still preserve safety.

(query: Query { key: 'emotion:anticipation' })
(sketch_gate: Sketch { type: 'bloom', false_positive: '0.01' })
(definite_miss: Verdict { status: 'reject' })
(maybe_hit: Frontier { status: 'maybe' })
(exact_lookup: Index { mode: 'exact' })
(answer: Result)

(query)-[:PROCESS]->(sketch_gate)
(sketch_gate)-[:FORK]->(definite_miss | maybe_hit)
(maybe_hit)-[:PROCESS]->(exact_lookup)
(definite_miss | exact_lookup)-[:RACE { expect: 'reject-or-confirm' }]->(answer)
(answer)-[:MEASURE { reason: 'topology-audit' }]->(warmup_approximate_probabilistic_gg_trace:Trace)
