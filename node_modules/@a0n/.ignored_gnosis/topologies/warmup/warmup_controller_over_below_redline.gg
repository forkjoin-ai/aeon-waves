// warmup_controller_over_below_redline.gg — Overprovisioned controller case below redline
//
// The proved branch is:
//   underDeficit = 0
//   overDeficit > 0
//   BurdenScalar < deficitWeight + shedPenalty
// so `constrain` is the unique argmin action.

(case: ControllerCase { theorem: 'THM-S7-WARM-CTRL', mismatch: 'overprovisioned', burden_regime: 'below-redline' })
(over_deficit: OverDeficit { units: '3' })
(redline: Redline { deficit_weight: '4', shed_penalty: '2' })
(burden: BurdenScalar { relation: '< redline' })

(expand: Expand { action: 'expand' })
(constrain: Constrain { action: 'constrain' })
(shed_load: ShedLoad { action: 'shed-load' })

(expand_drag: Penalty { reason: 'adds width in the wrong direction' })
(constrain_residual: Residual { units: '2', score_role: 'min' })
(shed_drag: Penalty { reason: 'premature fixed shed penalty' })

(case)-[:PROCESS]->(over_deficit)
(over_deficit)-[:PROCESS]->(redline)
(redline)-[:PROCESS]->(burden)
(burden)-[:FORK]->(expand | constrain | shed_load)
(expand)-[:PROCESS { reason: 'underfilled repair is dominated here' }]->(expand_drag)
(constrain)-[:PROCESS]->(constrain_residual)
(shed_load)-[:PROCESS { reason: 'fixed penalty arrives before redline' }]->(shed_drag)
(expand_drag | constrain_residual | shed_drag)-[:FOLD { strategy: 'pick-min-score' }]->(decision: Decision { chosen: 'constrain' })
(decision)-[:PROCESS]->(verdict: Result)
(verdict)-[:TUNNEL { condition: 'bounded-reject' }]->(warmup_controller_over_below_redline_gg_trace:Trace)
(verdict)-[:MEASURE { reason: 'topology-audit' }]->(warmup_controller_over_below_redline_gg_trace:Trace)
