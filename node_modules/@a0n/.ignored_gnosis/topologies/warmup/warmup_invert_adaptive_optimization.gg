// warmup_invert_adaptive_optimization.gg — Online learning drifts into noise
//
// Inversion: adaptation still changes policy over time, but the learned path
// now chases noisy telemetry and must be pulled back to a stable fallback.

(request: Workload { shape: 'mixed-read-write' })
(generic_plan: Scheduler { policy: 'round-robin' })
(noisy_telemetry: Telemetry { metric: 'spiky-latency' })
(policy_model: Learner { method: 'overfit-bandit' })
(drifted_plan: Scheduler { policy: 'noise-chasing' })
(selected_plan: Plan)
(oscillation: Instability)
(final_result: Result)

(request)-[:FORK]->(generic_plan | noisy_telemetry)
(noisy_telemetry)-[:PROCESS]->(policy_model)-[:PROCESS]->(drifted_plan)
(request)-[:PROCESS]->(drifted_plan)
(generic_plan | drifted_plan)-[:PROCESS { expect: 'fastest-now' }]->(selected_plan)
(selected_plan | policy_model)-[:PROCESS { mode: 'destructive' }]->(oscillation)
(oscillation | generic_plan)-[:FOLD { strategy: 'fallback-stable' }]->(final_result)
(final_result)-[:TUNNEL { condition: 'bounded-reject' }]->(warmup_invert_adaptive_optimization_gg_trace:Trace)
(final_result)-[:MEASURE { reason: 'topology-audit' }]->(warmup_invert_adaptive_optimization_gg_trace:Trace)
