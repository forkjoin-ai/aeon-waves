// warmup_invert_approximate_probabilistic.gg — Sketch narrowing becomes fanout
//
// Inversion: the probabilistic front door now emits too many false positives,
// so exact work multiplies and the system prunes only after paying the cost.

(query: Query { key: 'emotion:anticipation' })
(unstable_sketch: Sketch { type: 'bloom', false_positive: '0.35' })
(maybe_hit: Frontier { status: 'maybe' })
(false_positive: Frontier { status: 'spurious' })
(exact_lookup: Index { mode: 'exact' })
(shadow_lookup: Index { mode: 'duplicate-exact' })
(full_scan: Scan { scope: 'segment-set' })
(overworked_answer: Candidate)
(answer: Result)
(waste_heat: WasteHeat)

(query)-[:PROCESS]->(unstable_sketch)
(unstable_sketch)-[:FORK]->(maybe_hit | false_positive)
(maybe_hit)-[:PROCESS]->(exact_lookup)
(false_positive)-[:FORK]->(shadow_lookup | full_scan)
(exact_lookup | shadow_lookup | full_scan)-[:FOLD { strategy: 'overconfirm' }]->(overworked_answer)
(overworked_answer)-[:PROCESS { mode: 'destructive' }]->(answer)
(false_positive)-[:VENT { condition: 'discard-excess' }]->(waste_heat)
(waste_heat)-[:MEASURE { reason: 'topology-audit' }]->(warmup_invert_approximate_probabilistic_gg_trace:Trace)
