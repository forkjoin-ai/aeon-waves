// warmup_controller_under_redline_tie.gg — Underfilled controller boundary tie
//
// Boundary case:
//   underDeficit > 0
//   overDeficit = 0
//   BurdenScalar = deficitWeight + shedPenalty
// so `expand` ties `shed-load`, and the stable tie-break keeps `expand`.

(case: ControllerCase { theorem: 'THM-S7-WARM-CTRL', mismatch: 'underfilled', burden_regime: 'redline-tie' })
(under_deficit: UnderDeficit { units: '3' })
(redline: Redline { deficit_weight: '4', shed_penalty: '2' })
(burden: BurdenScalar { relation: '= redline' })

(expand: Expand { action: 'expand' })
(constrain: Constrain { action: 'constrain' })
(shed_load: ShedLoad { action: 'shed-load' })

(expand_tie: ScoreBoundary { relation: 'tie-with-shed-load' })
(constrain_drag: Penalty { reason: 'still dominated by deficit weight' })
(shed_tie: ScoreBoundary { relation: 'tie-with-expand' })

(case)-[:PROCESS]->(under_deficit)
(under_deficit)-[:PROCESS]->(redline)
(redline)-[:PROCESS]->(burden)
(burden)-[:FORK]->(expand | constrain | shed_load)
(expand)-[:PROCESS]->(expand_tie)
(constrain)-[:PROCESS { reason: 'wrong-direction repair remains worse' }]->(constrain_drag)
(shed_load)-[:PROCESS]->(shed_tie)
(expand_tie | constrain_drag | shed_tie)-[:FOLD { strategy: 'stable-expand-on-tie' }]->(decision: Decision { chosen: 'expand', tie_with: 'shed-load' })
(decision)-[:PROCESS]->(verdict: Result)
(verdict)-[:TUNNEL { condition: 'bounded-reject' }]->(warmup_controller_under_redline_tie_gg_trace:Trace)
(verdict)-[:MEASURE { reason: 'topology-audit' }]->(warmup_controller_under_redline_tie_gg_trace:Trace)
