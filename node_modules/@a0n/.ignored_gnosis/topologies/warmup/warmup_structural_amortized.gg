// warmup_structural_amortized.gg — Reshape once, benefit many times
//
// Warm-up mechanism: append cheap writes first, then compact them into a
// structure that makes later reads cheaper than the raw event log.

(write_stream: Stream { mode: 'append-only' })
(memtable: Buffer { level: 'L0' })
(compaction: Compactor { policy: 'levelled' })
(sorted_run: Segment { level: 'L1' })
(point_query: Query { key: 'emotion:grief' })
(memtable_probe: Probe { scope: 'memtable' })
(sstable_probe: Probe { scope: 'sorted-run' })

(write_stream)-[:PROCESS]->(memtable)
(memtable)-[:PROCESS]->(compaction)-[:PROCESS]->(sorted_run)
(point_query)-[:FORK]->(memtable_probe | sstable_probe)
(memtable)-[:PROCESS]->(memtable_probe)
(sorted_run)-[:PROCESS]->(sstable_probe)
(memtable_probe | sstable_probe)-[:FOLD { strategy: 'prefer-compacted', request_compression: 'middle-out/request/warmup-structural-amortized', reuse_scope: 'corridor', corridor_mode: 'readonly' }]->(answer: Result)
(answer)-[:TUNNEL { condition: 'bounded-reject' }]->(warmup_structural_amortized_gg_trace:Trace)
(answer)-[:MEASURE { reason: 'topology-audit' }]->(warmup_structural_amortized_gg_trace:Trace)
