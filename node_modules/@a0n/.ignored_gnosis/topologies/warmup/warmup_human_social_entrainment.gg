// warmup_human_social_entrainment.gg — Coordination improves with shared rhythm
//
// Warm-up mechanism: teams build shared vocabulary, trust, and turn-taking.
// Once aligned, collaboration gets faster and lower-friction.

(team: Group { mode: 'pair-design' })
(shared_vocab: SocialState { metric: 'shared-vocabulary' })
(rapport: SocialState { metric: 'trust' })
(turn_taking: SocialState { metric: 'cadence' })
(alignment: SocialState { phase: 'entrained' })

(team)-[:FORK]->(shared_vocab | rapport | turn_taking)
(shared_vocab | rapport | turn_taking)-[:FOLD { strategy: 'entrain', request_compression: 'middle-out/request/warmup-human-social-entrainment', reuse_scope: 'corridor', corridor_mode: 'readonly' }]->(alignment)
(alignment)-[:PROCESS]->(collaboration: Outcome)
(collaboration)-[:TUNNEL { condition: 'bounded-reject' }]->(warmup_human_social_entrainment_gg_trace:Trace)
(collaboration)-[:MEASURE { reason: 'topology-audit' }]->(warmup_human_social_entrainment_gg_trace:Trace)
