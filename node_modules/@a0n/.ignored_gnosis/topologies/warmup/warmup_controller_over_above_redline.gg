// warmup_controller_over_above_redline.gg — Overprovisioned controller case above redline
//
// The proved branch is:
//   underDeficit = 0
//   overDeficit > 0
//   BurdenScalar > deficitWeight + shedPenalty
// so `shed-load` dominates the repair branches.

(case: ControllerCase { theorem: 'THM-S7-WARM-CTRL', mismatch: 'overprovisioned', burden_regime: 'above-redline' })
(over_deficit: OverDeficit { units: '3' })
(redline: Redline { deficit_weight: '4', shed_penalty: '2' })
(burden: BurdenScalar { relation: '> redline' })

(expand: Expand { action: 'expand' })
(constrain: Constrain { action: 'constrain' })
(shed_load: ShedLoad { action: 'shed-load' })

(expand_drag: Penalty { reason: 'wrong-direction repair plus burden' })
(constrain_drag: Penalty { reason: 'repair plus burden exceeds redline' })
(shed_score: FixedCost { role: 'minimum' })

(case)-[:PROCESS]->(over_deficit)
(over_deficit)-[:PROCESS]->(redline)
(redline)-[:PROCESS]->(burden)
(burden)-[:FORK]->(expand | constrain | shed_load)
(expand)-[:PROCESS { reason: 'wrong-direction repair is still worse' }]->(expand_drag)
(constrain)-[:PROCESS { reason: 'BurdenScalar dominates repair' }]->(constrain_drag)
(shed_load)-[:PROCESS]->(shed_score)
(expand_drag | constrain_drag | shed_score)-[:FOLD { strategy: 'pick-min-score' }]->(decision: Decision { chosen: 'shed-load' })
(decision)-[:PROCESS]->(verdict: Result)
(verdict)-[:TUNNEL { condition: 'bounded-reject' }]->(warmup_controller_over_above_redline_gg_trace:Trace)
(verdict)-[:MEASURE { reason: 'topology-audit' }]->(warmup_controller_over_above_redline_gg_trace:Trace)
