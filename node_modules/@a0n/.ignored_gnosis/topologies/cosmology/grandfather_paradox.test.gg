// grandfather_paradox.test.gg — Native Gnosis witnesses for THM-GRANDFATHER-PARADOX
//
// These theorem-shaped `.gg` modules cover:
//   - void boundary is append-only (events cannot be un-occurred)
//   - the sliver prevents annihilation (weight >= 1 always)
//   - self-referential fold is impossible
//   - branching is fork, not fold (beta1 increases)

(test_suite: TestSuite { name: 'grandfather-paradox' })

(append_only: Verify { module: './grandfather_append_only.gg', beta1_max: '6' })
(sliver_prevents: Verify { module: './grandfather_sliver.gg', beta1_max: '6' })
(self_ref_impossible: Verify { module: './grandfather_self_referential.gg', beta1_max: '6' })
(branching_is_fork: Verify { module: './grandfather_branching.gg', beta1_max: '6' })

(test_suite)-[:PROCESS]->(append_only | sliver_prevents | self_ref_impossible | branching_is_fork)

(append_only)-[:PROCESS { expect: 'safe' }]->(append_result: Result)
(sliver_prevents)-[:PROCESS { expect: 'safe' }]->(sliver_result: Result)
(self_ref_impossible)-[:PROCESS { expect: 'safe' }]->(self_ref_result: Result)
(branching_is_fork)-[:PROCESS { expect: 'safe' }]->(branch_result: Result)

(append_result | sliver_result | self_ref_result | branch_result)-[:PROCESS { strategy: 'all-pass' }]->(verdict: Verdict)
