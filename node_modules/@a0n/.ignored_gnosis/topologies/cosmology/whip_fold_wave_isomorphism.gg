// whip_fold_wave_isomorphism.gg — THM-WHIP-WAVE-DUALITY witness (fold = wave speed increase)
//
// A fold operation on the whip's state corresponds exactly to a wave
// speed increase at the taper boundary. The fold functor and wave
// propagation functor are naturally isomorphic.
// Example: fold at segment 2 -> speed doubles, same as wave crossing taper.

(whip: Whip { theorem: 'THM-WHIP-WAVE-DUALITY', fold_point: '2' })
(pre_fold: WaveState { speed: '2', segment: '2' })
(post_fold: WaveState { speed: '4', segment: '3' })
(fold_op: FoldOperation { input_speed: '2', output_speed: '4', ratio: '2' })
(wave_cross: WavePropagation { input_speed: '2', output_speed: '4', taper: '2' })
(iso: Invariant { claim: 'fold_iso_wave', fold_ratio: '2', wave_taper: '2' })
(result: Result { theorem: 'fold-wave-isomorphism' })

(whip)-[:FORK]->(pre_fold | fold_op | wave_cross)
(pre_fold)-[:PROCESS]->(post_fold)
(fold_op | wave_cross)-[:RACE { expect: 'isomorphic' }]->(iso)
(iso)-[:PROCESS { strategy: 'verify-equality' }]->(result)
(result)-[:MEASURE { reason: 'topology-audit' }]->(whip_fold_wave_isomorphism_gg_trace:Trace)
