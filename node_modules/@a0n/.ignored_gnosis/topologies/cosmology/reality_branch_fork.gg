// reality_branch_fork.gg — Reality Forking

(base_state: Graph)-[:FORK]->(branch_a: Simulation | branch_b: Simulation)
(branch_a | branch_b)-[:FOLD { strategy: 'wisdom-merge' }]->(next_state: Graph)
(next_state)-[:TUNNEL { condition: 'bounded-reject' }]->(reality_branch_fork_gg_trace:Trace)
(next_state)-[:MEASURE { reason: 'topology-audit' }]->(reality_branch_fork_gg_trace:Trace)
