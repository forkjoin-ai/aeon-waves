// grandfather_sliver.gg — THM-SLIVER-PREVENTS-ANNIHILATION witness
//
// The +1 in weight = rounds - min(void, rounds) + 1 ensures
// no event's weight can reach zero. Even max rejection gives weight = 1.

(space: BuleyeanSpace { theorem: 'THM-SLIVER-PREVENTS-ANNIHILATION', choices: '3', rounds: '100' })
(ancestor: Choice { name: 'ancestor', void_count: '100', weight: '1' })
(parent: Choice { name: 'parent', void_count: '50', weight: '51' })
(traveler: Choice { name: 'traveler', void_count: '0', weight: '101' })
(sliver: Invariant { claim: 'min weight = 1, not 0', min: '1' })
(annihilation_blocked: Impossibility { reason: 'weight formula has +1' })
(result: Result { theorem: 'sliver-prevents-annihilation' })

(space)-[:FORK]->(ancestor | parent | traveler)
(ancestor | parent | traveler)-[:RACE { expect: 'all-positive' }]->(sliver)
(sliver)-[:PROCESS]->(annihilation_blocked)
(annihilation_blocked)-[:PROCESS { strategy: 'verify-nonzero' }]->(result)
(result)-[:MEASURE { reason: 'topology-audit' }]->(grandfather_sliver_gg_trace:Trace)
