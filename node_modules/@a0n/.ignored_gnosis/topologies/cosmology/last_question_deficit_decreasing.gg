// last_question_deficit_decreasing.gg — THM-LAST-QUESTION witness (deficit decreases by 1 per round)
//
// In the last question protocol, each round resolves exactly one
// dimension of uncertainty. The deficit decreases by exactly 1
// per round until it reaches zero.
// Example: initial deficit=5, after round 1 deficit=4, round 2 deficit=3, etc.

(protocol: LastQuestionProtocol { theorem: 'THM-LAST-QUESTION', initial_deficit: '5' })
(round_0: Round { id: '0', deficit: '5' })
(round_1: Round { id: '1', deficit: '4', resolved_dimension: '1' })
(round_2: Round { id: '2', deficit: '3', resolved_dimension: '2' })
(round_3: Round { id: '3', deficit: '2', resolved_dimension: '3' })
(step_size: Invariant { claim: 'deficit decreases by exactly 1 per round', deficit_sequence: '[5, 4, 3, 2]', step: '1' })
(result: Result { theorem: 'deficit-decreasing-by-one' })

(protocol)-[:PROCESS]->(round_0)
(round_0)-[:PROCESS]->(round_1)
(round_1)-[:PROCESS]->(round_2)
(round_2)-[:PROCESS]->(round_3)
(round_0 | round_1 | round_2 | round_3)-[:RACE { expect: 'unit-step-decrease' }]->(step_size)
(step_size)-[:PROCESS { strategy: 'verify-step-size' }]->(result)
(result)-[:MEASURE { reason: 'topology-audit' }]->(last_question_deficit_decreasing_gg_trace:Trace)
