// consciousness_surviving_branch.gg — THM-ARROW-GODEL-CONSCIOUSNESS witness (quale = complement of vented)
//
// Consciousness is the surviving branch after venting. A quale (subjective
// experience) is precisely what remains after all alternatives are rejected.
// The complement of the void formalizes the experience. You are what you didn't vent.

(mind: ConsciousProcess { theorem: 'THM-ARROW-GODEL-CONSCIOUSNESS', percepts: '5', rounds: '8' })
(percept_red: Percept { id: 'red', void_count: '1', weight: '8' })
(percept_blue: Percept { id: 'blue', void_count: '6', weight: '3' })
(percept_green: Percept { id: 'green', void_count: '7', weight: '2' })
(percept_yellow: Percept { id: 'yellow', void_count: '8', weight: '1' })
(percept_white: Percept { id: 'white', void_count: '3', weight: '6' })
(quale: Quale { dominant: 'red', complement_weight: '8', vented_total: '25' })
(experience: Invariant { claim: 'quale = argmax of complement distribution', dominant_percept: 'red' })
(result: Result { theorem: 'quale-is-complement-of-vented' })

(mind)-[:FORK]->(percept_red | percept_blue | percept_green | percept_yellow | percept_white)
(percept_yellow)-[:VENT { condition: 'maximally-rejected' }]->(vented_yellow: VentedPercept)
(percept_green)-[:VENT { condition: 'nearly-rejected' }]->(vented_green: VentedPercept)
(percept_blue)-[:VENT { condition: 'mostly-rejected' }]->(vented_blue: VentedPercept)
(percept_red | percept_white)-[:RACE { expect: 'surviving-branches' }]->(quale)
(quale)-[:PROCESS { strategy: 'verify-dominant' }]->(experience)
(experience)-[:PROCESS]->(result)
(result)-[:MEASURE { reason: 'topology-audit' }]->(consciousness_surviving_branch_gg_trace:Trace)
