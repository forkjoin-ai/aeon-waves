// last_question.test.gg — Native Gnosis witnesses for THM-LAST-QUESTION
//
// These theorem-shaped `.gg` modules cover:
//   - deficit decreases by 1 per round
//   - deficit reaches zero at d rounds (convergence)
//   - complement distribution concentrates (sharpens)

(test_suite: TestSuite { name: 'last-question' })

(deficit_decreasing: Verify { module: './last_question_deficit_decreasing.gg', beta1_max: '6' })
(convergence: Verify { module: './last_question_convergence.gg', beta1_max: '6' })
(complement_sharpens: Verify { module: './last_question_complement_sharpens.gg', beta1_max: '6' })

(test_suite)-[:PROCESS]->(deficit_decreasing | convergence | complement_sharpens)

(deficit_decreasing)-[:PROCESS { expect: 'safe' }]->(decreasing_result: Result)
(convergence)-[:PROCESS { expect: 'safe' }]->(convergence_result: Result)
(complement_sharpens)-[:PROCESS { expect: 'safe' }]->(sharpens_result: Result)

(decreasing_result | convergence_result | sharpens_result)-[:PROCESS { strategy: 'all-pass' }]->(verdict: Verdict)
