// whip_wave_duality.test.gg — Native Gnosis witnesses for THM-WHIP-WAVE-DUALITY
//
// These theorem-shaped `.gg` modules cover:
//   - taper accelerates tip (taper_speedup)
//   - total energy conserved (energy_conservation)
//   - fold is isomorphic to wave speed increase (fold_wave_isomorphism)

(test_suite: TestSuite { name: 'whip-wave-duality' })

(taper_speedup: Verify { module: './whip_taper_speedup.gg', beta1_max: '6' })
(energy_conservation: Verify { module: './whip_energy_conservation.gg', beta1_max: '6' })
(fold_wave_iso: Verify { module: './whip_fold_wave_isomorphism.gg', beta1_max: '6' })

(test_suite)-[:PROCESS]->(taper_speedup | energy_conservation | fold_wave_iso)

(taper_speedup)-[:PROCESS { expect: 'safe' }]->(taper_result: Result)
(energy_conservation)-[:PROCESS { expect: 'safe' }]->(energy_result: Result)
(fold_wave_iso)-[:PROCESS { expect: 'safe' }]->(iso_result: Result)

(taper_result | energy_result | iso_result)-[:PROCESS { strategy: 'all-pass' }]->(verdict: Verdict)
