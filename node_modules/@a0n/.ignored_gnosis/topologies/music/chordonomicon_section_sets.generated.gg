(experimental_deformation: TasteTransform { name: 'experimental-deformation', op: 'future overlay', preserves: 'auditable delta from corpus' })
(chordonomicon_section_popularity)-[:BASELINE]->(corpus_pure)
(corpus_pure)-[:OPTIONAL_TRANSFORM]->(human_smoothing | experimental_deformation)

