// chordonomicon_probability_tree.gg
//
// A finite, human-friendly chord-progression topology.
//
// Source data is Chordonomicon-style song chord streams. The topology projects
// chord symbols into six major-key roman functions, counts adjacent transitions,
// applies a positive-mass floor, and normalizes each row to 100 Nat units. The
// resulting row-stochastic kernel can steer runtime chord motion and can be
// mirrored in Lean as finite probability arithmetic.

(source: ChordonomiconCorpus {
  repository: 'spyroskantarelis/chordonomicon',
  dataset: 'ailsntua/Chordonomicon',
  projection: 'major-key roman functions',
  functions: '[I, ii, iii, IV, V, vi]'
})

(parse_streams: Logic { op: 'parse_chord_symbols', accepts: 'Chordonomicon chord strings' })
(infer_key: Logic { op: 'infer_major_tonic', score: 'diatonic root + quality compatibility' })
(project_roman: Logic { op: 'project_to_six_functions', floor: 'drop non-diatonic roots' })
(count_edges: Logic { op: 'count_adjacent_transitions' })
(smooth_rows: Logic { op: 'positive_floor', floor_mass: '1', reason: 'clinamen keeps every path alive' })
(normalize_rows: Logic { op: 'row_normalize', row_mass: '100' })
(kernel: FiniteStochasticKernel { rows: '6', row_mass: '100', input_mass: '600', output_mass: '600', lost_mass: '0' })

(source)-[:PROCESS]->(parse_streams)
(parse_streams)-[:PROCESS]->(infer_key)
(infer_key)-[:PROCESS]->(project_roman)
(project_roman)-[:PROCESS]->(count_edges)
(count_edges)-[:PROCESS]->(smooth_rows)
(smooth_rows)-[:PROCESS]->(normalize_rows)
(normalize_rows)-[:PROCESS]->(kernel)

// ── Roman-function states ───────────────────────────────────────────────────

(chord_I: RomanFunction { symbol: 'I', class: 'tonic', row: '[10,15,10,30,25,10]', row_sum: '100' })
(chord_ii: RomanFunction { symbol: 'ii', class: 'predominant', row: '[10,10,5,15,50,10]', row_sum: '100' })
(chord_iii: RomanFunction { symbol: 'iii', class: 'tonic', row: '[15,25,5,10,10,35]', row_sum: '100' })
(chord_IV: RomanFunction { symbol: 'IV', class: 'predominant', row: '[30,10,10,10,30,10]', row_sum: '100' })
(chord_V: RomanFunction { symbol: 'V', class: 'dominant', row: '[60,5,5,10,10,10]', row_sum: '100' })
(chord_vi: RomanFunction { symbol: 'vi', class: 'tonic', row: '[15,20,15,30,10,10]', row_sum: '100' })

(kernel)-[:FORK]->(chord_I | chord_ii | chord_iii | chord_IV | chord_V | chord_vi)

// ── Functional gravity: tonic -> predominant -> dominant -> tonic ───────────

(tonic: FunctionClass { name: 'tonic', members: '[I, iii, vi]' })
(predominant: FunctionClass { name: 'predominant', members: '[ii, IV]' })
(dominant: FunctionClass { name: 'dominant', members: '[V]' })

(chord_I | chord_iii | chord_vi)-[:FOLD { strategy: 'classify' }]->(tonic)
(chord_ii | chord_IV)-[:FOLD { strategy: 'classify' }]->(predominant)
(chord_V)-[:PROCESS]->(dominant)

(tonic)-[:GRAVITY { bonus: '8', phrase_role: 'depart' }]->(predominant)
(predominant)-[:GRAVITY { bonus: '10', phrase_role: 'prepare' }]->(dominant)
(dominant)-[:GRAVITY { bonus: '14', phrase_role: 'resolve' }]->(tonic)

// ── Row edges, using the prompt baseline as an auditable seed matrix ─────────

(chord_I)-[:TRANSITION { to: 'I', weight: '10', p: '0.10' }]->(chord_I)
(chord_I)-[:TRANSITION { to: 'ii', weight: '15', p: '0.15' }]->(chord_ii)
(chord_I)-[:TRANSITION { to: 'iii', weight: '10', p: '0.10', entropy: 'high' }]->(chord_iii)
(chord_I)-[:TRANSITION { to: 'IV', weight: '30', p: '0.30' }]->(chord_IV)
(chord_I)-[:TRANSITION { to: 'V', weight: '25', p: '0.25' }]->(chord_V)
(chord_I)-[:TRANSITION { to: 'vi', weight: '10', p: '0.10', entropy: 'high' }]->(chord_vi)

(chord_ii)-[:TRANSITION { to: 'I', weight: '10', p: '0.10', entropy: 'high' }]->(chord_I)
(chord_ii)-[:TRANSITION { to: 'ii', weight: '10', p: '0.10', entropy: 'high' }]->(chord_ii)
(chord_ii)-[:TRANSITION { to: 'iii', weight: '5', p: '0.05', entropy: 'high' }]->(chord_iii)
(chord_ii)-[:TRANSITION { to: 'IV', weight: '15', p: '0.15' }]->(chord_IV)
(chord_ii)-[:TRANSITION { to: 'V', weight: '50', p: '0.50', gravity: 'predominant-to-dominant' }]->(chord_V)
(chord_ii)-[:TRANSITION { to: 'vi', weight: '10', p: '0.10', entropy: 'high' }]->(chord_vi)

(chord_iii)-[:TRANSITION { to: 'I', weight: '15', p: '0.15' }]->(chord_I)
(chord_iii)-[:TRANSITION { to: 'ii', weight: '25', p: '0.25' }]->(chord_ii)
(chord_iii)-[:TRANSITION { to: 'iii', weight: '5', p: '0.05', entropy: 'high' }]->(chord_iii)
(chord_iii)-[:TRANSITION { to: 'IV', weight: '10', p: '0.10', entropy: 'high' }]->(chord_IV)
(chord_iii)-[:TRANSITION { to: 'V', weight: '10', p: '0.10', entropy: 'high' }]->(chord_V)
(chord_iii)-[:TRANSITION { to: 'vi', weight: '35', p: '0.35' }]->(chord_vi)

(chord_IV)-[:TRANSITION { to: 'I', weight: '30', p: '0.30' }]->(chord_I)
(chord_IV)-[:TRANSITION { to: 'ii', weight: '10', p: '0.10', entropy: 'high' }]->(chord_ii)
(chord_IV)-[:TRANSITION { to: 'iii', weight: '10', p: '0.10', entropy: 'high' }]->(chord_iii)
(chord_IV)-[:TRANSITION { to: 'IV', weight: '10', p: '0.10', entropy: 'high' }]->(chord_IV)
(chord_IV)-[:TRANSITION { to: 'V', weight: '30', p: '0.30' }]->(chord_V)
(chord_IV)-[:TRANSITION { to: 'vi', weight: '10', p: '0.10', entropy: 'high' }]->(chord_vi)

(chord_V)-[:TRANSITION { to: 'I', weight: '60', p: '0.60', gravity: 'dominant-resolution' }]->(chord_I)
(chord_V)-[:TRANSITION { to: 'ii', weight: '5', p: '0.05', entropy: 'high' }]->(chord_ii)
(chord_V)-[:TRANSITION { to: 'iii', weight: '5', p: '0.05', entropy: 'high' }]->(chord_iii)
(chord_V)-[:TRANSITION { to: 'IV', weight: '10', p: '0.10', entropy: 'high' }]->(chord_IV)
(chord_V)-[:TRANSITION { to: 'V', weight: '10', p: '0.10', entropy: 'high' }]->(chord_V)
(chord_V)-[:TRANSITION { to: 'vi', weight: '10', p: '0.10', entropy: 'high' }]->(chord_vi)

(chord_vi)-[:TRANSITION { to: 'I', weight: '15', p: '0.15' }]->(chord_I)
(chord_vi)-[:TRANSITION { to: 'ii', weight: '20', p: '0.20' }]->(chord_ii)
(chord_vi)-[:TRANSITION { to: 'iii', weight: '15', p: '0.15' }]->(chord_iii)
(chord_vi)-[:TRANSITION { to: 'IV', weight: '30', p: '0.30' }]->(chord_IV)
(chord_vi)-[:TRANSITION { to: 'V', weight: '10', p: '0.10', entropy: 'high' }]->(chord_V)
(chord_vi)-[:TRANSITION { to: 'vi', weight: '10', p: '0.10', entropy: 'high' }]->(chord_vi)

// ── Runtime steering surface ────────────────────────────────────────────────

(syncopation: RhythmLattice { meter: '4/4', pulse: 'eighth', swing: 'long-short', syncopation: 'weak attack tied/rested over stronger pulse' })
(bpm_control: TempoControl { min_bpm: '54', default_bpm: '100', max_bpm: '168', time_multipliers: '[1,2,3]', max_effective_bpm: '504', clamp: 'nearest integer base BPM, discrete multiplier' })
(beat_lock: RhythmLattice { meter: '4/4', pulse: 'quarter', swing: 'none', emission: 'metric beats only' })
(trading: PhraseAutomaton { trades: '[4 bars, 8 bars]', roles: '[call, response]' })
(song_sets: SectionChordVocabulary { verse: '[I, IV]', chorus: '[I, V, vi, IV]', bridge: '[vi, IV, I, V]', solo: '[I, IV]' })
(generated_section_sets: ChordonomiconSectionPopularity {
  file: 'open-source/gnosis/topologies/music/chordonomicon_section_sets.generated.gg',
  songs: '679807',
  tagged_songs: '397580',
  projected_sections: '2661950',
  slices: '[global, mainGenre, decade]',
  length_policy: 'shortest exact section cycle, else full compressed phrase',
  taste_policy: 'corpus-pure baseline with explicit transform overlays'
})
(section_automaton: FiniteAutomaton { state: 'SongSection x sectionBar mod empirical_phrase_length x role', emit: 'RomanChord', period: 'corpus-ranked candidate length' })
(verse_cycle: CycleWitness { section: 'verse', call: '[I, IV]', response: '[IV, I]' })
(chorus_cycle: CycleWitness { section: 'chorus', call: '[I, V, vi, IV]', two_cycles: '[I, V, vi, IV, I, V, vi, IV]' })
(bridge_cycle: CycleWitness { section: 'bridge', call: '[vi, IV, I, V]' })
(section_query: MusicAttentionQuery { q: 'SongSection x FlowRegime x TradeRole x bar_phase', asks: 'what harmonic value should survive now' })
(corpus_keys: MusicAttentionKeys { k: 'section x genre_slice x decade_slice x corpus_rank x phrase_length', weights: 'Chordonomicon counts' })
(chord_values: MusicAttentionValues { v: 'RomanChord vocabulary emitted to harp', gate: 'song_set_lock + chord_count + rank' })
(taste_router: MixtureOfAttentionRouter { experts: '[global, genre, decade, corpus_pure, human_smoothing, experimental]', route: 'ranked key merge; weights remain priors' })
(harp_tao_bowl: TaoBowlConstraint { rim: 'pluck/partials/attacks', void: 'delay-line rests and decay space', damping: 'lowpass/release', purpose: 'pleasant resonance without filled-bowl mud' })
(steering: RuntimePolicy { op: 'weighted_chord_walk_or_song_set', deterministic_seed: 'bar+pulse+current_chord', role_bias: 'call resolves, response colors' })
(result: Result { theorem: 'chordonomicon-progression-kernel-lossless', rows: 'stochastic', high_entropy_markers: 'present' })

(song_sets)-[:MATERIALIZES]->(section_automaton)
(generated_section_sets)-[:REPLACES_PRIOR { reason: 'data-derived popularity tree' }]->(song_sets)
(source)-[:GENERATES]->(generated_section_sets)
(section_automaton)-[:EMITS]->(verse_cycle | chorus_cycle | bridge_cycle)
(section_query)-[:ATTENDS_TO]->(corpus_keys)
(corpus_keys)-[:GATES]->(chord_values)
(taste_router)-[:ROUTES]->(corpus_keys)
(harp_tao_bowl)-[:CONSTRAINS]->(chord_values)
(syncopation | bpm_control | beat_lock | trading | song_sets | section_automaton | kernel)-[:FOLD { strategy: 'human-friendly-patterns' }]->(steering)
(section_query | corpus_keys | chord_values | taste_router | harp_tao_bowl)-[:FOLD { strategy: 'qkv-moa-tao-bowl-bridge' }]->(steering)
(steering)-[:PROCESS]->(result)
(result)-[:TUNNEL { condition: 'bounded-reject' }]->(chordonomicon_probability_tree_gg_trace:Trace)
(result)-[:MEASURE { reason: 'topology-audit' }]->(chordonomicon_probability_tree_gg_trace:Trace)
