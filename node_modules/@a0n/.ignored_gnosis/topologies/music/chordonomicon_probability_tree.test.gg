// chordonomicon_probability_tree.test.gg

(test_suite: TestSuite { name: 'chordonomicon-probability-tree' })

(probability_tree: Verify { module: './chordonomicon_probability_tree.gg', beta1_max: '8' })
(row_stochastic: Invariant { claim: 'each roman-function row sums to 100', rows: '6', row_mass: '100' })
(lossless_kernel: Invariant { claim: 'kernel input mass equals output mass', input_mass: '600', output_mass: '600', lost_mass: '0' })
(gravity_edges: Invariant { claim: 'tonic->predominant->dominant->tonic gravity present' })
(entropy_markers: Invariant { claim: 'low-probability transitions remain explicit high-entropy color' })
(song_set_cycles: Invariant { claim: 'section chord vocabularies emit finite four-bar song cycles', verse: '[I, vi, IV, V]', chorus: '[I, V, vi, IV]', bridge: '[ii, V, iii, vi]' })
(beat_lock_shape: Invariant { claim: 'beat-lock mode emits on metric quarter-pulses and suppresses odd eighth drift' })

(test_suite)-[:FORK]->(probability_tree | row_stochastic | lossless_kernel | gravity_edges | entropy_markers | song_set_cycles | beat_lock_shape)

(probability_tree)-[:RACE { expect: 'safe' }]->(tree_result: Result)
(row_stochastic | lossless_kernel)-[:FOLD { strategy: 'finite-kernel-accounting' }]->(kernel_result: Result)
(gravity_edges | entropy_markers)-[:FOLD { strategy: 'musical-humanity' }]->(music_result: Result)
(song_set_cycles | beat_lock_shape)-[:FOLD { strategy: 'runtime-shape-controls' }]->(shape_result: Result)

(tree_result | kernel_result | music_result | shape_result)-[:FOLD { strategy: 'all-pass' }]->(verdict: Verdict)
(verdict)-[:TUNNEL { condition: 'bounded-reject' }]->(chordonomicon_probability_tree_test_gg_trace:Trace)
(verdict)-[:MEASURE { reason: 'topology-audit' }]->(chordonomicon_probability_tree_test_gg_trace:Trace)
