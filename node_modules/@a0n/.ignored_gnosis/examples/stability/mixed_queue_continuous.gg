(traffic:Source { pressure: "lambda" })
(queue:State { potential: "beta1" })
(complete:Sink { beta1_target: "0", capacity: "64" })
(traffic)-[:PROCESS { weight: "1.0" }]->(queue)
(queue)-[:PROCESS { service_rate: "mu", drift_gamma: "1.0" }]->(complete)
