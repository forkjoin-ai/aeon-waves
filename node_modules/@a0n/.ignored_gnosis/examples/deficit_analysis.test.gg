// deficit_analysis.test.gg -- Verify per-subgraph deficit analysis
// Phase 4: Intentional wasted parallelism

(test_suite:TestSuite { name: 'deficit_analysis' })

// Fork with intentionally unclosed paths
(source:Source { void_density: '1.0' })
(source)-[:FORK]->(a | b | c)

// Only fold two of three -- one path is wasted
(a | b)-[:FOLD { strategy: 'merge' }]->(partial:Result)

// c is left dangling -- deficit = 1 at the leaf
// The deficit diagnostic should fire on node 'c'

(partial)-[:PROCESS]->(sink:Sink)
(sink)-[:TUNNEL { condition: 'bounded-reject' }]->(deficit_analysis_test_gg_trace:Trace)
(sink)-[:MEASURE { reason: 'topology-audit' }]->(deficit_analysis_test_gg_trace:Trace)
