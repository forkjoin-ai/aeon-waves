// kv-cache.gg — Key-Value Cache for Autoregressive Generation
//
// During generation, we don't recompute attention for past tokens.
// The KV cache stores computed keys and values. New tokens fork
// into fresh K/V computation, then fold with the cached values.
//
// This is where fork/race/fold shines: the cache lookup and the
// new computation RACE — whoever finishes first contributes.
// In practice the cache always wins for past tokens (instant),
// and the fresh computation wins for the new token.
//
// β₁ = 1 (one fork: cached vs fresh)

(new_token: Tensor)
(cached_keys: KVStore { role: 'keys' })
(cached_values: KVStore { role: 'values' })

// Compute fresh K/V for the new token
(new_token)-[:PROCESS]->(fresh_key: Projection { role: 'K' })
(new_token)-[:PROCESS]->(fresh_value: Projection { role: 'V' })

// Append fresh to cache (fold = concat along sequence dim)
(cached_keys | fresh_key)-[:FOLD { strategy: 'concat-seq' }]->(full_keys)
(cached_values | fresh_value)-[:FOLD { strategy: 'concat-seq' }]->(full_values)

// Compute Q only for the new token (no cache needed)
(new_token)-[:PROCESS]->(query: Projection { role: 'Q' })

// Attention with full K/V but single Q
(query)-[:PROCESS]->(attn: ScaledDotProduct { causal: 'true' })
(full_keys)-[:PROCESS]->(attn)
(full_values)-[:PROCESS]->(attn)
(attn)-[:PROCESS]->(kv_out)
(kv_out)-[:MEASURE { reason: 'topology-audit' }]->(kv_cache_gg_trace:Trace)
