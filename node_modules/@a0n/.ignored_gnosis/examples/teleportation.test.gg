// teleportation.test.gg -- Verify statistical teleportation
// Phase 5: TUNNEL with teleport sends only deficit

(test_suite:TestSuite { name: 'teleportation' })

(source:Source { void_density: '1.0' })
(source)-[:FORK]->(fast | slow)

// Fast path computes locally
(fast)-[:PROCESS]->(fast_result)

// Slow path teleports its deficit to reconstruct remotely
(slow)-[:TUNNEL { teleport: 'true' }]->(remote_result)

// Fold both results
(fast_result | remote_result)-[:FOLD { strategy: 'merge' }]->(final:Sink)
(final)-[:MEASURE { reason: 'topology-audit' }]->(teleportation_test_gg_trace:Trace)
