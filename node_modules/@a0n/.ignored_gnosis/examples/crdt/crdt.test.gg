// crdt.test.gg — Convergence proofs for all Quantum CRDT types
// The test formalizes the topology. Fork/race/fold all the way down.
// Each Verify node proves: all FORK paths reach beta1=0 after OBSERVE.

(test_suite: TestSuite)

// FORK: verify each CRDT type independently
(test_suite)-[:FORK]->(register | counter | set | sequence | map | entangle | sync_proof)

// Each module is verified by the model checker
(register: Verify { module: './qregister.gg', beta1_max: '10' })
(counter: Verify { module: './qcounter.gg', beta1_max: '10' })
(set: Verify { module: './qset.gg', beta1_max: '10' })
(sequence: Verify { module: './qsequence.gg', beta1_max: '10' })
(map: Verify { module: './qmap.gg', beta1_max: '10' })
(entangle: Verify { module: './entanglement.gg', beta1_max: '10' })
(sync_proof: Verify { module: './sync.gg', beta1_max: '10' })

// FOLD: all must pass
(register | counter | set | sequence | map | entangle | sync_proof)-[:FOLD { strategy: 'all-pass' }]->(verdict)

(verdict: Verdict)
(verdict)-[:TUNNEL { condition: 'bounded-reject' }]->(crdt_test_gg_trace:Trace)
(verdict)-[:MEASURE { reason: 'topology-audit' }]->(crdt_test_gg_trace:Trace)
