// crypto-cover-space.test.gg -- GG verification suite for the crypto corpus

(test_suite: TestSuite { name: 'crypto-cover-space' })
(ucan_secure: Verify { module: './ucan-zk-secure.gg', beta1_max: '8' })
(ucan_weak: Verify { module: './ucan-zk-weak.gg', beta1_max: '8' })
(ucan_toy: Verify { module: './ucan-zk-toy.gg', beta1_max: '8' })
(aead_secure: Verify { module: './aead-kem-secure.gg', beta1_max: '8' })
(aead_weak: Verify { module: './aead-kem-weak.gg', beta1_max: '8' })
(aead_toy: Verify { module: './aead-kem-toy.gg', beta1_max: '8' })
(password_digest_secure: Verify { module: './password-digest-secure.gg', beta1_max: '8' })
(password_digest_weak: Verify { module: './password-digest-weak.gg', beta1_max: '8' })
(password_digest_toy: Verify { module: './password-digest-toy.gg', beta1_max: '8' })
(password_digest_md5_toy: Verify { module: './password-digest-md5-toy.gg', beta1_max: '8' })
(password_digest_unsalted_secure: Verify { module: './password-digest-unsalted-secure.gg', beta1_max: '8' })
(password_digest_unsalted_weak: Verify { module: './password-digest-unsalted-weak.gg', beta1_max: '8' })
(password_digest_low_work_secure: Verify { module: './password-digest-low-work-secure.gg', beta1_max: '8' })
(password_digest_low_work_weak: Verify { module: './password-digest-low-work-weak.gg', beta1_max: '8' })
(password_digest_truncated_secure: Verify { module: './password-digest-truncated-secure.gg', beta1_max: '8' })
(password_digest_truncated_weak: Verify { module: './password-digest-truncated-weak.gg', beta1_max: '8' })
(recovery_trust_secure: Verify { module: './recovery-trust-secure.gg', beta1_max: '8' })
(recovery_trust_weak: Verify { module: './recovery-trust-weak.gg', beta1_max: '8' })
(recovery_trust_toy: Verify { module: './recovery-trust-toy.gg', beta1_max: '8' })
(sign_secure: Verify { module: './signing-custodial-secure.gg', beta1_max: '8' })
(sign_weak: Verify { module: './signing-custodial-weak.gg', beta1_max: '8' })
(sign_toy: Verify { module: './signing-custodial-toy.gg', beta1_max: '8' })

(test_suite)-[:FORK]->(ucan_secure | ucan_weak | ucan_toy | aead_secure | aead_weak | aead_toy | password_digest_secure | password_digest_weak | password_digest_toy | password_digest_md5_toy | password_digest_unsalted_secure | password_digest_unsalted_weak | password_digest_low_work_secure | password_digest_low_work_weak | password_digest_truncated_secure | password_digest_truncated_weak | recovery_trust_secure | recovery_trust_weak | recovery_trust_toy | sign_secure | sign_weak | sign_toy)

(ucan_secure)-[:RACE { expect: 'safe' }]->(ucan_secure_result: Result)
(ucan_weak)-[:RACE { expect: 'safe' }]->(ucan_weak_result: Result)
(ucan_toy)-[:RACE { expect: 'safe' }]->(ucan_toy_result: Result)
(aead_secure)-[:RACE { expect: 'safe' }]->(aead_secure_result: Result)
(aead_weak)-[:RACE { expect: 'safe' }]->(aead_weak_result: Result)
(aead_toy)-[:RACE { expect: 'safe' }]->(aead_toy_result: Result)
(password_digest_secure)-[:RACE { expect: 'safe' }]->(password_digest_secure_result: Result)
(password_digest_weak)-[:RACE { expect: 'safe' }]->(password_digest_weak_result: Result)
(password_digest_toy)-[:RACE { expect: 'safe' }]->(password_digest_toy_result: Result)
(password_digest_md5_toy)-[:RACE { expect: 'safe' }]->(password_digest_md5_toy_result: Result)
(password_digest_unsalted_secure)-[:RACE { expect: 'safe' }]->(password_digest_unsalted_secure_result: Result)
(password_digest_unsalted_weak)-[:RACE { expect: 'safe' }]->(password_digest_unsalted_weak_result: Result)
(password_digest_low_work_secure)-[:RACE { expect: 'safe' }]->(password_digest_low_work_secure_result: Result)
(password_digest_low_work_weak)-[:RACE { expect: 'safe' }]->(password_digest_low_work_weak_result: Result)
(password_digest_truncated_secure)-[:RACE { expect: 'safe' }]->(password_digest_truncated_secure_result: Result)
(password_digest_truncated_weak)-[:RACE { expect: 'safe' }]->(password_digest_truncated_weak_result: Result)
(recovery_trust_secure)-[:RACE { expect: 'safe' }]->(recovery_trust_secure_result: Result)
(recovery_trust_weak)-[:RACE { expect: 'safe' }]->(recovery_trust_weak_result: Result)
(recovery_trust_toy)-[:RACE { expect: 'safe' }]->(recovery_trust_toy_result: Result)
(sign_secure)-[:RACE { expect: 'safe' }]->(sign_secure_result: Result)
(sign_weak)-[:RACE { expect: 'safe' }]->(sign_weak_result: Result)
(sign_toy)-[:RACE { expect: 'safe' }]->(sign_toy_result: Result)

(ucan_secure_result | ucan_weak_result | ucan_toy_result | aead_secure_result | aead_weak_result | aead_toy_result | password_digest_secure_result | password_digest_weak_result | password_digest_toy_result | password_digest_md5_toy_result | password_digest_unsalted_secure_result | password_digest_unsalted_weak_result | password_digest_low_work_secure_result | password_digest_low_work_weak_result | password_digest_truncated_secure_result | password_digest_truncated_weak_result | recovery_trust_secure_result | recovery_trust_weak_result | recovery_trust_toy_result | sign_secure_result | sign_weak_result | sign_toy_result)-[:FOLD { strategy: 'all-pass' }]->(verdict: Verdict)
(verdict)-[:TUNNEL { condition: 'bounded-reject' }]->(crypto_cover_space_test_gg_trace:Trace)
(verdict)-[:MEASURE { reason: 'topology-audit' }]->(crypto_cover_space_test_gg_trace:Trace)
