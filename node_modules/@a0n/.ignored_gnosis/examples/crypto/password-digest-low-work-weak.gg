// password-digest-low-work-weak.gg -- low-work password derivation surface

(secret: Secret { purpose: 'password' })
(derive: KDF {
  purpose: 'password',
  algorithm: 'pbkdf2-sha256',
  iterations: '1000',
  saltBytes: '16'
})
(nonce: Nonce { reuse: 'false' })
(proof: Proof { verified: 'true' })
(digest: Digest {
  purpose: 'password',
  algorithm: 'pbkdf2-sha256',
  salted: 'true',
  saltBytes: '16'
})
(record: Envelope { replayGuard: 'true' })

(secret)-[:PROCESS]->(derive)-[:PROCESS]->(nonce)-[:PROCESS]->(proof)-[:PROCESS]->(digest)-[:PROCESS]->(record)
