// password-digest-toy.gg -- reduced-strength password digest calibration surface

(secret: Secret { purpose: 'password' })
(derive: KDF {
  purpose: 'password',
  algorithm: 'reduced-argon2id',
  iterations: '3',
  memoryKb: '65536',
  saltBytes: '16',
  toy: 'true'
})
(nonce: Nonce { reuse: 'false' })
(proof: Proof { verified: 'true' })
(digest: Digest {
  purpose: 'password',
  algorithm: 'reduced-argon2id',
  salted: 'true',
  saltBytes: '16',
  toy: 'true'
})
(record: Envelope { replayGuard: 'true' })

(secret)-[:PROCESS]->(derive)-[:PROCESS]->(nonce)-[:PROCESS]->(proof)-[:PROCESS]->(digest)-[:PROCESS]->(record)
