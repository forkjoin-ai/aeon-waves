// fold-training.test.gg
// Formal verification suite for the parameter-matched fold benchmark modules.

(test_suite: TestSuite { name: 'fold-training-benchmark' })
(linear_fold: Verify { module: './fold-training-linear.gg', beta1_max: '8' })
(winner_fold: Verify { module: './fold-training-winner-take-all.gg', beta1_max: '8' })
(early_fold: Verify { module: './fold-training-early-stop.gg', beta1_max: '8' })

(test_suite)-[:FORK]->(linear_fold | winner_fold | early_fold)

(linear_fold)-[:RACE { expect: 'safe' }]->(linear_result: Result)
(winner_fold)-[:RACE { expect: 'safe' }]->(winner_result: Result)
(early_fold)-[:RACE { expect: 'safe' }]->(early_result: Result)

(linear_result | winner_result | early_result)-[:FOLD { strategy: 'all-pass' }]->(verdict: Verdict)
(verdict)-[:TUNNEL { condition: 'bounded-reject' }]->(fold_training_test_gg_trace:Trace)
(verdict)-[:MEASURE { reason: 'topology-audit' }]->(fold_training_test_gg_trace:Trace)
