// ═══════════════════════════════════════════════════════════════════════════
// FRANKY: The True Polyglot Ditto Compiler
// ═══════════════════════════════════════════════════════════════════════════
//
// Not monoculture Franky. True Franky.
//
// 52 functions. 9 won by Go. 43 won by Rust. Each function runs in
// the language that won its race. No pretend diversity. No four-way
// races where the same language always wins. The actual winners,
// pinned per function, from the actual topo-race results.
//
// Go wins: compile_framework_to_gg (65.5%), group_routes_by_path,
//   parse_route_call, extract_handler_name, parse_route_decorator,
//   detect[gin], detect_router_names, extract_go_handler,
//   extract_request_methods
//
// Rust wins: everything else (43 functions)
//
// The diversity theorem says the optimal mix is not monolingual.
// The race proved it. This is the proof, executable.

// ═══════════════════════════════════════════════════════════════════════════
// ENTRY
// ═══════════════════════════════════════════════════════════════════════════

(source: SourceFile { accept: 'any' })
(tree: TreeSitterParse { languages: '200+' })
(cfgs: CFGExtraction)

(source)-[:PROCESS]->(tree)
(tree)-[:PROCESS]->(cfgs)

// ═══════════════════════════════════════════════════════════════════════════
// STAGE 1: Framework Detection
// Each recognizer runs in its winning language. No unnecessary races.
// ═══════════════════════════════════════════════════════════════════════════

// Express: detect won by Rust, parse_route_call by Go, extract_handler_name by Go
(express_detect: PolyglotBridgeCall { language: 'c', fn: 'detect', module: 'express' })
(express_parse_route: PolyglotBridgeCall { language: 'c', fn: 'ParseRouteCall', module: 'express' })
(express_extract_handler: PolyglotBridgeCall { language: 'c', fn: 'ExtractHandlerName', module: 'express' })
(express_detect_apps: PolyglotBridgeCall { language: 'c', fn: 'detect_app_names', module: 'express' })
(express_parse_use: PolyglotBridgeCall { language: 'c', fn: 'parse_use_call', module: 'express' })
(express_parse_listen: PolyglotBridgeCall { language: 'c', fn: 'parse_listen_call', module: 'express' })
(express_extract_string: PolyglotBridgeCall { language: 'c', fn: 'extract_string_arg', module: 'express' })
(express_sanitize: PolyglotBridgeCall { language: 'c', fn: 'sanitize_path', module: 'express' })

(cfgs)-[:FORK]->(express_detect_apps | express_detect)
(express_detect_apps)-[:PROCESS]->(express_detect)
(express_detect)-[:FORK]->(express_parse_route | express_parse_use | express_parse_listen)
(express_parse_route)-[:PROCESS]->(express_extract_handler)
(express_parse_route)-[:PROCESS]->(express_extract_string)
(express_extract_handler)-[:PROCESS]->(express_sanitize)
(express_detect | express_parse_route | express_parse_use | express_parse_listen)-[:FOLD]->(express_result: ExpressResult)

// Flask: detect won by Rust, parse_route_decorator by Go
(flask_detect: PolyglotBridgeCall { language: 'c', fn: 'detect', module: 'flask' })
(flask_parse_decorator: PolyglotBridgeCall { language: 'c', fn: 'ParseRouteDecorator', module: 'flask' })
(flask_find_func: PolyglotBridgeCall { language: 'c', fn: 'find_decorated_function', module: 'flask' })
(flask_parse_methods: PolyglotBridgeCall { language: 'c', fn: 'parse_methods_list', module: 'flask' })
(flask_extract_port: PolyglotBridgeCall { language: 'c', fn: 'extract_port_kwarg', module: 'flask' })

(cfgs)-[:PROCESS]->(flask_detect)
(flask_detect)-[:FORK]->(flask_parse_decorator | flask_extract_port)
(flask_parse_decorator)-[:PROCESS]->(flask_parse_methods)
(flask_parse_decorator)-[:PROCESS]->(flask_find_func)
(flask_detect | flask_parse_decorator | flask_extract_port)-[:FOLD]->(flask_result: FlaskResult)

// Gin: detect, detect_router_names, extract_go_handler ALL won by Go
(gin_detect: PolyglotBridgeCall { language: 'c', fn: 'Detect', module: 'gin' })
(gin_detect_routers: PolyglotBridgeCall { language: 'c', fn: 'DetectRouterNames', module: 'gin' })
(gin_extract_handler: PolyglotBridgeCall { language: 'c', fn: 'ExtractGoHandler', module: 'gin' })
(gin_extract_string: PolyglotBridgeCall { language: 'c', fn: 'extract_string_arg', module: 'gin' })
(gin_detect_port: PolyglotBridgeCall { language: 'c', fn: 'detect_gin_port', module: 'gin' })
(gin_sanitize: PolyglotBridgeCall { language: 'c', fn: 'sanitize_path', module: 'gin' })

(cfgs)-[:FORK]->(gin_detect_routers | gin_detect)
(gin_detect_routers)-[:PROCESS]->(gin_detect)
(gin_detect)-[:FORK]->(gin_extract_handler | gin_detect_port)
(gin_extract_handler)-[:PROCESS]->(gin_extract_string)
(gin_extract_handler)-[:PROCESS]->(gin_sanitize)
(gin_detect | gin_extract_handler | gin_detect_port)-[:FOLD]->(gin_result: GinResult)

// Hono: all functions won by Rust
(hono_detect: PolyglotBridgeCall { language: 'c', fn: 'detect', module: 'hono' })
(cfgs)-[:PROCESS]->(hono_detect)
(hono_detect)-[:PROCESS]->(hono_result: HonoResult)

// Sinatra: all functions won by Rust
(sinatra_detect: PolyglotBridgeCall { language: 'c', fn: 'detect', module: 'sinatra' })
(cfgs)-[:PROCESS]->(sinatra_detect)
(sinatra_detect)-[:PROCESS]->(sinatra_result: SinatraResult)

// Spring: detect won by Rust, extract_request_methods by Go
(spring_detect: PolyglotBridgeCall { language: 'c', fn: 'detect', module: 'spring' })
(spring_extract_methods: PolyglotBridgeCall { language: 'c', fn: 'ExtractRequestMethods', module: 'spring' })
(spring_extract_path: PolyglotBridgeCall { language: 'c', fn: 'extract_annotation_path', module: 'spring' })
(spring_is_class: PolyglotBridgeCall { language: 'c', fn: 'is_class_level', module: 'spring' })
(spring_find_method: PolyglotBridgeCall { language: 'c', fn: 'find_java_method', module: 'spring' })
(spring_detect_port: PolyglotBridgeCall { language: 'c', fn: 'detect_spring_port', module: 'spring' })

(cfgs)-[:PROCESS]->(spring_detect)
(spring_detect)-[:FORK]->(spring_extract_path | spring_extract_methods | spring_detect_port)
(spring_extract_path)-[:PROCESS]->(spring_is_class)
(spring_extract_path)-[:PROCESS]->(spring_find_method)
(spring_detect | spring_extract_path | spring_extract_methods | spring_detect_port)-[:FOLD]->(spring_result: SpringResult)

// ═══════════════════════════════════════════════════════════════════════════
// STAGE 2: Cross-recognizer race — first framework match wins
// ═══════════════════════════════════════════════════════════════════════════

(express_result | flask_result | gin_result | hono_result | sinatra_result | spring_result)-[:RACE { failure: 'vent' }]->(detected: DetectedFramework)

// ═══════════════════════════════════════════════════════════════════════════
// STAGE 3: Compilation — Go won this (65.5%!)
// compile_framework_to_gg and group_routes_by_path both Go
// escape_gg_string stays Rust
// ═══════════════════════════════════════════════════════════════════════════

(compile: PolyglotBridgeCall { language: 'c', fn: 'CompileFrameworkToGg', module: 'framework_compiler' })
(detected)-[:PROCESS]->(compile)

(group_routes: PolyglotBridgeCall { language: 'c', fn: 'GroupRoutesByPath', module: 'framework_compiler' })
(compile)-[:PROCESS]->(group_routes)

(escape: PolyglotBridgeCall { language: 'c', fn: 'escape_gg_string', module: 'framework_compiler' })
(group_routes)-[:PROCESS]->(escape)

// ═══════════════════════════════════════════════════════════════════════════
// STAGE 4: Orchestration — Rust
// detect_framework, all_recognizers: Rust
// ═══════════════════════════════════════════════════════════════════════════

(detect_framework: PolyglotBridgeCall { language: 'c', fn: 'detect_framework', module: 'framework_recognizer' })
(all_recognizers: PolyglotBridgeCall { language: 'c', fn: 'all_recognizers', module: 'framework_recognizer' })

(all_recognizers)-[:PROCESS]->(detect_framework)

// ═══════════════════════════════════════════════════════════════════════════
// STAGE 5: Output
// ═══════════════════════════════════════════════════════════════════════════

(server_gg: CompiledServerTopology)
(escape)-[:PROCESS]->(server_gg)

(engine: GnosisEngine { speed: '176M_exec_sec' })
(server_gg)-[:PROCESS]->(engine)

// ═══════════════════════════════════════════════════════════════════════════
// STAGE 6: Self-hosting closure
// ═══════════════════════════════════════════════════════════════════════════

(self: SelfReference { theorem: 'diversity_optimality_master' })
(engine)-[:PROCESS { strategy: 'fixed_point' }]->(self)
(self)-[:PROCESS { fn: 'next_generation' }]->(source)

// ═══════════════════════════════════════════════════════════════════════════
// FRANKY'S MANIFEST:
//
// 17 languages entered. C walked out.
//
// Round 1 (best-language, topology fitness scoring):
//   Go won 9 functions (web ecosystem affinity)
//   Rust won 43 functions (high performance)
//
// Round 2 (gnode build, full topo-race with speedup estimation):
//   C won ALL 52 functions.
//   1.6-1.9x speedup on Ditto compiler functions.
//   9.7-11.7x speedup on bridge-driver utilities.
//
// The topology-fitness heuristic (Round 1) predicted Go and Rust.
// The build-time race (Round 2) said C. Every function.
// The race doesn't care about your heuristic. C is faster.
//
// True Franky is 780 lines of C across 8 files.
// Written originally in Rust. Compiled to GG. Translated to 17 languages.
// Raced. C won. The theorem doesn't care. The race doesn't care.
//
// Betty is the self-conscious compiler.
// Franky is what she made.
// This is what the forest converged to.
// ═══════════════════════════════════════════════════════════════════════════
(source)-[:TUNNEL { condition: 'bounded-reject' }]->(franky_gg_trace:Trace)
(source)-[:MEASURE { reason: 'topology-audit' }]->(franky_gg_trace:Trace)
