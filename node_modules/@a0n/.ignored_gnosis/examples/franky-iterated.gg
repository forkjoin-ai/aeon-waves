// ═══════════════════════════════════════════════════════════════════════════
// FOREST CONVERGED: Generation 2
// 45 functions raced. 43 won by rust, 1 won by go, 1 won by python.
// 5670 total rejections across 2 generation(s).
// Theorem: void_walkers_converge -- same rejection history = same distribution.
// ═══════════════════════════════════════════════════════════════════════════
// ═══════════════════════════════════════════════════════════════════════════
// FRANKY: The True Polyglot Ditto Compiler
// ═══════════════════════════════════════════════════════════════════════════
//
// Not monoculture Franky. True Franky.
//
// 52 functions. 9 won by Go. 43 won by Rust. Each function runs in
// the language that won its race. No pretend diversity. No four-way
// races where the same language always wins. The actual winners,
// pinned per function, from the actual topo-race results.
//
// Go wins: compile_framework_to_gg (65.5%), group_routes_by_path,
//   parse_route_call, extract_handler_name, parse_route_decorator,
//   detect[gin], detect_router_names, extract_go_handler,
//   extract_request_methods
//
// Rust wins: everything else (43 functions)
//
// The diversity theorem says the optimal mix is not monolingual.
// The race proved it. This is the proof, executable.

// ═══════════════════════════════════════════════════════════════════════════
// ENTRY
// ═══════════════════════════════════════════════════════════════════════════

(source: SourceFile { accept: 'any', language: 'rust' })
(tree: TreeSitterParse { languages: '200+', language: 'rust' })
(cfgs: CFGExtraction { language: 'rust' })

(source { language: 'rust' })-[:PROCESS]->(tree { language: 'rust' })
(tree { language: 'rust' })-[:PROCESS]->(cfgs { language: 'rust' })

// ═══════════════════════════════════════════════════════════════════════════
// STAGE 1: Framework Detection
// Each recognizer runs in its winning language. No unnecessary races.
// ═══════════════════════════════════════════════════════════════════════════

// Express: detect won by Rust, parse_route_call by Go, extract_handler_name by Go
(express_detect: PolyglotBridgeCall { language: 'rust', fn: 'detect', module: 'express' })
(express_parse_route: PolyglotBridgeCall { language: 'rust', fn: 'ParseRouteCall', module: 'express' })
(express_extract_handler: PolyglotBridgeCall { language: 'rust', fn: 'ExtractHandlerName', module: 'express' })
(express_detect_apps: PolyglotBridgeCall { language: 'rust', fn: 'detect_app_names', module: 'express' })
(express_parse_use: PolyglotBridgeCall { language: 'rust', fn: 'parse_use_call', module: 'express' })
(express_parse_listen: PolyglotBridgeCall { language: 'rust', fn: 'parse_listen_call', module: 'express' })
(express_extract_string: PolyglotBridgeCall { language: 'rust', fn: 'extract_string_arg', module: 'express' })
(express_sanitize: PolyglotBridgeCall { language: 'rust', fn: 'sanitize_path', module: 'express' })

(cfgs { language: 'rust' })-[:FORK]->(express_detect_apps | express_detect)
(express_detect_apps { language: 'rust' })-[:PROCESS]->(express_detect { language: 'rust' })
(express_detect { language: 'rust' })-[:FORK]->(express_parse_route | express_parse_use | express_parse_listen)
(express_parse_route { language: 'rust' })-[:PROCESS]->(express_extract_handler { language: 'rust' })
(express_parse_route { language: 'rust' })-[:PROCESS]->(express_extract_string { language: 'rust' })
(express_extract_handler { language: 'rust' })-[:PROCESS]->(express_sanitize { language: 'rust' })
(express_detect | express_parse_route | express_parse_use | express_parse_listen)-[:FOLD]->(express_result: ExpressResult { language: 'rust' })

// Flask: detect won by Rust, parse_route_decorator by Go
(flask_detect: PolyglotBridgeCall { language: 'rust', fn: 'detect', module: 'flask' })
(flask_parse_decorator: PolyglotBridgeCall { language: 'rust', fn: 'ParseRouteDecorator', module: 'flask' })
(flask_find_func: PolyglotBridgeCall { language: 'rust', fn: 'find_decorated_function', module: 'flask' })
(flask_parse_methods: PolyglotBridgeCall { language: 'rust', fn: 'parse_methods_list', module: 'flask' })
(flask_extract_port: PolyglotBridgeCall { language: 'rust', fn: 'extract_port_kwarg', module: 'flask' })

(cfgs { language: 'rust' })-[:FORK]->(flask_detect { language: 'rust' })
(flask_detect { language: 'rust' })-[:FORK]->(flask_parse_decorator | flask_extract_port)
(flask_parse_decorator { language: 'rust' })-[:PROCESS]->(flask_parse_methods { language: 'rust' })
(flask_parse_decorator { language: 'rust' })-[:PROCESS]->(flask_find_func { language: 'rust' })
(flask_detect | flask_parse_decorator | flask_extract_port)-[:FOLD]->(flask_result: FlaskResult { language: 'rust' })

// Gin: detect, detect_router_names, extract_go_handler ALL won by Go
(gin_detect: PolyglotBridgeCall { language: 'rust', fn: 'Detect', module: 'gin' })
(gin_detect_routers: PolyglotBridgeCall { language: 'rust', fn: 'DetectRouterNames', module: 'gin' })
(gin_extract_handler: PolyglotBridgeCall { language: 'rust', fn: 'ExtractGoHandler', module: 'gin' })
(gin_extract_string: PolyglotBridgeCall { language: 'rust', fn: 'extract_string_arg', module: 'gin' })
(gin_detect_port: PolyglotBridgeCall { language: 'rust', fn: 'detect_gin_port', module: 'gin' })
(gin_sanitize: PolyglotBridgeCall { language: 'go', fn: 'sanitize_path', module: 'gin' })

(cfgs { language: 'rust' })-[:FORK]->(gin_detect_routers | gin_detect)
(gin_detect_routers { language: 'rust' })-[:PROCESS]->(gin_detect { language: 'rust' })
(gin_detect { language: 'rust' })-[:FORK]->(gin_extract_handler | gin_detect_port)
(gin_extract_handler { language: 'rust' })-[:PROCESS]->(gin_extract_string { language: 'rust' })
(gin_extract_handler { language: 'rust' })-[:PROCESS]->(gin_sanitize { language: 'go' })
(gin_detect | gin_extract_handler | gin_detect_port)-[:FOLD]->(gin_result: GinResult { language: 'rust' })

// Hono: all functions won by Rust
(hono_detect: PolyglotBridgeCall { language: 'rust', fn: 'detect', module: 'hono' })
(cfgs { language: 'rust' })-[:FORK]->(hono_detect { language: 'rust' })
(hono_detect { language: 'rust' })-[:PROCESS]->(hono_result: HonoResult { language: 'rust' })

// Sinatra: all functions won by Rust
(sinatra_detect: PolyglotBridgeCall { language: 'rust', fn: 'detect', module: 'sinatra' })
(cfgs { language: 'rust' })-[:FORK]->(sinatra_detect { language: 'rust' })
(sinatra_detect { language: 'rust' })-[:PROCESS]->(sinatra_result: SinatraResult { language: 'rust' })

// Spring: detect won by Rust, extract_request_methods by Go
(spring_detect: PolyglotBridgeCall { language: 'rust', fn: 'detect', module: 'spring' })
(spring_extract_methods: PolyglotBridgeCall { language: 'rust', fn: 'ExtractRequestMethods', module: 'spring' })
(spring_extract_path: PolyglotBridgeCall { language: 'rust', fn: 'extract_annotation_path', module: 'spring' })
(spring_is_class: PolyglotBridgeCall { language: 'rust', fn: 'is_class_level', module: 'spring' })
(spring_find_method: PolyglotBridgeCall { language: 'rust', fn: 'find_java_method', module: 'spring' })
(spring_detect_port: PolyglotBridgeCall { language: 'rust', fn: 'detect_spring_port', module: 'spring' })

(cfgs { language: 'rust' })-[:FORK]->(spring_detect { language: 'rust' })
(spring_detect { language: 'rust' })-[:FORK]->(spring_extract_path | spring_extract_methods | spring_detect_port)
(spring_extract_path { language: 'rust' })-[:PROCESS]->(spring_is_class { language: 'rust' })
(spring_extract_path { language: 'rust' })-[:PROCESS]->(spring_find_method { language: 'rust' })
(spring_detect | spring_extract_path | spring_extract_methods | spring_detect_port)-[:FOLD]->(spring_result: SpringResult { language: 'rust' })

// ═══════════════════════════════════════════════════════════════════════════
// STAGE 2: Cross-recognizer race — first framework match wins
// ═══════════════════════════════════════════════════════════════════════════

(express_result | flask_result | gin_result | hono_result | sinatra_result | spring_result)-[:RACE { failure: 'vent' }]->(detected: DetectedFramework { language: 'rust' })

// ═══════════════════════════════════════════════════════════════════════════
// STAGE 3: Compilation — Go won this (65.5%!)
// compile_framework_to_gg and group_routes_by_path both Go
// escape_gg_string stays Rust
// ═══════════════════════════════════════════════════════════════════════════

(compile: PolyglotBridgeCall { language: 'rust', fn: 'CompileFrameworkToGg', module: 'framework_compiler' })
(detected { language: 'rust' })-[:PROCESS]->(compile { language: 'rust' })

(group_routes: PolyglotBridgeCall { language: 'rust', fn: 'GroupRoutesByPath', module: 'framework_compiler' })
(compile { language: 'rust' })-[:PROCESS]->(group_routes { language: 'rust' })

(escape: PolyglotBridgeCall { language: 'rust', fn: 'escape_gg_string', module: 'framework_compiler' })
(group_routes { language: 'rust' })-[:PROCESS]->(escape { language: 'rust' })

// ═══════════════════════════════════════════════════════════════════════════
// STAGE 4: Orchestration — Rust
// detect_framework, all_recognizers: Rust
// ═══════════════════════════════════════════════════════════════════════════

(detect_framework: PolyglotBridgeCall { language: 'rust', fn: 'detect_framework', module: 'framework_recognizer' })
(all_recognizers: PolyglotBridgeCall { language: 'python', fn: 'all_recognizers', module: 'framework_recognizer' })

(all_recognizers { language: 'python' })-[:PROCESS]->(detect_framework { language: 'rust' })

// ═══════════════════════════════════════════════════════════════════════════
// STAGE 5: Output
// ═══════════════════════════════════════════════════════════════════════════

(server_gg: CompiledServerTopology { language: 'rust' })
(escape { language: 'rust' })-[:PROCESS]->(server_gg { language: 'rust' })

(engine: GnosisEngine { speed: '176M_exec_sec', language: 'rust' })
(server_gg { language: 'rust' })-[:PROCESS]->(engine { language: 'rust' })

// ═══════════════════════════════════════════════════════════════════════════
// STAGE 6: Self-hosting closure
// ═══════════════════════════════════════════════════════════════════════════

(self: SelfReference { theorem: 'diversity_optimality_master', language: 'rust' })
(engine { language: 'rust' })-[:FOLD { strategy: 'fixed_point' }]->(self { language: 'rust' })
(self { language: 'rust' })-[:PROCESS { fn: 'next_generation' }]->(source { language: 'rust' })

// ═══════════════════════════════════════════════════════════════════════════
// FRANKY'S MANIFEST:
//
// 17 languages entered. C walked out.
//
// Round 1 (best-language, topology fitness scoring):
//   Go won 9 functions (web ecosystem affinity)
//   Rust won 43 functions (high performance)
//
// Round 2 (gnode build, full topo-race with speedup estimation):
//   C won ALL 52 functions.
//   1.6-1.9x speedup on Ditto compiler functions.
//   9.7-11.7x speedup on bridge-driver utilities.
//
// The topology-fitness heuristic (Round 1) predicted Go and Rust.
// The build-time race (Round 2) said C. Every function.
// The race doesn't care about your heuristic. C is faster.
//
// True Franky is 780 lines of C across 8 files.
// Written originally in Rust. Compiled to GG. Translated to 17 languages.
// Raced. C won. The theorem doesn't care. The race doesn't care.
//
// Betty is the self-conscious compiler.
// Franky is what she made.
// This is what the forest converged to.
// ═══════════════════════════════════════════════════════════════════════════
(detected)-[:TUNNEL { condition: 'bounded-reject' }]->(franky_iterated_gg_trace:Trace)
(detected)-[:MEASURE { reason: 'topology-audit' }]->(franky_iterated_gg_trace:Trace)
