// void_tracking.test.gg -- Verify void boundary tracking through FORK/RACE/FOLD
// Phase 1: VoidBoundary as first-class runtime data

(test_suite:TestSuite { name: 'void_tracking' })

// FORK three branches
(source:Source { void_density: '1.0' })
(source)-[:FORK]->(branch_a | branch_b | branch_c)

// RACE them -- two losers should create void entries
(branch_a)-[:PROCESS]->(winner:Result)
(branch_b)-[:PROCESS]->(winner)
(branch_c)-[:PROCESS]->(winner)

// Verify: .void on result should have two rejection entries
(winner)-[:MEASURE]->(metrics:Measure)
(metrics)-[:PROCESS]->(sink:Sink)
