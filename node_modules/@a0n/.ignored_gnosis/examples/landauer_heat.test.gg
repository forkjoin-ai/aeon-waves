// landauer_heat.test.gg -- Verify Landauer heat accounting
// Phase 2: First law enforcement

(test_suite:TestSuite { name: 'landauer_heat' })

// FORK four branches
(source:Source { void_density: '1.0' })
(source)-[:FORK]->(a | b | c | d)

// FOLD two
(a | b)-[:FOLD { strategy: 'merge' }]->(folded:Result)

// VENT one
(c)-[:VENT { reason: 'pruned' }]->(void_sink)

// Process the last
(d)-[:PROCESS]->(processed:Result)

// Collapse remaining
(folded | processed)-[:FOLD { strategy: 'merge' }]->(final:Sink)

// Heat accounting:
//   Fork entropy: log2(4) = 2.0
//   Fold erasure: log2(2) + log2(2) = 2.0
//   Vent erasure: 1.0
//   Total erasure: 3.0
//   First law check: fork entropy (2.0) < erasure (3.0) -- should warn
(final)-[:MEASURE { reason: 'topology-audit' }]->(landauer_heat_test_gg_trace:Trace)
