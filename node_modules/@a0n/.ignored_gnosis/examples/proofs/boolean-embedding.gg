// boolean-embedding.gg -- Boolean is the K=2 special case of Buleyean
//
// Proof that Boolean logic embeds into Buleyean logic:
//   true  = BProp 0 (proved, ground state)
//   false = BProp 1 (one rejection away from proved)
//
// FORK case-splits on the two Boolean values.
// Each case proves the embedding by a single REJECT.
// FOLD composes both cases into QED.
//
// This is THM-BULEYEAN-LOGIC from BuleyeanLogic.lean:
//   bool_roundtrip, bAnd_matches_bool, bOr_matches_bool, bNot_matches_bool

(embed: Theorem { bules: '2', proposition: 'Boolean embeds at K=2' })

// Axioms: the embedding definition
(ax_true: Axiom { bules: '0', proposition: 'true = BProp 0' })
(ax_false: Axiom { bules: '0', proposition: 'false = BProp 1' })

// FORK: case split on Boolean values (2 cases = 2 bules)
(case_true: Lemma { bules: '1', proposition: 'true case' })
(case_false: Lemma { bules: '1', proposition: 'false case' })
(embed)-[:FORK { reason: 'case split on Boolean values' }]->(case_true | case_false)

// Case true: true maps to BProp 0 = proved
(true_qed: Lemma { bules: '0', proposition: 'true roundtrips' })
(case_true)-[:REJECT { reason: 'bToBool(bFromBool true) = true by simp' }]->(true_qed)

// Case false: false maps to BProp 1, which roundtrips
(false_qed: Lemma { bules: '0', proposition: 'false roundtrips' })
(case_false)-[:REJECT { reason: 'bToBool(bFromBool false) = false by simp' }]->(false_qed)

// FOLD: both cases proved
(true_qed | false_qed)-[:FOLD { reason: 'both Boolean values embed correctly' }]->(embed_qed: Theorem { bules: '0', proposition: 'Boolean embedding K=2 QED' })

// At embed_qed: bules = 0. Boolean is the K=2 special case.
// Lean4 emits: theorem bool_roundtrip (b : Bool) : bToBool (bFromBool b) = b
(embed_qed)-[:TUNNEL { condition: 'bounded-reject' }]->(boolean_embedding_gg_trace:Trace)
(embed_qed)-[:MEASURE { reason: 'topology-audit' }]->(boolean_embedding_gg_trace:Trace)
