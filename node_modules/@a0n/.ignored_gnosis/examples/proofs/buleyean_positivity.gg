// buleyean_positivity.gg — THM-BULEYEAN-POSITIVITY witness (the sliver)
//
// weight = rounds - min(void, rounds) + 1 >= 1 for all choices.
// Even maximum rejection (void = rounds) leaves weight = 1.

(space: BuleyeanSpace { theorem: 'THM-BULEYEAN-POSITIVITY', choices: '3', rounds: '10' })
(choice_a: Choice { void_count: '0', weight: '11' })
(choice_b: Choice { void_count: '5', weight: '6' })
(choice_c: Choice { void_count: '10', weight: '1' })
(sliver: Invariant { claim: 'all weights >= 1', min_weight: '1' })
(result: Result { theorem: 'never-say-never' })

(space)-[:FORK]->(choice_a | choice_b | choice_c)
(choice_a | choice_b | choice_c)-[:RACE { expect: 'all-positive' }]->(sliver)
(sliver)-[:PROCESS { strategy: 'verify-minimum' }]->(result)
(result)-[:MEASURE { reason: 'topology-audit' }]->(buleyean_positivity_gg_trace:Trace)
