// AeonFluxSiteAdequacy-lean.gg -- Lean-backed proof topology for the
// Aeon Flux site adequacy family.

(theorem: Theorem { bules: '3', proposition: 'AeonFluxSiteAdequacy' })

(site_surface: Hypothesis { bules: '0', proposition: 'AeonFluxSite declares a positive FlowFrame stream budget' })

(aeon_flux_site_nonpositive_deficit_iff_lossless_transport: Lemma { bules: '1', proposition: 'aeon_flux_site_nonpositive_deficit_iff_lossless_transport' })
(aeon_flux_site_zero_deficit_iff_tight_lossless_transport: Lemma { bules: '1', proposition: 'aeon_flux_site_zero_deficit_iff_tight_lossless_transport' })
(aeon_flux_site_positive_deficit_forces_collision_and_information_loss: Lemma { bules: '1', proposition: 'aeon_flux_site_positive_deficit_forces_collision_and_information_loss' })

(theorem)-[:PROCESS]->(site_surface)
(site_surface)-[:FORK { reason: 'split the adequacy family by deficit regime' }]->(aeon_flux_site_nonpositive_deficit_iff_lossless_transport | aeon_flux_site_zero_deficit_iff_tight_lossless_transport | aeon_flux_site_positive_deficit_forces_collision_and_information_loss)

(nonpositive_qed: Lemma { bules: '0' })
(zero_qed: Lemma { bules: '0' })
(positive_qed: Lemma { bules: '0' })

(aeon_flux_site_nonpositive_deficit_iff_lossless_transport)-[:REJECT { reason: 'proved in Lean 4 (zero sorry)' }]->(nonpositive_qed)
(aeon_flux_site_zero_deficit_iff_tight_lossless_transport)-[:REJECT { reason: 'proved in Lean 4 (zero sorry)' }]->(zero_qed)
(aeon_flux_site_positive_deficit_forces_collision_and_information_loss)-[:REJECT { reason: 'proved in Lean 4 (zero sorry)' }]->(positive_qed)

(nonpositive_qed | zero_qed | positive_qed)-[:FOLD { reason: 'all Aeon Flux site adequacy regimes are discharged' }]->(qed: Theorem { bules: '0', proposition: 'AeonFluxSiteAdequacy QED' })
(qed)-[:TUNNEL { condition: 'bounded-reject' }]->(AeonFluxSiteAdequacy_lean_gg_trace:Trace)
(qed)-[:MEASURE { reason: 'topology-audit' }]->(AeonFluxSiteAdequacy_lean_gg_trace:Trace)
