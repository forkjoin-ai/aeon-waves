// buleyean_evidence.test.gg — Native Gnosis witnesses for THM-BULEYEAN-EVIDENCE
//
// These theorem-shaped `.gg` modules cover:
//   - initial verdict = insufficient data (presumption)
//   - each evidence reduces deficit (monotone)
//   - guilty iff zero deficit

(test_suite: TestSuite { name: 'buleyean-evidence' })

(presumption: Verify { module: './evidence_presumption.gg', beta1_max: '6' })
(monotone: Verify { module: './evidence_monotone.gg', beta1_max: '6' })
(guilty_zero_deficit: Verify { module: './evidence_guilty_zero_deficit.gg', beta1_max: '6' })

(test_suite)-[:FORK]->(presumption | monotone | guilty_zero_deficit)

(presumption)-[:RACE { expect: 'safe' }]->(presumption_result: Result)
(monotone)-[:RACE { expect: 'safe' }]->(monotone_result: Result)
(guilty_zero_deficit)-[:RACE { expect: 'safe' }]->(guilty_result: Result)

(presumption_result | monotone_result | guilty_result)-[:FOLD { strategy: 'all-pass' }]->(verdict: Verdict)
(verdict)-[:TUNNEL { condition: 'bounded-reject' }]->(buleyean_evidence_test_gg_trace:Trace)
(verdict)-[:MEASURE { reason: 'topology-audit' }]->(buleyean_evidence_test_gg_trace:Trace)
