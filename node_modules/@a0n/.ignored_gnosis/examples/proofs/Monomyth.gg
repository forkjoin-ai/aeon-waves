// Monomyth.gg -- Campbell's Hero's Journey as a GG topology
//
// Documentation-layer bridge, not a new mechanized theorem.
// Departure begins in positive semiotic deficit.
// Initiation accumulates a void boundary through trials.
// Ordeal is a paid collapse under the failure trilemma.
// Re-entry exports lowered-deficit context back into the home channel.

(journey: Theorem { theorem: 'CAMPBELL-MONOMYTH-SCHEMA', status: 'documentation-layer' })

(home: SemioticChannel { theorem: 'THM-CAVE-DEFICIT', state: 'ordinary-world', deficit: 'positive' })
(call: ForkEvent { theorem: 'THM-CLINAMEN', state: 'call-to-adventure', live_paths: '2+' })
(refusal: Branch { state: 'refusal-of-the-call', weight: 'positive' })
(answer: Branch { state: 'acceptance-of-the-call', weight: 'positive' })
(mentor_seed: Branch { state: 'aid-path', weight: 'positive' })
(refusal_trace: Sliver { claim: 'refusal-retains-positive-weight' })
(mentor: SharedContext { theorem: 'THM-CONTEXT-REDUCES-DEFICIT', state: 'mentor', effect: 'reduces-effective-deficit' })
(threshold: Threshold { theorem: 'THM-DIVIDED-LINE-NO-SHORTCUTS', state: 'first-threshold' })

(trial_allies: Trial { state: 'allies-and-enemies', vented: '1' })
(trial_temptation: Trial { state: 'temptation', vented: '1' })
(trial_abyss: Trial { state: 'approach-to-inmost-cave', vented: '1' })
(allies_memory: RejectionMemory { source: 'trial-allies' })
(temptation_memory: RejectionMemory { source: 'trial-temptation' })
(abyss_memory: RejectionMemory { source: 'trial-abyss' })
(void_boundary: VoidBoundary { theorem: 'THM-VOID-BOUNDARY-MEASURABLE', monotone: 'true' })
(gradient: VoidGradient { theorem: 'THM-VOID-GRADIENT', policy: 'learn-from-rejection' })

(ordeal: DeterministicCollapse { theorem: 'THM-FAIL-TRILEMMA', state: 'ordeal', paid_by: 'vent-or-repair' })
(boon: Settlement { theorem: 'THM-NEGOTIATION-CONVERGENCE', state: 'reward', deficit: 'reduced' })
(resurrection: EmpathyTransform { theorem: 'THM-VOID-RELATIVITY', state: 'resurrection', interval: 'preserved' })
(elixir: SharedContext { theorem: 'THM-CONTEXT-REDUCES-DEFICIT', state: 're-entry-with-elixir', exports: 'lower-future-deficit' })
(result: Result { claim: 'finite-paid-context-assisted-void-walk' })

(journey)-[:PROCESS]->(home)
(home)-[:PROCESS { reason: 'positive deficit reveals an exterior beyond the ordinary world' }]->(call)
(call)-[:FORK { reason: 'the call opens refusal, acceptance, and aid as live paths' }]->(refusal | answer | mentor_seed)
(refusal)-[:SLIVER { reason: 'the unchosen branch remains legible and nonzero' }]->(refusal_trace)
(mentor_seed)-[:PROCESS { reason: 'aid enters as shared context rather than replacing agency' }]->(mentor)
(answer | mentor | refusal_trace)-[:FOLD { strategy: 'context-assisted-threshold-crossing' }]->(threshold)

(threshold)-[:FORK { reason: 'the road of trials branches into successive tests' }]->(trial_allies | trial_temptation | trial_abyss)
(trial_allies)-[:PROCESS { reason: 'failed alliances and enemies become structured negative knowledge' }]->(allies_memory)
(trial_temptation)-[:PROCESS { reason: 'false rewards become structured negative knowledge' }]->(temptation_memory)
(trial_abyss)-[:PROCESS { reason: 'approach pressure writes the inmost cave into memory' }]->(abyss_memory)
(allies_memory | temptation_memory | abyss_memory)-[:FOLD { strategy: 'accumulate-void-boundary' }]->(void_boundary)

(void_boundary)-[:PROCESS { reason: 'the rejection history becomes the sufficient statistic into the next move' }]->(gradient)
(gradient)-[:PROCESS { reason: 'the less-rejected survivor becomes the path into ordeal' }]->(ordeal)
(ordeal)-[:PROCESS { reason: 'transformation is paid, never free' }]->(boon)

(home | boon | void_boundary)-[:FOLD { strategy: 'evidenced-reentry-into-home' }]->(resurrection)
(resurrection)-[:PROCESS { reason: 'the boon is exported back into the community as context' }]->(elixir)
(elixir)-[:PROCESS]->(result)
(result)-[:TUNNEL { condition: 'bounded-reject' }]->(Monomyth_gg_trace:Trace)
(result)-[:MEASURE { reason: 'topology-audit' }]->(Monomyth_gg_trace:Trace)
