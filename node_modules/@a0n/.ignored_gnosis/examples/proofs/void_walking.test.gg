// void_walking.test.gg — Native Gnosis witnesses for THM-VOID-WALKING family
//
// These theorem-shaped `.gg` modules cover:
//   - void boundary grows per step (measurability)
//   - void dominates active computation (dominance)
//   - void boundary is sufficient statistic (efficiency)
//   - independent void walkers converge (coherence)

(test_suite: TestSuite { name: 'void-walking' })

(boundary_grows: Verify { module: './void_walking_boundary_grows.gg', beta1_max: '6' })
(void_dominates: Verify { module: './void_walking_dominance.gg', beta1_max: '6' })
(sufficient_statistic: Verify { module: './void_walking_sufficient_statistic.gg', beta1_max: '6' })
(walkers_converge: Verify { module: './void_walking_coherence.gg', beta1_max: '6' })

(test_suite)-[:FORK]->(boundary_grows | void_dominates | sufficient_statistic | walkers_converge)

(boundary_grows)-[:RACE { expect: 'safe' }]->(boundary_result: Result)
(void_dominates)-[:RACE { expect: 'safe' }]->(dominance_result: Result)
(sufficient_statistic)-[:RACE { expect: 'safe' }]->(statistic_result: Result)
(walkers_converge)-[:RACE { expect: 'safe' }]->(coherence_result: Result)

(boundary_result | dominance_result | statistic_result | coherence_result)-[:FOLD { strategy: 'all-pass' }]->(verdict: Verdict)
(verdict)-[:TUNNEL { condition: 'bounded-reject' }]->(void_walking_test_gg_trace:Trace)
(verdict)-[:MEASURE { reason: 'topology-audit' }]->(void_walking_test_gg_trace:Trace)
