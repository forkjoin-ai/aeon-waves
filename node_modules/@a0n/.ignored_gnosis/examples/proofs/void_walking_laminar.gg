// void_walking_laminar.gg — Self-Similar Void Walking at Every Scale
//
// The pattern is the same at every level:
//   FORK alternatives, RACE them, FOLD to winner, VENT losers,
//   read the void boundary, prune losers, repeat.
//
// Level 1: Codec racing (identity/gzip/brotli/deflate)
//   The void walker learns which codecs lose on this content type.
//   After warmup, prune losers. CPU savings on mixed content.
//
// Level 2: Agent strategy racing
//   Multiple agent strategies (greedy, exploratory, conservative)
//   race on the same problem. The void walker learns which strategies
//   lose on this problem class. After warmup, prune losers.
//
// Level 3: Meta-agent racing
//   Multiple meta-agent configurations (warmup=2, warmup=4, maxPrune=1, maxPrune=2)
//   race on the same workload. The void walker learns which configs
//   lose on this workload class. After warmup, prune losers.
//
// The fold: at some level, the void walker's complement distribution
// converges and further nesting adds zero information. That's the
// RG fixed point. The self-similar fern stops branching.
//
// This topology encodes all three levels as a single GGL program.

// ═══════════════════════════════════════════════════════════════════════
// Level 1: Codec Racing with Void Walking
// ═══════════════════════════════════════════════════════════════════════

(data: Source { type: 'bytes' })

// LAMINAR edge with void walking enabled (default)
(data)-[:LAMINAR { chunk: '65536', codecs: 'identity,gzip,brotli,deflate', voidWalking: 'true' }]->(compressed: Result)

// The void walker at this level learns: "brotli wins on text, identity wins on images"
// After 2 chunks, it prunes gzip and deflate on text-heavy content.

// ═══════════════════════════════════════════════════════════════════════
// Level 2: Agent Strategy Racing
// ═══════════════════════════════════════════════════════════════════════

(problem: Task { type: 'optimization' })

// FORK: three agent strategies
(problem)-[:FORK]->(
  greedy:   Agent { strategy: 'greedy',       description: 'exploit current best' } |
  explore:  Agent { strategy: 'exploratory',  description: 'explore new regions' } |
  conserve: Agent { strategy: 'conservative', description: 'minimize risk' }
)

// RACE: all strategies run, void walker tracks which ones lose
(greedy)-[:RACE { metric: 'objective_value' }]->(greedy_result: AgentResult)
(explore)-[:RACE { metric: 'objective_value' }]->(explore_result: AgentResult)
(conserve)-[:RACE { metric: 'objective_value' }]->(conserve_result: AgentResult)

// FOLD: pick best result, VENT losers into void boundary
(greedy_result | explore_result | conserve_result)-[:FOLD { strategy: 'raceMin', voidWalking: 'true' }]->(best_strategy: AgentResult)

// The void walker at this level learns: "greedy wins on convex problems,
// exploratory wins on multimodal problems." After warmup, it prunes
// the consistently-losing strategy.

// ═══════════════════════════════════════════════════════════════════════
// Level 3: Meta-Agent Racing (fold it one more time)
// ═══════════════════════════════════════════════════════════════════════

(workload: Workload { type: 'mixed' })

// FORK: three meta-agent configurations (different void walking params)
(workload)-[:FORK]->(
  fast_prune:   MetaAgent { warmup: '2', maxPrune: '2', description: 'aggressive pruning' } |
  slow_prune:   MetaAgent { warmup: '4', maxPrune: '1', description: 'cautious pruning' } |
  no_prune:     MetaAgent { warmup: '0', maxPrune: '0', description: 'always race all' }
)

// RACE: all meta-agents run Level 2 internally, void walker tracks which configs lose
(fast_prune)-[:RACE { metric: 'cpu_time' }]->(fast_result: MetaResult)
(slow_prune)-[:RACE { metric: 'cpu_time' }]->(slow_result: MetaResult)
(no_prune)-[:RACE { metric: 'cpu_time' }]->(no_result: MetaResult)

// FOLD: pick best config. This is the LAST fold -- the RG fixed point.
// Further nesting would race "meta-meta-agents" that choose between
// meta-agent configurations, but the complement distribution has
// converged: the winning config is stable across workloads.
// The fern stops branching here.
(fast_result | slow_result | no_result)-[:FOLD { strategy: 'raceMin', voidWalking: 'true', convergenceCheck: 'true' }]->(final: MetaResult)

// VENT: the convergenceCheck flag detects when the complement distribution
// has stabilized (kurtosis exceeds threshold). When it fires, the meta-level
// fold emits a VENT with the converged configuration, freezing the choice.
(final)-[:VENT { condition: 'convergence_detected', diagnostic: 'rg_fixed_point' }]->(frozen_config: FrozenConfig)

// The frozen config formalizes the RG fixed point: further iteration adds zero
// information. The void walker has converged. The system knows what it is.
(frozen_config)-[:MEASURE { reason: 'topology-audit' }]->(void_walking_laminar_gg_trace:Trace)
