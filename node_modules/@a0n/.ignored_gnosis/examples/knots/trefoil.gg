// Trefoil Knot (3₁) -- simplest non-trivial knot, 3 crossings
//
// The trefoil has three crossings where strands pass over each other.
// In code: triple nested loop over the same collection.
//
// for (i in items)
//   for (j in items)       ← crossing 1
//     for (k in items)     ← crossing 2 + 3
//       if (f(i,j,k)) ...
//
// Unknotting number: 1 (one Reidemeister move to unknot)
// Untangled form: sort + single pass (O(N³) → O(N log N))

(input: Source { data: 'collection' })

// Three crossings: three nested iterations over the same data
(cross_1: Process { op: 'iterate', over: 'collection' })
(cross_2: Process { op: 'iterate', over: 'collection' })
(cross_3: Process { op: 'iterate', over: 'collection' })
(compare: Process { op: 'compare_triple' })
(output: Sink { result: 'matches' })

(input)-[:PROCESS]->(cross_1)
(cross_1)-[:FORK]->(cross_2, cross_3)
(cross_2)-[:PROCESS]->(compare)
(cross_3)-[:PROCESS]->(compare)
(compare)-[:PROCESS { strategy: 'merge-all' }]->(output)

// Untangled form (the unknot):
// (input)-[:PROCESS { op: 'sort' }]->(sorted)
// (sorted)-[:PROCESS { op: 'single_pass_scan' }]->(output)
//
// THM-GINI-SORT-EQUIVALENCE: the sort-based form produces
// the same result as the triple nested comparison.
// Crossing number: 3 → 0. One Reidemeister type II move.
