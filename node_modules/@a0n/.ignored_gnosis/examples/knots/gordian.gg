// Gordian Knot -- the legendary knot no one could untie
//
// Alexander the Great "solved" it by cutting (O(1) -- but destroys the rope).
// In code: a legacy function so tangled that everyone is afraid to refactor.
// Every antipattern at once. The unknotting number is high but finite.
//
// The Gordian pattern:
//   - Nested loops with spread operators (trefoil + spread crossings)
//   - .shift() in while loop (BFS crossings)
//   - Per-element division in inner loop (deferred division crossings)
//   - .filter() called repeatedly on same collection (type index crossings)
//   - Redundant computation (results computed and thrown away)
//
// Crossing number: 11 (composite of trefoil + figure-eight + extras)
// Unknotting number: 6 (one Reidemeister move per antipattern)
//
// Alexander's solution (cutting) = rewrite from scratch.
// The Wallington solution (untangling) = apply 6 Reidemeister moves.
// Same result. The topology is preserved. The rope is intact.

(input: Source { data: 'legacy_data' })

// Crossing 1-2: Math.max(...arr.map(fn)) -- spread + map
(spread_map: Process { op: 'map_to_array', text: 'Math.max(...items.map(x => x.value))' })

// Crossing 3: .shift() in BFS loop
(bfs_loop: Process { op: 'bfs_with_shift', kind: 'Loop', text: 'queue.shift()' })

// Crossing 4-5: nested loop (quadratic)
(outer_loop: Process { op: 'iterate', over: 'legacy_data', kind: 'Loop' })
(inner_loop: Process { op: 'iterate', over: 'legacy_data', kind: 'Loop' })

// Crossing 6-7: .filter() called 3x on same collection
(filter_a: Process { op: 'filter', by: 'type_a', text: '.filter(x => x.type === "a")' })
(filter_b: Process { op: 'filter', by: 'type_b', text: '.filter(x => x.type === "b")' })
(filter_c: Process { op: 'filter', by: 'type_c', text: '.filter(x => x.type === "c")' })

// Crossing 8: per-element division
(normalize: Process { op: 'normalize', kind: 'Loop', text: 'arr[i] /= total' })

// Crossing 9-10: compute result, then discard (dead computation)
(compute: Process { op: 'expensive_compute' })
(discard: Process { op: 'void_discard', text: 'void result' })

// Crossing 11: redundant recomputation
(recompute: Process { op: 'expensive_compute' })

(output: Sink { result: 'gordian_result' })

// The tangle
(input)-[:PROCESS]->(spread_map)
(spread_map)-[:PROCESS]->(bfs_loop)
(bfs_loop)-[:FORK]->(outer_loop, filter_a)
(outer_loop)-[:PROCESS]->(inner_loop)
(inner_loop)-[:PROCESS]->(normalize)
(filter_a)-[:PROCESS]->(filter_b)
(filter_b)-[:PROCESS]->(filter_c)
(filter_c)-[:PROCESS { strategy: 'merge-all' }]->(compute)
(normalize)-[:PROCESS { strategy: 'merge-all' }]->(compute)
(compute)-[:PROCESS]->(discard)
(discard)-[:PROCESS]->(recompute)
(recompute)-[:PROCESS]->(output)

// The Wallington untangling (6 Reidemeister moves):
//
// Move 1 (RI):  spread_map → single-pass max        [THM-FREQ-EQUIVALENCE]
// Move 2 (RI):  bfs_loop .shift() → index pointer   [THM-QUEUE-SHIFT-EQUIVALENCE]
// Move 3 (RII): nested loops → sort-based            [THM-GINI-SORT-EQUIVALENCE]
// Move 4 (RI):  3x .filter() → type index            [THM-TYPEINDEX-INVARIANT]
// Move 5 (RIII): normalize division → reciprocal     [THM-RECIPROCAL-MULTIPLY-EQUIV]
// Move 6 (RI):  remove dead compute+discard+recompute [treeshaking]
//
// After 6 moves: crossing number 11 → 0. The Gordian unknot.
// Alexander cut the rope. Wallington untied it.
