// Figure-Eight Knot (4₁) -- amphichiral knot, 4 crossings
//
// The figure-eight is the simplest amphichiral knot: it equals its
// mirror image. In code: two independent quadratic patterns that
// mirror each other -- one reads, one writes, both O(N²).
//
// // Crossing 1-2: build index by scanning all pairs
// for (a in items)
//   for (b in items)
//     index[key(a,b)] = merge(a,b)    ← O(N²) build
//
// // Crossing 3-4: query index by scanning all pairs (mirror)
// for (a in items)
//   for (b in items)
//     result.push(index[key(a,b)])     ← O(N²) query
//
// Amphichiral property: the build loop and query loop are mirror images.
// Untangling one automatically untangles the other (mirror symmetry).
//
// Unknotting number: 1
// Untangled form: hash map build O(N) + hash map query O(N) = O(N)

(input: Source { data: 'items' })

// Build phase: two crossings (nested loop to build index)
(build_outer: Process { op: 'iterate', over: 'items', label: 'build' })
(build_inner: Process { op: 'iterate', over: 'items', label: 'build' })
(index_write: Process { op: 'map_set' })

// Query phase: two crossings (nested loop to query index) -- mirror of build
(query_outer: Process { op: 'iterate', over: 'items', label: 'query' })
(query_inner: Process { op: 'iterate', over: 'items', label: 'query' })
(index_read: Process { op: 'map_get' })

(output: Sink { result: 'merged_pairs' })

// Build strand
(input)-[:FORK]->(build_outer, query_outer)
(build_outer)-[:PROCESS]->(build_inner)
(build_inner)-[:PROCESS]->(index_write)

// Query strand (mirror)
(query_outer)-[:PROCESS]->(query_inner)
(query_inner)-[:PROCESS]->(index_read)

// Fold: merge build + query results
(index_write)-[:PROCESS { strategy: 'merge-all' }]->(output)
(index_read)-[:PROCESS { strategy: 'merge-all' }]->(output)

// Untangled form (unknot):
// (input)-[:PROCESS { op: 'hash_build_linear' }]->(index)
// (index)-[:PROCESS { op: 'hash_query_linear' }]->(output)
//
// Amphichiral: untangling the build strand automatically untangles
// the query strand because they are topological mirrors.
// Crossing number: 4 → 0. Two Reidemeister type II moves.
// THM-TYPEINDEX-INVARIANT: incremental index = nested scan.
