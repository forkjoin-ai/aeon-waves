// buleyean_positivity.test.gg -- Verify Buleyean positivity enforcement
// Phase 3: No fold produces probability zero

(test_suite:TestSuite { name: 'buleyean_positivity' })

// Set up branches with bule annotations
(source:Source { void_density: '1.0' })
(source)-[:FORK]->(reachable { bule: '3' } | unreachable { bule: '0' })

// Attempt fold on unreachable branch -- should trigger BULE_POSITIVITY_VIOLATED
(reachable | unreachable)-[:FOLD { strategy: 'merge' }]->(result:Sink)
(result)-[:TUNNEL { condition: 'bounded-reject' }]->(buleyean_positivity_test_gg_trace:Trace)
(result)-[:MEASURE { reason: 'topology-audit' }]->(buleyean_positivity_test_gg_trace:Trace)
