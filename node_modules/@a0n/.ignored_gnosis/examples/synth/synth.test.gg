// synth.test.gg — Formal verification topology for the quantum synth
//
// This formalizes the test. It maps to a topology. Fork/race/fold all the way down.
//
// Each module is a node. Verification FORKs into all modules.
// Each module RACEs against its invariants (pass or fail).
// Results FOLD into a single verdict.
//
// The test harness reads this file and executes the topology:
//   - Nodes with .gg imports → load and verify that module
//   - FORK → verify in parallel
//   - RACE → first violation fails the module
//   - FOLD → all must pass for the suite to pass

// ═══ Modules Under Test ═══

(test_suite: TestSuite { name: 'quantum-synth' })

(oscillator: Verify { module: './oscillator.gg', beta1_max: '10' })
(filter: Verify { module: './filter.gg', beta1_max: '10' })
(envelope: Verify { module: './envelope.gg', beta1_max: '10' })
(lfo: Verify { module: './lfo.gg', beta1_max: '10' })
(effects: Verify { module: './effects.gg', beta1_max: '10' })

// ═══ Fork: verify all modules in parallel ═══

(test_suite)-[:FORK]->(oscillator | filter | envelope | lfo | effects)

// ═══ Race: each module races its invariants ═══
// (the Verify node's properties define what to check)

(oscillator)-[:RACE { expect: 'safe' }]->(osc_result: Result)
(filter)-[:RACE { expect: 'safe' }]->(filter_result: Result)
(envelope)-[:RACE { expect: 'safe' }]->(env_result: Result)
(lfo)-[:RACE { expect: 'safe' }]->(lfo_result: Result)
(effects)-[:RACE { expect: 'safe' }]->(fx_result: Result)

// ═══ Fold: all results collapse into verdict ═══

(osc_result | filter_result | env_result | lfo_result | fx_result)-[:FOLD { strategy: 'all-pass' }]->(verdict: Verdict)
(verdict)-[:TUNNEL { condition: 'bounded-reject' }]->(synth_test_gg_trace:Trace)
(verdict)-[:MEASURE { reason: 'topology-audit' }]->(synth_test_gg_trace:Trace)
