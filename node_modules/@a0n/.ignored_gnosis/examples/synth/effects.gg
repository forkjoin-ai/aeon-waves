// effects.gg — Effect Chain as Fork/Race/Fold
//
// Effects are parallel universes of the signal. The dry signal
// and each effect exist in superposition. The mix knob determines
// how much of each universe bleeds into the final output.
//
// Delay: the signal travels through time (a buffer)
// Reverb: the signal diffracts through a virtual space
// Chorus: the signal interferes with pitch-shifted copies of itself
//
// β₁ = 3 (dry + 3 effects in superposition)

(fx_input: Signal)
(dry_mix: Parameter { range: '0-1', default: '0.7' })

// Fork: signal enters all effect universes simultaneously
(dry: Passthrough)
(delay: Delay { time: '0.375', feedback: '0.4', unit: 'seconds' })
(reverb: Reverb { decay: '2.0', damping: '0.5', room: 'medium' })
(chorus: Chorus { rate: '1.5', depth: '0.003', voices: '3' })

(fx_input)-[:FORK]->(dry | delay | reverb | chorus)

// Fold: mix all effect outputs weighted by their send levels
(dry | delay | reverb | chorus)-[:FOLD { strategy: 'weighted-sum' }]->(fx_out)
(fx_out)-[:TUNNEL { condition: 'bounded-reject' }]->(effects_gg_trace:Trace)
(fx_out)-[:MEASURE { reason: 'topology-audit' }]->(effects_gg_trace:Trace)
