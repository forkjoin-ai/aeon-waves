// oscillator.gg — Quantum Oscillator Bank
//
// An oscillator doesn't produce A wave. It exists in superposition
// of ALL waveforms simultaneously — sine, saw, square, triangle.
// The topology forks into all waveforms and the mix knob
// controls which interference pattern collapses out.
//
// β₁ = 3 (four waveforms in superposition)

(freq: Parameter { range: '20-20000', unit: 'Hz', default: '440' })
(phase: Accumulator { wrap: '6.283185' })
(freq)-[:PROCESS]->(phase)

// Fork into all waveforms — the oscillator is in superposition
(sine: Waveform { type: 'sine' })
(saw: Waveform { type: 'sawtooth' })
(square: Waveform { type: 'square', duty: '0.5' })
(triangle: Waveform { type: 'triangle' })

(phase)-[:FORK]->(sine | saw | square | triangle)

// Interference: waveforms mix according to their amplitudes
// This is constructive interference — the waves ADD
(sine | saw | square | triangle)-[:SLIVER { mode: 'constructive' }]->(osc_out)
