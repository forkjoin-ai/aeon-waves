{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://forkjoin.ai/schemas/moonshine-agent-event.schema.json",
  "title": "Moonshine agent JSONL event",
  "type": "object",
  "required": ["schemaVersion", "type", "timestamp"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "type": {
      "enum": [
        "run_start",
        "plan",
        "tool_request",
        "tool_result",
        "metacog_verdict",
        "provider_intent",
        "provider_status",
        "run_record",
        "tool_admission",
        "tool_denial",
        "run_checkpoint",
        "permission_request",
        "permission_decision",
        "assistant_delta",
        "patch_preview",
        "final",
        "error"
      ]
    },
    "timestamp": { "type": "string" },
    "run_id": { "type": "string" },
    "workspace_path": { "type": "string" },
    "permission_mode": { "enum": ["ask", "read-only", "auto"] },
    "provider": { "enum": ["sovereign", "codex", "claude"] },
    "intent_id": { "type": "string" },
    "tool_name": { "type": "string" },
    "command": { "type": "string" },
    "path": { "type": "string" },
    "prompt": { "type": "string" },
    "verdict": {
      "enum": ["proceed", "reflect", "fold", "defer", "escalate", "veto"]
    },
    "reason": { "type": "string" },
    "requested_action": { "type": "string" },
    "risk": {
      "enum": [
        "read_only",
        "workspace_write",
        "destructive",
        "network",
        "vcs_mutation",
        "formal_claim",
        "unknown"
      ]
    },
    "status": { "type": "string" },
    "exit_code": { "type": "integer" },
    "duration_ms": { "type": "integer", "minimum": 0 },
    "choices": {
      "type": "array",
      "items": { "type": "string" }
    },
    "formal_target": { "type": "string" },
    "verification_command": { "type": "string" },
    "content": { "type": "string" },
    "error": { "type": "string" }
  },
  "additionalProperties": true
}
