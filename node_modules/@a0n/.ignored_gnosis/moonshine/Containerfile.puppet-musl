# The PUPPET, layered the SOVEREIGN way — RUN-free, no Docker daemon.
#
# moonshine is cross-compiled to a static linux-musl binary on the HOST (zig handles
# the tree-sitter C deps — no musl-cross toolchain, no in-container build), then this
# RUN-free Containerfile (COPY/ENV/ENTRYPOINT only) is layered into Alpine by `swerve`
# — pure content-addressed file layering on ANY host, no Linux daemon, no buildkit.
# This is the exact pattern the skymesh broadcaster sliver uses.
#
# Build (from the monorepo root):
#   open-source/gnosis/moonshine/build-puppet.sh   [SWERVE_ARCH=amd64|arm64]
# Run a puppet (one fork/race/fold generation, then exit — the smallest meshed unit):
#   swerve cline aeon-puppet:latest --env MOONSHINE_TOKENIZER_GGUF=/models/qwen.gguf \
#     --env FAT_STATION_URL=http://<fat-station>:PORT -c "The sovereign mesh is"
FROM alpine:3.21
# A static musl binary needs no libgcc; moonshine's reqwest uses rustls + webpki-roots
# (its own CA bundle), so no ca-certificates package either → genuinely RUN-free.
COPY moonshine /usr/local/bin/moonshine
ENV AEON_PUPPET=1
# Headless distributed-inference path: one real fork/race/fold generation over the
# sovereign inference cache + aeon Flow, then exit. The orchestrator re-invokes per
# work item / model ref (the browser-fleet replacement). Override CMD for other work.
ENTRYPOINT ["/usr/local/bin/moonshine"]
# A puppet is a LONG-LIVED mesh node: `serve` warms the fat-station and stays up,
# heartbeating, ready for fork/race/fold dispatch (the browser-fleet replacement).
CMD ["serve"]
