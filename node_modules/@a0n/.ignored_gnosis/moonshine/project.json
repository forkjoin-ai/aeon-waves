{
  "name": "moonshine",
  "projectType": "application",
  "sourceRoot": "open-source/gnosis/moonshine/src",
  "tags": ["scope:gnosis", "type:rust", "platform:cli"],
  "targets": {
    "build": {
      "executor": "a0:run-commands",
      "options": {
        "command": "cargo build --release",
        "cwd": "open-source/gnosis/moonshine"
      },
      "outputs": ["{projectRoot}/target/release/moonshine"]
    },
    "check": {
      "executor": "a0:run-commands",
      "options": {
        "command": "cargo check",
        "cwd": "open-source/gnosis/moonshine"
      }
    },
    "test": {
      "executor": "a0:run-commands",
      "options": {
        "command": "cargo test",
        "cwd": "open-source/gnosis/moonshine"
      }
    },
    "lint": {
      "executor": "a0:run-commands",
      "options": {
        "command": "cargo clippy -- -D warnings",
        "cwd": "open-source/gnosis/moonshine"
      }
    }
  }
}
