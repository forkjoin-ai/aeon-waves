{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gnosis.forkjoin.ai/schemas/verification-bundle.schema.json",
  "title": "Autonomous remediation verification bundle",
  "description": "Deterministic closure artifact for merge bots (Arena 5). Stochastic search is irrelevant; only this structure is evaluated.",
  "type": "object",
  "required": [
    "schemaVersion",
    "patch_content_id",
    "toolchain_id",
    "ci_config_id",
    "gates"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "1.0.0"
    },
    "patch_content_id": {
      "type": "string",
      "minLength": 16,
      "description": "Content-addressed tree or bundle hash (hex or opaque id)."
    },
    "toolchain_id": {
      "type": "string",
      "description": "Pinned Lean/Node/resolver pin (hash or lockfile digest)."
    },
    "ci_config_id": {
      "type": "string",
      "description": "Hash of workflow YAML + container digest."
    },
    "gates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "exit", "log_hash"],
        "properties": {
          "name": { "type": "string" },
          "exit": { "type": "integer", "enum": [0] },
          "log_hash": { "type": "string" }
        }
      }
    },
    "formal": {
      "type": "object",
      "properties": {
        "sorry_count_delta": { "type": "integer", "maximum": 0 },
        "touched_modules": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "signatures": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "format": { "type": "string", "enum": ["sigstore", "none"] },
          "payload": { "type": "string" }
        }
      }
    }
  }
}
