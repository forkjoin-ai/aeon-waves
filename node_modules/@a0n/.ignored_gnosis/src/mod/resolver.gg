(detect_specifier:ModuleResolveSpecifierKind)-[:FORK { cases: 'bare,filesystem' }]->(resolve_bare:ModuleResolveBareSpecifier | prepare_filesystem_path:ModulePrepareFilesystemPath)
(prepare_filesystem_path)-[:PROCESS]->(candidate_state:ModuleFilesystemCandidateState)
(candidate_state)-[:FORK { cases: 'exact,search' }]->(resolve_exact_candidate:ModuleResolveExactFilesystemCandidate | resolve_search_candidates:ModuleResolveFilesystemCandidates)
(resolve_bare | resolve_exact_candidate | resolve_search_candidates)-[:FOLD { strategy: 'resolved-module' }]->(resolved_module:Sink)
(resolved_module)-[:TUNNEL { condition: 'bounded-reject' }]->(resolver_gg_trace:Trace)
(resolved_module)-[:MEASURE { reason: 'topology-audit' }]->(resolver_gg_trace:Trace)
