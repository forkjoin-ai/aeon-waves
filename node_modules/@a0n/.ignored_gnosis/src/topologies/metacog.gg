// metacog.gg -- The agent loop as a gnosis topology
//
// METACOG: perceive → decide → act → observe → reflect → adapt
//
// This topology formalizes the agent. When the gnosis engine executes it,
// it runs one tick of a VoidAgent. The personality stack constrains
// perception. Social attention gates decisions. Rejection accumulates
// void. Measurement drives gait adaptation.
//
// The agent doesn't "run" this topology. The agent is this topology.

// ============================================================================
// Perception: multi-head attention over action space
// ============================================================================

(stimulus : Stimulus)

// Personality constraint: deepest layer biases perception before attending
(stimulus) -[:PROCESS]-> (personality_gate : PersonalityConstraint)

// Multi-head self-attention (parallel heads attend independently)
(personality_gate) -[:FORK]-> (head_0 : AttentionHead, head_1 : AttentionHead, head_2 : AttentionHead)

// Heads fold into merged perception weights
(head_0, head_1, head_2) -[:FOLD]-> (perception : MergedPerception)

// ============================================================================
// Social: cross-attention to another agent (optional)
// ============================================================================

// Social attention runs in parallel with self-perception
(personality_gate) -[:FORK]-> (social_attend : SocialCrossAttention)

// Social and self-perception race to influence the decision
// If no social bond, social_attend vents and self-perception wins
(social_attend) -[:VENT { condition: 'no_bond' }]-> (social_void : SocialVoid)

// ============================================================================
// Decision: personality-constrained action selection
// ============================================================================

// Both perception paths feed into the decision
(perception) -[:PROCESS]-> (decision : DecisionGate)
(social_attend) -[:PROCESS]-> (decision)

// Decision superposes across all action dimensions
// Complement distribution formalizes the amplitude
(decision) -[:SUPERPOSE { p: 'complement' }]-> (action_0 : Action, action_1 : Action, action_2 : Action)

// One action survives
(action_0, action_1, action_2) -[:RACE]-> (chosen_action : ChosenAction)

// ============================================================================
// Environment interaction (external -- topology boundary)
// ============================================================================

(chosen_action) -[:PROCESS]-> (environment : EnvironmentInteraction)

// ============================================================================
// Observation: rejection accumulates void
// ============================================================================

(environment) -[:FORK]-> (observe_perception : PerceptionUpdate, observe_social : SocialUpdate, observe_personality : PersonalityPropagation)

// Perception: rejected actions accumulate void with neighborhood spread
// Social: rejected joint actions update cross-attention boundary
// Personality: signal propagates through stack with timescale attenuation

(observe_perception, observe_social, observe_personality) -[:FOLD]-> (observed : ObservedState)

// ============================================================================
// Reflection: the agent measures itself (c1)
// ============================================================================

(observed) -[:FORK]-> (measure_perception : MeasurePerception, measure_personality : MeasurePersonality, measure_social : MeasureSocial)

// Four measurements per system
(measure_perception) -[:FORK]-> (p_entropy : Entropy, p_kurtosis : Kurtosis, p_gini : Gini, p_bule : InverseBule)
(p_entropy, p_kurtosis, p_gini, p_bule) -[:FOLD]-> (perception_state : PerceptionMeasurement)

(measure_personality) -[:FORK]-> (pers_entropy : Entropy, pers_kurtosis : Kurtosis, pers_gini : Gini, pers_bule : InverseBule)
(pers_entropy, pers_kurtosis, pers_gini, pers_bule) -[:FOLD]-> (personality_state : PersonalityMeasurement)

(measure_social) -[:FORK]-> (s_entropy : Entropy, s_kurtosis : Kurtosis, s_gini : Gini, s_bule : InverseBule)
(s_entropy, s_kurtosis, s_gini, s_bule) -[:FOLD]-> (social_state : SocialMeasurement)

(perception_state, personality_state, social_state) -[:FOLD]-> (reflection : Reflection)

// ============================================================================
// Adaptation: gait selection + parameter tuning (c2 + c3)
// ============================================================================

(reflection) -[:PROCESS]-> (gait_select : GaitSelector)

// Gait superposes
(gait_select) -[:SUPERPOSE { p: 'kurtosis' }]-> (stand : Stand, trot : Trot, canter : Canter, gallop : Gallop)
(stand, trot, canter, gallop) -[:RACE]-> (active_gait : ActiveGait)

// Parameter adaptation (parallel eta + exploration adjustment)
(active_gait) -[:FORK]-> (adapt_eta : EtaAdaptation, adapt_explore : ExplorationAdaptation, adapt_decay : LayerNormDecay)
(adapt_eta, adapt_explore, adapt_decay) -[:FOLD]-> (adapted : AdaptedAgent)

// This describes the state transition. The adapted agent becomes
// the input for the next logical tick.
(adapted) -[:PROCESS]-> (next_tick:Sink)

// ============================================================================
// Self-measurement: the agent observes itself at key points
// ============================================================================

(perception) -[:MEASURE]-> (perception)
(reflection) -[:MEASURE]-> (reflection)
(active_gait) -[:MEASURE]-> (active_gait)

// ============================================================================
// Convergence / Divergence exits
// ============================================================================

// Converged: inverseBule near zero, agent has settled
(reflection) -[:TUNNEL { condition: 'inverseBule < 0.001' }]-> (converged : AgentConverged)

// Diverged: entropy near maximum, agent is lost
(reflection) -[:VENT { condition: 'entropy > maxEntropy * 0.99' }]-> (diverged : AgentDiverged)
