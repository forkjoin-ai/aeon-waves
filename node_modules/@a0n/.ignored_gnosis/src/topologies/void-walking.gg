// void-walking.gg -- The self-referential topology
//
// This topology describes void walking itself. When the gnosis engine
// executes it, the engine is walking its own void boundary, accumulating
// rejections against the very nodes that define what rejection means.
//
// The c0-c3 metacognitive loop as a .gg topology:
//   c0 (Choose + Update) → c1 (Measure) → c2 (Select Gait) → c3 (Adapt)
//
// The topology folds in on itself: each execution of this topology
// updates the void boundary that the complement distribution reads
// from to decide which node to execute next.

// ============================================================================
// Entry: the walker faces the void boundary
// ============================================================================

(boundary : VoidBoundary)

// ============================================================================
// c0: Choose from the complement distribution, then update the boundary
// ============================================================================

(boundary) -[:PROCESS]-> (complement : ComplementDistribution)
(complement) -[:SUPERPOSE { p: 'eta' }]-> (choice_a : Dimension, choice_b : Dimension, choice_c : Dimension)

// The chosen dimension gets void accumulated. Unchosen dimensions
// become the complement -- they grow relatively more attractive.
(choice_a, choice_b, choice_c) -[:RACE]-> (update : BoundaryUpdate)

// ============================================================================
// c1: Measure the distribution shape
// ============================================================================

(update) -[:PROCESS]-> (measure : Measurement)

// Measurement forks into four parallel observations.
// Each observes a different aspect of the complement distribution.
(measure) -[:FORK]-> (entropy : ShannonEntropy, kurtosis : ExcessKurtosis, gini : GiniCoefficient, inv_bule : InverseBule)

// All four measurements fold into a single observation.
(entropy, kurtosis, gini, inv_bule) -[:FOLD]-> (observation : Observation)

// ============================================================================
// c2: Select gait from kurtosis
// ============================================================================

// The observation determines the gait. This is the adaptive depth control:
// how deep the walker looks before taking the next step.
(observation) -[:PROCESS]-> (gait_select : GaitSelector)

// Gait selection superposes four possible gaits.
// Kurtosis determines which amplitude survives.
(gait_select) -[:SUPERPOSE { p: 'kurtosis' }]-> (stand : Stand, trot : Trot, canter : Canter, gallop : Gallop)

// Only one gait survives observation.
(stand, trot, canter, gallop) -[:RACE]-> (active_gait : ActiveGait)

// ============================================================================
// c3: Adapt parameters based on gait
// ============================================================================

(active_gait) -[:PROCESS]-> (adapt : ParameterAdaptation)

// Adaptation modifies eta (temperature) and exploration rate.
// The gait determines the direction of adaptation:
//   stand:   no change
//   trot:    more exploration, lower eta (broaden search)
//   canter:  less exploration, higher eta (narrow focus)
//   gallop:  minimal exploration, maximum eta (exploit)
(adapt) -[:FORK]-> (eta_adjust : EtaAdjustment, explore_adjust : ExplorationAdjustment)
(eta_adjust, explore_adjust) -[:FOLD]-> (adapted_state : AdaptedState)

// ============================================================================
// The loop: adapted state feeds back into the boundary
// ============================================================================

// This describes the state transition. The adapted state becomes
// the input for the next logical iteration.
(adapted_state) -[:PROCESS]-> (next_iteration:Sink)

// ============================================================================
// Cross-cutting: the topology measures itself
// ============================================================================

// MEASURE edges don't affect flow -- they're observation-only.
// The topology measures its own execution at key points.
(complement) -[:MEASURE]-> (complement)
(observation) -[:MEASURE]-> (observation)
(active_gait) -[:MEASURE]-> (active_gait)

// ============================================================================
// Escape: when the walker converges, the loop terminates
// ============================================================================

// TUNNEL provides an early exit when inverseBule drops below threshold.
// Convergence means the walker has found a stable complement distribution --
// the void boundary has settled.
(observation) -[:TUNNEL { condition: 'inverseBule < 0.001' }]-> (converged : Converged)

// VENT provides an escape when the walker diverges.
// Divergence means the void boundary is growing without bound --
// the walker is lost.
(observation) -[:VENT { condition: 'entropy > maxEntropy * 0.99' }]-> (diverged : Diverged)
