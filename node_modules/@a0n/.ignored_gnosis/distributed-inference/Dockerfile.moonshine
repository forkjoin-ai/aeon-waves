# Dockerfile.moonshine: Resonance-Tuned Inference Container
#
# Production inference container with:
# - Pre-loaded model weights
# - Resonance knot packages (mcnally-cliff curves)
# - Adaptive learning rate scheduler
# - Monster mesh distributed inference coordination
#
# Build: docker build -f Dockerfile.moonshine -t gnosis-moonshine:latest .
# Run:   docker run --gpus all -p 8000:8000 gnosis-moonshine:latest

FROM nvidia/cuda:12.4.1-cudnn9-runtime-ubuntu24.04

LABEL maintainer="Gnosis Team"
LABEL description="Resonance-tuned distributed inference container"

# Install system dependencies
RUN apt-get update && apt-get install -y \
    python3.11 \
    python3-pip \
    python3-dev \
    git \
    wget \
    curl \
    build-essential \
    && rm -rf /var/lib/apt/lists/*

# Set Python 3.11 as default
RUN update-alternatives --install /usr/bin/python3 python3 /usr/bin/python3.11 1

# Create working directory
WORKDIR /app

# Copy application code
COPY open-source/gnosis/distributed-inference /app/distributed-inference
COPY open-source/buleyean-rl /app/buleyean-rl

# Install Python dependencies
RUN pip3 install --no-cache-dir \
    torch==2.3.0 \
    transformers==4.36.0 \
    numpy==1.24.3 \
    scipy==1.11.0 \
    safetensors==0.4.0 \
    pydantic==2.5.0 \
    fastapi==0.104.1 \
    uvicorn==0.24.0 \
    python-multipart==0.0.6 \
    typing-extensions==4.8.0

# Install Rust toolchain (for native extensions)
RUN curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y && \
    . $HOME/.cargo/env

# Install distributed-inference in development mode
WORKDIR /app/distributed-inference
RUN pip3 install -e .

# Install mcnally-cliff-curves package
WORKDIR /app/buleyean-rl
RUN pip3 install -e .

# Create resonance curves directory structure
RUN mkdir -p /models/resonance /models/weights /models/cache

# Copy resonance knot files (created via create_rknots.py)
# These contain optimal learning rates and spectral measurements
COPY rknots/*.rknot /models/resonance/

# Copy optional uncompressed references for debugging
COPY rknots/*.rknot.json /models/resonance/

# Create entry point script for resonance-aware inference
RUN cat > /app/start-moonshine.sh << 'EOF'
#!/bin/bash
set -e

echo "=== Gnosis Moonshine: Resonance-Tuned Inference Container ==="
echo "Starting at $(date)"

# Load model with optimal learning rate from resonance curves
export PYTHONPATH="/app/distributed-inference:/app/buleyean-rl:$PYTHONPATH"

# Default model (override with --model flag)
MODEL=${MODEL:-"qwen-0.5b"}
PORT=${PORT:-8000}

echo "Model: $MODEL"
echo "Port: $PORT"
echo "Resonance curves: /models/resonance/"

# Start inference server with resonance-aware scheduler
python3 << PYEOF
import sys
sys.path.insert(0, '/app/distributed-inference/src')
sys.path.insert(0, '/app/buleyean-rl')

from mcnally_cliff_curves import load_model_with_optimal_lr
from mcnally_cliff_curves.integration import AdaptiveResonanceLRScheduler
import torch
import json
from pathlib import Path

# Load model with optimal LR from resonance curves
print(f"Loading {MODEL} with resonance-tuned parameters...")
model, optimal_lr = load_model_with_optimal_lr(
    MODEL,
    curves_dir=Path("/models/resonance")
)

# Load rknot metadata
rknot_path = Path("/models/resonance") / f"{MODEL}.rknot.json"
if rknot_path.exists():
    with open(rknot_path) as f:
        rknot = json.load(f)
    print(f"Resonance metadata loaded: {rknot['metadata']}")
    print(f"  Optimal LR: {rknot['resonance']['optimal_learning_rate']}")
    print(f"  Confidence: {rknot['resonance']['confidence']:.1%}")
    print(f"  Expected speedup: {rknot['benefits']['inference_speedup_percent']}%")
    print(f"  Quantization: {rknot['benefits']['quantization_bits']}-bit")

# Start inference server (placeholder - integrate with actual server)
print("Inference server starting...")
print(f"Listen on 0.0.0.0:{PORT}")

# TODO: Start actual fastapi/uvicorn server
# from distributed_inference.inference_server import app
# import uvicorn
# uvicorn.run(app, host="0.0.0.0", port=int(PORT))

PYEOF

EOF

RUN chmod +x /app/start-moonshine.sh

# Health check: verify resonance curves are loadable
RUN python3 << 'PYEOF'
import sys
sys.path.insert(0, '/app/buleyean-rl')

from mcnally_cliff_curves import RessonanceFrequencyLookup
from pathlib import Path

print("Verifying resonance curves...")
lookup = RessonanceFrequencyLookup(Path("/models/resonance"))

# Check each available model
import json
rknot_dir = Path("/models/resonance")
for rknot_file in rknot_dir.glob("*.rknot.json"):
    with open(rknot_file) as f:
        rknot = json.load(f)
    model_name = rknot["model_name"]
    optimal_lr = rknot["resonance"]["optimal_learning_rate"]
    print(f"  ✓ {model_name}: LR={optimal_lr:.6f}")

print("All resonance curves validated!")
PYEOF

# Set working directory to app
WORKDIR /app

# Expose inference port
EXPOSE 8000

# Set environment variables for production
ENV PYTHONUNBUFFERED=1
ENV TORCH_HOME=/models/cache
ENV TRANSFORMERS_CACHE=/models/cache

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=40s --retries=3 \
    CMD curl -f http://localhost:8000/health || exit 1

# Default command
CMD ["/app/start-moonshine.sh"]
