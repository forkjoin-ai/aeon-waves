# syntax=docker/dockerfile:1
#
# Lean multi-stage build for the gnosis skymesh `fat-station` node.
#
# WHY a Linux build: src/bin/fat-station.rs:re_exec_self uses
# std::os::unix::process::CommandExt::exec(), which is Unix-only and does not
# compile on Windows. The merged source (with the /hidden-embed endpoint) builds
# cleanly on glibc Linux with pure-Rust networking (tiny_http, memmap2,
# ureq+rustls, rayon) — no CUDA / OpenSSL / system libs required.
#
# BUILD CONTEXT must be `open-source/` (the parent of gnosis/ and bitwise/),
# because distributed-inference/Cargo.toml has PATH deps into both:
#   ../gnosis-frf, ../gnosis-http, ../rtl-bridge  (under gnosis/)
#   ../../bitwise                                 (= open-source/bitwise)
# and gnosis-frf in turn path-depends on gnosis-helix + gnosis-engine-core
# (also under gnosis/). Copying gnosis/ + bitwise/ wholesale covers the full
# transitive path-dep graph; .dockerignore strips target/, node_modules/,
# *.knot/*.rknot/*.gguf, datasets, and other heavy artifacts.
#
#   docker build -f gnosis/distributed-inference/Dockerfile.skymesh .
#   (with the build context set to open-source/)

# ---- stage 1: build ---------------------------------------------------------
FROM rust:1-bookworm AS build
WORKDIR /src

# Crates needed for the path-dep graph. Wholesale copy (dockerignore already
# trimmed the heavy bits). bitwise lives a level up from gnosis in the real
# tree (../../bitwise), so it must sit as a sibling of gnosis inside /src.
COPY gnosis/ ./gnosis/
COPY bitwise/ ./bitwise/

WORKDIR /src/gnosis/distributed-inference
# fat-station + the SkyMesh embed agent (joins the GLOBAL skymesh gateway:
# claims runHiddenEmbed work, runs it against the local /hidden-embed, posts back).
RUN cargo build --release --bin fat-station --bin protocol69-embed-agent --bin protocol69-gen-agent \
    && cp target/release/fat-station /fat-station \
    && cp target/release/protocol69-embed-agent /protocol69-embed-agent \
    && cp target/release/protocol69-gen-agent /protocol69-gen-agent \
    && strip /fat-station /protocol69-embed-agent /protocol69-gen-agent || true

# ---- stage 2: runtime -------------------------------------------------------
FROM debian:bookworm-slim AS runtime
# nodejs (v18, has global fetch + node:http) runs the dependency-free OpenAI proxy.
RUN apt-get update \
    && apt-get install -y --no-install-recommends ca-certificates curl nodejs \
    && rm -rf /var/lib/apt/lists/*
COPY --from=build /fat-station /usr/local/bin/fat-station
# SkyMesh embed agent — joins the GLOBAL skymesh gateway (--skymesh-url).
COPY --from=build /protocol69-embed-agent /usr/local/bin/protocol69-embed-agent
# SkyMesh gen agent — drains the runGenerate queue from the same gateway.
COPY --from=build /protocol69-gen-agent /usr/local/bin/protocol69-gen-agent
# Dependency-free OpenAI-compatible proxy (no @a0n/* workspace deps; node:http + fetch).
COPY gnosis/distributed-inference/openai-proxy.mjs /usr/local/bin/openai-proxy.mjs
# Entrypoint starts the OpenAI proxy alongside fat-station (set OPENAI_DISABLE=1 to skip).
# FAT_PORT must match the fat-station --port passed as args; OPENAI_PORT is the OpenAI port.
RUN printf '%s\n' \
  '#!/bin/sh' \
  ': "${FAT_PORT:=8090}"; : "${OPENAI_PORT:=8081}"; : "${MODEL_NAME:=gnosis}"' \
  'if [ "${OPENAI_DISABLE:-0}" != "1" ]; then' \
  '  FAT_STATION_URL="http://127.0.0.1:${FAT_PORT}" PORT="${OPENAI_PORT}" MODEL_NAME="${MODEL_NAME}" node /usr/local/bin/openai-proxy.mjs &' \
  'fi' \
  '# Join the GLOBAL skymesh: claim/serve runHiddenEmbed work from the gateway.' \
  '# Default-on (matches the MeshCacheNodeDO flag); SKYMESH_EMBED_ENABLED=false to disable.' \
  'if [ "${SKYMESH_EMBED_ENABLED:-1}" != "0" ] && [ "${SKYMESH_EMBED_ENABLED:-1}" != "false" ]; then' \
  '  : "${SKYMESH_URL:=https://skymesh.forkjoin.ai}"' \
  '  ( while true; do protocol69-embed-agent --skymesh-url "${SKYMESH_URL}" --fat-station-url "http://127.0.0.1:${FAT_PORT}" --agent-id "${SKYMESH_AGENT_ID:-embed-${FAT_PORT}}" || true; sleep 5; done ) &' \
  'fi' \
  '# Drain the runGenerate queue too (default-on; SKYMESH_GEN_ENABLED=false to disable).' \
  'if [ "${SKYMESH_GEN_ENABLED:-1}" != "0" ] && [ "${SKYMESH_GEN_ENABLED:-1}" != "false" ]; then' \
  '  : "${SKYMESH_URL:=https://skymesh.forkjoin.ai}"' \
  '  ( while true; do protocol69-gen-agent --skymesh-url "${SKYMESH_URL}" --fat-station-url "http://127.0.0.1:${FAT_PORT}" --agent-id "${SKYMESH_GEN_AGENT_ID:-gen-${FAT_PORT}}" || true; sleep 5; done ) &' \
  'fi' \
  'exec /usr/local/bin/fat-station "$@"' \
  > /usr/local/bin/skymesh-entrypoint.sh \
  && chmod +x /usr/local/bin/skymesh-entrypoint.sh
EXPOSE 8090
EXPOSE 9090/udp
EXPOSE 8081
ENTRYPOINT ["/usr/local/bin/skymesh-entrypoint.sh"]
