# Generic knot-baker: download any R2 knot in a debian builder (the model images
# have no curl), size-verify, and COPY it into the target base image at
# /models/<knot>. Set the service's knot env to that LOCAL path (no http://) so
# the gnosis loader uses MmapBackend (demand-paged) instead of HTTP-Range
# streaming every layer from R2. Cuts cold-start dramatically (gemma4-12b: 775s->41s).
#
#   --build-arg BASE_IMAGE=<img> --build-arg KNOT_NAME=<x.knot> --build-arg KNOT_SIZE=<bytes>
ARG BASE_IMAGE
FROM debian:bookworm-slim AS dl
ARG KNOT_NAME
ARG KNOT_SIZE
RUN apt-get update && apt-get install -y --no-install-recommends curl ca-certificates \
 && rm -rf /var/lib/apt/lists/* \
 && curl -fSL --retry 10 --retry-delay 10 --retry-all-errors -C - \
      "https://www-edgework-app.edgework.ai/api/v1/r2/distributed-inference/models/${KNOT_NAME}" \
      -o /knot \
 && sz=$(stat -c%s /knot) && echo "knot ${KNOT_NAME} size = $sz" \
 && [ "$sz" = "${KNOT_SIZE}" ] || { echo "SIZE MISMATCH (want ${KNOT_SIZE} got $sz)"; exit 1; }

FROM ${BASE_IMAGE}
ARG KNOT_NAME
COPY --from=dl /knot /models/${KNOT_NAME}
