# Dockerfile.gemma4-gpufix: rebuild ONLY the CUDA fat-station binary with the
# gemma4 GPU-GEMM fix (shape-selective FLUX_GPUFIX_MIN_D + f32-path gpucheck),
# then graft it over the existing moonshine-gpu image so all the surrounding
# infra (openai-server, gnode, entrypoint, knot streaming) is reused unchanged.
#
# Build: docker build -f open-source/gnosis/distributed-inference/Dockerfile.gemma4-gpufix \
#          -t <tag> open-source/
# Context is open-source/ (path-deps into gnosis/ + bitwise/, same as Dockerfile.skymesh).

# ---- stage 1: compile fat-station --features cuda (the bf16/f16/f32 GPU binary) -
FROM nvidia/cuda:12.4.1-devel-ubuntu22.04 AS build
ENV DEBIAN_FRONTEND=noninteractive
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl ca-certificates build-essential pkg-config git \
    && rm -rf /var/lib/apt/lists/*
# Rust toolchain (stable; code uses std::sync::OnceLock, stable since 1.70).
RUN curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y --profile minimal
ENV PATH="/root/.cargo/bin:${PATH}"
# cudarc dynamic-linking resolves libcublas/libcuda at link time; the devel image
# ships them under /usr/local/cuda. The driver stub satisfies the link.
ENV LIBRARY_PATH="/usr/local/cuda/lib64/stubs:/usr/local/cuda/lib64:${LIBRARY_PATH}"
ENV LD_LIBRARY_PATH="/usr/local/cuda/lib64/stubs:/usr/local/cuda/lib64:${LD_LIBRARY_PATH}"

WORKDIR /src
COPY gnosis/ ./gnosis/
COPY bitwise/ ./bitwise/

WORKDIR /src/gnosis/distributed-inference
RUN cargo build --release --features cuda --bin fat-station \
    && cp target/release/fat-station /fat-station \
    && strip /fat-station || true

# ---- stage 2: graft the new binary over the existing GPU image ---------------
FROM us-central1-docker.pkg.dev/neutral-418500/gnosis/moonshine:moonshine-gpu-v17-gpufix
# FAT_STATION_BIN=/usr/local/bin/fat-station-bf16 is the binary the entrypoint runs.
COPY --from=build /fat-station /usr/local/bin/fat-station-bf16
