namespace ForkRaceFoldTheorems

structure CraniopharyngiomaEchogenicityGapAssumptions where
  echogenicityCharacterised : Bool
  histologicalMisclassificationRisk : Nat
  gapFromUncharacterisedEchogenicity : echogenicityCharacterised = false → 0 < histologicalMisclassificationRisk

theorem craniopharyngioma_echogenicity_gap_exists (a : CraniopharyngiomaEchogenicityGapAssumptions)
    (h : a.echogenicityCharacterised = false) : 0 < a.histologicalMisclassificationRisk :=
  a.gapFromUncharacterisedEchogenicity h

structure CraniopharyngiomaHydrocephalusGapAssumptions where
  hydrocephalusAssessed : Bool
  thirdVentricleCompressionDocumented : Bool
  vpShuntPlanningGap : Nat
  gapFromUnassessedHydrocephalus : hydrocephalusAssessed = false → thirdVentricleCompressionDocumented = false → 0 < vpShuntPlanningGap

theorem craniopharyngioma_hydrocephalus_gap_exists (a : CraniopharyngiomaHydrocephalusGapAssumptions)
    (hHydro : a.hydrocephalusAssessed = false) (hThird : a.thirdVentricleCompressionDocumented = false) : 0 < a.vpShuntPlanningGap :=
  a.gapFromUnassessedHydrocephalus hHydro hThird

structure CraniopharyngiomaHypothalamicGapAssumptions where
  hypothalamicInvolvementGraded : Bool
  pituitaryStalkVisualised : Bool
  endocrineWorkupGap : Nat
  gapFromUnassessedHypothalamus : hypothalamicInvolvementGraded = false → pituitaryStalkVisualised = false → 0 < endocrineWorkupGap

theorem craniopharyngioma_hypothalamic_gap_exists (a : CraniopharyngiomaHypothalamicGapAssumptions)
    (hHypoth : a.hypothalamicInvolvementGraded = false) (hStalk : a.pituitaryStalkVisualised = false) : 0 < a.endocrineWorkupGap :=
  a.gapFromUnassessedHypothalamus hHypoth hStalk

structure CraniopharyngiomaOpticChiasmGapAssumptions where
  opticChiasmDisplacementEvaluated : Bool
  ophthalmologyReferralDelayRisk : Nat
  gapFromUnassessedChiasm : opticChiasmDisplacementEvaluated = false → 0 < ophthalmologyReferralDelayRisk

theorem craniopharyngioma_optic_chiasm_gap_exists (a : CraniopharyngiomaOpticChiasmGapAssumptions)
    (h : a.opticChiasmDisplacementEvaluated = false) : 0 < a.ophthalmologyReferralDelayRisk :=
  a.gapFromUnassessedChiasm h

structure CraniopharyngiomaMDTReferralGapAssumptions where
  brainMRIReferralInitiated : Bool
  neurosurgicalPlanningTriggered : Bool
  delayedResectionRisk : Nat
  gapFromMissingMDTReferral : brainMRIReferralInitiated = false → neurosurgicalPlanningTriggered = false → 0 < delayedResectionRisk

theorem craniopharyngioma_mdt_referral_gap_exists (a : CraniopharyngiomaMDTReferralGapAssumptions)
    (hMRI : a.brainMRIReferralInitiated = false) (hNeuro : a.neurosurgicalPlanningTriggered = false) : 0 < a.delayedResectionRisk :=
  a.gapFromMissingMDTReferral hMRI hNeuro

end ForkRaceFoldTheorems
