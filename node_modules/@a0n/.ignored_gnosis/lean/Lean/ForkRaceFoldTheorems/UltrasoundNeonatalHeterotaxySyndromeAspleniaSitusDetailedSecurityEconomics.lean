/-!
# UltrasoundNeonatalHeterotaxySyndromeAspleniaSitusDetailedSecurityEconomics

Neonatal Heterotaxy Syndrome with Asplenia (Right Isomerism / Bilateral
Right-sidedness): complex multi-organ situs anomaly with high incidence of
severe congenital heart disease (TAPVR, AVSD, DORV, pulmonary atresia),
asplenia-mediated immune deficiency, and intestinal malrotation. Five
security-economics gap theorems for clinical imaging gaps that constitute
missed-diagnosis risk with measurable medico-legal / readmission cost.

Anti-thesis pattern: structure posits the ABSENCE of an imaging assessment,
theorem derives strictly-positive risk. Zero sorry — all close by exact.
-/

namespace ForkRaceFoldTheorems

-- ── Theorem 1 ────────────────────────────────────────────────────────────────
-- Anti-thesis: abdominal situs (stomach, liver, spleen positions) NOT
-- determined by subxiphoid sweep AND inferior vena cava / aorta sidedness
-- NOT documented → incorrect situs classification / missed heterotaxy risk
-- is strictly positive.

structure HeterotaxyAbdominalSitusIVCGapAssumptions where
  abdominalSitusDetermined : Bool
  ivcAortaSidenessDocumented : Bool
  situsClassificationRisk : Nat
  gapFromUndeterminedSitusAndIVC :
    abdominalSitusDetermined = false →
    ivcAortaSidenessDocumented = false →
    0 < situsClassificationRisk

theorem heterotaxy_abdominal_situs_ivc_gap_exists
    (a : HeterotaxyAbdominalSitusIVCGapAssumptions)
    (hSitus : a.abdominalSitusDetermined = false)
    (hIVC : a.ivcAortaSidenessDocumented = false) :
    0 < a.situsClassificationRisk :=
  a.gapFromUndeterminedSitusAndIVC hSitus hIVC

-- ── Theorem 2 ────────────────────────────────────────────────────────────────
-- Anti-thesis: pulmonary venous drainage NOT fully mapped (TAPVR subtype
-- NOT classified) AND morphologic right-vs-left atrial appendage isomerism
-- NOT assessed → missed obstructed TAPVR / inappropriate prostaglandin
-- management risk is strictly positive.

structure HeterotaxyTAPVRAtrialisomerismGapAssumptions where
  pulmonaryVenousDrainageMapped : Bool
  atrialAppendageIsomerismAssessed : Bool
  obstructedTAPVRRisk : Nat
  gapFromUnmappedPVDAndIsomerism :
    pulmonaryVenousDrainageMapped = false →
    atrialAppendageIsomerismAssessed = false →
    0 < obstructedTAPVRRisk

theorem heterotaxy_tapvr_atrial_isomerism_gap_exists
    (a : HeterotaxyTAPVRAtrialisomerismGapAssumptions)
    (hPV : a.pulmonaryVenousDrainageMapped = false)
    (hAI : a.atrialAppendageIsomerismAssessed = false) :
    0 < a.obstructedTAPVRRisk :=
  a.gapFromUnmappedPVDAndIsomerism hPV hAI

-- ── Theorem 3 ────────────────────────────────────────────────────────────────
-- Anti-thesis: atrioventricular septal defect (AVSD) component NOT
-- assessed AND superior-inferior ventricular relationship NOT documented
-- → AVSD repair planning / ventricular dominance error risk is strictly
-- positive.

structure HeterotaxyAVSDVentricularRelationGapAssumptions where
  avsdComponentAssessed : Bool
  ventricularRelationshipDocumented : Bool
  avsdRepairPlanningRisk : Nat
  gapFromUnassessedAVSDAndVentricles :
    avsdComponentAssessed = false →
    ventricularRelationshipDocumented = false →
    0 < avsdRepairPlanningRisk

theorem heterotaxy_avsd_ventricular_relation_gap_exists
    (a : HeterotaxyAVSDVentricularRelationGapAssumptions)
    (hAV : a.avsdComponentAssessed = false)
    (hVR : a.ventricularRelationshipDocumented = false) :
    0 < a.avsdRepairPlanningRisk :=
  a.gapFromUnassessedAVSDAndVentricles hAV hVR

-- ── Theorem 4 ────────────────────────────────────────────────────────────────
-- Anti-thesis: spleen NOT identified and functional asplenia NOT confirmed
-- AND empiric antibiotic prophylaxis indication NOT documented → overwhelming
-- post-splenectomy infection (OPSI) / sepsis-mortality risk is strictly
-- positive.

structure HeterotaxyAspleniaProphylaxisGapAssumptions where
  spleenAbsenceConfirmed : Bool
  antibioticProphylaxisDocumented : Bool
  opsiSepsisRisk : Nat
  gapFromUnconfirmedAsleniaAndProphylaxis :
    spleenAbsenceConfirmed = false →
    antibioticProphylaxisDocumented = false →
    0 < opsiSepsisRisk

theorem heterotaxy_asplenia_prophylaxis_gap_exists
    (a : HeterotaxyAspleniaProphylaxisGapAssumptions)
    (hSp : a.spleenAbsenceConfirmed = false)
    (hAb : a.antibioticProphylaxisDocumented = false) :
    0 < a.opsiSepsisRisk :=
  a.gapFromUnconfirmedAsleniaAndProphylaxis hSp hAb

-- ── Theorem 5 ────────────────────────────────────────────────────────────────
-- Anti-thesis: intestinal rotation NOT assessed (pyloric / duodenal /
-- mesenteric position NOT characterised) AND midgut volvulus exclusion NOT
-- documented → missed malrotation / acute volvulus / bowel ischaemia risk
-- is strictly positive.

structure HeterotaxyMalrotationVolvulusGapAssumptions where
  intestinalRotationAssessed : Bool
  volvulusExclusionDocumented : Bool
  bowelIschaemiaRisk : Nat
  gapFromUnassessedRotationAndVolvulus :
    intestinalRotationAssessed = false →
    volvulusExclusionDocumented = false →
    0 < bowelIschaemiaRisk

theorem heterotaxy_malrotation_volvulus_gap_exists
    (a : HeterotaxyMalrotationVolvulusGapAssumptions)
    (hRot : a.intestinalRotationAssessed = false)
    (hVol : a.volvulusExclusionDocumented = false) :
    0 < a.bowelIschaemiaRisk :=
  a.gapFromUnassessedRotationAndVolvulus hRot hVol

end ForkRaceFoldTheorems
