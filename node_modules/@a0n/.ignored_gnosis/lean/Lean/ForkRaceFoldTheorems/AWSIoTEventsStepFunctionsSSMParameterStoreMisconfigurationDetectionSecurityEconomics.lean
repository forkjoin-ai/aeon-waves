namespace ForkRaceFoldTheorems

structure SSMParameterCMKSecureStringGapAssumptions where
  sensitiveParamsUseSecureStringCMK : Bool
  secretsExposureGap : Nat
  gapFromMissingSecureStringCMK : sensitiveParamsUseSecureStringCMK = false → 0 < secretsExposureGap

theorem ssm_parameter_cmk_secure_string_gap_exists (a : SSMParameterCMKSecureStringGapAssumptions)
    (h : a.sensitiveParamsUseSecureStringCMK = false) : 0 < a.secretsExposureGap :=
  a.gapFromMissingSecureStringCMK h

structure SSMSCPConfigDeleteGapAssumptions where
  scpBlocksParameterDeletion : Bool
  configDetectsMissingCMK : Bool
  parameterDeletionSuppressionRisk : Nat
  gapFromMissingSCPAndConfig : scpBlocksParameterDeletion = false → configDetectsMissingCMK = false → 0 < parameterDeletionSuppressionRisk

theorem ssm_scp_config_delete_gap_exists (a : SSMSCPConfigDeleteGapAssumptions)
    (hSCP : a.scpBlocksParameterDeletion = false) (hConfig : a.configDetectsMissingCMK = false) : 0 < a.parameterDeletionSuppressionRisk :=
  a.gapFromMissingSCPAndConfig hSCP hConfig

structure SSMIAMPathScopeGapAssumptions where
  iamScopedToParameterPaths : Bool
  secretsProliferationRisk : Nat
  gapFromUnscopedIAM : iamScopedToParameterPaths = false → 0 < secretsProliferationRisk

theorem ssm_iam_path_scope_gap_exists (a : SSMIAMPathScopeGapAssumptions)
    (h : a.iamScopedToParameterPaths = false) : 0 < a.secretsProliferationRisk :=
  a.gapFromUnscopedIAM h

structure SSMParameterChangeAlarmSOCGapAssumptions where
  parameterChangeAlarmConfigured : Bool
  socRunbookExists : Bool
  socGap : Nat
  gapFromMissingAlarmAndRunbook : parameterChangeAlarmConfigured = false → socRunbookExists = false → 0 < socGap

theorem ssm_parameter_change_alarm_soc_gap_exists (a : SSMParameterChangeAlarmSOCGapAssumptions)
    (hAlarm : a.parameterChangeAlarmConfigured = false) (hRunbook : a.socRunbookExists = false) : 0 < a.socGap :=
  a.gapFromMissingAlarmAndRunbook hAlarm hRunbook

structure SSMXRayCloudTrailGapAssumptions where
  xRayTracingEnabled : Bool
  cloudTrailSSMCorrelationEnabled : Bool
  observabilityGap : Nat
  gapFromMissingXRayAndCloudTrail : xRayTracingEnabled = false → cloudTrailSSMCorrelationEnabled = false → 0 < observabilityGap

theorem ssm_xray_cloudtrail_gap_exists (a : SSMXRayCloudTrailGapAssumptions)
    (hXRay : a.xRayTracingEnabled = false) (hCloudTrail : a.cloudTrailSSMCorrelationEnabled = false) : 0 < a.observabilityGap :=
  a.gapFromMissingXRayAndCloudTrail hXRay hCloudTrail

end ForkRaceFoldTheorems
