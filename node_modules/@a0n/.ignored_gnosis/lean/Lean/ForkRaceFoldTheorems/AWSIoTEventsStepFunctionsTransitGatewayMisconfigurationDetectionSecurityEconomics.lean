namespace ForkRaceFoldTheorems

structure TransitGatewayFlowLogCMKGapAssumptions where
  tgwFlowLogsEncryptedWithCMK : Bool
  complianceRisk : Nat
  gapFromMissingCMK : tgwFlowLogsEncryptedWithCMK = false → 0 < complianceRisk

theorem transit_gateway_flow_log_cmk_gap_exists (a : TransitGatewayFlowLogCMKGapAssumptions)
    (h : a.tgwFlowLogsEncryptedWithCMK = false) : 0 < a.complianceRisk :=
  a.gapFromMissingCMK h

structure TransitGatewaySCPConfigDeletionGapAssumptions where
  scpBlocksTGWDeletion : Bool
  configDetectsTGWChange : Bool
  networkIsolationLossRisk : Nat
  gapFromMissingSCPAndConfig : scpBlocksTGWDeletion = false → configDetectsTGWChange = false → 0 < networkIsolationLossRisk

theorem transit_gateway_scp_config_deletion_gap_exists (a : TransitGatewaySCPConfigDeletionGapAssumptions)
    (hSCP : a.scpBlocksTGWDeletion = false) (hConfig : a.configDetectsTGWChange = false) : 0 < a.networkIsolationLossRisk :=
  a.gapFromMissingSCPAndConfig hSCP hConfig

structure TransitGatewayAttachmentIAMScopeGapAssumptions where
  tgwAttachmentIAMScopedToVPC : Bool
  crossAccountAttachmentAudited : Bool
  lateralMovementRisk : Nat
  gapFromUnscopedTGWIAM : tgwAttachmentIAMScopedToVPC = false → crossAccountAttachmentAudited = false → 0 < lateralMovementRisk

theorem transit_gateway_attachment_iam_scope_gap_exists (a : TransitGatewayAttachmentIAMScopeGapAssumptions)
    (hScope : a.tgwAttachmentIAMScopedToVPC = false) (hAudit : a.crossAccountAttachmentAudited = false) : 0 < a.lateralMovementRisk :=
  a.gapFromUnscopedTGWIAM hScope hAudit

structure TransitGatewayRouteTableChangeAlarmSOCGapAssumptions where
  routeTableChangeAlarmConfigured : Bool
  socRunbookExists : Bool
  socGap : Nat
  gapFromMissingAlarmAndRunbook : routeTableChangeAlarmConfigured = false → socRunbookExists = false → 0 < socGap

theorem transit_gateway_route_table_change_alarm_soc_gap_exists (a : TransitGatewayRouteTableChangeAlarmSOCGapAssumptions)
    (hAlarm : a.routeTableChangeAlarmConfigured = false) (hRunbook : a.socRunbookExists = false) : 0 < a.socGap :=
  a.gapFromMissingAlarmAndRunbook hAlarm hRunbook

structure TransitGatewayXRayCloudTrailGapAssumptions where
  xRayTracingEnabled : Bool
  cloudTrailTGWEventsEnabled : Bool
  observabilityGap : Nat
  gapFromMissingXRayAndCloudTrail : xRayTracingEnabled = false → cloudTrailTGWEventsEnabled = false → 0 < observabilityGap

theorem transit_gateway_xray_cloudtrail_gap_exists (a : TransitGatewayXRayCloudTrailGapAssumptions)
    (hXRay : a.xRayTracingEnabled = false) (hCT : a.cloudTrailTGWEventsEnabled = false) : 0 < a.observabilityGap :=
  a.gapFromMissingXRayAndCloudTrail hXRay hCT

end ForkRaceFoldTheorems
