/-!
# AWSIoTEventsStepFunctionsEKSMSKMisconfigurationDetectionSecurityEconomics

AWS IoT Events → Step Functions → EKS: Amazon MSK (Managed Streaming for
Apache Kafka) misconfiguration detection. Security-economics gap theorems —
five proofs that absent controls create measurable revenue-at-risk or
compliance exposure.

Anti-thesis pattern: each structure posits the ABSENCE of a control, then
derives a positive risk quantity. Zero sorry — all theorems close by exact.
-/

namespace ForkRaceFoldTheorems

-- ── Theorem 1 ────────────────────────────────────────────────────────────────
-- Anti-thesis: the MSK cluster broker storage is NOT encrypted at rest with
-- a customer-managed KMS key → compliance gap is strictly positive.

structure MSKBrokerCMKGapAssumptions where
  brokerEncryptedWithCMK : Bool
  complianceRisk : Nat
  gapFromMissingCMK : brokerEncryptedWithCMK = false → 0 < complianceRisk

theorem msk_broker_cmk_gap_exists
    (a : MSKBrokerCMKGapAssumptions)
    (h : a.brokerEncryptedWithCMK = false) :
    0 < a.complianceRisk :=
  a.gapFromMissingCMK h

-- ── Theorem 2 ────────────────────────────────────────────────────────────────
-- Anti-thesis: no Service Control Policy (SCP) prevents disabling TLS
-- encryption in transit on the MSK cluster → data-interception risk is
-- strictly positive.

structure MSKTLSSCPGapAssumptions where
  scpEnforcesTLSInTransit : Bool
  interceptionRisk : Nat
  gapFromMissingSCP : scpEnforcesTLSInTransit = false → 0 < interceptionRisk

theorem msk_tls_scp_gap_exists
    (a : MSKTLSSCPGapAssumptions)
    (h : a.scpEnforcesTLSInTransit = false) :
    0 < a.interceptionRisk :=
  a.gapFromMissingSCP h

-- ── Theorem 3 ────────────────────────────────────────────────────────────────
-- Anti-thesis: the IAM role used by Step Functions to produce to MSK topics
-- is not scoped to the specific cluster ARN and topic prefix → privilege-
-- escalation gap is strictly positive.

structure MSKIAMRoleScopeGapAssumptions where
  iamRoleScopedToClusterArn : Bool
  privilegeEscalationRisk : Nat
  gapFromUnscopedRole : iamRoleScopedToClusterArn = false → 0 < privilegeEscalationRisk

theorem msk_iam_role_scope_gap_exists
    (a : MSKIAMRoleScopeGapAssumptions)
    (h : a.iamRoleScopedToClusterArn = false) :
    0 < a.privilegeEscalationRisk :=
  a.gapFromUnscopedRole h

-- ── Theorem 4 ────────────────────────────────────────────────────────────────
-- Anti-thesis: no CloudWatch alarm fires on MSK consumer-group lag exceeding
-- threshold AND the SOC has no runbook for that signal → SOC detection gap
-- is strictly positive.

structure MSKConsumerLagAlarmSOCGapAssumptions where
  cloudWatchAlarmConfigured : Bool
  socRunbookExists : Bool
  socGap : Nat
  gapFromMissingAlarmAndRunbook :
    cloudWatchAlarmConfigured = false →
    socRunbookExists = false →
    0 < socGap

theorem msk_consumer_lag_alarm_soc_gap_exists
    (a : MSKConsumerLagAlarmSOCGapAssumptions)
    (hAlarm : a.cloudWatchAlarmConfigured = false)
    (hRunbook : a.socRunbookExists = false) :
    0 < a.socGap :=
  a.gapFromMissingAlarmAndRunbook hAlarm hRunbook

-- ── Theorem 5 ────────────────────────────────────────────────────────────────
-- Anti-thesis: AWS X-Ray active tracing is NOT enabled on the Step Functions
-- → MSK producer path AND CloudTrail logging of MSK cluster configuration
-- changes is not centralised → observability gap is strictly positive.

structure MSKXRayGapAssumptions where
  xRayTracingEnabled : Bool
  cloudTrailClusterChangesCaptured : Bool
  observabilityGap : Nat
  gapFromMissingXRay :
    xRayTracingEnabled = false →
    cloudTrailClusterChangesCaptured = false →
    0 < observabilityGap

theorem msk_xray_gap_exists
    (a : MSKXRayGapAssumptions)
    (hXRay : a.xRayTracingEnabled = false)
    (hTrail : a.cloudTrailClusterChangesCaptured = false) :
    0 < a.observabilityGap :=
  a.gapFromMissingXRay hXRay hTrail

end ForkRaceFoldTheorems
