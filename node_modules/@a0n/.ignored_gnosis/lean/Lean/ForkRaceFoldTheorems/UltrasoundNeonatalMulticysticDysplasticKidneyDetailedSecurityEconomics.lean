/-!
# UltrasoundNeonatalMulticysticDysplasticKidneyDetailedSecurityEconomics

Neonatal renal ultrasound — multicystic dysplastic kidney (MCDK).
Security-economics gap theorems derived from absent diagnostic controls.

Anti-thesis pattern: each structure posits the ABSENCE of a required
measurement or finding, then derives a positive risk quantity.
Zero sorry — all theorems close by exact.
-/

namespace ForkRaceFoldTheorems

-- ── Theorem 1 ────────────────────────────────────────────────────────────────
-- Anti-thesis: the cyst distribution and kidney morphology are NOT documented
-- (random, non-communicating cysts, no central pelvis) → contralateral
-- compensation assessment gap is strictly positive.

structure MCDKMorphologyDocumentationGapAssumptions where
  cystDistributionDocumented : Bool
  contralateralAssessmentGap : Nat
  gapFromUndocumentedMorphology :
    cystDistributionDocumented = false → 0 < contralateralAssessmentGap

theorem mcdk_morphology_documentation_gap_exists
    (a : MCDKMorphologyDocumentationGapAssumptions)
    (h : a.cystDistributionDocumented = false) :
    0 < a.contralateralAssessmentGap :=
  a.gapFromUndocumentedMorphology h

-- ── Theorem 2 ────────────────────────────────────────────────────────────────
-- Anti-thesis: colour Doppler flow to the affected kidney is NOT assessed →
-- involution trajectory monitoring gap is strictly positive.

structure MCDKColorDopplerFlowGapAssumptions where
  colorDopplerAssessed : Bool
  involutionMonitoringGap : Nat
  gapFromMissingDoppler :
    colorDopplerAssessed = false → 0 < involutionMonitoringGap

theorem mcdk_color_doppler_flow_gap_exists
    (a : MCDKColorDopplerFlowGapAssumptions)
    (h : a.colorDopplerAssessed = false) :
    0 < a.involutionMonitoringGap :=
  a.gapFromMissingDoppler h

-- ── Theorem 3 ────────────────────────────────────────────────────────────────
-- Anti-thesis: the contralateral kidney length Z-score and collecting system
-- are NOT measured → compensatory hypertrophy quantification gap is strictly
-- positive.

structure MCDKContralateralKidneyAssessmentGapAssumptions where
  contralateralLengthZScoreMeasured : Bool
  hypertrophyQuantificationGap : Nat
  gapFromUnmeasuredContralateral :
    contralateralLengthZScoreMeasured = false → 0 < hypertrophyQuantificationGap

theorem mcdk_contralateral_kidney_assessment_gap_exists
    (a : MCDKContralateralKidneyAssessmentGapAssumptions)
    (h : a.contralateralLengthZScoreMeasured = false) :
    0 < a.hypertrophyQuantificationGap :=
  a.gapFromUnmeasuredContralateral h

-- ── Theorem 4 ────────────────────────────────────────────────────────────────
-- Anti-thesis: associated contralateral vesico-ureteric junction obstruction
-- or ureteropelvic junction anomaly is NOT excluded → contralateral-anomaly
-- detection gap is strictly positive.

structure MCDKContralateralAnomalyExclusionGapAssumptions where
  contralateralAnomalyExcluded : Bool
  anomalyDetectionGap : Nat
  gapFromUnexcludedAnomaly :
    contralateralAnomalyExcluded = false → 0 < anomalyDetectionGap

theorem mcdk_contralateral_anomaly_exclusion_gap_exists
    (a : MCDKContralateralAnomalyExclusionGapAssumptions)
    (h : a.contralateralAnomalyExcluded = false) :
    0 < a.anomalyDetectionGap :=
  a.gapFromUnexcludedAnomaly h

-- ── Theorem 5 ────────────────────────────────────────────────────────────────
-- Anti-thesis: the largest cyst diameter is NOT recorded AND no follow-up
-- interval is specified for involution tracking → surveillance protocol gap
-- is strictly positive.

structure MCDKInvolutionSurveillanceGapAssumptions where
  largestCystDiameterRecorded : Bool
  followUpIntervalSpecified : Bool
  surveillanceGap : Nat
  gapFromMissingSurveillanceProtocol :
    largestCystDiameterRecorded = false →
    followUpIntervalSpecified = false →
    0 < surveillanceGap

theorem mcdk_involution_surveillance_gap_exists
    (a : MCDKInvolutionSurveillanceGapAssumptions)
    (hDiameter : a.largestCystDiameterRecorded = false)
    (hFollowUp : a.followUpIntervalSpecified = false) :
    0 < a.surveillanceGap :=
  a.gapFromMissingSurveillanceProtocol hDiameter hFollowUp

end ForkRaceFoldTheorems
