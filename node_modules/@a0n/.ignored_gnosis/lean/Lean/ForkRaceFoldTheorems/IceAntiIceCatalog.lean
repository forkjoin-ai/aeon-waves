import ForkRaceFoldTheorems.DiscreteSamplingDuel
import ForkRaceFoldTheorems.AntiDomainOverlay

namespace ForkRaceFoldTheorems
namespace IceAntiIceCatalog

open DiscreteSamplingDuel
open AntiDomainOverlay

/-- Overlay-hole bypass witness. -/
structure OverlayHoleBypass where
  iceSize : Nat
  attackerSize : Nat
  regionSize : Nat
  reclaimedHits : Nat

/-- Clock-rate side-channel witness. -/
structure ClockSideChannelBypass where
  defenderRate : Nat
  attackerRate : Nat
  horizon : Nat
  frameDeficit : Nat
  strictlyPositive : Bool

/-- The attacker's reclaimed hit count on its own support equals `attackerOv.size` independently of `iceOv.size`. -/
def overlayHoleBypass (iceOv attackerOv : Overlay) (regionSize : Nat) : OverlayHoleBypass :=
  let disjointFits := iceOv.size + attackerOv.size <= regionSize
  { iceSize := iceOv.size,
    attackerSize := attackerOv.size,
    regionSize := regionSize,
    reclaimedHits := if disjointFits then attackerOv.size else 0 }

/-- The frame deficit is strictly positive over a positive horizon with a faster clock. -/
theorem clockRateSideChannelUnbounded (H : Nat) (fA fD : Nat)
    (hH : 0 < H) (hfA : fD < fA) :
    0 < frameDeficitFormula H fA fD := by
  have hd : 0 < fA - fD := Nat.sub_pos_of_lt hfA
  exact Nat.mul_pos hH hd

/-- Clock rate side channel witness. -/
def clockRateSideChannel (defenderClock attackerClock : Clock) (H : Nat) : ClockSideChannelBypass :=
  let deficit := frameDeficitFormula H attackerClock.rate defenderClock.rate
  { defenderRate := defenderClock.rate,
    attackerRate := attackerClock.rate,
    horizon := H,
    frameDeficit := deficit,
    strictlyPositive := H > 0 && attackerClock.rate > defenderClock.rate && deficit > 0 }

end IceAntiIceCatalog
end ForkRaceFoldTheorems
