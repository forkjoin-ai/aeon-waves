/-!
# UltrasoundNeonatalCoarctationOfAortaDetailedSecurityEconomics

Neonatal coarctation of the aorta (CoA): discrete narrowing of the aortic
isthmus near the ductus arteriosus insertion. Five security-economics gap
theorems for clinical imaging gaps that constitute missed-diagnosis risk —
each with measurable economic (medico-legal / readmission) cost.

Anti-thesis pattern: structure posits the ABSENCE of an imaging assessment,
theorem derives strictly-positive risk. Zero sorry — all close by exact.
-/

namespace ForkRaceFoldTheorems

-- ── Theorem 1 ────────────────────────────────────────────────────────────────
-- Anti-thesis: coarctation segment minimum diameter NOT measured AND aortic
-- isthmus Z-score NOT calculated → incorrect severity classification and
-- interventional threshold risk is strictly positive.

structure CoASegmentDiameterZScoreGapAssumptions where
  coarctationDiameterMeasured : Bool
  isthmusZScoreCalculated : Bool
  severityMisclassificationRisk : Nat
  gapFromUnmeasuredDiameterAndZScore :
    coarctationDiameterMeasured = false →
    isthmusZScoreCalculated = false →
    0 < severityMisclassificationRisk

theorem coa_segment_diameter_zscore_gap_exists
    (a : CoASegmentDiameterZScoreGapAssumptions)
    (hDiam : a.coarctationDiameterMeasured = false)
    (hZ : a.isthmusZScoreCalculated = false) :
    0 < a.severityMisclassificationRisk :=
  a.gapFromUnmeasuredDiameterAndZScore hDiam hZ

-- ── Theorem 2 ────────────────────────────────────────────────────────────────
-- Anti-thesis: Doppler peak gradient across the coarctation NOT measured AND
-- diastolic tail (persistent antegrade flow in the descending aorta) NOT
-- documented → haemodynamic severity under-estimation risk is strictly
-- positive.

structure CoADopplerGradientDiastolicTailGapAssumptions where
  dopplerGradientMeasured : Bool
  diastolicTailDocumented : Bool
  haemodynamicUnderestimationRisk : Nat
  gapFromUnmeasuredGradientAndTail :
    dopplerGradientMeasured = false →
    diastolicTailDocumented = false →
    0 < haemodynamicUnderestimationRisk

theorem coa_doppler_gradient_diastolic_tail_gap_exists
    (a : CoADopplerGradientDiastolicTailGapAssumptions)
    (hGrad : a.dopplerGradientMeasured = false)
    (hTail : a.diastolicTailDocumented = false) :
    0 < a.haemodynamicUnderestimationRisk :=
  a.gapFromUnmeasuredGradientAndTail hGrad hTail

-- ── Theorem 3 ────────────────────────────────────────────────────────────────
-- Anti-thesis: aortic arch morphology (transverse arch, isthmus, ductal
-- ampulla) NOT characterised AND arch hypoplasia NOT excluded → incorrect
-- surgical approach (balloon vs. surgical resection) risk is strictly
-- positive.

structure CoAArchMorphologyHypoplasiaGapAssumptions where
  archMorphologyCharacterised : Bool
  archHypoplasiaExcluded : Bool
  incorrectSurgicalApproachRisk : Nat
  gapFromUncharacterisedArchAndHypoplasia :
    archMorphologyCharacterised = false →
    archHypoplasiaExcluded = false →
    0 < incorrectSurgicalApproachRisk

theorem coa_arch_morphology_hypoplasia_gap_exists
    (a : CoAArchMorphologyHypoplasiaGapAssumptions)
    (hArch : a.archMorphologyCharacterised = false)
    (hHypo : a.archHypoplasiaExcluded = false) :
    0 < a.incorrectSurgicalApproachRisk :=
  a.gapFromUncharacterisedArchAndHypoplasia hArch hHypo

-- ── Theorem 4 ────────────────────────────────────────────────────────────────
-- Anti-thesis: associated intracardiac anomalies (bicuspid aortic valve,
-- VSD, Shone's complex) NOT excluded AND left ventricular outflow tract
-- obstruction NOT quantified → incomplete surgical planning risk is strictly
-- positive.

structure CoAIntracardiacAssociationsLVOTGapAssumptions where
  intracardiacAssociationsExcluded : Bool
  lvotObstructionQuantified : Bool
  incompleteSurgicalPlanningRisk : Nat
  gapFromUnexcludedAssociationsAndLVOT :
    intracardiacAssociationsExcluded = false →
    lvotObstructionQuantified = false →
    0 < incompleteSurgicalPlanningRisk

theorem coa_intracardiac_associations_lvot_gap_exists
    (a : CoAIntracardiacAssociationsLVOTGapAssumptions)
    (hAssoc : a.intracardiacAssociationsExcluded = false)
    (hLVOT : a.lvotObstructionQuantified = false) :
    0 < a.incompleteSurgicalPlanningRisk :=
  a.gapFromUnexcludedAssociationsAndLVOT hAssoc hLVOT

-- ── Theorem 5 ────────────────────────────────────────────────────────────────
-- Anti-thesis: ductal dependency (right-to-left ductal flow sustaining lower-
-- body perfusion) NOT documented AND PGE1 continuation indication NOT
-- assessed → premature ductal closure / end-organ ischaemia risk is strictly
-- positive.

structure CoADuctalDependencyPGE1GapAssumptions where
  ductalDependencyDocumented : Bool
  pge1ContinuationAssessed : Bool
  endOrganIschaemiaRisk : Nat
  gapFromUndocumentedDependencyAndPGE1 :
    ductalDependencyDocumented = false →
    pge1ContinuationAssessed = false →
    0 < endOrganIschaemiaRisk

theorem coa_ductal_dependency_pge1_gap_exists
    (a : CoADuctalDependencyPGE1GapAssumptions)
    (hDep : a.ductalDependencyDocumented = false)
    (hPGE : a.pge1ContinuationAssessed = false) :
    0 < a.endOrganIschaemiaRisk :=
  a.gapFromUndocumentedDependencyAndPGE1 hDep hPGE

end ForkRaceFoldTheorems
