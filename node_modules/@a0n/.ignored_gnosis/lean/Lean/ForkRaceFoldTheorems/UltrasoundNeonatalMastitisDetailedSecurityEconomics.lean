/-!
# UltrasoundNeonatalMastitisDetailedSecurityEconomics

Neonatal mastitis and breast abscess ultrasound diagnostic gap theorems.
Five proofs that absence of specific US-guided clinical steps creates
measurable patient-safety risk. Anti-thesis pattern; zero sorry.
-/

namespace ForkRaceFoldTheorems

-- ── Theorem 1 ────────────────────────────────────────────────────────────────
-- Anti-thesis: breast ultrasound does NOT distinguish abscess cavity from
-- simple cellulitis → drainage-indication gap is strictly positive.

structure NeonatalBreastAbscessDistinctionGapAssumptions where
  usDistinguishesAbscessFromCellulitis : Bool
  drainageIndicationGap : Nat
  gapFromUndistinguished :
    usDistinguishesAbscessFromCellulitis = false → 0 < drainageIndicationGap

theorem neonatal_breast_abscess_distinction_gap_exists
    (a : NeonatalBreastAbscessDistinctionGapAssumptions)
    (h : a.usDistinguishesAbscessFromCellulitis = false) :
    0 < a.drainageIndicationGap :=
  a.gapFromUndistinguished h

-- ── Theorem 2 ────────────────────────────────────────────────────────────────
-- Anti-thesis: Doppler US does NOT quantify perilesional hyperaemia AND
-- vascularity grade is absent → antibiotic-escalation gap is strictly positive.

structure NeonatalMastitisDopplerHyperaemiaGapAssumptions where
  dopplerVascularityGraded : Bool
  antibioticEscalationGap : Nat
  gapFromUngradedVascularity :
    dopplerVascularityGraded = false → 0 < antibioticEscalationGap

theorem neonatal_mastitis_doppler_hyperaemia_gap_exists
    (a : NeonatalMastitisDopplerHyperaemiaGapAssumptions)
    (h : a.dopplerVascularityGraded = false) :
    0 < a.antibioticEscalationGap :=
  a.gapFromUngradedVascularity h

-- ── Theorem 3 ────────────────────────────────────────────────────────────────
-- Anti-thesis: serial US is NOT performed post-aspiration AND abscess
-- re-accumulation is not confirmed absent → treatment-failure gap is strictly positive.

structure NeonatalMastitisSerialUSGapAssumptions where
  serialUSPerformedPostAspiration : Bool
  reaccumulationConfirmedAbsent : Bool
  treatmentFailureGap : Nat
  gapFromMissingSerialUS :
    serialUSPerformedPostAspiration = false →
    reaccumulationConfirmedAbsent = false →
    0 < treatmentFailureGap

theorem neonatal_mastitis_serial_us_gap_exists
    (a : NeonatalMastitisSerialUSGapAssumptions)
    (hUS : a.serialUSPerformedPostAspiration = false)
    (hConfirm : a.reaccumulationConfirmedAbsent = false) :
    0 < a.treatmentFailureGap :=
  a.gapFromMissingSerialUS hUS hConfirm

-- ── Theorem 4 ────────────────────────────────────────────────────────────────
-- Anti-thesis: echocardiography is NOT performed to exclude haematogenous
-- seeding AND endocarditis is not ruled out → septic-complication gap is strictly positive.

structure NeonatalMastitisEndocarditisEchoGapAssumptions where
  echoPerformedToExcludeEndocarditis : Bool
  septicComplicationGap : Nat
  gapFromMissingEcho :
    echoPerformedToExcludeEndocarditis = false → 0 < septicComplicationGap

theorem neonatal_mastitis_endocarditis_echo_gap_exists
    (a : NeonatalMastitisEndocarditisEchoGapAssumptions)
    (h : a.echoPerformedToExcludeEndocarditis = false) :
    0 < a.septicComplicationGap :=
  a.gapFromMissingEcho h

-- ── Theorem 5 ────────────────────────────────────────────────────────────────
-- Anti-thesis: follow-up breast US at 4–6 weeks is NOT scheduled AND
-- breast-tissue remodelling is not confirmed → long-term-outcome gap is strictly positive.

structure NeonatalMastitisFollowUpUSGapAssumptions where
  followUpUSScheduled : Bool
  tissueRemodellingConfirmed : Bool
  longTermOutcomeGap : Nat
  gapFromMissingFollowUp :
    followUpUSScheduled = false →
    tissueRemodellingConfirmed = false →
    0 < longTermOutcomeGap

theorem neonatal_mastitis_follow_up_us_gap_exists
    (a : NeonatalMastitisFollowUpUSGapAssumptions)
    (hFU : a.followUpUSScheduled = false)
    (hRM : a.tissueRemodellingConfirmed = false) :
    0 < a.longTermOutcomeGap :=
  a.gapFromMissingFollowUp hFU hRM

end ForkRaceFoldTheorems
