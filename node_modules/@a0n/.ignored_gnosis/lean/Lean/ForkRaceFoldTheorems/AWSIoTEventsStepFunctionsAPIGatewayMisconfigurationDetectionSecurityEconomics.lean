/-!
# AWSIoTEventsStepFunctionsAPIGatewayMisconfigurationDetectionSecurityEconomics

API Gateway REST/HTTP API misconfiguration scanner driven by IoT Events +
Step Functions. Five security-economics gap theorems: each proves that the
ABSENCE of a control on the API Gateway surface creates a measurable
compliance or attack-surface cost.

Anti-thesis pattern: structure posits the ABSENCE of a control, theorem
derives strictly-positive gap. Zero sorry — all close by exact.
-/

namespace ForkRaceFoldTheorems

-- ── Theorem 1 ────────────────────────────────────────────────────────────────
-- Anti-thesis: API Gateway access logs are NOT encrypted with a
-- customer-managed KMS key in CloudWatch Logs → compliance gap is strictly
-- positive, exposing request metadata and payload summaries at rest.

structure APIGatewayLogsCMKGapAssumptions where
  accessLogsEncryptedWithCMK : Bool
  complianceGap : Nat
  gapFromMissingCMK : accessLogsEncryptedWithCMK = false → 0 < complianceGap

theorem apigateway_logs_cmk_gap_exists
    (a : APIGatewayLogsCMKGapAssumptions)
    (h : a.accessLogsEncryptedWithCMK = false) :
    0 < a.complianceGap :=
  a.gapFromMissingCMK h

-- ── Theorem 2 ────────────────────────────────────────────────────────────────
-- Anti-thesis: API Gateway does NOT enforce TLS 1.2 or higher AND an SCP
-- does not prevent weaker TLS policies → data-in-transit exposure risk is
-- strictly positive.

structure APIGatewayTLSSCPGapAssumptions where
  tls12OrHigherEnforced : Bool
  scpPreventsWeakerTLS : Bool
  dataInTransitRisk : Nat
  gapFromMissingTLSAndSCP :
    tls12OrHigherEnforced = false →
    scpPreventsWeakerTLS = false →
    0 < dataInTransitRisk

theorem apigateway_tls_scp_gap_exists
    (a : APIGatewayTLSSCPGapAssumptions)
    (hTLS : a.tls12OrHigherEnforced = false)
    (hSCP : a.scpPreventsWeakerTLS = false) :
    0 < a.dataInTransitRisk :=
  a.gapFromMissingTLSAndSCP hTLS hSCP

-- ── Theorem 3 ────────────────────────────────────────────────────────────────
-- Anti-thesis: the API Gateway resource policy or Lambda authorizer is NOT
-- scoped to the specific invoking principal → unauthorised-access risk is
-- strictly positive.

structure APIGatewayResourcePolicyScopeGapAssumptions where
  resourcePolicyScopedToPrincipal : Bool
  unauthorisedAccessRisk : Nat
  gapFromUnscopedPolicy : resourcePolicyScopedToPrincipal = false → 0 < unauthorisedAccessRisk

theorem apigateway_resource_policy_scope_gap_exists
    (a : APIGatewayResourcePolicyScopeGapAssumptions)
    (h : a.resourcePolicyScopedToPrincipal = false) :
    0 < a.unauthorisedAccessRisk :=
  a.gapFromUnscopedPolicy h

-- ── Theorem 4 ────────────────────────────────────────────────────────────────
-- Anti-thesis: no CloudWatch alarm is configured on API Gateway 4xx/5xx
-- error rates AND the SOC has no runbook for API-level failure → SOC
-- blind-spot risk is strictly positive.

structure APIGatewayErrorAlarmSOCGapAssumptions where
  errorRateAlarmConfigured : Bool
  socRunbookForAPIFailure : Bool
  socBlindSpotRisk : Nat
  gapFromMissingAlarmAndRunbook :
    errorRateAlarmConfigured = false →
    socRunbookForAPIFailure = false →
    0 < socBlindSpotRisk

theorem apigateway_error_alarm_soc_gap_exists
    (a : APIGatewayErrorAlarmSOCGapAssumptions)
    (hAlarm : a.errorRateAlarmConfigured = false)
    (hRunbook : a.socRunbookForAPIFailure = false) :
    0 < a.socBlindSpotRisk :=
  a.gapFromMissingAlarmAndRunbook hAlarm hRunbook

-- ── Theorem 5 ────────────────────────────────────────────────────────────────
-- Anti-thesis: AWS X-Ray tracing is NOT enabled on the API Gateway stage AND
-- the Step Functions state machine that provisions it also lacks X-Ray →
-- observability gap is strictly positive.

structure APIGatewayXRayGapAssumptions where
  apiGatewayXRayEnabled : Bool
  stateMachineXRayEnabled : Bool
  observabilityGap : Nat
  gapFromMissingXRay :
    apiGatewayXRayEnabled = false →
    stateMachineXRayEnabled = false →
    0 < observabilityGap

theorem apigateway_xray_gap_exists
    (a : APIGatewayXRayGapAssumptions)
    (hAPI : a.apiGatewayXRayEnabled = false)
    (hSFN : a.stateMachineXRayEnabled = false) :
    0 < a.observabilityGap :=
  a.gapFromMissingXRay hAPI hSFN

end ForkRaceFoldTheorems
