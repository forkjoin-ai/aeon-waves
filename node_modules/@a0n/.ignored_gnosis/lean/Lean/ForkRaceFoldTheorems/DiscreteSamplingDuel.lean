namespace ForkRaceFoldTheorems
namespace DiscreteSamplingDuel

/-- A discrete clock with a positive tick rate. -/
structure Clock where
  rate : Nat
  hPositive : 0 < rate

/-- Ticks produced by clock `c` over sampling horizon `H`. -/
def tickCount (c : Clock) (H : Nat) : Nat :=
  H * c.rate

/-- The frame deficit `H * (fA - fB)`. Clamped to zero for `Nat` when `fB > fA`. -/
def frameDeficitFormula (H : Nat) (fA : Nat) (fB : Nat) : Nat :=
  H * (fA - fB)

/-- Detect whether `fA` is an integer multiple `k * fB` for some `k >= 1`. -/
def resonanceAlignsExactly (fA fB : Nat) : Prop :=
  fB > 0 /\ fA >= fB /\ fA % fB = 0

end DiscreteSamplingDuel
end ForkRaceFoldTheorems
