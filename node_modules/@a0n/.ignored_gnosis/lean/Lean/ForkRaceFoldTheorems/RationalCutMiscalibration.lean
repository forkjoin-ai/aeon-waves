namespace ForkRaceFoldTheorems
namespace RationalCutMiscalibration

/-- Fibonacci sequence. -/
def fib : Nat -> Nat
  | 0 => 0
  | 1 => 1
  | n + 2 => fib n + fib (n + 1)

/-- A cut is Fibonacci-resonant iff `(p, q) = (fib k, fib (k+1))` for some `k`. -/
def isFibonacciResonantCut (p q : Nat) : Prop :=
  Exists (fun k => p = fib k /\ q = fib (k + 1))

end RationalCutMiscalibration
end ForkRaceFoldTheorems
