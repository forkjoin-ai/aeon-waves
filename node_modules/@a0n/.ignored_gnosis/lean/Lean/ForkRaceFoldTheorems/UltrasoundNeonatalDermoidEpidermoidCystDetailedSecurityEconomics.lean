namespace ForkRaceFoldTheorems

structure DermoidCystContentDifferentiationGapAssumptions where
  cystContentCharacterised : Bool
  histologicalMisclassificationRisk : Nat
  gapFromUncharacterisedContent : cystContentCharacterised = false → 0 < histologicalMisclassificationRisk

theorem dermoid_cyst_content_differentiation_gap_exists (a : DermoidCystContentDifferentiationGapAssumptions)
    (h : a.cystContentCharacterised = false) : 0 < a.histologicalMisclassificationRisk :=
  a.gapFromUncharacterisedContent h

structure DermoidCystWallCalcificationGapAssumptions where
  wallComplexityAssessed : Bool
  calcificationDocumented : Bool
  malignancyRiskStratificationGap : Nat
  gapFromUnassessedWall : wallComplexityAssessed = false → calcificationDocumented = false → 0 < malignancyRiskStratificationGap

theorem dermoid_cyst_wall_calcification_gap_exists (a : DermoidCystWallCalcificationGapAssumptions)
    (hWall : a.wallComplexityAssessed = false) (hCalc : a.calcificationDocumented = false) : 0 < a.malignancyRiskStratificationGap :=
  a.gapFromUnassessedWall hWall hCalc

structure DermoidCystIntracranialExtensionGapAssumptions where
  intracranialExtentEvaluated : Bool
  mriIndicationTriggered : Bool
  missingMRIReferralRisk : Nat
  gapFromUnassessedExtension : intracranialExtentEvaluated = false → mriIndicationTriggered = false → 0 < missingMRIReferralRisk

theorem dermoid_cyst_intracranial_extension_gap_exists (a : DermoidCystIntracranialExtensionGapAssumptions)
    (hExt : a.intracranialExtentEvaluated = false) (hMRI : a.mriIndicationTriggered = false) : 0 < a.missingMRIReferralRisk :=
  a.gapFromUnassessedExtension hExt hMRI

structure DermoidCystMassEffectGapAssumptions where
  massEffectDocumented : Bool
  neuralCompressionAssessed : Bool
  delayedDecompressionRisk : Nat
  gapFromUnassessedMassEffect : massEffectDocumented = false → neuralCompressionAssessed = false → 0 < delayedDecompressionRisk

theorem dermoid_cyst_mass_effect_gap_exists (a : DermoidCystMassEffectGapAssumptions)
    (hMass : a.massEffectDocumented = false) (hNeural : a.neuralCompressionAssessed = false) : 0 < a.delayedDecompressionRisk :=
  a.gapFromUnassessedMassEffect hMass hNeural

structure DermoidCystSurgicalPlanningGapAssumptions where
  surgicalReferralInitiated : Bool
  mdtNeurosurgicalPlanningTriggered : Bool
  delayedExcisionRisk : Nat
  gapFromMissingSurgicalPlan : surgicalReferralInitiated = false → mdtNeurosurgicalPlanningTriggered = false → 0 < delayedExcisionRisk

theorem dermoid_cyst_surgical_planning_gap_exists (a : DermoidCystSurgicalPlanningGapAssumptions)
    (hRef : a.surgicalReferralInitiated = false) (hMDT : a.mdtNeurosurgicalPlanningTriggered = false) : 0 < a.delayedExcisionRisk :=
  a.gapFromMissingSurgicalPlan hRef hMDT

end ForkRaceFoldTheorems
