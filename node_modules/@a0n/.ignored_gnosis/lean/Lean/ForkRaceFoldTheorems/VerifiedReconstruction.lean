import ForkRaceFoldTheorems.TrainingSaturation

namespace ForkRaceFoldTheorems
namespace VerifiedReconstruction

open TrainingSaturation

/-!
# Verified reconstruction from training saturation

This module consumes the `TrainingSaturation` base case and packages the exact
12/17/22 resonance witness as a finite reconstruction certificate.
-/

/-- A finite reconstruction witness with camera, shared-space, and color data. -/
structure ReconstructionWitness where
  node : SwarmNode
  omega : HarmonicFrequency
  frames : Nat
  sharedSpace : Nat
  colors : List NoiseColor
deriving DecidableEq, Repr

/-- The concrete witness produced by the exact training-saturation frequency. -/
def exactReconstructionWitness : ReconstructionWitness :=
  { node := zeroEnergyNode
    omega := exactGamutFrequency
    frames := 5
    sharedSpace := 100
    colors := [NoiseColor.white, NoiseColor.pink, NoiseColor.brown] }

/-- The training-saturation base condition as a reconstruction predicate. -/
def baseReady (witness : ReconstructionWitness) : Prop :=
  VerifiedReconstructionBase witness.node witness.omega

/-- All five camera views are synchronized. -/
def framesSynchronized (witness : ReconstructionWitness) : Prop :=
  witness.frames = 5

/-- The shared-space overlap is complete in the finite witness. -/
def sharedSpaceComplete (witness : ReconstructionWitness) : Prop :=
  witness.sharedSpace = 100

/-- The witness traverses the visible white/pink/brown color gamut. -/
def colorGamutComplete (witness : ReconstructionWitness) : Prop :=
  shootsNoiseGamut witness.colors

/-- The node address matches the exact harmonic frequency. -/
def addressAligned (witness : ReconstructionWitness) : Prop :=
  witness.node.dimension = witness.omega.localAeon /\
    witness.node.fingerprint = witness.omega.fingerprint

/-- The local energy barrier is bypassed by carrier readiness at resonance. -/
def localBarrierBypassed (witness : ReconstructionWitness) : Prop :=
  Not (conservativeReady witness.node 1) /\
    carrierReadiness witness.node witness.omega

/-- Complete reconstruction certificate assembled from the bounded checks. -/
def reconstructionComplete (witness : ReconstructionWitness) : Prop :=
  baseReady witness /\
    meshExists witness.node /\
    impedance witness.omega = 0 /\
    localBarrierBypassed witness /\
    colorGamutComplete witness /\
    framesSynchronized witness /\
    sharedSpaceComplete witness /\
    addressAligned witness

/-- The TrainingSaturation base theorem lifts into the reconstruction surface. -/
theorem training_saturation_base_lifts_to_reconstruction :
    baseReady exactReconstructionWitness := by
  simpa [baseReady, exactReconstructionWitness] using
    verified_reconstruction_base_from_existence

/-- The exact reconstruction witness has mesh existence. -/
theorem exact_reconstruction_mesh_exists :
    meshExists exactReconstructionWitness.node := by
  simp [meshExists]

/-- Exact reconstruction carries the zero-impedance resonance result. -/
theorem exact_reconstruction_zero_impedance :
    impedance exactReconstructionWitness.omega = 0 := by
  simpa [exactReconstructionWitness] using exact_frequency_zero_impedance

/-- The exact reconstruction witness remains blocked by the local energy gate. -/
theorem exact_reconstruction_energy_gate_blocked :
    Not (conservativeReady exactReconstructionWitness.node 1) := by
  simpa [exactReconstructionWitness] using zero_energy_not_conservative_ready

/-- The exact reconstruction witness has carrier readiness at resonance. -/
theorem exact_reconstruction_carrier_ready :
    carrierReadiness exactReconstructionWitness.node exactReconstructionWitness.omega := by
  exact And.intro exact_frequency_completes_gamut (by simp [intrinsicReady])

/-- The exact reconstruction witness bypasses the local barrier topologically. -/
theorem exact_reconstruction_local_barrier_bypassed :
    localBarrierBypassed exactReconstructionWitness := by
  exact And.intro
    exact_reconstruction_energy_gate_blocked
    exact_reconstruction_carrier_ready

/-- The exact reconstruction witness traverses white, pink, and brown. -/
theorem exact_reconstruction_color_gamut :
    colorGamutComplete exactReconstructionWitness := by
  simpa [colorGamutComplete, exactReconstructionWitness] using
    white_pink_brown_shoots_gamut

/-- The exact reconstruction witness synchronizes all five finite views. -/
theorem exact_reconstruction_frames_synchronized :
    framesSynchronized exactReconstructionWitness := by
  rfl

/-- The exact reconstruction witness has complete shared-space overlap. -/
theorem exact_reconstruction_shared_space_complete :
    sharedSpaceComplete exactReconstructionWitness := by
  rfl

/-- The exact reconstruction witness aligns node address with harmonic address. -/
theorem exact_reconstruction_address_aligned :
    addressAligned exactReconstructionWitness := by
  simp [addressAligned, exactReconstructionWitness, zeroEnergyNode, exactGamutFrequency]

/-- At the exact reconstruction witness, carrier readiness is intrinsic readiness. -/
theorem exact_reconstruction_readiness_iff_intrinsic :
    carrierReadiness exactReconstructionWitness.node exactReconstructionWitness.omega <->
      intrinsicReady exactReconstructionWitness.node := by
  simpa [exactReconstructionWitness] using
    exact_frequency_readiness_iff_intrinsic zeroEnergyNode

/-- The exact finite witness satisfies the full reconstruction certificate. -/
theorem exact_reconstruction_complete :
    reconstructionComplete exactReconstructionWitness := by
  exact And.intro training_saturation_base_lifts_to_reconstruction
    (And.intro exact_reconstruction_mesh_exists
      (And.intro exact_reconstruction_zero_impedance
        (And.intro exact_reconstruction_local_barrier_bypassed
          (And.intro exact_reconstruction_color_gamut
            (And.intro exact_reconstruction_frames_synchronized
              (And.intro exact_reconstruction_shared_space_complete
                exact_reconstruction_address_aligned))))))

/-- A verified reconstruction witness exists. -/
theorem verified_reconstruction_exists :
    Exists reconstructionComplete := by
  exact Exists.intro exactReconstructionWitness exact_reconstruction_complete

end VerifiedReconstruction
end ForkRaceFoldTheorems
