/-!
# AWSIoTEventsStepFunctionsNATGatewayMisconfigurationDetectionSecurityEconomics

AWS NAT Gateway misconfiguration scanner for IoT Events + Step Functions
pipelines. Five security-economics gap theorems: each proves that the ABSENCE
of a control on the NAT Gateway surface creates measurable compliance or
attack-surface cost.

Anti-thesis pattern: structure posits the ABSENCE of a control, theorem
derives strictly-positive gap. Zero sorry — all close by exact.
-/

namespace ForkRaceFoldTheorems

-- ── Theorem 1 ────────────────────────────────────────────────────────────────
-- Anti-thesis: VPC flow logs for the private subnets that route through the
-- NAT Gateway are NOT encrypted with a customer-managed KMS key → compliance
-- gap is strictly positive.

structure NATGWFlowLogCMKGapAssumptions where
  flowLogsEncryptedWithCMK : Bool
  complianceGap : Nat
  gapFromMissingCMK : flowLogsEncryptedWithCMK = false → 0 < complianceGap

theorem natgw_flow_log_cmk_gap_exists
    (a : NATGWFlowLogCMKGapAssumptions)
    (h : a.flowLogsEncryptedWithCMK = false) :
    0 < a.complianceGap :=
  a.gapFromMissingCMK h

-- ── Theorem 2 ────────────────────────────────────────────────────────────────
-- Anti-thesis: no SCP or AWS Config rule prevents deletion of the NAT Gateway
-- used by IoT Events private subnets AND more than one private subnet depends
-- on it → deletion-scope risk is strictly positive.

structure NATGWSCPDeletionGapAssumptions where
  scpOrConfigRulePresent : Bool
  dependentPrivateSubnetCount : Nat
  deletionScopeRisk : Nat
  gapFromMissingProtectionAndMultiSubnet :
    scpOrConfigRulePresent = false →
    1 < dependentPrivateSubnetCount →
    0 < deletionScopeRisk

theorem natgw_scp_deletion_gap_exists
    (a : NATGWSCPDeletionGapAssumptions)
    (hSCP : a.scpOrConfigRulePresent = false)
    (hSubnets : 1 < a.dependentPrivateSubnetCount) :
    0 < a.deletionScopeRisk :=
  a.gapFromMissingProtectionAndMultiSubnet hSCP hSubnets

-- ── Theorem 3 ────────────────────────────────────────────────────────────────
-- Anti-thesis: the IAM role permitted to invoke ec2:DeleteNatGateway is NOT
-- scoped to the specific NAT Gateway ID → privilege escalation risk is strictly
-- positive.

structure NATGWIAMRoleScopeGapAssumptions where
  iamRoleScopedToGateway : Bool
  privilegeEscalationRisk : Nat
  gapFromUnscopedRole : iamRoleScopedToGateway = false → 0 < privilegeEscalationRisk

theorem natgw_iam_role_scope_gap_exists
    (a : NATGWIAMRoleScopeGapAssumptions)
    (h : a.iamRoleScopedToGateway = false) :
    0 < a.privilegeEscalationRisk :=
  a.gapFromUnscopedRole h

-- ── Theorem 4 ────────────────────────────────────────────────────────────────
-- Anti-thesis: no CloudWatch alarm fires on NAT Gateway bandwidth saturation
-- or error-port-allocation events AND the SOC has no on-call runbook →
-- SOC blind-spot risk is strictly positive.

structure NATGWAlarmSOCGapAssumptions where
  cloudWatchAlarmConfigured : Bool
  socRunbookExists : Bool
  socBlindSpotRisk : Nat
  gapFromMissingAlarmAndRunbook :
    cloudWatchAlarmConfigured = false →
    socRunbookExists = false →
    0 < socBlindSpotRisk

theorem natgw_alarm_soc_gap_exists
    (a : NATGWAlarmSOCGapAssumptions)
    (hAlarm : a.cloudWatchAlarmConfigured = false)
    (hRunbook : a.socRunbookExists = false) :
    0 < a.socBlindSpotRisk :=
  a.gapFromMissingAlarmAndRunbook hAlarm hRunbook

-- ── Theorem 5 ────────────────────────────────────────────────────────────────
-- Anti-thesis: AWS X-Ray active tracing is NOT enabled on the Step Functions
-- state machine that manages NAT Gateway lifecycle AND CloudTrail API calls
-- for ec2:CreateNatGateway are not forwarded to a SIEM → observability gap
-- is strictly positive.

structure NATGWXRayCloudTrailGapAssumptions where
  xRayTracingEnabled : Bool
  cloudTrailForwardedToSIEM : Bool
  observabilityGap : Nat
  gapFromMissingXRayAndSIEM :
    xRayTracingEnabled = false →
    cloudTrailForwardedToSIEM = false →
    0 < observabilityGap

theorem natgw_xray_cloudtrail_gap_exists
    (a : NATGWXRayCloudTrailGapAssumptions)
    (hXRay : a.xRayTracingEnabled = false)
    (hSIEM : a.cloudTrailForwardedToSIEM = false) :
    0 < a.observabilityGap :=
  a.gapFromMissingXRayAndSIEM hXRay hSIEM

end ForkRaceFoldTheorems
