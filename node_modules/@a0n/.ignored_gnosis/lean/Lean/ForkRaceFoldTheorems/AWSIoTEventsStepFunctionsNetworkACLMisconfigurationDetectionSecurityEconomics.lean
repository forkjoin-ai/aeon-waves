/-!
# AWSIoTEventsStepFunctionsNetworkACLMisconfigurationDetectionSecurityEconomics

AWS Network ACL misconfiguration scanner for IoT Events + Step Functions
pipelines. Five security-economics gap theorems: each proves that the ABSENCE
of a control on the Network ACL surface creates measurable compliance or
attack-surface cost.

Anti-thesis pattern: structure posits the ABSENCE of a control, theorem
derives strictly-positive gap. Zero sorry — all close by exact.
-/

namespace ForkRaceFoldTheorems

-- ── Theorem 1 ────────────────────────────────────────────────────────────────
-- Anti-thesis: VPC flow logs for subnets governed by the Network ACL are NOT
-- encrypted with a customer-managed KMS key → compliance gap is strictly positive.

structure NetworkACLFlowLogCMKGapAssumptions where
  flowLogsEncryptedWithCMK : Bool
  complianceGap : Nat
  gapFromMissingCMK : flowLogsEncryptedWithCMK = false → 0 < complianceGap

theorem network_acl_flow_log_cmk_gap_exists
    (a : NetworkACLFlowLogCMKGapAssumptions)
    (h : a.flowLogsEncryptedWithCMK = false) :
    0 < a.complianceGap :=
  a.gapFromMissingCMK h

-- ── Theorem 2 ────────────────────────────────────────────────────────────────
-- Anti-thesis: no SCP or AWS Config rule prevents deletion of the Network ACL
-- protecting IoT Events ingress subnets AND the ACL has more than one subnet
-- association → deletion-scope risk is strictly positive.

structure NetworkACLSCPDeletionGapAssumptions where
  scpOrConfigRulePresent : Bool
  subnetAssociationCount : Nat
  deletionScopeRisk : Nat
  gapFromMissingProtectionAndMultiSubnet :
    scpOrConfigRulePresent = false →
    1 < subnetAssociationCount →
    0 < deletionScopeRisk

theorem network_acl_scp_deletion_gap_exists
    (a : NetworkACLSCPDeletionGapAssumptions)
    (hSCP : a.scpOrConfigRulePresent = false)
    (hSubnets : 1 < a.subnetAssociationCount) :
    0 < a.deletionScopeRisk :=
  a.gapFromMissingProtectionAndMultiSubnet hSCP hSubnets

-- ── Theorem 3 ────────────────────────────────────────────────────────────────
-- Anti-thesis: the IAM role permitted to invoke ec2:ReplaceNetworkAclEntry is
-- NOT scoped to the specific ACL ARN → privilege escalation risk is strictly
-- positive.

structure NetworkACLIAMRoleScopeGapAssumptions where
  iamRoleScopedToACL : Bool
  privilegeEscalationRisk : Nat
  gapFromUnscopedRole : iamRoleScopedToACL = false → 0 < privilegeEscalationRisk

theorem network_acl_iam_role_scope_gap_exists
    (a : NetworkACLIAMRoleScopeGapAssumptions)
    (h : a.iamRoleScopedToACL = false) :
    0 < a.privilegeEscalationRisk :=
  a.gapFromUnscopedRole h

-- ── Theorem 4 ────────────────────────────────────────────────────────────────
-- Anti-thesis: no CloudWatch alarm fires on Network ACL rule changes AND the
-- SOC has no on-call runbook for unexpected ACL modifications → SOC blind-spot
-- risk is strictly positive.

structure NetworkACLChangeAlarmSOCGapAssumptions where
  cloudWatchAlarmConfigured : Bool
  socRunbookExists : Bool
  socBlindSpotRisk : Nat
  gapFromMissingAlarmAndRunbook :
    cloudWatchAlarmConfigured = false →
    socRunbookExists = false →
    0 < socBlindSpotRisk

theorem network_acl_change_alarm_soc_gap_exists
    (a : NetworkACLChangeAlarmSOCGapAssumptions)
    (hAlarm : a.cloudWatchAlarmConfigured = false)
    (hRunbook : a.socRunbookExists = false) :
    0 < a.socBlindSpotRisk :=
  a.gapFromMissingAlarmAndRunbook hAlarm hRunbook

-- ── Theorem 5 ────────────────────────────────────────────────────────────────
-- Anti-thesis: AWS X-Ray active tracing is NOT enabled on the Step Functions
-- state machine that modifies Network ACL rules AND CloudTrail API calls for
-- ec2:CreateNetworkAclEntry are not forwarded to a SIEM → observability gap
-- is strictly positive.

structure NetworkACLXRayCloudTrailGapAssumptions where
  xRayTracingEnabled : Bool
  cloudTrailForwardedToSIEM : Bool
  observabilityGap : Nat
  gapFromMissingXRayAndSIEM :
    xRayTracingEnabled = false →
    cloudTrailForwardedToSIEM = false →
    0 < observabilityGap

theorem network_acl_xray_cloudtrail_gap_exists
    (a : NetworkACLXRayCloudTrailGapAssumptions)
    (hXRay : a.xRayTracingEnabled = false)
    (hSIEM : a.cloudTrailForwardedToSIEM = false) :
    0 < a.observabilityGap :=
  a.gapFromMissingXRayAndSIEM hXRay hSIEM

end ForkRaceFoldTheorems
