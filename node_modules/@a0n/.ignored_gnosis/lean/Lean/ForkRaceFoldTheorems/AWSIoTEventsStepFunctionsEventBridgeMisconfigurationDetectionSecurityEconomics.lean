/-!
# AWSIoTEventsStepFunctionsEventBridgeMisconfigurationDetectionSecurityEconomics

Security-economics gap theorems for AWS IoT Events → Step Functions →
EventBridge pipeline misconfiguration detection. Five proofs that absence of
controls creates measurable revenue-at-risk or compliance exposure.

Anti-thesis pattern: each structure posits the ABSENCE of a control, then
derives a positive risk quantity. Zero sorry — all theorems close by exact.
-/

namespace ForkRaceFoldTheorems

-- ── Theorem 1 ────────────────────────────────────────────────────────────────
-- Anti-thesis: the EventBridge event bus is NOT encrypted with a customer-managed
-- KMS key → compliance gap is strictly positive.

structure EventBridgeCMKGapAssumptions where
  busCMKEncrypted : Bool
  complianceRisk : Nat
  gapFromMissingCMK : busCMKEncrypted = false → 0 < complianceRisk

theorem eventbridge_cmk_gap_exists
    (a : EventBridgeCMKGapAssumptions)
    (h : a.busCMKEncrypted = false) :
    0 < a.complianceRisk :=
  a.gapFromMissingCMK h

-- ── Theorem 2 ────────────────────────────────────────────────────────────────
-- Anti-thesis: no SCP denies creation of public EventBridge rules AND the
-- event-bus resource policy allows cross-account event publication without
-- condition keys → rule-hijack risk is strictly positive.

structure EventBridgeSCPAndBusPolicyGapAssumptions where
  scpDeniesPublicRules : Bool
  busPolicyRestrictsXAccount : Bool
  hijackRisk : Nat
  gapFromMissingSCPAndPolicy :
    scpDeniesPublicRules = false →
    busPolicyRestrictsXAccount = false →
    0 < hijackRisk

theorem eventbridge_scp_and_bus_policy_gap_exists
    (a : EventBridgeSCPAndBusPolicyGapAssumptions)
    (hSCP : a.scpDeniesPublicRules = false)
    (hPolicy : a.busPolicyRestrictsXAccount = false) :
    0 < a.hijackRisk :=
  a.gapFromMissingSCPAndPolicy hSCP hPolicy

-- ── Theorem 3 ────────────────────────────────────────────────────────────────
-- Anti-thesis: the Step Functions IAM role grants EventBridge PutEvents to all
-- buses instead of the specific bus ARN → IAM scope gap is strictly positive.

structure EventBridgeIAMRoleScopeGapAssumptions where
  iamRoleScopedToSpecificBus : Bool
  iamScopeGap : Nat
  gapFromBroadRole : iamRoleScopedToSpecificBus = false → 0 < iamScopeGap

theorem eventbridge_iam_role_scope_gap_exists
    (a : EventBridgeIAMRoleScopeGapAssumptions)
    (h : a.iamRoleScopedToSpecificBus = false) :
    0 < a.iamScopeGap :=
  a.gapFromBroadRole h

-- ── Theorem 4 ────────────────────────────────────────────────────────────────
-- Anti-thesis: no CloudWatch alarm fires on EventBridge FailedInvocations
-- exceeding threshold AND the SOC has no dead-letter rule runbook → SOC gap is
-- strictly positive.

structure EventBridgeAlarmSOCGapAssumptions where
  cloudWatchAlarmConfigured : Bool
  dlrRunbookExists : Bool
  socGap : Nat
  gapFromMissingAlarmAndRunbook :
    cloudWatchAlarmConfigured = false →
    dlrRunbookExists = false →
    0 < socGap

theorem eventbridge_alarm_soc_gap_exists
    (a : EventBridgeAlarmSOCGapAssumptions)
    (hAlarm : a.cloudWatchAlarmConfigured = false)
    (hRunbook : a.dlrRunbookExists = false) :
    0 < a.socGap :=
  a.gapFromMissingAlarmAndRunbook hAlarm hRunbook

-- ── Theorem 5 ────────────────────────────────────────────────────────────────
-- Anti-thesis: AWS X-Ray active tracing is NOT enabled on the Step Functions
-- state machine that publishes to EventBridge AND correlation IDs are not
-- propagated in event detail → observability gap is strictly positive.

structure EventBridgeXRayGapAssumptions where
  xRayTracingEnabled : Bool
  correlationIdPropagated : Bool
  observabilityGap : Nat
  gapFromMissingXRay :
    xRayTracingEnabled = false →
    correlationIdPropagated = false →
    0 < observabilityGap

theorem eventbridge_xray_gap_exists
    (a : EventBridgeXRayGapAssumptions)
    (hXRay : a.xRayTracingEnabled = false)
    (hCorr : a.correlationIdPropagated = false) :
    0 < a.observabilityGap :=
  a.gapFromMissingXRay hXRay hCorr

end ForkRaceFoldTheorems
