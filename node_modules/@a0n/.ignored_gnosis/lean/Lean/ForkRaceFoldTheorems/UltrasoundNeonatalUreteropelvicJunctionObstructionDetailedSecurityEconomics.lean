/-!
# UltrasoundNeonatalUreteropelvicJunctionObstructionDetailedSecurityEconomics

Neonatal renal ultrasound — ureteropelvic junction (UPJ) obstruction.
Security-economics gap theorems derived from absent diagnostic controls.

Anti-thesis pattern: each structure posits the ABSENCE of a required
measurement or finding, then derives a positive risk quantity.
Zero sorry — all theorems close by exact.
-/

namespace ForkRaceFoldTheorems

-- ── Theorem 1 ────────────────────────────────────────────────────────────────
-- Anti-thesis: the anteroposterior renal pelvis diameter (APD) is NOT measured
-- and SFU grade is not documented → severity classification gap is strictly
-- positive.

structure UPJObstructionAPDGradingGapAssumptions where
  anteroposteriorDiameterMeasured : Bool
  sfuGradeDocumented : Bool
  severityClassificationGap : Nat
  gapFromMissingAPDAndGrade :
    anteroposteriorDiameterMeasured = false →
    sfuGradeDocumented = false →
    0 < severityClassificationGap

theorem upj_obstruction_apd_grading_gap_exists
    (a : UPJObstructionAPDGradingGapAssumptions)
    (hAPD : a.anteroposteriorDiameterMeasured = false)
    (hSFU : a.sfuGradeDocumented = false) :
    0 < a.severityClassificationGap :=
  a.gapFromMissingAPDAndGrade hAPD hSFU

-- ── Theorem 2 ────────────────────────────────────────────────────────────────
-- Anti-thesis: renal parenchymal thickness and cortical echogenicity are NOT
-- documented → parenchymal injury assessment gap is strictly positive.

structure UPJParenchymalThicknessGapAssumptions where
  parenchymalThicknessDocumented : Bool
  corticalEchogenicityDocumented : Bool
  parenchymalInjuryAssessmentGap : Nat
  gapFromMissingParenchymaData :
    parenchymalThicknessDocumented = false →
    corticalEchogenicityDocumented = false →
    0 < parenchymalInjuryAssessmentGap

theorem upj_parenchymal_thickness_gap_exists
    (a : UPJParenchymalThicknessGapAssumptions)
    (hThickness : a.parenchymalThicknessDocumented = false)
    (hEcho : a.corticalEchogenicityDocumented = false) :
    0 < a.parenchymalInjuryAssessmentGap :=
  a.gapFromMissingParenchymaData hThickness hEcho

-- ── Theorem 3 ────────────────────────────────────────────────────────────────
-- Anti-thesis: the ureter is NOT traced to rule out ureterovesical junction
-- (UVJ) obstruction or mega-ureter → differential diagnosis gap is strictly
-- positive.

structure UPJUreterVisualisationGapAssumptions where
  ureterTracedToUVJ : Bool
  differentialDiagnosisGap : Nat
  gapFromUnvisualizedUreter :
    ureterTracedToUVJ = false → 0 < differentialDiagnosisGap

theorem upj_ureter_visualisation_gap_exists
    (a : UPJUreterVisualisationGapAssumptions)
    (h : a.ureterTracedToUVJ = false) :
    0 < a.differentialDiagnosisGap :=
  a.gapFromUnvisualizedUreter h

-- ── Theorem 4 ────────────────────────────────────────────────────────────────
-- Anti-thesis: colour Doppler resistive index (RI) is NOT measured in the
-- intra-renal arteries AND ureteral jets are not assessed → functional
-- obstruction assessment gap is strictly positive.

structure UPJDopplerResistiveIndexGapAssumptions where
  resistiveIndexMeasured : Bool
  ureteralJetsAssessed : Bool
  functionalObstructionAssessmentGap : Nat
  gapFromMissingDopplerData :
    resistiveIndexMeasured = false →
    ureteralJetsAssessed = false →
    0 < functionalObstructionAssessmentGap

theorem upj_doppler_resistive_index_gap_exists
    (a : UPJDopplerResistiveIndexGapAssumptions)
    (hRI : a.resistiveIndexMeasured = false)
    (hJets : a.ureteralJetsAssessed = false) :
    0 < a.functionalObstructionAssessmentGap :=
  a.gapFromMissingDopplerData hRI hJets

-- ── Theorem 5 ────────────────────────────────────────────────────────────────
-- Anti-thesis: contralateral kidney size Z-score is NOT measured AND no
-- follow-up ultrasound interval is specified → surveillance gap is strictly
-- positive.

structure UPJContralateralSurveillanceGapAssumptions where
  contralateralZScoreMeasured : Bool
  followUpUltrasoundScheduled : Bool
  surveillanceGap : Nat
  gapFromMissingSurveillance :
    contralateralZScoreMeasured = false →
    followUpUltrasoundScheduled = false →
    0 < surveillanceGap

theorem upj_contralateral_surveillance_gap_exists
    (a : UPJContralateralSurveillanceGapAssumptions)
    (hZScore : a.contralateralZScoreMeasured = false)
    (hFollowUp : a.followUpUltrasoundScheduled = false) :
    0 < a.surveillanceGap :=
  a.gapFromMissingSurveillance hZScore hFollowUp

end ForkRaceFoldTheorems
