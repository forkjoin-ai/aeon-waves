/-!
# UltrasoundNeonatalGastrointestinalDuplicationCystDetailedSecurityEconomics

Neonatal gastrointestinal (GI) duplication cyst ultrasound diagnostic-gap
theorems. Each theorem proves that ABSENCE of a required ultrasound
assessment creates a measurable patient-safety or diagnostic-quality gap.

Anti-thesis pattern: structure posits missing assessment; theorem
derives strictly-positive gap. Zero sorry — all close by exact.
-/

namespace ForkRaceFoldTheorems

-- ── Theorem 1 ────────────────────────────────────────────────────────────────
-- Anti-thesis: duplication cyst wall structure (echogenic inner mucosal
-- layer, hypoechoic muscular layer — the "double-wall" sign) is NOT
-- documented → diagnostic gap is strictly positive, missing the pathognomonic
-- feature that distinguishes duplication cysts from other cystic masses.

structure DuplicationCystDoubleWallSignGapAssumptions where
  doubleWallSignDocumented : Bool
  diagnosticGap : Nat
  gapFromMissingDoubleWall : doubleWallSignDocumented = false → 0 < diagnosticGap

theorem duplication_cyst_double_wall_sign_gap_exists
    (a : DuplicationCystDoubleWallSignGapAssumptions)
    (h : a.doubleWallSignDocumented = false) :
    0 < a.diagnosticGap :=
  a.gapFromMissingDoubleWall h

-- ── Theorem 2 ────────────────────────────────────────────────────────────────
-- Anti-thesis: cyst location along the GI tract (oesophageal, gastric,
-- enteric, colonic) and relationship to adjacent bowel is NOT characterised
-- → surgical planning gap is strictly positive.

structure DuplicationCystLocationGapAssumptions where
  locationAlongGITractDocumented : Bool
  adjacentBowelRelationshipCharacterised : Bool
  surgicalPlanningGap : Nat
  gapFromMissingLocation :
    locationAlongGITractDocumented = false →
    adjacentBowelRelationshipCharacterised = false →
    0 < surgicalPlanningGap

theorem duplication_cyst_location_gap_exists
    (a : DuplicationCystLocationGapAssumptions)
    (hLoc : a.locationAlongGITractDocumented = false)
    (hAdj : a.adjacentBowelRelationshipCharacterised = false) :
    0 < a.surgicalPlanningGap :=
  a.gapFromMissingLocation hLoc hAdj

-- ── Theorem 3 ────────────────────────────────────────────────────────────────
-- Anti-thesis: Doppler flow within or around the cyst wall is NOT assessed →
-- vascular gap is strictly positive, missing information about feeding-vessel
-- anatomy needed for safe surgical excision.

structure DuplicationCystDopplerFlowGapAssumptions where
  dopplerFlowAssessed : Bool
  feedingVesselAnatomyGap : Nat
  gapFromMissingDoppler : dopplerFlowAssessed = false → 0 < feedingVesselAnatomyGap

theorem duplication_cyst_doppler_flow_gap_exists
    (a : DuplicationCystDopplerFlowGapAssumptions)
    (h : a.dopplerFlowAssessed = false) :
    0 < a.feedingVesselAnatomyGap :=
  a.gapFromMissingDoppler h

-- ── Theorem 4 ────────────────────────────────────────────────────────────────
-- Anti-thesis: complication signs (haemorrhage into cyst, infection, bowel
-- obstruction) are NOT documented → complication gap is strictly positive,
-- potentially missing indications for urgent intervention.

structure DuplicationCystComplicationGapAssumptions where
  haemorrhageSignsDocumented : Bool
  obstructionAssessed : Bool
  complicationGap : Nat
  gapFromMissingComplicationAssessment :
    haemorrhageSignsDocumented = false →
    obstructionAssessed = false →
    0 < complicationGap

theorem duplication_cyst_complication_gap_exists
    (a : DuplicationCystComplicationGapAssumptions)
    (hHaem : a.haemorrhageSignsDocumented = false)
    (hObs : a.obstructionAssessed = false) :
    0 < a.complicationGap :=
  a.gapFromMissingComplicationAssessment hHaem hObs

-- ── Theorem 5 ────────────────────────────────────────────────────────────────
-- Anti-thesis: associated vertebral/spinal anomalies (neurenteric cyst
-- spectrum) are NOT sought on ultrasound AND surgical referral is NOT made →
-- surgical referral gap is strictly positive.

structure DuplicationCystSpinalAssociationReferralGapAssumptions where
  spinalAnomaliesSought : Bool
  surgicalReferralMade : Bool
  referralGap : Nat
  gapFromMissingSpinalAndReferral :
    spinalAnomaliesSought = false →
    surgicalReferralMade = false →
    0 < referralGap

theorem duplication_cyst_spinal_association_referral_gap_exists
    (a : DuplicationCystSpinalAssociationReferralGapAssumptions)
    (hSpinal : a.spinalAnomaliesSought = false)
    (hRef : a.surgicalReferralMade = false) :
    0 < a.referralGap :=
  a.gapFromMissingSpinalAndReferral hSpinal hRef

end ForkRaceFoldTheorems
