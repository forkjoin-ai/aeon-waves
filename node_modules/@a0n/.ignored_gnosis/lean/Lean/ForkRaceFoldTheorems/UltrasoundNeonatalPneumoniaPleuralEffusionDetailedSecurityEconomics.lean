namespace ForkRaceFoldTheorems

structure NeonatalConsolidationGradingGapAssumptions where
  consolidationGradedBilaterally : Bool
  severityMisclassificationRisk : Nat
  gapFromUngradedConsolidation : consolidationGradedBilaterally = false → 0 < severityMisclassificationRisk

theorem neonatal_consolidation_grading_gap_exists (a : NeonatalConsolidationGradingGapAssumptions)
    (h : a.consolidationGradedBilaterally = false) : 0 < a.severityMisclassificationRisk :=
  a.gapFromUngradedConsolidation h

structure NeonatalPleuralEffusionMeasurementGapAssumptions where
  effusionDepthQuantified : Bool
  echoCharacteristicsReported : Bool
  drainageDecisionGap : Nat
  gapFromUnmeasuredEffusion : effusionDepthQuantified = false → echoCharacteristicsReported = false → 0 < drainageDecisionGap

theorem neonatal_pleural_effusion_measurement_gap_exists (a : NeonatalPleuralEffusionMeasurementGapAssumptions)
    (hDepth : a.effusionDepthQuantified = false) (hEcho : a.echoCharacteristicsReported = false) : 0 < a.drainageDecisionGap :=
  a.gapFromUnmeasuredEffusion hDepth hEcho

structure NeonatalBLineSlideGapAssumptions where
  bLinePatternCharacterised : Bool
  pleuralSlidingAssessed : Bool
  pneumothoraxMissedRisk : Nat
  gapFromUnassessedBLineSlide : bLinePatternCharacterised = false → pleuralSlidingAssessed = false → 0 < pneumothoraxMissedRisk

theorem neonatal_bline_slide_gap_exists (a : NeonatalBLineSlideGapAssumptions)
    (hBLine : a.bLinePatternCharacterised = false) (hSlide : a.pleuralSlidingAssessed = false) : 0 < a.pneumothoraxMissedRisk :=
  a.gapFromUnassessedBLineSlide hBLine hSlide

structure NeonatalCardiacFunctionEffusionGapAssumptions where
  cardiacFunctionAssessed : Bool
  cardiogenicCauseExcluded : Bool
  mismanagementRisk : Nat
  gapFromUnassessedCardiacFunction : cardiacFunctionAssessed = false → cardiogenicCauseExcluded = false → 0 < mismanagementRisk

theorem neonatal_cardiac_function_effusion_gap_exists (a : NeonatalCardiacFunctionEffusionGapAssumptions)
    (hCardiac : a.cardiacFunctionAssessed = false) (hCardiogenic : a.cardiogenicCauseExcluded = false) : 0 < a.mismanagementRisk :=
  a.gapFromUnassessedCardiacFunction hCardiac hCardiogenic

structure NeonatalChylothoraxExclusionGapAssumptions where
  serialFollowUpPlanned : Bool
  chylothoraxWorkupInitiated : Bool
  missedChylothoraxRisk : Nat
  gapFromMissingExclusion : serialFollowUpPlanned = false → chylothoraxWorkupInitiated = false → 0 < missedChylothoraxRisk

theorem neonatal_chylothorax_exclusion_gap_exists (a : NeonatalChylothoraxExclusionGapAssumptions)
    (hSerial : a.serialFollowUpPlanned = false) (hWorkup : a.chylothoraxWorkupInitiated = false) : 0 < a.missedChylothoraxRisk :=
  a.gapFromMissingExclusion hSerial hWorkup

end ForkRaceFoldTheorems
