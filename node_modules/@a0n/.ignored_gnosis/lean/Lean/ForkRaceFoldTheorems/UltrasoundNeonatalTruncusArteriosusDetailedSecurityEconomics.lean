/-!
# UltrasoundNeonatalTruncusArteriosusDetailedSecurityEconomics

Neonatal truncus arteriosus: single arterial trunk supplying systemic,
pulmonary, and coronary circulation. Five security-economics gap theorems
for clinical imaging gaps that constitute missed-diagnosis risk — each with a
measurable economic (medico-legal / readmission) cost.

Anti-thesis pattern: structure posits the ABSENCE of an imaging assessment,
theorem derives strictly-positive risk. Zero sorry — all close by exact.
-/

namespace ForkRaceFoldTheorems

-- ── Theorem 1 ────────────────────────────────────────────────────────────────
-- Anti-thesis: single truncal valve morphology NOT characterised (bicuspid /
-- tricuspid / quadricuspid) → truncal valve regurgitation severity misjudged,
-- surgical timing risk is strictly positive.

structure TruncalValveMorphologyGapAssumptions where
  valveMorphologyCharacterised : Bool
  surgicalTimingRisk : Nat
  gapFromUncharacterisedMorphology :
    valveMorphologyCharacterised = false → 0 < surgicalTimingRisk

theorem truncal_valve_morphology_gap_exists
    (a : TruncalValveMorphologyGapAssumptions)
    (h : a.valveMorphologyCharacterised = false) :
    0 < a.surgicalTimingRisk :=
  a.gapFromUncharacterisedMorphology h

-- ── Theorem 2 ────────────────────────────────────────────────────────────────
-- Anti-thesis: pulmonary artery origin NOT classified (Van Praagh type) AND
-- pulmonary band candidacy NOT assessed → repair strategy error risk is
-- strictly positive.

structure PulmonaryArteryOriginClassificationGapAssumptions where
  originClassified : Bool
  bandCandidacyAssessed : Bool
  repairStrategyRisk : Nat
  gapFromUnclassifiedOriginAndCandidacy :
    originClassified = false →
    bandCandidacyAssessed = false →
    0 < repairStrategyRisk

theorem pulmonary_artery_origin_classification_gap_exists
    (a : PulmonaryArteryOriginClassificationGapAssumptions)
    (hOrigin : a.originClassified = false)
    (hCandidacy : a.bandCandidacyAssessed = false) :
    0 < a.repairStrategyRisk :=
  a.gapFromUnclassifiedOriginAndCandidacy hOrigin hCandidacy

-- ── Theorem 3 ────────────────────────────────────────────────────────────────
-- Anti-thesis: ventricular septal defect size and position NOT measured
-- → conduit sizing error risk is strictly positive.

structure VSDSizePositionGapAssumptions where
  vsdSizeMeasured : Bool
  vsdPositionDocumented : Bool
  conduitSizingRisk : Nat
  gapFromUnmeasuredVSDSizePosition :
    vsdSizeMeasured = false →
    vsdPositionDocumented = false →
    0 < conduitSizingRisk

theorem vsd_size_position_gap_exists
    (a : VSDSizePositionGapAssumptions)
    (hSize : a.vsdSizeMeasured = false)
    (hPosition : a.vsdPositionDocumented = false) :
    0 < a.conduitSizingRisk :=
  a.gapFromUnmeasuredVSDSizePosition hSize hPosition

-- ── Theorem 4 ────────────────────────────────────────────────────────────────
-- Anti-thesis: aortic arch sidedness and interruption NOT excluded → repair
-- sequencing error risk is strictly positive.

structure AorticArchSidednessInterruptionGapAssumptions where
  archSidednessDocumented : Bool
  interruptionExcluded : Bool
  repairSequencingRisk : Nat
  gapFromUndocumentedArchAndInterruption :
    archSidednessDocumented = false →
    interruptionExcluded = false →
    0 < repairSequencingRisk

theorem aortic_arch_sidedness_interruption_gap_exists
    (a : AorticArchSidednessInterruptionGapAssumptions)
    (hArch : a.archSidednessDocumented = false)
    (hInterruption : a.interruptionExcluded = false) :
    0 < a.repairSequencingRisk :=
  a.gapFromUndocumentedArchAndInterruption hArch hInterruption

-- ── Theorem 5 ────────────────────────────────────────────────────────────────
-- Anti-thesis: truncal valve regurgitation severity NOT graded by CW Doppler
-- AND ventricular function NOT quantified → operative mortality risk is
-- strictly positive.

structure TruncalValveRegurgitationVFGapAssumptions where
  regurgitationGraded : Bool
  ventricularFunctionQuantified : Bool
  operativeMortalityRisk : Nat
  gapFromUngradedRegurgitationAndUnquantifiedVF :
    regurgitationGraded = false →
    ventricularFunctionQuantified = false →
    0 < operativeMortalityRisk

theorem truncal_valve_regurgitation_vf_gap_exists
    (a : TruncalValveRegurgitationVFGapAssumptions)
    (hGrade : a.regurgitationGraded = false)
    (hVF : a.ventricularFunctionQuantified = false) :
    0 < a.operativeMortalityRisk :=
  a.gapFromUngradedRegurgitationAndUnquantifiedVF hGrade hVF

end ForkRaceFoldTheorems
