namespace ForkRaceFoldTheorems

structure EcoliMeningitisVentriculitisGapAssumptions where
  cranialUltrasoundForVentriculitisPerformed : Bool
  ventricleDilationDocumented : Bool
  ventriculitisProgressionRisk : Nat
  gapFromMissingVentriculitisUS : cranialUltrasoundForVentriculitisPerformed = false → ventricleDilationDocumented = false → 0 < ventriculitisProgressionRisk

theorem ecoli_meningitis_ventriculitis_gap_exists (a : EcoliMeningitisVentriculitisGapAssumptions)
    (hUS : a.cranialUltrasoundForVentriculitisPerformed = false) (hDoc : a.ventricleDilationDocumented = false) : 0 < a.ventriculitisProgressionRisk :=
  a.gapFromMissingVentriculitisUS hUS hDoc

