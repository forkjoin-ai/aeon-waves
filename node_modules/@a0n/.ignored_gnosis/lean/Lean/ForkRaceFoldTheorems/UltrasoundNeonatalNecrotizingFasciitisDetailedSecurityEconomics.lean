/-!
# UltrasoundNeonatalNecrotizingFasciitisDetailedSecurityEconomics

Neonatal necrotizing fasciitis: five security-economics gap theorems proving
that absence of ultrasound-guided detection and monitoring controls creates
measurable patient-safety risk or compliance exposure.

Anti-thesis pattern: structure posits the ABSENCE of a control, theorem
derives strictly-positive gap. Zero sorry — all close by exact.
-/

namespace ForkRaceFoldTheorems

-- ── Theorem 1 ────────────────────────────────────────────────────────────────
-- Anti-thesis: soft-tissue high-frequency ultrasound is NOT performed to
-- detect fascial plane gas and fluid in neonatal necrotizing fasciitis →
-- patient-safety risk is strictly positive.

structure NecFasciitisSOftTissueUSGapAssumptions where
  softTissueUSPerformed : Bool
  patientSafetyRisk : Nat
  gapFromMissingUS : softTissueUSPerformed = false → 0 < patientSafetyRisk

theorem nec_fasciitis_soft_tissue_us_gap_exists
    (a : NecFasciitisSOftTissueUSGapAssumptions)
    (h : a.softTissueUSPerformed = false) :
    0 < a.patientSafetyRisk :=
  a.gapFromMissingUS h

-- ── Theorem 2 ────────────────────────────────────────────────────────────────
-- Anti-thesis: Doppler ultrasound of the affected limb is NOT performed to
-- assess vascular compromise AND surgical referral is delayed → limb-loss risk
-- is strictly positive.

structure NecFaschiitisDopplerLimbGapAssumptions where
  dopplerUSPerformed : Bool
  surgicalReferralDelayed : Bool
  limbLossRisk : Nat
  gapFromMissingDopplerAndDelay :
    dopplerUSPerformed = false →
    surgicalReferralDelayed = true →
    0 < limbLossRisk

theorem nec_fasciitis_doppler_limb_gap_exists
    (a : NecFaschiitisDopplerLimbGapAssumptions)
    (hDoppler : a.dopplerUSPerformed = false)
    (hDelay : a.surgicalReferralDelayed = true) :
    0 < a.limbLossRisk :=
  a.gapFromMissingDopplerAndDelay hDoppler hDelay

-- ── Theorem 3 ────────────────────────────────────────────────────────────────
-- Anti-thesis: serial ultrasound is NOT used to monitor post-surgical wound
-- margins for residual necrotic tissue → recurrence detection gap is strictly
-- positive.

structure NecFasciitisSerialUSMonitoringGapAssumptions where
  serialUSPerformed : Bool
  recurrenceDetectionGap : Nat
  gapFromMissingSerialUS : serialUSPerformed = false → 0 < recurrenceDetectionGap

theorem nec_fasciitis_serial_us_monitoring_gap_exists
    (a : NecFasciitisSerialUSMonitoringGapAssumptions)
    (h : a.serialUSPerformed = false) :
    0 < a.recurrenceDetectionGap :=
  a.gapFromMissingSerialUS h

-- ── Theorem 4 ────────────────────────────────────────────────────────────────
-- Anti-thesis: cardiac echocardiography is NOT performed to rule out septic
-- emboli in neonatal necrotizing fasciitis bacteraemia AND no cardiology
-- referral is made → cardiac complication risk is strictly positive.

structure NecFasciitisCardiacEchoGapAssumptions where
  echocardiographyPerformed : Bool
  cardiologyReferralMade : Bool
  cardiacComplicationRisk : Nat
  gapFromMissingEchoAndReferral :
    echocardiographyPerformed = false →
    cardiologyReferralMade = false →
    0 < cardiacComplicationRisk

theorem nec_fasciitis_cardiac_echo_gap_exists
    (a : NecFasciitisCardiacEchoGapAssumptions)
    (hEcho : a.echocardiographyPerformed = false)
    (hRef : a.cardiologyReferralMade = false) :
    0 < a.cardiacComplicationRisk :=
  a.gapFromMissingEchoAndReferral hEcho hRef

-- ── Theorem 5 ────────────────────────────────────────────────────────────────
-- Anti-thesis: skin and soft-tissue follow-up ultrasound is NOT scheduled
-- after discharge AND reconstructive surgery planning ultrasound is absent →
-- long-term functional outcome risk is strictly positive.

structure NecFasciitisFollowUpUSGapAssumptions where
  followUpUSScheduled : Bool
  reconstructivePlanningUSPerformed : Bool
  longTermFunctionalRisk : Nat
  gapFromMissingFollowUp :
    followUpUSScheduled = false →
    reconstructivePlanningUSPerformed = false →
    0 < longTermFunctionalRisk

theorem nec_fasciitis_follow_up_us_gap_exists
    (a : NecFasciitisFollowUpUSGapAssumptions)
    (hFollowUp : a.followUpUSScheduled = false)
    (hRecon : a.reconstructivePlanningUSPerformed = false) :
    0 < a.longTermFunctionalRisk :=
  a.gapFromMissingFollowUp hFollowUp hRecon

end ForkRaceFoldTheorems
