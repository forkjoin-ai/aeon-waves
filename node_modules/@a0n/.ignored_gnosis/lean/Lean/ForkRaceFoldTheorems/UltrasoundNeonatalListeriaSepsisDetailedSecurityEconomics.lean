/-!
# UltrasoundNeonatalListeriaSepsisDetailedSecurityEconomics

Neonatal listeria sepsis: five security-economics gap theorems proving that
absence of ultrasound-guided detection and monitoring controls creates
measurable patient-safety risk or compliance exposure.

Anti-thesis pattern: structure posits the ABSENCE of a control, theorem
derives strictly-positive gap. Zero sorry — all close by exact.
-/

namespace ForkRaceFoldTheorems

-- ── Theorem 1 ────────────────────────────────────────────────────────────────
-- Anti-thesis: cranial ultrasound is NOT performed to detect cerebral abscess
-- in neonatal listeria sepsis → patient-safety risk is strictly positive.

structure ListeriaAbscessCranialUSGapAssumptions where
  cranialUSPerformed : Bool
  patientSafetyRisk : Nat
  gapFromMissingUS : cranialUSPerformed = false → 0 < patientSafetyRisk

theorem listeria_abscess_cranial_us_gap_exists
    (a : ListeriaAbscessCranialUSGapAssumptions)
    (h : a.cranialUSPerformed = false) :
    0 < a.patientSafetyRisk :=
  a.gapFromMissingUS h

-- ── Theorem 2 ────────────────────────────────────────────────────────────────
-- Anti-thesis: abdominal ultrasound is NOT used to detect hepatic or splenic
-- granulomata in disseminated listeriosis AND the diagnosis is delayed →
-- dissemination risk is strictly positive.

structure ListeriaHepaticGranulomataUSGapAssumptions where
  abdominalUSPerformed : Bool
  diagnosisDelayed : Bool
  disseminationRisk : Nat
  gapFromMissingUSAndDelay :
    abdominalUSPerformed = false →
    diagnosisDelayed = true →
    0 < disseminationRisk

theorem listeria_hepatic_granulomata_us_gap_exists
    (a : ListeriaHepaticGranulomataUSGapAssumptions)
    (hUS : a.abdominalUSPerformed = false)
    (hDelay : a.diagnosisDelayed = true) :
    0 < a.disseminationRisk :=
  a.gapFromMissingUSAndDelay hUS hDelay

-- ── Theorem 3 ────────────────────────────────────────────────────────────────
-- Anti-thesis: renal cortical echogenicity is NOT assessed by ultrasound in
-- neonatal listeria sepsis → renal compromise detection gap is strictly positive.

structure ListeriaRenalEchogenicityUSGapAssumptions where
  renalUSAssessed : Bool
  renalCompromiseDetectionGap : Nat
  gapFromMissingRenalUS : renalUSAssessed = false → 0 < renalCompromiseDetectionGap

theorem listeria_renal_echogenicity_us_gap_exists
    (a : ListeriaRenalEchogenicityUSGapAssumptions)
    (h : a.renalUSAssessed = false) :
    0 < a.renalCompromiseDetectionGap :=
  a.gapFromMissingRenalUS h

-- ── Theorem 4 ────────────────────────────────────────────────────────────────
-- Anti-thesis: cardiac echocardiography is NOT performed to rule out
-- endocarditis in neonatal listeria bacteraemia AND no cardiology referral is
-- made → cardiac complication risk is strictly positive.

structure ListeriaEndocarditisEchoGapAssumptions where
  echocardiographyPerformed : Bool
  cardiologyReferralMade : Bool
  cardiacComplicationRisk : Nat
  gapFromMissingEchoAndReferral :
    echocardiographyPerformed = false →
    cardiologyReferralMade = false →
    0 < cardiacComplicationRisk

theorem listeria_endocarditis_echo_gap_exists
    (a : ListeriaEndocarditisEchoGapAssumptions)
    (hEcho : a.echocardiographyPerformed = false)
    (hRef : a.cardiologyReferralMade = false) :
    0 < a.cardiacComplicationRisk :=
  a.gapFromMissingEchoAndReferral hEcho hRef

-- ── Theorem 5 ────────────────────────────────────────────────────────────────
-- Anti-thesis: neurodevelopmental follow-up ultrasound is NOT scheduled after
-- neonatal listeria meningitis AND hearing assessment is not arranged →
-- long-term outcome risk is strictly positive.

structure ListeriaNeuroFollowUpUSGapAssumptions where
  neurodevelopmentalFollowUpScheduled : Bool
  hearingAssessmentArranged : Bool
  longTermOutcomeRisk : Nat
  gapFromMissingFollowUp :
    neurodevelopmentalFollowUpScheduled = false →
    hearingAssessmentArranged = false →
    0 < longTermOutcomeRisk

theorem listeria_neuro_follow_up_us_gap_exists
    (a : ListeriaNeuroFollowUpUSGapAssumptions)
    (hNeuro : a.neurodevelopmentalFollowUpScheduled = false)
    (hHearing : a.hearingAssessmentArranged = false) :
    0 < a.longTermOutcomeRisk :=
  a.gapFromMissingFollowUp hNeuro hHearing

end ForkRaceFoldTheorems
