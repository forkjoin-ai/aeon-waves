/-!
# AWSIoTEventsStepFunctionsInternetGatewayMisconfigurationDetectionSecurityEconomics

AWS Internet Gateway misconfiguration scanner for IoT Events + Step Functions
pipelines. Five security-economics gap theorems: each proves that the ABSENCE
of a control on the Internet Gateway surface creates measurable compliance or
attack-surface cost.

Anti-thesis pattern: structure posits the ABSENCE of a control, theorem
derives strictly-positive gap. Zero sorry — all close by exact.
-/

namespace ForkRaceFoldTheorems

-- ── Theorem 1 ────────────────────────────────────────────────────────────────
-- Anti-thesis: VPC flow logs for subnets reachable via the Internet Gateway
-- are NOT encrypted with a customer-managed KMS key → compliance gap is
-- strictly positive.

structure IGWFlowLogCMKGapAssumptions where
  flowLogsEncryptedWithCMK : Bool
  complianceGap : Nat
  gapFromMissingCMK : flowLogsEncryptedWithCMK = false → 0 < complianceGap

theorem igw_flow_log_cmk_gap_exists
    (a : IGWFlowLogCMKGapAssumptions)
    (h : a.flowLogsEncryptedWithCMK = false) :
    0 < a.complianceGap :=
  a.gapFromMissingCMK h

-- ── Theorem 2 ────────────────────────────────────────────────────────────────
-- Anti-thesis: no SCP or AWS Config rule prevents detachment or deletion of
-- the Internet Gateway from the IoT Events VPC AND the VPC has more than one
-- public subnet → deletion-scope risk is strictly positive.

structure IGWSCPDeletionGapAssumptions where
  scpOrConfigRulePresent : Bool
  publicSubnetCount : Nat
  deletionScopeRisk : Nat
  gapFromMissingProtectionAndMultiSubnet :
    scpOrConfigRulePresent = false →
    1 < publicSubnetCount →
    0 < deletionScopeRisk

theorem igw_scp_deletion_gap_exists
    (a : IGWSCPDeletionGapAssumptions)
    (hSCP : a.scpOrConfigRulePresent = false)
    (hSubnets : 1 < a.publicSubnetCount) :
    0 < a.deletionScopeRisk :=
  a.gapFromMissingProtectionAndMultiSubnet hSCP hSubnets

-- ── Theorem 3 ────────────────────────────────────────────────────────────────
-- Anti-thesis: the IAM role permitted to invoke ec2:DetachInternetGateway is
-- NOT scoped to the specific gateway ID → privilege escalation risk is strictly
-- positive.

structure IGWIAMRoleScopeGapAssumptions where
  iamRoleScopedToGateway : Bool
  privilegeEscalationRisk : Nat
  gapFromUnscopedRole : iamRoleScopedToGateway = false → 0 < privilegeEscalationRisk

theorem igw_iam_role_scope_gap_exists
    (a : IGWIAMRoleScopeGapAssumptions)
    (h : a.iamRoleScopedToGateway = false) :
    0 < a.privilegeEscalationRisk :=
  a.gapFromUnscopedRole h

-- ── Theorem 4 ────────────────────────────────────────────────────────────────
-- Anti-thesis: no CloudWatch alarm fires on Internet Gateway attachment/
-- detachment events AND the SOC has no on-call runbook for unexpected IGW
-- changes → SOC blind-spot risk is strictly positive.

structure IGWChangeAlarmSOCGapAssumptions where
  cloudWatchAlarmConfigured : Bool
  socRunbookExists : Bool
  socBlindSpotRisk : Nat
  gapFromMissingAlarmAndRunbook :
    cloudWatchAlarmConfigured = false →
    socRunbookExists = false →
    0 < socBlindSpotRisk

theorem igw_change_alarm_soc_gap_exists
    (a : IGWChangeAlarmSOCGapAssumptions)
    (hAlarm : a.cloudWatchAlarmConfigured = false)
    (hRunbook : a.socRunbookExists = false) :
    0 < a.socBlindSpotRisk :=
  a.gapFromMissingAlarmAndRunbook hAlarm hRunbook

-- ── Theorem 5 ────────────────────────────────────────────────────────────────
-- Anti-thesis: AWS X-Ray active tracing is NOT enabled on the Step Functions
-- state machine that modifies IGW routing AND CloudTrail API calls for
-- ec2:AttachInternetGateway are not forwarded to a SIEM → observability gap
-- is strictly positive.

structure IGWXRayCloudTrailGapAssumptions where
  xRayTracingEnabled : Bool
  cloudTrailForwardedToSIEM : Bool
  observabilityGap : Nat
  gapFromMissingXRayAndSIEM :
    xRayTracingEnabled = false →
    cloudTrailForwardedToSIEM = false →
    0 < observabilityGap

theorem igw_xray_cloudtrail_gap_exists
    (a : IGWXRayCloudTrailGapAssumptions)
    (hXRay : a.xRayTracingEnabled = false)
    (hSIEM : a.cloudTrailForwardedToSIEM = false) :
    0 < a.observabilityGap :=
  a.gapFromMissingXRayAndSIEM hXRay hSIEM

end ForkRaceFoldTheorems
