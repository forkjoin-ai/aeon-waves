/-!
# AWSIoTEventsStepFunctionsEKSSecretsManagerMisconfigurationDetectionSecurityEconomics

EKS cluster Secrets Manager integration misconfiguration detection
security-economics. Five gap theorems: each proves that absence of a
specific secrets-management control creates strictly-positive compliance
or revenue-at-risk exposure.

Anti-thesis pattern: structure posits absence of a control, theorem derives
strictly-positive risk. Zero sorry — all close by exact.
-/

namespace ForkRaceFoldTheorems

-- ── Theorem 1 ────────────────────────────────────────────────────────────────
-- Anti-thesis: EKS pods access secrets via environment variables sourced
-- directly from AWS Secrets Manager WITHOUT using the Secrets Store CSI
-- driver AND secrets are NOT encrypted with a customer-managed KMS key
-- → plaintext secret exposure / compliance gap is strictly positive.

structure EKSSecretsManagerCMKCSIGapAssumptions where
  secretsStoreCSIDriverEnabled : Bool
  secretsEncryptedWithCMK : Bool
  plaintextExposureRisk : Nat
  gapFromMissingCSIAndCMK :
    secretsStoreCSIDriverEnabled = false →
    secretsEncryptedWithCMK = false →
    0 < plaintextExposureRisk

theorem eks_secrets_manager_cmk_csi_gap_exists
    (a : EKSSecretsManagerCMKCSIGapAssumptions)
    (hCSI : a.secretsStoreCSIDriverEnabled = false)
    (hCMK : a.secretsEncryptedWithCMK = false) :
    0 < a.plaintextExposureRisk :=
  a.gapFromMissingCSIAndCMK hCSI hCMK

-- ── Theorem 2 ────────────────────────────────────────────────────────────────
-- Anti-thesis: automatic secret rotation is NOT enabled for database
-- credentials stored in Secrets Manager AND no SCP prevents disabling
-- rotation → stale-credential exploitation / lateral-movement revenue
-- risk is strictly positive.

structure EKSSecretsManagerRotationSCPGapAssumptions where
  secretRotationEnabled : Bool
  scpPreventsRotationDisable : Bool
  staleCredentialRisk : Nat
  gapFromMissingRotationAndSCP :
    secretRotationEnabled = false →
    scpPreventsRotationDisable = false →
    0 < staleCredentialRisk

theorem eks_secrets_manager_rotation_scp_gap_exists
    (a : EKSSecretsManagerRotationSCPGapAssumptions)
    (hRot : a.secretRotationEnabled = false)
    (hSCP : a.scpPreventsRotationDisable = false) :
    0 < a.staleCredentialRisk :=
  a.gapFromMissingRotationAndSCP hRot hSCP

-- ── Theorem 3 ────────────────────────────────────────────────────────────────
-- Anti-thesis: the IAM role attached to EKS pods via IRSA for Secrets
-- Manager access is NOT scoped to the specific secret ARN → cross-service
-- secret access / privilege-escalation risk is strictly positive.

structure EKSSecretsManagerIRSAScopeGapAssumptions where
  irsaRoleScopedToSecretArn : Bool
  crossServiceSecretAccessRisk : Nat
  gapFromUnscopedIRSA :
    irsaRoleScopedToSecretArn = false → 0 < crossServiceSecretAccessRisk

theorem eks_secrets_manager_irsa_scope_gap_exists
    (a : EKSSecretsManagerIRSAScopeGapAssumptions)
    (h : a.irsaRoleScopedToSecretArn = false) :
    0 < a.crossServiceSecretAccessRisk :=
  a.gapFromUnscopedIRSA h

-- ── Theorem 4 ────────────────────────────────────────────────────────────────
-- Anti-thesis: no CloudWatch alarm fires when secret access anomalies
-- (unexpected callers, high access rates) are detected AND the SOC has no
-- runbook for Secrets Manager GuardDuty findings → SOC gap is strictly
-- positive.

structure EKSSecretsManagerAlarmSOCGapAssumptions where
  secretAccessAnomalyAlarmConfigured : Bool
  socRunbookExists : Bool
  socGap : Nat
  gapFromMissingAlarmAndRunbook :
    secretAccessAnomalyAlarmConfigured = false →
    socRunbookExists = false →
    0 < socGap

theorem eks_secrets_manager_alarm_soc_gap_exists
    (a : EKSSecretsManagerAlarmSOCGapAssumptions)
    (hAlarm : a.secretAccessAnomalyAlarmConfigured = false)
    (hRunbook : a.socRunbookExists = false) :
    0 < a.socGap :=
  a.gapFromMissingAlarmAndRunbook hAlarm hRunbook

-- ── Theorem 5 ────────────────────────────────────────────────────────────────
-- Anti-thesis: AWS X-Ray active tracing is NOT enabled on the Secrets
-- Manager API call path from EKS pods AND GetSecretValue calls are not
-- retained in CloudTrail for 90 days → observability gap is strictly
-- positive.

structure EKSSecretsManagerXRayGapAssumptions where
  xRayTracingEnabled : Bool
  cloudTrailRetentionMet : Bool
  observabilityGap : Nat
  gapFromMissingXRayAndRetention :
    xRayTracingEnabled = false →
    cloudTrailRetentionMet = false →
    0 < observabilityGap

theorem eks_secrets_manager_xray_gap_exists
    (a : EKSSecretsManagerXRayGapAssumptions)
    (hXRay : a.xRayTracingEnabled = false)
    (hRet : a.cloudTrailRetentionMet = false) :
    0 < a.observabilityGap :=
  a.gapFromMissingXRayAndRetention hXRay hRet

end ForkRaceFoldTheorems
