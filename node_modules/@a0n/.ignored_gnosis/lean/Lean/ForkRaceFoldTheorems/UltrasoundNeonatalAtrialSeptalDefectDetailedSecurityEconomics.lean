/-!
# UltrasoundNeonatalAtrialSeptalDefectDetailedSecurityEconomics

Neonatal atrial septal defect (ASD): left-to-right shunt at the atrial level
ranging from patent foramen ovale to large secundum, primum, sinus venosus,
or unroofed coronary sinus ASD. Five security-economics gap theorems for
clinical imaging gaps that constitute missed-diagnosis risk — each with
measurable economic (medico-legal / readmission) cost.

Anti-thesis pattern: structure posits the ABSENCE of an imaging assessment,
theorem derives strictly-positive risk. Zero sorry — all close by exact.
-/

namespace ForkRaceFoldTheorems

-- ── Theorem 1 ────────────────────────────────────────────────────────────────
-- Anti-thesis: ASD anatomical subtype NOT classified (secundum / primum /
-- sinus venosus / coronary sinus) AND defect size NOT measured → incorrect
-- repair-approach planning risk is strictly positive.

structure ASDSubtypeSizeGapAssumptions where
  subtypeClassified : Bool
  defectSizeMeasured : Bool
  repairApproachRisk : Nat
  gapFromUnclassifiedSubtypeAndSize :
    subtypeClassified = false →
    defectSizeMeasured = false →
    0 < repairApproachRisk

theorem asd_subtype_size_gap_exists
    (a : ASDSubtypeSizeGapAssumptions)
    (hSubtype : a.subtypeClassified = false)
    (hSize : a.defectSizeMeasured = false) :
    0 < a.repairApproachRisk :=
  a.gapFromUnclassifiedSubtypeAndSize hSubtype hSize

-- ── Theorem 2 ────────────────────────────────────────────────────────────────
-- Anti-thesis: right ventricular volume overload NOT quantified AND
-- right-to-left shunt fraction NOT measured by pulmonary-to-systemic flow
-- ratio (Qp:Qs) → haemodynamic significance misclassification risk is
-- strictly positive.

structure RVVolumeOverloadQpQsGapAssumptions where
  rvVolumeOverloadQuantified : Bool
  qpQsMeasured : Bool
  haemodynamicSignificanceRisk : Nat
  gapFromUnquantifiedRVAndQpQs :
    rvVolumeOverloadQuantified = false →
    qpQsMeasured = false →
    0 < haemodynamicSignificanceRisk

theorem rv_volume_overload_qpqs_gap_exists
    (a : RVVolumeOverloadQpQsGapAssumptions)
    (hRV : a.rvVolumeOverloadQuantified = false)
    (hQpQs : a.qpQsMeasured = false) :
    0 < a.haemodynamicSignificanceRisk :=
  a.gapFromUnquantifiedRVAndQpQs hRV hQpQs

-- ── Theorem 3 ────────────────────────────────────────────────────────────────
-- Anti-thesis: associated partial anomalous pulmonary venous drainage NOT
-- excluded for sinus venosus ASD AND pulmonary vein insertion NOT mapped →
-- incomplete surgical repair risk is strictly positive.

structure SinusVenosusAPVDGapAssumptions where
  apvdExcluded : Bool
  pvInsertionMapped : Bool
  incompleteRepairRisk : Nat
  gapFromUnexcludedAPVDAndUnmappedPV :
    apvdExcluded = false →
    pvInsertionMapped = false →
    0 < incompleteRepairRisk

theorem sinus_venosus_apvd_gap_exists
    (a : SinusVenosusAPVDGapAssumptions)
    (hAPVD : a.apvdExcluded = false)
    (hPV : a.pvInsertionMapped = false) :
    0 < a.incompleteRepairRisk :=
  a.gapFromUnexcludedAPVDAndUnmappedPV hAPVD hPV

-- ── Theorem 4 ────────────────────────────────────────────────────────────────
-- Anti-thesis: mitral valve cleft or primum ASD associated AVSD component
-- NOT assessed AND atrioventricular valve regurgitation NOT graded →
-- post-repair atrioventricular valve dysfunction risk is strictly positive.

structure AVSDComponentMitralCleftGapAssumptions where
  avsdComponentAssessed : Bool
  avValveRegurgitationGraded : Bool
  postRepairDysfunctionRisk : Nat
  gapFromUnassessedAVSDAndRegurgitation :
    avsdComponentAssessed = false →
    avValveRegurgitationGraded = false →
    0 < postRepairDysfunctionRisk

theorem avsd_component_mitral_cleft_gap_exists
    (a : AVSDComponentMitralCleftGapAssumptions)
    (hAVSD : a.avsdComponentAssessed = false)
    (hReg : a.avValveRegurgitationGraded = false) :
    0 < a.postRepairDysfunctionRisk :=
  a.gapFromUnassessedAVSDAndRegurgitation hAVSD hReg

-- ── Theorem 5 ────────────────────────────────────────────────────────────────
-- Anti-thesis: pulmonary arterial pressure NOT estimated from tricuspid
-- regurgitation jet AND inferior vena cava size/collapsibility NOT assessed →
-- pulmonary hypertension under-detection risk is strictly positive.

structure PulmonaryHypertensionASDGapAssumptions where
  paPressureEstimated : Bool
  ivcSizeCollapsibilityAssessed : Bool
  pulmonaryHypertensionRisk : Nat
  gapFromUnestimatedPAAndIVC :
    paPressureEstimated = false →
    ivcSizeCollapsibilityAssessed = false →
    0 < pulmonaryHypertensionRisk

theorem pulmonary_hypertension_asd_gap_exists
    (a : PulmonaryHypertensionASDGapAssumptions)
    (hPA : a.paPressureEstimated = false)
    (hIVC : a.ivcSizeCollapsibilityAssessed = false) :
    0 < a.pulmonaryHypertensionRisk :=
  a.gapFromUnestimatedPAAndIVC hPA hIVC

end ForkRaceFoldTheorems
