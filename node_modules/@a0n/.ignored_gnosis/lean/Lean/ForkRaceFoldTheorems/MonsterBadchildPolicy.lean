import Init

namespace ForkRaceFoldTheorems
namespace MonsterBadchildPolicy

/-!
Pure policy/decide model mirrored from the Rust crate `monster-badchild`
(`open-source/gnosis/monster-badchild/src/policy.rs`), the inversion of
aeon-flux's goodchild. goodchild returns a bare `bool` (allow/deny);
monster-badchild keeps the exact same evaluation cascade but emits a three-way
`Verdict`:

    allow            -> route to the real target
    deny, quiet      -> redirect into the shadow decoy
    deny, observed   -> trap in the camouflaged honey-pit

"Everyone gets through; they just don't go where they want." There is no deny
status code anywhere — denial is a destination, not a door. The theorems below
are about that control flow, not about the deterministic rollout hash; the hash
is an impl detail abstracted here as a single `Bool` (`rolloutOk`).
-/

/-- The three-way outcome that replaces goodchild's boolean. Payloads from the
Rust enum (target/decoy/reason strings) are erased: the theorems are about which
door is taken, not about its destination string. -/
inductive Verdict where
  | allow
  | redirect
  | trap
  deriving DecidableEq, Repr

/-- The subject of an evaluation, resolved from a (real) UCAN chain or context.
Mirrors goodchild's `VerifiedAuthContext` / `monster-badchild`'s `Subject`. The
`force_disable` / `force_enable` capabilities and the required-tier match are
modeled directly as booleans. -/
structure Subject where
  /-- Carries the `force_enable` capability override. -/
  forceEnable : Bool
  /-- Carries the `force_disable` capability override. -/
  forceDisable : Bool
  /-- The subject's tier satisfies the policy's required-tier gate (a policy with
  no required tier is modeled by this being `true`). -/
  tierOk : Bool
  deriving DecidableEq, Repr

/-- A stateless policy for one resource. Mirrors goodchild's `FeatureFlag` + rule
and `monster-badchild`'s `Policy`. The deterministic percentage rollout is
abstracted as the single Bool `rolloutOk` (the bucket landed inside the rollout):
its concrete value is an impl detail of `simple_hash`, while the theorems concern
the surrounding control flow only. -/
structure Policy where
  /-- The base enabled state of the resource. -/
  enabled : Bool
  /-- The deterministic rollout gate admitted this subject. -/
  rolloutOk : Bool
  deriving DecidableEq, Repr

/-- Evaluate a request against a policy, mirroring `policy.rs::evaluate` exactly.
`observed` is the active-deception signal: when an observer is recognized, every
outcome hardens to `trap`, even an otherwise-allowed request — the rogue does not
get made. The remaining cascade is goodchild's decision order, with each deny
emitting `redirect` (the quiet shadow) rather than a closed door. -/
def evaluate (p : Policy) (s : Subject) (observed : Bool) : Verdict :=
  if observed then Verdict.trap
  else if s.forceDisable then Verdict.redirect
  else if s.forceEnable then Verdict.allow
  else if !p.enabled then Verdict.redirect
  else if !s.tierOk then Verdict.redirect
  else if !p.rolloutOk then Verdict.redirect
  else Verdict.allow

/-- The wire status code for every verdict. There is no deny status anywhere in
the module: allow, redirect, and trap all answer `200`. Denial is a destination,
not an HTTP door — this is the admit-all property made concrete. -/
def status : Verdict → Nat := fun _ => 200

-- ===========================================================================
-- Theorems (case analysis / decide; no sorry, no axiom).
-- ===========================================================================

/-- 1. `admit_all`: no deny door exists. Every caller, under every policy,
subject, and observation flag, receives status `200`. -/
theorem admit_all (p : Policy) (s : Subject) (observed : Bool) :
    status (evaluate p s observed) = 200 := by
  rfl

/-- 2. `observed_is_always_trapped`: the rogue is never made. An observed caller
is trapped regardless of credentials, policy state, or rollout. -/
theorem observed_is_always_trapped (p : Policy) (s : Subject) :
    evaluate p s true = Verdict.trap := by
  rfl

/-- 3. `allow_implies_unobserved`: an `allow` can only be reached when the caller
was not observed. (Contrapositive of `observed_is_always_trapped`.) -/
theorem allow_implies_unobserved (p : Policy) (s : Subject) (observed : Bool)
    (h : evaluate p s observed = Verdict.allow) : observed = false := by
  cases observed with
  | true => simp [evaluate] at h
  | false => rfl

/-- 4. `allow_requires_authorization`: an unobserved `allow` is only granted to a
subject that is either explicitly `force_enable`d, or one for whom the full
cascade passes (enabled, tier ok, rollout ok, and not force-disabled). -/
theorem allow_requires_authorization (p : Policy) (s : Subject)
    (h : evaluate p s false = Verdict.allow) :
    (s.forceEnable = true) ∨
      (p.enabled = true ∧ s.tierOk = true ∧ p.rolloutOk = true ∧
        s.forceDisable = false) := by
  unfold evaluate at h
  cases hfd : s.forceDisable with
  | true => simp [hfd] at h
  | false =>
    cases hfe : s.forceEnable with
    | true => exact Or.inl rfl
    | false =>
      cases he : p.enabled with
      | false => simp [hfd, hfe, he] at h
      | true =>
        cases ht : s.tierOk with
        | false => simp [hfd, hfe, he, ht] at h
        | true =>
          cases hr : p.rolloutOk with
          | false => simp [hfd, hfe, he, ht, hr] at h
          | true => exact Or.inr ⟨rfl, rfl, rfl, rfl⟩

/-- 5. `never_denies_only_redirects_or_traps`: a deny is never a hard failure.
Whenever the verdict is not `allow`, it is one of the two destinations,
`redirect` or `trap`. (Together with `Verdict` being exactly these three
constructors, this pins the codomain to `{allow, redirect, trap}`.) -/
theorem never_denies_only_redirects_or_traps (p : Policy) (s : Subject)
    (observed : Bool) (h : evaluate p s observed ≠ Verdict.allow) :
    evaluate p s observed = Verdict.redirect ∨
      evaluate p s observed = Verdict.trap := by
  cases hv : evaluate p s observed with
  | allow => exact absurd hv h
  | redirect => exact Or.inl rfl
  | trap => exact Or.inr rfl

end MonsterBadchildPolicy
end ForkRaceFoldTheorems
