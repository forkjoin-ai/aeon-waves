/-!
# UltrasoundNeonatalPosteriorUrethralValveDetailedSecurityEconomics

Neonatal renal/bladder ultrasound — posterior urethral valve (PUV).
Security-economics gap theorems derived from absent diagnostic controls.

Anti-thesis pattern: each structure posits the ABSENCE of a required
measurement or finding, then derives a positive risk quantity.
Zero sorry — all theorems close by exact.
-/

namespace ForkRaceFoldTheorems

-- ── Theorem 1 ────────────────────────────────────────────────────────────────
-- Anti-thesis: posterior urethral dilatation (key-hole sign) is NOT documented
-- AND the bladder wall thickness is not measured → PUV diagnosis gap is
-- strictly positive.

structure PUVKeyHoleSignDocumentationGapAssumptions where
  keyHoleSignDocumented : Bool
  bladderWallThicknessMeasured : Bool
  diagnosisGap : Nat
  gapFromMissingKeyHoleAndWall :
    keyHoleSignDocumented = false →
    bladderWallThicknessMeasured = false →
    0 < diagnosisGap

theorem puv_keyhole_sign_documentation_gap_exists
    (a : PUVKeyHoleSignDocumentationGapAssumptions)
    (hKeyHole : a.keyHoleSignDocumented = false)
    (hWall : a.bladderWallThicknessMeasured = false) :
    0 < a.diagnosisGap :=
  a.gapFromMissingKeyHoleAndWall hKeyHole hWall

-- ── Theorem 2 ────────────────────────────────────────────────────────────────
-- Anti-thesis: bilateral hydronephrosis severity (SFU grade) is NOT graded on
-- both sides → upper-tract decompensation assessment gap is strictly positive.

structure PUVBilateralHydronephrosisGradingGapAssumptions where
  bilateralSFUGradeRecorded : Bool
  upperTractAssessmentGap : Nat
  gapFromUngradedHydronephrosis :
    bilateralSFUGradeRecorded = false → 0 < upperTractAssessmentGap

theorem puv_bilateral_hydronephrosis_grading_gap_exists
    (a : PUVBilateralHydronephrosisGradingGapAssumptions)
    (h : a.bilateralSFUGradeRecorded = false) :
    0 < a.upperTractAssessmentGap :=
  a.gapFromUngradedHydronephrosis h

-- ── Theorem 3 ────────────────────────────────────────────────────────────────
-- Anti-thesis: renal cortical echogenicity and corticomedullary differentiation
-- are NOT assessed bilaterally → renal dysplasia detection gap is strictly
-- positive.

structure PUVRenalCortexEchogenicityGapAssumptions where
  corticalEchogenicityAssessedBilaterally : Bool
  dysplasiaDetectionGap : Nat
  gapFromUnassessedCortex :
    corticalEchogenicityAssessedBilaterally = false → 0 < dysplasiaDetectionGap

theorem puv_renal_cortex_echogenicity_gap_exists
    (a : PUVRenalCortexEchogenicityGapAssumptions)
    (h : a.corticalEchogenicityAssessedBilaterally = false) :
    0 < a.dysplasiaDetectionGap :=
  a.gapFromUnassessedCortex h

-- ── Theorem 4 ────────────────────────────────────────────────────────────────
-- Anti-thesis: post-void residual bladder volume is NOT measured AND ureteral
-- jets are not assessed with colour Doppler → vesicoureteral reflux assessment
-- gap is strictly positive.

structure PUVPostVoidResidualGapAssumptions where
  postVoidResidualMeasured : Bool
  ureteralJetsAssessed : Bool
  refluxAssessmentGap : Nat
  gapFromMissingResidualAndJets :
    postVoidResidualMeasured = false →
    ureteralJetsAssessed = false →
    0 < refluxAssessmentGap

theorem puv_post_void_residual_gap_exists
    (a : PUVPostVoidResidualGapAssumptions)
    (hResidual : a.postVoidResidualMeasured = false)
    (hJets : a.ureteralJetsAssessed = false) :
    0 < a.refluxAssessmentGap :=
  a.gapFromMissingResidualAndJets hResidual hJets

-- ── Theorem 5 ────────────────────────────────────────────────────────────────
-- Anti-thesis: amniotic fluid index (AFI) status in antenatal records is NOT
-- correlated with postnatal renal function markers → prognostic-integration
-- gap is strictly positive.

structure PUVAntenatalAFIPostnatalCorrelationGapAssumptions where
  antenatalAFICorrelated : Bool
  prognosticIntegrationGap : Nat
  gapFromMissingAFICorrelation :
    antenatalAFICorrelated = false → 0 < prognosticIntegrationGap

theorem puv_antenatal_afi_postnatal_correlation_gap_exists
    (a : PUVAntenatalAFIPostnatalCorrelationGapAssumptions)
    (h : a.antenatalAFICorrelated = false) :
    0 < a.prognosticIntegrationGap :=
  a.gapFromMissingAFICorrelation h

end ForkRaceFoldTheorems
