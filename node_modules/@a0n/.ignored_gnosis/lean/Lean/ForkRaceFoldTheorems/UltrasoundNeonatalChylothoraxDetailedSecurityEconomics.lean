/-!
# UltrasoundNeonatalChylothoraxDetailedSecurityEconomics

Anti-thesis: neonatal/fetal ultrasound reliably characterises chylothorax by
quantifying effusion volume and echogenicity (anechoic vs. echogenic chyle),
assessing lung compression and mediastinal shift, identifying associated hydrops
and skin oedema, evaluating cardiac function and inferior vena cava flow, and
coordinating thoracocentesis/pleurodesis MDT referral. Management decisions
based on these assessments are clinically sound.

Refutation: each failure mode below proves that the ABSENCE of a systematic
assessment control implies a strictly positive clinical and economic risk.
Zero sorry — all theorems close by exact.
-/

namespace ForkRaceFoldTheorems

-- ── Theorem 1 ────────────────────────────────────────────────────────────────
-- Anti-thesis: effusion volume (three-plane measurement or depth at maximal
-- recess) is NOT quantified AND echogenicity (anechoic vs. echogenic chylous
-- fluid) is NOT characterised → inappropriate drainage timing risk is strictly
-- positive.

structure ChylothoraxEffusionVolumeEchogenicityGapAssumptions where
  effusionQuantified : Bool
  echogenicityCharacterised : Bool
  drainageTimingRisk : Nat
  gapFromMissingVolumeAndEchogenicity :
    effusionQuantified = false →
    echogenicityCharacterised = false →
    0 < drainageTimingRisk

theorem chylothorax_effusion_volume_echogenicity_gap_exists
    (a : ChylothoraxEffusionVolumeEchogenicityGapAssumptions)
    (hVolume : a.effusionQuantified = false)
    (hEcho : a.echogenicityCharacterised = false) :
    0 < a.drainageTimingRisk :=
  a.gapFromMissingVolumeAndEchogenicity hVolume hEcho

-- ── Theorem 2 ────────────────────────────────────────────────────────────────
-- Anti-thesis: lung compression ratio and mediastinal shift direction are NOT
-- documented AND contralateral lung echogenicity is NOT assessed → respiratory
-- decompensation risk is strictly positive.

structure ChylothoraxLungCompressionMediastinalShiftGapAssumptions where
  lungCompressionDocumented : Bool
  contralateralLungAssessed : Bool
  respiratoryDecompensationRisk : Nat
  gapFromMissingCompressionAndLung :
    lungCompressionDocumented = false →
    contralateralLungAssessed = false →
    0 < respiratoryDecompensationRisk

theorem chylothorax_lung_compression_mediastinal_shift_gap_exists
    (a : ChylothoraxLungCompressionMediastinalShiftGapAssumptions)
    (hCompression : a.lungCompressionDocumented = false)
    (hLung : a.contralateralLungAssessed = false) :
    0 < a.respiratoryDecompensationRisk :=
  a.gapFromMissingCompressionAndLung hCompression hLung

-- ── Theorem 3 ────────────────────────────────────────────────────────────────
-- Anti-thesis: associated hydrops features (skin oedema, ascites, pericardial
-- effusion) are NOT systematically assessed AND polyhydramnios is NOT
-- documented → hydrops severity underestimation risk is strictly positive.

structure ChylothoraxHydropsPolyhydramniosGapAssumptions where
  hydropyFeaturesAssessed : Bool
  polyhydramniosDocumented : Bool
  hydropsUnderestimationRisk : Nat
  gapFromMissingHydropsAndPolyhydramnios :
    hydropyFeaturesAssessed = false →
    polyhydramniosDocumented = false →
    0 < hydropsUnderestimationRisk

theorem chylothorax_hydrops_polyhydramnios_gap_exists
    (a : ChylothoraxHydropsPolyhydramniosGapAssumptions)
    (hHydrops : a.hydropyFeaturesAssessed = false)
    (hPolyhydramnios : a.polyhydramniosDocumented = false) :
    0 < a.hydropsUnderestimationRisk :=
  a.gapFromMissingHydropsAndPolyhydramnios hHydrops hPolyhydramnios

-- ── Theorem 4 ────────────────────────────────────────────────────────────────
-- Anti-thesis: Doppler assessment of cardiac function (biventricular systolic
-- function, TR jet velocity for RV pressure) and inferior vena cava collaps-
-- ibility are NOT performed → haemodynamic compromise risk is strictly positive.

structure ChylothoraxCardiacFunctionIVCGapAssumptions where
  cardiacFunctionAssessed : Bool
  ivcCollapsibilityAssessed : Bool
  haemodynamicRisk : Nat
  gapFromMissingCardiacAndIVC :
    cardiacFunctionAssessed = false →
    ivcCollapsibilityAssessed = false →
    0 < haemodynamicRisk

theorem chylothorax_cardiac_function_ivc_gap_exists
    (a : ChylothoraxCardiacFunctionIVCGapAssumptions)
    (hCardiac : a.cardiacFunctionAssessed = false)
    (hIVC : a.ivcCollapsibilityAssessed = false) :
    0 < a.haemodynamicRisk :=
  a.gapFromMissingCardiacAndIVC hCardiac hIVC

-- ── Theorem 5 ────────────────────────────────────────────────────────────────
-- Anti-thesis: thoracocentesis guidance feasibility is NOT documented AND MDT
-- referral (neonatology, paediatric surgery, lymphatics specialist) is NOT
-- issued with octreotide therapy consideration → treatment-delay risk is
-- strictly positive.

structure ChylothoraxThoracocentesisMDTGapAssumptions where
  thoracocentesisFeasibilityDocumented : Bool
  mdtReferralIssued : Bool
  treatmentDelayRisk : Nat
  gapFromMissingGuidanceAndMDT :
    thoracocentesisFeasibilityDocumented = false →
    mdtReferralIssued = false →
    0 < treatmentDelayRisk

theorem chylothorax_thoracocentesis_mdt_gap_exists
    (a : ChylothoraxThoracocentesisMDTGapAssumptions)
    (hGuidance : a.thoracocentesisFeasibilityDocumented = false)
    (hMDT : a.mdtReferralIssued = false) :
    0 < a.treatmentDelayRisk :=
  a.gapFromMissingGuidanceAndMDT hGuidance hMDT

end ForkRaceFoldTheorems
