import Init

namespace ForkRaceFoldTheorems
namespace MonsterBadchildMesh

/-!
Pure mesh witnesses mirrored from the Rust crate `monster-badchild`
(`open-source/gnosis/monster-badchild/src/mesh.rs`). Those primitives are the
detection/containment signatures the rogue reasons over; here we prove the
load-bearing arithmetic facts behind them in `Nat` only (prelude + `Init`, no
mathlib). Each theorem below corresponds to a Rust unit test in `mesh.rs`.
-/

-- ===========================================================================
-- 1. ZENONIC (slowloris): contracting gaps that never land.
-- ===========================================================================

/-- A Zenonic gap as a rational `num / denom`. Slowloris contracts `denom` while
holding `num` fixed; the gap only "lands" when `num` reaches zero. -/
structure Gap where
  num : Nat
  denom : Nat
  deriving DecidableEq, Repr

/-- Halve the effective gap by doubling the denominator (`contractStep`). The
numerator is held fixed, so the landing predicate is unaffected. -/
def contractStep (g : Gap) : Gap :=
  { num := g.num, denom := 2 * g.denom }

/-- Apply `contractStep` `n` times (`iterate`). -/
def iterate : Nat -> Gap -> Gap
  | 0, g => g
  | Nat.succ n, g => contractStep (iterate n g)

/-- True only when the numerator reaches zero (`hasLanded`). -/
def hasLanded (g : Gap) : Bool :=
  g.num = 0

/-- Contraction holds the numerator fixed at every finite depth. This is the
core of the Zenonic barrier: nothing the slowloris does to the denominator can
touch the numerator. -/
theorem iterate_num_fixed (n : Nat) (g : Gap) :
    (iterate n g).num = g.num := by
  induction n with
  | zero => rfl
  | succ k ih =>
      simp [iterate, contractStep, ih]

/-- For a positive initial numerator the gap never lands at any finite depth
(`zenonicApproachNumeratorFixed`). Mirrors
`zenonic_never_lands_with_positive_numerator`. -/
theorem zenonic_never_lands (n : Nat) (g : Gap) (h : g.num > 0) :
    hasLanded (iterate n g) = false := by
  unfold hasLanded
  rw [iterate_num_fixed]
  have hne : g.num ≠ 0 := Nat.pos_iff_ne_zero.mp h
  exact decide_eq_false (by simpa using hne)

/-- A gap whose numerator is already zero has landed at any depth. Mirrors
`zenonic_already_landed_when_numerator_zero`. -/
theorem zenonic_landed_when_zero (n : Nat) (g : Gap) (h : g.num = 0) :
    hasLanded (iterate n g) = true := by
  unfold hasLanded
  rw [iterate_num_fixed, h]
  rfl

-- ===========================================================================
-- 2. OVERLAY-HOLE (path enumeration): reclaim on additive-disjoint support.
-- ===========================================================================

/-- Path-enumeration witness. The attacker reclaims `attacker` hits exactly when
the defended overlay (`ice`) and the attacker overlay both fit inside the region
(`overlayHoleBypass`). -/
def overlayHoleBypass (ice attacker region : Nat) : Nat :=
  if ice + attacker <= region then attacker else 0

/-- Reclaim is positive iff the disjoint fit holds and the attacker is nonzero
(`reclaim_pos_iff`). Mirrors `overlay_hole_bypass_reclaims_only_when_disjoint`. -/
theorem reclaim_pos_iff (ice attacker region : Nat) :
    overlayHoleBypass ice attacker region > 0 ↔
      (attacker > 0 ∧ ice + attacker ≤ region) := by
  unfold overlayHoleBypass
  by_cases h : ice + attacker <= region
  · simp [h]
  · simp [h]

/-- No reclaim when the overlays do not fit disjointly in the region. -/
theorem reclaim_zero_when_not_fit (ice attacker region : Nat)
    (h : ¬ ice + attacker ≤ region) :
    overlayHoleBypass ice attacker region = 0 := by
  unfold overlayHoleBypass
  simp [h]

/-- A disjoint fit reclaims exactly the attacker's footprint. -/
theorem reclaim_when_fit (ice attacker region : Nat)
    (h : ice + attacker ≤ region) :
    overlayHoleBypass ice attacker region = attacker := by
  unfold overlayHoleBypass
  simp [h]

-- ===========================================================================
-- 3. CLOCK side-channel: frame deficit between heartbeats.
-- ===========================================================================

/-- `H * max(0, fA - fB)` — frames the attacker steals between heartbeats. `Nat`
subtraction truncates at `0`, which realizes the `max(0, ·)` in the Rust
`frame_deficit`. -/
def frameDeficit (h fa fb : Nat) : Nat :=
  h * (fa - fb)

/-- The frame deficit is strictly positive iff there is a positive horizon and
the attacker samples strictly faster than the defender (`deficit_pos_iff`).
Mirrors `clock_side_channel_fires_only_when_attacker_faster`. -/
theorem deficit_pos_iff (h fa fb : Nat) :
    frameDeficit h fa fb > 0 ↔ (h > 0 ∧ fa > fb) := by
  unfold frameDeficit
  constructor
  · intro hpos
    have hh : h > 0 := by
      rcases Nat.eq_zero_or_pos h with h0 | hp
      · simp [h0] at hpos
      · exact hp
    have hsub : fa > fb := by
      by_cases hle : fa ≤ fb
      · have hzero : fa - fb = 0 := Nat.sub_eq_zero_of_le hle
        simp [hzero] at hpos
      · exact Nat.lt_of_not_ge hle
    exact ⟨hh, hsub⟩
  · intro ⟨hh, hfast⟩
    have hsub : fa - fb > 0 := by
      exact Nat.sub_pos_of_lt hfast
    exact Nat.mul_pos hh hsub

/-- A defender at least as fast as the attacker opens no deficit. -/
theorem no_deficit_when_defender_fast (h fa fb : Nat) (hslow : fa ≤ fb) :
    frameDeficit h fa fb = 0 := by
  unfold frameDeficit
  have : fa - fb = 0 := Nat.sub_eq_zero_of_le hslow
  simp [this]

-- ===========================================================================
-- 4. HONEY-PIT (Aikido): drain work independent of inhabitants.
-- ===========================================================================

/-- A bounded containment pool. `drainSlots` is a fixed server-side worker count;
the Aikido property is that drain work is independent of how many are trapped. -/
structure HoneyPit where
  capacity : Nat
  inhabitants : Nat
  drainSlots : Nat
  deriving DecidableEq, Repr

/-- Server-side drain work over `ticks` (`serverDrainWork`): linear in ticks and
in the fixed drain-slot count. -/
def serverDrainWork (drainSlots ticks : Nat) : Nat :=
  drainSlots * ticks

/-- Drain work computed directly from a pit. -/
def pitDrainWork (pit : HoneyPit) (ticks : Nat) : Nat :=
  serverDrainWork pit.drainSlots ticks

/-- Graceful-overflow contract: a new connection can be trapped only below
capacity (`canTrap`). -/
def canTrap (pit : HoneyPit) : Bool :=
  pit.inhabitants < pit.capacity

/-- Admit one connection into containment (`trap`), incrementing the inhabitants
by one and leaving capacity and drain slots fixed. -/
def trap (pit : HoneyPit) : HoneyPit :=
  { capacity := pit.capacity,
    inhabitants := pit.inhabitants + 1,
    drainSlots := pit.drainSlots }

/-- The Aikido property: drain work does not mention inhabitants, so two pits
with the same drain slots but different inhabitant counts produce equal drain
work (`aikidoServerBound`). Mirrors
`honeypit_preconditions_and_drain_independence`. -/
theorem drain_independent_of_inhabitants
    (capacity inhabitantsA inhabitantsB drainSlots ticks : Nat) :
    pitDrainWork { capacity := capacity, inhabitants := inhabitantsA,
                   drainSlots := drainSlots } ticks =
      pitDrainWork { capacity := capacity, inhabitants := inhabitantsB,
                     drainSlots := drainSlots } ticks := by
  rfl

/-- Trapping a connection increments the inhabitant count by exactly one. Mirrors
the `trap` step in `trap_respects_capacity`. -/
theorem trap_increments_inhabitants (pit : HoneyPit) :
    (trap pit).inhabitants = pit.inhabitants + 1 := by
  rfl

/-- Trapping never changes the drain-slot count, so it cannot change drain work
either (the Aikido bound is stable across admissions). -/
theorem trap_preserves_drain_work (pit : HoneyPit) (ticks : Nat) :
    pitDrainWork (trap pit) ticks = pitDrainWork pit ticks := by
  rfl

/-- `canTrap` exactly reflects the strict capacity bound. -/
theorem can_trap_iff (pit : HoneyPit) :
    canTrap pit = true ↔ pit.inhabitants < pit.capacity := by
  unfold canTrap
  exact decide_eq_true_iff

/-- Once a pit reaches capacity it can no longer trap (graceful overflow). After
trapping a pit that was exactly one short of capacity, `canTrap` is false.
Mirrors the at-capacity assertion in `trap_respects_capacity`. -/
theorem trap_to_capacity_blocks (pit : HoneyPit)
    (h : pit.inhabitants + 1 = pit.capacity) :
    canTrap (trap pit) = false := by
  unfold canTrap trap
  simp [h]

end MonsterBadchildMesh
end ForkRaceFoldTheorems
