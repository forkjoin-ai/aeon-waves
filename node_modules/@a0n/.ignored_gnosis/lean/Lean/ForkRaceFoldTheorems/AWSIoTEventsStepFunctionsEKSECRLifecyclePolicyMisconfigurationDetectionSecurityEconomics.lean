/-!
# AWSIoTEventsStepFunctionsEKSECRLifecyclePolicyMisconfigurationDetectionSecurityEconomics

AWS IoT Events → Step Functions → EKS: ECR lifecycle policy misconfiguration
detection. Security-economics gap theorems — five proofs that absent controls
create measurable revenue-at-risk or compliance exposure.

Anti-thesis pattern: each structure posits the ABSENCE of a control, then
derives a positive risk quantity. Zero sorry — all theorems close by exact.
-/

namespace ForkRaceFoldTheorems

-- ── Theorem 1 ────────────────────────────────────────────────────────────────
-- Anti-thesis: ECR repository lifecycle policy is NOT enforced with a
-- customer-managed KMS key on encrypted image tags → compliance gap is
-- strictly positive.

structure ECRLifecyclePolicyCMKGapAssumptions where
  lifecyclePolicyEnforcedWithCMK : Bool
  complianceRisk : Nat
  gapFromMissingCMK : lifecyclePolicyEnforcedWithCMK = false → 0 < complianceRisk

theorem ecr_lifecycle_policy_cmk_gap_exists
    (a : ECRLifecyclePolicyCMKGapAssumptions)
    (h : a.lifecyclePolicyEnforcedWithCMK = false) :
    0 < a.complianceRisk :=
  a.gapFromMissingCMK h

-- ── Theorem 2 ────────────────────────────────────────────────────────────────
-- Anti-thesis: no Service Control Policy (SCP) prevents deletion of the ECR
-- lifecycle policy in production accounts → uncontrolled image accumulation
-- risk is strictly positive.

structure ECRLifecyclePolicySCPGapAssumptions where
  scpPreventsLifecyclePolicyDeletion : Bool
  accumulationRisk : Nat
  gapFromMissingSCP : scpPreventsLifecyclePolicyDeletion = false → 0 < accumulationRisk

theorem ecr_lifecycle_policy_scp_gap_exists
    (a : ECRLifecyclePolicySCPGapAssumptions)
    (h : a.scpPreventsLifecyclePolicyDeletion = false) :
    0 < a.accumulationRisk :=
  a.gapFromMissingSCP h

-- ── Theorem 3 ────────────────────────────────────────────────────────────────
-- Anti-thesis: the IAM role authorised to modify ECR lifecycle policies is
-- NOT scoped to the specific registry → privilege-escalation gap is strictly
-- positive.

structure ECRLifecyclePolicyIAMScopeGapAssumptions where
  iamRoleScopedToRegistry : Bool
  privilegeEscalationRisk : Nat
  gapFromUnscopedRole : iamRoleScopedToRegistry = false → 0 < privilegeEscalationRisk

theorem ecr_lifecycle_policy_iam_scope_gap_exists
    (a : ECRLifecyclePolicyIAMScopeGapAssumptions)
    (h : a.iamRoleScopedToRegistry = false) :
    0 < a.privilegeEscalationRisk :=
  a.gapFromUnscopedRole h

-- ── Theorem 4 ────────────────────────────────────────────────────────────────
-- Anti-thesis: no CloudWatch alarm fires on ECR lifecycle policy change events
-- AND the SOC has no runbook for responding → SOC detection gap is strictly
-- positive.

structure ECRLifecyclePolicyAlarmSOCGapAssumptions where
  cloudWatchAlarmConfigured : Bool
  socRunbookExists : Bool
  socGap : Nat
  gapFromMissingAlarmAndRunbook :
    cloudWatchAlarmConfigured = false →
    socRunbookExists = false →
    0 < socGap

theorem ecr_lifecycle_policy_alarm_soc_gap_exists
    (a : ECRLifecyclePolicyAlarmSOCGapAssumptions)
    (hAlarm : a.cloudWatchAlarmConfigured = false)
    (hRunbook : a.socRunbookExists = false) :
    0 < a.socGap :=
  a.gapFromMissingAlarmAndRunbook hAlarm hRunbook

-- ── Theorem 5 ────────────────────────────────────────────────────────────────
-- Anti-thesis: AWS X-Ray active tracing is NOT enabled on ECR lifecycle API
-- calls AND CloudTrail logging is not centralised → observability gap is
-- strictly positive.

structure ECRLifecyclePolicyXRayGapAssumptions where
  xRayTracingEnabled : Bool
  cloudTrailCentralised : Bool
  observabilityGap : Nat
  gapFromMissingXRay :
    xRayTracingEnabled = false →
    cloudTrailCentralised = false →
    0 < observabilityGap

theorem ecr_lifecycle_policy_xray_gap_exists
    (a : ECRLifecyclePolicyXRayGapAssumptions)
    (hXRay : a.xRayTracingEnabled = false)
    (hTrail : a.cloudTrailCentralised = false) :
    0 < a.observabilityGap :=
  a.gapFromMissingXRay hXRay hTrail

end ForkRaceFoldTheorems
