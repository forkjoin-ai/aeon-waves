namespace ForkRaceFoldTheorems

structure BackupVaultCMKGapAssumptions where
  backupVaultEncryptedWithCMK : Bool
  complianceRisk : Nat
  gapFromMissingCMK : backupVaultEncryptedWithCMK = false → 0 < complianceRisk

theorem backup_vault_cmk_gap_exists (a : BackupVaultCMKGapAssumptions)
    (h : a.backupVaultEncryptedWithCMK = false) : 0 < a.complianceRisk :=
  a.gapFromMissingCMK h

structure BackupVaultSCPConfigDeletionGapAssumptions where
  scpBlocksVaultDeletion : Bool
  configDetectsBackupChange : Bool
  backupLossRisk : Nat
  gapFromMissingSCPAndConfig : scpBlocksVaultDeletion = false → configDetectsBackupChange = false → 0 < backupLossRisk

theorem backup_vault_scp_config_deletion_gap_exists (a : BackupVaultSCPConfigDeletionGapAssumptions)
    (hSCP : a.scpBlocksVaultDeletion = false) (hConfig : a.configDetectsBackupChange = false) : 0 < a.backupLossRisk :=
  a.gapFromMissingSCPAndConfig hSCP hConfig

structure BackupVaultIAMScopeGapAssumptions where
  backupIAMScopedToAccount : Bool
  crossAccountRestoreAudited : Bool
  privilegeEscalationRisk : Nat
  gapFromUnscopedBackupIAM : backupIAMScopedToAccount = false → crossAccountRestoreAudited = false → 0 < privilegeEscalationRisk

theorem backup_vault_iam_scope_gap_exists (a : BackupVaultIAMScopeGapAssumptions)
    (hScope : a.backupIAMScopedToAccount = false) (hAudit : a.crossAccountRestoreAudited = false) : 0 < a.privilegeEscalationRisk :=
  a.gapFromUnscopedBackupIAM hScope hAudit

structure BackupJobFailureAlarmSOCGapAssumptions where
  backupJobFailureAlarmConfigured : Bool
  socRunbookExists : Bool
  socGap : Nat
  gapFromMissingAlarmAndRunbook : backupJobFailureAlarmConfigured = false → socRunbookExists = false → 0 < socGap

theorem backup_job_failure_alarm_soc_gap_exists (a : BackupJobFailureAlarmSOCGapAssumptions)
    (hAlarm : a.backupJobFailureAlarmConfigured = false) (hRunbook : a.socRunbookExists = false) : 0 < a.socGap :=
  a.gapFromMissingAlarmAndRunbook hAlarm hRunbook

structure BackupVaultXRayCloudTrailGapAssumptions where
  xRayTracingEnabled : Bool
  cloudTrailBackupEventsEnabled : Bool
  observabilityGap : Nat
  gapFromMissingXRayAndCloudTrail : xRayTracingEnabled = false → cloudTrailBackupEventsEnabled = false → 0 < observabilityGap

theorem backup_vault_xray_cloudtrail_gap_exists (a : BackupVaultXRayCloudTrailGapAssumptions)
    (hXRay : a.xRayTracingEnabled = false) (hCT : a.cloudTrailBackupEventsEnabled = false) : 0 < a.observabilityGap :=
  a.gapFromMissingXRayAndCloudTrail hXRay hCT

end ForkRaceFoldTheorems
