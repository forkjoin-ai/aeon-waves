/-!
# UltrasoundNeonatalLymphaticMalformationDetailedSecurityEconomics

Anti-thesis: neonatal fetal ultrasound reliably characterizes lymphatic
malformation (LM) by classifying macrocystic vs. microcystic disease and
lesion extent, measuring size and assessing growth trajectory, evaluating
fetal hydrops and mediastinal compression, quantifying airway compromise and
EXIT procedure candidacy, and coordinating sclerotherapy planning and MDT
referral. Management decisions based on these assessments are clinically sound.

Refutation: each failure mode below proves that the ABSENCE of a systematic
assessment control implies a strictly positive clinical and economic risk.
Zero sorry — all theorems close by exact.
-/

namespace ForkRaceFoldTheorems

-- ── Theorem 1 ────────────────────────────────────────────────────────────────
-- Anti-thesis: the lesion subtype (macrocystic vs. microcystic) is NOT classified
-- AND the anatomical extent across compartments is NOT mapped → treatment
-- selection risk is strictly positive.

structure LMSubtypeExtentGapAssumptions where
  subtypeClassified : Bool
  extentMapped : Bool
  treatmentSelectionRisk : Nat
  gapFromMissingSubtypeAndExtent :
    subtypeClassified = false →
    extentMapped = false →
    0 < treatmentSelectionRisk

theorem lm_subtype_extent_gap_exists
    (a : LMSubtypeExtentGapAssumptions)
    (hSubtype : a.subtypeClassified = false)
    (hExtent : a.extentMapped = false) :
    0 < a.treatmentSelectionRisk :=
  a.gapFromMissingSubtypeAndExtent hSubtype hExtent

-- ── Theorem 2 ────────────────────────────────────────────────────────────────
-- Anti-thesis: lesion volume is NOT measured AND serial growth trajectory is NOT
-- tracked across gestational age → prognostication risk is strictly positive.

structure LMVolumeGrowthTrajectoryGapAssumptions where
  volumeMeasured : Bool
  growthTrajectoryTracked : Bool
  prognosticationRisk : Nat
  gapFromMissingVolumeAndGrowth :
    volumeMeasured = false →
    growthTrajectoryTracked = false →
    0 < prognosticationRisk

theorem lm_volume_growth_trajectory_gap_exists
    (a : LMVolumeGrowthTrajectoryGapAssumptions)
    (hVolume : a.volumeMeasured = false)
    (hGrowth : a.growthTrajectoryTracked = false) :
    0 < a.prognosticationRisk :=
  a.gapFromMissingVolumeAndGrowth hVolume hGrowth

-- ── Theorem 3 ────────────────────────────────────────────────────────────────
-- Anti-thesis: fetal hydrops is NOT assessed AND mediastinal compression and
-- cardiac deviation are NOT evaluated → fetal decompensation risk is strictly
-- positive.

structure LMHydropsMediastinalCompressionGapAssumptions where
  hydropsAssessed : Bool
  mediastinalCompressionEvaluated : Bool
  fetalDecompensationRisk : Nat
  gapFromMissingHydropsAndMediastinal :
    hydropsAssessed = false →
    mediastinalCompressionEvaluated = false →
    0 < fetalDecompensationRisk

theorem lm_hydrops_mediastinal_compression_gap_exists
    (a : LMHydropsMediastinalCompressionGapAssumptions)
    (hHydrops : a.hydropsAssessed = false)
    (hMediastinal : a.mediastinalCompressionEvaluated = false) :
    0 < a.fetalDecompensationRisk :=
  a.gapFromMissingHydropsAndMediastinal hHydrops hMediastinal

-- ── Theorem 4 ────────────────────────────────────────────────────────────────
-- Anti-thesis: airway compromise score is NOT quantified AND EXIT procedure
-- candidacy is NOT assessed → neonatal airway rescue risk is strictly positive.

structure LMAirwayCompromiseEXITGapAssumptions where
  airwayCompromiseQuantified : Bool
  exitCandidacyAssessed : Bool
  neonatalAirwayRescueRisk : Nat
  gapFromMissingAirwayAndEXIT :
    airwayCompromiseQuantified = false →
    exitCandidacyAssessed = false →
    0 < neonatalAirwayRescueRisk

theorem lm_airway_compromise_exit_gap_exists
    (a : LMAirwayCompromiseEXITGapAssumptions)
    (hAirway : a.airwayCompromiseQuantified = false)
    (hEXIT : a.exitCandidacyAssessed = false) :
    0 < a.neonatalAirwayRescueRisk :=
  a.gapFromMissingAirwayAndEXIT hAirway hEXIT

-- ── Theorem 5 ────────────────────────────────────────────────────────────────
-- Anti-thesis: sclerotherapy candidacy is NOT evaluated AND multidisciplinary
-- team (MDT) referral to a fetal surgery or vascular anomaly center is NOT
-- initiated → postnatal management gap is strictly positive.

structure LMSclerotherapyMDTReferralGapAssumptions where
  sclerotherapyCandidacyEvaluated : Bool
  mdtReferralInitiated : Bool
  postnatalManagementGap : Nat
  gapFromMissingSclerotherapyAndMDT :
    sclerotherapyCandidacyEvaluated = false →
    mdtReferralInitiated = false →
    0 < postnatalManagementGap

theorem lm_sclerotherapy_mdt_referral_gap_exists
    (a : LMSclerotherapyMDTReferralGapAssumptions)
    (hSclero : a.sclerotherapyCandidacyEvaluated = false)
    (hMDT : a.mdtReferralInitiated = false) :
    0 < a.postnatalManagementGap :=
  a.gapFromMissingSclerotherapyAndMDT hSclero hMDT

end ForkRaceFoldTheorems
