/-!
# UltrasoundNeonatalPeripherallyInsertedCentralCatheterDetailedSecurityEconomics

Neonatal peripherally inserted central catheter (PICC) ultrasound diagnostic
gap theorems. Five proofs that absence of specific US-guided clinical steps
creates measurable patient-safety risk. Anti-thesis pattern; zero sorry.
-/

namespace ForkRaceFoldTheorems

structure PICCTipPositionUSGapAssumptions where
  usTipPositionConfirmedAtCavoatrialJunction : Bool
  infusionInjuryGap : Nat
  gapFromUnconfirmedTip :
    usTipPositionConfirmedAtCavoatrialJunction = false → 0 < infusionInjuryGap

theorem picc_tip_position_us_gap_exists
    (a : PICCTipPositionUSGapAssumptions)
    (h : a.usTipPositionConfirmedAtCavoatrialJunction = false) :
    0 < a.infusionInjuryGap :=
  a.gapFromUnconfirmedTip h

structure PICCVenousThrombosisDopplerGapAssumptions where
  dopplerVenousFlowAssessed : Bool
  thrombusExcluded : Bool
  venousThrombosisGap : Nat
  gapFromUnassessedVenousFlow :
    dopplerVenousFlowAssessed = false →
    thrombusExcluded = false →
    0 < venousThrombosisGap

theorem picc_venous_thrombosis_doppler_gap_exists
    (a : PICCVenousThrombosisDopplerGapAssumptions)
    (hDoppler : a.dopplerVenousFlowAssessed = false)
    (hThrombus : a.thrombusExcluded = false) :
    0 < a.venousThrombosisGap :=
  a.gapFromUnassessedVenousFlow hDoppler hThrombus

structure PICCExtravasationUSGapAssumptions where
  usDetectsExtravasation : Bool
  softTissueInjuryExcluded : Bool
  extravasationGap : Nat
  gapFromUndetectedExtravasation :
    usDetectsExtravasation = false →
    softTissueInjuryExcluded = false →
    0 < extravasationGap

theorem picc_extravasation_us_gap_exists
    (a : PICCExtravasationUSGapAssumptions)
    (hUS : a.usDetectsExtravasation = false)
    (hInjury : a.softTissueInjuryExcluded = false) :
    0 < a.extravasationGap :=
  a.gapFromUndetectedExtravasation hUS hInjury

structure PICCPleuralEffusionUSGapAssumptions where
  usAssessesPleuralEffusion : Bool
  effusionExcluded : Bool
  respiratoryComplicationGap : Nat
  gapFromUnassessedEffusion :
    usAssessesPleuralEffusion = false →
    effusionExcluded = false →
    0 < respiratoryComplicationGap

theorem picc_pleural_effusion_us_gap_exists
    (a : PICCPleuralEffusionUSGapAssumptions)
    (hUS : a.usAssessesPleuralEffusion = false)
    (hEffusion : a.effusionExcluded = false) :
    0 < a.respiratoryComplicationGap :=
  a.gapFromUnassessedEffusion hUS hEffusion

structure PICCSerialUSPostInsertionGapAssumptions where
  serialUSAt24hPerformed : Bool
  migrationOrThrombosisExcluded : Bool
  delayedComplicationGap : Nat
  gapFromMissingSerialUS :
    serialUSAt24hPerformed = false →
    migrationOrThrombosisExcluded = false →
    0 < delayedComplicationGap

theorem picc_serial_us_post_insertion_gap_exists
    (a : PICCSerialUSPostInsertionGapAssumptions)
    (hUS : a.serialUSAt24hPerformed = false)
    (hMigration : a.migrationOrThrombosisExcluded = false) :
    0 < a.delayedComplicationGap :=
  a.gapFromMissingSerialUS hUS hMigration

end ForkRaceFoldTheorems
