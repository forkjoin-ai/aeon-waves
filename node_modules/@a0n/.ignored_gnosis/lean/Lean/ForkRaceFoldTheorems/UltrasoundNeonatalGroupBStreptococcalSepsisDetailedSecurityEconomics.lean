namespace ForkRaceFoldTheorems

structure GBSSepsisJointBoneInfectionGapAssumptions where
  musculoskeletalUltrasoundPerformed : Bool
  jointEffusionAndOsteomyelitisMapped : Bool
  delayedOrthopedicReferralRisk : Nat
  gapFromMissingMSKUS : musculoskeletalUltrasoundPerformed = false → jointEffusionAndOsteomyelitisMapped = false → 0 < delayedOrthopedicReferralRisk

theorem gbs_sepsis_joint_bone_infection_gap_exists (a : GBSSepsisJointBoneInfectionGapAssumptions)
    (hUS : a.musculoskeletalUltrasoundPerformed = false) (hMap : a.jointEffusionAndOsteomyelitisMapped = false) : 0 < a.delayedOrthopedicReferralRisk :=
  a.gapFromMissingMSKUS hUS hMap

