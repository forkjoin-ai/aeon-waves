namespace ForkRaceFoldTheorems

structure MeningococcalSepsisSubduralEmpyemaGapAssumptions where
  cranialUltrasoundPerformed : Bool
  subduralCollectionDocumented : Bool
  untreatedEmpyemaRisk : Nat
  gapFromMissingCranialUS : cranialUltrasoundPerformed = false → subduralCollectionDocumented = false → 0 < untreatedEmpyemaRisk

theorem meningococcal_sepsis_subdural_empyema_gap_exists (a : MeningococcalSepsisSubduralEmpyemaGapAssumptions)
    (hUS : a.cranialUltrasoundPerformed = false) (hDoc : a.subduralCollectionDocumented = false) : 0 < a.untreatedEmpyemaRisk :=
  a.gapFromMissingCranialUS hUS hDoc

