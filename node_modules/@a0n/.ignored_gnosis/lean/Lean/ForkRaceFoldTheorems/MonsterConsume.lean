import Init

namespace ForkRaceFoldTheorems
namespace MonsterConsume

/--
A resident execution schedule covers a batch when every original input slot
below `batchLen` appears in the schedule. This property gives Monster what it
needs before it may execute requests in scheduled order while emitting responses
in canonical input order.
-/
def CoversBatch (batchLen : Nat) (executionOrder : List Nat) : Prop :=
  ∀ slot, slot < batchLen -> slot ∈ executionOrder

/--
The stronger runtime-facing schedule certificate: every scheduled slot is
within the batch, every batch slot is covered, and no slot is repeated.
-/
structure ResidentExecutionSchedule (batchLen : Nat) where
  executionOrder : List Nat
  inBounds : ∀ slot, slot ∈ executionOrder -> slot < batchLen
  covers : CoversBatch batchLen executionOrder
  nodup : executionOrder.Nodup

/-- Responses produced by running `execute` in scheduled order. -/
def scheduledResponses {Response : Type}
    (execute : Nat -> Response)
    (executionOrder : List Nat) : List (Nat × Response) :=
  executionOrder.map (fun slot => (slot, execute slot))

/-- Lookup the response for an original input slot in a scheduled response log. -/
def lookupResponse {Response : Type}
    (slot : Nat) : List (Nat × Response) -> Option Response
  | [] => none
  | (candidate, response) :: rest =>
      if candidate = slot then some response else lookupResponse slot rest

/--
Canonical Monster emission: write output slots in original input order, using
the scheduled response log as the source of completed work.
-/
def canonicalResponses {Response : Type}
    (batchLen : Nat)
    (responses : List (Nat × Response)) : List (Option Response) :=
  (List.range batchLen).map (fun slot => lookupResponse slot responses)

/--
If a slot appears in the execution order, lookup through the scheduled response
log returns exactly the response produced for that original slot.
-/
theorem lookup_scheduled_response_of_mem {Response : Type}
    (execute : Nat -> Response)
    (slot : Nat)
    (executionOrder : List Nat)
    (hMem : slot ∈ executionOrder) :
    lookupResponse slot (scheduledResponses execute executionOrder) =
      some (execute slot) := by
  induction executionOrder with
  | nil =>
      cases hMem
  | cons head rest ih =>
      simp [scheduledResponses, lookupResponse] at hMem ⊢
      cases hMem with
      | inl hHead =>
          subst hHead
          simp
      | inr hRest =>
          by_cases hEq : head = slot
          · subst hEq
            simp
          · simp [hEq]
            exact ih hRest

/--
Any schedule that covers the batch lets canonical emission recover every
original input slot, regardless of the order in which those slots executed.
-/
theorem canonical_responses_eq_original_order {Response : Type}
    (execute : Nat -> Response)
    (batchLen : Nat)
    (executionOrder : List Nat)
    (hCovers : CoversBatch batchLen executionOrder) :
    canonicalResponses batchLen (scheduledResponses execute executionOrder) =
      (List.range batchLen).map (fun slot => some (execute slot)) := by
  unfold canonicalResponses
  apply List.map_congr_left
  intro slot hSlot
  exact lookup_scheduled_response_of_mem
    execute slot executionOrder (hCovers slot (List.mem_range.mp hSlot))

/--
Certified resident schedules preserve canonical output order. The proof uses
only `covers`; `inBounds` and `nodup` remain part of the certificate because
they rule out out-of-batch work and duplicate scheduled work for runtime audits.
-/
theorem resident_schedule_preserves_canonical_output {Response : Type}
    (execute : Nat -> Response)
    {batchLen : Nat}
    (schedule : ResidentExecutionSchedule batchLen) :
    canonicalResponses batchLen
        (scheduledResponses execute schedule.executionOrder) =
      (List.range batchLen).map (fun slot => some (execute slot)) := by
  exact canonical_responses_eq_original_order
    execute batchLen schedule.executionOrder schedule.covers

/-- The identity schedule is a certified resident schedule for any batch. -/
def identitySchedule (batchLen : Nat) :
    ResidentExecutionSchedule batchLen where
  executionOrder := List.range batchLen
  inBounds := by
    intro slot hSlot
    exact List.mem_range.mp hSlot
  covers := by
    intro slot hSlot
    exact List.mem_range.mpr hSlot
  nodup := List.nodup_range

/--
The serial fallback used when Monster has no resident window still satisfies
the same canonical-output theorem as a scheduled batch.
-/
theorem identity_schedule_preserves_canonical_output {Response : Type}
    (execute : Nat -> Response)
    (batchLen : Nat) :
    canonicalResponses batchLen
        (scheduledResponses execute (List.range batchLen)) =
      (List.range batchLen).map (fun slot => some (execute slot)) := by
  exact resident_schedule_preserves_canonical_output
    execute (identitySchedule batchLen)

end MonsterConsume
end ForkRaceFoldTheorems
