import ForkRaceFoldTheorems.PortAuthenticatedMesh

namespace ForkRaceFoldTheorems
namespace LinkedMeshComposition

open PortAuthenticatedMesh

/-- A link. -/
structure Link where
  sourcePortIdx : Nat
  destPortIdx : Nat
  sourceOverlayCancelled : Bool
  destOverlayCancelled : Bool

/-- A link admitted. -/
def linkAdmitted (sourceMesh destMesh : Mesh) (link : Link) : Bool :=
  link.sourcePortIdx < sourceMesh.portCount &&
  link.destPortIdx < destMesh.portCount &&
  !link.sourceOverlayCancelled &&
  !link.destOverlayCancelled

end LinkedMeshComposition
end ForkRaceFoldTheorems
