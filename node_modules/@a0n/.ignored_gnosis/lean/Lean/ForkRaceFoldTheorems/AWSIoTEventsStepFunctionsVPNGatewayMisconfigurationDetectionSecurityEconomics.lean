namespace ForkRaceFoldTheorems

structure VPNGatewayTunnelCMKGapAssumptions where
  vpnConnectionLogsEncryptedWithCMK : Bool
  complianceRisk : Nat
  gapFromMissingCMK : vpnConnectionLogsEncryptedWithCMK = false → 0 < complianceRisk

theorem vpn_gateway_tunnel_cmk_gap_exists (a : VPNGatewayTunnelCMKGapAssumptions)
    (h : a.vpnConnectionLogsEncryptedWithCMK = false) : 0 < a.complianceRisk :=
  a.gapFromMissingCMK h

structure VPNGatewaySCPDeletionGapAssumptions where
  scpPreventsVPNGatewayDeletion : Bool
  configRuleMonitorsVPN : Bool
  unauthorisedDeletionRisk : Nat
  gapFromMissingSCPAndConfig : scpPreventsVPNGatewayDeletion = false → configRuleMonitorsVPN = false → 0 < unauthorisedDeletionRisk

theorem vpn_gateway_scp_deletion_gap_exists (a : VPNGatewaySCPDeletionGapAssumptions)
    (hSCP : a.scpPreventsVPNGatewayDeletion = false) (hConfig : a.configRuleMonitorsVPN = false) : 0 < a.unauthorisedDeletionRisk :=
  a.gapFromMissingSCPAndConfig hSCP hConfig

structure VPNGatewayIAMScopeGapAssumptions where
  iamPolicyScopedToVPNGateway : Bool
  crossAccountAttachmentBlocked : Bool
  escalationRisk : Nat
  gapFromUnscopedIAM : iamPolicyScopedToVPNGateway = false → crossAccountAttachmentBlocked = false → 0 < escalationRisk

theorem vpn_gateway_iam_scope_gap_exists (a : VPNGatewayIAMScopeGapAssumptions)
    (hIAM : a.iamPolicyScopedToVPNGateway = false) (hCross : a.crossAccountAttachmentBlocked = false) : 0 < a.escalationRisk :=
  a.gapFromUnscopedIAM hIAM hCross

structure VPNTunnelStatusAlarmSOCGapAssumptions where
  tunnelDownAlarmConfigured : Bool
  socRunbookExists : Bool
  socGap : Nat
  gapFromMissingAlarmAndRunbook : tunnelDownAlarmConfigured = false → socRunbookExists = false → 0 < socGap

theorem vpn_tunnel_status_alarm_soc_gap_exists (a : VPNTunnelStatusAlarmSOCGapAssumptions)
    (hAlarm : a.tunnelDownAlarmConfigured = false) (hRunbook : a.socRunbookExists = false) : 0 < a.socGap :=
  a.gapFromMissingAlarmAndRunbook hAlarm hRunbook

structure VPNGatewayXRayCloudTrailGapAssumptions where
  cloudTrailLogsVPNEvents : Bool
  stepFunctionXRayEnabled : Bool
  observabilityGap : Nat
  gapFromMissingXRayAndTrail : cloudTrailLogsVPNEvents = false → stepFunctionXRayEnabled = false → 0 < observabilityGap

theorem vpn_gateway_xray_cloudtrail_gap_exists (a : VPNGatewayXRayCloudTrailGapAssumptions)
    (hTrail : a.cloudTrailLogsVPNEvents = false) (hXRay : a.stepFunctionXRayEnabled = false) : 0 < a.observabilityGap :=
  a.gapFromMissingXRayAndTrail hTrail hXRay

end ForkRaceFoldTheorems
