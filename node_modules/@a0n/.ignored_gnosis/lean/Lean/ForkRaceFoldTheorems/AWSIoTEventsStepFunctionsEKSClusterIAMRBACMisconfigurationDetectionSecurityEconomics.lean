/-!
# AWSIoTEventsStepFunctionsEKSClusterIAMRBACMisconfigurationDetectionSecurityEconomics

EKS cluster IAM and RBAC misconfiguration detection security-economics.
Five gap theorems: each proves that absence of a specific IAM or RBAC
control creates strictly-positive compliance or revenue-at-risk exposure.

Anti-thesis pattern: structure posits absence of a control, theorem derives
strictly-positive risk. Zero sorry — all close by exact.
-/

namespace ForkRaceFoldTheorems

-- ── Theorem 1 ────────────────────────────────────────────────────────────────
-- Anti-thesis: EKS cluster aws-auth ConfigMap is NOT managed by an IaC tool
-- (ad-hoc user entries permitted) AND no customer-managed KMS key encrypts
-- Kubernetes secrets → RBAC drift compliance gap is strictly positive.

structure EKSIAMRBACAuthConfigMapCMKGapAssumptions where
  authConfigMapIaCManaged : Bool
  secretsEncryptedWithCMK : Bool
  complianceRisk : Nat
  gapFromUnmanagedAuthConfigMapAndCMK :
    authConfigMapIaCManaged = false →
    secretsEncryptedWithCMK = false →
    0 < complianceRisk

theorem eks_iam_rbac_auth_configmap_cmk_gap_exists
    (a : EKSIAMRBACAuthConfigMapCMKGapAssumptions)
    (hCM : a.authConfigMapIaCManaged = false)
    (hCMK : a.secretsEncryptedWithCMK = false) :
    0 < a.complianceRisk :=
  a.gapFromUnmanagedAuthConfigMapAndCMK hCM hCMK

-- ── Theorem 2 ────────────────────────────────────────────────────────────────
-- Anti-thesis: cluster-admin ClusterRoleBinding is NOT restricted to break-
-- glass accounts AND no SCP prevents IAM role attachment to EKS service
-- accounts → privilege-escalation revenue risk is strictly positive.

structure EKSIAMRBACClusterAdminSCPGapAssumptions where
  clusterAdminBindingRestricted : Bool
  scpPreventsRoleAttachment : Bool
  privilegeEscalationRisk : Nat
  gapFromUnrestrictedClusterAdminAndSCP :
    clusterAdminBindingRestricted = false →
    scpPreventsRoleAttachment = false →
    0 < privilegeEscalationRisk

theorem eks_iam_rbac_cluster_admin_scp_gap_exists
    (a : EKSIAMRBACClusterAdminSCPGapAssumptions)
    (hCA : a.clusterAdminBindingRestricted = false)
    (hSCP : a.scpPreventsRoleAttachment = false) :
    0 < a.privilegeEscalationRisk :=
  a.gapFromUnrestrictedClusterAdminAndSCP hCA hSCP

-- ── Theorem 3 ────────────────────────────────────────────────────────────────
-- Anti-thesis: the IAM role used for IRSA (IAM Roles for Service Accounts) is
-- NOT scoped to the specific namespace and service-account name → cross-
-- namespace IRSA credential theft risk is strictly positive.

structure EKSIAMRBACIRSAScopeGapAssumptions where
  irsaRoleScopedToNamespaceAndSA : Bool
  crossNamespaceCredentialTheftRisk : Nat
  gapFromUnscopedIRSA :
    irsaRoleScopedToNamespaceAndSA = false → 0 < crossNamespaceCredentialTheftRisk

theorem eks_iam_rbac_irsa_scope_gap_exists
    (a : EKSIAMRBACIRSAScopeGapAssumptions)
    (h : a.irsaRoleScopedToNamespaceAndSA = false) :
    0 < a.crossNamespaceCredentialTheftRisk :=
  a.gapFromUnscopedIRSA h

-- ── Theorem 4 ────────────────────────────────────────────────────────────────
-- Anti-thesis: no CloudWatch alarm fires when ClusterRoleBinding or RoleBinding
-- resources are created or modified in the cluster AND the SOC has no runbook
-- for unexpected RBAC changes → SOC gap is strictly positive.

structure EKSIAMRBACRoleBindingAlarmSOCGapAssumptions where
  roleBindingChangeAlarmConfigured : Bool
  socRunbookExists : Bool
  socGap : Nat
  gapFromMissingAlarmAndRunbook :
    roleBindingChangeAlarmConfigured = false →
    socRunbookExists = false →
    0 < socGap

theorem eks_iam_rbac_role_binding_alarm_soc_gap_exists
    (a : EKSIAMRBACRoleBindingAlarmSOCGapAssumptions)
    (hAlarm : a.roleBindingChangeAlarmConfigured = false)
    (hRunbook : a.socRunbookExists = false) :
    0 < a.socGap :=
  a.gapFromMissingAlarmAndRunbook hAlarm hRunbook

-- ── Theorem 5 ────────────────────────────────────────────────────────────────
-- Anti-thesis: AWS X-Ray active tracing is NOT enabled on the EKS IAM/RBAC
-- configuration API call path AND RBAC configuration changes are not retained
-- in CloudTrail for 90 days → observability gap is strictly positive.

structure EKSIAMRBACXRayGapAssumptions where
  xRayTracingEnabled : Bool
  cloudTrailRetentionMet : Bool
  observabilityGap : Nat
  gapFromMissingXRayAndRetention :
    xRayTracingEnabled = false →
    cloudTrailRetentionMet = false →
    0 < observabilityGap

theorem eks_iam_rbac_xray_gap_exists
    (a : EKSIAMRBACXRayGapAssumptions)
    (hXRay : a.xRayTracingEnabled = false)
    (hRet : a.cloudTrailRetentionMet = false) :
    0 < a.observabilityGap :=
  a.gapFromMissingXRayAndRetention hXRay hRet

end ForkRaceFoldTheorems
