/-!
# UltrasoundNeonatalTotalAnomalousPulmonaryVenousReturnDetailedSecurityEconomics

Neonatal total anomalous pulmonary venous return (TAPVR): all four pulmonary
veins drain anomalously to the right heart. Five security-economics gap
theorems for clinical imaging gaps that constitute missed-diagnosis risk —
each with a measurable economic (medico-legal / readmission) cost.

Anti-thesis pattern: structure posits the ABSENCE of an imaging assessment,
theorem derives strictly-positive risk. Zero sorry — all close by exact.
-/

namespace ForkRaceFoldTheorems

-- ── Theorem 1 ────────────────────────────────────────────────────────────────
-- Anti-thesis: anomalous pulmonary venous connection site NOT classified
-- (supracardiac / cardiac / infracardiac / mixed) → incorrect surgical
-- approach risk is strictly positive.

structure AnomalousConnectionSiteClassificationGapAssumptions where
  connectionSiteClassified : Bool
  incorrectApproachRisk : Nat
  gapFromUnclassifiedSite :
    connectionSiteClassified = false → 0 < incorrectApproachRisk

theorem anomalous_connection_site_classification_gap_exists
    (a : AnomalousConnectionSiteClassificationGapAssumptions)
    (h : a.connectionSiteClassified = false) :
    0 < a.incorrectApproachRisk :=
  a.gapFromUnclassifiedSite h

-- ── Theorem 2 ────────────────────────────────────────────────────────────────
-- Anti-thesis: pulmonary venous obstruction NOT assessed by pulsed-wave
-- Doppler AND vertical vein patency NOT confirmed → critical obstruction
-- missed, mortality risk is strictly positive.

structure PulmonaryVenousObstructionGapAssumptions where
  obstructionAssessedByDoppler : Bool
  verticalVeinPatencyConfirmed : Bool
  mortalityRisk : Nat
  gapFromUnassessedObstructionAndVein :
    obstructionAssessedByDoppler = false →
    verticalVeinPatencyConfirmed = false →
    0 < mortalityRisk

theorem pulmonary_venous_obstruction_gap_exists
    (a : PulmonaryVenousObstructionGapAssumptions)
    (hDoppler : a.obstructionAssessedByDoppler = false)
    (hVein : a.verticalVeinPatencyConfirmed = false) :
    0 < a.mortalityRisk :=
  a.gapFromUnassessedObstructionAndVein hDoppler hVein

-- ── Theorem 3 ────────────────────────────────────────────────────────────────
-- Anti-thesis: atrial septal defect size NOT measured AND right-to-left shunt
-- direction NOT confirmed → inadequate mixing assessment risk is strictly
-- positive.

structure ASDSizeShuntDirectionTAPVRGapAssumptions where
  asdSizeMeasured : Bool
  shuntDirectionConfirmed : Bool
  mixingAssessmentRisk : Nat
  gapFromUnmeasuredASDAndUnconfirmedShunt :
    asdSizeMeasured = false →
    shuntDirectionConfirmed = false →
    0 < mixingAssessmentRisk

theorem asd_size_shunt_direction_tapvr_gap_exists
    (a : ASDSizeShuntDirectionTAPVRGapAssumptions)
    (hASD : a.asdSizeMeasured = false)
    (hShunt : a.shuntDirectionConfirmed = false) :
    0 < a.mixingAssessmentRisk :=
  a.gapFromUnmeasuredASDAndUnconfirmedShunt hASD hShunt

-- ── Theorem 4 ────────────────────────────────────────────────────────────────
-- Anti-thesis: right ventricular size and function NOT quantified AND
-- pulmonary artery pressure NOT estimated → haemodynamic mismanagement risk
-- is strictly positive.

structure RVSizeFunctionPressureGapAssumptions where
  rvSizeQuantified : Bool
  pulmonaryPressureEstimated : Bool
  haemodynamicRisk : Nat
  gapFromUnquantifiedRVAndPressure :
    rvSizeQuantified = false →
    pulmonaryPressureEstimated = false →
    0 < haemodynamicRisk

theorem rv_size_function_pressure_gap_exists
    (a : RVSizeFunctionPressureGapAssumptions)
    (hRV : a.rvSizeQuantified = false)
    (hPressure : a.pulmonaryPressureEstimated = false) :
    0 < a.haemodynamicRisk :=
  a.gapFromUnquantifiedRVAndPressure hRV hPressure

-- ── Theorem 5 ────────────────────────────────────────────────────────────────
-- Anti-thesis: coronary sinus dilation NOT identified as a marker of cardiac
-- TAPVR AND individual pulmonary vein insertion points NOT mapped → intra-
-- operative misidentification risk is strictly positive.

structure CoronarySinusPVInsertionGapAssumptions where
  coronarySinusDilationIdentified : Bool
  pvInsertionPointsMapped : Bool
  intraoperativeRisk : Nat
  gapFromUnidentifiedCSAndUnmappedPV :
    coronarySinusDilationIdentified = false →
    pvInsertionPointsMapped = false →
    0 < intraoperativeRisk

theorem coronary_sinus_pv_insertion_gap_exists
    (a : CoronarySinusPVInsertionGapAssumptions)
    (hCS : a.coronarySinusDilationIdentified = false)
    (hPV : a.pvInsertionPointsMapped = false) :
    0 < a.intraoperativeRisk :=
  a.gapFromUnidentifiedCSAndUnmappedPV hCS hPV

end ForkRaceFoldTheorems
