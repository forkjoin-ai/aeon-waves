/-!
# AWSIoTEventsStepFunctionsSQSMisconfigurationDetectionSecurityEconomics

Security-economics gap theorems for AWS IoT Events → Step Functions → SQS
pipeline misconfiguration detection. Five proofs that absence of controls
creates measurable revenue-at-risk or compliance exposure.

Anti-thesis pattern: each structure posits the ABSENCE of a control, then
derives a positive risk quantity. Zero sorry — all theorems close by exact.
-/

namespace ForkRaceFoldTheorems

-- ── Theorem 1 ────────────────────────────────────────────────────────────────
-- Anti-thesis: SQS queue messages are NOT encrypted with a customer-managed KMS
-- key → compliance gap is strictly positive.

structure SQSCMKGapAssumptions where
  queueEncryptedWithCMK : Bool
  complianceRisk : Nat
  gapFromMissingCMK : queueEncryptedWithCMK = false → 0 < complianceRisk

theorem sqs_cmk_gap_exists
    (a : SQSCMKGapAssumptions)
    (h : a.queueEncryptedWithCMK = false) :
    0 < a.complianceRisk :=
  a.gapFromMissingCMK h

-- ── Theorem 2 ────────────────────────────────────────────────────────────────
-- Anti-thesis: no SCP denies deletion of SQS queues used by production Step
-- Functions state machines AND no queue-policy restricts cross-account sends →
-- queue-hijack risk is strictly positive.

structure SQSSCPAndQueuePolicyGapAssumptions where
  scpDeniesQueueDeletion : Bool
  queuePolicyRestrictsXAccount : Bool
  hijackRisk : Nat
  gapFromMissingSCPAndPolicy :
    scpDeniesQueueDeletion = false →
    queuePolicyRestrictsXAccount = false →
    0 < hijackRisk

theorem sqs_scp_and_queue_policy_gap_exists
    (a : SQSSCPAndQueuePolicyGapAssumptions)
    (hSCP : a.scpDeniesQueueDeletion = false)
    (hPolicy : a.queuePolicyRestrictsXAccount = false) :
    0 < a.hijackRisk :=
  a.gapFromMissingSCPAndPolicy hSCP hPolicy

-- ── Theorem 3 ────────────────────────────────────────────────────────────────
-- Anti-thesis: the Step Functions state-machine IAM role grants SQS SendMessage
-- to all queues instead of the specific queue ARN → IAM scope gap is strictly
-- positive.

structure SQSIAMRoleScopeGapAssumptions where
  iamRoleScopedToSpecificQueue : Bool
  iamScopeGap : Nat
  gapFromBroadRole : iamRoleScopedToSpecificQueue = false → 0 < iamScopeGap

theorem sqs_iam_role_scope_gap_exists
    (a : SQSIAMRoleScopeGapAssumptions)
    (h : a.iamRoleScopedToSpecificQueue = false) :
    0 < a.iamScopeGap :=
  a.gapFromBroadRole h

-- ── Theorem 4 ────────────────────────────────────────────────────────────────
-- Anti-thesis: no CloudWatch alarm fires on SQS ApproximateNumberOfMessagesNotVisible
-- exceeding threshold AND the SOC has no dead-letter-queue runbook → SOC gap is
-- strictly positive.

structure SQSAlarmSOCGapAssumptions where
  cloudWatchAlarmConfigured : Bool
  dlqRunbookExists : Bool
  socGap : Nat
  gapFromMissingAlarmAndRunbook :
    cloudWatchAlarmConfigured = false →
    dlqRunbookExists = false →
    0 < socGap

theorem sqs_alarm_soc_gap_exists
    (a : SQSAlarmSOCGapAssumptions)
    (hAlarm : a.cloudWatchAlarmConfigured = false)
    (hRunbook : a.dlqRunbookExists = false) :
    0 < a.socGap :=
  a.gapFromMissingAlarmAndRunbook hAlarm hRunbook

-- ── Theorem 5 ────────────────────────────────────────────────────────────────
-- Anti-thesis: AWS X-Ray active tracing is NOT enabled on the Step Functions
-- state machine that writes to SQS AND message-attribute propagation is absent →
-- observability gap is strictly positive.

structure SQSXRayGapAssumptions where
  xRayTracingEnabled : Bool
  messageAttributePropagationEnabled : Bool
  observabilityGap : Nat
  gapFromMissingXRay :
    xRayTracingEnabled = false →
    messageAttributePropagationEnabled = false →
    0 < observabilityGap

theorem sqs_xray_gap_exists
    (a : SQSXRayGapAssumptions)
    (hXRay : a.xRayTracingEnabled = false)
    (hProp : a.messageAttributePropagationEnabled = false) :
    0 < a.observabilityGap :=
  a.gapFromMissingXRay hXRay hProp

end ForkRaceFoldTheorems
