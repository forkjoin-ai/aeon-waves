/-!
# UltrasoundNeonatalThyroglosDuctCystDetailedSecurityEconomics

Anti-thesis: neonatal fetal ultrasound reliably characterizes thyroglossal duct
cyst (TDC) by classifying location relative to hyoid bone and assessing
infrahyoid vs. suprahyoid extent, measuring cyst dimensions and wall
characteristics, evaluating ectopic thyroid tissue as the only functioning
thyroid, assessing airway compromise and deviation, and coordinating postnatal
Sistrunk procedure planning and MDT referral. Management decisions based on
these assessments are clinically sound.

Refutation: each failure mode below proves that the ABSENCE of a systematic
assessment control implies a strictly positive clinical and economic risk.
Zero sorry — all theorems close by exact.
-/

namespace ForkRaceFoldTheorems

-- ── Theorem 1 ────────────────────────────────────────────────────────────────
-- Anti-thesis: the cyst location relative to the hyoid bone (suprahyoid vs.
-- infrahyoid vs. intrahyoid) is NOT classified AND the superior extent toward
-- the tongue base is NOT assessed → surgical planning risk is strictly positive.

structure TDCLocationExtentGapAssumptions where
  locationClassified : Bool
  superiorExtentAssessed : Bool
  surgicalPlanningRisk : Nat
  gapFromMissingLocationAndExtent :
    locationClassified = false →
    superiorExtentAssessed = false →
    0 < surgicalPlanningRisk

theorem tdc_location_extent_gap_exists
    (a : TDCLocationExtentGapAssumptions)
    (hLocation : a.locationClassified = false)
    (hExtent : a.superiorExtentAssessed = false) :
    0 < a.surgicalPlanningRisk :=
  a.gapFromMissingLocationAndExtent hLocation hExtent

-- ── Theorem 2 ────────────────────────────────────────────────────────────────
-- Anti-thesis: cyst dimensions (AP, transverse, cranio-caudal) are NOT measured
-- AND wall characteristics (thin-walled vs. complex/septated) are NOT described
-- → recurrence risk stratification gap is strictly positive.

structure TDCDimensionsWallCharacteristicsGapAssumptions where
  dimensionsMeasured : Bool
  wallCharacteristicsDescribed : Bool
  recurrenceRiskGap : Nat
  gapFromMissingDimensionsAndWall :
    dimensionsMeasured = false →
    wallCharacteristicsDescribed = false →
    0 < recurrenceRiskGap

theorem tdc_dimensions_wall_characteristics_gap_exists
    (a : TDCDimensionsWallCharacteristicsGapAssumptions)
    (hDimensions : a.dimensionsMeasured = false)
    (hWall : a.wallCharacteristicsDescribed = false) :
    0 < a.recurrenceRiskGap :=
  a.gapFromMissingDimensionsAndWall hDimensions hWall

-- ── Theorem 3 ────────────────────────────────────────────────────────────────
-- Anti-thesis: ectopic thyroid tissue within or adjacent to the cyst is NOT
-- identified AND the presence of a normally-positioned thyroid is NOT confirmed
-- → inadvertent thyroid excision risk is strictly positive.

structure TDCEctopicThyroidConfirmationGapAssumptions where
  ectopicThyroidIdentified : Bool
  normalThyroidConfirmed : Bool
  thyroidExcisionRisk : Nat
  gapFromMissingEctopicAndNormal :
    ectopicThyroidIdentified = false →
    normalThyroidConfirmed = false →
    0 < thyroidExcisionRisk

theorem tdc_ectopic_thyroid_confirmation_gap_exists
    (a : TDCEctopicThyroidConfirmationGapAssumptions)
    (hEctopic : a.ectopicThyroidIdentified = false)
    (hNormal : a.normalThyroidConfirmed = false) :
    0 < a.thyroidExcisionRisk :=
  a.gapFromMissingEctopicAndNormal hEctopic hNormal

-- ── Theorem 4 ────────────────────────────────────────────────────────────────
-- Anti-thesis: tracheal deviation angle is NOT assessed AND airway compression
-- score secondary to cyst mass effect is NOT graded → neonatal airway risk is
-- strictly positive.

structure TDCAirwayDeviationCompressionGapAssumptions where
  trachealDeviationAssessed : Bool
  airwayCompressionGraded : Bool
  neonatalAirwayRisk : Nat
  gapFromMissingDeviationAndCompression :
    trachealDeviationAssessed = false →
    airwayCompressionGraded = false →
    0 < neonatalAirwayRisk

theorem tdc_airway_deviation_compression_gap_exists
    (a : TDCAirwayDeviationCompressionGapAssumptions)
    (hDeviation : a.trachealDeviationAssessed = false)
    (hCompression : a.airwayCompressionGraded = false) :
    0 < a.neonatalAirwayRisk :=
  a.gapFromMissingDeviationAndCompression hDeviation hCompression

-- ── Theorem 5 ────────────────────────────────────────────────────────────────
-- Anti-thesis: postnatal Sistrunk procedure candidacy is NOT evaluated AND
-- multidisciplinary team (MDT) referral to a paediatric head-and-neck surgeon
-- is NOT initiated → postnatal management gap is strictly positive.

structure TDCSistrunkMDTReferralGapAssumptions where
  sistrunkCandidacyEvaluated : Bool
  mdtReferralInitiated : Bool
  postnatalManagementGap : Nat
  gapFromMissingSistrunkAndMDT :
    sistrunkCandidacyEvaluated = false →
    mdtReferralInitiated = false →
    0 < postnatalManagementGap

theorem tdc_sistrunk_mdt_referral_gap_exists
    (a : TDCSistrunkMDTReferralGapAssumptions)
    (hSistrunk : a.sistrunkCandidacyEvaluated = false)
    (hMDT : a.mdtReferralInitiated = false) :
    0 < a.postnatalManagementGap :=
  a.gapFromMissingSistrunkAndMDT hSistrunk hMDT

end ForkRaceFoldTheorems
