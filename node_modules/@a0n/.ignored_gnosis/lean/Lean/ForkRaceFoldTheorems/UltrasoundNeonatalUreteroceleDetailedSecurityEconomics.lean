/-!
# UltrasoundNeonatalUreteroceleDetailedSecurityEconomics

Neonatal renal ultrasound — ureterocele.
Security-economics gap theorems derived from absent diagnostic controls.

Anti-thesis pattern: each structure posits the ABSENCE of a required
measurement or finding, then derives a positive risk quantity.
Zero sorry — all theorems close by exact.
-/

namespace ForkRaceFoldTheorems

-- ── Theorem 1 ────────────────────────────────────────────────────────────────
-- Anti-thesis: ureterocele transverse and longitudinal dimensions are NOT
-- measured AND intravesical vs ectopic location is not documented →
-- size-classification gap is strictly positive.

structure UreteroceleSizeClassificationGapAssumptions where
  ureteroceleDimensionsMeasured : Bool
  locationDocumented : Bool
  sizeClassificationGap : Nat
  gapFromMissingDimensions :
    ureteroceleDimensionsMeasured = false →
    locationDocumented = false →
    0 < sizeClassificationGap

theorem ureterocele_size_classification_gap_exists
    (a : UreteroceleSizeClassificationGapAssumptions)
    (hDims : a.ureteroceleDimensionsMeasured = false)
    (hLoc : a.locationDocumented = false) :
    0 < a.sizeClassificationGap :=
  a.gapFromMissingDimensions hDims hLoc

-- ── Theorem 2 ────────────────────────────────────────────────────────────────
-- Anti-thesis: duplex kidney anatomy — upper-pole moiety, ureter insertion, and
-- lower-pole collecting system — is NOT documented → collecting-system
-- classification gap is strictly positive.

structure UreteroceleDuplexAnatomyGapAssumptions where
  upperPoleDocumented : Bool
  uretericInsertionDocumented : Bool
  collectingSystemGap : Nat
  gapFromMissingDuplexData :
    upperPoleDocumented = false →
    uretericInsertionDocumented = false →
    0 < collectingSystemGap

theorem ureterocele_duplex_anatomy_gap_exists
    (a : UreteroceleDuplexAnatomyGapAssumptions)
    (hUpper : a.upperPoleDocumented = false)
    (hInsert : a.uretericInsertionDocumented = false) :
    0 < a.collectingSystemGap :=
  a.gapFromMissingDuplexData hUpper hInsert

-- ── Theorem 3 ────────────────────────────────────────────────────────────────
-- Anti-thesis: bladder outlet obstruction is NOT assessed AND post-void residual
-- volume is not measured → lower urinary tract obstruction assessment gap is
-- strictly positive.

structure UreteroceleLUTOAssessmentGapAssumptions where
  bladderOutletObstructionAssessed : Bool
  postVoidResidualMeasured : Bool
  lowerUrinaryTractObstructionGap : Nat
  gapFromMissingLUTOData :
    bladderOutletObstructionAssessed = false →
    postVoidResidualMeasured = false →
    0 < lowerUrinaryTractObstructionGap

theorem ureterocele_luto_assessment_gap_exists
    (a : UreteroceleLUTOAssessmentGapAssumptions)
    (hOutlet : a.bladderOutletObstructionAssessed = false)
    (hPVR : a.postVoidResidualMeasured = false) :
    0 < a.lowerUrinaryTractObstructionGap :=
  a.gapFromMissingLUTOData hOutlet hPVR

-- ── Theorem 4 ────────────────────────────────────────────────────────────────
-- Anti-thesis: contralateral upper tract is NOT evaluated for hydronephrosis
-- AND no ipsilateral lower-pole APD is reported → bilateral assessment gap is
-- strictly positive.

structure UreteroceleBilateralAssessmentGapAssumptions where
  contralateralUpperTractEvaluated : Bool
  ipsilateralLowerPoleAPDReported : Bool
  bilateralAssessmentGap : Nat
  gapFromMissingBilateralData :
    contralateralUpperTractEvaluated = false →
    ipsilateralLowerPoleAPDReported = false →
    0 < bilateralAssessmentGap

theorem ureterocele_bilateral_assessment_gap_exists
    (a : UreteroceleBilateralAssessmentGapAssumptions)
    (hContralateral : a.contralateralUpperTractEvaluated = false)
    (hIPsi : a.ipsilateralLowerPoleAPDReported = false) :
    0 < a.bilateralAssessmentGap :=
  a.gapFromMissingBilateralData hContralateral hIPsi

-- ── Theorem 5 ────────────────────────────────────────────────────────────────
-- Anti-thesis: no follow-up renal ultrasound interval is specified AND no VCUG
-- referral decision is documented → surveillance gap is strictly positive.

structure UreteroceleSurveillancePlanGapAssumptions where
  followUpIntervalSpecified : Bool
  vcugReferralDocumented : Bool
  surveillanceGap : Nat
  gapFromMissingSurveillancePlan :
    followUpIntervalSpecified = false →
    vcugReferralDocumented = false →
    0 < surveillanceGap

theorem ureterocele_surveillance_plan_gap_exists
    (a : UreteroceleSurveillancePlanGapAssumptions)
    (hInterval : a.followUpIntervalSpecified = false)
    (hVCUG : a.vcugReferralDocumented = false) :
    0 < a.surveillanceGap :=
  a.gapFromMissingSurveillancePlan hInterval hVCUG

end ForkRaceFoldTheorems
