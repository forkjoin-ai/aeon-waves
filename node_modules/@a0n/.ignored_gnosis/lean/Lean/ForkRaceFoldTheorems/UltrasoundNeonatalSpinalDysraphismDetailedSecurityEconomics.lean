/-!
# UltrasoundNeonatalSpinalDysraphismDetailedSecurityEconomics

Security-economics gap theorems for neonatal spinal dysraphism (spina bifida,
myelomeningocele) ultrasound evaluation. Five proofs that absence of documented
sonographic findings creates measurable clinical-liability or revenue-at-risk
exposure.

Anti-thesis pattern: each structure posits the ABSENCE of a documented finding,
then derives a positive risk quantity. Zero sorry — all theorems close by exact.
-/

namespace ForkRaceFoldTheorems

-- ── Theorem 1 ────────────────────────────────────────────────────────────────
-- Anti-thesis: spinal defect level (vertebral segment), extent (number of
-- segments), and skin coverage are NOT documented → neurosurgical-planning
-- liability gap is strictly positive.

structure SpinalDysraphismDefectLevelGapAssumptions where
  defectLevelDocumented : Bool
  skinCoverageDocumented : Bool
  neurosurgicalLiabilityGap : Nat
  gapFromMissingLevelAndCoverage :
    defectLevelDocumented = false →
    skinCoverageDocumented = false →
    0 < neurosurgicalLiabilityGap

theorem spinal_dysraphism_defect_level_gap_exists
    (a : SpinalDysraphismDefectLevelGapAssumptions)
    (hLevel : a.defectLevelDocumented = false)
    (hSkin : a.skinCoverageDocumented = false) :
    0 < a.neurosurgicalLiabilityGap :=
  a.gapFromMissingLevelAndCoverage hLevel hSkin

-- ── Theorem 2 ────────────────────────────────────────────────────────────────
-- Anti-thesis: conus medullaris level (normal vs low-lying) and tethered cord
-- exclusion are NOT documented → missed tethered cord gap is strictly positive.

structure SpinalDysraphismConusMedullarisGapAssumptions where
  conusLevelDocumented : Bool
  tetheredCordExcluded : Bool
  tetheredCordGap : Nat
  gapFromMissingConusAndExclusion :
    conusLevelDocumented = false →
    tetheredCordExcluded = false →
    0 < tetheredCordGap

theorem spinal_dysraphism_conus_medullaris_gap_exists
    (a : SpinalDysraphismConusMedullarisGapAssumptions)
    (hConus : a.conusLevelDocumented = false)
    (hExcl : a.tetheredCordExcluded = false) :
    0 < a.tetheredCordGap :=
  a.gapFromMissingConusAndExclusion hConus hExcl

-- ── Theorem 3 ────────────────────────────────────────────────────────────────
-- Anti-thesis: associated Chiari II malformation cranial signs (lemon sign,
-- banana sign, ventriculomegaly degree) are NOT documented → cranial surveillance
-- planning gap is strictly positive.

structure SpinalDysraphismChiariIIGapAssumptions where
  chiariSignsDocumented : Bool
  ventriculomegalyGraded : Bool
  cranialSurveillanceGap : Nat
  gapFromMissingChiariAndVentriculo :
    chiariSignsDocumented = false →
    ventriculomegalyGraded = false →
    0 < cranialSurveillanceGap

theorem spinal_dysraphism_chiari_ii_gap_exists
    (a : SpinalDysraphismChiariIIGapAssumptions)
    (hChiari : a.chiariSignsDocumented = false)
    (hVent : a.ventriculomegalyGraded = false) :
    0 < a.cranialSurveillanceGap :=
  a.gapFromMissingChiariAndVentriculo hChiari hVent

-- ── Theorem 4 ────────────────────────────────────────────────────────────────
-- Anti-thesis: renal and bladder ultrasound assessment (hydronephrosis,
-- bladder-wall thickening) are NOT performed AND neuropathic bladder exclusion
-- is absent → neurogenic bladder miss gap is strictly positive.

structure SpinalDysraphismRenalBladderGapAssumptions where
  renalUltrasoundPerformed : Bool
  neuropathicBladderExcluded : Bool
  neurogenicBladderGap : Nat
  gapFromMissingRenalAndBladder :
    renalUltrasoundPerformed = false →
    neuropathicBladderExcluded = false →
    0 < neurogenicBladderGap

theorem spinal_dysraphism_renal_bladder_gap_exists
    (a : SpinalDysraphismRenalBladderGapAssumptions)
    (hRenal : a.renalUltrasoundPerformed = false)
    (hBladder : a.neuropathicBladderExcluded = false) :
    0 < a.neurogenicBladderGap :=
  a.gapFromMissingRenalAndBladder hRenal hBladder

-- ── Theorem 5 ────────────────────────────────────────────────────────────────
-- Anti-thesis: prenatal-to-postnatal MRI referral criteria and fetal surgery
-- candidacy assessment are NOT documented AND multidisciplinary team referral
-- is absent → delayed fetal surgery eligibility gap is strictly positive.

structure SpinalDysraphismFetalSurgeryReferralGapAssumptions where
  mriReferralDocumented : Bool
  mdsTeamReferralDocumented : Bool
  fetalSurgeryDelayGap : Nat
  gapFromMissingMRIAndMDS :
    mriReferralDocumented = false →
    mdsTeamReferralDocumented = false →
    0 < fetalSurgeryDelayGap

theorem spinal_dysraphism_fetal_surgery_referral_gap_exists
    (a : SpinalDysraphismFetalSurgeryReferralGapAssumptions)
    (hMRI : a.mriReferralDocumented = false)
    (hMDS : a.mdsTeamReferralDocumented = false) :
    0 < a.fetalSurgeryDelayGap :=
  a.gapFromMissingMRIAndMDS hMRI hMDS

end ForkRaceFoldTheorems
