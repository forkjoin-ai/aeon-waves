/-!
# UltrasoundNeonatalCysticFibrosisDetailedSecurityEconomics

Security-economics gap theorems for neonatal cystic fibrosis ultrasound
evaluation (meconium ileus, bowel echogenicity). Five proofs that absence of
documented sonographic findings creates measurable clinical-liability or
revenue-at-risk exposure.

Anti-thesis pattern: each structure posits the ABSENCE of a documented finding,
then derives a positive risk quantity. Zero sorry — all theorems close by exact.
-/

namespace ForkRaceFoldTheorems

-- ── Theorem 1 ────────────────────────────────────────────────────────────────
-- Anti-thesis: bowel echogenicity grade (0–3 vs liver echogenicity) is NOT
-- documented → CF-screening liability gap is strictly positive.

structure CFBowelEchogenicityGapAssumptions where
  bowelEchogenicityGraded : Bool
  screeningLiabilityGap : Nat
  gapFromMissingGrade : bowelEchogenicityGraded = false → 0 < screeningLiabilityGap

theorem cf_bowel_echogenicity_gap_exists
    (a : CFBowelEchogenicityGapAssumptions)
    (h : a.bowelEchogenicityGraded = false) :
    0 < a.screeningLiabilityGap :=
  a.gapFromMissingGrade h

-- ── Theorem 2 ────────────────────────────────────────────────────────────────
-- Anti-thesis: meconium-ileus bowel dilation calibre is NOT measured AND
-- echogenic plug documentation is absent → diagnostic ambiguity gap is strictly
-- positive.

structure CFMeconiumIleusDilationGapAssumptions where
  bowelDilationMeasured : Bool
  echogenicPlugDocumented : Bool
  diagnosticAmbiguityGap : Nat
  gapFromMissingDilationAndPlug :
    bowelDilationMeasured = false →
    echogenicPlugDocumented = false →
    0 < diagnosticAmbiguityGap

theorem cf_meconium_ileus_dilation_gap_exists
    (a : CFMeconiumIleusDilationGapAssumptions)
    (hDil : a.bowelDilationMeasured = false)
    (hPlug : a.echogenicPlugDocumented = false) :
    0 < a.diagnosticAmbiguityGap :=
  a.gapFromMissingDilationAndPlug hDil hPlug

-- ── Theorem 3 ────────────────────────────────────────────────────────────────
-- Anti-thesis: gallbladder visualisation and bile-duct calibre assessment are
-- NOT documented AND CF-related liver disease (hepatomegaly, echogenicity) is
-- absent from report → missed hepatobiliary complication gap is strictly positive.

structure CFGallbladderBileDuctGapAssumptions where
  gallbladderDocumented : Bool
  liverEchogenicityDocumented : Bool
  hepatobiliaryGap : Nat
  gapFromMissingGallbladderAndLiver :
    gallbladderDocumented = false →
    liverEchogenicityDocumented = false →
    0 < hepatobiliaryGap

theorem cf_gallbladder_bile_duct_gap_exists
    (a : CFGallbladderBileDuctGapAssumptions)
    (hGB : a.gallbladderDocumented = false)
    (hLiver : a.liverEchogenicityDocumented = false) :
    0 < a.hepatobiliaryGap :=
  a.gapFromMissingGallbladderAndLiver hGB hLiver

-- ── Theorem 4 ────────────────────────────────────────────────────────────────
-- Anti-thesis: pancreatic morphology (cystic change, echogenicity) is NOT
-- assessed AND spleen size is undocumented → missed CF pancreatic exocrine
-- insufficiency marker gap is strictly positive.

structure CFPancreaticMorphologyGapAssumptions where
  pancreasAssessed : Bool
  spleenDocumented : Bool
  pancreaticGap : Nat
  gapFromMissingPancreasAndSpleen :
    pancreasAssessed = false →
    spleenDocumented = false →
    0 < pancreaticGap

theorem cf_pancreatic_morphology_gap_exists
    (a : CFPancreaticMorphologyGapAssumptions)
    (hPanc : a.pancreasAssessed = false)
    (hSpleen : a.spleenDocumented = false) :
    0 < a.pancreaticGap :=
  a.gapFromMissingPancreasAndSpleen hPanc hSpleen

-- ── Theorem 5 ────────────────────────────────────────────────────────────────
-- Anti-thesis: referral for sweat-chloride testing and genetics follow-up is NOT
-- documented in the sonographic report AND family history correlation is absent →
-- delayed CF diagnosis risk is strictly positive.

structure CFReferralGeneticsGapAssumptions where
  sweatChlorideReferralDocumented : Bool
  familyHistoryCorrelated : Bool
  delayedDiagnosisRisk : Nat
  gapFromMissingReferralAndHistory :
    sweatChlorideReferralDocumented = false →
    familyHistoryCorrelated = false →
    0 < delayedDiagnosisRisk

theorem cf_referral_genetics_gap_exists
    (a : CFReferralGeneticsGapAssumptions)
    (hRef : a.sweatChlorideReferralDocumented = false)
    (hHx : a.familyHistoryCorrelated = false) :
    0 < a.delayedDiagnosisRisk :=
  a.gapFromMissingReferralAndHistory hRef hHx

end ForkRaceFoldTheorems
