/-!
# AWSIoTEventsStepFunctionsElasticIPMisconfigurationDetectionSecurityEconomics

AWS Elastic IP misconfiguration scanner for IoT Events + Step Functions
pipelines. Five security-economics gap theorems: each proves that the ABSENCE
of a control on the Elastic IP surface creates measurable compliance or
attack-surface cost.

Anti-thesis pattern: structure posits the ABSENCE of a control, theorem
derives strictly-positive gap. Zero sorry — all close by exact.
-/

namespace ForkRaceFoldTheorems

-- ── Theorem 1 ────────────────────────────────────────────────────────────────
-- Anti-thesis: VPC flow logs for subnets associated with Elastic IPs used by
-- IoT Events instances are NOT encrypted with a customer-managed KMS key →
-- compliance gap is strictly positive.

structure EIPFlowLogCMKGapAssumptions where
  flowLogsEncryptedWithCMK : Bool
  complianceGap : Nat
  gapFromMissingCMK : flowLogsEncryptedWithCMK = false → 0 < complianceGap

theorem eip_flow_log_cmk_gap_exists
    (a : EIPFlowLogCMKGapAssumptions)
    (h : a.flowLogsEncryptedWithCMK = false) :
    0 < a.complianceGap :=
  a.gapFromMissingCMK h

-- ── Theorem 2 ────────────────────────────────────────────────────────────────
-- Anti-thesis: no SCP or AWS Config rule prevents disassociation or release of
-- Elastic IPs used by IoT Events private instances AND more than one Elastic IP
-- is allocated to the VPC → deletion-scope risk is strictly positive.

structure EIPSCPReleaseGapAssumptions where
  scpOrConfigRulePresent : Bool
  elasticIpCount : Nat
  releaseRisk : Nat
  gapFromMissingProtectionAndMultiEIP :
    scpOrConfigRulePresent = false →
    1 < elasticIpCount →
    0 < releaseRisk

theorem eip_scp_release_gap_exists
    (a : EIPSCPReleaseGapAssumptions)
    (hSCP : a.scpOrConfigRulePresent = false)
    (hEIPs : 1 < a.elasticIpCount) :
    0 < a.releaseRisk :=
  a.gapFromMissingProtectionAndMultiEIP hSCP hEIPs

-- ── Theorem 3 ────────────────────────────────────────────────────────────────
-- Anti-thesis: the IAM role permitted to invoke ec2:ReleaseAddress is NOT
-- scoped to the specific Elastic IP allocation ID → privilege escalation risk
-- is strictly positive.

structure EIPIAMRoleScopeGapAssumptions where
  iamRoleScopedToAllocation : Bool
  privilegeEscalationRisk : Nat
  gapFromUnscopedRole : iamRoleScopedToAllocation = false → 0 < privilegeEscalationRisk

theorem eip_iam_role_scope_gap_exists
    (a : EIPIAMRoleScopeGapAssumptions)
    (h : a.iamRoleScopedToAllocation = false) :
    0 < a.privilegeEscalationRisk :=
  a.gapFromUnscopedRole h

-- ── Theorem 4 ────────────────────────────────────────────────────────────────
-- Anti-thesis: no CloudWatch alarm fires on unexpected Elastic IP
-- disassociation or reassociation events AND the SOC has no on-call runbook
-- for EIP hijack signals → SOC blind-spot risk is strictly positive.

structure EIPReassociationAlarmSOCGapAssumptions where
  cloudWatchAlarmConfigured : Bool
  socRunbookExists : Bool
  socBlindSpotRisk : Nat
  gapFromMissingAlarmAndRunbook :
    cloudWatchAlarmConfigured = false →
    socRunbookExists = false →
    0 < socBlindSpotRisk

theorem eip_reassociation_alarm_soc_gap_exists
    (a : EIPReassociationAlarmSOCGapAssumptions)
    (hAlarm : a.cloudWatchAlarmConfigured = false)
    (hRunbook : a.socRunbookExists = false) :
    0 < a.socBlindSpotRisk :=
  a.gapFromMissingAlarmAndRunbook hAlarm hRunbook

-- ── Theorem 5 ────────────────────────────────────────────────────────────────
-- Anti-thesis: AWS X-Ray active tracing is NOT enabled on the Step Functions
-- state machine that manages Elastic IP lifecycle AND CloudTrail API calls for
-- ec2:AllocateAddress / ec2:AssociateAddress are not forwarded to a SIEM →
-- observability gap is strictly positive.

structure EIPXRayCloudTrailGapAssumptions where
  xRayTracingEnabled : Bool
  cloudTrailForwardedToSIEM : Bool
  observabilityGap : Nat
  gapFromMissingXRayAndSIEM :
    xRayTracingEnabled = false →
    cloudTrailForwardedToSIEM = false →
    0 < observabilityGap

theorem eip_xray_cloudtrail_gap_exists
    (a : EIPXRayCloudTrailGapAssumptions)
    (hXRay : a.xRayTracingEnabled = false)
    (hSIEM : a.cloudTrailForwardedToSIEM = false) :
    0 < a.observabilityGap :=
  a.gapFromMissingXRayAndSIEM hXRay hSIEM

end ForkRaceFoldTheorems
