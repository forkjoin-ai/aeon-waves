namespace ForkRaceFoldTheorems
namespace ZenonicBarrier

/-- A Zenonic gap. -/
structure Gap where
  num : Nat
  denom : Nat
  hDenomPositive : 0 < denom

/-- Double the denominator, preserve the numerator. -/
def contractStep (g : Gap) : Gap :=
  { num := g.num, denom := 2 * g.denom, hDenomPositive := by
      have h := g.hDenomPositive
      exact Nat.mul_pos (by decide) h }

/-- Numerator is preserved by step. -/
theorem numeratorPreservedByStep (g : Gap) :
    (contractStep g).num = g.num := by
  rfl

/-- Apply `contractStep` `n` times. -/
def iterate : Nat -> Gap -> Gap
  | 0, g => g
  | n + 1, g => contractStep (iterate n g)

/-- The barrier never reached in finite steps. -/
theorem barrierNeverReachedInFiniteSteps (g : Gap) (hNum : 0 < g.num) (n : Nat) :
    0 < (iterate n g).num := by
  induction n with
  | zero => exact hNum
  | succ n ih => exact ih

/-- Zenonic approach bypass. -/
structure ZenonicApproachBypass where
  initialGap : Gap
  iterations : Nat
  finalGap : Gap
  hasLanded : Bool

/-- The numerator is fixed during the approach. -/
theorem zenonicApproachNumeratorFixed (g : Gap) (n : Nat) :
    (iterate n g).num = g.num := by
  induction n with
  | zero => rfl
  | succ n ih => exact ih

/-- Construct the bypass witness. -/
def zenonicApproachBypass (g : Gap) (n : Nat) : ZenonicApproachBypass :=
  { initialGap := g,
    iterations := n,
    finalGap := iterate n g,
    hasLanded := (iterate n g).num == 0 }

end ZenonicBarrier
end ForkRaceFoldTheorems
