/-!
# AWSIoTEventsStepFunctionsEKSNodegroupRemoteAccessMisconfigurationDetectionSecurityEconomics

EKS managed node group remoteAccess configuration (EC2 SSH key pair and
source-security-group restrictions) misconfiguration detection
security-economics. Five gap theorems: each proves that absence of a specific
control creates strictly-positive compliance or revenue-at-risk exposure.

Anti-thesis pattern: structure posits absence of a control, theorem derives
strictly-positive risk. Zero sorry — all close by exact.
-/

namespace ForkRaceFoldTheorems

-- ── Theorem 1 ────────────────────────────────────────────────────────────────
-- Anti-thesis: EKS nodegroup remoteAccess EC2 key pair is NOT rotated on a
-- documented schedule AND no customer-managed KMS key protects the associated
-- secrets → compliance gap is strictly positive.

structure RemoteAccessKeyRotationCMKGapAssumptions where
  keyPairRotatedOnSchedule : Bool
  secretsProtectedByCMK : Bool
  complianceRisk : Nat
  gapFromUnrotatedKeyAndCMK :
    keyPairRotatedOnSchedule = false →
    secretsProtectedByCMK = false →
    0 < complianceRisk

theorem remote_access_key_rotation_cmk_gap_exists
    (a : RemoteAccessKeyRotationCMKGapAssumptions)
    (hRot : a.keyPairRotatedOnSchedule = false)
    (hCMK : a.secretsProtectedByCMK = false) :
    0 < a.complianceRisk :=
  a.gapFromUnrotatedKeyAndCMK hRot hCMK

-- ── Theorem 2 ────────────────────────────────────────────────────────────────
-- Anti-thesis: remoteAccess sourceSecurityGroups is set to 0.0.0.0/0 (world-
-- open) AND no restrictive SCP denies this configuration → lateral-movement
-- risk is strictly positive.

structure RemoteAccessWorldOpenSGSCPGapAssumptions where
  sourceRestrictedToApprovedGroups : Bool
  scpDeniesWorldOpen : Bool
  lateralMovementRisk : Nat
  gapFromWorldOpenAndMissingSCP :
    sourceRestrictedToApprovedGroups = false →
    scpDeniesWorldOpen = false →
    0 < lateralMovementRisk

theorem remote_access_world_open_sg_scp_gap_exists
    (a : RemoteAccessWorldOpenSGSCPGapAssumptions)
    (hSG : a.sourceRestrictedToApprovedGroups = false)
    (hSCP : a.scpDeniesWorldOpen = false) :
    0 < a.lateralMovementRisk :=
  a.gapFromWorldOpenAndMissingSCP hSG hSCP

-- ── Theorem 3 ────────────────────────────────────────────────────────────────
-- Anti-thesis: the IAM role authorising remoteAccess configuration changes is
-- NOT scoped to the specific node group → cross-group SSH key substitution
-- risk is strictly positive.

structure RemoteAccessIAMScopeGapAssumptions where
  iamRoleScopedToNodegroup : Bool
  crossGroupKeySubstitutionRisk : Nat
  gapFromUnscopedRole : iamRoleScopedToNodegroup = false → 0 < crossGroupKeySubstitutionRisk

theorem remote_access_iam_scope_gap_exists
    (a : RemoteAccessIAMScopeGapAssumptions)
    (h : a.iamRoleScopedToNodegroup = false) :
    0 < a.crossGroupKeySubstitutionRisk :=
  a.gapFromUnscopedRole h

-- ── Theorem 4 ────────────────────────────────────────────────────────────────
-- Anti-thesis: no CloudWatch alarm fires on SSH authentication failures
-- against nodegroup instances AND the SOC has no runbook for brute-force
-- activity → SOC gap is strictly positive.

structure SSHBruteForceAlarmSOCGapAssumptions where
  sshFailureAlarmConfigured : Bool
  socRunbookExists : Bool
  socGap : Nat
  gapFromMissingAlarmAndRunbook :
    sshFailureAlarmConfigured = false →
    socRunbookExists = false →
    0 < socGap

theorem ssh_brute_force_alarm_soc_gap_exists
    (a : SSHBruteForceAlarmSOCGapAssumptions)
    (hAlarm : a.sshFailureAlarmConfigured = false)
    (hRunbook : a.socRunbookExists = false) :
    0 < a.socGap :=
  a.gapFromMissingAlarmAndRunbook hAlarm hRunbook

-- ── Theorem 5 ────────────────────────────────────────────────────────────────
-- Anti-thesis: AWS X-Ray active tracing is NOT enabled on the EKS control-
-- plane API path for remoteAccess mutations AND key-pair change events are
-- not logged to CloudTrail → observability gap is strictly positive.

structure RemoteAccessXRayGapAssumptions where
  xRayTracingEnabled : Bool
  cloudTrailLoggingEnabled : Bool
  observabilityGap : Nat
  gapFromMissingXRayAndCloudTrail :
    xRayTracingEnabled = false →
    cloudTrailLoggingEnabled = false →
    0 < observabilityGap

theorem remote_access_xray_gap_exists
    (a : RemoteAccessXRayGapAssumptions)
    (hXRay : a.xRayTracingEnabled = false)
    (hTrail : a.cloudTrailLoggingEnabled = false) :
    0 < a.observabilityGap :=
  a.gapFromMissingXRayAndCloudTrail hXRay hTrail

end ForkRaceFoldTheorems
