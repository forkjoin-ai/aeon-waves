/-!
# UltrasoundNeonatalTranspositionOfGreatArteriesDetailedSecurityEconomics

Neonatal D-transposition of the great arteries (D-TGA): parallel circulation
assessment by echocardiography. Five security-economics gap theorems for
clinical imaging gaps that constitute missed-diagnosis risk — each with a
measurable economic (medico-legal / readmission) cost.

Anti-thesis pattern: structure posits the ABSENCE of an imaging assessment,
theorem derives strictly-positive risk. Zero sorry — all close by exact.
-/

namespace ForkRaceFoldTheorems

-- ── Theorem 1 ────────────────────────────────────────────────────────────────
-- Anti-thesis: ventriculo-arterial connection NOT documented by subcostal
-- sweep → missed D-TGA diagnosis risk is strictly positive.

structure VentriculoArterialConnectionGapAssumptions where
  connectionDocumented : Bool
  missedDiagnosisRisk : Nat
  gapFromUndocumentedConnection :
    connectionDocumented = false → 0 < missedDiagnosisRisk

theorem ventriculo_arterial_connection_gap_exists
    (a : VentriculoArterialConnectionGapAssumptions)
    (h : a.connectionDocumented = false) :
    0 < a.missedDiagnosisRisk :=
  a.gapFromUndocumentedConnection h

-- ── Theorem 2 ────────────────────────────────────────────────────────────────
-- Anti-thesis: atrial septal defect size NOT measured AND balloon atrial
-- septostomy candidacy NOT assessed → urgent intervention delay risk is
-- strictly positive.

structure ASDSizeBASCandidacyGapAssumptions where
  asdSizeMeasured : Bool
  basCandidacyAssessed : Bool
  interventionDelayRisk : Nat
  gapFromUnmeasuredASDAndCandidacy :
    asdSizeMeasured = false →
    basCandidacyAssessed = false →
    0 < interventionDelayRisk

theorem asd_size_bas_candidacy_gap_exists
    (a : ASDSizeBASCandidacyGapAssumptions)
    (hASD : a.asdSizeMeasured = false)
    (hBAS : a.basCandidacyAssessed = false) :
    0 < a.interventionDelayRisk :=
  a.gapFromUnmeasuredASDAndCandidacy hASD hBAS

-- ── Theorem 3 ────────────────────────────────────────────────────────────────
-- Anti-thesis: coronary artery anatomy NOT characterised prior to arterial
-- switch operation planning → surgical mortality risk is strictly positive.

structure CoronaryArteryAnatomyGapAssumptions where
  coronaryAnatomyCharacterised : Bool
  surgicalMortalityRisk : Nat
  gapFromUncharacterisedCoronary :
    coronaryAnatomyCharacterised = false → 0 < surgicalMortalityRisk

theorem coronary_artery_anatomy_gap_exists
    (a : CoronaryArteryAnatomyGapAssumptions)
    (h : a.coronaryAnatomyCharacterised = false) :
    0 < a.surgicalMortalityRisk :=
  a.gapFromUncharacterisedCoronary h

-- ── Theorem 4 ────────────────────────────────────────────────────────────────
-- Anti-thesis: ductal patency and direction of ductal shunt NOT confirmed by
-- colour Doppler → haemodynamic misclassification risk is strictly positive.

structure DuctalPatencyShuntDirectionGapAssumptions where
  ductalPatencyConfirmed : Bool
  shuntDirectionConfirmed : Bool
  misclassificationRisk : Nat
  gapFromUnconfirmedDuct :
    ductalPatencyConfirmed = false →
    shuntDirectionConfirmed = false →
    0 < misclassificationRisk

theorem ductal_patency_shunt_direction_gap_exists
    (a : DuctalPatencyShuntDirectionGapAssumptions)
    (hPatency : a.ductalPatencyConfirmed = false)
    (hShunt : a.shuntDirectionConfirmed = false) :
    0 < a.misclassificationRisk :=
  a.gapFromUnconfirmedDuct hPatency hShunt

-- ── Theorem 5 ────────────────────────────────────────────────────────────────
-- Anti-thesis: ventricular septal defect NOT excluded (subpulmonary or
-- perimembranous) AND surgical repair complexity NOT stratified → operative
-- planning gap is strictly positive.

structure VSDExclusionComplexityGapAssumptions where
  vsdExcluded : Bool
  repairComplexityStratified : Bool
  operativePlanningGap : Nat
  gapFromUnexcludedVSDAndUnstratified :
    vsdExcluded = false →
    repairComplexityStratified = false →
    0 < operativePlanningGap

theorem vsd_exclusion_complexity_gap_exists
    (a : VSDExclusionComplexityGapAssumptions)
    (hVSD : a.vsdExcluded = false)
    (hComplexity : a.repairComplexityStratified = false) :
    0 < a.operativePlanningGap :=
  a.gapFromUnexcludedVSDAndUnstratified hVSD hComplexity

end ForkRaceFoldTheorems
