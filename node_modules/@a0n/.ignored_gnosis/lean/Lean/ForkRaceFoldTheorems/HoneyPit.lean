namespace ForkRaceFoldTheorems
namespace HoneyPit

/-- A honey pit. -/
structure HoneyPit where
  capacity : Nat
  inhabitants : Nat
  drainSlots : Nat
  hCapacityPositive : 0 < capacity
  hInhabitantsLeCapacity : inhabitants <= capacity
  hDrainSlotsPositive : 0 < drainSlots

/-- Port penalty free server slots. -/
def serverSlotCount (pit : HoneyPit) : Nat :=
  pit.drainSlots

/-- A pool overflow graceful bounds check. -/
def canTrap (pit : HoneyPit) : Bool :=
  pit.inhabitants < pit.capacity

/-- Trap an inhabitant. -/
def trap (pit : HoneyPit) (h : pit.inhabitants < pit.capacity) : HoneyPit :=
  { capacity := pit.capacity,
    inhabitants := pit.inhabitants + 1,
    drainSlots := pit.drainSlots,
    hCapacityPositive := pit.hCapacityPositive,
    hInhabitantsLeCapacity := Nat.succ_le_of_lt h,
    hDrainSlotsPositive := pit.hDrainSlotsPositive }

/-- Server drain work. -/
def serverDrainWork (pit : HoneyPit) (ticks : Nat) : Nat :=
  pit.drainSlots * ticks

/-- Attacker wait linear lower bound. -/
def attackerWait (k : Nat) (iterateDepth : Nat) : Nat :=
  k * iterateDepth

end HoneyPit
end ForkRaceFoldTheorems
