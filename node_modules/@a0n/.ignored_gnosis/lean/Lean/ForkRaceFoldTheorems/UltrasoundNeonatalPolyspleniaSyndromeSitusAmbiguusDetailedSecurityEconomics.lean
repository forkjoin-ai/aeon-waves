/-!
# UltrasoundNeonatalPolyspleniaSyndromeSitusAmbiguusDetailedSecurityEconomics

Neonatal Polysplenia Syndrome (Left Isomerism / Bilateral Left-sidedness /
Situs Ambiguus with Polysplenia): multi-organ laterality defect associated
with bilateral left-sided structures, multiple small spleens, interruption
of the inferior vena cava with azygos continuation, and congenital heart
disease (AVSD, TAPVR, complete heart block). Five security-economics gap
theorems for clinical imaging gaps that constitute missed-diagnosis risk
with measurable medico-legal / readmission cost.

Anti-thesis pattern: structure posits the ABSENCE of an imaging assessment,
theorem derives strictly-positive risk. Zero sorry — all close by exact.
-/

namespace ForkRaceFoldTheorems

-- ── Theorem 1 ────────────────────────────────────────────────────────────────
-- Anti-thesis: IVC continuity NOT assessed AND azygos / hemiazygos
-- continuation NOT identified → missed IVC interruption / inappropriate
-- Glenn candidacy assessment risk is strictly positive.

structure PolysleniaIVCContinuityAzygosGapAssumptions where
  ivcContinuityAssessed : Bool
  azygousContinuationIdentified : Bool
  ivcInterruptionRisk : Nat
  gapFromUnassessedIVCAndAzygos :
    ivcContinuityAssessed = false →
    azygousContinuationIdentified = false →
    0 < ivcInterruptionRisk

theorem polysplenia_ivc_continuity_azygos_gap_exists
    (a : PolysleniaIVCContinuityAzygosGapAssumptions)
    (hIVC : a.ivcContinuityAssessed = false)
    (hAz : a.azygousContinuationIdentified = false) :
    0 < a.ivcInterruptionRisk :=
  a.gapFromUnassessedIVCAndAzygos hIVC hAz

-- ── Theorem 2 ────────────────────────────────────────────────────────────────
-- Anti-thesis: multiple splenic echoes NOT counted and polysplenia NOT
-- confirmed AND functional splenic capacity NOT assessed → under-
-- estimation of immune competence / over-treatment with prophylactic
-- antibiotics risk is strictly positive.

structure PolyspleniaSplenicCountFunctionGapAssumptions where
  splenicEchoesCounted : Bool
  splenicFunctionAssessed : Bool
  immuneCompetenceRisk : Nat
  gapFromUncountedSpleensAndFunction :
    splenicEchoesCounted = false →
    splenicFunctionAssessed = false →
    0 < immuneCompetenceRisk

theorem polysplenia_splenic_count_function_gap_exists
    (a : PolyspleniaSplenicCountFunctionGapAssumptions)
    (hSp : a.splenicEchoesCounted = false)
    (hFn : a.splenicFunctionAssessed = false) :
    0 < a.immuneCompetenceRisk :=
  a.gapFromUncountedSpleensAndFunction hSp hFn

-- ── Theorem 3 ────────────────────────────────────────────────────────────────
-- Anti-thesis: atrioventricular septal defect components NOT assessed AND
-- atrial morphology (left-atrial appendage isomerism) NOT confirmed →
-- incorrect AV valve repair planning / complete heart block risk is
-- strictly positive.

structure PolysleniaAVSDHeartBlockGapAssumptions where
  avsdComponentsAssessed : Bool
  atrialMorphologyConfirmed : Bool
  avRepairHeartBlockRisk : Nat
  gapFromUnassessedAVSDAndMorphology :
    avsdComponentsAssessed = false →
    atrialMorphologyConfirmed = false →
    0 < avRepairHeartBlockRisk

theorem polysplenia_avsd_heart_block_gap_exists
    (a : PolysleniaAVSDHeartBlockGapAssumptions)
    (hAV : a.avsdComponentsAssessed = false)
    (hMo : a.atrialMorphologyConfirmed = false) :
    0 < a.avRepairHeartBlockRisk :=
  a.gapFromUnassessedAVSDAndMorphology hAV hMo

-- ── Theorem 4 ────────────────────────────────────────────────────────────────
-- Anti-thesis: bilateral superior venae cavae NOT identified AND
-- pulmonary venous drainage NOT mapped → missed TAPVR / incorrect
-- systemic-venous cannulation strategy risk is strictly positive.

structure PolyspleniaBilateralSVCTAPVRGapAssumptions where
  bilateralSVCIdentified : Bool
  pulmonaryVenousDrainageMapped : Bool
  cannulationTAPVRRisk : Nat
  gapFromUnidentifiedSVCAndPVD :
    bilateralSVCIdentified = false →
    pulmonaryVenousDrainageMapped = false →
    0 < cannulationTAPVRRisk

theorem polysplenia_bilateral_svc_tapvr_gap_exists
    (a : PolyspleniaBilateralSVCTAPVRGapAssumptions)
    (hSVC : a.bilateralSVCIdentified = false)
    (hPV : a.pulmonaryVenousDrainageMapped = false) :
    0 < a.cannulationTAPVRRisk :=
  a.gapFromUnidentifiedSVCAndPVD hSVC hPV

-- ── Theorem 5 ────────────────────────────────────────────────────────────────
-- Anti-thesis: intestinal rotation NOT characterised AND biliary atresia
-- NOT excluded (liver size and echogenicity NOT assessed) → missed
-- simultaneous malrotation and biliary atresia / cascade surgical
-- morbidity risk is strictly positive.

structure PolyspleniaMalrotationBiliaryAtresiaGapAssumptions where
  intestinalRotationCharacterised : Bool
  biliaryAtresiaExcluded : Bool
  cascadeSurgicalMorbidityRisk : Nat
  gapFromUncharacterisedRotationAndBiliary :
    intestinalRotationCharacterised = false →
    biliaryAtresiaExcluded = false →
    0 < cascadeSurgicalMorbidityRisk

theorem polysplenia_malrotation_biliary_atresia_gap_exists
    (a : PolyspleniaMalrotationBiliaryAtresiaGapAssumptions)
    (hRot : a.intestinalRotationCharacterised = false)
    (hBil : a.biliaryAtresiaExcluded = false) :
    0 < a.cascadeSurgicalMorbidityRisk :=
  a.gapFromUncharacterisedRotationAndBiliary hRot hBil

end ForkRaceFoldTheorems
