namespace ForkRaceFoldTheorems

structure NeonatalMeningitisSubduralCollectionGapAssumptions where
  subduralCollectionCharacterised : Bool
  subduralDrainageRisk : Nat
  gapFromUncharacterisedSubdural : subduralCollectionCharacterised = false → 0 < subduralDrainageRisk

theorem neonatal_meningitis_subdural_collection_gap_exists (a : NeonatalMeningitisSubduralCollectionGapAssumptions)
    (h : a.subduralCollectionCharacterised = false) : 0 < a.subduralDrainageRisk :=
  a.gapFromUncharacterisedSubdural h

structure NeonatalMeningitisCorticalDiffusionGapAssumptions where
  corticalDiffusionRestrictionMapped : Bool
  infarctRiskStratified : Bool
  delayedInfarctRecognitionRisk : Nat
  gapFromUnmappedDiffusion : corticalDiffusionRestrictionMapped = false → infarctRiskStratified = false → 0 < delayedInfarctRecognitionRisk

theorem neonatal_meningitis_cortical_diffusion_gap_exists (a : NeonatalMeningitisCorticalDiffusionGapAssumptions)
    (hDiff : a.corticalDiffusionRestrictionMapped = false) (hRisk : a.infarctRiskStratified = false) : 0 < a.delayedInfarctRecognitionRisk :=
  a.gapFromUnmappedDiffusion hDiff hRisk

structure NeonatalMeningitisVasculitisDopplerGapAssumptions where
  cerebralVasculitisDopplerAssessed : Bool
  vasculopathyDetectionEnabled : Bool
  missedVasculopathyRisk : Nat
  gapFromMissingDopplerAssessment : cerebralVasculitisDopplerAssessed = false → vasculopathyDetectionEnabled = false → 0 < missedVasculopathyRisk

theorem neonatal_meningitis_vasculitis_doppler_gap_exists (a : NeonatalMeningitisVasculitisDopplerGapAssumptions)
    (hDop : a.cerebralVasculitisDopplerAssessed = false) (hVasc : a.vasculopathyDetectionEnabled = false) : 0 < a.missedVasculopathyRisk :=
  a.gapFromMissingDopplerAssessment hDop hVasc

structure NeonatalMeningitisAbscessDifferentiationGapAssumptions where
  abscessEmpyemaDifferentiated : Bool
  neurosurgicalReferralTriggered : Bool
  delayedDrainageRisk : Nat
  gapFromUndifferentiatedAbscess : abscessEmpyemaDifferentiated = false → neurosurgicalReferralTriggered = false → 0 < delayedDrainageRisk

theorem neonatal_meningitis_abscess_differentiation_gap_exists (a : NeonatalMeningitisAbscessDifferentiationGapAssumptions)
    (hAbs : a.abscessEmpyemaDifferentiated = false) (hRef : a.neurosurgicalReferralTriggered = false) : 0 < a.delayedDrainageRisk :=
  a.gapFromUndifferentiatedAbscess hAbs hRef

structure NeonatalMeningitisNeurodevelopmentalFollowUpGapAssumptions where
  neurodevelopmentalFollowUpScheduled : Bool
  hearingScreeningCompleted : Bool
  longTermOutcomeGap : Nat
  gapFromMissingFollowUp : neurodevelopmentalFollowUpScheduled = false → hearingScreeningCompleted = false → 0 < longTermOutcomeGap

theorem neonatal_meningitis_neurodevelopmental_follow_up_gap_exists (a : NeonatalMeningitisNeurodevelopmentalFollowUpGapAssumptions)
    (hFU : a.neurodevelopmentalFollowUpScheduled = false) (hHear : a.hearingScreeningCompleted = false) : 0 < a.longTermOutcomeGap :=
  a.gapFromMissingFollowUp hFU hHear

end ForkRaceFoldTheorems
