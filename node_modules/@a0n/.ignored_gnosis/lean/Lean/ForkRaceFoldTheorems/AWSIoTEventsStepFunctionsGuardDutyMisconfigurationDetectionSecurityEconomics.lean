/-!
# AWSIoTEventsStepFunctionsGuardDutyMisconfigurationDetectionSecurityEconomics

Anti-thesis: AWS IoT Events + Step Functions integrated with Amazon GuardDuty
reliably detects threat-detection misconfigurations by validating finding
encryption/archival controls, enforcing SCP/Config detector-disable prevention,
scoping detector IAM, alarming on HIGH-severity finding anomalies, and
correlating X-Ray/CloudTrail events. Management decisions based on these controls
are operationally sound.

Refutation: each failure mode below proves that the ABSENCE of a systematic
control implies a strictly positive security and economic risk.
Zero sorry — all theorems close by exact.
-/

namespace ForkRaceFoldTheorems

-- ── Theorem 1 ────────────────────────────────────────────────────────────────
-- Anti-thesis: GuardDuty findings exported to S3 are NOT encrypted with a
-- customer-managed KMS key AND automatic archival rules are NOT configured →
-- finding integrity risk is strictly positive.

structure GuardDutyFindingsCMKArchivalGapAssumptions where
  findingsEncryptedWithCMK : Bool
  archivalRulesConfigured : Bool
  findingIntegrityRisk : Nat
  gapFromMissingCMKAndArchival :
    findingsEncryptedWithCMK = false →
    archivalRulesConfigured = false →
    0 < findingIntegrityRisk

theorem guardduty_findings_cmk_archival_gap_exists
    (a : GuardDutyFindingsCMKArchivalGapAssumptions)
    (hCMK : a.findingsEncryptedWithCMK = false)
    (hArchival : a.archivalRulesConfigured = false) :
    0 < a.findingIntegrityRisk :=
  a.gapFromMissingCMKAndArchival hCMK hArchival

-- ── Theorem 2 ────────────────────────────────────────────────────────────────
-- Anti-thesis: no SCP prevents disabling GuardDuty detectors AND no AWS Config
-- rule enforces GuardDuty detector enablement → detector suppression risk is
-- strictly positive.

structure GuardDutySCPConfigDetectorDisableGapAssumptions where
  scpBlocksDetectorDisable : Bool
  configRuleEnforcesDetector : Bool
  detectorSuppressionRisk : Nat
  gapFromMissingSCPAndConfig :
    scpBlocksDetectorDisable = false →
    configRuleEnforcesDetector = false →
    0 < detectorSuppressionRisk

theorem guardduty_scp_config_detector_disable_gap_exists
    (a : GuardDutySCPConfigDetectorDisableGapAssumptions)
    (hSCP : a.scpBlocksDetectorDisable = false)
    (hConfig : a.configRuleEnforcesDetector = false) :
    0 < a.detectorSuppressionRisk :=
  a.gapFromMissingSCPAndConfig hSCP hConfig

-- ── Theorem 3 ────────────────────────────────────────────────────────────────
-- Anti-thesis: IAM permissions for GuardDuty detector administrative actions are
-- NOT scoped to the specific detector ARN → privilege escalation risk is strictly
-- positive.

structure GuardDutyDetectorIAMScopeGapAssumptions where
  iamScopedToDetector : Bool
  privilegeEscalationRisk : Nat
  gapFromUnscopedIAM : iamScopedToDetector = false → 0 < privilegeEscalationRisk

theorem guardduty_detector_iam_scope_gap_exists
    (a : GuardDutyDetectorIAMScopeGapAssumptions)
    (h : a.iamScopedToDetector = false) :
    0 < a.privilegeEscalationRisk :=
  a.gapFromUnscopedIAM h

-- ── Theorem 4 ────────────────────────────────────────────────────────────────
-- Anti-thesis: no CloudWatch alarm fires on GuardDuty HIGH-severity finding
-- rate anomaly AND the SOC has no runbook for threat escalation response →
-- SOC gap is strictly positive.

structure GuardDutyHighSeverityAlarmSOCGapAssumptions where
  highSeverityAlarmConfigured : Bool
  socRunbookExists : Bool
  socGap : Nat
  gapFromMissingAlarmAndRunbook :
    highSeverityAlarmConfigured = false →
    socRunbookExists = false →
    0 < socGap

theorem guardduty_high_severity_alarm_soc_gap_exists
    (a : GuardDutyHighSeverityAlarmSOCGapAssumptions)
    (hAlarm : a.highSeverityAlarmConfigured = false)
    (hRunbook : a.socRunbookExists = false) :
    0 < a.socGap :=
  a.gapFromMissingAlarmAndRunbook hAlarm hRunbook

-- ── Theorem 5 ────────────────────────────────────────────────────────────────
-- Anti-thesis: AWS X-Ray tracing is NOT correlated with CloudTrail GuardDuty
-- API events AND GuardDuty finding event forwarding to Security Hub is NOT
-- enabled → observability gap is strictly positive.

structure GuardDutyXRayCloudTrailCorrelationGapAssumptions where
  xRayCloudTrailCorrelated : Bool
  securityHubForwardingEnabled : Bool
  observabilityGap : Nat
  gapFromMissingXRayAndSecurityHub :
    xRayCloudTrailCorrelated = false →
    securityHubForwardingEnabled = false →
    0 < observabilityGap

theorem guardduty_xray_cloudtrail_correlation_gap_exists
    (a : GuardDutyXRayCloudTrailCorrelationGapAssumptions)
    (hXRay : a.xRayCloudTrailCorrelated = false)
    (hSecHub : a.securityHubForwardingEnabled = false) :
    0 < a.observabilityGap :=
  a.gapFromMissingXRayAndSecurityHub hXRay hSecHub

end ForkRaceFoldTheorems
