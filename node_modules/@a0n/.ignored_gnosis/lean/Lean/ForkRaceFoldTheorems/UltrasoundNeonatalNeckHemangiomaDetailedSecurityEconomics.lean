structure NeckHemangiomaAirwayCompressionGapAssumptions where
  airwayCompressionAssessed : Bool
  oropharyngealDisplacementDocumented : Bool
  airwayEmergencyRisk : Nat
  gapFromMissingAirwayAndOropharyngeal :
