-- ── Theorem 5 ────────────────────────────────────────────────────────────────
-- Anti-thesis: propranolol initiation is NOT coordinated with cardiac baseline
-- assessment AND MDT referral (dermatology, vascular surgery, ENT) is NOT
-- documented → treatment-complication risk is strictly positive.

structure NeckHemangiomaPropranolelMDTReferralGapAssumptions where
  cardiacBaselineAssessed : Bool
  mdtReferralDocumented : Bool
  treatmentComplicationRisk : Nat
  gapFromMissingCardiacAndMDT :
    cardiacBaselineAssessed = false →
    mdtReferralDocumented = false →
    0 < treatmentComplicationRisk

theorem neck_hemangioma_propranolol_mdt_referral_gap_exists
