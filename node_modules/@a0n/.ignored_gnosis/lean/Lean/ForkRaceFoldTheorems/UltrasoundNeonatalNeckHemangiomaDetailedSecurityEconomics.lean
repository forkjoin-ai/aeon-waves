/-!
# UltrasoundNeonatalNeckHemangiomaDetailedSecurityEconomics

Anti-thesis: neonatal/fetal ultrasound reliably characterizes neck hemangioma
by classifying subtype (infantile vs. congenital RICH/NICH), measuring lesion
dimensions and depth, assessing Doppler flow pattern and arterial feeder
calibre, evaluating airway compression and oropharyngeal displacement, and
coordinating propranolol initiation and MDT referral. Management decisions
based on these assessments are clinically sound.

Refutation: each failure mode below proves that the ABSENCE of a systematic
assessment control implies a strictly positive clinical and economic risk.
Zero sorry — all theorems close by exact.
-/

namespace ForkRaceFoldTheorems

-- ── Theorem 1 ────────────────────────────────────────────────────────────────
-- Anti-thesis: hemangioma subtype (infantile IH vs. congenital RICH/NICH) is
-- NOT classified AND lesion depth relative to airway is NOT documented →
-- management-pathway confusion risk is strictly positive.

structure NeckHemangiomaSubtypeDepthGapAssumptions where
  subtypeClassified : Bool
  depthDocumented : Bool
  managementPathwayRisk : Nat
  gapFromMissingSubtypeAndDepth :
    subtypeClassified = false →
    depthDocumented = false →
    0 < managementPathwayRisk

theorem neck_hemangioma_subtype_depth_gap_exists
    (a : NeckHemangiomaSubtypeDepthGapAssumptions)
    (hSubtype : a.subtypeClassified = false)
    (hDepth : a.depthDocumented = false) :
    0 < a.managementPathwayRisk :=
  a.gapFromMissingSubtypeAndDepth hSubtype hDepth

-- ── Theorem 2 ────────────────────────────────────────────────────────────────
-- Anti-thesis: lesion dimensions (three-plane measurement: AP, transverse,
-- craniocaudal) are NOT measured AND proliferation phase is NOT characterised
-- by high-flow Doppler signal → propranolol dosing baseline risk is strictly
-- positive.

structure NeckHemangiomaVolumeDopplerGapAssumptions where
  dimensionsMeasured : Bool
  highFlowDopplerCharacterised : Bool
  propranololDosingRisk : Nat
  gapFromMissingVolumeAndDoppler :
    dimensionsMeasured = false →
    highFlowDopplerCharacterised = false →
    0 < propranololDosingRisk

theorem neck_hemangioma_volume_doppler_gap_exists
    (a : NeckHemangiomaVolumeDopplerGapAssumptions)
    (hDimensions : a.dimensionsMeasured = false)
    (hDoppler : a.highFlowDopplerCharacterised = false) :
    0 < a.propranololDosingRisk :=
  a.gapFromMissingVolumeAndDoppler hDimensions hDoppler

-- ── Theorem 3 ────────────────────────────────────────────────────────────────
-- Anti-thesis: arterial feeder calibre and peak systolic velocity are NOT
