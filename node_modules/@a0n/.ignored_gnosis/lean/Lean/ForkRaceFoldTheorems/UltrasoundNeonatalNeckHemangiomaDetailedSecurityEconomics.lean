theorem neck_hemangioma_feeder_venous_drainage_gap_exists
    (a : NeckHemangiomaFeederVenousDrainageGapAssumptions)
    (hFeeder : a.feederCalibremeasured = false)
    (hDrainage : a.venousDrainageDocumented = false) :
