/-!
# AWSIoTEventsStepFunctionsEKSNodegroupUpdateConfigMisconfigurationDetectionSecurityEconomics

EKS managed node-group UpdateConfig misconfiguration scanner. Five
security-economics gap theorems: each proves that the ABSENCE of a control
on the UpdateConfig surface creates a measurable compliance or attack-surface
cost.

Anti-thesis pattern: structure posits the ABSENCE of a control, theorem
derives strictly-positive gap. Zero sorry — all close by exact.
-/

namespace ForkRaceFoldTheorems

-- ── Theorem 1 ────────────────────────────────────────────────────────────────
-- Anti-thesis: EBS volumes launched during an UpdateConfig rolling upgrade are
-- NOT encrypted with a customer-managed KMS key → compliance gap is strictly
-- positive.

structure UpdateConfigEBSCMKGapAssumptions where
  ebsVolumesEncryptedWithCMK : Bool
  complianceGap : Nat
  gapFromMissingCMK : ebsVolumesEncryptedWithCMK = false → 0 < complianceGap

theorem update_config_ebs_cmk_gap_exists
    (a : UpdateConfigEBSCMKGapAssumptions)
    (h : a.ebsVolumesEncryptedWithCMK = false) :
    0 < a.complianceGap :=
  a.gapFromMissingCMK h

-- ── Theorem 2 ────────────────────────────────────────────────────────────────
-- Anti-thesis: UpdateConfig maxUnavailable is not bounded to a safe percentage
-- AND the nodegroup spans multiple AZs → surge-capacity disruption risk is
-- strictly positive.

structure UpdateConfigMaxUnavailableScopeGapAssumptions where
  maxUnavailableBounded : Bool
  multiAZNodegroup : Bool
  surgeDisruptionRisk : Nat
  gapFromUnboundedMaxUnavailable :
    maxUnavailableBounded = false →
    multiAZNodegroup = true →
    0 < surgeDisruptionRisk

theorem update_config_max_unavailable_scope_gap_exists
    (a : UpdateConfigMaxUnavailableScopeGapAssumptions)
    (hBound : a.maxUnavailableBounded = false)
    (hMultiAZ : a.multiAZNodegroup = true) :
    0 < a.surgeDisruptionRisk :=
  a.gapFromUnboundedMaxUnavailable hBound hMultiAZ

-- ── Theorem 3 ────────────────────────────────────────────────────────────────
-- Anti-thesis: the IAM role permitted to invoke eks:UpdateNodegroupConfig is
-- NOT scoped to the specific nodegroup ARN → privilege escalation risk is
-- strictly positive.

structure UpdateConfigIAMRoleScopeGapAssumptions where
  iamRoleScopedToNodegroup : Bool
  privilegeEscalationRisk : Nat
  gapFromUnscopedRole : iamRoleScopedToNodegroup = false → 0 < privilegeEscalationRisk

theorem update_config_iam_role_scope_gap_exists
    (a : UpdateConfigIAMRoleScopeGapAssumptions)
    (h : a.iamRoleScopedToNodegroup = false) :
    0 < a.privilegeEscalationRisk :=
  a.gapFromUnscopedRole h

-- ── Theorem 4 ────────────────────────────────────────────────────────────────
-- Anti-thesis: no CloudWatch alarm is configured on UpdateConfig API calls
-- AND the SOC has no on-call procedure for unexpected nodegroup updates →
-- SOC blind-spot risk is strictly positive.

structure UpdateConfigCloudWatchAlarmSOCGapAssumptions where
  cloudWatchAlarmOnUpdateConfig : Bool
  socProcedureForUnexpectedUpdates : Bool
  socBlindSpotRisk : Nat
  gapFromMissingAlarmAndProcedure :
    cloudWatchAlarmOnUpdateConfig = false →
    socProcedureForUnexpectedUpdates = false →
    0 < socBlindSpotRisk

theorem update_config_cloudwatch_alarm_soc_gap_exists
    (a : UpdateConfigCloudWatchAlarmSOCGapAssumptions)
    (hAlarm : a.cloudWatchAlarmOnUpdateConfig = false)
    (hProc : a.socProcedureForUnexpectedUpdates = false) :
    0 < a.socBlindSpotRisk :=
  a.gapFromMissingAlarmAndProcedure hAlarm hProc

-- ── Theorem 5 ────────────────────────────────────────────────────────────────
-- Anti-thesis: AWS X-Ray active tracing is NOT enabled on the Step Functions
-- state machine that triggers UpdateConfig AND invocation traces are not
-- stored → observability gap is strictly positive.

structure UpdateConfigXRayGapAssumptions where
  xRayTracingOnStateMachine : Bool
  invocationTracesStored : Bool
  observabilityGap : Nat
  gapFromMissingXRay :
    xRayTracingOnStateMachine = false →
    invocationTracesStored = false →
    0 < observabilityGap

theorem update_config_xray_gap_exists
    (a : UpdateConfigXRayGapAssumptions)
    (hXRay : a.xRayTracingOnStateMachine = false)
    (hTraces : a.invocationTracesStored = false) :
    0 < a.observabilityGap :=
  a.gapFromMissingXRay hXRay hTraces

end ForkRaceFoldTheorems
