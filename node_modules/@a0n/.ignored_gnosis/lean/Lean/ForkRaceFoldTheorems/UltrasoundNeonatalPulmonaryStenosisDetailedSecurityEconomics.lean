/-!
# UltrasoundNeonatalPulmonaryStenosisDetailedSecurityEconomics

Neonatal pulmonary stenosis (PS): obstruction at the pulmonary valve level
ranging from mild valvular PS to critical PS with duct-dependent pulmonary
circulation. Five security-economics gap theorems for clinical imaging gaps
that constitute missed-diagnosis risk — each with measurable economic
(medico-legal / readmission) cost.

Anti-thesis pattern: structure posits the ABSENCE of an imaging assessment,
theorem derives strictly-positive risk. Zero sorry — all close by exact.
-/

namespace ForkRaceFoldTheorems

-- ── Theorem 1 ────────────────────────────────────────────────────────────────
-- Anti-thesis: pulmonary valve peak instantaneous gradient NOT measured by
-- continuous-wave Doppler AND right ventricular systolic pressure NOT
-- estimated → incorrect severity classification risk is strictly positive.

structure PulmonaryValveGradientRVPressureGapAssumptions where
  peakGradientMeasured : Bool
  rvSystolicPressureEstimated : Bool
  severityClassificationRisk : Nat
  gapFromUnmeasuredGradientAndPressure :
    peakGradientMeasured = false →
    rvSystolicPressureEstimated = false →
    0 < severityClassificationRisk

theorem pulmonary_valve_gradient_rv_pressure_gap_exists
    (a : PulmonaryValveGradientRVPressureGapAssumptions)
    (hGrad : a.peakGradientMeasured = false)
    (hPressure : a.rvSystolicPressureEstimated = false) :
    0 < a.severityClassificationRisk :=
  a.gapFromUnmeasuredGradientAndPressure hGrad hPressure

-- ── Theorem 2 ────────────────────────────────────────────────────────────────
-- Anti-thesis: valve morphology NOT characterised (unicuspid / bicuspid /
-- tricuspid) AND post-stenotic main pulmonary artery dilation NOT measured →
-- inappropriate catheter-intervention planning risk is strictly positive.

structure PulmonaryValveMorphologyDilationGapAssumptions where
  valveMorphologyCharacterised : Bool
  poststenovticDilationMeasured : Bool
  interventionPlanningRisk : Nat
  gapFromUncharacterisedMorphologyAndDilation :
    valveMorphologyCharacterised = false →
    poststenovticDilationMeasured = false →
    0 < interventionPlanningRisk

theorem pulmonary_valve_morphology_dilation_gap_exists
    (a : PulmonaryValveMorphologyDilationGapAssumptions)
    (hMorph : a.valveMorphologyCharacterised = false)
    (hDil : a.poststenovticDilationMeasured = false) :
    0 < a.interventionPlanningRisk :=
  a.gapFromUncharacterisedMorphologyAndDilation hMorph hDil

-- ── Theorem 3 ────────────────────────────────────────────────────────────────
-- Anti-thesis: right ventricular hypertrophy severity NOT graded AND
-- tricuspid regurgitation jet velocity NOT measured → RV failure prediction
-- gap is strictly positive.

structure RVHypertrophyTricuspidRegurgitationGapAssumptions where
  rvhGraded : Bool
  trJetVelocityMeasured : Bool
  rvFailurePredictionRisk : Nat
  gapFromUngradedHypertrophyAndTR :
    rvhGraded = false →
    trJetVelocityMeasured = false →
    0 < rvFailurePredictionRisk

theorem rv_hypertrophy_tricuspid_regurgitation_gap_exists
    (a : RVHypertrophyTricuspidRegurgitationGapAssumptions)
    (hRVH : a.rvhGraded = false)
    (hTR : a.trJetVelocityMeasured = false) :
    0 < a.rvFailurePredictionRisk :=
  a.gapFromUngradedHypertrophyAndTR hRVH hTR

-- ── Theorem 4 ────────────────────────────────────────────────────────────────
-- Anti-thesis: ductal dependency for pulmonary blood flow NOT assessed AND
-- prostaglandin requirement NOT determined in critical PS → preventable
-- haemodynamic collapse risk is strictly positive.

structure DuctalDependencyPGE1GapAssumptions where
  ductalDependencyAssessed : Bool
  pge1RequirementDetermined : Bool
  haemodynamicCollapseRisk : Nat
  gapFromUnassessedDuctalDependencyAndPGE1 :
    ductalDependencyAssessed = false →
    pge1RequirementDetermined = false →
    0 < haemodynamicCollapseRisk

theorem ductal_dependency_pge1_gap_exists
    (a : DuctalDependencyPGE1GapAssumptions)
    (hDuctal : a.ductalDependencyAssessed = false)
    (hPGE1 : a.pge1RequirementDetermined = false) :
    0 < a.haemodynamicCollapseRisk :=
  a.gapFromUnassessedDuctalDependencyAndPGE1 hDuctal hPGE1

-- ── Theorem 5 ────────────────────────────────────────────────────────────────
-- Anti-thesis: infundibular (subvalvular) obstruction NOT excluded AND
-- pulmonary annulus Z-score NOT calculated → underestimation of total
-- outflow-tract obstruction risk is strictly positive.

structure InfundibularObstructionAnnulusZScoreGapAssumptions where
  infundibularObstructionExcluded : Bool
  annulusZScoreCalculated : Bool
  outflowTractUnderestimationRisk : Nat
  gapFromUnexcludedInfundibularAndZScore :
    infundibularObstructionExcluded = false →
    annulusZScoreCalculated = false →
    0 < outflowTractUnderestimationRisk

theorem infundibular_obstruction_annulus_zscore_gap_exists
    (a : InfundibularObstructionAnnulusZScoreGapAssumptions)
    (hInfund : a.infundibularObstructionExcluded = false)
    (hZScore : a.annulusZScoreCalculated = false) :
    0 < a.outflowTractUnderestimationRisk :=
  a.gapFromUnexcludedInfundibularAndZScore hInfund hZScore

end ForkRaceFoldTheorems
