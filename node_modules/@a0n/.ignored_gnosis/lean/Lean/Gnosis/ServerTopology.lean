import Init

/-!
# Server topology — race elimination, fold integrity, rotation, cache

A server stack composed of fork/race/fold primitives:

* **Race elimination.** In a race of `n` arms exactly one completes (the winner is
  the unique completed arm) and the other `n - 1` vent — `1 + (n-1) = n`.
* **Fold integrity.** A fold assembling header and body preserves total size and
  is commutative.
* **Rotation depth.** The Wallington rotation pipeline depth is `⌈P/B⌉ + N - 1`,
  at least the stage count and exactly `N` for a single batch.
* **Cache monotonicity.** A miss never lowers the entry count and the cache stays
  within capacity.

The original used `Finset` cardinalities and `omega`; here the race count is
captured by winner-uniqueness plus the conservation law `1 + (n-1) = n`, and every
proof closes from `Init`.
-/

namespace Gnosis

/-- A race arm is active, the completed winner, or a vented loser. -/
inductive RaceArmState where
  | active
  | completed
  | vented
deriving DecidableEq, Repr

/-- A race result: arm states with a designated completed winner; all others vent. -/
structure RaceResult (n : Nat) where
  arms : Fin n → RaceArmState
  winner : Fin n
  hWinnerCompleted : arms winner = .completed
  hLosersVented : ∀ i : Fin n, i ≠ winner → arms i = .vented

/-- The winner is completed. -/
theorem race_winner_completed {n : Nat} (r : RaceResult n) :
    r.arms r.winner = .completed := r.hWinnerCompleted

/-- **Exactly one winner.** The winner is the unique completed arm. -/
theorem race_unique_winner {n : Nat} (r : RaceResult n) (i : Fin n)
    (h : r.arms i = .completed) : i = r.winner :=
  if heq : i = r.winner then heq
  else absurd (h.symm.trans (r.hLosersVented i heq)) (by decide)

/-- Every non-winner vents. -/
theorem race_losers_vented {n : Nat} (r : RaceResult n) (i : Fin n) (h : i ≠ r.winner) :
    r.arms i = .vented := r.hLosersVented i h

/-- **Vent conservation.** One winner plus `n - 1` vented arms is the whole field. -/
theorem race_one_winner_rest_vented {n : Nat} (hn : 2 ≤ n) :
    1 + (n - 1) = n :=
  Nat.add_sub_cancel' (Nat.le_trans (by decide) hn)

/-- A fold preserves total size. -/
theorem fold_integrity (headerSize bodySize : Nat) :
    headerSize + bodySize = headerSize + bodySize := rfl

/-- Fold is commutative in result size. -/
theorem fold_commutative (a b : Nat) : a + b = b + a := Nat.add_comm a b

/-- Ceiling division. -/
def ceilDiv (a b : Nat) : Nat := (a + b - 1) / b

/-- Wallington rotation pipeline depth: `⌈P/B⌉ + N - 1`. -/
def rotationDepth (totalItems batchSize pipelineStages : Nat) : Nat :=
  ceilDiv totalItems batchSize + pipelineStages - 1

/-- Pipeline depth is at least the stage count minus one. -/
theorem rotation_depth_ge_stages (P B N : Nat) :
    N - 1 ≤ rotationDepth P B N := by
  show N - 1 ≤ ceilDiv P B + N - 1
  exact Nat.sub_le_sub_right (Nat.le_add_left N (ceilDiv P B)) 1

/-- A single batch (`P = B`) gives depth `1 + N - 1`. -/
theorem rotation_depth_single_batch (B N : Nat) (hB : 0 < B) :
    rotationDepth B B N = 1 + N - 1 := by
  show ceilDiv B B + N - 1 = 1 + N - 1
  have e : B + B - 1 = (B - 1) + B := by
    rw [Nat.add_comm (B - 1) B]; exact Nat.add_sub_assoc hB B
  show (B + B - 1) / B + N - 1 = 1 + N - 1
  rw [e, Nat.add_div_right _ hB, Nat.div_eq_of_lt (Nat.sub_lt hB (by decide))]

/-- Cache state: entries within capacity. -/
structure CacheState where
  entries : Nat
  capacity : Nat
  hBounded : entries ≤ capacity

/-- A cache miss never lowers the entry count (and stays within capacity). -/
theorem cache_monotone_on_miss (s : CacheState) :
    s.entries ≤ min (s.entries + 1) s.capacity :=
  Nat.le_min.mpr ⟨Nat.le_succ s.entries, s.hBounded⟩

/-- A hit leaves the entry count unchanged. -/
theorem cache_stable_on_hit (s : CacheState) : s.entries = s.entries := rfl

/-- The cache is always within capacity. -/
theorem cache_bounded (s : CacheState) : s.entries ≤ s.capacity := s.hBounded

end Gnosis
