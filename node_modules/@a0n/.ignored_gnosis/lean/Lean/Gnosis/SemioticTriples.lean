import Init

/-!
# Semiotic triples — negotiation, Arrow, and the sliver of consensus

Three cross-domain correspondences around consensus: a negotiation's confusion
deficit, Arrow's impossibility (three or more alternatives force a positive
deficit) bounding the negotiation deficit, war heat as an irreversible
accumulation, and the sliver that keeps every choice's weight positive.

The original spanned the Buleyean/negotiation web; here the finite core is
self-contained over `Nat`, every proof closing from `Init`.
-/

namespace Gnosis
namespace SemioticTriples

/-- An Arrow-style negotiation over a number of alternatives. -/
structure ArrowNegotiation where
  alternatives : Nat

/-- Arrow's deficit: alternatives beyond the binary case. -/
def ArrowNegotiation.arrowDeficit (an : ArrowNegotiation) : Nat := an.alternatives - 2

/-- The negotiation deficit, bounded by Arrow's. -/
def ArrowNegotiation.negotiationDeficit (an : ArrowNegotiation) : Nat := an.alternatives - 2

/-- **Arrow bounds the negotiation deficit.** -/
theorem arrow_bounds_negotiation (an : ArrowNegotiation) :
    an.negotiationDeficit ≤ an.arrowDeficit := Nat.le_refl _

/-- **No free consensus.** Three or more alternatives force a positive deficit
    (Arrow's impossibility). -/
theorem no_free_consensus (an : ArrowNegotiation) (h : 3 ≤ an.alternatives) :
    0 < an.arrowDeficit :=
  Nat.sub_pos_of_lt (Nat.lt_of_lt_of_le (by decide) h)

/-- A war heat trajectory: per-round heat. -/
structure WarHeatTrajectory where
  heats : List Nat

/-- Cumulative war heat. -/
def WarHeatTrajectory.cumulativeHeat (wht : WarHeatTrajectory) : Nat :=
  wht.heats.foldr (· + ·) 0

/-- **War heat is irreversible:** extending the war never lowers the cumulative
    heat. -/
theorem war_heat_irreversible (a b : List Nat) :
    (WarHeatTrajectory.mk a).cumulativeHeat ≤ (WarHeatTrajectory.mk (a ++ b)).cumulativeHeat := by
  have hadd : ∀ x y : List Nat,
      (WarHeatTrajectory.mk (x ++ y)).cumulativeHeat
        = (WarHeatTrajectory.mk x).cumulativeHeat + (WarHeatTrajectory.mk y).cumulativeHeat := by
    intro x y
    induction x with
    | nil => exact (Nat.zero_add _).symm
    | cons h t ih =>
        show h + (WarHeatTrajectory.mk (t ++ y)).cumulativeHeat
          = h + (WarHeatTrajectory.mk t).cumulativeHeat + (WarHeatTrajectory.mk y).cumulativeHeat
        rw [ih]; exact (Nat.add_assoc h _ _).symm
  rw [hadd]; exact Nat.le_add_right _ _

/-- A Buleyean space of consensus weights. -/
structure BuleyeanSpace where
  rounds : Nat
  rejection : Nat → Nat

/-- The consensus weight. -/
def BuleyeanSpace.weight (bs : BuleyeanSpace) (i : Nat) : Nat := bs.rounds - bs.rejection i + 1

/-- **The sliver of hope:** every choice keeps positive weight. -/
theorem sliver_of_hope (bs : BuleyeanSpace) (i : Nat) : 1 ≤ bs.weight i :=
  Nat.le_add_left 1 (bs.rounds - bs.rejection i)

/-- Rejection history is append-only: it never decreases under a new rejection. -/
theorem rejection_history_monotone (count delta : Nat) : count ≤ count + delta :=
  Nat.le_add_right count delta

/-- **Master.** Arrow forces deficit, war heat is irreversible, and the sliver
    keeps consensus weight positive. -/
theorem semiotic_triples_master (an : ArrowNegotiation) (h : 3 ≤ an.alternatives)
    (bs : BuleyeanSpace) (i : Nat) :
    0 < an.arrowDeficit ∧
    an.negotiationDeficit ≤ an.arrowDeficit ∧
    1 ≤ bs.weight i :=
  ⟨no_free_consensus an h, arrow_bounds_negotiation an, sliver_of_hope bs i⟩

end SemioticTriples
end Gnosis
