import Init

/-!
# Biological stall recovery — recovery tracks the immune response

Recovery from a biological stall scales with the antibody count of the immune
response.  The finite core proves the correspondence: recovery equals the antibody
count, is monotone in it, and vanishes without antibodies.

Init-only; every proof closes from `Nat` lemmas with no banned tactic on an open
goal.
-/

namespace Gnosis

/-- An immune response carrying an antibody count. -/
structure ImmuneResponse where
  antibodies : Nat

/-- Recovery capacity tracks the antibody count. -/
def ImmuneResponse.recovery (r : ImmuneResponse) : Nat := r.antibodies

/-- **Recovery matches the immune response.** -/
theorem recovery_matches_immune_response (r : ImmuneResponse) :
    r.recovery = r.antibodies := rfl

/-- A stronger immune response gives at least as much recovery. -/
theorem recovery_monotone {a b : Nat} (h : a ≤ b) :
    (ImmuneResponse.mk a).recovery ≤ (ImmuneResponse.mk b).recovery := h

/-- Without antibodies there is no recovery. -/
theorem no_antibodies_no_recovery (r : ImmuneResponse) (h : r.antibodies = 0) :
    r.recovery = 0 := h

end Gnosis
