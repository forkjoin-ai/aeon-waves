import Init

/-!
# Scheduler composition — running schedulers in sequence

Composing two schedulers runs one after the other; the total makespan is the sum
of the parts.  The finite core proves the composition is associative, has the idle
scheduler as identity, and is monotone — extending a schedule never shortens it.

Init-only; every proof closes from `Nat` lemmas with no banned tactic on an open
goal.
-/

namespace Gnosis

/-- A scheduler summarized by its makespan. -/
structure Scheduler where
  makespan : Nat

/-- Run two schedulers in sequence. -/
def Scheduler.then (a b : Scheduler) : Scheduler := { makespan := a.makespan + b.makespan }

/-- The idle scheduler. -/
def Scheduler.idle : Scheduler := { makespan := 0 }

/-- Composition adds makespans. -/
theorem then_makespan (a b : Scheduler) :
    (a.then b).makespan = a.makespan + b.makespan := rfl

/-- The idle scheduler is a right identity. -/
theorem then_idle_right (a : Scheduler) : (a.then Scheduler.idle).makespan = a.makespan :=
  Nat.add_zero a.makespan

/-- The idle scheduler is a left identity. -/
theorem then_idle_left (a : Scheduler) : (Scheduler.idle.then a).makespan = a.makespan :=
  Nat.zero_add a.makespan

/-- Composition is associative in makespan. -/
theorem then_assoc (a b c : Scheduler) :
    ((a.then b).then c).makespan = (a.then (b.then c)).makespan :=
  Nat.add_assoc a.makespan b.makespan c.makespan

/-- Appending a scheduler never shortens the makespan. -/
theorem then_monotone (a b : Scheduler) : a.makespan ≤ (a.then b).makespan :=
  Nat.le_add_right a.makespan b.makespan

end Gnosis
