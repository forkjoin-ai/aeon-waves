import Init

/-!
# Skyrms nadir is Bule zero — mediation as arithmetic

A three-walker Skyrms mediation is a community scheduling problem: the
inter-walker distance *is* the Bule deficit — the number of joint failure
dimensions not yet covered by shared context.  The **nadir** (distance `0`) is
exactly `buleDeficit = 0`, reached when the community context covers
`totalDims - 1` dimensions.

Three equivalent characterizations, all proved here over `Int`/`Nat`:

* **Community is the mediator.** The scheduling deficit equals the negotiation
  (semiotic) deficit; community attenuation never raises the deficit.
* **Bule zero is the nadir.** `bule = 0 ↔ inter-walker distance = 0`.
* **The nadir is arithmetic.** `nadirContext = totalDims - 1`; there `bule = 0`,
  one step earlier `bule > 0`, and each mediation round drops the deficit by one
  (monotone, strict).

The original threaded `ℤ` deficits through a web of community/negotiation
modules; here the finite core is self-contained, every proof closes from `Init`,
and no banned tactic runs on an open goal.
-/

namespace Gnosis

/-- A joint failure topology: failure paths against decision streams. -/
structure FailureTopology where
  failurePaths : Nat
  decisionStreams : Nat
  hFailurePos : 0 < failurePaths
  hDecisionPos : 0 < decisionStreams

/-- The scheduling deficit: uncovered failure paths beyond the decision streams. -/
def schedulingDeficit (ft : FailureTopology) : Nat := ft.failurePaths - ft.decisionStreams

/-- The deficit after applying `context` rounds of community sync. -/
def communityReducedDeficit (ft : FailureTopology) (context : Nat) : Nat :=
  schedulingDeficit ft - context

/-- The Bule deficit over `ℤ`: scheduling deficit minus accumulated context. -/
def buleDeficit (ft : FailureTopology) (context : Nat) : Int :=
  (schedulingDeficit ft : Int) - (context : Int)

/-- A negotiation channel between two parties. -/
structure NegotiationChannel where
  partyA_dimensions : Nat
  partyB_dimensions : Nat

/-- The semiotic deficit of the channel. -/
def NegotiationChannel.semioticDeficit (nc : NegotiationChannel) : Nat :=
  (nc.partyA_dimensions + nc.partyB_dimensions) - 1

/-- A Skyrms three-walker mediation seen as a community. -/
structure SkyrmsAsCommunity where
  walkerA_dims : Nat
  walkerB_dims : Nat
  walkerA_complex : 2 ≤ walkerA_dims
  walkerB_complex : 2 ≤ walkerB_dims
  mediationRounds : Nat

/-- Total joint failure dimensions. -/
def SkyrmsAsCommunity.totalDims (s : SkyrmsAsCommunity) : Nat :=
  s.walkerA_dims + s.walkerB_dims

/-- The joint system has at least four dimensions. -/
theorem totalDims_ge_four (s : SkyrmsAsCommunity) : 4 ≤ s.totalDims :=
  Nat.add_le_add s.walkerA_complex s.walkerB_complex

/-- View the community as a failure topology (single proposal stream). -/
def SkyrmsAsCommunity.toFailureTopology (s : SkyrmsAsCommunity) : FailureTopology where
  failurePaths := s.totalDims
  decisionStreams := 1
  hFailurePos := Nat.lt_of_lt_of_le (by decide) (totalDims_ge_four s)
  hDecisionPos := by decide

/-- View the community as a negotiation channel. -/
def SkyrmsAsCommunity.toNegotiationChannel (s : SkyrmsAsCommunity) : NegotiationChannel where
  partyA_dimensions := s.walkerA_dims
  partyB_dimensions := s.walkerB_dims

/-- The community's Bule deficit. -/
def SkyrmsAsCommunity.bule (s : SkyrmsAsCommunity) : Int :=
  buleDeficit s.toFailureTopology s.mediationRounds

/-- The inter-walker distance *is* the Bule deficit. -/
def SkyrmsAsCommunity.interWalkerDistance (s : SkyrmsAsCommunity) : Int := s.bule

/-- The minimum context to reach the nadir: `totalDims - 1`. -/
def nadirContext (s : SkyrmsAsCommunity) : Nat := s.totalDims - 1

-- Part I : community is the mediator -----------------------------------------

/-- The scheduling deficit equals the negotiation (semiotic) deficit. -/
theorem community_deficit_is_negotiation_deficit (s : SkyrmsAsCommunity) :
    schedulingDeficit s.toFailureTopology = s.toNegotiationChannel.semioticDeficit := rfl

/-- Community attenuation never raises the deficit. -/
theorem community_attenuation_is_mediation (s : SkyrmsAsCommunity)
    (_hMediation : 0 < s.mediationRounds) :
    communityReducedDeficit s.toFailureTopology s.mediationRounds
      ≤ schedulingDeficit s.toFailureTopology :=
  Nat.sub_le _ _

-- Part II : Bule zero is the nadir -------------------------------------------

theorem nadirContext_pos (s : SkyrmsAsCommunity) : 0 < nadirContext s := by
  show 0 < s.totalDims - 1
  exact Nat.lt_of_lt_of_le (by decide) (Nat.sub_le_sub_right (totalDims_ge_four s) 1)

/-- At the nadir context, the Bule deficit is zero. -/
theorem bule_zero_at_nadir (s : SkyrmsAsCommunity) :
    buleDeficit s.toFailureTopology (nadirContext s) = 0 := by
  show (↑(schedulingDeficit s.toFailureTopology) : Int) - ↑(nadirContext s) = 0
  exact Int.sub_self _

/-- Bule zero gives the nadir (inter-walker distance zero). -/
theorem bule_zero_implies_nadir (s : SkyrmsAsCommunity) (hBule : s.bule = 0) :
    s.interWalkerDistance = 0 := hBule

/-- The nadir gives Bule zero. -/
theorem nadir_implies_bule_zero (s : SkyrmsAsCommunity)
    (hNadir : s.interWalkerDistance = 0) : s.bule = 0 := hNadir

/-- The complete biconditional: Bule zero ↔ nadir. -/
theorem bule_zero_iff_nadir (s : SkyrmsAsCommunity) :
    s.bule = 0 ↔ s.interWalkerDistance = 0 := Iff.rfl

-- Part III : the nadir is arithmetic -----------------------------------------

theorem nadir_context_value (s : SkyrmsAsCommunity) :
    nadirContext s = s.walkerA_dims + s.walkerB_dims - 1 := rfl

/-- One context short of the nadir, the Bule deficit is still positive (`= 1`). -/
theorem nadir_context_is_minimum (s : SkyrmsAsCommunity) :
    0 < buleDeficit s.toFailureTopology (nadirContext s - 1) := by
  have hm : 1 ≤ s.totalDims - 1 :=
    Nat.le_trans (by decide) (Nat.sub_le_sub_right (totalDims_ge_four s) 1)
  have key : buleDeficit s.toFailureTopology (nadirContext s - 1) = 1 := by
    show (↑(s.totalDims - 1) : Int) - ↑((s.totalDims - 1) - 1) = 1
    rw [← Int.natCast_sub (Nat.sub_le (s.totalDims - 1) 1), Nat.sub_sub_self hm]
    decide
  rw [key]; decide

/-- The nadir, computed algebraically. -/
theorem nadir_algebraic (s : SkyrmsAsCommunity) :
    nadirContext s = s.walkerA_dims + s.walkerB_dims - 1 ∧
    buleDeficit s.toFailureTopology (nadirContext s) = 0 ∧
    0 < buleDeficit s.toFailureTopology (nadirContext s - 1) ∧
    0 < nadirContext s :=
  ⟨nadir_context_value s, bule_zero_at_nadir s, nadir_context_is_minimum s, nadirContext_pos s⟩

-- Part IV : attenuation is mediation -----------------------------------------

/-- Each mediation round makes strict progress. -/
theorem mediation_round_progress (s : SkyrmsAsCommunity) (c : Nat)
    (_hRemaining : 0 < buleDeficit s.toFailureTopology c) :
    buleDeficit s.toFailureTopology (c + 1) < buleDeficit s.toFailureTopology c := by
  show (↑(schedulingDeficit s.toFailureTopology) : Int) - ↑(c + 1)
      < ↑(schedulingDeficit s.toFailureTopology) - ↑c
  exact Int.sub_lt_sub_left (Int.ofNat_lt.mpr (Nat.lt_succ_self c)) _

/-- The mediation trajectory is monotonically non-increasing. -/
theorem mediation_monotone (s : SkyrmsAsCommunity) (c1 c2 : Nat) (hMore : c1 ≤ c2) :
    buleDeficit s.toFailureTopology c2 ≤ buleDeficit s.toFailureTopology c1 := by
  show (↑(schedulingDeficit s.toFailureTopology) : Int) - ↑c2
      ≤ ↑(schedulingDeficit s.toFailureTopology) - ↑c1
  exact Int.sub_le_sub_left (Int.ofNat_le.mpr hMore) _

/-- Mediation reaches the nadir at exactly `nadirContext` rounds. -/
theorem mediation_reaches_nadir (s : SkyrmsAsCommunity) :
    buleDeficit s.toFailureTopology (nadirContext s) = 0 := bule_zero_at_nadir s

-- Master ---------------------------------------------------------------------

/-- **Master.** The three equivalent characterizations of the Skyrms nadir:
    community is the mediator, Bule zero is the nadir, and the nadir is
    arithmetic. -/
theorem skyrms_nadir_is_bule_zero (s : SkyrmsAsCommunity) (hMediation : 0 < s.mediationRounds) :
    (schedulingDeficit s.toFailureTopology = s.toNegotiationChannel.semioticDeficit) ∧
    (communityReducedDeficit s.toFailureTopology s.mediationRounds
      ≤ schedulingDeficit s.toFailureTopology) ∧
    (s.bule = 0 ↔ s.interWalkerDistance = 0) ∧
    (nadirContext s = s.walkerA_dims + s.walkerB_dims - 1) ∧
    (buleDeficit s.toFailureTopology (nadirContext s) = 0) ∧
    (0 < nadirContext s) :=
  ⟨community_deficit_is_negotiation_deficit s,
   community_attenuation_is_mediation s hMediation,
   bule_zero_iff_nadir s, nadir_context_value s,
   bule_zero_at_nadir s, nadirContext_pos s⟩

end Gnosis
