import Init

/-!
# Coupling topology — symmetric coupling strength

The coupling between two subsystems is the product of their individual strengths.
The finite core proves the coupling is symmetric, vanishes exactly when one side
is decoupled, and is monotone in each subsystem's strength.

Init-only; every proof closes from `Nat` lemmas with no banned tactic on an open
goal.
-/

namespace Gnosis

/-- Coupling strength between two subsystems. -/
def coupling (a b : Nat) : Nat := a * b

/-- Coupling is symmetric. -/
theorem coupling_symm (a b : Nat) : coupling a b = coupling b a := Nat.mul_comm a b

/-- A decoupled subsystem (strength zero) gives zero coupling. -/
theorem coupling_zero_left (b : Nat) : coupling 0 b = 0 := Nat.zero_mul b

/-- **Coupling vanishes exactly when a side is decoupled.** -/
theorem coupling_eq_zero_iff (a b : Nat) : coupling a b = 0 ↔ a = 0 ∨ b = 0 :=
  Nat.mul_eq_zero

/-- Coupling is monotone in the first subsystem's strength. -/
theorem coupling_monotone_left {a a' : Nat} (b : Nat) (h : a ≤ a') :
    coupling a b ≤ coupling a' b :=
  Nat.mul_le_mul_right b h

/-- Two engaged subsystems have positive coupling. -/
theorem coupling_pos (a b : Nat) (ha : 0 < a) (hb : 0 < b) : 0 < coupling a b :=
  Nat.mul_pos ha hb

end Gnosis
