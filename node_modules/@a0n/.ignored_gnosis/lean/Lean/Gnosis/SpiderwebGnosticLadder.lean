import Init

/-!
# Spiderweb gnostic ladder — strict ascent through the rungs

A gnostic ladder lifts through evenly-spaced rungs.  The finite core proves the
ascent is strictly monotone (each rung strictly above the previous, given a
positive spacing), non-decreasing in general, and bounded below by the base.

Init-only; every proof closes from `Nat` lemmas with no banned tactic on an open
goal.
-/

namespace Gnosis

/-- A ladder: a base height and a per-rung spacing. -/
structure Ladder where
  base : Nat
  spacing : Nat

/-- Height of rung `n`. -/
def Ladder.height (l : Ladder) (n : Nat) : Nat := l.base + n * l.spacing

/-- Every rung is at least the base. -/
theorem height_ge_base (l : Ladder) (n : Nat) : l.base ≤ l.height n :=
  Nat.le_add_right l.base (n * l.spacing)

/-- The ascent is non-decreasing. -/
theorem height_monotone (l : Ladder) {j k : Nat} (h : j ≤ k) : l.height j ≤ l.height k :=
  Nat.add_le_add_left (Nat.mul_le_mul_right l.spacing h) l.base

/-- **Strict ascent.** With positive spacing each rung is strictly higher. -/
theorem height_strict (l : Ladder) (hs : 0 < l.spacing) (n : Nat) :
    l.height n < l.height (n + 1) := by
  show l.base + n * l.spacing < l.base + (n + 1) * l.spacing
  apply Nat.add_lt_add_left
  rw [Nat.succ_mul]
  exact Nat.lt_add_of_pos_right hs

end Gnosis
