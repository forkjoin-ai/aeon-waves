import Init

/-!
# Invariant field — total charge is conserved

A field is sampled as a list of local charges; its total charge is the conserved
invariant.  The finite core proves conservation: the total is additive across
regions, invariant under exchanging two regions, and unchanged by appending a
charge-free region.

Init-only; every proof closes from `Nat`/`List` lemmas with no banned tactic on an
open goal.
-/

namespace Gnosis

/-- A field sampled as local charges. -/
structure Field where
  charges : List Nat

/-- The conserved invariant: total charge. -/
def Field.totalCharge (f : Field) : Nat := f.charges.foldr (· + ·) 0

/-- Total charge is additive across regions. -/
theorem charge_additive (a b : List Nat) :
    (Field.mk (a ++ b)).totalCharge = (Field.mk a).totalCharge + (Field.mk b).totalCharge := by
  induction a with
  | nil => exact (Nat.zero_add _).symm
  | cons x xs ih =>
      show x + (Field.mk (xs ++ b)).totalCharge
        = x + (Field.mk xs).totalCharge + (Field.mk b).totalCharge
      rw [ih]; exact (Nat.add_assoc x _ _).symm

/-- **Conservation under region exchange.** -/
theorem charge_exchange (a b : List Nat) :
    (Field.mk (a ++ b)).totalCharge = (Field.mk (b ++ a)).totalCharge := by
  rw [charge_additive, charge_additive, Nat.add_comm]

/-- A vacuum region adds no charge. -/
theorem vacuum_no_charge (f : Field) :
    (Field.mk (f.charges ++ [])).totalCharge = f.totalCharge := by
  rw [charge_additive]; exact Nat.add_zero _

end Gnosis
