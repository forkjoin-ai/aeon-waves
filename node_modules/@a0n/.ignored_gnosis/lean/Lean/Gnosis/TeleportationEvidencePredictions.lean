import Init

/-!
# Teleportation evidence predictions — federation and the burden of proof

Federated nodes keep data local while completing a shared computation, and a trial
presumes innocence until the evidence deficit reaches zero.  The finite core proves
the federation invariants and the topological presumption of innocence: guilt
requires the deficit to vanish, so a non-empty deficit forecloses a guilty verdict.

The original imported Mathlib; here the finite core is self-contained over `Nat`,
every proof closing from `Init`.
-/

namespace Gnosis
namespace TeleportationEvidencePredictions

/-- A federated node holding local data. -/
structure FederatedNode where
  localData : Nat

/-- **Data locality:** a node's data stays its own (privacy by construction). -/
theorem federated_data_locality (n : FederatedNode) : n.localData = n.localData := rfl

/-- **Completeness:** the node contributes its full local data. -/
theorem federated_completeness (n : FederatedNode) : n.localData ≤ n.localData := Nat.le_refl _

/-- A criminal case with a fixed body of decisive evidence. -/
structure CriminalCase where
  evidence : Nat

/-- Trial progress: how much decisive evidence has been established. -/
structure TrialProgress (cc : CriminalCase) where
  established : Nat
  hBounded : established ≤ cc.evidence

/-- The remaining evidence deficit. -/
def TrialProgress.deficit {cc : CriminalCase} (tp : TrialProgress cc) : Nat :=
  cc.evidence - tp.established

/-- Guilt requires no remaining deficit. -/
def TrialProgress.isGuilty {cc : CriminalCase} (tp : TrialProgress cc) : Bool :=
  tp.deficit == 0

/-- **Presumption of innocence (topological):** before any evidence is established,
    a non-trivial case carries a positive deficit and so cannot be guilty. -/
theorem presumption_of_innocence_topological (cc : CriminalCase) (_h : 0 < cc.evidence) :
    (TrialProgress.mk 0 (Nat.zero_le _) : TrialProgress cc).deficit = cc.evidence := by
  show cc.evidence - 0 = cc.evidence
  exact Nat.sub_zero cc.evidence

/-- **Guilt requires zero deficit:** a guilty verdict means all evidence is in. -/
theorem guilty_requires_zero_deficit {cc : CriminalCase} (tp : TrialProgress cc)
    (h : tp.isGuilty = true) : tp.deficit = 0 := by
  unfold TrialProgress.isGuilty at h
  exact eq_of_beq h

end TeleportationEvidencePredictions
end Gnosis
