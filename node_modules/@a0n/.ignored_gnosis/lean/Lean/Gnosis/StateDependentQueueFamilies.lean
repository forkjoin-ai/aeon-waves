import Init

/-!
# State-dependent queue families — vacation kernels are positive recurrent

A vacation queue kernel makes its service rate depend on the queue state: longer
queues are served faster.  The finite core proves the Foster–Lyapunov stability of
such a family: service is monotone in the state, so above a stability threshold the
service strictly beats the arrival rate, giving a positive drift toward the petite
set — the finite witness of positive recurrence.

The original carried this over `ℝ`/measure theory; here the finite core is
self-contained over `Nat`, every proof closing from `Init`.
-/

namespace Gnosis
namespace StateDependentQueueFamilies

/-- A vacation queue kernel family: arrival rate against a state-dependent service. -/
structure VacationQueueKernelFamily where
  arrival : Nat
  serviceAt : Nat → Nat
  serviceMonotone : ∀ s, serviceAt s ≤ serviceAt (s + 1)
  threshold : Nat
  hStable : arrival < serviceAt threshold

/-- **Service depends on the vacation state** (monotone in the queue length). -/
theorem serviceDependsOnVacation_holds (f : VacationQueueKernelFamily) (s : Nat) :
    f.serviceAt s ≤ f.serviceAt (s + 1) := f.serviceMonotone s

/-- Service is monotone across any gap. -/
theorem service_mono_le (f : VacationQueueKernelFamily) :
    ∀ (d s : Nat), f.serviceAt s ≤ f.serviceAt (s + d)
  | 0, _s => Nat.le_refl _
  | d + 1, s => Nat.le_trans (service_mono_le f d s) (f.serviceMonotone (s + d))

/-- Service is monotone from any state at or above another. -/
theorem service_mono_of_le (f : VacationQueueKernelFamily) {a b : Nat} (h : a ≤ b) :
    f.serviceAt a ≤ f.serviceAt b := by
  have := service_mono_le f (b - a) a
  rwa [Nat.add_sub_cancel' h] at this

/-- The Foster–Lyapunov drift at a state: how fast service drains the queue. -/
def VacationQueueKernelFamily.fosterLyapunovDrift (f : VacationQueueKernelFamily) (s : Nat) : Nat :=
  f.serviceAt s - f.arrival

/-- **Positive recurrence (Foster–Lyapunov):** above the threshold the drift is
    strictly positive — service beats arrival, draining toward the petite set. -/
theorem foster_lyapunov_positive_above_threshold (f : VacationQueueKernelFamily) (s : Nat)
    (h : f.threshold ≤ s) : 0 < f.fosterLyapunovDrift s := by
  show 0 < f.serviceAt s - f.arrival
  exact Nat.sub_pos_of_lt (Nat.lt_of_lt_of_le f.hStable (service_mono_of_le f h))

/-- The threshold itself is in the stable region (the petite set boundary). -/
theorem petiteSet_threshold_stable (f : VacationQueueKernelFamily) :
    f.arrival < f.serviceAt f.threshold := f.hStable

end StateDependentQueueFamilies
end Gnosis
