import Init

/-!
# Contrarian latent witness absence — zero absence is optimal

A contrarian claim: a latent witness is optimal exactly when its absence count is
zero.  The finite core proves it: zero absence beats any positive bound, optimality
is precisely the no-absence condition, and absence is a cost (monotone).

Init-only; every proof closes from `Nat` lemmas with no banned tactic on an open
goal.
-/

namespace Gnosis

/-- A latent witness with an absence count (a cost). -/
structure LatentWitness where
  absenceCount : Nat

/-- Optimality: no absences. -/
def LatentWitness.optimal (w : LatentWitness) : Prop := w.absenceCount = 0

/-- **Zero absence is optimal:** it falls below the unit threshold. -/
theorem latent_witness_absence_optimal (w : LatentWitness) (h : w.absenceCount = 0) :
    w.absenceCount < 1 := by rw [h]; decide

/-- Optimality is exactly the no-absence condition. -/
theorem optimal_iff_no_absence (w : LatentWitness) : w.optimal ↔ w.absenceCount = 0 := Iff.rfl

/-- Absence is a cost: fewer absences never score worse. -/
theorem fewer_absences_better {a b : Nat} (h : a ≤ b) :
    (LatentWitness.mk a).absenceCount ≤ (LatentWitness.mk b).absenceCount := h

end Gnosis
