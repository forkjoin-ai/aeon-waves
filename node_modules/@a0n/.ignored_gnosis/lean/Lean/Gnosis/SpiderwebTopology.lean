import Init

/-!
# Spiderweb topology — the cycle rank of a connected mesh

A connected spiderweb on `nodes ≥ 1` vertices with `edges` strands has first Betti
number (cycle rank) `edges + 1 - nodes`.  The finite core proves a tree (edges =
nodes − 1) is acyclic, that adding a strand creates exactly one cycle, and that
the cycle rank is bounded by the strand count.

Init-only; every proof closes from `Nat` lemmas with no banned tactic on an open
goal.
-/

namespace Gnosis

/-- A connected web: at least one node and at least `nodes - 1` strands. -/
structure Web where
  nodes : Nat
  edges : Nat
  hNodes : 1 ≤ nodes
  hConnected : nodes ≤ edges + 1

/-- The cycle rank (first Betti number). -/
def Web.cycleRank (w : Web) : Nat := w.edges + 1 - w.nodes

/-- A tree (`edges + 1 = nodes`) is acyclic. -/
theorem tree_acyclic (w : Web) (hTree : w.edges + 1 = w.nodes) : w.cycleRank = 0 := by
  show w.edges + 1 - w.nodes = 0
  rw [hTree, Nat.sub_self]

/-- **Adding a strand creates exactly one cycle.** -/
theorem add_strand_adds_cycle (w : Web) :
    (Web.mk w.nodes (w.edges + 1) w.hNodes
      (Nat.le_trans w.hConnected (Nat.le_succ _))).cycleRank = w.cycleRank + 1 := by
  show w.edges + 1 + 1 - w.nodes = (w.edges + 1 - w.nodes) + 1
  rw [Nat.succ_sub w.hConnected]

/-- The cycle rank is at most the strand count. -/
theorem cycleRank_le_edges (w : Web) : w.cycleRank ≤ w.edges := by
  show w.edges + 1 - w.nodes ≤ w.edges
  have h : w.edges + 1 - w.nodes ≤ w.edges + 1 - 1 :=
    Nat.sub_le_sub_left w.hNodes (w.edges + 1)
  rwa [Nat.add_sub_cancel] at h

end Gnosis
