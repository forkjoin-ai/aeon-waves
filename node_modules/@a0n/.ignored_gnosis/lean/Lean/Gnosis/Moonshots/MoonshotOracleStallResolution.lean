import Init

/-!
# Oracle stall resolution — bounded fuel guarantees termination

An oracle execution with bounded fuel cannot stall forever: each step burns one
unit of fuel.  The finite core proves the resolution as a terminating monovariant
— fuel never increases, `k` steps leave `fuel - k`, and running for the full fuel
budget halts at zero.

Init-only; every proof closes from `Nat` lemmas with no banned tactic on an open
goal.
-/

namespace Gnosis

/-- One execution step burns a unit of fuel. -/
def burn (fuel : Nat) : Nat := fuel - 1

/-- Run `k` execution steps. -/
def run : Nat → Nat → Nat
  | 0,     fuel => fuel
  | k + 1, fuel => burn (run k fuel)

/-- A step never increases fuel. -/
theorem burn_le (fuel : Nat) : burn fuel ≤ fuel := Nat.sub_le fuel 1

/-- **Closed form.** `k` steps leave `fuel - k`. -/
theorem run_eq : ∀ (k fuel : Nat), run k fuel = fuel - k
  | 0,     fuel => (Nat.sub_zero fuel).symm
  | k + 1, fuel => by
      show burn (run k fuel) = fuel - (k + 1)
      rw [run_eq k fuel]
      show (fuel - k) - 1 = fuel - (k + 1)
      rw [Nat.sub_sub]

/-- Fuel is a monovariant: running never increases it. -/
theorem run_le (k fuel : Nat) : run k fuel ≤ fuel := by
  rw [run_eq]; exact Nat.sub_le fuel k

/-- **Termination.** Running the full fuel budget halts at zero. -/
theorem execution_resolves (fuel : Nat) : run fuel fuel = 0 := by
  rw [run_eq]; exact Nat.sub_self fuel

end Gnosis
