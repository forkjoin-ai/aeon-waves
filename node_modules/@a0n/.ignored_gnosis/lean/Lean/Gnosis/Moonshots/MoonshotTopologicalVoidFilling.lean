import Init

/-!
# Topological void filling — filling a void up to capacity

A topological void of fixed capacity is filled cell by cell.  The finite core
proves the fill monovariant: the filled amount never exceeds capacity, the
remaining space decreases as cells are added, and the void can be filled
completely.

Init-only; every proof closes from `Nat` lemmas with no banned tactic on an open
goal.
-/

namespace Gnosis

/-- A void of fixed capacity with a number of filled cells (within capacity). -/
structure TopologicalVoid where
  capacity : Nat
  filled : Nat
  hFilled : filled ≤ capacity

/-- Space remaining to be filled. -/
def TopologicalVoid.remaining (v : TopologicalVoid) : Nat := v.capacity - v.filled

/-- The filled amount never exceeds capacity. -/
theorem filled_le_capacity (v : TopologicalVoid) : v.filled ≤ v.capacity := v.hFilled

/-- Filled plus remaining recovers the capacity. -/
theorem fill_conservation (v : TopologicalVoid) : v.filled + v.remaining = v.capacity :=
  Nat.add_sub_cancel' v.hFilled

/-- Adding a cell strictly shrinks the remaining space (while space is left). -/
theorem remaining_decreases (v : TopologicalVoid) (h : v.filled < v.capacity) :
    v.capacity - (v.filled + 1) < v.remaining := by
  show v.capacity - (v.filled + 1) < v.capacity - v.filled
  exact Nat.sub_succ_lt_self v.capacity v.filled h

/-- A full void has no remaining space. -/
theorem full_void_empty_remaining (v : TopologicalVoid) (h : v.filled = v.capacity) :
    v.remaining = 0 := by
  show v.capacity - v.filled = 0
  rw [h, Nat.sub_self]

end Gnosis
