import Init

/-!
# Ergodic semantic resolution — ambiguity always resolves in finite time

Semantic resolution reduces a finite ambiguity by a positive amount per round, so
it always reaches a fully-resolved state.  The finite core proves the resolution
is a terminating monovariant: each round never raises ambiguity, `k` rounds leave
`ambiguity - k·rate`, and enough rounds reach zero.

Init-only; every proof closes from `Nat` lemmas with no banned tactic on an open
goal.
-/

namespace Gnosis

/-- A resolver: a per-round resolution rate. -/
structure Resolver where
  rate : Nat

/-- Ambiguity remaining after `k` rounds from `ambiguity`. -/
def Resolver.resolve (r : Resolver) (ambiguity k : Nat) : Nat := ambiguity - k * r.rate

/-- A round never raises ambiguity. -/
theorem resolve_le (r : Resolver) (ambiguity k : Nat) :
    r.resolve ambiguity k ≤ ambiguity :=
  Nat.sub_le ambiguity (k * r.rate)

/-- Resolution is monotone in the round count (more rounds, less ambiguity). -/
theorem resolve_monotone (r : Resolver) (ambiguity : Nat) {j k : Nat} (h : j ≤ k) :
    r.resolve ambiguity k ≤ r.resolve ambiguity j :=
  Nat.sub_le_sub_left (Nat.mul_le_mul_right r.rate h) ambiguity

/-- **Resolution is always finite.** With a positive rate, enough rounds resolve
    all ambiguity. -/
theorem resolution_always_finite (r : Resolver) (ambiguity : Nat) (h : 0 < r.rate) :
    r.resolve ambiguity ambiguity = 0 := by
  show ambiguity - ambiguity * r.rate = 0
  exact Nat.sub_eq_zero_of_le (Nat.le_mul_of_pos_right ambiguity h)

end Gnosis
