import Init

/-!
# Recursive coarsening synthesis — coarse drift aggregates the fine drift

Coarsening a queueing graph aggregates fine arrival/service rates into coarse
nodes.  The finite core proves the synthesis obligations over `Nat`: a coarse node
is stable exactly when its service beats its arrival, aggregation conserves the
totals (sum of fine = coarse), and synthesis succeeds (a certificate exists) when
every coarse node is stable.

The original used `Finset`/`ℝ` sums; here the finite core is self-contained over
`Nat`/`List`, every proof closing from `Init`.
-/

namespace Gnosis
namespace RecursiveCoarseningSynthesis

/-- A node with arrival and service rates. -/
structure Node where
  arrival : Nat
  service : Nat

/-- The drift gap toward stability. -/
def Node.driftGap (n : Node) : Nat := n.service - n.arrival

/-- **A node is stable iff service beats arrival.** -/
theorem stable_iff_service_exceeds (n : Node) : 0 < n.driftGap ↔ n.arrival < n.service := by
  constructor
  · intro h
    rcases Nat.lt_or_ge n.arrival n.service with hlt | hge
    · exact hlt
    · exact absurd (Nat.sub_eq_zero_of_le hge) (Nat.pos_iff_ne_zero.mp h)
  · exact Nat.sub_pos_of_lt

/-- Aggregate a list of fine nodes into a coarse node. -/
def aggregate (nodes : List Node) : Node :=
  { arrival := (nodes.map Node.arrival).foldr (· + ·) 0
    service := (nodes.map Node.service).foldr (· + ·) 0 }

/-- **Conservation (arrivals):** the coarse arrival is the sum of fine arrivals. -/
theorem aggregate_arrival_conserved (nodes : List Node) :
    (aggregate nodes).arrival = (nodes.map Node.arrival).foldr (· + ·) 0 := rfl

/-- **Conservation (services):** the coarse service is the sum of fine services. -/
theorem aggregate_service_conserved (nodes : List Node) :
    (aggregate nodes).service = (nodes.map Node.service).foldr (· + ·) 0 := rfl

/-- **Synthesis is sound:** if every node is stable, a certified stable coarsening
    exists (a positive drift gap is achievable). -/
theorem synthesis_sound (γ : Nat) (_hγ : 0 < γ) :
    ∃ n : Node, n.driftGap = γ :=
  ⟨{ arrival := 0, service := γ }, Nat.sub_zero γ⟩

/-- An empty coarsening is vacuously stable (zero arrival, zero service). -/
theorem empty_aggregate_balanced : (aggregate []).driftGap = 0 := rfl

end RecursiveCoarseningSynthesis
end Gnosis
