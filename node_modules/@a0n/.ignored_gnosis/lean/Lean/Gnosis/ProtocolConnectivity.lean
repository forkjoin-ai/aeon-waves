import Init

/-!
# Protocol connectivity — a hop metric on a line protocol

Connectivity is measured by a hop distance between protocol endpoints.  Modeling
endpoints as positions on a line, the hop count is the symmetric difference.  The
finite core proves the metric basics: an endpoint reaches itself in zero hops, the
metric is symmetric, and zero distance characterizes identical endpoints.

Init-only; every proof closes from `Nat` lemmas with no banned tactic on an open
goal.
-/

namespace Gnosis

/-- Hop distance between two endpoints. -/
def hops (i j : Nat) : Nat := (i - j) + (j - i)

/-- An endpoint reaches itself in zero hops. -/
theorem hops_self (i : Nat) : hops i i = 0 := by
  show (i - i) + (i - i) = 0
  rw [Nat.sub_self]

/-- The hop metric is symmetric. -/
theorem hops_symm (i j : Nat) : hops i j = hops j i := Nat.add_comm _ _

/-- **Zero distance characterizes connectivity to self.** -/
theorem hops_eq_zero_iff (i j : Nat) : hops i j = 0 ↔ i = j := by
  constructor
  · intro h
    have hpair := Nat.add_eq_zero_iff.mp h
    exact Nat.le_antisymm (Nat.sub_eq_zero_iff_le.mp hpair.1) (Nat.sub_eq_zero_iff_le.mp hpair.2)
  · intro h; rw [h]; exact hops_self j

/-- Distinct endpoints are a positive number of hops apart. -/
theorem hops_pos_of_ne (i j : Nat) (h : i ≠ j) : 0 < hops i j := by
  rcases Nat.lt_or_ge i j with hlt | hge
  · exact Nat.lt_of_lt_of_le (Nat.sub_pos_of_lt hlt) (Nat.le_add_left _ _)
  · have : j < i := Nat.lt_of_le_of_ne hge (fun he => h he.symm)
    exact Nat.lt_of_lt_of_le (Nat.sub_pos_of_lt this) (Nat.le_add_right _ _)

end Gnosis
