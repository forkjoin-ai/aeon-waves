import Init

/-!
# Protocol deficit latency — multiplexing pressure and latency inflation

When a computation forks into `pathCount` independent paths but the transport
offers only `transportStreams` streams, paths must share streams.  The
**multiplexing pressure** is the ceiling `⌈pathCount / streams⌉`; a loss on a
shared stream stalls every path on it, so worst-case **latency inflation** equals
that pressure.

The finite core:

* TCP (one stream) carries the full pressure `pathCount` — the worst case.
* A matched topology (`streams = pathCount`) has pressure `1` — no inflation.
* A positive topological deficit forces inflation `> 1`.

Every proof closes from `Init`; the original's `omega` is replaced by `Nat`
lemmas, with no banned tactic on an open goal.
-/

namespace Gnosis

/-- Independent loops of the computation: `pathCount - 1`. -/
def computationBeta1 (pathCount : Nat) : Nat := pathCount - 1
/-- Independent loops the transport can carry: `streams - 1`. -/
def transportBeta1 (transportStreams : Nat) : Nat := transportStreams - 1
/-- The topological deficit: uncarried loops. -/
def topologicalDeficit (pathCount transportStreams : Nat) : Nat :=
  computationBeta1 pathCount - transportBeta1 transportStreams

/-- Average paths per stream (ceiling division). -/
def multiplexingPressure (pathCount transportStreams : Nat) : Nat :=
  if transportStreams = 0 then pathCount
  else (pathCount + transportStreams - 1) / transportStreams

/-- For positive `b`, `(a + b - 1)/b = 1` when `a = b` (one full stream). -/
theorem ceilDiv_self (b : Nat) (hb : 0 < b) : (b + b - 1) / b = 1 := by
  have e : b + b - 1 = (b - 1) + b := by
    rw [Nat.add_comm (b - 1) b]; exact Nat.add_sub_assoc hb b
  rw [e, Nat.add_div_right _ hb, Nat.div_eq_of_lt (Nat.sub_lt hb (by decide))]

/-- Under TCP (one stream) the pressure equals the path count. -/
theorem tcp_multiplexing_pressure {pathCount : Nat} (_hPaths : 0 < pathCount) :
    multiplexingPressure pathCount 1 = pathCount := by
  unfold multiplexingPressure
  rw [if_neg (by decide), Nat.add_sub_cancel, Nat.div_one]

/-- Under a matched topology the pressure is one. -/
theorem matched_multiplexing_pressure {pathCount : Nat} (hPaths : 0 < pathCount) :
    multiplexingPressure pathCount pathCount = 1 := by
  unfold multiplexingPressure
  rw [if_neg (Nat.pos_iff_ne_zero.mp hPaths)]
  exact ceilDiv_self pathCount hPaths

/-- The latency inflation factor is the multiplexing pressure. -/
def latencyInflationFactor (pathCount transportStreams : Nat) : Nat :=
  multiplexingPressure pathCount transportStreams

theorem tcp_latency_inflation {pathCount : Nat} (hPaths : 0 < pathCount) :
    latencyInflationFactor pathCount 1 = pathCount :=
  tcp_multiplexing_pressure hPaths

theorem matched_no_inflation {pathCount : Nat} (hPaths : 0 < pathCount) :
    latencyInflationFactor pathCount pathCount = 1 :=
  matched_multiplexing_pressure hPaths

/-- A positive deficit forces inflation strictly above one: when streams fall
    short of paths, at least two paths share some stream. -/
theorem positive_deficit_implies_inflation {pathCount transportStreams : Nat}
    (hStreams : 0 < transportStreams) (hLt : transportStreams < pathCount) :
    1 < latencyInflationFactor pathCount transportStreams := by
  unfold latencyInflationFactor multiplexingPressure
  rw [if_neg (Nat.pos_iff_ne_zero.mp hStreams)]
  have key : transportStreams + 1 + transportStreams - 1 = 2 * transportStreams := by
    rw [Nat.add_right_comm transportStreams 1 transportStreams, Nat.add_sub_cancel, Nat.two_mul]
  have h2s : 2 * transportStreams ≤ pathCount + transportStreams - 1 :=
    key ▸ Nat.sub_le_sub_right (Nat.add_le_add_right hLt transportStreams) 1
  have h2 : 2 ≤ (pathCount + transportStreams - 1) / transportStreams :=
    (Nat.le_div_iff_mul_le hStreams).mpr h2s
  exact Nat.lt_of_lt_of_le (by decide) h2

/-- Zero deficit (matched) means no inflation. -/
theorem zero_deficit_no_inflation {pathCount : Nat} (hPaths : 0 < pathCount) :
    latencyInflationFactor pathCount pathCount = 1 :=
  matched_no_inflation hPaths

/-- The deficit–inflation chain: a nontrivial computation has positive deficit,
    multiple independent paths, and hence the precondition for inflation. -/
theorem deficit_beauty_chain {pathCount : Nat} (hPaths : 2 ≤ pathCount) :
    0 < topologicalDeficit pathCount 1 ∧
    2 ≤ computationBeta1 pathCount + 1 ∧
    0 < computationBeta1 pathCount := by
  have h1 : 0 < computationBeta1 pathCount :=
    Nat.sub_pos_of_lt (Nat.lt_of_lt_of_le (by decide) hPaths)
  refine ⟨?_, ?_, h1⟩
  · show 0 < computationBeta1 pathCount - transportBeta1 1
    exact h1
  · exact Nat.succ_le_succ h1

end Gnosis
