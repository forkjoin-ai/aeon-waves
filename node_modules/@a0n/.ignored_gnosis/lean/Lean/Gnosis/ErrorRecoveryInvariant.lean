import Init

/-!
# Error recovery invariant — recovery drives the error count to zero

A recovery step removes one error.  The finite core proves the invariant that
recovery is a terminating monovariant: each step never increases the error count,
iterating `k` steps leaves exactly `errors - k`, and running as many steps as
there are errors recovers fully (reaches zero).

Init-only; every proof closes from `Nat` lemmas with no banned tactic on an open
goal.
-/

namespace Gnosis

/-- One recovery step removes a single error. -/
def recover (errors : Nat) : Nat := errors - 1

/-- Iterate recovery `k` times. -/
def recoverIter : Nat → Nat → Nat
  | 0,     e => e
  | k + 1, e => recover (recoverIter k e)

/-- A recovery step never increases the error count. -/
theorem recover_le (e : Nat) : recover e ≤ e := Nat.sub_le e 1

/-- **Closed form.** `k` recovery steps leave `errors - k`. -/
theorem recoverIter_eq : ∀ (k e : Nat), recoverIter k e = e - k
  | 0,     e => (Nat.sub_zero e).symm
  | k + 1, e => by
      show recover (recoverIter k e) = e - (k + 1)
      rw [recoverIter_eq k e]
      show (e - k) - 1 = e - (k + 1)
      rw [Nat.sub_sub]

/-- Recovery is a monovariant: iterating never increases the error count. -/
theorem recoverIter_le (k e : Nat) : recoverIter k e ≤ e := by
  rw [recoverIter_eq]; exact Nat.sub_le e k

/-- **Full recovery.** Running as many steps as errors reaches zero. -/
theorem recovers_fully (e : Nat) : recoverIter e e = 0 := by
  rw [recoverIter_eq]; exact Nat.sub_self e

end Gnosis
