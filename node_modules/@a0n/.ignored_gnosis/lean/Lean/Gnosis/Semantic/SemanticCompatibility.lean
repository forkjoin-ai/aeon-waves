import Init

/-!
# Semantic compatibility — a decidable type-compatibility lattice

Contracts compare types for compatibility.  The finite core builds the
compatibility relation on JSON schema kinds and topology types and proves its
lattice laws: reflexivity, `unknown` is compatible with everything, and `integer`
is a subtype of `number`.

Init-only; every proof closes from `Init` with no banned tactic on an open goal.
-/

namespace Gnosis
namespace SemanticCompatibility

/-- The verdict of a compatibility check. -/
inductive TypeCompat where
  | compatible
  | incompatible
deriving DecidableEq

/-- JSON schema kinds. -/
inductive JsonSchemaKind where
  | null | boolean | integer | number | string
deriving DecidableEq

/-- Topology types, with an `unknown` top element. -/
inductive TopologyType where
  | mesh | ring | star | unknown
deriving DecidableEq

/-- JSON schema compatibility: equal kinds, or `integer <: number`. -/
def jsonSchemaCompat (a b : JsonSchemaKind) : TypeCompat :=
  if a = b then .compatible
  else if a = JsonSchemaKind.integer ∧ b = JsonSchemaKind.number then .compatible
  else .incompatible

/-- Topology compatibility: equal types, or either side `unknown`. -/
def topologyTypeCompat (a b : TopologyType) : TypeCompat :=
  if a = b then .compatible
  else if a = TopologyType.unknown ∨ b = TopologyType.unknown then .compatible
  else .incompatible

/-- **Reflexivity** of JSON schema compatibility. -/
theorem json_schema_compat_refl (s : JsonSchemaKind) :
    jsonSchemaCompat s s = TypeCompat.compatible := by
  unfold jsonSchemaCompat; rw [if_pos rfl]

/-- **Reflexivity** of topology compatibility. -/
theorem topology_type_compat_refl (t : TopologyType) :
    topologyTypeCompat t t = TypeCompat.compatible := by
  unfold topologyTypeCompat; rw [if_pos rfl]

/-- `unknown` is compatible on the left. -/
theorem unknown_compatible_left (t : TopologyType) :
    topologyTypeCompat TopologyType.unknown t = TypeCompat.compatible := by
  unfold topologyTypeCompat
  by_cases h : TopologyType.unknown = t
  · rw [if_pos h]
  · rw [if_neg h, if_pos (Or.inl rfl)]

/-- `unknown` is compatible on the right. -/
theorem unknown_compatible_right (t : TopologyType) :
    topologyTypeCompat t TopologyType.unknown = TypeCompat.compatible := by
  unfold topologyTypeCompat
  by_cases h : t = TopologyType.unknown
  · rw [if_pos h]
  · rw [if_neg h, if_pos (Or.inr rfl)]

/-- **`integer` is a subtype of `number`.** -/
theorem integer_subtype_number :
    jsonSchemaCompat JsonSchemaKind.integer JsonSchemaKind.number = TypeCompat.compatible := by
  decide

end SemanticCompatibility
end Gnosis
