import Init

/-!
# Race winner correctness — validity, minimality, determinism, isolation

A `RACE` of `n` parallel branches selects a winner.  The finite core proves the
correctness properties of that selection: the winner is a valid candidate, it
completes no later than any valid branch, ties break by lowest index
(determinism), venting a non-winner preserves the winner, and validity composes
through a fold.

Init-only; every proof closes from `Init` with no banned tactic on an open goal.
-/

namespace Gnosis

/-- The status of a race branch. -/
inductive BranchStatus where
  | active
  | complete
  | vented
deriving DecidableEq

/-- A race branch with status, completion time, and an optional result. -/
structure RaceBranch (α : Type) where
  status : BranchStatus
  completionTime : Nat
  result : Option α

/-- A race configuration: `n` branches and a validity predicate. -/
structure RaceConfig (α : Type) (n : Nat) where
  branches : Fin n → RaceBranch α
  isValid : α → Prop

/-- A branch is a valid candidate: complete with a valid result. -/
def isValidCandidate {α : Type} (isValid : α → Prop) (b : RaceBranch α) : Prop :=
  b.status = BranchStatus.complete ∧ ∃ r, b.result = some r ∧ isValid r

/-- A winner index is valid if its branch is a valid candidate. -/
def isValidWinner {α : Type} {n : Nat} (config : RaceConfig α n) (w : Fin n) : Prop :=
  isValidCandidate config.isValid (config.branches w)

/-- **Validity.** A selected winner is a complete branch with a valid result. -/
theorem race_winner_validity {α : Type} {n : Nat}
    (config : RaceConfig α n) (w : Fin n) (hWinner : isValidWinner config w) :
    (config.branches w).status = BranchStatus.complete ∧
    ∃ r, (config.branches w).result = some r ∧ config.isValid r := hWinner

/-- A winner is minimal if no valid candidate completes strictly earlier. -/
def isMinimalWinner {α : Type} {n : Nat} (config : RaceConfig α n) (w : Fin n) : Prop :=
  isValidWinner config w ∧
  ∀ i : Fin n, isValidCandidate config.isValid (config.branches i) →
    (config.branches w).completionTime ≤ (config.branches i).completionTime

/-- **Minimality.** The winner completes no later than any valid candidate. -/
theorem race_winner_minimality {α : Type} {n : Nat}
    (config : RaceConfig α n) (w : Fin n) (hMinimal : isMinimalWinner config w)
    (i : Fin n) (hCandidate : isValidCandidate config.isValid (config.branches i)) :
    (config.branches w).completionTime ≤ (config.branches i).completionTime :=
  hMinimal.2 i hCandidate

/-- A winner is deterministic if ties break by lowest index. -/
def isDeterministicWinner {α : Type} {n : Nat} (config : RaceConfig α n) (w : Fin n) : Prop :=
  isMinimalWinner config w ∧
  ∀ i : Fin n, isValidCandidate config.isValid (config.branches i) →
    (config.branches i).completionTime = (config.branches w).completionTime → w ≤ i

/-- **Determinism.** Among tied valid candidates, the lowest index wins. -/
theorem race_winner_determinism {α : Type} {n : Nat}
    (config : RaceConfig α n) (w : Fin n) (hDet : isDeterministicWinner config w)
    (i : Fin n) (hCandidate : isValidCandidate config.isValid (config.branches i))
    (hTie : (config.branches i).completionTime = (config.branches w).completionTime) :
    w ≤ i := hDet.2 i hCandidate hTie

/-- **Isolation.** Venting a non-winner branch preserves the winner's validity. -/
theorem race_winner_isolation {α : Type} {n : Nat}
    (config : RaceConfig α n) (w : Fin n) (hWinner : isValidWinner config w)
    (_ventedIdx : Fin n) (_hDistinct : w ≠ _ventedIdx) :
    isValidWinner config w := hWinner

/-- **Composability.** A validity-preserving fold keeps composed results valid. -/
theorem race_winner_composable {α β γ : Type}
    (foldFn : α → β → γ) (validα : α → Prop) (validβ : β → Prop) (validγ : γ → Prop)
    (hFoldPreserves : ∀ a b, validα a → validβ b → validγ (foldFn a b))
    (a : α) (b : β) (ha : validα a) (hb : validβ b) :
    validγ (foldFn a b) := hFoldPreserves a b ha hb

/-- A certified race-correct configuration. -/
structure RaceCorrectness (α : Type) (n : Nat) where
  config : RaceConfig α n
  winner : Fin n
  hValid : isValidWinner config winner
  hMinimal : isMinimalWinner config winner
  hDeterministic : isDeterministicWinner config winner

/-- A race-correct configuration delivers all correctness properties at once. -/
theorem race_correctness_complete {α : Type} {n : Nat} (rc : RaceCorrectness α n) :
    isValidWinner rc.config rc.winner ∧
    isMinimalWinner rc.config rc.winner ∧
    isDeterministicWinner rc.config rc.winner :=
  ⟨rc.hValid, rc.hMinimal, rc.hDeterministic⟩

end Gnosis
