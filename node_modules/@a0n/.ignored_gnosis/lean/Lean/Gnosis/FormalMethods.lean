import Init

/-!
# Formal methods — the inductive invariant principle

The core of formal verification: if a property holds initially and is preserved by
each step, it holds at every reachable step.  The finite core proves the inductive
invariant principle in full generality and discharges a concrete instance (the
doubling counter stays even).

Init-only; every proof closes from `Init`/`Nat` lemmas with no banned tactic on an
open goal.
-/

namespace Gnosis

/-- **Inductive invariant.** A property true at `0` and preserved by every step
    holds at all `n`. -/
theorem inductive_invariant (I : Nat → Prop) (init : I 0)
    (step : ∀ n, I n → I (n + 1)) : ∀ n, I n
  | 0 => init
  | n + 1 => step n (inductive_invariant I init step n)

/-- A transition system with an inductive safety invariant. -/
structure TransitionSystem where
  inv : Nat → Prop
  init : inv 0
  preserved : ∀ n, inv n → inv (n + 1)

/-- The invariant of a transition system holds at every step. -/
theorem ts_invariant_holds (ts : TransitionSystem) : ∀ n, ts.inv n :=
  inductive_invariant ts.inv ts.init ts.preserved

/-- Concrete instance: the doubling counter is always even. -/
theorem doubling_even (k : Nat) : (2 * k) % 2 = 0 := Nat.mul_mod_right 2 k

/-- A safety property: if the invariant excludes a bad predicate, the bad state is
    never reached. -/
theorem safety (ts : TransitionSystem) (bad : Nat → Prop)
    (excl : ∀ n, ts.inv n → ¬ bad n) (n : Nat) : ¬ bad n :=
  excl n (ts_invariant_holds ts n)

end Gnosis
