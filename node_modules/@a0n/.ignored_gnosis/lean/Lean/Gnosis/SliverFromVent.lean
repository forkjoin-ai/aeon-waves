import Init
/-!
# Sliver from vent — the sliver is one unit of vented heat

Every vent dissipates exactly one unit of heat, and that unit becomes the sliver
that keeps weight positive.  The finite core proves the chain vent → heat → sliver
→ positivity: a vent produces unit heat, a generation's heat is its vent count, and
the heat-augmented weight `rounds - rejection + heat` is positive whenever heat is.

The original spanned the Buleyean probability/logic/pulse modules; here the finite
core is self-contained over `Nat`, every proof closing from `Init`.
-/

namespace Gnosis
namespace SliverFromVent

/-- A vent event. -/
structure VentEvent where
  pathId : Nat

/-- A vent dissipates one unit of heat. -/
def ventHeat (_event : VentEvent) : Nat := 1

/-- A vent's heat is exactly one. -/
theorem vent_heat_is_one (event : VentEvent) : ventHeat event = 1 := rfl

/-- A vent's heat is positive. -/
theorem vent_heat_positive (event : VentEvent) : 0 < ventHeat event := Nat.zero_lt_one

/-- A generation accumulates vents. -/
structure Generation where
  ventCount : Nat

/-- A generation's total heat is its vent count. -/
def Generation.totalHeat (g : Generation) : Nat := g.ventCount

theorem heat_equals_vents (g : Generation) : g.totalHeat = g.ventCount := rfl

/-- A generation that vented something is hot. -/
theorem generation_heat_positive (g : Generation) (h : 0 < g.ventCount) : 0 < g.totalHeat := h

/-- The heat-augmented weight. -/
def weightWithHeat (rounds rejections heat : Nat) : Nat := rounds - rejections + heat

/-- **The sliver is the heat:** with one unit of vent heat the weight is the usual
    `rounds - rejection + 1`. -/
theorem sliver_is_heat (rounds rejections : Nat) :
    weightWithHeat rounds rejections 1 = rounds - rejections + 1 := rfl

/-- The sliver equals the minimum vent heat. -/
theorem sliver_equals_minimum_heat : weightWithHeat 0 0 1 = ventHeat ⟨0⟩ := rfl

/-- Step 1: a vent produces heat. -/
theorem step1_vent_produces_heat (event : VentEvent) : 0 < ventHeat event := Nat.zero_lt_one

/-- Step 2: positive heat provides the sliver (positive augmented weight). -/
theorem step2_heat_provides_sliver (rounds rejections : Nat) :
    0 < weightWithHeat rounds rejections 1 := by
  show 0 < rounds - rejections + 1
  exact Nat.succ_pos _

/-- Step 3: the sliver guarantees positivity for any heat at least one. -/
theorem step3_sliver_guarantees_positivity (rounds rejections heat : Nat) (h : 1 ≤ heat) :
    0 < weightWithHeat rounds rejections heat := by
  show 0 < rounds - rejections + heat
  exact Nat.lt_of_lt_of_le h (Nat.le_add_left heat (rounds - rejections))

end SliverFromVent
end Gnosis
