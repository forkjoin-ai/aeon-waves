import Init
import Gnosis.WallingtonOptimality

/-!
# Server optimality — a fork/race/fold stack hits five optima at once

A server stack schedules a fork/race/fold DAG with the Wallington rotation and
matches transport at every layer.  Building on `WallingtonOptimality`, the finite
core proves the stack simultaneously achieves: critical-path makespan,
Pareto-optimal resourcing, strict dominance over sequential, speedup `β₁ + 1`, and
zero topological deficit — instantiated on the x-gnosis 4-stage / 3-path topology.

Init-only; every proof closes from `Init` (and the Init-only `WallingtonOptimality`)
with no banned tactic on an open goal.
-/

namespace Gnosis

/-- A server layer with fork/race/fold structure. -/
structure ServerLayer where
  pathCount : Nat
  streamCount : Nat
  hPathsPos : 0 < pathCount
  hStreamsPos : 0 < streamCount

/-- A layer has zero deficit when streams meet paths. -/
def ServerLayer.zeroDeficit (layer : ServerLayer) : Prop := layer.pathCount ≤ layer.streamCount

/-- The topological deficit of a layer: uncarried independent paths. -/
def layerDeficit (paths streams : Nat) : Nat := (paths - 1) - (streams - 1)

/-- A matched layer carries no deficit. -/
theorem matched_deficit_is_zero (p : Nat) : layerDeficit p p = 0 := Nat.sub_self (p - 1)

/-- A multi-layer server stack with genuine parallelism. -/
structure ServerStack where
  dag : ForkRaceFoldDAG
  layers : List ServerLayer
  hParallel : 2 ≤ dag.numPaths

/-- **Critical-path makespan.** -/
theorem server_critical_path_makespan (server : ServerStack) :
    rotationMakespan server.dag = server.dag.numStages * server.dag.maxStageTime :=
  rotation_makespan_bound server.dag

/-- **Lossless transport.** A zero-deficit layer carries no topological deficit. -/
theorem layer_lossless_of_zero_deficit (layer : ServerLayer) (hZero : layer.zeroDeficit) :
    layerDeficit layer.pathCount layer.streamCount = 0 :=
  Nat.sub_eq_zero_of_le (Nat.sub_le_sub_right hZero 1)

/-- Every zero-deficit layer of a stack is lossless. -/
theorem server_lossless_of_all_zero_deficit (layers : List ServerLayer)
    (hAll : ∀ l ∈ layers, ServerLayer.zeroDeficit l) :
    ∀ l ∈ layers, layerDeficit l.pathCount l.streamCount = 0 :=
  fun l hl => layer_lossless_of_zero_deficit l (hAll l hl)

/-- **Pareto optimality.** -/
theorem server_pareto_optimal (server : ServerStack) :
    sequentialResources < rotationResources server.dag ∧
    rotationMakespan server.dag < sequentialMakespan server.dag :=
  rotation_pareto_schedule server.dag server.hParallel

/-- **Speedup = β₁ + 1.** -/
theorem server_speedup_exact (server : ServerStack) :
    speedupFactor server.dag = server.dag.beta1 + 1 :=
  rotation_deficit_correlation server.dag (Nat.le_trans (by decide) server.hParallel)

/-- **Strict dominance** over sequential scheduling. -/
theorem server_dominates_sequential (server : ServerStack) :
    rotationMakespan server.dag < sequentialMakespan server.dag :=
  rotation_dominates_sequential server.dag server.hParallel

/-- **Zero deficit** at matched transport. -/
theorem server_zero_deficit (server : ServerStack) :
    layerDeficit server.dag.numPaths server.dag.numPaths = 0 :=
  matched_deficit_is_zero server.dag.numPaths

/-- **Server optimality.** All five optima hold simultaneously. -/
theorem server_optimality (server : ServerStack) :
    rotationMakespan server.dag = server.dag.numStages * server.dag.maxStageTime ∧
    (sequentialResources < rotationResources server.dag ∧
     rotationMakespan server.dag < sequentialMakespan server.dag) ∧
    rotationMakespan server.dag < sequentialMakespan server.dag ∧
    speedupFactor server.dag = server.dag.beta1 + 1 ∧
    layerDeficit server.dag.numPaths server.dag.numPaths = 0 :=
  ⟨server_critical_path_makespan server, server_pareto_optimal server,
   server_dominates_sequential server, server_speedup_exact server,
   server_zero_deficit server⟩

/-- Speedup is monotone in parallelism. -/
theorem server_speedup_monotone (s₁ s₂ : ServerStack)
    (hMore : s₁.dag.numPaths ≤ s₂.dag.numPaths) :
    speedupFactor s₁.dag ≤ speedupFactor s₂.dag := hMore

/-- The x-gnosis topology: 4 stages, 3 racing paths (cache | mmap | disk). -/
def xgnosisDAG : ForkRaceFoldDAG where
  numStages := 4
  numPaths := 3
  maxStageTime := 1
  hStagesPos := by decide
  hPathsPos := by decide
  hTimePos := by decide

theorem xgnosis_speedup : speedupFactor xgnosisDAG = 3 := rfl
theorem xgnosis_beta1 : xgnosisDAG.beta1 = 2 := rfl
theorem xgnosis_makespan : rotationMakespan xgnosisDAG = 4 := rfl
theorem xgnosis_sequential : sequentialMakespan xgnosisDAG = 12 := rfl

/-- The x-gnosis optimality certificate. -/
theorem xgnosis_optimality :
    rotationMakespan xgnosisDAG = 4 ∧
    rotationMakespan xgnosisDAG < sequentialMakespan xgnosisDAG ∧
    speedupFactor xgnosisDAG = 3 ∧
    layerDeficit xgnosisDAG.numPaths xgnosisDAG.numPaths = 0 :=
  ⟨rfl, by decide, rfl, matched_deficit_is_zero 3⟩

end Gnosis
