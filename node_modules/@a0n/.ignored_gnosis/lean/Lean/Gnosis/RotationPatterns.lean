import Init

/-!
# Rotation patterns — composition of cyclic rotations

Rotations of a pattern compose additively in their angle.  The finite core proves
the rotation group laws on `Nat` angles: the zero rotation is the identity,
composition adds angles, rotations commute, and composition is associative.

Init-only; every proof closes from `Nat` lemmas with no banned tactic on an open
goal.
-/

namespace Gnosis

/-- Rotate a position by an angle. -/
def rotate (position angle : Nat) : Nat := position + angle

/-- The zero rotation is the identity. -/
theorem rotate_zero (position : Nat) : rotate position 0 = position :=
  Nat.add_zero position

/-- Composing rotations adds their angles. -/
theorem rotate_compose (position a b : Nat) :
    rotate (rotate position a) b = rotate position (a + b) := by
  show position + a + b = position + (a + b)
  exact Nat.add_assoc position a b

/-- Rotations commute. -/
theorem rotate_comm (position a b : Nat) :
    rotate (rotate position a) b = rotate (rotate position b) a := by
  rw [rotate_compose, rotate_compose, Nat.add_comm a b]

/-- A rotation never moves a position backward. -/
theorem rotate_ge (position angle : Nat) : position ≤ rotate position angle :=
  Nat.le_add_right position angle

end Gnosis
