import Init

/-!
# Seven Laws predictions — the Buleyean laws instantiated as predictions

Each falsifiable prediction is an instance of a Buleyean law: no theory is ever
fully disproven (positivity), confidence is bounded (`≤ rounds + 1`), a crash
sharpens the market (concentration), instruments with more dimensions than channels
cast shadows (deficit), and restructuring conserves the total.

The original mapped many domains into `BuleyeanSpace`; here the finite core is
self-contained over `Nat`, every proof closing from `Init`.
-/

namespace Gnosis
namespace SevenLawsPredictions

/-- A Buleyean space of competing hypotheses. -/
structure BuleyeanSpace where
  rounds : Nat
  rejection : Nat → Nat
  bounded : ∀ i, rejection i ≤ rounds

def BuleyeanSpace.weight (bs : BuleyeanSpace) (i : Nat) : Nat := bs.rounds - bs.rejection i + 1

/-- **No theory is ever fully disproven** (positivity). -/
theorem prediction_no_theory_fully_disproven (bs : BuleyeanSpace) (i : Nat) :
    1 ≤ bs.weight i := Nat.le_add_left 1 (bs.rounds - bs.rejection i)

/-- **Confidence is bounded** by `rounds + 1`. -/
theorem prediction_ai_confidence_bounded (bs : BuleyeanSpace) (i : Nat) :
    bs.weight i ≤ bs.rounds + 1 :=
  Nat.add_le_add_right (Nat.sub_le bs.rounds (bs.rejection i)) 1

/-- **A crash improves the market** (concentration): more-rejected options weigh less. -/
theorem prediction_crash_improves_markets (bs : BuleyeanSpace) (i j : Nat)
    (h : bs.rejection i ≤ bs.rejection j) : bs.weight j ≤ bs.weight i := by
  show bs.rounds - bs.rejection j + 1 ≤ bs.rounds - bs.rejection i + 1
  exact Nat.add_le_add_right (Nat.sub_le_sub_left h bs.rounds) 1

/-- **Instruments have shadows:** more dimensions than channels forces a deficit. -/
theorem prediction_instruments_have_shadows (dims channels : Nat) (h : channels < dims) :
    0 < dims - channels := Nat.sub_pos_of_lt h

/-- **Restructuring conserves the total:** eliminated plus remaining is the whole. -/
theorem prediction_restructuring_conserves {total eliminated : Nat} (h : eliminated ≤ total) :
    eliminated + (total - eliminated) = total := Nat.add_sub_cancel' h

end SevenLawsPredictions
end Gnosis
