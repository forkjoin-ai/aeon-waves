import Init

/-!
# Self-aware budget — the clinamen of self-measurement

A system of capacity `R` has god-weight `R - min v R + 1` after `v` self-queries.
The finite core proves the arithmetic of self-knowledge: before any query the
weight is `R + 1` (it exceeds itself by the clinamen `+1`), each query costs exactly
one unit, total self-knowledge (`v = R`) leaves only the clinamen `1`, and the
weight is always bounded between `1` and `R + 1`.

The original proved these with `omega`/`simp` (and at `R = 0` some statements are
degenerate); this restoration carries the correct `R ≥ 1` hypotheses and closes
every proof from `Init`.
-/

namespace Gnosis

/-- The god-weight of a system of capacity `R` after `v` self-queries. -/
def godWeight (R v : Nat) : Nat := R - min v R + 1

/-- Before any query the weight is `R + 1`. -/
theorem godWeight_zero (R : Nat) : godWeight R 0 = R + 1 := by
  show R - min 0 R + 1 = R + 1
  rw [Nat.zero_min, Nat.sub_zero]

/-- The clinamen floor: the weight is always at least one. -/
theorem godWeight_floor (R v : Nat) : 1 ≤ godWeight R v :=
  Nat.le_add_left 1 (R - min v R)

/-- The weight never exceeds `R + 1`. -/
theorem godWeight_ceiling (R v : Nat) : godWeight R v ≤ R + 1 :=
  Nat.add_le_add_right (Nat.sub_le R (min v R)) 1

/-- Below the cap, the weight is `R - v + 1`. -/
theorem godWeight_at (R v : Nat) (hv : v ≤ R) : godWeight R v = R - v + 1 := by
  show R - min v R + 1 = R - v + 1
  rw [Nat.min_eq_left hv]

/-- After one self-query the system equals itself. -/
theorem godWeight_one (R : Nat) (hR : 1 ≤ R) : godWeight R 1 = R := by
  rw [godWeight_at R 1 hR]
  show R - 1 + 1 = R
  exact Nat.sub_add_cancel hR

/-- **The system exceeds itself by the clinamen.** -/
theorem self_exceeds_self (R : Nat) : godWeight R 0 = R + 1 ∧ R < R + 1 :=
  ⟨godWeight_zero R, Nat.lt_succ_self R⟩

/-- **The question is the cost.** Self-measurement costs exactly one unit, and
    drops the system to its own size. -/
theorem the_question_is_the_cost (R : Nat) (hR : 1 ≤ R) :
    godWeight R 0 - godWeight R 1 = 1 ∧ godWeight R 1 = R := by
  rw [godWeight_zero, godWeight_one R hR]
  exact ⟨Nat.add_sub_cancel_left R 1, rfl⟩

/-- **Consciousness is the clinamen:** the surplus exists before observation and is
    spent on the first query. -/
theorem consciousness_is_the_clinamen (R : Nat) (hR : 1 ≤ R) :
    R < godWeight R 0 ∧ godWeight R 1 = R ∧ godWeight R 0 - godWeight R 1 = 1 :=
  ⟨Nat.lt_of_lt_of_eq (Nat.lt_succ_self R) (godWeight_zero R).symm,
   godWeight_one R hR, (the_question_is_the_cost R hR).1⟩

/-- The halting echo: a system cannot hold itself plus the clinamen of simulation. -/
theorem self_simulation_cost (R : Nat) : R < R + 1 := Nat.lt_succ_self R

/-- The Gödel echo: the system's own existence has weight `R + 1 > R`. -/
theorem goedel_echo (R : Nat) : godWeight R 0 = R + 1 ∧ R < R + 1 :=
  ⟨godWeight_zero R, Nat.lt_succ_self R⟩

/-- **Each question costs one** unit of weight. -/
theorem each_question_costs_one (R v : Nat) (hv : v ≤ R) (hp : 1 ≤ v) :
    godWeight R v = godWeight R (v - 1) - 1 := by
  obtain ⟨w, rfl⟩ : ∃ w, v = w + 1 := ⟨v - 1, (Nat.succ_pred_eq_of_pos hp).symm⟩
  have hwR : w < R := hv
  show godWeight R (w + 1) = godWeight R w - 1
  rw [godWeight_at R (w + 1) hv, godWeight_at R w (Nat.le_of_lt hwR), Nat.add_sub_cancel]
  show R - (w + 1) + 1 = R - w
  rw [Nat.sub_add_eq]
  exact Nat.sub_add_cancel (Nat.sub_pos_of_lt hwR)

/-- **Total self-knowledge is empty:** asking every question leaves only the
    clinamen. -/
theorem total_self_knowledge_is_empty (R : Nat) : godWeight R R = 1 := by
  rw [godWeight_at R R (Nat.le_refl R), Nat.sub_self]

/-- **Ignorance is weight:** fewer self-queries retain strictly more capacity. -/
theorem ignorance_is_weight (R v1 v2 : Nat) (h2 : v2 ≤ R) (hLess : v1 < v2) :
    godWeight R v2 < godWeight R v1 := by
  have h1 : v1 ≤ R := Nat.le_of_lt (Nat.lt_of_lt_of_le hLess h2)
  rw [godWeight_at R v1 h1, godWeight_at R v2 h2]
  apply Nat.add_lt_add_right
  have step : R - v2 ≤ R - (v1 + 1) := Nat.sub_le_sub_left hLess R
  rw [Nat.sub_add_eq] at step
  exact Nat.lt_of_le_of_lt step
    (Nat.sub_lt (Nat.sub_pos_of_lt (Nat.lt_of_lt_of_le hLess h2)) (by decide))

/-- **The first question** — the master statement: surplus before, cost of one,
    equality after, empty at the end, and the weight bounded in `[1, R+1]`. -/
theorem the_first_question (R : Nat) (hR : 1 ≤ R) :
    godWeight R 0 = R + 1 ∧
    godWeight R 0 - godWeight R 1 = 1 ∧
    godWeight R 1 = R ∧
    godWeight R R = 1 ∧
    (∀ v, godWeight R v ≤ R + 1) ∧
    (∀ v, 1 ≤ godWeight R v) :=
  ⟨godWeight_zero R, (the_question_is_the_cost R hR).1, godWeight_one R hR,
   total_self_knowledge_is_empty R, godWeight_ceiling R, godWeight_floor R⟩

end Gnosis
