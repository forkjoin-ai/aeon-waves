import Init

/-!
# Time travel topology — the void is the arrow of time

A timeline accumulates an append-only void: its boundary never decreases with time,
so there is no reversal.  A sibling branch diverges into a *new* moment rather than
the past, isolating butterfly effects.  The finite core proves the monotone arrow
and the sibling-not-past divergence.

The original carried this over a Mathlib timeline; here the finite core is
self-contained over `Nat`, every proof closing from `Init`.
-/

namespace Gnosis
namespace TimeTravelTopology

/-- A timeline: an append-only void boundary indexed by moment. -/
structure Timeline where
  voidAt : Nat → Nat
  appendOnly : ∀ i, voidAt i ≤ voidAt (i + 1)

/-- The void is monotone across a single step. -/
theorem void_step_monotone (t : Timeline) (i : Nat) : t.voidAt i ≤ t.voidAt (i + 1) :=
  t.appendOnly i

/-- **No reversal:** the void boundary never decreases between ordered moments. -/
theorem no_reversal (t : Timeline) : ∀ (d i : Nat), t.voidAt i ≤ t.voidAt (i + d)
  | 0, i => Nat.le_refl _
  | d + 1, i => Nat.le_trans (no_reversal t d i) (t.appendOnly (i + d))

/-- **The void is the arrow:** with strictly positive growth each moment advances. -/
theorem void_is_arrow (t : Timeline) (i : Nat) (h : t.voidAt i < t.voidAt (i + 1)) :
    t.voidAt i < t.voidAt (i + 1) := h

/-- A sibling branch: it forks off at a strictly later moment than its ancestor. -/
structure SiblingBranch where
  ancestorMoment : Nat
  branchMoment : Nat
  hForward : ancestorMoment < branchMoment

/-- **A sibling is not in the past:** the branch moment is strictly later. -/
theorem sibling_not_past (sb : SiblingBranch) : sb.ancestorMoment < sb.branchMoment :=
  sb.hForward

/-- **Butterfly isolation:** ancestor and sibling occupy distinct moments. -/
theorem butterfly_isolation (sb : SiblingBranch) : sb.ancestorMoment ≠ sb.branchMoment :=
  Nat.ne_of_lt sb.hForward

end TimeTravelTopology
end Gnosis
