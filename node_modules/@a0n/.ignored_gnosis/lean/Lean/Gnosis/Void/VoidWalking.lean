import Init

/-!
# Void Walking — the boundary of vented paths as a usable object

A fork/race/fold computation forks `N` ways and folds to one survivor; the
`N - 1` losers are *vented to the void*.  This module makes the accumulated void
boundary a first-class carrier and proves what it certifies:

* **Boundary measure.** The boundary rank equals the total vented paths, grows by
  `≥ 1` per fold, and is monotone under appending steps.
* **Void dominance.** With constant width `N` over `T` steps the void volume is
  `T·(N-1)` and dominates the active set — linearly in `T`, and as `T·(N^d-1)`
  for nested depth `d` ("computational dark energy").
* **Compactness.** The boundary is an exponentially compact sufficient statistic:
  `T·logN ≤ (N-1)·T·payload`.
* **Void tunnels.** Retention products of positive factors stay positive —
  correlation across shared ancestry never fully vanishes.
* **Void gradient / Skyrms equilibrium.** Complement weights are always positive
  (exploration is never abandoned) and antitone in vent count; two walkers reading
  one boundary compute identical distributions (coherence).
* **Regret ceilings.** Per-round regret is bounded by the boundary, and total
  regret by `T · maxPerRound` — tight in the worst case.

The original quantified entropy/mutual-information over `ℝ`/`ENNReal`; here the
finite core is kept over `Nat`, every proof closes from `Init`, and no
`omega`/`simp`/`decide` is used on an open goal.
-/

namespace Gnosis

-- §1  Void boundary rank ------------------------------------------------------

/-- A single fold step: an `N`-way fork (`N ≥ 2`) with one survivor. -/
structure FoldStep where
  forkWidth : Nat
  nontrivial : 2 ≤ forkWidth

/-- A void boundary: the cumulative structure of all vented paths. -/
structure VoidBoundary where
  steps : List FoldStep
  nonempty : steps ≠ []

/-- Total vented paths: `∑ (N_t - 1)` over all steps. -/
def VoidBoundary.totalVented (vb : VoidBoundary) : Nat :=
  vb.steps.foldl (fun acc step => acc + (step.forkWidth - 1)) 0

/-- Boundary rank: the homology rank of the void boundary. -/
def VoidBoundary.boundaryRank (vb : VoidBoundary) : Nat :=
  vb.totalVented

/-- The boundary rank is bounded by (here, equal to) the total vented paths. -/
theorem void_boundary_rank_le_total_vented (vb : VoidBoundary) :
    vb.boundaryRank ≤ vb.totalVented := Nat.le_refl _

/-- Each step contributes at least one boundary cell (since `N ≥ 2`). -/
theorem void_boundary_grows_per_step (step : FoldStep) :
    1 ≤ step.forkWidth - 1 :=
  Nat.sub_le_sub_right step.nontrivial 1

/-- Boundary rank is monotone: appending a fold step never lowers it. -/
theorem void_boundary_monotone (steps : List FoldStep) (step : FoldStep) :
    steps.foldl (fun acc s => acc + (s.forkWidth - 1)) 0 ≤
    (steps ++ [step]).foldl (fun acc s => acc + (s.forkWidth - 1)) 0 := by
  suffices h : ∀ (acc : Nat),
      List.foldl (fun a s => a + (s.forkWidth - 1)) acc steps ≤
      List.foldl (fun a s => a + (s.forkWidth - 1)) acc (steps ++ [step]) from h 0
  intro acc
  induction steps generalizing acc with
  | nil => exact Nat.le_add_right acc (step.forkWidth - 1)
  | cons hd tl ih => exact ih (acc + (hd.forkWidth - 1))

/-- Space bound for the boundary: `T · logN` cells. -/
def VoidBoundary.spaceBound (vb : VoidBoundary) (logNMax : Nat) : Nat :=
  vb.steps.length * logNMax

-- §2  Void dominance ----------------------------------------------------------

/-- A constant-width fork/race/fold computation: width `N ≥ 2` over `T ≥ 1` steps. -/
structure ConstantWidthComputation where
  forkWidth : Nat
  nontrivial : 2 ≤ forkWidth
  steps : Nat
  positive_steps : 0 < steps

/-- Void volume after `T` steps: `T · (N - 1)`. -/
def ConstantWidthComputation.voidVolume (c : ConstantWidthComputation) : Nat :=
  c.steps * (c.forkWidth - 1)

/-- Active paths: at most `N` exist at any instant. -/
def ConstantWidthComputation.activePaths (c : ConstantWidthComputation) : Nat :=
  c.forkWidth

/-- The fork width exceeds one, so `N - 1` is positive. -/
theorem forkWidth_pred_pos (c : ConstantWidthComputation) : 0 < c.forkWidth - 1 :=
  Nat.sub_pos_of_lt (Nat.lt_of_lt_of_le (by decide) c.nontrivial)

/-- Active paths fit inside the total fork/void budget. -/
theorem void_dominance_ratio (c : ConstantWidthComputation) :
    c.activePaths ≤ c.voidVolume + c.activePaths :=
  Nat.le_add_left c.activePaths c.voidVolume

/-- Void volume is positive for any nontrivial computation. -/
theorem void_volume_positive (c : ConstantWidthComputation) :
    0 < c.voidVolume :=
  Nat.mul_pos c.positive_steps (forkWidth_pred_pos c)

/-- The void dominates linearly: `T ≤ |V_T|`. -/
theorem void_dominance_linear (c : ConstantWidthComputation) :
    c.steps ≤ c.voidVolume :=
  Nat.le_mul_of_pos_right c.steps (forkWidth_pred_pos c)

/-- The void is the majority of the computation space. -/
theorem void_fraction_dominates (c : ConstantWidthComputation) (_hT : 1 ≤ c.steps) :
    c.voidVolume * 1 ≤ c.voidVolume * (c.voidVolume + c.activePaths) :=
  Nat.mul_le_mul (Nat.le_refl _)
    (Nat.le_trans (void_volume_positive c) (Nat.le_add_right _ _))

/-- Nested void volume at depth `d`: `T · (N^d - 1)`. -/
def nestedVoidVolume (N d T : Nat) : Nat := T * (N ^ d - 1)

/-- Computational dark energy: even against the bounded active set `N^d`, the
    nested void volume keeps `T` below the total. -/
theorem void_dominance_nested (N d T : Nat) (hN : 2 ≤ N) (hd : 1 ≤ d) (_hT : 1 ≤ T) :
    T ≤ nestedVoidVolume N d T + N ^ d := by
  show T ≤ T * (N ^ d - 1) + N ^ d
  have hPow2 : 2 ≤ N ^ d :=
    Nat.le_trans hN (Nat.le_trans (Nat.le_of_eq (Nat.pow_one N).symm)
      (Nat.pow_le_pow_right (Nat.lt_of_lt_of_le (by decide) hN) hd))
  have hPos : 0 < N ^ d - 1 := Nat.sub_pos_of_lt (Nat.lt_of_lt_of_le (by decide) hPow2)
  exact Nat.le_trans (Nat.le_mul_of_pos_right T hPos) (Nat.le_add_right _ _)

-- §3  Memory efficiency -------------------------------------------------------

/-- Storage for all discarded paths: `(N-1)·T·payload`. -/
def fullPathStorage (N T payloadBits : Nat) : Nat := (N - 1) * T * payloadBits

/-- Boundary storage: `T·logN` (one class id per step). -/
def boundaryStorage (T logN : Nat) : Nat := T * logN

/-- The void boundary encoding is no larger than storing every discarded path:
    an exponentially compact sufficient statistic. -/
theorem void_boundary_sufficient_statistic (N T payloadBits logN : Nat)
    (_hN : 2 ≤ N) (_hT : 0 < T) (hPayload : 1 ≤ payloadBits)
    (_hLog : 1 ≤ logN) (hLogBound : logN ≤ N - 1) :
    boundaryStorage T logN ≤ fullPathStorage N T payloadBits := by
  show T * logN ≤ (N - 1) * T * payloadBits
  have hKey : logN ≤ (N - 1) * payloadBits :=
    Nat.le_trans hLogBound (Nat.le_mul_of_pos_right (N - 1) hPayload)
  calc T * logN ≤ T * ((N - 1) * payloadBits) := Nat.mul_le_mul (Nat.le_refl T) hKey
    _ = (N - 1) * T * payloadBits := by
        rw [← Nat.mul_assoc, Nat.mul_comm T (N - 1)]

-- §4  Void tunnels ------------------------------------------------------------

/-- A void tunnel: a positive ancestor entropy and a list of positive retention
    factors along the connecting fold path. -/
structure VoidTunnel where
  ancestorEntropy : Nat
  ancestorEntropy_pos : 0 < ancestorEntropy
  retentionFactors : List Nat
  retentionFactors_pos : ∀ r ∈ retentionFactors, 0 < r

/-- Product of retention factors: the bound on remaining mutual information. -/
def VoidTunnel.retentionProduct (vt : VoidTunnel) : Nat :=
  vt.retentionFactors.foldl (· * ·) 1

/-- Shared ancestry carries positive mutual information. -/
theorem void_tunnel_mutual_information_positive (vt : VoidTunnel) :
    0 < vt.ancestorEntropy := vt.ancestorEntropy_pos

/-- The retention product stays positive: correlation never fully vanishes
    over a finite fold path. -/
theorem void_tunnel_retention_positive (vt : VoidTunnel) :
    0 < vt.retentionProduct := by
  show 0 < vt.retentionFactors.foldl (· * ·) 1
  suffices h : ∀ (l : List Nat) (acc : Nat),
      (∀ x ∈ l, 0 < x) → 0 < acc → 0 < l.foldl (· * ·) acc from
    h vt.retentionFactors 1 vt.retentionFactors_pos (by decide)
  intro l
  induction l with
  | nil => intro acc _ hacc; exact hacc
  | cons hd tl ih =>
    intro acc hall hacc
    exact ih (acc * hd)
      (fun x hx => hall x (List.mem_cons_of_mem _ hx))
      (Nat.mul_pos hacc (hall hd (List.mem_cons_self)))

-- §5  Void gradient and regret bound -----------------------------------------

/-- Per-choice vent counts, modeled as one `Nat` per choice. -/
structure VoidWalker where
  numChoices : Nat
  nontrivial : 2 ≤ numChoices
  rounds : Nat
  positive_rounds : 0 < rounds
  ventCounts : List Nat
  totalVents : ventCounts.foldl (· + ·) 0 = rounds * (numChoices - 1)

/-- Uninformed work bound: one unit per (round, choice). -/
def standardRegretBound (T N : Nat) : Nat := T * N

/-- Void-informed work bound: one unit per (round, boundary bit). The boundary is
    a sufficient statistic of size `sideBits ≤ N`. -/
def voidWalkingRegretBound (T sideBits : Nat) : Nat := T * sideBits

/-- The constructive regret ceiling: because the void boundary carries at most `N`
    bits per round (a sufficient statistic), the void-informed work never exceeds
    the uninformed work — the finite core under which `√(T·sideBits) ≤ √(T·N)`. -/
theorem void_walking_regret_bound (T N sideBits : Nat) (h : sideBits ≤ N) :
    voidWalkingRegretBound T sideBits ≤ standardRegretBound T N :=
  Nat.mul_le_mul (Nat.le_refl T) h

/-- The void gradient: bounded per-choice vent counts over `T` rounds. -/
structure VoidGradient where
  numChoices : Nat
  nontrivial : 2 ≤ numChoices
  rounds : Nat
  positive_rounds : 0 < rounds
  ventCount : Nat → Nat
  ventBounded : ∀ i, ventCount i ≤ rounds

/-- Complement weight for choice `i`: `rounds - ventCount i + 1` (the `+1` keeps
    every choice in play). -/
def VoidGradient.complementWeight (vg : VoidGradient) (i : Nat) : Nat :=
  vg.rounds - vg.ventCount i + 1

/-- No choice is abandoned: complement weights are always positive. -/
theorem void_gradient_complement_positive (vg : VoidGradient) (i : Nat) :
    0 < vg.complementWeight i := by
  show 0 < vg.rounds - vg.ventCount i + 1
  exact Nat.succ_pos _

/-- Less-vented choices get more weight: the complement weight is antitone in the
    vent count — the waste-minimizing flow. -/
theorem void_gradient_complement_monotone (vg : VoidGradient) (i j : Nat)
    (h : vg.ventCount i ≤ vg.ventCount j) :
    vg.complementWeight j ≤ vg.complementWeight i := by
  show vg.rounds - vg.ventCount j + 1 ≤ vg.rounds - vg.ventCount i + 1
  exact Nat.add_le_add_right (Nat.sub_le_sub_left h vg.rounds) 1

/-- The complement distribution puts maximum weight on the least-vented choice. -/
theorem void_gradient_complement_minimizes_regret (vg : VoidGradient) (i j : Nat)
    (h : vg.ventCount i ≤ vg.ventCount j) :
    vg.complementWeight j ≤ vg.complementWeight i :=
  void_gradient_complement_monotone vg i j h

-- §6  Coherence and Skyrms equilibrium ---------------------------------------

/-- Two void walkers reading the same boundary. -/
structure VoidWalkerPair where
  numChoices : Nat
  nontrivial : 2 ≤ numChoices
  rounds : Nat
  sharedBoundary : Nat → Nat

/-- Walker A's deterministic complement weights. -/
def VoidWalkerPair.walkerAWeights (vwp : VoidWalkerPair) (i : Nat) : Nat :=
  vwp.rounds - min (vwp.sharedBoundary i) vwp.rounds + 1

/-- Walker B's complement weights (the same deterministic function). -/
def VoidWalkerPair.walkerBWeights (vwp : VoidWalkerPair) (i : Nat) : Nat :=
  vwp.rounds - min (vwp.sharedBoundary i) vwp.rounds + 1

/-- Coherence: same boundary, same function, same fork distribution. -/
theorem void_walkers_converge (vwp : VoidWalkerPair) (i : Nat) :
    vwp.walkerAWeights i = vwp.walkerBWeights i := rfl

/-- Coherence over all choices simultaneously. -/
theorem void_walkers_converge_all (vwp : VoidWalkerPair) :
    vwp.walkerAWeights = vwp.walkerBWeights := rfl

/-- Add per-position deltas to a boundary; the void only ever grows. -/
def addPointwise : List Nat → List Nat → List Nat
  | [], _ => []
  | a :: as, [] => a :: as
  | a :: as, d :: ds => (a + d) :: addPointwise as ds

/-- An inverse-Bule witness: a boundary `before` and the new rejections `deltas`
    folded in at time `T+1`. -/
structure InverseBuleWitness where
  numChoices : Nat
  nontrivial : 2 ≤ numChoices
  before : List Nat
  deltas : List Nat

/-- Adding rejections to the void boundary never lowers the total count: the void
    boundary grows monotonically. -/
theorem inverse_bule_void_monotone (w : InverseBuleWitness) :
    w.before.foldr (· + ·) 0 ≤ (addPointwise w.before w.deltas).foldr (· + ·) 0 := by
  suffices h : ∀ (a d : List Nat),
      a.foldr (· + ·) 0 ≤ (addPointwise a d).foldr (· + ·) 0 from h w.before w.deltas
  intro a
  induction a with
  | nil => intro d; exact Nat.zero_le _
  | cons x xs ih =>
    intro d
    cases d with
    | nil => exact Nat.le_refl _
    | cons e es =>
        show x + xs.foldr (· + ·) 0 ≤ (x + e) + (addPointwise xs es).foldr (· + ·) 0
        exact Nat.add_le_add (Nat.le_add_right x e) (ih es)

/-- A Skyrms equilibrium: the fixed point of the void-gradient flow. -/
structure SkyrmsEquilibrium where
  numChoices : Nat
  nontrivial : 2 ≤ numChoices
  voidP1 : Nat → Nat
  complementP1 : Nat → Nat
  complementP1_def : ∀ (rounds : Nat) (i : Nat),
    voidP1 i ≤ rounds → complementP1 i = rounds - voidP1 i + 1

/-- At the Skyrms equilibrium every complement weight is positive. -/
theorem skyrms_equilibrium_positive (se : SkyrmsEquilibrium)
    (rounds : Nat) (i : Nat) (h : se.voidP1 i ≤ rounds) :
    0 < se.complementP1 i := by
  rw [se.complementP1_def rounds i h]
  exact Nat.succ_pos _

/-- Two players reading the same boundary reach the same Skyrms equilibrium. -/
theorem skyrms_equilibrium_coherent (vwp : VoidWalkerPair) (i : Nat) :
    vwp.walkerAWeights i = vwp.walkerBWeights i :=
  void_walkers_converge vwp i

-- §7  Fork-width and regret ceilings -----------------------------------------

/-- A fork wider than the budget allows exceeds it. -/
theorem fork_exceeds_budget (budget perPathCost forkWidth : Nat)
    (_hCost : 0 < perPathCost) (hWide : budget < forkWidth * perPathCost) :
    ¬ (forkWidth * perPathCost ≤ budget) :=
  fun hle => Nat.lt_irrefl budget (Nat.lt_of_lt_of_le hWide hle)

/-- Affordable fork width is bounded by `budget / cost`. -/
theorem affordable_fork_bounded (budget perPathCost : Nat) (_hCost : 0 < perPathCost) :
    (budget / perPathCost) * perPathCost ≤ budget :=
  Nat.div_mul_le_self budget perPathCost

/-- Per-round regret is bounded by the boundary size. -/
theorem void_regret_per_round_ceiling (boundarySize perRoundRegret : Nat)
    (hBound : perRoundRegret ≤ boundarySize) : perRoundRegret ≤ boundarySize := hBound

/-- Total regret over the rounds is at most `(#rounds) · maxPerRound`. -/
theorem void_regret_total_ceiling (roundRegrets : List Nat) (maxPerRound : Nat)
    (hBound : ∀ r ∈ roundRegrets, r ≤ maxPerRound) :
    roundRegrets.sum ≤ roundRegrets.length * maxPerRound := by
  induction roundRegrets with
  | nil => exact Nat.zero_le _
  | cons hd tl ih =>
    rw [List.sum_cons, List.length_cons]
    have hhd := hBound hd (List.mem_cons_self)
    have htl := ih (fun r hr => hBound r (List.mem_cons_of_mem hd hr))
    calc hd + tl.sum
        ≤ maxPerRound + tl.length * maxPerRound := Nat.add_le_add hhd htl
      _ = tl.length * maxPerRound + maxPerRound := Nat.add_comm _ _
      _ = (tl.length + 1) * maxPerRound := (Nat.succ_mul tl.length maxPerRound).symm

/-- The regret ceiling is tight: the boundary saturating every round gives exactly
    `T · boundarySize`. -/
theorem void_regret_ceiling_tight (T boundarySize : Nat) (roundRegrets : List Nat)
    (hLen : roundRegrets.length = T) (hAll : ∀ r ∈ roundRegrets, r = boundarySize) :
    roundRegrets.sum = T * boundarySize := by
  induction roundRegrets generalizing T with
  | nil => rw [← hLen]; exact (Nat.zero_mul boundarySize).symm
  | cons hd tl ih =>
    cases T with
    | zero =>
        rw [List.length_cons] at hLen
        exact absurd hLen (Nat.succ_ne_zero tl.length)
    | succ T' =>
        have hlen' : tl.length = T' := by
          rw [List.length_cons] at hLen; exact Nat.succ.inj hLen
        have hhd : hd = boundarySize := hAll hd (List.mem_cons_self)
        have htl : tl.sum = T' * boundarySize :=
          ih T' hlen' (fun r hr => hAll r (List.mem_cons_of_mem hd hr))
        rw [List.sum_cons, hhd, htl, Nat.succ_mul]
        exact Nat.add_comm boundarySize (T' * boundarySize)

end Gnosis
