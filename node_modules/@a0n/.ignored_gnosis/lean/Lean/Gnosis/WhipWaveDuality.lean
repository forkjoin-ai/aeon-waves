import Init

/-!
# Whip wave duality — a taper folds tension into speed

A whip tapers: a fold concentrates a conserved tension into a thinner segment,
raising the wave speed until the snap.  Modeling wave-speed-squared as
`tension / rho`, the finite core proves the fold conserves tension, a thinner
segment is no slower (monotone in `1/rho`), and a snap sequence stores one bit per
snap.

The original used `ℚ`; here the finite core is over `Nat`, every proof closing from
`Init`.
-/

namespace Gnosis
namespace WhipWaveDuality

/-- A taper segment: a tension carried at a linear density `rho`. -/
structure TaperSegment where
  tension : Nat
  rho : Nat
  hRhoPos : 0 < rho

/-- Wave-speed-squared: tension per unit density. -/
def TaperSegment.waveSpeedSq (seg : TaperSegment) : Nat := seg.tension / seg.rho

/-- **The fold conserves tension:** refolding at the same tension keeps it. -/
theorem fold_conserves_tension (T : Nat) (r1 r2 : Nat) (h1 : 0 < r1) (h2 : 0 < r2) :
    (TaperSegment.mk T r1 h1).tension = (TaperSegment.mk T r2 h2).tension := rfl

/-- **A thinner taper is no slower:** lower density gives at least the wave speed. -/
theorem fold_increases_wave_speed (T : Nat) {r1 r2 : Nat} (h1 : 0 < r1) (h2 : 0 < r2)
    (hThinner : r2 ≤ r1) :
    (TaperSegment.mk T r1 h1).waveSpeedSq ≤ (TaperSegment.mk T r2 h2).waveSpeedSq :=
  Nat.div_le_div_left hThinner h2

/-- A snap sequence stores one bit per snap. -/
def snapSequenceBits (snaps : List Bool) : Nat := snaps.length

/-- **The snap sequence capacity** is exactly its length in bits. -/
theorem snap_sequence_capacity (snaps : List Bool) : snapSequenceBits snaps = snaps.length := rfl

/-- Appending snaps never lowers the stored capacity. -/
theorem snap_capacity_monotone (a b : List Bool) :
    snapSequenceBits a ≤ snapSequenceBits (a ++ b) := by
  show a.length ≤ (a ++ b).length
  rw [List.length_append]
  exact Nat.le_add_right _ _

end WhipWaveDuality
end Gnosis
