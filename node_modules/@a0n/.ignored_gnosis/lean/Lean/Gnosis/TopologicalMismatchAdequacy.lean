import Init

/-!
# Topological mismatch adequacy — when transport realizes a workload losslessly

A fork/race/fold workload of `pathCount` paths is realized over `transportStreams`
streams.  The realization is **lossless** when streams meet the paths, **tight**
when they match exactly, and carries a topological deficit `pathCount - streams`.
The finite core proves the deficit characterizations: zero deficit iff stream
capacity suffices, positive deficit iff streams are short, and the matched
realization is tight and lossless.

The original threaded `DeficitCapacity`; here the finite core is self-contained
over `Nat`, every proof closing from `Init`.
-/

namespace Gnosis
namespace TopologicalMismatchAdequacy

/-- A fork/race/fold workload. -/
structure FRFWorkload where
  pathCount : Nat

/-- A realization is lossless when transport meets the paths. -/
def lossless (W : FRFWorkload) (transportStreams : Nat) : Prop := W.pathCount ≤ transportStreams

/-- A realization is tight when transport matches the paths exactly. -/
def tight (W : FRFWorkload) (transportStreams : Nat) : Prop := transportStreams = W.pathCount

/-- The topological deficit of a realization. -/
def topologicalDeficit (W : FRFWorkload) (transportStreams : Nat) : Nat :=
  W.pathCount - transportStreams

theorem topologicalDeficit_eq_path_minus_stream (W : FRFWorkload) (transportStreams : Nat) :
    topologicalDeficit W transportStreams = W.pathCount - transportStreams := rfl

/-- **Zero deficit iff stream capacity suffices.** -/
theorem deficit_zero_iff_stream_capacity (W : FRFWorkload) (transportStreams : Nat) :
    topologicalDeficit W transportStreams = 0 ↔ W.pathCount ≤ transportStreams :=
  Nat.sub_eq_zero_iff_le

/-- **Positive deficit iff streams are short.** -/
theorem positive_deficit_iff_stream_shortage (W : FRFWorkload) (transportStreams : Nat) :
    0 < topologicalDeficit W transportStreams ↔ transportStreams < W.pathCount := by
  constructor
  · intro h
    rcases Nat.lt_or_ge transportStreams W.pathCount with hlt | hge
    · exact hlt
    · exact absurd ((deficit_zero_iff_stream_capacity W transportStreams).mpr hge)
        (Nat.pos_iff_ne_zero.mp h)
  · exact Nat.sub_pos_of_lt

/-- The matched realization is lossless. -/
theorem lossless_tightLosslessRealization (W : FRFWorkload) : lossless W W.pathCount :=
  Nat.le_refl W.pathCount

/-- The matched realization is tight. -/
theorem tight_tightLosslessRealization (W : FRFWorkload) : tight W W.pathCount := rfl

/-- The matched realization has zero deficit. -/
theorem tight_zero_deficit (W : FRFWorkload) : topologicalDeficit W W.pathCount = 0 :=
  Nat.sub_self W.pathCount

end TopologicalMismatchAdequacy
end Gnosis
