import Init

/-!
# Publication bias — the file drawer and the God Formula

Publication bias is the gap between the effects in the file drawer and those in
print.  Through the god-weight `R - min v R + 1`, the finite core proves the
arithmetic: more nulls leave less weight (replication gap), pre-registration makes
weight-plus-nulls conserve to `R + 1`, and a correction recovers `R - v + 1`.

The original used `omega`/`native_decide`; this restoration closes from `Init`.
-/

namespace Gnosis
namespace PublicationBias

/-- The god-weight of `R` studies with `v` nulls. -/
def godWeight (R v : Nat) : Nat := R - min v R + 1

/-- Below the cap, the weight is `R - v + 1`. -/
theorem godWeight_at (R v : Nat) (hv : v ≤ R) : godWeight R v = R - v + 1 := by
  show R - min v R + 1 = R - v + 1
  rw [Nat.min_eq_left hv]

theorem godWeight_zero (R : Nat) : godWeight R 0 = R + 1 := by
  show R - min 0 R + 1 = R + 1
  rw [Nat.zero_min, Nat.sub_zero]

/-- **File drawer.** The bias cancels in the weight but the denominator does not:
    a censored set of 40 studies shows the same weight as the full 100. -/
theorem file_drawer : godWeight 100 60 = 41 ∧ godWeight 40 0 = 41 := ⟨by decide, by decide⟩

/-- **Replication crisis.** Inflated publication (95% positive) shows far less
    weight than the true 70% null rate. -/
theorem replication_crisis :
    godWeight 1000 700 = 301 ∧ godWeight 1000 950 = 51 ∧
    godWeight 1000 950 < godWeight 1000 700 := ⟨by decide, by decide, by decide⟩

/-- **P-hacking.** Two or more tests give at least one extra fork path. -/
theorem p_hacking_inflation (numTests : Nat) (hTests : 2 ≤ numTests) :
    1 ≤ numTests - 1 :=
  Nat.sub_le_sub_right hTests 1

/-- **Funnel asymmetry.** Missing studies enlarge the true denominator. -/
theorem funnel_asymmetry (published missing : Nat) (hMissing : 1 ≤ missing) :
    published < published + missing :=
  Nat.lt_add_of_pos_right hMissing

/-- The correction restores the true weight `R - v + 1`. -/
theorem correction (R v : Nat) (hv : v ≤ R) : godWeight R v = R - v + 1 :=
  godWeight_at R v hv

/-- **Pre-registration** makes weight plus nulls conserve to `R + 1`. -/
theorem pre_registration (R : Nat) : ∀ v, v ≤ R → godWeight R v + v = R + 1 := by
  intro v hv
  rw [godWeight_at R v hv]
  show R - v + 1 + v = R + 1
  rw [Nat.add_right_comm, Nat.sub_add_cancel hv]

/-- **Master.** The weight collapses the bias, empties at full nulls, and stays
    above the clinamen floor. -/
theorem publication_bias_master (R : Nat) :
    (∀ v, v ≤ R → godWeight R v = godWeight (R - v) 0) ∧
    godWeight R R = 1 ∧ (∀ v, 1 ≤ godWeight R v) := by
  refine ⟨?_, ?_, ?_⟩
  · intro v hv; rw [godWeight_at R v hv, godWeight_zero]
  · rw [godWeight_at R R (Nat.le_refl R), Nat.sub_self]
  · intro v; exact Nat.le_add_left 1 (R - min v R)

end PublicationBias
end Gnosis
