import Init

/-!
# Hypergraph interpretation mapping — layers map to their node sets

An interpretation layer of a hypergraph is mapped to its node set; its complexity
is nodes plus hyperedges.  The finite core proves the mapping preserves the node
count, that nodes bound the complexity, and that complexity is additive across the
node/edge split.

Init-only; every proof closes from `Nat` lemmas with no banned tactic on an open
goal.
-/

namespace Gnosis

/-- An interpretation layer: nodes and hyperedges. -/
structure InterpretationLayer where
  nodes : Nat
  hyperedges : Nat

/-- The layer's complexity. -/
def InterpretationLayer.complexity (l : InterpretationLayer) : Nat := l.nodes + l.hyperedges

/-- The interpretation mapping preserves the node set. -/
theorem layer_mapping_exists (l : InterpretationLayer) :
    (InterpretationLayer.mk l.nodes l.hyperedges).nodes = l.nodes := rfl

/-- Nodes bound the complexity. -/
theorem nodes_le_complexity (l : InterpretationLayer) : l.nodes ≤ l.complexity :=
  Nat.le_add_right l.nodes l.hyperedges

/-- Hyperedges bound the complexity. -/
theorem hyperedges_le_complexity (l : InterpretationLayer) : l.hyperedges ≤ l.complexity :=
  Nat.le_add_left l.hyperedges l.nodes

/-- An edge-free layer's complexity is its node count. -/
theorem edgeless_complexity (l : InterpretationLayer) (h : l.hyperedges = 0) :
    l.complexity = l.nodes := by
  show l.nodes + l.hyperedges = l.nodes
  rw [h, Nat.add_zero]

end Gnosis
