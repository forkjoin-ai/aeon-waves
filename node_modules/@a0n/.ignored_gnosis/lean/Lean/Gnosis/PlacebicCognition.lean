import Init

/-!
# Placebic cognition -- finite witness for the Langer copy-machine study

This module encodes the supplied compliance percentages from Langer, Blank, and
Chanowitz's copy-machine experiment as a bounded cognitive-control witness.  It
does not claim a universal law of psychology.  It proves the finite pattern the
experiment exhibits: under a low-cost favor, the syntactic reason cue carries
nearly the same compliance as the semantic reason; under a high-cost favor, the
placebic cue collapses to the request-only baseline while the semantic reason
retains positive lift.

The cognitive reading is thresholded attention: cheap interactions admit a
script gate, costly interactions force semantic inspection.
-/

namespace Gnosis
namespace PlacebicCognition

/-- The manipulated favor size in pages. -/
inductive FavorSize where
  | small
  | large
deriving DecidableEq

/-- The manipulated request form. -/
inductive RequestCue where
  | requestOnly
  | placebicReason
  | realReason
deriving DecidableEq

/-- Percent compliance as reported in the prompt's experimental table. -/
def compliancePct : FavorSize -> RequestCue -> Nat
  | .small, .requestOnly => 60
  | .small, .placebicReason => 93
  | .small, .realReason => 94
  | .large, .requestOnly => 24
  | .large, .placebicReason => 24
  | .large, .realReason => 42

/-- Page cost used as the attention-threshold proxy. -/
def pageCost : FavorSize -> Nat
  | .small => 5
  | .large => 20

/-- The finite attention threshold separating script gate from semantic inspection. -/
def attentionThreshold : Nat := 10

/-- Low-cost interactions can be handled by the script gate. -/
def scriptGate (size : FavorSize) : Prop :=
  pageCost size ≤ attentionThreshold

/-- High-cost interactions force semantic inspection. -/
def semanticInspection (size : FavorSize) : Prop :=
  attentionThreshold < pageCost size

/-- Compliance lift against the request-only baseline for the same favor size. -/
def cueLift (size : FavorSize) (cue : RequestCue) : Nat :=
  compliancePct size cue - compliancePct size .requestOnly

/-- Difference between the semantic reason and the placebic reason. -/
def semanticPremium (size : FavorSize) : Nat :=
  compliancePct size .realReason - compliancePct size .placebicReason

/-- Symmetric natural-number difference for finite percentage comparisons. -/
def absDiff (a b : Nat) : Nat := (a - b) + (b - a)

/--
Epistemic frame for a conversational cue.

`tracksTruth` records whether the cue remains answerable to truth; `addsTaskInfo`
records whether it reduces the receiver's task uncertainty; `speakerTruthIndifferent`
captures the Frankfurt-style bullshit axis; `receiverSuppliesStandingWave`
captures the listener-side completion that turns a structurally valid but
uninformative cue into a felt reason.
-/
structure CueEpistemicFrame where
  tracksTruth : Bool
  addsTaskInfo : Bool
  speakerTruthIndifferent : Bool
  receiverSuppliesStandingWave : Bool
deriving DecidableEq, Repr

/-- The copy-machine placebic reason: true in form, empty for task information. -/
def copyMachinePlacebicFrame : CueEpistemicFrame :=
  { tracksTruth := true
    addsTaskInfo := false
    speakerTruthIndifferent := false
    receiverSuppliesStandingWave := true }

/-- A Frankfurt-style bullshit frame: task-empty and indifferent to truth. -/
def frankfurtBullshitFrame : CueEpistemicFrame :=
  { tracksTruth := false
    addsTaskInfo := false
    speakerTruthIndifferent := true
    receiverSuppliesStandingWave := false }

/-- Truth-filled structural vacuum placebo: true, not useful, completed by the receiver. -/
def truthFilledStructuralVacuumPlacebo (frame : CueEpistemicFrame) : Prop :=
  frame.tracksTruth = true ∧
  frame.addsTaskInfo = false ∧
  frame.speakerTruthIndifferent = false ∧
  frame.receiverSuppliesStandingWave = true

/-- Veridical sway: the compact name for truth-filled structural vacuum placebo. -/
def veridicalSway (frame : CueEpistemicFrame) : Prop :=
  truthFilledStructuralVacuumPlacebo frame

/-- Frankfurt-style bullshit: the speaker is indifferent to truth while adding no task information. -/
def frankfurtBullshit (frame : CueEpistemicFrame) : Prop :=
  frame.speakerTruthIndifferent = true ∧ frame.addsTaskInfo = false

/--
Local classifier for the next bullshit taxonomy.

`arguedUsefulReason` models a reason that tracks truth, drains the question, and
adds task information. `veridicalSway` models the copy-machine placebic cue.
`conversationalDodgeball` reserves the unresolved/refinement space from the
conversational dodgeball witnesses. `frankfurtBullshitPhantom` reserves the
truth-indifferent phantom-crossing surface.
-/
inductive CueClass where
  | arguedUsefulReason
  | veridicalSway
  | conversationalDodgeball
  | frankfurtBullshitPhantom
deriving DecidableEq, Repr

/-- Runtime evaluation knobs used by the finite cue classifier. -/
structure CueEvaluation where
  frame : CueEpistemicFrame
  closureDisciplined : Bool
  semanticDrain : Bool
  phantomCrossing : Bool
deriving DecidableEq, Repr

/-- A task-useful reason in the local taxonomy. -/
def arguedUsefulReasonFrame : CueEpistemicFrame :=
  { tracksTruth := true
    addsTaskInfo := true
    speakerTruthIndifferent := false
    receiverSuppliesStandingWave := false }

/-- A bare request or structural vacuum with no receiver-side standing wave. -/
def noReasonStructuralVacuumFrame : CueEpistemicFrame :=
  { tracksTruth := true
    addsTaskInfo := false
    speakerTruthIndifferent := false
    receiverSuppliesStandingWave := false }

/-- A local unresolved dodgeball-like cue: visible, but not closure. -/
def unresolvedDodgeballFrame : CueEpistemicFrame :=
  noReasonStructuralVacuumFrame

/-- Canonical evaluation for a task-useful argued reason. -/
def arguedUsefulReasonEvaluation : CueEvaluation :=
  { frame := arguedUsefulReasonFrame
    closureDisciplined := true
    semanticDrain := true
    phantomCrossing := false }

/-- Canonical evaluation for the copy-machine placebic reason. -/
def copyMachinePlacebicEvaluation : CueEvaluation :=
  { frame := copyMachinePlacebicFrame
    closureDisciplined := false
    semanticDrain := false
    phantomCrossing := false }

/-- Canonical evaluation for an unresolved conversational dodgeball residue. -/
def unresolvedDodgeballEvaluation : CueEvaluation :=
  { frame := unresolvedDodgeballFrame
    closureDisciplined := false
    semanticDrain := false
    phantomCrossing := false }

/-- Canonical evaluation for truth-indifferent phantom bullshit. -/
def frankfurtBullshitEvaluation : CueEvaluation :=
  { frame := frankfurtBullshitFrame
    closureDisciplined := false
    semanticDrain := false
    phantomCrossing := true }

/-- One bit of task information in this finite model; zero means structural vacuum. -/
def taskInformationGain (frame : CueEpistemicFrame) : Nat :=
  match frame.addsTaskInfo with
  | true => 1
  | false => 0

/-- Receiver-side search cost: a supplied standing wave is cheaper to settle. -/
def standingWaveSearchCost (frame : CueEpistemicFrame) : Nat :=
  match frame.receiverSuppliesStandingWave with
  | true => 1
  | false => 5

/-- Phantom-crossing cost reserved for truth-indifferent bullshit surfaces. -/
def phantomCrossingCost (evaluation : CueEvaluation) : Nat :=
  match evaluation.phantomCrossing, evaluation.frame.speakerTruthIndifferent with
  | true, true => 8
  | _, _ => 0

/-- Classify a finite cue evaluation into the local four-way taxonomy. -/
def cueClass (evaluation : CueEvaluation) : CueClass :=
  match evaluation.frame.speakerTruthIndifferent, evaluation.phantomCrossing with
  | true, _ => .frankfurtBullshitPhantom
  | _, true => .frankfurtBullshitPhantom
  | false, false =>
      match evaluation.closureDisciplined, evaluation.semanticDrain,
          evaluation.frame.addsTaskInfo with
      | true, true, true => .arguedUsefulReason
      | _, _, _ =>
          match evaluation.frame.tracksTruth, evaluation.frame.addsTaskInfo,
              evaluation.frame.receiverSuppliesStandingWave with
          | true, false, true => .veridicalSway
          | _, _, _ => .conversationalDodgeball

/-- Local predicate for an argued useful reason. -/
def arguedUsefulReason (evaluation : CueEvaluation) : Prop :=
  evaluation.frame.tracksTruth = true ∧
  evaluation.frame.addsTaskInfo = true ∧
  evaluation.frame.speakerTruthIndifferent = false ∧
  evaluation.closureDisciplined = true ∧
  evaluation.semanticDrain = true

/-- Local predicate for unresolved dodgeball residue. -/
def conversationalDodgeballResidue (evaluation : CueEvaluation) : Prop :=
  evaluation.closureDisciplined = false ∧
  evaluation.semanticDrain = false ∧
  evaluation.frame.receiverSuppliesStandingWave = false

/-- Local predicate for phantom-crossing bullshit. -/
def phantomCrossingBullshit (evaluation : CueEvaluation) : Prop :=
  frankfurtBullshit evaluation.frame ∧ evaluation.phantomCrossing = true

/-- The small favor is below the attention threshold. -/
theorem small_uses_script_gate : scriptGate .small := by
  unfold scriptGate pageCost attentionThreshold
  decide

/-- The large favor is above the attention threshold. -/
theorem large_forces_semantic_inspection : semanticInspection .large := by
  unfold semanticInspection pageCost attentionThreshold
  decide

/-- The finite two-level design is partitioned by the threshold. -/
theorem favor_size_threshold_partition (size : FavorSize) :
    scriptGate size ∨ semanticInspection size := by
  cases size <;> unfold scriptGate semanticInspection pageCost attentionThreshold <;> decide

/-- In the low-cost condition, the placebic cue adds 33 compliance points. -/
theorem small_placebic_lift : cueLift .small .placebicReason = 33 := rfl

/-- In the low-cost condition, the real reason adds 34 compliance points. -/
theorem small_real_reason_lift : cueLift .small .realReason = 34 := rfl

/-- Under the script gate, the placebic and semantic reasons are empirically adjacent. -/
theorem small_placebic_matches_real_reason_within_one :
    absDiff (compliancePct .small .placebicReason)
      (compliancePct .small .realReason) ≤ 1 := by
  decide

/-- In the high-cost condition, the placebic cue has no lift over request-only. -/
theorem large_placebic_lift_collapses : cueLift .large .placebicReason = 0 := rfl

/-- In the high-cost condition, the real reason retains an 18-point lift. -/
theorem large_real_reason_lift : cueLift .large .realReason = 18 := rfl

/-- Semantic inspection separates real reasons from placebic reasons in the high-cost condition. -/
theorem large_semantic_premium_positive : semanticPremium .large = 18 := rfl

/-- The placebic reason is true-form structural vacuum, not useful task information. -/
theorem placebic_reason_truth_filled_structural_vacuum :
    truthFilledStructuralVacuumPlacebo copyMachinePlacebicFrame := by
  exact ⟨rfl, rfl, rfl, rfl⟩

/-- The compact name: the copy-machine placebic cue witnesses veridical sway. -/
theorem placebic_reason_veridical_sway :
    veridicalSway copyMachinePlacebicFrame :=
  placebic_reason_truth_filled_structural_vacuum

/-- The placebic reason is not Frankfurt-style bullshit in this bounded frame. -/
theorem placebic_reason_not_frankfurt_bullshit :
    ¬ frankfurtBullshit copyMachinePlacebicFrame := by
  intro h
  cases h.1

/-- Frankfurt-style bullshit is witnessed by truth indifference and no task information. -/
theorem frankfurt_bullshit_frame_witness :
    frankfurtBullshit frankfurtBullshitFrame := by
  exact ⟨rfl, rfl⟩

/-- The local classifier recognizes a task-useful argued reason. -/
theorem classifier_argued_useful_reason :
    cueClass arguedUsefulReasonEvaluation = .arguedUsefulReason := rfl

/-- The local classifier recognizes the copy-machine cue as veridical sway. -/
theorem classifier_copy_machine_placebic :
    cueClass copyMachinePlacebicEvaluation = .veridicalSway := rfl

/-- The local classifier recognizes unresolved residue as conversational dodgeball. -/
theorem classifier_unresolved_dodgeball :
    cueClass unresolvedDodgeballEvaluation = .conversationalDodgeball := rfl

/-- The local classifier recognizes truth-indifferent phantom bullshit. -/
theorem classifier_frankfurt_bullshit_phantom :
    cueClass frankfurtBullshitEvaluation = .frankfurtBullshitPhantom := rfl

/-- A useful argued reason carries one finite bit of task information. -/
theorem argued_reason_has_task_information :
    taskInformationGain arguedUsefulReasonFrame = 1 := rfl

/-- The placebic cue carries no task information in this finite model. -/
theorem placebic_has_zero_task_information :
    taskInformationGain copyMachinePlacebicFrame = 0 := rfl

/-- The placebic cue has no phantom-crossing cost in this bounded frame. -/
theorem placebic_has_zero_phantom_crossing_cost :
    phantomCrossingCost copyMachinePlacebicEvaluation = 0 := rfl

/-- Truth-indifferent bullshit carries positive phantom-crossing cost. -/
theorem frankfurt_bullshit_has_phantom_crossing_cost :
    phantomCrossingCost frankfurtBullshitEvaluation = 8 := rfl

/--
The user's standing-wave hypothesis in finite form: the placebic truth cue is
cheaper for the receiver to settle than a bare structural vacuum with no reason.
-/
theorem placebic_truth_reduces_search_cost_against_no_reason :
    standingWaveSearchCost copyMachinePlacebicFrame <
      standingWaveSearchCost noReasonStructuralVacuumFrame := by
  unfold standingWaveSearchCost copyMachinePlacebicFrame noReasonStructuralVacuumFrame
  decide

/-- Veridical sway settles attention without adding task information. -/
theorem veridical_sway_settles_without_task_information :
    veridicalSway copyMachinePlacebicFrame ∧
    taskInformationGain copyMachinePlacebicFrame = 0 ∧
    standingWaveSearchCost copyMachinePlacebicFrame = 1 ∧
    phantomCrossingCost copyMachinePlacebicEvaluation = 0 := by
  exact ⟨placebic_reason_veridical_sway,
    placebic_has_zero_task_information,
    rfl,
    placebic_has_zero_phantom_crossing_cost⟩

/-- The four canonical cue classes remain separated in the local classifier. -/
theorem four_way_classifier_signature :
    cueClass arguedUsefulReasonEvaluation = .arguedUsefulReason ∧
    cueClass copyMachinePlacebicEvaluation = .veridicalSway ∧
    cueClass unresolvedDodgeballEvaluation = .conversationalDodgeball ∧
    cueClass frankfurtBullshitEvaluation = .frankfurtBullshitPhantom := by
  exact ⟨classifier_argued_useful_reason,
    classifier_copy_machine_placebic,
    classifier_unresolved_dodgeball,
    classifier_frankfurt_bullshit_phantom⟩

/--
The experiment's finite cognitive signature: syntax has lift under the script
gate, but under semantic inspection only the meaningful reason keeps lift.
-/
theorem copy_machine_cognitive_signature :
    cueLift .small .placebicReason = 33 ∧
    cueLift .large .placebicReason = 0 ∧
    semanticPremium .large = 18 ∧
    truthFilledStructuralVacuumPlacebo copyMachinePlacebicFrame ∧
    ¬ frankfurtBullshit copyMachinePlacebicFrame :=
  ⟨small_placebic_lift,
    large_placebic_lift_collapses,
    large_semantic_premium_positive,
    placebic_reason_truth_filled_structural_vacuum,
    placebic_reason_not_frankfurt_bullshit⟩

end PlacebicCognition
end Gnosis
