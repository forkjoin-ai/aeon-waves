import Init

/-!
# Sliver of hope — the `+1` that never lets weight vanish

The Buleyean weight `rounds - rejection + 1` keeps a sliver: even at maximum
rejection the weight is `1`, never zero.  Dually, a proof step subtracts one and
drives a proposition to ground in finitely many steps.  The finite core proves the
sliver bound, the proof descent, and that the two are inverse `±1` moves.

The original spanned the probability/logic Buleyean modules; here the finite core
is self-contained over `Nat`, every proof closing from `Init`.
-/

namespace Gnosis
namespace SliverOfHope

/-- A Buleyean space: per-choice rejection counts over `rounds`. -/
structure BuleyeanSpace where
  rounds : Nat
  rejection : Nat → Nat
  bounded : ∀ i, rejection i ≤ rounds

/-- The Buleyean weight: `rounds - rejection + 1`. -/
def BuleyeanSpace.weight (bs : BuleyeanSpace) (i : Nat) : Nat :=
  bs.rounds - bs.rejection i + 1

/-- The sliver is the `+1`. -/
theorem sliver_is_plus_one (bs : BuleyeanSpace) (i : Nat) :
    bs.weight i = (bs.rounds - bs.rejection i) + 1 := rfl

/-- At maximum rejection only the sliver remains. -/
theorem sliver_at_maximum_rejection (bs : BuleyeanSpace) (i : Nat)
    (h : bs.rejection i = bs.rounds) : bs.weight i = 1 := by
  show bs.rounds - bs.rejection i + 1 = 1
  rw [h, Nat.sub_self]

/-- **The sliver of hope:** weight is never less than one. -/
theorem sliver_at_least_one (bs : BuleyeanSpace) (i : Nat) : 1 ≤ bs.weight i :=
  Nat.le_add_left 1 (bs.rounds - bs.rejection i)

/-- A proof step subtracts one. -/
def proofStep (p : Nat) : Nat := p - 1

/-- A proof step on a positive proposition strictly descends. -/
theorem proof_step_is_minus_one (p : Nat) (hp : 0 < p) : proofStep p < p :=
  Nat.sub_lt hp (by decide)

/-- Iterate the proof step. -/
def proofIter : Nat → Nat → Nat
  | 0, p => p
  | k + 1, p => proofStep (proofIter k p)

/-- `k` proof steps leave `p - k`. -/
theorem proofIter_eq : ∀ (k p : Nat), proofIter k p = p - k
  | 0, p => (Nat.sub_zero p).symm
  | k + 1, p => by
      show proofStep (proofIter k p) = p - (k + 1)
      rw [proofIter_eq k p]
      show (p - k) - 1 = p - (k + 1)
      rw [Nat.sub_sub]

/-- **Proof reaches ground:** enough steps drive a proposition to zero. -/
theorem proof_reaches_ground (n : Nat) : proofIter n n = 0 := by
  rw [proofIter_eq]; exact Nat.sub_self n

/-- **Hope enables proof:** the sliver guarantees a positive starting weight. -/
theorem hope_enables_proof (bs : BuleyeanSpace) (i : Nat) : 0 < bs.weight i :=
  sliver_at_least_one bs i

/-- One Bule of hope: the weight stays at least one. -/
theorem one_bule_of_hope (bs : BuleyeanSpace) (i : Nat) : 1 ≤ bs.weight i :=
  sliver_at_least_one bs i

end SliverOfHope
end Gnosis
