import Init

/-!
# Solomonoff–Buleyean — simplicity as a Buleyean prior

A Solomonoff space weights hypotheses by inverse complexity; mapped into the
Buleyean frame, the complexity becomes a rejection count.  The finite core proves
the Solomonoff–Buleyean axioms: positivity, the weight formula, concentration
(simpler hypotheses weigh more), and the bound by `rounds + 1`.

The original mapped `ComplexityAssignment` into `BuleyeanSpace`; here the finite
core is self-contained over `Nat`, every proof closing from `Init`.
-/

namespace Gnosis
namespace SolomonoffBuleyean

/-- A Solomonoff space: per-hypothesis complexity over a budget of `rounds`. -/
structure SolomonoffSpace where
  rounds : Nat
  complexity : Nat → Nat
  bounded : ∀ i, complexity i ≤ rounds

/-- The Buleyean weight: complexity plays the role of rejection. -/
def SolomonoffSpace.weight (ss : SolomonoffSpace) (i : Nat) : Nat :=
  ss.rounds - ss.complexity i + 1

/-- **Positivity:** every hypothesis keeps positive weight. -/
theorem solomonoff_positivity (ss : SolomonoffSpace) (i : Nat) : 0 < ss.weight i :=
  Nat.succ_pos _

/-- **The weight is bounded** by `rounds + 1` (normalization ceiling). -/
theorem solomonoff_normalization (ss : SolomonoffSpace) (i : Nat) :
    ss.weight i ≤ ss.rounds + 1 :=
  Nat.add_le_add_right (Nat.sub_le ss.rounds (ss.complexity i)) 1

/-- **Concentration:** simpler hypotheses (lower complexity) weigh more. -/
theorem solomonoff_concentration (ss : SolomonoffSpace) (i j : Nat)
    (h : ss.complexity i ≤ ss.complexity j) : ss.weight j ≤ ss.weight i := by
  show ss.rounds - ss.complexity j + 1 ≤ ss.rounds - ss.complexity i + 1
  exact Nat.add_le_add_right (Nat.sub_le_sub_left h ss.rounds) 1

/-- **The Solomonoff–Buleyean axioms** together. -/
theorem solomonoff_buleyean_axioms (ss : SolomonoffSpace) (i : Nat) :
    0 < ss.weight i ∧ ss.weight i ≤ ss.rounds + 1 :=
  ⟨solomonoff_positivity ss i, solomonoff_normalization ss i⟩

/-- **Solomonoff dominates the uniform prior:** the simplest hypothesis
    (zero complexity) attains the maximum weight `rounds + 1`. -/
theorem solomonoff_dominates_uniform (ss : SolomonoffSpace) (i : Nat)
    (h : ss.complexity i = 0) : ss.weight i = ss.rounds + 1 := by
  show ss.rounds - ss.complexity i + 1 = ss.rounds + 1
  rw [h, Nat.sub_zero]

end SolomonoffBuleyean
end Gnosis
