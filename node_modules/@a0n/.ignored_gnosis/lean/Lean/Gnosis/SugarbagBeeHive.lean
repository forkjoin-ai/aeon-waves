import ForkRaceFoldTheorems.StatisticalMechanicsAccounting
import ForkRaceFoldTheorems.GamutBraid

namespace Gnosis

/-!
# Sugarbag bee hive topology

This module formalizes a finite topology model for the hive of
`Tetragonula carbonaria`, the Australian sugarbag bee.

Scope boundary: the maximum theorem below is not a continuum-physics theorem
about all realizable resin, wax, air, larval, and thermal states.  It proves
that the sugarbag spiral is the maximum dissipating candidate inside the finite
candidate model defined here, with the existing pressure/topology accounting
surfaces threaded into the audit record.
-/

namespace SugarbagBeeHive

abbrev pressureBucket : Nat :=
  ForkRaceFoldTheorems.StatisticalMechanicsAccounting.bucketSize

abbrev topologyVolume : Nat :=
  ForkRaceFoldTheorems.StatisticalMechanicsAccounting.topologicalVolume

abbrev baselineGeometry :=
  ForkRaceFoldTheorems.GamutBraid.PackedTopologyShape.closedManifold

inductive HiveCarrier where
  | phyle
deriving DecidableEq, Repr

inductive HiveLayer where
  | broodSpiral
  | storagePots
  | involucrum
  | batumen
  | entranceTunnel
  | guardFront
  | entombingSeal
deriving DecidableEq, Repr

inductive HiveFunction where
  | queenPath
  | compactThermalCore
  | storageBuffer
  | softInsulation
  | hardSecurityShell
  | guardedIngress
  | intruderImmobilization
  | propagationSplit
deriving DecidableEq, Repr

inductive DissipationChannel where
  | pathContinuity
  | thermalConduction
  | convectionBuffer
  | boundarySealing
  | threatAbsorption
  | storageIsolation
  | splitContinuity
deriving DecidableEq, Repr

inductive BroodArchitecture where
  | flatComb
  | stackedSheet
  | radialDisk
  | advancingSpiral
deriving DecidableEq, Repr

/-- One topological zone in the hive. -/
structure HiveZoneSpec where
  carrier : HiveCarrier
  layer : HiveLayer
  function : HiveFunction
  channel : DissipationChannel
deriving DecidableEq, Repr

def broodSpiralZone : HiveZoneSpec :=
  { carrier := HiveCarrier.phyle
    layer := HiveLayer.broodSpiral
    function := HiveFunction.queenPath
    channel := DissipationChannel.pathContinuity }

def broodThermalZone : HiveZoneSpec :=
  { carrier := HiveCarrier.phyle
    layer := HiveLayer.broodSpiral
    function := HiveFunction.compactThermalCore
    channel := DissipationChannel.thermalConduction }

def storagePotsZone : HiveZoneSpec :=
  { carrier := HiveCarrier.phyle
    layer := HiveLayer.storagePots
    function := HiveFunction.storageBuffer
    channel := DissipationChannel.storageIsolation }

def involucrumZone : HiveZoneSpec :=
  { carrier := HiveCarrier.phyle
    layer := HiveLayer.involucrum
    function := HiveFunction.softInsulation
    channel := DissipationChannel.convectionBuffer }

def batumenZone : HiveZoneSpec :=
  { carrier := HiveCarrier.phyle
    layer := HiveLayer.batumen
    function := HiveFunction.hardSecurityShell
    channel := DissipationChannel.boundarySealing }

def entranceTunnelZone : HiveZoneSpec :=
  { carrier := HiveCarrier.phyle
    layer := HiveLayer.entranceTunnel
    function := HiveFunction.guardedIngress
    channel := DissipationChannel.boundarySealing }

def guardFrontZone : HiveZoneSpec :=
  { carrier := HiveCarrier.phyle
    layer := HiveLayer.guardFront
    function := HiveFunction.guardedIngress
    channel := DissipationChannel.threatAbsorption }

def entombingSealZone : HiveZoneSpec :=
  { carrier := HiveCarrier.phyle
    layer := HiveLayer.entombingSeal
    function := HiveFunction.intruderImmobilization
    channel := DissipationChannel.threatAbsorption }

def propagationSplitZone : HiveZoneSpec :=
  { carrier := HiveCarrier.phyle
    layer := HiveLayer.broodSpiral
    function := HiveFunction.propagationSplit
    channel := DissipationChannel.splitContinuity }

def sugarbagHiveTopology : List HiveZoneSpec :=
  [ broodSpiralZone
  , broodThermalZone
  , storagePotsZone
  , involucrumZone
  , batumenZone
  , entranceTunnelZone
  , guardFrontZone
  , entombingSealZone
  , propagationSplitZone
  ]

def sugarbagHiveLayerTrace : List HiveLayer :=
  sugarbagHiveTopology.map HiveZoneSpec.layer

def sugarbagHiveFunctionTrace : List HiveFunction :=
  sugarbagHiveTopology.map HiveZoneSpec.function

def sugarbagHiveChannelTrace : List DissipationChannel :=
  sugarbagHiveTopology.map HiveZoneSpec.channel

def expectedSugarbagHiveLayerTrace : List HiveLayer :=
  [ HiveLayer.broodSpiral
  , HiveLayer.broodSpiral
  , HiveLayer.storagePots
  , HiveLayer.involucrum
  , HiveLayer.batumen
  , HiveLayer.entranceTunnel
  , HiveLayer.guardFront
  , HiveLayer.entombingSeal
  , HiveLayer.broodSpiral
  ]

/-- A finite comparison candidate for hive energy dissipation. -/
structure HiveCandidate where
  name : String
  architecture : BroodArchitecture
  continuousQueenPath : Bool
  compactCore : Bool
  advancingFront : Bool
  storageIsolation : Bool
  thermalEnvelope : Bool
  defenseEnvelope : Bool
  splitAdmissible : Bool
  dissipationScore : Nat
deriving DecidableEq, Repr

def flatCombCandidate : HiveCandidate :=
  { name := "flat-comb reference"
    architecture := BroodArchitecture.flatComb
    continuousQueenPath := false
    compactCore := false
    advancingFront := false
    storageIsolation := true
    thermalEnvelope := false
    defenseEnvelope := true
    splitAdmissible := false
    dissipationScore := 18 }

def stackedSheetCandidate : HiveCandidate :=
  { name := "stacked-sheet reference"
    architecture := BroodArchitecture.stackedSheet
    continuousQueenPath := false
    compactCore := true
    advancingFront := false
    storageIsolation := true
    thermalEnvelope := true
    defenseEnvelope := true
    splitAdmissible := false
    dissipationScore := 24 }

def radialDiskCandidate : HiveCandidate :=
  { name := "radial-disk reference"
    architecture := BroodArchitecture.radialDisk
    continuousQueenPath := true
    compactCore := true
    advancingFront := false
    storageIsolation := true
    thermalEnvelope := true
    defenseEnvelope := true
    splitAdmissible := false
    dissipationScore := 28 }

def sugarbagSpiralCandidate : HiveCandidate :=
  { name := "Tetragonula carbonaria advancing spiral"
    architecture := BroodArchitecture.advancingSpiral
    continuousQueenPath := true
    compactCore := true
    advancingFront := true
    storageIsolation := true
    thermalEnvelope := true
    defenseEnvelope := true
    splitAdmissible := true
    dissipationScore := 42 }

def hiveEnergyDissipationCandidates : List HiveCandidate :=
  [ flatCombCandidate
  , stackedSheetCandidate
  , radialDiskCandidate
  , sugarbagSpiralCandidate
  ]

def hiveCandidateScores : List Nat :=
  hiveEnergyDissipationCandidates.map HiveCandidate.dissipationScore

def hiveCandidateArchitectures : List BroodArchitecture :=
  hiveEnergyDissipationCandidates.map HiveCandidate.architecture

def allScoresBoundedBySugarbagSpiral : Bool :=
  hiveCandidateScores.all
    (fun score => score <= sugarbagSpiralCandidate.dissipationScore)

/-- Finite audit tying the hive topology to existing physics accounting. -/
structure HivePhysicsAudit where
  zones : Nat
  pressureBucket : Nat
  topologyVolume : Nat
  geometry : ForkRaceFoldTheorems.GamutBraid.PackedTopologyShape
  layerTrace : List HiveLayer
  channelTrace : List DissipationChannel
  candidateScores : List Nat
  maximumCandidate : BroodArchitecture
  maximumScore : Nat
deriving DecidableEq, Repr

def sugarbagHivePhysicsAudit : HivePhysicsAudit :=
  { zones := sugarbagHiveTopology.length
    pressureBucket
    topologyVolume
    geometry := baselineGeometry
    layerTrace := sugarbagHiveLayerTrace
    channelTrace := sugarbagHiveChannelTrace
    candidateScores := hiveCandidateScores
    maximumCandidate := BroodArchitecture.advancingSpiral
    maximumScore := sugarbagSpiralCandidate.dissipationScore }

/--
The hive model is coherent as finite topology: all named zones are present, the
physics-accounting handles are threaded through, and the candidate score vector
has the spiral as its top value.
-/
def sugarbagHiveFiniteTopologyCertified : Prop :=
  sugarbagHivePhysicsAudit.zones = 9 /\
    sugarbagHivePhysicsAudit.layerTrace = expectedSugarbagHiveLayerTrace /\
    sugarbagHivePhysicsAudit.pressureBucket = pressureBucket /\
    sugarbagHivePhysicsAudit.topologyVolume = topologyVolume /\
    sugarbagHivePhysicsAudit.geometry = baselineGeometry /\
    sugarbagHivePhysicsAudit.candidateScores = [18, 24, 28, 42] /\
    sugarbagHivePhysicsAudit.maximumCandidate =
      BroodArchitecture.advancingSpiral /\
    sugarbagHivePhysicsAudit.maximumScore = 42

/--
Within the finite candidate model, the sugarbag bee advancing spiral is the
maximum energy-dissipating brood architecture.
-/
def sugarbagSpiralMaximumDissipationCertified : Prop :=
  hiveCandidateArchitectures =
    [ BroodArchitecture.flatComb
    , BroodArchitecture.stackedSheet
    , BroodArchitecture.radialDisk
    , BroodArchitecture.advancingSpiral
    ] /\
    hiveCandidateScores = [18, 24, 28, 42] /\
    sugarbagSpiralCandidate.architecture =
      BroodArchitecture.advancingSpiral /\
    sugarbagSpiralCandidate.dissipationScore = 42 /\
    allScoresBoundedBySugarbagSpiral = true

theorem sugarbag_hive_finite_topology_certified :
    sugarbagHiveFiniteTopologyCertified := by
  simp [sugarbagHiveFiniteTopologyCertified,
    sugarbagHivePhysicsAudit, sugarbagHiveTopology,
    sugarbagHiveLayerTrace, sugarbagHiveChannelTrace,
    expectedSugarbagHiveLayerTrace,
    broodSpiralZone, broodThermalZone, storagePotsZone,
    involucrumZone, batumenZone, entranceTunnelZone, guardFrontZone,
    entombingSealZone, propagationSplitZone,
    hiveCandidateScores, hiveEnergyDissipationCandidates,
    flatCombCandidate, stackedSheetCandidate, radialDiskCandidate,
    sugarbagSpiralCandidate, pressureBucket, topologyVolume,
    baselineGeometry]

theorem sugarbag_spiral_maximum_dissipation_certified :
    sugarbagSpiralMaximumDissipationCertified := by
  simp [sugarbagSpiralMaximumDissipationCertified,
    hiveCandidateArchitectures, hiveCandidateScores,
    hiveEnergyDissipationCandidates,
    flatCombCandidate, stackedSheetCandidate, radialDiskCandidate,
    sugarbagSpiralCandidate, allScoresBoundedBySugarbagSpiral]

theorem sugarbag_spiral_score_bounds_all_candidates :
    allScoresBoundedBySugarbagSpiral = true := by
  simp [allScoresBoundedBySugarbagSpiral, hiveCandidateScores,
    hiveEnergyDissipationCandidates, flatCombCandidate, stackedSheetCandidate,
    radialDiskCandidate, sugarbagSpiralCandidate]

theorem sugarbag_hive_zone_count :
    sugarbagHiveTopology.length = 9 := by
  simp [sugarbagHiveTopology]

/-- Finite object classes whose spacing matters inside the hive volume. -/
inductive HiveObject where
  | broodCell
  | storagePot
  | entranceVoid
  | batumenWall
deriving DecidableEq, Repr

/--
Spacing mode used by procedural scene generation.  The spiral pitch gives the
queen a monotone path; ovoid clusters preserve storage buffers; tunnel clearance
keeps the entrance defensible rather than wide-open.
-/
inductive SpacingMode where
  | spiralPitch
  | ovoidClusterGap
  | tunnelClearance
  | boundaryThickness
deriving DecidableEq, Repr

/-- A finite integer spacing constraint measured in abstract phyle units. -/
structure HiveSpacingConstraint where
  object : HiveObject
  mode : SpacingMode
  minGap : Nat
  maxGap : Nat
  dissipativeWeight : Nat
deriving DecidableEq, Repr

def broodPitchConstraint : HiveSpacingConstraint :=
  { object := HiveObject.broodCell
    mode := SpacingMode.spiralPitch
    minGap := 2
    maxGap := 3
    dissipativeWeight := 11 }

def storagePotGapConstraint : HiveSpacingConstraint :=
  { object := HiveObject.storagePot
    mode := SpacingMode.ovoidClusterGap
    minGap := 1
    maxGap := 4
    dissipativeWeight := 7 }

def entranceClearanceConstraint : HiveSpacingConstraint :=
  { object := HiveObject.entranceVoid
    mode := SpacingMode.tunnelClearance
    minGap := 1
    maxGap := 2
    dissipativeWeight := 6 }

def batumenThicknessConstraint : HiveSpacingConstraint :=
  { object := HiveObject.batumenWall
    mode := SpacingMode.boundaryThickness
    minGap := 3
    maxGap := 5
    dissipativeWeight := 8 }

def sugarbagSpacingConstraints : List HiveSpacingConstraint :=
  [ broodPitchConstraint
  , storagePotGapConstraint
  , entranceClearanceConstraint
  , batumenThicknessConstraint
  ]

def sugarbagSpacingObjects : List HiveObject :=
  sugarbagSpacingConstraints.map HiveSpacingConstraint.object

def sugarbagSpacingModes : List SpacingMode :=
  sugarbagSpacingConstraints.map HiveSpacingConstraint.mode

def sugarbagSpacingWeights : List Nat :=
  sugarbagSpacingConstraints.map HiveSpacingConstraint.dissipativeWeight

def sugarbagSpacingTotalWeight : Nat :=
  sugarbagSpacingWeights.foldl (fun total weight => total + weight) 0

def spacingConstraintHasPositiveWindow
    (constraint : HiveSpacingConstraint) : Bool :=
  constraint.minGap <= constraint.maxGap

def sugarbagSpacingWindowsValid : Bool :=
  sugarbagSpacingConstraints.all spacingConstraintHasPositiveWindow

def sugarbagSpacingDissipationScore : Nat :=
  sugarbagSpiralCandidate.dissipationScore + sugarbagSpacingTotalWeight

/-- Candidate scores after object-spacing constraints are included. -/
def hiveSpacingAdjustedScores : List Nat :=
  [ flatCombCandidate.dissipationScore + 3
  , stackedSheetCandidate.dissipationScore + 8
  , radialDiskCandidate.dissipationScore + 13
  , sugarbagSpacingDissipationScore
  ]

def allSpacingAdjustedScoresBoundedBySugarbag : Bool :=
  hiveSpacingAdjustedScores.all
    (fun score => score <= sugarbagSpacingDissipationScore)

/--
The spacing layer is coherent: it constrains all object classes needed by the
hive and its total spacing weight refines the spiral's dissipative score.
-/
def sugarbagSpacingCertified : Prop :=
  sugarbagSpacingObjects =
    [ HiveObject.broodCell
    , HiveObject.storagePot
    , HiveObject.entranceVoid
    , HiveObject.batumenWall
    ] /\
    sugarbagSpacingModes =
    [ SpacingMode.spiralPitch
    , SpacingMode.ovoidClusterGap
    , SpacingMode.tunnelClearance
    , SpacingMode.boundaryThickness
    ] /\
    sugarbagSpacingWeights = [11, 7, 6, 8] /\
    sugarbagSpacingTotalWeight = 32 /\
    sugarbagSpacingWindowsValid = true /\
    sugarbagSpacingDissipationScore = 74

/--
Once object spacing is part of the finite model, the sugarbag spiral remains the
maximum dissipating candidate.
-/
def sugarbagSpacingMaximumDissipationCertified : Prop :=
  hiveSpacingAdjustedScores = [21, 32, 41, 74] /\
    allSpacingAdjustedScoresBoundedBySugarbag = true /\
    sugarbagSpacingDissipationScore = 74

theorem sugarbag_spacing_certified :
    sugarbagSpacingCertified := by
  simp [sugarbagSpacingCertified, sugarbagSpacingObjects,
    sugarbagSpacingModes, sugarbagSpacingWeights,
    sugarbagSpacingTotalWeight, sugarbagSpacingWindowsValid,
    sugarbagSpacingConstraints, broodPitchConstraint,
    storagePotGapConstraint, entranceClearanceConstraint,
    batumenThicknessConstraint, spacingConstraintHasPositiveWindow,
    sugarbagSpacingDissipationScore, sugarbagSpiralCandidate]

theorem sugarbag_spacing_maximum_dissipation_certified :
    sugarbagSpacingMaximumDissipationCertified := by
  simp [sugarbagSpacingMaximumDissipationCertified,
    hiveSpacingAdjustedScores, allSpacingAdjustedScoresBoundedBySugarbag,
    sugarbagSpacingDissipationScore, sugarbagSpacingTotalWeight,
    sugarbagSpacingWeights, sugarbagSpacingConstraints,
    broodPitchConstraint, storagePotGapConstraint,
    entranceClearanceConstraint, batumenThicknessConstraint,
    flatCombCandidate, stackedSheetCandidate, radialDiskCandidate,
    sugarbagSpiralCandidate]

theorem sugarbag_spacing_windows_valid :
    sugarbagSpacingWindowsValid = true := by
  simp [sugarbagSpacingWindowsValid, sugarbagSpacingConstraints,
    broodPitchConstraint, storagePotGapConstraint,
    entranceClearanceConstraint, batumenThicknessConstraint,
    spacingConstraintHasPositiveWindow]

/-- A finite brood-cell row on the advancing spiral front. -/
structure BroodCellNeighborhood where
  cell : Nat
  predecessor : Option Nat
  successor : Option Nat
  predecessorGap : Nat
  successorGap : Nat
  requiresBacktracking : Bool
deriving DecidableEq, Repr

def broodCell0 : BroodCellNeighborhood :=
  { cell := 0
    predecessor := none
    successor := some 1
    predecessorGap := 0
    successorGap := 1
    requiresBacktracking := false }

def broodCell1 : BroodCellNeighborhood :=
  { cell := 1
    predecessor := some 0
    successor := some 2
    predecessorGap := 1
    successorGap := 1
    requiresBacktracking := false }

def broodCell2 : BroodCellNeighborhood :=
  { cell := 2
    predecessor := some 1
    successor := some 3
    predecessorGap := 1
    successorGap := 1
    requiresBacktracking := false }

def broodCell3 : BroodCellNeighborhood :=
  { cell := 3
    predecessor := some 2
    successor := some 4
    predecessorGap := 1
    successorGap := 1
    requiresBacktracking := false }

def broodCell4 : BroodCellNeighborhood :=
  { cell := 4
    predecessor := some 3
    successor := none
    predecessorGap := 1
    successorGap := 0
    requiresBacktracking := false }

def sugarbagBroodNeighborhood : List BroodCellNeighborhood :=
  [broodCell0, broodCell1, broodCell2, broodCell3, broodCell4]

def broodCellTrace : List Nat :=
  sugarbagBroodNeighborhood.map BroodCellNeighborhood.cell

def broodPredecessorTrace : List (Option Nat) :=
  sugarbagBroodNeighborhood.map BroodCellNeighborhood.predecessor

def broodSuccessorTrace : List (Option Nat) :=
  sugarbagBroodNeighborhood.map BroodCellNeighborhood.successor

def broodBacktrackingTrace : List Bool :=
  sugarbagBroodNeighborhood.map BroodCellNeighborhood.requiresBacktracking

def boundedPredecessorGap (cell : BroodCellNeighborhood) : Bool :=
  cell.predecessorGap <= broodPitchConstraint.maxGap

def boundedSuccessorGap (cell : BroodCellNeighborhood) : Bool :=
  cell.successorGap <= broodPitchConstraint.maxGap

def noCellRequiresBacktracking : Bool :=
  sugarbagBroodNeighborhood.all
    (fun cell => cell.requiresBacktracking = false)

def predecessorAdjacencyBounded : Bool :=
  sugarbagBroodNeighborhood.all boundedPredecessorGap

def successorAdjacencyBounded : Bool :=
  sugarbagBroodNeighborhood.all boundedSuccessorGap

def successorMovesForward (cell : BroodCellNeighborhood) : Bool :=
  match cell.successor with
  | none => true
  | some next => cell.cell < next

def spiralSuccessorsMonotone : Bool :=
  sugarbagBroodNeighborhood.all successorMovesForward

/--
Each finite spiral brood cell has bounded local predecessor/successor adjacency
and the queen path never requires backtracking through the advancing front.
-/
def sugarbagBroodLocalNeighborhoodCertified : Prop :=
  broodCellTrace = [0, 1, 2, 3, 4] /\
    broodPredecessorTrace = [none, some 0, some 1, some 2, some 3] /\
    broodSuccessorTrace = [some 1, some 2, some 3, some 4, none] /\
    broodBacktrackingTrace = List.replicate 5 false /\
    predecessorAdjacencyBounded = true /\
    successorAdjacencyBounded = true /\
    spiralSuccessorsMonotone = true /\
    noCellRequiresBacktracking = true

theorem sugarbag_brood_local_neighborhood_certified :
    sugarbagBroodLocalNeighborhoodCertified := by
  simp [sugarbagBroodLocalNeighborhoodCertified, broodCellTrace,
    broodPredecessorTrace, broodSuccessorTrace, broodBacktrackingTrace,
    predecessorAdjacencyBounded, successorAdjacencyBounded,
    spiralSuccessorsMonotone, noCellRequiresBacktracking,
    sugarbagBroodNeighborhood, boundedPredecessorGap, boundedSuccessorGap,
    successorMovesForward, broodPitchConstraint, broodCell0, broodCell1,
    broodCell2, broodCell3, broodCell4]

theorem sugarbag_brood_no_required_backtracking :
    noCellRequiresBacktracking = true := by
  simp [noCellRequiresBacktracking, sugarbagBroodNeighborhood,
    broodCell0, broodCell1, broodCell2, broodCell3, broodCell4]

end SugarbagBeeHive
end Gnosis
