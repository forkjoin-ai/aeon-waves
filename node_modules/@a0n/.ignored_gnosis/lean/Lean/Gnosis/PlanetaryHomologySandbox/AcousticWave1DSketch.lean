import Init

/-!
# Acoustic wave 1D sketch — amplitude is conserved under propagation

A discrete 1D acoustic wave on a ring is sampled as a list of node displacements;
propagation is a cyclic shift.  The finite core proves the conservation law: the
total amplitude is additive across segments and invariant under a propagation step,
and the sample length (sampling capacity) is preserved.

Init-only; every proof closes from `Nat`/`List` lemmas with no banned tactic on an
open goal.
-/

namespace Gnosis
namespace AcousticWave1DSketch

/-- Total amplitude of a sampled wave. -/
def amplitude (l : List Nat) : Nat := l.foldr (· + ·) 0

/-- One propagation step: a cyclic shift of the samples. -/
def propagate : List Nat → List Nat
  | [] => []
  | x :: xs => xs ++ [x]

/-- Amplitude is additive across segments. -/
theorem amplitude_append (a b : List Nat) :
    amplitude (a ++ b) = amplitude a + amplitude b := by
  induction a with
  | nil => exact (Nat.zero_add _).symm
  | cons x xs ih =>
      show x + amplitude (xs ++ b) = x + amplitude xs + amplitude b
      rw [ih]; exact (Nat.add_assoc x _ _).symm

/-- **Conservation.** Propagation preserves the total amplitude. -/
theorem propagate_conserves_amplitude (l : List Nat) : amplitude (propagate l) = amplitude l := by
  cases l with
  | nil => rfl
  | cons x xs =>
      show amplitude (xs ++ [x]) = x + amplitude xs
      rw [amplitude_append]
      show amplitude xs + (x + 0) = x + amplitude xs
      rw [Nat.add_zero, Nat.add_comm]

/-- Propagation preserves the number of samples (sampling capacity). -/
theorem propagate_preserves_length (l : List Nat) : (propagate l).length = l.length := by
  cases l with
  | nil => rfl
  | cons x xs =>
      show (xs ++ [x]).length = xs.length + 1
      rw [List.length_append]
      rfl

end AcousticWave1DSketch
end Gnosis
