import Init

/-!
# Oracle execution stall annihilation — stalled branches are driven to zero

Annihilating a stall removes one stalled branch per pass.  The finite core proves
the annihilation terminates: each pass never increases the stalled-branch count,
`k` passes leave `stalls - k`, and running for the full count annihilates every
stall.

Init-only; every proof closes from `Nat` lemmas with no banned tactic on an open
goal.
-/

namespace Gnosis

/-- One annihilation pass removes a stalled branch. -/
def annihilate (stalls : Nat) : Nat := stalls - 1

/-- Run `k` annihilation passes. -/
def annihilateIter : Nat → Nat → Nat
  | 0,     s => s
  | k + 1, s => annihilate (annihilateIter k s)

/-- A pass never increases the stall count. -/
theorem annihilate_le (s : Nat) : annihilate s ≤ s := Nat.sub_le s 1

/-- **Closed form.** `k` passes leave `stalls - k`. -/
theorem annihilateIter_eq : ∀ (k s : Nat), annihilateIter k s = s - k
  | 0,     s => (Nat.sub_zero s).symm
  | k + 1, s => by
      show annihilate (annihilateIter k s) = s - (k + 1)
      rw [annihilateIter_eq k s]
      show (s - k) - 1 = s - (k + 1)
      rw [Nat.sub_sub]

/-- **Annihilation.** Running for the full stall count clears every stall. -/
theorem stall_is_annihilated (s : Nat) : annihilateIter s s = 0 := by
  rw [annihilateIter_eq]; exact Nat.sub_self s

end Gnosis
