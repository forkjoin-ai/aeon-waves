import Init

/-!
# Universe shape by dimension — the visible slice is a 2-torus

The visible torus rank of an ambient dimension is the off-by-one `d - 1`, and the
Wallington dimension law closes it back (`(d-1)+1 = d`) for any positive dimension.
Our rocky 3D floor gives a 2-torus slice (rank 2, β₁ = 2); higher dimensions are
not 2-tori, and the torus rank is strictly monotone in ambient dimension.

The original used `omega`/`native_decide`; this restoration closes from `Init`.
-/

namespace Gnosis

/-- The Wallington dimension law: rank back to ambient. -/
def wallingtonDimension (rank : Nat) : Nat := rank + 1

/-- A `d`-torus has first Betti number `d`. -/
def torusBetti1 (rank : Nat) : Nat := rank

/-- The rocky shadow floor anchoring our visible slice. -/
def earthLikeRockyShadowDimension : Nat := 3

/-- The visible torus rank of an ambient dimension. -/
def visibleTorusRank (ambientDimension : Nat) : Nat := ambientDimension - 1

/-- A slice is toroidal when the off-by-one law closes back to the ambient. -/
def toroidalVisibleShape (ambientDimension : Nat) : Prop :=
  1 ≤ ambientDimension ∧ wallingtonDimension (visibleTorusRank ambientDimension) = ambientDimension

/-- A 2-torus visible slice. -/
def twoTorusVisibleShape (ambientDimension : Nat) : Prop :=
  toroidalVisibleShape ambientDimension ∧ visibleTorusRank ambientDimension = 2

/-- Our visible ambient dimension. -/
def ourVisibleAmbientDimension : Nat := earthLikeRockyShadowDimension

theorem visible_torus_rank_is_off_by_one (ambientDimension : Nat) :
    visibleTorusRank ambientDimension = ambientDimension - 1 := rfl

/-- Every positive dimension has a toroidal visible slice. -/
theorem positive_dimensions_have_toroidal_visible_shape (d : Nat) (h : 1 ≤ d) :
    toroidalVisibleShape d :=
  ⟨h, Nat.sub_add_cancel h⟩

theorem our_visible_ambient_dimension_is_three : ourVisibleAmbientDimension = 3 := rfl

/-- Our 3D slice is a 2-torus. -/
theorem our_visible_three_d_slice_is_two_torus :
    twoTorusVisibleShape ourVisibleAmbientDimension :=
  ⟨positive_dimensions_have_toroidal_visible_shape 3 (by decide), rfl⟩

/-- Our visible slice has first Betti number 2. -/
theorem our_visible_three_d_slice_has_betti_two :
    torusBetti1 (visibleTorusRank ourVisibleAmbientDimension) = 2 := rfl

/-- Dimensions four and up are not 2-tori. -/
theorem higher_dimensions_are_not_two_torus (d : Nat) (h : 4 ≤ d) :
    ¬ twoTorusVisibleShape d := by
  intro htwo
  have hd : d - 1 = 2 := htwo.2
  have h3 : 3 ≤ d - 1 := Nat.sub_le_sub_right h 1
  rw [hd] at h3
  exact absurd h3 (by decide)

/-- The 2-torus shape is not dimension-free: some toroidal slice is not a 2-torus. -/
theorem two_torus_is_not_dimension_free :
    ∃ d : Nat, toroidalVisibleShape d ∧ ¬ twoTorusVisibleShape d :=
  ⟨4, positive_dimensions_have_toroidal_visible_shape 4 (by decide),
   higher_dimensions_are_not_two_torus 4 (by decide)⟩

/-- The visible torus rank is strictly monotone in ambient dimension. -/
theorem universe_shape_depends_on_dimension (d₁ d₂ : Nat) (h₁ : 1 ≤ d₁) (h : d₁ < d₂) :
    visibleTorusRank d₁ < visibleTorusRank d₂ :=
  Nat.pred_lt_pred (Nat.pos_iff_ne_zero.mp h₁) h

end Gnosis
