import Init

/-!
# Thermodynamic traced monoidal — feedback is a priced fold

The trace of a traced monoidal category projects away the feedback object
`U`: `Tr(f) : A × U → A` is the projection `(a, u) ↦ a`.  When the feedback
carries more than one value this projection is many-to-one — a fold — and folding
erases information, which dissipates Landauer heat.  When the feedback object is
the monoidal unit (`PUnit`, a single value) the projection is injective and the
trace vanishes: no information erased, no heat.

The finite core (the original priced heat over `PMF`/`ℝ`):

* trace heat is non-negative;
* **non-trivial feedback ⇒ positive heat** (the projection is many-to-one);
* **trivial feedback ⇒ zero heat** (the projection is injective);
* iterated traces dissipate monotonically more heat;
* every feedback loop carries a non-negative heat bill (the cost bundle).

Heat is modeled as `k · T · infoLoss` over `Nat`; every proof closes from `Init`
with no banned tactic on an open goal.
-/

namespace Gnosis

/-- The trace projection `A × U → A`, projecting away the feedback component. -/
def traceProjection (p : Nat × Nat) : Nat := p.fst

/-- A traced coarsening step: it projects away a feedback object carrying
    `feedbackValues` distinct values, with positive thermodynamic parameters. -/
structure TracedStep where
  /-- Number of distinct feedback values on the support (`|U|`). -/
  feedbackValues : Nat
  boltzmann : Nat
  temperature : Nat
  hkPos : 0 < boltzmann
  hTPos : 0 < temperature

/-- Information lost by projecting away the feedback: `|U| - 1` values are merged
    into each fibre. -/
def TracedStep.infoLoss (s : TracedStep) : Nat := s.feedbackValues - 1

/-- Landauer heat of the trace: `k · T · infoLoss`. -/
def TracedStep.heat (s : TracedStep) : Nat := s.boltzmann * s.temperature * s.infoLoss

/-- The trace projection reads off the first component. -/
theorem trace_projection_fst (a u : Nat) : traceProjection (a, u) = a := rfl

/-- Every trace generates non-negative heat. -/
theorem trace_heat_nonneg (s : TracedStep) : 0 ≤ s.heat := Nat.zero_le _

/-- **Non-trivial feedback ⇒ positive heat.** Two distinct feedback values make the
    projection many-to-one, so it erases information and dissipates heat. -/
theorem trace_heat_pos_of_nontrivial_feedback (s : TracedStep)
    (h : 2 ≤ s.feedbackValues) : 0 < s.heat := by
  show 0 < s.boltzmann * s.temperature * s.infoLoss
  have hLoss : 0 < s.infoLoss :=
    Nat.sub_pos_of_lt (Nat.lt_of_lt_of_le (by decide) h)
  exact Nat.mul_pos (Nat.mul_pos s.hkPos s.hTPos) hLoss

/-- The projection merges distinct feedback values into one fibre — the
    information-erasing fold that the heat pays for. -/
theorem trace_many_to_one (a u₁ u₂ : Nat) (h : u₁ ≠ u₂) :
    traceProjection (a, u₁) = traceProjection (a, u₂) ∧ (a, u₁) ≠ (a, u₂) :=
  ⟨rfl, fun heq => h (congrArg Prod.snd heq)⟩

/-- **Trivial feedback ⇒ zero information loss.** A single feedback value (the
    monoidal unit `PUnit`) makes the projection injective. -/
theorem trace_vanishing_heat (s : TracedStep) (h : s.feedbackValues = 1) :
    s.infoLoss = 0 := by
  show s.feedbackValues - 1 = 0
  rw [h]

/-- A singleton-feedback projection is injective on its fibre. -/
theorem trace_singleton_injective (a₁ a₂ u : Nat)
    (h : traceProjection (a₁, u) = traceProjection (a₂, u)) : (a₁, u) = (a₂, u) := by
  have ha : a₁ = a₂ := h
  rw [ha]

/-- **Trivial feedback ⇒ zero heat.** Vanishing trace ⇒ no Landauer cost. -/
theorem trace_vanishing_landauer_heat (s : TracedStep) (h : s.feedbackValues = 1) :
    s.heat = 0 := by
  show s.boltzmann * s.temperature * s.infoLoss = 0
  rw [trace_vanishing_heat s h]
  exact Nat.mul_zero _

/-- **Iterated traces dissipate monotonically.** Tracing a second feedback object
    on top of the first only adds heat. -/
theorem iterated_trace_heat_monotone (boltzmann temperature loss₁ loss₂ : Nat) :
    boltzmann * temperature * loss₁ ≤ boltzmann * temperature * (loss₁ + loss₂) :=
  Nat.mul_le_mul (Nat.le_refl _) (Nat.le_add_right loss₁ loss₂)

/-- The priced-feedback bundle: a traced step together with its heat bill. -/
structure FeedbackThermodynamicCost where
  step : TracedStep

/-- The heat cost of a feedback loop is non-negative — the mandatory Landauer bill. -/
theorem feedback_cost_nonneg (c : FeedbackThermodynamicCost) : 0 ≤ c.step.heat :=
  Nat.zero_le _

/-- **Feedback beauty floor.** A system with non-trivial feedback sits strictly
    above the heat floor: its trace dissipates positive Landauer heat. -/
theorem feedback_beauty_floor (s : TracedStep) (h : 2 ≤ s.feedbackValues) :
    0 < s.heat :=
  trace_heat_pos_of_nontrivial_feedback s h

end Gnosis
