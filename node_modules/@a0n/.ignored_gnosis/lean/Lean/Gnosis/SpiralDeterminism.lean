import Init

/-!
# Spiral determinism — a deterministic outward spiral

A spiral grows its radius by a fixed positive increment each step.  The finite
core proves the dynamics are deterministic and strictly outward: iterating is a
function of the start and step count, the radius never decreases, and with a
positive growth it strictly increases every step.

Init-only; every proof closes from `Nat` lemmas with no banned tactic on an open
goal.
-/

namespace Gnosis

/-- A spiral law: a starting radius and a per-step growth. -/
structure Spiral where
  start : Nat
  growth : Nat

/-- Radius after `k` steps. -/
def Spiral.radius (s : Spiral) (k : Nat) : Nat := s.start + k * s.growth

/-- **Determinism.** Equal step counts give equal radii. -/
theorem radius_deterministic (s : Spiral) {j k : Nat} (h : j = k) :
    s.radius j = s.radius k := by rw [h]

/-- The radius is non-decreasing in the step count. -/
theorem radius_monotone (s : Spiral) {j k : Nat} (h : j ≤ k) :
    s.radius j ≤ s.radius k :=
  Nat.add_le_add_left (Nat.mul_le_mul_right s.growth h) s.start

/-- The radius never drops below the start. -/
theorem radius_ge_start (s : Spiral) (k : Nat) : s.start ≤ s.radius k :=
  Nat.le_add_right s.start (k * s.growth)

/-- **Strictly outward.** With positive growth each step increases the radius. -/
theorem radius_strict (s : Spiral) (hg : 0 < s.growth) (k : Nat) :
    s.radius k < s.radius (k + 1) := by
  show s.start + k * s.growth < s.start + (k + 1) * s.growth
  apply Nat.add_lt_add_left
  rw [Nat.succ_mul]
  exact Nat.lt_add_of_pos_right hg

end Gnosis
