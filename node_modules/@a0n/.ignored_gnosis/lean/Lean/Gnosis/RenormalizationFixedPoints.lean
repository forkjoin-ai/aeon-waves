import Init

/-!
# Renormalization Fixed Points — iterated coarsening as RG flow

Repeated coarsening is a renormalization-group trajectory through quotient space:
each step irreversibly erases information and dissipates Landauer heat, and the
flow terminates at a **fixed point** where further coarsening loses nothing.

The finite core kept here (the original quantified entropy over `PMF`/`ℝ`):

* **Chain rule.** Information loss is additive along a trajectory.
* **Thermodynamic arrow.** Cumulative heat is monotone: more steps, more heat.
* **Fixed point ⇔ zero loss.** A step is a fixed point exactly when it loses no
  information (the finite analog of `H(X ∣ q(X)) = 0`); concretely, a coarsening
  with no collision on its support is injective there.
* **Beauty floor.** At a fixed point the Landauer heat is zero.
* **Descent + termination.** Off a fixed point the loss is positive, and the
  remaining entropy is a monovariant driven down by each step.

`infoLoss`/`heat` are modeled over `Nat`; every proof closes from `Init` with no
banned tactic on an open goal.
-/

namespace Gnosis

-- §1  Steps, heat, and the chain rule ----------------------------------------

/-- A renormalization step: a coarsening with its finite information loss and a
    positive Boltzmann constant and temperature. -/
structure RGStep where
  infoLoss : Nat
  boltzmann : Nat
  temperature : Nat
  hkPos : 0 < boltzmann
  hTPos : 0 < temperature

/-- Landauer heat of a step: `k · T · infoLoss`. -/
def RGStep.heat (s : RGStep) : Nat := s.boltzmann * s.temperature * s.infoLoss

/-- A step is an RG fixed point when it loses no information. -/
def RGStep.IsFixedPoint (s : RGStep) : Prop := s.infoLoss = 0

/-- Total information loss along a trajectory of step losses. -/
def trajectoryLoss (losses : List Nat) : Nat := losses.foldr (· + ·) 0

/-- **Chain rule.** Information loss is additive along a trajectory: composing two
    segments sums their losses. -/
theorem trajectory_information_loss_additive (xs ys : List Nat) :
    trajectoryLoss (xs ++ ys) = trajectoryLoss xs + trajectoryLoss ys := by
  induction xs with
  | nil => exact (Nat.zero_add _).symm
  | cons x xs ih =>
      show x + trajectoryLoss (xs ++ ys) = x + trajectoryLoss xs + trajectoryLoss ys
      rw [ih]; exact (Nat.add_assoc x _ _).symm

/-- Heat at a given total loss, for fixed `k, T`. -/
def heatAt (boltzmann temperature loss : Nat) : Nat := boltzmann * temperature * loss

/-- **Thermodynamic arrow.** Cumulative heat is monotone: extending a trajectory
    can only increase the dissipated heat. -/
theorem trajectory_cumulative_heat_monotone
    (boltzmann temperature prefixLoss extra : Nat) :
    heatAt boltzmann temperature prefixLoss
      ≤ heatAt boltzmann temperature (prefixLoss + extra) :=
  Nat.mul_le_mul (Nat.le_refl _) (Nat.le_add_right prefixLoss extra)

/-- Three-step additivity: loss across three segments is the sum of the three. -/
theorem trajectory_three_step_additive (xs ys zs : List Nat) :
    trajectoryLoss (xs ++ ys ++ zs)
      = trajectoryLoss xs + trajectoryLoss ys + trajectoryLoss zs := by
  rw [trajectory_information_loss_additive, trajectory_information_loss_additive]

/-- Three-step heat monotonicity: heat is non-decreasing at each prefix. -/
theorem trajectory_three_step_heat_monotone
    (boltzmann temperature a b c : Nat) :
    heatAt boltzmann temperature a ≤ heatAt boltzmann temperature (a + b) ∧
    heatAt boltzmann temperature (a + b) ≤ heatAt boltzmann temperature (a + b + c) :=
  ⟨trajectory_cumulative_heat_monotone boltzmann temperature a b,
   trajectory_cumulative_heat_monotone boltzmann temperature (a + b) c⟩

-- §2  Fixed points -----------------------------------------------------------

/-- **Characterization.** A step is a fixed point iff its information loss is zero. -/
theorem fixed_point_iff_zero_loss (s : RGStep) :
    s.IsFixedPoint ↔ s.infoLoss = 0 := Iff.rfl

/-- **Beauty floor.** At a fixed point no further heat is generated. -/
theorem fixed_point_minimum_heat (s : RGStep) (h : s.IsFixedPoint) :
    s.heat = 0 := by
  show s.boltzmann * s.temperature * s.infoLoss = 0
  rw [show s.infoLoss = 0 from h]
  exact Nat.mul_zero _

/-- A fixed point sits at the beauty floor: zero heat and zero loss together. -/
theorem fixed_point_beauty_floor (s : RGStep) (h : s.IsFixedPoint) :
    s.heat = 0 ∧ s.infoLoss = 0 :=
  ⟨fixed_point_minimum_heat s h, h⟩

/-- **Descent.** Off a fixed point the information loss is strictly positive — the
    trajectory is not yet stationary. -/
theorem nonfixed_positive_loss (s : RGStep) (h : ¬ s.IsFixedPoint) :
    0 < s.infoLoss :=
  Nat.pos_of_ne_zero h

-- §3  Concrete coarsening: injectivity on support ----------------------------

/-- A concrete coarsening: a finite support and a quotient map. -/
structure Coarsening where
  support : List Nat
  quotient : Nat → Nat

/-- The quotient is injective on the support — the fixed-point condition. -/
def Coarsening.InjOnSupport (c : Coarsening) : Prop :=
  ∀ a ∈ c.support, ∀ b ∈ c.support, c.quotient a = c.quotient b → a = b

/-- A collision: two distinct supported points sharing an image. -/
def Coarsening.HasCollision (c : Coarsening) : Prop :=
  ∃ a ∈ c.support, ∃ b ∈ c.support, c.quotient a = c.quotient b ∧ a ≠ b

/-- A collision witnesses a loss of information: it breaks injectivity on support,
    so the coarsening is not a fixed point. -/
theorem collision_breaks_injectivity (c : Coarsening) (h : c.HasCollision) :
    ¬ c.InjOnSupport := by
  intro hInj
  obtain ⟨a, ha, b, hb, hEq, hNe⟩ := h
  exact hNe (hInj a ha b hb hEq)

/-- Injective on support means every coincidence of images is a coincidence of
    points: no information was merged. -/
theorem injective_identifies_classes (c : Coarsening) (h : c.InjOnSupport)
    (a b : Nat) (ha : a ∈ c.support) (hb : b ∈ c.support)
    (hEq : c.quotient a = c.quotient b) : a = b :=
  h a ha b hb hEq

-- §4  Termination: remaining entropy is a monovariant ------------------------

/-- Remaining entropy after running the trajectory's step losses against an
    initial budget `E`. -/
def remainingEntropy : Nat → List Nat → Nat
  | E, [] => E
  | E, loss :: rest => remainingEntropy (E - loss) rest

/-- **Monovariant.** The remaining entropy never exceeds the starting budget; each
    step can only draw it down — so on a finite budget the flow terminates. -/
theorem remaining_le_start : ∀ (E : Nat) (losses : List Nat),
    remainingEntropy E losses ≤ E
  | E, [] => Nat.le_refl E
  | E, loss :: rest =>
      Nat.le_trans (remaining_le_start (E - loss) rest) (Nat.sub_le E loss)

/-- A single non-trivial step strictly lowers the remaining entropy while the
    budget is non-empty: the descent is strict off a fixed point. -/
theorem step_strictly_descends (E loss : Nat) (hLoss : 0 < loss) (hE : 0 < E) :
    E - loss < E :=
  Nat.sub_lt hE hLoss

end Gnosis
