import Init

/-!
# Second-tier mysteries — Buleyean structure behind harder puzzles

Megalithic coordination needs no architect (positivity), and an undeciphered
script is underdetermined exactly when it has more symbols than meanings (a
positive decipherment deficit), trivially solved when they match.

The original mapped each domain into `BuleyeanSpace`; here the finite core is
self-contained over `Nat`, every proof closing from `Init`.
-/

namespace Gnosis
namespace SecondTierMysteries

/-- A Buleyean space of competing reconstructions. -/
structure BuleyeanSpace where
  rounds : Nat
  rejection : Nat → Nat
  bounded : ∀ i, rejection i ≤ rounds

def BuleyeanSpace.weight (bs : BuleyeanSpace) (i : Nat) : Nat := bs.rounds - bs.rejection i + 1

/-- **Megalithic coordination needs no architect:** every contributor keeps positive
    weight. -/
theorem megalithic_no_architect_needed (bs : BuleyeanSpace) (i : Nat) : 1 ≤ bs.weight i :=
  Nat.le_add_left 1 (bs.rounds - bs.rejection i)

/-- Coherence: equal rejection histories give equal weights. -/
theorem megalithic_coherence (bs1 bs2 : BuleyeanSpace) (i : Nat)
    (hR : bs1.rounds = bs2.rounds) (hV : bs1.rejection i = bs2.rejection i) :
    bs1.weight i = bs2.weight i := by
  show bs1.rounds - bs1.rejection i + 1 = bs2.rounds - bs2.rejection i + 1
  rw [hR, hV]

/-- An undeciphered script: symbols against candidate meanings. -/
structure UndecipheredScript where
  symbols : Nat
  meanings : Nat

/-- The decipherment deficit: unresolved interpretive degrees of freedom. -/
def deciphermentDeficit (us : UndecipheredScript) : Nat := us.symbols - us.meanings

/-- **A script is underdetermined** when symbols outrun meanings. -/
theorem decipherment_is_underdetermined (us : UndecipheredScript) (h : us.meanings < us.symbols) :
    0 < deciphermentDeficit us := Nat.sub_pos_of_lt h

/-- **Decipherment by rejection** (concentration): fewer rejections, higher weight. -/
theorem decipherment_by_rejection (bs : BuleyeanSpace) (i j : Nat)
    (h : bs.rejection i ≤ bs.rejection j) : bs.weight j ≤ bs.weight i := by
  show bs.rounds - bs.rejection j + 1 ≤ bs.rounds - bs.rejection i + 1
  exact Nat.add_le_add_right (Nat.sub_le_sub_left h bs.rounds) 1

/-- A matched script (meanings ≥ symbols) is trivially deciphered. -/
theorem zero_deficit_trivial_decipherment (symbols meanings : Nat) (h : symbols ≤ meanings) :
    symbols - meanings = 0 := Nat.sub_eq_zero_of_le h

end SecondTierMysteries
end Gnosis
