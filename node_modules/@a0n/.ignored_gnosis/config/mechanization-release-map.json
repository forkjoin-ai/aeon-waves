{
  "description": "Human-readable map: deployable surfaces → mechanization checks. Forge / ForgoCD should invoke validate:mechanization-release-gate; expand entries as custody grows.",
  "apps": {
    "apps/edge-web-app/**": [
      "pnpm run a0 -- run @a0n/gnosis:validate:mechanization-release-gate",
      "pnpm run a0 -- run @affectively/edge-web-app:typecheck"
    ],
    "apps/forkjoin-app/**": [
      "pnpm run a0 -- run @a0n/gnosis:validate:mechanization-release-gate",
      "pnpm run a0 -- run forkjoin-app:typecheck"
    ],
    "open-source/gnosis/THEOREM_LEDGER.md": [
      "pnpm run a0 -- run @a0n/gnosis:validate:mechanization-release-gate",
      "pnpm run gnode -- run open-source/gnosis/scripts/generate-ledger-mcp-coverage.ts --export main"
    ],
    "apps/communication-mcp/**": [
      "pnpm run a0 -- run @a0n/gnosis:validate:mechanization-release-gate"
    ],
    "apps/protocol-mcp/**": [
      "pnpm run a0 -- run @a0n/gnosis:validate:mechanization-release-gate",
      "pnpm run a0 -- run @forkjoin/protocol-mcp:typecheck"
    ]
  }
}
