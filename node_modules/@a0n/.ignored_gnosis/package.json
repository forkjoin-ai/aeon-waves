  "scripts": {
    "build": "pnpm --dir ../aeon run build && pnpm run monster:build",
    "build:typecheck": "pnpm exec tsc -p tsconfig.typecheck.json",
    "build:toy-tla": "monster ./scripts/build-toy-tla.ts",
    "generate:ledger-mcp": "pnpm --dir ../.. run gnode -- run open-source/gnosis/scripts/generate-ledger-mcp-coverage.ts --export main",
    "validate:ledger-mcp": "pnpm --dir ../.. run gnode -- run open-source/gnosis/scripts/validate-ledger-mcp-coverage.ts --export main",
    "validate:mutation-theorem-map": "pnpm exec tsx ./scripts/validate-mutation-theorem-map.ts",
    "validate:theorem-names": "./bin/monster scripts/validate-theorem-drift.mjs",
    "validate:mechanization-release-gate": "pnpm exec tsx ./scripts/run-mechanization-release-gate.ts",
    "validate:physics-sandbox": "cd lean && lake build PhysicsSandbox",
    "validate:seismic-stress-toy": "cd lean && lake build PlanetaryHomologySandbox && cd .. && ./bin/monster test src/__tests__/seismic-stress-toy.test.ts",
    "prepare:lean-minimal": "./bin/monster scripts/prepare-lean-minimal.mjs",
    "validate:init-only-imports": "./bin/monster scripts/validate-init-only-import-closure.mjs",
    "validate:init-only-imports:x10": "./bin/monster scripts/repeat-init-only-validation.mjs",
    "validate:lean-minimal": "pnpm run prepare:lean-minimal && cd lean-minimal && lake build && cd .. && pnpm run validate:init-only-imports",
