{
  "name": "gnosis-forkjoin-app",
  "sourceRoot": "open-source/gnosis/forkjoin-app/src",
  "projectType": "application",
  "tags": [
    "scope:edge",
    "scope:mcp",
    "scope:docs",
    "type:app"
  ],
  "targets": {
    "build": {
      "executor": "a0:run-commands",
      "options": {
        "cwd": "open-source/gnosis/forkjoin-app",
        "command": "bun run build"
      },
      "outputs": [
        "{projectRoot}/dist"
      ]
    },
    "dev": {
      "executor": "a0:run-commands",
      "options": {
        "cwd": "open-source/gnosis/forkjoin-app",
        "command": "bun run dev"
      }
    },
    "deploy:dev": {
      "executor": "a0:run-commands",
      "options": {
        "cwd": "open-source/gnosis/forkjoin-app",
        "command": "bun run deploy:dev"
      },
      "dependsOn": [
        "build"
      ]
    },
    "deploy:stage": {
      "executor": "a0:run-commands",
      "options": {
        "cwd": "open-source/gnosis/forkjoin-app",
        "command": "bun run deploy:stage"
      },
      "dependsOn": [
        "build"
      ]
    },
    "deploy:prod": {
      "executor": "a0:run-commands",
      "options": {
        "cwd": "open-source/gnosis/forkjoin-app",
        "command": "bun run deploy:prod"
      },
      "dependsOn": [
        "build"
      ]
    },
    "test": {
      "executor": "a0:run-commands",
      "options": {
        "cwd": "open-source/gnosis/forkjoin-app",
        "command": "pnpm run test",
        "passWithNoTests": true
      }
    },
    "typecheck": {
      "executor": "a0:run-commands",
      "options": {
        "cwd": "open-source/gnosis/forkjoin-app",
        "command": "echo 'gnosis-forkjoin-app typecheck deferred: legacy Three/React strict backlog'"
      }
    },
    "lint": {
      "executor": "a0:eslint",
      "options": {
        "lintFilePatterns": [
          "open-source/gnosis/forkjoin-app/src/**/*.ts",
          "open-source/gnosis/forkjoin-app/client/**/*.{ts,tsx}",
          "open-source/gnosis/forkjoin-app/scripts/**/*.ts",
          "open-source/gnosis/forkjoin-app/test/**/*.ts"
        ]
      }
    },
    "smoke:deployed": {
      "executor": "a0:run-commands",
      "options": {
        "cwd": "open-source/gnosis/forkjoin-app",
        "command": "bun run smoke:deployed"
      }
    },
    "register-aeonpid": {
      "executor": "a0:run-commands",
      "options": {
        "cwd": "open-source/gnosis/forkjoin-app",
        "command": "bun ../../../scripts/register-aeonpid.ts forkjoin-app production"
      }
    }
  }
}
