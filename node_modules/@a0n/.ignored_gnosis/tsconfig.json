{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "allowImportingTsExtensions": true,
    "lib": ["ES2022", "DOM"],
    "jsx": "react-jsx",
    "declaration": true,
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "paths": {
      "gnosis_runtime": ["./runtime/pkg/gnosis_runtime.js"],
      "@a0n/gnosis/test": ["./src/testing/index.ts"],
      "@a0n/gnosis/test/bun": ["./src/testing/bun.ts"],
      "@a0n/gnosis/test/vitest": ["./src/testing/vitest.ts"],
      "@a0n/raect": ["../raect/src/index.ts"],
      "@a0n/raect/*.js": ["../raect/src/*.ts", "../raect/src/*.tsx", "../raect/src/*/index.ts"],
      "@a0n/raect/*": ["../raect/src/*"],
      "@a0n/aeon": ["../aeon/src/index.ts"],
      "@a0n/aeon/*.js": ["../aeon/src/*.ts", "../aeon/src/*/index.ts"],
      "@a0n/aeon/*": ["../aeon/src/*"],
      "@a0n/bitwise": ["../bitwise/index.ts"],
      "@a0n/bitwise/pkg": ["../bitwise/pkg/bitwise.d.ts"],
      "@a0n/bitwise/*.js": ["../bitwise/*.ts"],
      "@a0n/bitwise/*": ["../bitwise/*"],
      "@a0n/auth": ["../auth/src/index.ts"],
      "@a0n/auth/*": ["../auth/src/*"],
      "@a0n/aeon-logic": ["../aeon-logic/src/index.ts"],
      "@a0n/aeon-logic/browser": ["../aeon-logic/src/browser.ts"],
      "@a0n/aeon-logic/probability-routing": ["../aeon-logic/src/probability-routing.ts"],
      "@a0n/aeon-pipelines": ["../aeon-pipelines/src/index.ts"],
      "@a0n/aeon-pipelines/*": ["../aeon-pipelines/src/*"],
      "@a0n/twokeys": ["../../packages/twokeys/src/index.ts"],
      "@a0n/telemetry": ["../../packages/telemetry/src/index.ts"],

      "vitest": ["./src/testing/vitest.ts"],
      "@jest/globals": ["./src/testing/index.ts"],
      "gnosis-betti-wasm": ["./gnosis-betti-wasm/pkg/gnosis_betti_wasm.js"]
    }
  },
  "include": ["src/**/*", "../bitwise/*.ts"],
  "exclude": ["src/__tests__/**/*", "src/**/*.test.ts", "src/benchmarks/**", "../bitwise/*.test.ts", "../bitwise/test-e2e.ts"]
}
