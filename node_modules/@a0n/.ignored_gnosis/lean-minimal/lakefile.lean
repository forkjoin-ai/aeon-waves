import Lake
open Lake DSL

/-!
# Gnosis Lean minimal (no Mathlib)

Builds only **Init-first** sandbox roots that share `../lean/Lean` sources without pulling in
`mathlib`. Heritage package: `../lean` (also Init-only today; see `roots` note there).

See `lean-minimal/README.md`.
-/

package «gnosis_lean_minimal» where
  version := v!"0.1.0"

-- Intentionally no `require mathlib` (fast CI / local checks).

@[default_target]
lean_lib GnosisLeanMinimal where
  -- Symlink `Lean` → `../lean/Lean` so Lake resolves `ForkRaceFoldTheorems.*` inside this package.
  srcDir := "Lean"
  /-
  Explicit order: Lake otherwise may schedule import consumers before their
  `ForkRaceFoldTheorems.*` prerequisites, which breaks module resolution.

  Heritage `../lean` includes `ParticlePredictionsFromFiveForces` (Init-only);
  it is mirrored here as a root so `lake build` tracks the same module graph.
  -/
  roots := #[
    `ForkRaceFoldTheorems.AntiDomainOverlay,
    `ForkRaceFoldTheorems.DiscreteSamplingDuel,
    `ForkRaceFoldTheorems.ZenonicBarrier,
    `ForkRaceFoldTheorems.RationalCutMiscalibration,
    `ForkRaceFoldTheorems.IceAntiIceCatalog,
    `ForkRaceFoldTheorems.HoneyPit,
    `ForkRaceFoldTheorems.PortAuthenticatedMesh,
    `ForkRaceFoldTheorems.CompetingOverlayResolution,
    `ForkRaceFoldTheorems.LinkedMeshComposition,
    `ForkRaceFoldTheorems.AntiVacuumDefenses,
    `ForkRaceFoldTheorems.TrainingSaturation,
    `ForkRaceFoldTheorems.VerifiedReconstruction,
    `ForkRaceFoldTheorems.CosmicArchitecture,
    `ForkRaceFoldTheorems.SovereignSieve,
    `ForkRaceFoldTheorems.StatisticalMechanicsAccounting,
    `ForkRaceFoldTheorems.GamutBraid,
    `ForkRaceFoldTheorems.GlossolaliaRace,
    `ForkRaceFoldTheorems.TerminalProsody,
    `ForkRaceFoldTheorems.ParticlePredictionsFromFiveForces
  ]

/-- PR-fast braid gate: only the current finite Fork/Race/Fold theorem surface. -/
lean_lib ArenaSocioMinimal where
  srcDir := "Lean"
  roots := #[
    `ForkRaceFoldTheorems.GamutBraid,
    `ForkRaceFoldTheorems.GlossolaliaRace,
    `ForkRaceFoldTheorems.TerminalProsody,
  ]
