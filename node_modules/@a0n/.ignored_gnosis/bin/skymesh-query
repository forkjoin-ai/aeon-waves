#!/usr/bin/env node
/*
 * skymesh-query -- debug tool: send a prompt to a Skymesh inference node
 * (fat-station) and print the real inference reply.
 *
 * Uses the reliable per-token autoregressive path (/tokenize + /decode-next with
 * X-Token/X-Position), NOT /generate (whose batched decode loop currently repeats
 * the last token). decode-next advances the node's KV cache one token at a time
 * and returns the argmax token_id + logit for the next position -- the same path
 * the Paris quality gate proves (prompt "The capital of France is" -> 12095 " Paris").
 *
 * Usage:
 *   bin/skymesh-query "The capital of France is" [--n 24] [--url http://127.0.0.1:8786]
 *   bin/skymesh-query --tokens 785,6722,315,9625,374 [--n 24]   (raw token ids)
 *
 * Notes: the node's KV cache is stateful + single-threaded; run one query at a
 * time. Full detokenization needs the node started with TOKENIZER_GGUF_PATH set to
 * a Qwen2 GGUF. Text->token /tokenize uses the node's tiny in-tree smoke table, so
 * arbitrary prose may 400 ("not in the smoke tokenizer's table") -- pass --tokens
 * with raw ids (or run the production tokenizer, aether-tokenizer-bridge) for those.
 */
'use strict';

function arg(name, def) {
  const i = process.argv.indexOf(name);
  return i !== -1 && i + 1 < process.argv.length ? process.argv[i + 1] : def;
}

const URL = arg('--url', process.env.SKYMESH_NODE_URL || 'http://127.0.0.1:8786');
const MAX_NEW = parseInt(arg('--n', '24'), 10);
// Prompt = the first non-flag argv after the script.
const prompt = process.argv.slice(2).find((a, i, arr) => !a.startsWith('--') && (i === 0 || !arr[i - 1].startsWith('--')));

// qwen end-of-text / im_end tokens -- stop decoding on these.
const STOP = new Set([151643, 151645, 151644]);

async function post(path, { headers = {}, body } = {}) {
  const res = await fetch(`${URL}${path}`, { method: 'POST', headers, body });
  const text = await res.text();
  if (!res.ok) throw new Error(`${path} HTTP ${res.status}: ${text.slice(0, 160)}`);
  try { return JSON.parse(text); } catch { return text; }
}

async function main() {
  if (!prompt && !arg('--tokens', '')) {
    console.error('usage: skymesh-query "<prompt>" [--n 24] [--url http://127.0.0.1:8786]');
    console.error('   or: skymesh-query --tokens 785,6722,315,9625,374 [--n 24]');
    process.exit(2);
  }
  // 1) health
  try {
    const h = await fetch(`${URL}/health`).then((r) => r.status);
    if (h !== 200) throw new Error(`health ${h}`);
  } catch (e) {
    console.error(`[skymesh-query] no inference node at ${URL} (${e.message}). Start one:`);
    console.error('  open-source/gnosis/distributed-inference/target/release/fat-station --knot ~/.edgework/models/qwen2.5-0.5b-instruct.knot --port 8786 --role both');
    process.exit(1);
  }

  // 2) tokenize (or take raw --tokens, bypassing the smoke-table encode limit)
  const rawTokens = arg('--tokens', '');
  let promptTokens;
  if (rawTokens) {
    promptTokens = rawTokens.split(',').map((s) => parseInt(s.trim(), 10)).filter((n) => Number.isFinite(n));
  } else {
    const tok = await post('/tokenize', {
      headers: { 'content-type': 'application/json' },
      body: JSON.stringify({ text: prompt }),
    }).catch((e) => {
      console.error(`[skymesh-query] /tokenize failed: ${e.message}`);
      console.error('  (the node\'s in-tree tokenizer is tiny; pass --tokens <ids> or run the production tokenizer)');
      process.exit(1);
    });
    promptTokens = tok.tokens || tok.token_ids || [];
  }
  console.log(`[skymesh-query] node ${URL}`);
  if (!rawTokens) console.log(`prompt : ${JSON.stringify(prompt)}`);
  console.log(`tokens : [${promptTokens.join(',')}] (${promptTokens.length})`);

  // 3) feed the prompt one token at a time; the reply after the last prompt
  //    token is the first prediction. Then continue autoregressively.
  const t0 = Date.now();
  let pos = 0;
  let next = null;
  for (const t of promptTokens) {
    const r = await post('/decode-next', { headers: { 'X-Token': String(t), 'X-Position': String(pos++) } });
    next = r.token_id;
  }
  const generated = [];
  for (let i = 0; i < MAX_NEW && next != null && !STOP.has(next); i++) {
    generated.push(next);
    const r = await post('/decode-next', { headers: { 'X-Token': String(next), 'X-Position': String(pos++) } });
    next = r.token_id;
  }
  const elapsed = Date.now() - t0;

  // 4) detokenize (best-effort)
  let reply = '(decode failed)';
  try {
    const d = await post('/detokenize', {
      headers: { 'content-type': 'application/json' },
      body: JSON.stringify({ token_ids: generated }),
    });
    reply = d.text ?? reply;
  } catch { /* smoke table may not cover all tokens */ }

  console.log(`reply  : ${JSON.stringify(reply)}`);
  console.log(`out    : [${generated.join(',')}] (${generated.length} tok, ${elapsed} ms)`);
}

main().catch((e) => {
  console.error('[skymesh-query] error:', e.message);
  process.exit(1);
});
