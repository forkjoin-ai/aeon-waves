#!/usr/bin/env bash
#
# Skymesh hosted-edge bridge -- one command.
#
# Connects the LOCAL aeon-monitor (HTTP 127.0.0.1:8722) UP to the hosted relay
# (WSS, the MonitorRelayDO at wss://skymesh.forkjoin.ai/monitor/bridge). It
# forwards frame/status/scenes UP and applies control DOWN, so the deployed
# Skymesh site shows real live monitor data and can drive the local radio with
# no CORS and no mixed content.
#
# Run the local monitor first (bin/skymesh-live), then this. The bridge dials
# OUT over WSS (no inbound firewall hole) and survives the local monitor going
# away.
#
# Requires SKYMESH_BRIDGE_TOKEN (must match the Worker `BRIDGE_TOKEN` secret),
# UNLESS run DashRelay-only (--no-relay --dashrelay <wss-base>).
#
# GLOBAL PARTYLINE: --mesh-id routes per mesh (default skymesh-global, the one
# global room); --node-id (default hostname) tags every frame's metadata.nodeId.
# --dashrelay <wss-base> adds an ADDITIVE second uplink to a DashRelay room.
#
# PREFLIGHT PARIS GATE: on a DOWN {type:"preflight",id} the bridge runs the
# VERIFIED paris-probe-rknot prover (REAL inference, ~3s) against --model and
# replies {type:"preflight-result",...} UP. A PASS (next token after "The capital
# of France is" is " Paris", token 12095) marks the node admitted -- prove, then
# join the global mesh. --model sets the gate model; --probe-bin the prover.
#
# MESH QUERY: on a DOWN {type:"query",id,prompt?,tokens?,maxTokens} the bridge
# runs the REAL per-token decode (VERIFIED /tokenize + /decode-next path, NOT
# /generate) against the local fat-station (--node-url, default
# http://127.0.0.1:8786) and replies {type:"query-result",...} UP. The node's
# tokenizer is a tiny smoke table, so arbitrary prose may 400 -- pass raw token
# ids and the detail surfaces any tokenizer error.
#
# Usage:  bin/skymesh-bridge [--relay <wss-url>] [--local <http-url>]
#                            [--token <secret>] [--scenes a,b,c]
#                            [--mesh-id <id>] [--node-id <id>]
#                            [--dashrelay <wss-base>] [--no-relay]
#                            [--model <path>] [--probe-bin <path>]
#                            [--node-url <http-url>]
#                            [--cache-url <base>] [--no-cache]
#
# GLOBAL ANSWER CACHE: on a DOWN {type:"query",...} the bridge first looks up the
# global answer cache (GET <cache-url>/api/v1/cache/lookup, keyed by the fp48
# canonical hash of the prompt tokens + model + skymesh-query/v1) and serves a
# VERIFIED hit (pass + admitted + signed) verbatim with cached:true -- no
# inference. On a miss it runs inference and, ONLY IF this node is admitted, signs
# + stores the answer (POST <cache-url>/api/v1/cache/put) and returns
# cached:false. --cache-url '' (default) or --no-cache leaves the cache OFF; any
# cache error falls through to inference and never breaks a query.
#
set -euo pipefail

GNOSIS_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
BRIDGE="$GNOSIS_ROOT/rtlsdr-mock-sim/skymesh-bridge.mts"

# DashRelay-only (--no-relay) does not need the bridge token; the hosted-relay
# path does. Only enforce the token when the relay is in play.
case " $* " in
  *" --no-relay "*) : ;;
  *) : "${SKYMESH_BRIDGE_TOKEN:?set SKYMESH_BRIDGE_TOKEN (matches the Worker BRIDGE_TOKEN secret), or run --no-relay --dashrelay <wss-base>}" ;;
esac

echo "[skymesh-bridge] local  http://127.0.0.1:8722  ->  relay wss://skymesh.forkjoin.ai/monitor/bridge (mesh skymesh-global)"

exec "$GNOSIS_ROOT/bin/gnode" run "$BRIDGE" "$@"
