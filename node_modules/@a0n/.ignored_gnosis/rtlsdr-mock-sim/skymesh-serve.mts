#!/usr/bin/env node
/**
 * Skymesh live frame server.
 *
 * A zero-extra-dependency Node HTTP server that streams gnosis.skymesh.v1 frames
 * to the Skymesh web app (built separately, in apps/skymesh -- NOT
 * touched here). The app polls GET /skymesh/frame.json for the latest frame and
 * subscribes to GET /skymesh/stream (Server-Sent Events) for ~4 fps live updates;
 * the UI itself animates at 12 fps from the pushed beat/spectrum state, so the
 * server only needs to push beat transitions + evolving spectra.
 *
 * Three modes:
 *   --mode demo    (default) synthesize the 6-beat sequence as live frames with
 *                  evolving 64-band spectra (moving noise floor + a carrier bin
 *                  that locks). No hardware. Drives the UI with motion.
 *   --mode file    poll a frame.json file (default the canonical skymesh-run.mts
 *                  output) and push it on change -- a real run drives the UI.
 *   --mode capture OPTIONAL/best-effort: shell rtl_sdr -d 0 / -d 1 to grab short
 *                  windows, extractWitness on each, admit, build + push the frame.
 *                  This is the REAL two-NESDR path; if rtl_sdr or the devices are
 *                  unavailable it logs and falls back to demo. It never crashes
 *                  the server.
 *
 * CORS is open (Access-Control-Allow-Origin: *) so the Vite dev server can consume
 * it cross-origin.
 */
import { createServer, type IncomingMessage, type ServerResponse } from 'node:http';
import { createSocket, type Socket as DgramSocket } from 'node:dgram';
import { readFileSync, statSync } from 'node:fs';
import { extname, resolve } from 'node:path';
import { tmpdir } from 'node:os';
import { join } from 'node:path';
import {
  admitStation,
  buildStation,
  buildSkymeshFrame,
  AIR_GAP_PROOF,
  SKYMESH_SCHEMA_VERSION,
  DEFAULT_SKYMESH_FRAME_PATH,
  type SkymeshFrame,
  type SkymeshStation,
} from './skymesh.ts';
import {
  extractWitness,
  DEFAULT_WITNESS_OPTS,
} from './skymesh-witness.ts';
import {
  probeRtlSdr,
  captureRtlSdrWindow,
} from './rf-cache-key.ts';
import { PROTOCOL69_BROADCAST_SYMBOL } from '../src/protocol69.ts';
// The canonical broadcast wire is aeon's Flow protocol. Each UDP datagram is one
// FlowCodec-encoded ConsciousTick frame (10-byte header + JSON payload) on the
// Skymesh stream (0x5353). See open-source/aeon/src/flow/FlowCodec.ts (the wire
// authority) and open-source/aeon/src/flow/SkymeshFlow.ts (the frame builder).
import {
  FlowCodec,
  encodeSkymeshFlowFrame,
  SKYMESH_FLOW_STREAM_ID,
  FORK,
  FOLD,
  type SkymeshFlowFrame,
} from '@a0n/aeon/flow';

// --------------------------------------------------------------------------
// CLI
// --------------------------------------------------------------------------

function argValue(name: string, def: string): string {
  const i = process.argv.indexOf(name);
  if (i === -1 || i + 1 >= process.argv.length) return def;
  return process.argv[i + 1]!;
}
function argFlag(name: string): boolean {
  return process.argv.includes(name);
}
/**
 * Resolve a flag that may carry an OPTIONAL value. `--udp` enables UDP and may
 * be followed by a port (`--udp 8725`); a bare `--udp` (or `--udp` followed by
 * another flag) uses the default. Returns the parsed value or `def` when the
 * flag is present without a usable value, or `null` when the flag is absent.
 */
function argOptionalValue(name: string, def: string): string | null {
  const i = process.argv.indexOf(name);
  if (i === -1) return null;
  const next = process.argv[i + 1];
  if (next === undefined || next.startsWith('--')) return def;
  return next;
}
/** Collect every occurrence of a repeatable `name <value>` flag, in order. */
function argValues(name: string): string[] {
  const out: string[] = [];
  for (let i = 0; i < process.argv.length; i++) {
    if (process.argv[i] === name && i + 1 < process.argv.length) {
      out.push(process.argv[i + 1]!);
    }
  }
  return out;
}

type ServeMode = 'demo' | 'file' | 'capture';

const SPECTRUM_BANDS = DEFAULT_WITNESS_OPTS.bands; // 64

// --------------------------------------------------------------------------
// Demo frame generator (pure; the test exercises this directly).
//
// The web-app cycle is six beats. The schema's station states are LISTENING ->
// WITNESS_LOCKED -> TELEPORTED -> DENIED; we add a "WITNESS_LOCKING" beat label
// for the lock-in animation (it still renders as a locked-but-not-admitted
// station, i.e. state WITNESS_LOCKED with witnessLocked true). The last two beats
// rotate the failure cases: DENIED (a tampered/forged key -- same sky, denied)
// and MISS (a different sky -- witnesses disagree). Both yield match:false.
// --------------------------------------------------------------------------

export type DemoBeatLabel =
  | 'LISTENING'
  | 'WITNESS_LOCKING'
  | 'WITNESS_LOCKED'
  | 'TELEPORTED'
  | 'DENIED'
  | 'MISS';

/** The canonical six-beat demo cycle, in order. */
export const DEMO_BEAT_SEQUENCE: readonly DemoBeatLabel[] = [
  'LISTENING',
  'WITNESS_LOCKING',
  'WITNESS_LOCKED',
  'TELEPORTED',
  'DENIED',
  'MISS',
] as const;

/**
 * Synthesize a plausible 64-band spectrum: a slowly-moving noise floor plus a
 * carrier bin that sharpens as the beat progresses. `lockProgress` in [0,1]
 * raises the carrier above the floor; `phase` slides the floor so the UI sees
 * motion every push. `carrierBand` selects which bin carries (two stations of the
 * same sky share it; a MISS station carries a different bin).
 */
export function synthSpectrum(args: {
  readonly phase: number;
  readonly lockProgress: number;
  readonly carrierBand: number;
  readonly bands?: number;
}): number[] {
  const bands = args.bands ?? SPECTRUM_BANDS;
  const carrier = ((args.carrierBand % bands) + bands) % bands;
  const raw = new Array<number>(bands);
  let total = 0;
  for (let b = 0; b < bands; b++) {
    // Moving noise floor: a low, smooth, phase-shifted ripple. Deterministic so
    // the same (phase, beat) always yields the same spectrum (testable).
    const floor =
      0.4 +
      0.15 * Math.sin((b / bands) * Math.PI * 6 + args.phase) +
      0.1 * Math.sin((b / bands) * Math.PI * 13 - args.phase * 1.7);
    // Carrier: a peak at the carrier band, growing with lockProgress, with a
    // little spectral skirt on the neighbours.
    const d = Math.min(Math.abs(b - carrier), bands - Math.abs(b - carrier));
    const carrierGain =
      args.lockProgress > 0 ? 8 * args.lockProgress * Math.exp(-(d * d) / 2) : 0;
    const v = Math.max(0, floor) + carrierGain;
    raw[b] = v;
    total += v;
  }
  // Normalize to a shape vector (matches the witness spectrum convention).
  const out = new Array<number>(bands);
  for (let b = 0; b < bands; b++) out[b] = total > 0 ? raw[b]! / total : 0;
  return out;
}

/** Build one station record for the demo, by-passing real witness extraction. */
function demoStation(args: {
  readonly id: string;
  readonly witness: number;
  readonly witnessLocked: boolean;
  readonly referenceWitness: number;
  readonly spectrum: number[];
  /** Forge the projection key so admission fails closed (DENIED beat). */
  readonly broadcastSymbol?: number;
  /**
   * Force the displayed state to WITNESS_LOCKED: the station has locked a witness
   * but is not yet attempting admission against a reference. We run admission with
   * witnessLocked=false (so admitStation returns LISTENING, never DENIED) and then
   * present witnessLocked=true to buildStation, which promotes LISTENING ->
   * WITNESS_LOCKED. This is the pre-teleport beat (locked, no token).
   */
  readonly displayLockedOnly?: boolean;
}): SkymeshStation {
  const lockedForAdmission = args.displayLockedOnly ? false : args.witnessLocked;
  const admission = admitStation({
    witness: args.witness,
    witnessLocked: lockedForAdmission,
    referenceWitness: args.referenceWitness,
    broadcastSymbol: args.broadcastSymbol,
  });
  return buildStation({
    id: args.id,
    witness: args.witness,
    witnessLocked: args.witnessLocked,
    spectrum: args.spectrum,
    admission,
  });
}

// Shared-sky witness for the two stations (top-3 dominant bands encoded 8 bits
// each, ascending -- see skymesh-witness.encodeBands). The carrier band is one
// of them so the synthesized spectrum and the witness tell the same story.
const SHARED_CARRIER_BAND = 30;
const SHARED_WITNESS = (10 << 16) | (20 << 8) | SHARED_CARRIER_BAND;
// A MISS station hears a different sky: an entirely different dominant-band set.
const MISS_CARRIER_BAND = 47;
const MISS_WITNESS = (3 << 16) | (15 << 8) | MISS_CARRIER_BAND;

/**
 * Produce the gnosis.skymesh.v1 frame for one beat of the demo cycle. `tick`
 * advances the moving noise floor so successive pushes animate. Pure + total:
 * the test asserts the schema shape, spectrum length, and the beat progression
 * (TELEPORTED -> match true; DENIED/MISS -> match false).
 */
export function demoFrameForBeat(beat: DemoBeatLabel, tick: number): SkymeshFrame {
  const phase = (tick % 360) * 0.12;

  switch (beat) {
    case 'LISTENING': {
      // No lock yet: both stations scanning, no token. Low, moving floor.
      const specA = synthSpectrum({ phase, lockProgress: 0, carrierBand: SHARED_CARRIER_BAND });
      const specB = synthSpectrum({ phase: phase + 0.6, lockProgress: 0, carrierBand: SHARED_CARRIER_BAND });
      const a = demoStation({ id: 'station-a', witness: SHARED_WITNESS, witnessLocked: false, referenceWitness: SHARED_WITNESS, spectrum: specA });
      const b = demoStation({ id: 'station-b', witness: SHARED_WITNESS, witnessLocked: false, referenceWitness: SHARED_WITNESS, spectrum: specB });
      return buildSkymeshFrame([a, b]);
    }
    case 'WITNESS_LOCKING': {
      // Carrier rising; locked but not yet admitting against the sky (no ref yet).
      const lp = 0.45;
      const specA = synthSpectrum({ phase, lockProgress: lp, carrierBand: SHARED_CARRIER_BAND });
      const specB = synthSpectrum({ phase: phase + 0.6, lockProgress: lp, carrierBand: SHARED_CARRIER_BAND });
      // Locked off the air but not yet admitting against a reference -> the
      // displayed state is WITNESS_LOCKED (no token yet).
      const a = demoStation({ id: 'station-a', witness: SHARED_WITNESS, witnessLocked: true, referenceWitness: SHARED_WITNESS, spectrum: specA, displayLockedOnly: true });
      const b = demoStation({ id: 'station-b', witness: SHARED_WITNESS, witnessLocked: true, referenceWitness: SHARED_WITNESS, spectrum: specB, displayLockedOnly: true });
      return buildSkymeshFrame([a, b]);
    }
    case 'WITNESS_LOCKED': {
      // Both fully locked on the same carrier; the shared answer has not
      // teleported yet (WITNESS_LOCKED, no token).
      const specA = synthSpectrum({ phase, lockProgress: 0.85, carrierBand: SHARED_CARRIER_BAND });
      const specB = synthSpectrum({ phase: phase + 0.6, lockProgress: 0.85, carrierBand: SHARED_CARRIER_BAND });
      const a = demoStation({ id: 'station-a', witness: SHARED_WITNESS, witnessLocked: true, referenceWitness: SHARED_WITNESS, spectrum: specA, displayLockedOnly: true });
      const b = demoStation({ id: 'station-b', witness: SHARED_WITNESS, witnessLocked: true, referenceWitness: SHARED_WITNESS, spectrum: specB, displayLockedOnly: true });
      return buildSkymeshFrame([a, b]);
    }
    case 'TELEPORTED': {
      // Both admit against each other's witness: 66 XOR 7 = 69, cached answer
      // served in lockstep. match true.
      const specA = synthSpectrum({ phase, lockProgress: 1, carrierBand: SHARED_CARRIER_BAND });
      const specB = synthSpectrum({ phase: phase + 0.6, lockProgress: 1, carrierBand: SHARED_CARRIER_BAND });
      const a = demoStation({ id: 'station-a', witness: SHARED_WITNESS, witnessLocked: true, referenceWitness: SHARED_WITNESS, spectrum: specA });
      const b = demoStation({ id: 'station-b', witness: SHARED_WITNESS, witnessLocked: true, referenceWitness: SHARED_WITNESS, spectrum: specB });
      return buildSkymeshFrame([a, b]);
    }
    case 'DENIED': {
      // Station B heard the SAME sky (witness agrees) but presents a forged
      // protocol69 key (broadcast symbol 67): projection 67 XOR 7 = 64, not 69 ->
      // fail closed. A teleports, B DENIED. match false.
      const specA = synthSpectrum({ phase, lockProgress: 1, carrierBand: SHARED_CARRIER_BAND });
      const specB = synthSpectrum({ phase: phase + 0.6, lockProgress: 1, carrierBand: SHARED_CARRIER_BAND });
      const a = demoStation({ id: 'station-a', witness: SHARED_WITNESS, witnessLocked: true, referenceWitness: SHARED_WITNESS, spectrum: specA });
      const b = demoStation({ id: 'station-b', witness: SHARED_WITNESS, witnessLocked: true, referenceWitness: SHARED_WITNESS, spectrum: specB, broadcastSymbol: 67 });
      return buildSkymeshFrame([a, b]);
    }
    case 'MISS': {
      // Station B hears a DIFFERENT sky -> different witness -> no agreement ->
      // neither is admitted to the shared answer. match false.
      const specA = synthSpectrum({ phase, lockProgress: 1, carrierBand: SHARED_CARRIER_BAND });
      const specB = synthSpectrum({ phase: phase + 0.6, lockProgress: 1, carrierBand: MISS_CARRIER_BAND });
      const a = demoStation({ id: 'station-a', witness: SHARED_WITNESS, witnessLocked: true, referenceWitness: MISS_WITNESS, spectrum: specA });
      const b = demoStation({ id: 'station-b', witness: MISS_WITNESS, witnessLocked: true, referenceWitness: SHARED_WITNESS, spectrum: specB });
      return buildSkymeshFrame([a, b]);
    }
  }
}

/**
 * Stateful demo frame generator. Each call advances the cycle: it holds each
 * beat for `holdTicks` pushes (so a beat visibly animates before transitioning),
 * then steps to the next beat, wrapping after MISS back to LISTENING.
 */
export function makeDemoGenerator(holdTicks = 8): () => SkymeshFrame {
  let tick = 0;
  return () => {
    const beatIndex = Math.floor(tick / Math.max(1, holdTicks)) % DEMO_BEAT_SEQUENCE.length;
    const beat = DEMO_BEAT_SEQUENCE[beatIndex]!;
    const frame = demoFrameForBeat(beat, tick);
    tick++;
    return frame;
  };
}

/**
 * The full six-beat cycle as a frame array (one frame per beat, no animation
 * sub-ticks). Useful for the test, which asserts the progression end to end.
 */
export function demoCycleFrames(tick = 0): SkymeshFrame[] {
  return DEMO_BEAT_SEQUENCE.map((beat, i) => demoFrameForBeat(beat, tick + i));
}

// --------------------------------------------------------------------------
// File mode: poll a frame.json and push on change.
// --------------------------------------------------------------------------

function readFrameFile(path: string): SkymeshFrame | null {
  try {
    const raw = readFileSync(path, 'utf8');
    const parsed = JSON.parse(raw) as SkymeshFrame;
    if (parsed?.schemaVersion !== SKYMESH_SCHEMA_VERSION) return null;
    return parsed;
  } catch {
    return null;
  }
}

// --------------------------------------------------------------------------
// Capture mode: best-effort two-NESDR path. Never crashes the server.
// --------------------------------------------------------------------------

interface CaptureConfig {
  readonly binary: string;
  readonly centerFrequencyHz: number;
  readonly sampleRateHz: number;
  readonly samplePairs: number;
  readonly lockConfidence: number;
}

/**
 * Attempt one capture-mode frame off two real NESDRs (-d 0 / -d 1). Returns null
 * if any device/binary is unavailable or a capture fails; the caller falls back.
 */
function captureFrameOnce(cfg: CaptureConfig): SkymeshFrame | null {
  const probe = probeRtlSdr();
  if (!probe.healthy || probe.devices.length < 2) {
    return null;
  }
  const witnesses: { id: string; witness: number; locked: boolean; spectrum: number[] }[] = [];
  for (const dev of ['0', '1']) {
    const out = join(tmpdir(), `skymesh-capture-d${dev}.u8`);
    const cap = captureRtlSdrWindow({
      binary: cfg.binary,
      outputPath: out,
      centerFrequencyHz: cfg.centerFrequencyHz,
      sampleRateHz: cfg.sampleRateHz,
      samplePairs: cfg.samplePairs,
      deviceIndex: dev,
    });
    if (!cap.ok) return null;
    let iq: Uint8Array;
    try {
      iq = new Uint8Array(readFileSync(out));
    } catch {
      return null;
    }
    const w = extractWitness(iq, { sampleRateHz: cfg.sampleRateHz });
    witnesses.push({
      id: dev === '0' ? 'station-a' : 'station-b',
      witness: w.witness,
      locked: w.confidence >= cfg.lockConfidence,
      spectrum: w.spectrum,
    });
  }
  const [a, b] = witnesses;
  if (!a || !b) return null;
  const admA = admitStation({
    witness: a.witness,
    witnessLocked: a.locked,
    referenceWitness: b.witness,
    broadcastSymbol: PROTOCOL69_BROADCAST_SYMBOL,
  });
  const admB = admitStation({
    witness: b.witness,
    witnessLocked: b.locked,
    referenceWitness: a.witness,
    broadcastSymbol: PROTOCOL69_BROADCAST_SYMBOL,
  });
  const stationA = buildStation({ id: a.id, witness: a.witness, witnessLocked: a.locked, spectrum: a.spectrum, admission: admA });
  const stationB = buildStation({ id: b.id, witness: b.witness, witnessLocked: b.locked, spectrum: b.spectrum, admission: admB });
  return buildSkymeshFrame([stationA, stationB]);
}

// --------------------------------------------------------------------------
// UDP datagram publisher over the aeon Flow wire (node:dgram, no new deps).
//
// Each new frame is emitted as exactly ONE FlowCodec-encoded ConsciousTick
// datagram (10-byte big-endian header + JSON payload) on the Skymesh Flow
// stream (0x5353) -- the canonical aeon Flow protocol, NOT an ad-hoc raw-JSON
// scheme. The JSON payload is the SAME gnosis.skymesh.v1 frame the SSE clients
// receive. One Flow frame per datagram (no MTU fragmentation for this hose).
//
// Multicast (the "same sky" broadcast: every listener on the group hears the
// identical datagram) is the default fan-out; unicast targets may be added or
// used instead. The publisher NEVER takes down the HTTP/SSE server: bind/send
// failures are logged and swallowed.
//
// Wire authority: open-source/aeon/src/flow/FlowCodec.ts (10-byte header --
// u16 streamId BE, u32 sequence BE, u8 flags, u24 length BE) and SkymeshFlow.ts
// (SKYMESH_FLOW_STREAM_ID = 0x5353, schema gnosis.skymesh.v1).
// --------------------------------------------------------------------------

/** UDP wire defaults (FIXED contract; other agents depend on these). */
export const UDP_DEFAULT_PORT = 8725;
export const UDP_DEFAULT_GROUP = '239.69.0.66';
export const UDP_DEFAULT_TTL = 1;
/**
 * Max UDP payload over IPv4 (65535 total - 20 IP header - 8 UDP header). A
 * Flow frame whose encoded bytes exceed this is skipped with a warning --
 * never truncated. Measured on the full FlowCodec datagram (header + payload).
 */
export const UDP_MAX_DATAGRAM_BYTES = 65507;

/**
 * Flow stream id for Skymesh broadcasts (re-exported for subscribers/tests
 * that want the contract value without importing @a0n/aeon directly).
 * @see open-source/aeon/src/flow/SkymeshFlow.ts
 */
export const UDP_FLOW_STREAM_ID = SKYMESH_FLOW_STREAM_ID; // 0x5353

/**
 * Flow flags for a Skymesh broadcast frame: FORK | FOLD (= 0x05). Each
 * datagram is a self-contained fork-then-fold tick (the air-gapped stations
 * fork off the same sky and fold to the same answer). FIXED contract.
 */
export const UDP_FLOW_FLAGS = FORK | FOLD; // 0x05

interface UdpTarget {
  readonly host: string;
  readonly port: number;
}

export interface UdpConfig {
  readonly enabled: boolean;
  readonly port: number;
  readonly group: string;
  readonly ttl: number;
  /** Unicast targets (in addition to the multicast group). */
  readonly targets: readonly UdpTarget[];
}

/** Parse a repeatable `host:port` target. Throws on a malformed entry. */
export function parseUdpTarget(raw: string): UdpTarget {
  const idx = raw.lastIndexOf(':');
  if (idx <= 0 || idx === raw.length - 1) {
    throw new Error(`--udp-target must be host:port (got: ${raw})`);
  }
  const host = raw.slice(0, idx);
  const port = Number.parseInt(raw.slice(idx + 1), 10);
  if (!Number.isInteger(port) || port < 1 || port > 65535) {
    throw new Error(`--udp-target port out of range in: ${raw}`);
  }
  return { host, port };
}

/**
 * A small frame publisher over a single UDP socket. Create once at startup via
 * `createUdpPublisher`; call `.publish(frame)` on every frame push; `.close()`
 * on shutdown. Returns `null` from the factory if UDP is disabled or the socket
 * cannot be created -- callers must treat UDP as best-effort and keep serving.
 */
export interface UdpPublisher {
  publish(frame: SkymeshFrame): void;
  close(): void;
}

export function createUdpPublisher(cfg: UdpConfig): UdpPublisher | null {
  if (!cfg.enabled) return null;

  // The Flow encoder is pure + synchronous (JS path; WASM is a perf-only
  // optimization we do not need here). One codec, reused for every frame.
  const codec = FlowCodec.createSync();
  // Monotonic Flow sequence counter (0, 1, 2, ...). u32 wraps at 2^32 to stay
  // within the Flow header's u32 sequence field.
  let sequence = 0;

  let socket: DgramSocket;
  try {
    socket = createSocket({ type: 'udp4', reuseAddr: true });
  } catch (e) {
    console.error(
      `[skymesh-serve] udp: failed to create dgram socket: ` +
        `${e instanceof Error ? e.message : String(e)} (udp disabled, http/sse unaffected)`,
    );
    return null;
  }

  // Never let an asynchronous socket error crash the process; log and keep the
  // HTTP/SSE server running. A udp error is not fatal to the server.
  socket.on('error', (err) => {
    console.error(`[skymesh-serve] udp: socket error: ${err.message} (continuing)`);
  });

  let multicastReady = false;
  // Bind so we can set the multicast TTL; bind is async, so set TTL on listening.
  try {
    socket.bind(() => {
      try {
        socket.setMulticastTTL(cfg.ttl);
        multicastReady = true;
      } catch (e) {
        console.error(
          `[skymesh-serve] udp: setMulticastTTL failed: ` +
            `${e instanceof Error ? e.message : String(e)} ` +
            `(multicast group sends may be skipped; unicast targets still used)`,
        );
      }
    });
  } catch (e) {
    console.error(
      `[skymesh-serve] udp: bind failed: ${e instanceof Error ? e.message : String(e)} ` +
        `(udp disabled, http/sse unaffected)`,
    );
    try {
      socket.close();
    } catch {
      /* ignore */
    }
    return null;
  }

  function send(payload: Buffer, host: string, port: number): void {
    socket.send(payload, port, host, (err) => {
      if (err) {
        console.error(
          `[skymesh-serve] udp: send to ${host}:${port} failed: ${err.message} (continuing)`,
        );
      }
    });
  }

  return {
    publish(frame: SkymeshFrame): void {
      // Encode ONE aeon Flow ConsciousTick frame: streamId 0x5353, a monotonic
      // sequence, flags FORK|FOLD (0x05), payload = utf8(JSON of the same frame
      // the SSE clients receive). encodeSkymeshFlowFrame owns the schema check
      // and the payload bytes; we pin the FIXED sequence + flags contract.
      const flowFrame = encodeSkymeshFlowFrame(
        frame as unknown as SkymeshFlowFrame,
        { sequence: sequence >>> 0, flags: UDP_FLOW_FLAGS },
      );
      sequence = (sequence + 1) >>> 0; // advance + wrap at u32, monotonic
      const encoded = codec.encode(flowFrame); // 10-byte header + payload
      const datagram = Buffer.from(
        encoded.buffer,
        encoded.byteOffset,
        encoded.byteLength,
      );
      // Honest size guard on the FULL Flow datagram: never silently truncate.
      // Skymesh frames are a few KB so this should never fire, but skip + warn
      // if it ever does. One Flow frame per datagram (no fragmentation).
      if (datagram.byteLength > UDP_MAX_DATAGRAM_BYTES) {
        console.error(
          `[skymesh-serve] udp: Flow frame is ${datagram.byteLength} bytes ` +
            `(> ${UDP_MAX_DATAGRAM_BYTES} UDP/IPv4 limit); skipping this datagram ` +
            `(never truncated). HTTP/SSE unaffected.`,
        );
        return;
      }
      // Multicast fan-out (the skymesh broadcast).
      if (multicastReady) {
        send(datagram, cfg.group, cfg.port);
      }
      // Unicast targets.
      for (const t of cfg.targets) {
        send(datagram, t.host, t.port);
      }
    },
    close(): void {
      try {
        socket.close();
      } catch {
        /* already closed */
      }
    },
  };
}

