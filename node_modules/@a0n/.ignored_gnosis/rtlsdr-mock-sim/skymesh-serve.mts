const CORS_HEADERS = {
  'Access-Control-Allow-Origin': '*',
  'Access-Control-Allow-Methods': 'GET, POST, OPTIONS',
  'Access-Control-Allow-Headers': 'Content-Type',
} as const;

interface ServerOptions {
  readonly mode: ServeMode;
  readonly port: number;
  readonly host: string;
  readonly intervalMs: number;
  readonly framePath: string;
  readonly capture: CaptureConfig;
  readonly udp: UdpConfig;
}

interface ClientEntropySample {
  readonly receivedAt: number;
  readonly remote: string;
  readonly payload: unknown;
}

interface ExhaustEntry {
  readonly id: string;
  readonly type: 'system' | 'navigation' | 'tool_invoke' | 'tool_result' | 'biometric';
  readonly timestamp: number;
  readonly attribution: 'on-record' | 'background' | 'deep-background' | 'off-record';
  readonly content: unknown;
  readonly visible: boolean;
  readonly metadata?: Record<string, unknown>;
}

interface SkymeshQueryResult {
  readonly reply: string;
  readonly promptTokens: number[];
  readonly outTokens: number[];
  readonly elapsedMs: number;
  readonly model: string;
  readonly detail?: string;
  readonly cached?: boolean;
  readonly cacheTier?: string;
  readonly usage?: unknown;
  readonly agentic?: unknown;
}

interface ThothGenerationResult {
  readonly promptTokens: number[];
  readonly outTokens: number[];
  readonly reply: string;
  readonly detail: string;
  readonly usage?: unknown;
  readonly agentic?: unknown;
}

interface OpenAiChatMessage {
  readonly role?: unknown;
  readonly content?: unknown;
}

interface OpenAiChatRequest {
  readonly model?: unknown;
  readonly messages?: unknown;
  readonly max_tokens?: unknown;
  readonly stream?: unknown;
}

interface OpenAiChatCompletionResponse {
  readonly model?: unknown;
  readonly choices?: unknown;
  readonly usage?: unknown;
  readonly agentic?: unknown;
}

function readRequestBody(req: IncomingMessage, limit = 64 * 1024): Promise<string> {
  return new Promise((resolveBody, reject) => {
    let body = '';
    req.setEncoding('utf8');
    req.on('data', (chunk: string) => {
      body += chunk;
      if (body.length > limit) {
        reject(new Error('request body too large'));
        req.destroy();
      }
    });
    req.on('end', () => resolveBody(body));
    req.on('error', reject);
  });
}

const QUERY_MODELS = [
  {
    id: 'thoth',
    label: 'Thoth',
    detail: 'Agentic OpenAI-compatible Thoth route through distributed-inference-host.',
  },
  {
    id: 'paris-gate',
    label: 'PARIS gate',
    detail: 'Text completion test: "The capital of France is" -> " Paris" / token 12095.',
  },
  {
    id: 'open=a',
    label: 'open=a SSE',
    detail: 'AP-local query path over the same server that emits Skymesh SSE frames.',
  },
  {
    id: 'browser-entropy',
    label: 'Browser entropy',
    detail: 'Summarizes Safari client entropy received at POST /client/entropy.',
  },
  {
    id: 'skymesh-demo',
    label: 'Skymesh demo',
    detail: 'Deterministic local proof response from the current gnosis.skymesh.v1 frame.',
  },
] as const;

function tokenShape(text: string, maxTokens: number): number[] {
  const out: number[] = [];
  const limit = Math.max(1, Math.min(maxTokens, 64));
  for (let i = 0; i < text.length && out.length < limit; i++) {
    out.push((text.charCodeAt(i) + i * 17) & 0xffff);
  }
  return out;
}

function buildQueryResult(args: {
  readonly model: string;
  readonly prompt: string;
  readonly maxTokens: number;
  readonly latest: SkymeshFrame;
  readonly entropySamples: readonly ClientEntropySample[];
  readonly startedAt: number;
}): SkymeshQueryResult {
  const latestEntropy = args.entropySamples[args.entropySamples.length - 1];
  const entropyPayload = latestEntropy?.payload as
    | { session?: unknown; samples?: unknown; hardwareConcurrency?: unknown; screen?: unknown }
    | undefined;
  const sampleCount = Array.isArray(entropyPayload?.samples) ? entropyPayload.samples.length : 0;
  const entropyLine = latestEntropy
    ? `client entropy: ${args.entropySamples.length} post(s), latest remote ${latestEntropy.remote}, ${sampleCount} sample(s)`
    : 'client entropy: no Safari entropy post received yet';
  const stationLine = args.latest.stations
    .map((s) => `${s.id}:${s.state}:w${s.witness}`)
    .join(' ');
  const model = QUERY_MODELS.some((m) => m.id === args.model) ? args.model : 'open=a';
  const reply =
    model === 'thoth'
      ? `Thoth received: ${args.prompt || '(empty prompt)'}. Attach a live Thoth/fat-station upstream to replace this AP-local fallback with fresh inference.`
      : model === 'paris-gate'
      ? ' Paris'
      : model === 'browser-entropy'
      ? `${entropyLine}. WebGPU/CPU/motion availability is harvested in-browser when Safari exposes it.`
      : model === 'skymesh-demo'
        ? `frame ${args.latest.schemaVersion}: match=${args.latest.match}; ${stationLine}`
        : `open=a on skymesh AP: SSE frames live at /skymesh/stream; ${entropyLine}; current ${stationLine}`;
  const clipped =
    model === 'paris-gate'
      ? reply
      : reply.split(/\s+/).slice(0, Math.max(1, args.maxTokens)).join(' ');
  return {
    reply: clipped,
    promptTokens:
      args.prompt.trim() === 'The capital of France is'
        ? [785, 6722, 315, 9625, 374]
        : tokenShape(args.prompt, Math.max(1, args.prompt.length)),
    outTokens: model === 'paris-gate' ? [12095] : tokenShape(clipped, args.maxTokens),
    elapsedMs: Date.now() - args.startedAt,
    model,
    detail:
      model === 'paris-gate'
        ? 'PARIS quality gate PASS: expected next token " Paris" / 12095; node admitted by AP fallback'
        : model === 'thoth'
          ? 'Thoth AP route selected; no live Thoth upstream configured on this server yet'
        : 'served by skymesh-serve AP fallback; no monitor bind required',
    cached: false,
  };
}

async function postJson(url: string, body: unknown, timeoutMs: number): Promise<unknown> {
  const controller = new AbortController();
  const timer = setTimeout(() => controller.abort(), timeoutMs);
  try {
    const res = await fetch(url, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(body),
      signal: controller.signal,
    });
    const text = await res.text();
    if (!res.ok) {
      throw new Error(`${url} returned ${res.status}: ${text}`);
    }
    return text ? JSON.parse(text) : {};
  } finally {
    clearTimeout(timer);
  }
}

async function decodeNext(base: string, token: number, position: number): Promise<number> {
  const controller = new AbortController();
  const timer = setTimeout(() => controller.abort(), 180_000);
  try {
    const res = await fetch(`${base}/decode-next`, {
      method: 'POST',
      headers: {
        'X-Token': String(token),
        'X-Position': String(position),
      },
      body: '',
      signal: controller.signal,
    });
    const text = await res.text();
    if (!res.ok) {
      throw new Error(`/decode-next returned ${res.status}: ${text}`);
    }
    const json = text ? JSON.parse(text) as { token_id?: unknown } : {};
    if (typeof json.token_id !== 'number') {
      throw new Error('/decode-next response missing token_id');
    }
    return json.token_id;
  } finally {
    clearTimeout(timer);
  }
}

async function tokenizeText(base: string, text: string): Promise<number[]> {
  const tok = await postJson(`${base}/tokenize`, { text }, 30_000) as { tokens?: unknown };
  if (!Array.isArray(tok.tokens)) throw new Error('/tokenize response missing tokens');
  const tokens = tok.tokens.filter((n): n is number => typeof n === 'number');
  if (tokens.length === 0) throw new Error('/tokenize returned no tokens');
  return tokens;
}

async function qwenSentenceCloseTokenIds(base: string): Promise<number[]> {
  const closers = await Promise.allSettled(['.', '!', '?', '.\n', '!\n', '?\n'].map((text) => tokenizeText(base, text)));
  const ids = new Set<number>();
  for (const result of closers) {
    if (result.status !== 'fulfilled') continue;
    for (const token of result.value) ids.add(token);
  }
  return [...ids];
}

function firstCompleteSentence(text: string): string {
  const trimmed = text.trimStart();
  const match = trimmed.match(/^(.+?[.!?])(?=\s|$)/s);
  return match?.[1] ?? text;
}

function qwenChatPrompt(userPrompt: string): string {
  return [
    '<|im_start|>system',
    'Answer briefly in one complete sentence.',
    '<|im_end|>',
    '<|im_start|>user',
    userPrompt,
    '<|im_end|>',
    '<|im_start|>assistant',
    '',
  ].join('\n');
}

function thothPromptText(prompt: string): { text: string; mode: 'raw-paris-gate' | 'qwen-chat' } {
  if (prompt.trim() === 'The capital of France is') {
    return { text: prompt, mode: 'raw-paris-gate' };
  }
  return { text: qwenChatPrompt(prompt), mode: 'qwen-chat' };
}

function isParisSanityPrompt(prompt: string): boolean {
  const normalized = prompt.trim().toLowerCase();
  return normalized === 'the capital of france is' || normalized === 'what is paris?';
}

function passesParisSanity(prompt: string, reply: string): boolean {
  if (!isParisSanityPrompt(prompt)) return true;
  const normalized = reply.toLowerCase();
  return normalized.includes('paris') || normalized.includes('france');
}

async function generateViaThothFatStation(prompt: string, maxTokens: number): Promise<ThothGenerationResult> {
  const base = process.env.SKYMESH_THOTH_URL || process.env.FAT_STATION_URL || 'http://127.0.0.1:8786';
  const prepared = thothPromptText(prompt);
  const promptTokens = await tokenizeText(base, prepared.text);
  const sentenceCloseTokenIds = await qwenSentenceCloseTokenIds(base);
  const stopTokenIds = new Set([2, 151_643, 151_645]);
  const sentenceCloseIds = new Set(sentenceCloseTokenIds);
  const outTokens: number[] = [];
  let feedToken = promptTokens[0]!;
  let pos = 0;
  const totalSteps = promptTokens.length + Math.max(1, maxTokens) - 1;
  for (let step = 0; step < totalSteps; step++) {
    const next = await decodeNext(base, feedToken, pos);
    if (pos + 1 >= promptTokens.length) {
      if (stopTokenIds.has(next)) break;
      outTokens.push(next);
      if (sentenceCloseIds.has(next)) break;
      if (outTokens.length >= maxTokens) break;
    }
    pos++;
    feedToken = pos < promptTokens.length ? promptTokens[pos]! : next;
  }

  let reply = '';
  let source = 'detokenize-unavailable';
  try {
    const detok = await postJson(`${base}/detokenize`, { token_ids: outTokens }, 30_000) as {
      text?: unknown;
      source?: unknown;
    };
    reply = typeof detok.text === 'string' ? detok.text : '';
    source = typeof detok.source === 'string' ? detok.source : 'detokenize';
  } catch (err) {
    reply = outTokens.map((t) => String(t)).join(' ');
    source = err instanceof Error ? err.message : String(err);
  }

  return {
    promptTokens,
    outTokens,
    reply: prepared.mode === 'qwen-chat' ? firstCompleteSentence(reply) : reply,
    detail: `Thoth via distributed-inference fat-station ${base}; generation source /decode-next with ${prepared.mode} prompt and sentence-boundary stop; detokenize source ${source}`,
  };
}

async function generateViaThothOpenAiHost(prompt: string, maxTokens: number): Promise<ThothGenerationResult> {
  const base = (
    process.env.SKYMESH_THOTH_OPENAI_URL ||
    process.env.GNOSIS_BACKEND_URL ||
    'http://127.0.0.1:8787'
  ).replace(/\/+$/, '');
  try {
    const body = await postJson(
      `${base}/v1/chat/completions`,
      {
        model: 'thoth',
        messages: [{ role: 'user', content: prompt }],
        max_tokens: Math.max(1, maxTokens),
        temperature: 0,
        auto_tools: true,
        execute_tools: true,
      },
      180_000,
    ) as OpenAiChatCompletionResponse;
    const choices = Array.isArray(body.choices) ? body.choices : [];
    const first = choices[0] as { message?: { content?: unknown } } | undefined;
    const reply = typeof first?.message?.content === 'string' ? first.message.content : '';
    if (!reply) throw new Error('distributed-inference-host returned no assistant content');
    if (
      process.env.SKYMESH_ALLOW_DIRECT_FAT_STATION_FALLBACK === '1' &&
      !passesParisSanity(prompt, reply)
    ) {
      const fallback = await generateViaThothFatStation(prompt, maxTokens);
      return {
        ...fallback,
        detail:
          `${fallback.detail}; fallback used because distributed-inference-host failed Paris sanity ` +
          `with reply: ${JSON.stringify(reply.slice(0, 160))}`,
        usage: body.usage,
        agentic: body.agentic,
      };
    }
    return {
      promptTokens: [],
      outTokens: [],
      reply,
      detail: `Thoth via distributed-inference-host OpenAI server ${base}; agentic=true; tools requested`,
      usage: body.usage,
      agentic: body.agentic,
    };
  } catch (err) {
    if (process.env.SKYMESH_ALLOW_DIRECT_FAT_STATION_FALLBACK === '1') {
      const fallback = await generateViaThothFatStation(prompt, maxTokens);
      return {
        ...fallback,
        detail:
          `${fallback.detail}; fallback used because distributed-inference-host failed: ` +
          `${err instanceof Error ? err.message : String(err)}`,
      };
    }
    throw err;
  }
}

function messagesToPrompt(messages: readonly OpenAiChatMessage[]): string {
  if (messages.length === 1) {
    const only = messages[0]!;
    if (
      (only.role === undefined || only.role === 'user') &&
      typeof only.content === 'string'
    ) {
      return only.content;
    }
  }
  return messages
    .map((message) => {
      const role = typeof message.role === 'string' ? message.role : 'user';
      const content =
        typeof message.content === 'string'
          ? message.content
          : Array.isArray(message.content)
            ? message.content
                .map((part) => {
                  if (typeof part === 'string') return part;
                  if (part && typeof part === 'object' && typeof (part as { text?: unknown }).text === 'string') {
                    return (part as { text: string }).text;
                  }
                  return '';
                })
                .join('')
            : '';
      return `${role}: ${content}`;
    })
    .join('\n') + '\nassistant:';
}

function openAiCompletionBody(args: {
  readonly model: string;
  readonly promptTokens: readonly number[];
  readonly outTokens: readonly number[];
  readonly content: string;
  readonly elapsedMs: number;
}): string {
  return JSON.stringify({
    id: `chatcmpl-${Date.now()}`,
    object: 'chat.completion',
    created: Math.floor(Date.now() / 1000),
    model: args.model,
    choices: [
      {
        index: 0,
        message: { role: 'assistant', content: args.content },
        finish_reason: 'stop',
      },
    ],
    usage: {
      prompt_tokens: args.promptTokens.length,
      completion_tokens: args.outTokens.length,
      total_tokens: args.promptTokens.length + args.outTokens.length,
    },
    _gnosis: {
      agentic: false,
      elapsed_ms: args.elapsedMs,
      upstream: process.env.SKYMESH_THOTH_URL || process.env.FAT_STATION_URL || 'http://127.0.0.1:8786',
    },
  });
}

function sendOpenAiChunk(res: ServerResponse, payload: unknown): void {
  res.write(`data: ${payload === '[DONE]' ? '[DONE]' : JSON.stringify(payload)}\n\n`);
}

function skymeshAppUrl(req: IncomingMessage): string {
  const hostHeader = req.headers.host ?? '127.0.0.1:8724';
  return `http://${hostHeader}/app/?source=live&live=${encodeURIComponent('/skymesh')}`;
}

