const APP_DIST_DIR = resolve(process.cwd(), '../../apps/skymesh/dist/client');

function contentTypeFor(path: string): string {
  switch (extname(path)) {
    case '.html':
      return 'text/html; charset=utf-8';
    case '.css':
      return 'text/css; charset=utf-8';
    case '.js':
      return 'text/javascript; charset=utf-8';
    case '.json':
      return 'application/json';
    case '.svg':
      return 'image/svg+xml';
    case '.png':
      return 'image/png';
    case '.ico':
      return 'image/x-icon';
    default:
      return 'application/octet-stream';
  }
}

function serveBuiltApp(url: string, res: ServerResponse): boolean {
  const relative =
    url === '/app' || url === '/app/'
      ? 'index.html'
      : url.startsWith('/app/')
        ? decodeURIComponent(url.slice('/app/'.length))
        : url.startsWith('/assets/')
          ? decodeURIComponent(url.slice(1))
          : '';
  if (!relative || relative.includes('..')) return false;
  const filePath = resolve(APP_DIST_DIR, relative);
  if (!filePath.startsWith(APP_DIST_DIR)) return false;
  try {
    const body = readFileSync(filePath);
    res.writeHead(200, {
      ...CORS_HEADERS,
      'Content-Type': contentTypeFor(filePath),
      'Cache-Control': relative === 'index.html' ? 'no-store' : 'no-cache',
    });
    res.end(body);
    return true;
  } catch {
    return false;
  }
}

function startServer(opts: ServerOptions): void {
  // The latest frame any endpoint will serve. Seeded immediately so frame.json
  // is never empty before the first push.
  let latest: SkymeshFrame = demoFrameForBeat('LISTENING', 0);
  const sseClients = new Set<ServerResponse>();
  const exhaustClients = new Set<ServerResponse>();
  const entropySamples: ClientEntropySample[] = [];
  const exhaustEntries: ExhaustEntry[] = [];

  // Optional UDP datagram side-channel. Created once at startup; null when the
  // socket could not be created or --udp was not requested.
  const udpPublisher = createUdpPublisher(opts.udp);

  function broadcast(frame: SkymeshFrame): void {
    latest = frame;
    const payload = `data: ${JSON.stringify(frame)}\n\n`;
    for (const res of sseClients) {
      res.write(payload);
    }
    // Send the same frame as one UDP datagram at the same moment SSE is pushed.
    if (udpPublisher) {
      udpPublisher.publish(frame);
    }
  }

  function appendExhaust(entry: Omit<ExhaustEntry, 'id' | 'timestamp' | 'attribution' | 'visible'> & {
    readonly attribution?: ExhaustEntry['attribution'];
    readonly visible?: boolean;
  }): ExhaustEntry {
    const full: ExhaustEntry = {
      id: `${Date.now().toString(36)}-${Math.random().toString(36).slice(2)}`,
      timestamp: Date.now(),
      attribution: entry.attribution ?? 'background',
      visible: entry.visible ?? true,
      type: entry.type,
      content: entry.content,
      metadata: entry.metadata,
    };
    exhaustEntries.push(full);
    while (exhaustEntries.length > 512) exhaustEntries.shift();
    const payload = `data: ${JSON.stringify(full)}\n\n`;
    for (const res of exhaustClients) {
      res.write(payload);
    }
    return full;
  }

  // ---- Frame source per mode ----
  const demoGen = makeDemoGenerator();
  let effectiveMode = opts.mode;
  let fileLastMtimeMs = -1;

  // File mode: load the current frame synchronously at boot so frame.json is the
  // real frame on the very first request (not the seeded LISTENING placeholder).
  if (opts.mode === 'file') {
    try {
      const st = statSync(opts.framePath);
      const frame = readFrameFile(opts.framePath);
      if (frame) {
        fileLastMtimeMs = st.mtimeMs;
        latest = frame;
      }
    } catch {
      // Not present yet; the poll picks it up when skymesh-run.mts writes it.
    }
  }

  function tick(): void {
    if (effectiveMode === 'demo') {
      broadcast(demoGen());
      return;
    }
    if (effectiveMode === 'file') {
      try {
        const st = statSync(opts.framePath);
        if (st.mtimeMs !== fileLastMtimeMs) {
          const frame = readFrameFile(opts.framePath);
          if (frame) {
            fileLastMtimeMs = st.mtimeMs;
            broadcast(frame);
          }
        }
      } catch {
        // File not present yet; keep the last frame, do not crash.
      }
      return;
    }
    if (effectiveMode === 'capture') {
      const frame = captureFrameOnce(opts.capture);
      if (frame) {
        broadcast(frame);
      } else {
        console.error(
          `[skymesh-serve] capture failed this window (device busy / no energy / ` +
            `binary error); falling back to demo for this push.`,
        );
        broadcast(demoGen());
      }
    }
  }

  const server = createServer((req: IncomingMessage, res: ServerResponse) => {
    const url = (req.url ?? '/').split('?')[0];

    if (req.method === 'OPTIONS') {
      res.writeHead(204, CORS_HEADERS);
      res.end();
      return;
    }

    if (url === '/healthz') {
      res.writeHead(200, { ...CORS_HEADERS, 'Content-Type': 'text/plain' });
      res.end('ok');
      return;
    }

    if (url === '/skymesh/exhaust.json') {
      const parsedUrl = new URL(req.url ?? '/', `http://${req.headers.host ?? '127.0.0.1'}`);
      const since = Number(parsedUrl.searchParams.get('since') ?? '0');
      res.writeHead(200, {
        ...CORS_HEADERS,
        'Content-Type': 'application/json',
        'Cache-Control': 'no-store',
      });
      res.end(JSON.stringify({
        ok: true,
        entries: exhaustEntries.filter((entry) => !Number.isFinite(since) || entry.timestamp > since).slice(-80),
      }));
      return;
    }

    if (url === '/skymesh/exhaust') {
      res.writeHead(200, {
        ...CORS_HEADERS,
        'Content-Type': 'text/event-stream',
        'Cache-Control': 'no-cache',
        Connection: 'keep-alive',
      });
      res.write('retry: 2000\n\n');
      for (const entry of exhaustEntries.slice(-24)) {
        res.write(`data: ${JSON.stringify(entry)}\n\n`);
      }
      exhaustClients.add(res);
      req.on('close', () => {
        exhaustClients.delete(res);
      });
      return;
    }

    if (req.method === 'GET' && serveBuiltApp(url, res)) {
      return;
    }

    if (
      req.method === 'GET' &&
      (
        url === '/' ||
        url === '/hotspot-detect.html' ||
        url === '/library/test/success.html' ||
        url === '/generate_204' ||
        url === '/gen_204' ||
        url === '/connecttest.txt' ||
        url === '/ncsi.txt'
      )
    ) {
      const appUrl = skymeshAppUrl(req);
      res.writeHead(200, {
        ...CORS_HEADERS,
        'Content-Type': 'text/html; charset=utf-8',
        'Cache-Control': 'no-store',
      });
      res.end(portalHtml(appUrl));
      return;
    }

    if (url === '/client/entropy' && req.method === 'POST') {
      void readRequestBody(req)
        .then(async (body) => {
          let payload: unknown = null;
          try {
            payload = body ? JSON.parse(body) : null;
          } catch {
            res.writeHead(400, { ...CORS_HEADERS, 'Content-Type': 'application/json' });
            res.end(JSON.stringify({ ok: false, error: 'invalid_json' }));
            return;
          }
          entropySamples.push({
            receivedAt: Date.now(),
            remote: req.socket.remoteAddress ?? 'unknown',
            payload,
          });
          while (entropySamples.length > 512) entropySamples.shift();
          res.writeHead(200, { ...CORS_HEADERS, 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ ok: true, samples: entropySamples.length }));
        })
        .catch((err: unknown) => {
          res.writeHead(400, { ...CORS_HEADERS, 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ ok: false, error: err instanceof Error ? err.message : String(err) }));
        });
      return;
    }

    if (url === '/client/entropy.json') {
      res.writeHead(200, {
        ...CORS_HEADERS,
        'Content-Type': 'application/json',
        'Cache-Control': 'no-store',
      });
      res.end(JSON.stringify({
        count: entropySamples.length,
        latest: entropySamples.slice(-16),
      }));
      return;
    }

    if (url === '/skymesh/models') {
      res.writeHead(200, {
        ...CORS_HEADERS,
        'Content-Type': 'application/json',
        'Cache-Control': 'no-store',
      });
      res.end(JSON.stringify({ ok: true, models: QUERY_MODELS }));
      return;
    }

    if (url === '/v1/models' && req.method === 'GET') {
      res.writeHead(200, {
        ...CORS_HEADERS,
        'Content-Type': 'application/json',
        'Cache-Control': 'no-store',
      });
      res.end(JSON.stringify({
        object: 'list',
        data: QUERY_MODELS.map((model) => ({
          id: model.id,
          object: 'model',
          created: 0,
          owned_by: 'skymesh',
        })),
      }));
      return;
    }

    if (url === '/v1/chat/completions' && req.method === 'POST') {
      const startedAt = Date.now();
      void readRequestBody(req)
        .then(async (body) => {
          let parsed: OpenAiChatRequest;
          try {
            parsed = body ? JSON.parse(body) as OpenAiChatRequest : {};
          } catch {
            res.writeHead(400, { ...CORS_HEADERS, 'Content-Type': 'application/json' });
            res.end(JSON.stringify({ error: { message: 'invalid_json', type: 'invalid_request_error' } }));
            return;
          }
          if (!Array.isArray(parsed.messages)) {
            res.writeHead(400, { ...CORS_HEADERS, 'Content-Type': 'application/json' });
            res.end(JSON.stringify({ error: { message: 'messages must be an array', type: 'invalid_request_error' } }));
            return;
          }

          const model = typeof parsed.model === 'string' ? parsed.model : 'thoth';
          const maxTokens =
            typeof parsed.max_tokens === 'number' && Number.isFinite(parsed.max_tokens)
              ? Math.max(1, Math.min(256, Math.floor(parsed.max_tokens)))
              : 64;
          const prompt = messagesToPrompt(parsed.messages as OpenAiChatMessage[]);
          const invoke = appendExhaust({
            type: 'tool_invoke',
            content: {
              tool: 'openai/chat.completions',
              phase: 'invoke',
              args: { model, max_tokens: maxTokens, stream: parsed.stream === true },
            },
            metadata: { remote: req.socket.remoteAddress ?? 'unknown' },
          });

          try {
            const generated =
              model === 'thoth'
                ? await generateViaThothOpenAiHost(prompt, maxTokens)
                : (() => {
                    const fallback = buildQueryResult({
                      model,
                      prompt,
                      maxTokens,
                      latest,
                      entropySamples,
                      startedAt,
                    });
                    return {
                      promptTokens: fallback.promptTokens,
                      outTokens: fallback.outTokens,
                      reply: fallback.reply,
                      detail: fallback.detail ?? 'skymesh fallback',
                    };
                  })();
            appendExhaust({
              type: 'tool_result',
              content: {
                tool: 'openai/chat.completions',
                phase: 'result',
                result: {
                  model,
                  reply: generated.reply,
                  promptTokens: generated.promptTokens,
                  outTokens: generated.outTokens,
                  elapsedMs: Date.now() - startedAt,
                  detail: generated.detail,
                  usage: generated.usage,
                  agentic: generated.agentic,
                },
                duration: Date.now() - startedAt,
                invokeId: invoke.id,
              },
              metadata: { remote: req.socket.remoteAddress ?? 'unknown' },
            });

            if (parsed.stream === true) {
              res.writeHead(200, {
                ...CORS_HEADERS,
                'Content-Type': 'text/event-stream',
                'Cache-Control': 'no-cache',
                Connection: 'keep-alive',
              });
              const id = `chatcmpl-${Date.now()}`;
              sendOpenAiChunk(res, {
                id,
                object: 'chat.completion.chunk',
                created: Math.floor(Date.now() / 1000),
                model,
                choices: [{ index: 0, delta: { role: 'assistant' }, finish_reason: null }],
              });
              sendOpenAiChunk(res, {
                id,
                object: 'chat.completion.chunk',
                created: Math.floor(Date.now() / 1000),
                model,
                choices: [{ index: 0, delta: { content: generated.reply }, finish_reason: null }],
              });
              sendOpenAiChunk(res, {
                id,
                object: 'chat.completion.chunk',
                created: Math.floor(Date.now() / 1000),
                model,
                choices: [{ index: 0, delta: {}, finish_reason: 'stop' }],
              });
              sendOpenAiChunk(res, '[DONE]');
              res.end();
              return;
            }

            res.writeHead(200, { ...CORS_HEADERS, 'Content-Type': 'application/json' });
            res.end(openAiCompletionBody({
              model,
              promptTokens: generated.promptTokens,
              outTokens: generated.outTokens,
              content: generated.reply,
              elapsedMs: Date.now() - startedAt,
            }));
          } catch (err) {
            appendExhaust({
              type: 'tool_result',
              content: {
                tool: 'openai/chat.completions',
                phase: 'result',
                result: { error: err instanceof Error ? err.message : String(err) },
                duration: Date.now() - startedAt,
                invokeId: invoke.id,
              },
              metadata: { remote: req.socket.remoteAddress ?? 'unknown' },
            });
            res.writeHead(502, { ...CORS_HEADERS, 'Content-Type': 'application/json' });
            res.end(JSON.stringify({
              error: {
                message: err instanceof Error ? err.message : String(err),
                type: 'upstream_error',
              },
            }));
          }
        })
        .catch((err: unknown) => {
          res.writeHead(400, { ...CORS_HEADERS, 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ error: { message: err instanceof Error ? err.message : String(err), type: 'invalid_request_error' } }));
        });
      return;
    }

    if (url === '/skymesh/query' && req.method === 'POST') {
      const startedAt = Date.now();
      void readRequestBody(req)
        .then(async (body) => {
          let parsed: {
            prompt?: unknown;
            tokens?: unknown;
            maxTokens?: unknown;
            model?: unknown;
            clientEntropy?: unknown;
          };
          try {
            parsed = body ? JSON.parse(body) : {};
          } catch {
            res.writeHead(400, { ...CORS_HEADERS, 'Content-Type': 'application/json' });
            res.end(JSON.stringify({ ok: false, error: 'invalid_json' }));
            return;
          }
          const prompt =
            typeof parsed.prompt === 'string'
              ? parsed.prompt
              : Array.isArray(parsed.tokens)
                ? parsed.tokens.join(',')
                : '';
          const maxTokens =
            typeof parsed.maxTokens === 'number' && Number.isFinite(parsed.maxTokens)
              ? Math.max(1, Math.min(256, Math.floor(parsed.maxTokens)))
              : 48;
          const model = typeof parsed.model === 'string' ? parsed.model : 'open=a';
          const invoke = appendExhaust({
            type: 'tool_invoke',
            content: {
              tool: `skymesh/query/${model}`,
              phase: 'invoke',
              args: { prompt, maxTokens },
            },
            metadata: { remote: req.socket.remoteAddress ?? 'unknown' },
          });
          if (parsed.clientEntropy !== undefined) {
            entropySamples.push({
              receivedAt: Date.now(),
              remote: req.socket.remoteAddress ?? 'unknown',
              payload: parsed.clientEntropy,
            });
            while (entropySamples.length > 512) entropySamples.shift();
            appendExhaust({
              type: 'biometric',
              content: parsed.clientEntropy,
              metadata: { remote: req.socket.remoteAddress ?? 'unknown' },
            });
          }
          let result: SkymeshQueryResult;
          if (model === 'thoth') {
            try {
              const generated = await generateViaThothOpenAiHost(prompt, maxTokens);
              result = {
                reply: generated.reply,
                promptTokens: generated.promptTokens,
                outTokens: generated.outTokens,
                elapsedMs: Date.now() - startedAt,
                model: 'thoth',
                detail: generated.detail,
                ...(generated.usage ? { usage: generated.usage } : {}),
                ...(generated.agentic ? { agentic: generated.agentic } : {}),
                cached: false,
              };
            } catch (err) {
              result = {
                reply: '',
                promptTokens: [],
                outTokens: [],
                elapsedMs: Date.now() - startedAt,
                model: 'thoth',
                detail: `Thoth/distributed-inference-host query failed: ${err instanceof Error ? err.message : String(err)}`,
                cached: false,
              };
            }
          } else {
            result = buildQueryResult({
              model,
              prompt,
              maxTokens,
              latest,
              entropySamples,
              startedAt,
            });
          }
          appendExhaust({
            type: 'tool_result',
            content: {
              tool: `skymesh/query/${model}`,
              phase: 'result',
              result,
              duration: result.elapsedMs,
              invokeId: invoke.id,
            },
            metadata: { remote: req.socket.remoteAddress ?? 'unknown' },
          });
          res.writeHead(200, { ...CORS_HEADERS, 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ ok: true, result }));
        })
        .catch((err: unknown) => {
          res.writeHead(400, { ...CORS_HEADERS, 'Content-Type': 'application/json' });
          res.end(JSON.stringify({ ok: false, error: err instanceof Error ? err.message : String(err) }));
        });
      return;
    }

    if (url === '/skymesh/frame.json') {
      res.writeHead(200, {
        ...CORS_HEADERS,
        'Content-Type': 'application/json',
        'Cache-Control': 'no-store',
      });
      res.end(JSON.stringify(latest));
      return;
    }

    if (url === '/skymesh/stream') {
      res.writeHead(200, {
        ...CORS_HEADERS,
        'Content-Type': 'text/event-stream',
        'Cache-Control': 'no-cache',
        Connection: 'keep-alive',
      });
      // Push the current frame immediately so a fresh subscriber renders at once.
      res.write(`retry: ${opts.intervalMs}\n\n`);
      res.write(`data: ${JSON.stringify(latest)}\n\n`);
      sseClients.add(res);
      req.on('close', () => {
        sseClients.delete(res);
      });
      return;
    }

    res.writeHead(404, { ...CORS_HEADERS, 'Content-Type': 'application/json' });
    res.end(JSON.stringify({ error: 'not_found', path: url }));
  });

  server.listen(opts.port, opts.host, () => {
    const base = `http://${opts.host}:${opts.port}`;
    // Probe for NESDRs AFTER the listener is up, so capture mode never delays the
    // server coming online (the probe is a blocking spawnSync). If hardware is
    // missing, fall back to the demo generator.
    if (effectiveMode === 'capture') {
      const probe = probeRtlSdr();
      if (!probe.healthy || probe.devices.length < 2) {
        console.error(
          `[skymesh-serve] capture mode requested but rtl_sdr/devices unavailable ` +
            `(healthy=${probe.healthy}, devices=${probe.devices.length}); ` +
            `falling back to --mode demo. This path needs two real NESDRs.`,
        );
        effectiveMode = 'demo';
      } else {
        console.error(
          `[skymesh-serve] capture mode: ${probe.devices.length} RTL-SDR device(s) detected; ` +
            `capturing from -d 0 and -d 1. NOTE: rtl_sdr capture is synchronous and ` +
            `blocks the push loop for the capture window; this is the real hardware path.`,
        );
      }
    }

    console.log(`[skymesh-serve] mode=${effectiveMode} interval=${opts.intervalMs}ms`);
    console.log(`[skymesh-serve] listening on ${base}`);
    console.log(`[skymesh-serve]   frame:  GET ${base}/skymesh/frame.json`);
    console.log(`[skymesh-serve]   stream: GET ${base}/skymesh/stream  (Server-Sent Events)`);
    console.log(`[skymesh-serve]   query:  POST ${base}/skymesh/query | GET /skymesh/models`);
    console.log(`[skymesh-serve]   health: GET ${base}/healthz`);
    console.log(`[skymesh-serve] entropy: POST ${base}/client/entropy | GET /client/entropy.json`);
    if (effectiveMode === 'file') {
      console.log(`[skymesh-serve]   tailing frame file: ${opts.framePath}`);
    }
    if (udpPublisher) {
      console.log(
        `[skymesh-serve] udp: broadcasting gnosis.skymesh.v1 over aeon Flow ` +
          `(stream 0x${SKYMESH_FLOW_STREAM_ID.toString(16)}) -> ` +
          `${opts.udp.group}:${opts.udp.port} (ttl ${opts.udp.ttl})`,
      );
      if (opts.udp.targets.length > 0) {
        const list = opts.udp.targets.map((t) => `${t.host}:${t.port}`).join(', ');
        console.log(`[skymesh-serve] udp: unicast targets -> ${list}`);
      }
    }

    // Start pushing once the server is live (and after the capture probe).
    const timer = setInterval(tick, opts.intervalMs);
    if (typeof timer.unref === 'function') timer.unref();
  });

  // Graceful shutdown: close the dgram socket so it never leaks on exit.
  const shutdown = (): void => {
    if (udpPublisher) udpPublisher.close();
    try {
      server.close();
    } catch {
      /* ignore */
    }
  };
  process.once('SIGINT', () => {
    shutdown();
    process.exit(0);
  });
  process.once('SIGTERM', () => {
    shutdown();
    process.exit(0);
  });
}

// --------------------------------------------------------------------------
// Entry point (skipped when imported, e.g. by the test).
// --------------------------------------------------------------------------

function parseMode(raw: string): ServeMode {
  if (raw === 'demo' || raw === 'file' || raw === 'capture') return raw;
  throw new Error(`--mode must be demo, file, or capture (got: ${raw})`);
}

function main(): void {
  const mode = parseMode(argValue('--mode', 'demo'));
  const port = Number.parseInt(argValue('--port', '8722'), 10);
  const host = argValue('--host', '127.0.0.1');
  const intervalMs = Number.parseInt(argValue('--interval-ms', '250'), 10);
  const framePath = resolve(argValue('--frame', DEFAULT_SKYMESH_FRAME_PATH));
  const capture: CaptureConfig = {
    binary: argValue('--rtl-sdr-bin', 'rtl_sdr'),
    centerFrequencyHz: Number.parseInt(argValue('--center-hz', '100000000'), 10),
    sampleRateHz: Number.parseInt(argValue('--iq-rate', '2400000'), 10),
    samplePairs: Number.parseInt(argValue('--sample-pairs', '262144'), 10),
    lockConfidence: Number.parseFloat(argValue('--lock-confidence', '0.12')),
  };

  // UDP datagram side-channel (additive; off unless --udp is present).
  const udpPortRaw = argOptionalValue('--udp', String(UDP_DEFAULT_PORT));
  const udp: UdpConfig = {
    enabled: udpPortRaw !== null,
    port:
      udpPortRaw !== null
        ? Number.parseInt(udpPortRaw, 10) || UDP_DEFAULT_PORT
        : UDP_DEFAULT_PORT,
    group: argValue('--udp-group', UDP_DEFAULT_GROUP),
    ttl: Number.parseInt(argValue('--udp-ttl', String(UDP_DEFAULT_TTL)), 10),
    targets: argValues('--udp-target').map(parseUdpTarget),
  };

  if (argFlag('--help') || argFlag('-h')) {
    console.log(
      [
        'skymesh-serve -- stream gnosis.skymesh.v1 frames to the web app',
        '',
        'Usage: tsx skymesh-serve.mts [--mode demo|file|capture] [--port 8722]',
        '',
        '  --mode demo      (default) synthesize the 6-beat live demo (no hardware)',
        '  --mode file      poll a frame.json and push on change (--frame <path>)',
        '  --mode capture   best-effort two-NESDR capture; falls back to demo',
        '  --port <n>       listen port (default 8722)',
        '  --host <addr>    bind address (default 127.0.0.1)',
        '  --interval-ms    push interval (default 250 = ~4 fps)',
        '  --frame <path>   frame.json for --mode file (default ' + DEFAULT_SKYMESH_FRAME_PATH + ')',
        '',
        'UDP datagram side-channel over the aeon Flow wire (additive; one FlowCodec',
        'frame per datagram, stream 0x' + SKYMESH_FLOW_STREAM_ID.toString(16) + ', schema gnosis.skymesh.v1):',
        '  --udp [port]        enable UDP Flow publishing (default port ' + UDP_DEFAULT_PORT + ')',
        '  --udp-group <grp>   multicast group (default ' + UDP_DEFAULT_GROUP + ')',
        '  --udp-ttl <n>       multicast TTL (default ' + UDP_DEFAULT_TTL + ' = link-local)',
        '  --udp-target h:p    unicast target host:port (repeatable; in addition to multicast)',
        '',
        'Endpoints: GET /skymesh/frame.json, GET /skymesh/stream (SSE), GET /healthz',
      ].join('\n'),
    );
    return;
  }

  startServer({ mode, port, host, intervalMs, framePath, capture, udp });
}

// Only run the server when executed directly (tsx/node), not when imported.
const isMain = (() => {
  try {
    const invoked = process.argv[1] ? resolve(process.argv[1]) : '';
    return invoked.endsWith('skymesh-serve.mts') || invoked.endsWith('skymesh-serve.js');
  } catch {
    return false;
  }
})();

if (isMain) {
  try {
    main();
  } catch (e) {
    console.error(e instanceof Error ? e.message : String(e));
    process.exitCode = 1;
  }
}
