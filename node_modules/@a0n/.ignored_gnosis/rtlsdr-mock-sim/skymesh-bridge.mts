// --------------------------------------------------------------------------
// MESH QUERY (FIXED contract shared by bridge + relay + app + MCP).
//
// The relay forwards a {type:"query",id,prompt?,tokens?,maxTokens} DOWN; the
// bridge runs the REAL per-token autoregressive decode against its local
// fat-station (the SAME reliable /decode-next path bin/skymesh-query proves --
// NOT /generate, whose batched decode repeats the last token) and replies
// {type:"query-result",...} UP. The inference is REAL; the reply is never mocked
// in the shipped path. Only the fetch is injectable (the test seam).
// --------------------------------------------------------------------------

/** qwen end-of-text / im_end tokens -- stop decoding on these. */
export const QUERY_STOP_TOKENS = [151643, 151645, 151644] as const;
/** Default number of new tokens to decode when the request omits maxTokens. */
export const QUERY_DEFAULT_MAX_TOKENS = 24;

/** The query-result the bridge sends UP (FIXED contract). */
export interface QueryResult {
  type: 'query-result';
  id: string;
  /** The detokenized reply text (best-effort; '' if detokenize is unavailable). */
  reply: string;
  /** The prompt token ids (echoed; from --tokens or the node's /tokenize). */
  promptTokens: number[];
  /** The generated token ids (argmax per position, before any stop token). */
  outTokens: number[];
  /** Wall-clock decode latency (ms) on the node. */
  elapsedMs: number;
  /** The model the node reports (from --model or /status). */
  model: string;
  /** Diagnostic detail (present on no-node / tokenize-400 / decode error). */
  detail?: string;
  /** True when the reply was served from the GLOBAL ANSWER CACHE (no inference). */
  cached?: boolean;
  /** Which mycelial cache tier served a hit (fano7 / aeon66 / monster196884). */
  cacheTier?: string;
}

// --------------------------------------------------------------------------
// GLOBAL ANSWER CACHE (WS-3 cache-aware bridge path).
//
// The cache library + HTTP contract are owned by WS-1 (@a0n/knotgraph
// global-cache.ts) and WS-2 (edgework-app /api/v1/cache/*). @a0n/knotgraph is
// NOT a dependency of @a0n/gnosis, so the bridge does NOT import it; instead it
// REPLICATES the lib's two contract surfaces it needs, byte-for-byte:
//
//   1) canonicalQueryHash(tokens, qspecId) -- the fp48 key, computed via the
//      SAME `cacheFingerprint48HexSync` from @a0n/bitwise/cache-fp48 over the
//      SAME canonical byte layout (qspecId utf8, 0x00, then each token id as a
//      little-endian u32). MODEL-AGNOSTIC: model is provenance, NOT in the key.
//      One differing prompt token or qspec changes the bytes -> the key. This is
//      the exact query-level analogue of fanoMycelialTierKeyBytes the WS-1 lib uses.
//   2) the GlobalAnswerCacheEntry shape the cache PUT body expects.
//
// Signing is v1: the WS-1 default verifier (presenceOnlySignatureVerifier) is
// presence-based, so a non-empty DETERMINISTIC node sig over the entry's
// identity (queryHash + answerTokens + nodeId) suffices. A real ed25519/HMAC
// node key is a follow-on; this is noted as v1.
// --------------------------------------------------------------------------

/** The fixed quality-spec / gate id for skymesh mesh queries (cache key part). */
export const SKYMESH_QSPEC_ID = 'skymesh-query/v2';
/** Canonical-key token separator byte (mirrors global-cache.ts TOKEN_SEP). */
const CACHE_TOKEN_SEP = 0x00;

/**
 * Replicates @a0n/knotgraph global-cache.ts `canonicalQueryKeyBytes`:
 *   qspecId utf8 | 0x00 | token[0] LE u32 | token[1] ...
 * MODEL-AGNOSTIC (model is provenance, NOT in the key). Byte-for-byte identical
 * so the bridge's key matches the WS-1/WS-2 key.
 */
export function canonicalQueryKeyBytes(
  queryTokens: readonly number[],
  qspecId: string,
): Uint8Array {
  const enc = new TextEncoder();
  const qspecBytes = enc.encode(qspecId);
  const out = new Uint8Array(qspecBytes.length + 1 + queryTokens.length * 4);
  let offset = 0;
  out.set(qspecBytes, offset);
  offset += qspecBytes.length;
  out[offset++] = CACHE_TOKEN_SEP;
  const view = new DataView(out.buffer);
  for (let i = 0; i < queryTokens.length; i++) {
    view.setUint32(offset, queryTokens[i]! >>> 0, true);
    offset += 4;
  }
  return out;
}

/**
 * The KEY: canonical query hash. fp48 (12 lowercase hex chars) over
 * `(queryTokens, qspecId)` via the SAME `cacheFingerprint48HexSync` the WS-1 lib
 * uses. MODEL-AGNOSTIC. Deterministic: same query -> same hash. Mirrors
 * @a0n/knotgraph `canonicalQueryHash` (incl. the empty-tokens clinamen guard).
 */
export function canonicalQueryHash(
  queryTokens: readonly number[],
  qspecId: string,
): string {
  if (queryTokens.length === 0) {
    throw new RangeError('canonicalQueryHash: empty queryTokens (clinamen_swerve guard)');
  }
  return cacheFingerprint48HexSync(canonicalQueryKeyBytes(queryTokens, qspecId));
}

/** The trusted attestation carried by a stored answer (mirrors WS-1 shape). */
export interface GlobalAnswerCacheAttestation {
  gate: string;
  pass: boolean;
  token: number;
  logit: number;
  nodeId: string;
  admitted: boolean;
  sig: string;
  attesterDid?: string;
}

/** One global cache entry (mirrors @a0n/knotgraph GlobalAnswerCacheEntry). */
export interface GlobalAnswerCacheEntry {
  queryHash: string;
  queryTokens: number[];
  model: string;
  qspecId: string;
  answerTokens: number[];
  answerText: string;
  attestation: GlobalAnswerCacheAttestation;
  ts: number;
  /** Optional tier hint; the cache stores it. */
  tier?: string;
}

/**
 * Deterministic node signature (v1). The WS-1 default verifier is presence-based,
 * so a stable non-empty digest over the entry's identity (queryHash, model,
 * qspecId, answerTokens, nodeId) suffices for v1. fp48 over the canonical bytes
 * gives a deterministic, non-empty, tamper-coupled string. Real ed25519/HMAC node
 * keys are a follow-on (noted v1).
 */
export function signCacheEntryV1(
  queryHash: string,
  answerTokens: readonly number[],
  nodeId: string,
  model: string,
  qspecId: string,
): string {
  const enc = new TextEncoder();
  const head = enc.encode(`${queryHash}␀${model}␀${qspecId}␀${nodeId}␀`);
  const bytes = new Uint8Array(head.length + answerTokens.length * 4);
  bytes.set(head, 0);
  const view = new DataView(bytes.buffer);
  for (let i = 0; i < answerTokens.length; i++) {
    view.setUint32(head.length + i * 4, answerTokens[i]! >>> 0, true);
  }
  return `sigv1:${cacheFingerprint48HexSync(bytes)}`;
}

/** A cache lookup response (WS-2 FIXED contract: GET .../cache/lookup). */
export interface CacheLookupResponse {
  hit: boolean;
  entry?: GlobalAnswerCacheEntry;
}

/**
 * On-hit verification before serving a cached answer (mirrors WS-1 `verifyEntry`
 * + `sameQueryIdentity`). Requires the trusted-attestation invariants (pass +
 * admitted + a non-empty sig + a replayable answer) AND the fp48 birthday-bound
 * identity check: the entry's own (queryTokens, qspecId) must re-hash to its
 * queryHash, must equal the REQUEST key, and the request's tokens must match
 * exactly. MODEL-AGNOSTIC: model is provenance, NOT identity — it is not
 * compared (any model's answer serves). The signature check is presence-based
 * (WS-1 default verifier; real crypto is a follow-on, noted v1).
 */
export function verifyCacheEntry(
  entry: GlobalAnswerCacheEntry,
  requestHash: string,
  requestTokens: readonly number[],
): boolean {
  const att = entry.attestation;
  if (!att || att.pass !== true || att.admitted !== true) return false;
  if (typeof att.sig !== 'string' || att.sig.length === 0) return false;
  if (!Array.isArray(entry.answerTokens) || entry.answerTokens.length === 0) return false;
  if (!Array.isArray(entry.queryTokens) || entry.queryTokens.length === 0) return false;
  // The stored entry must be internally consistent: its own identity re-hashes to
  // its queryHash, and that equals the request key.
  let rederived: string;
  try {
    rederived = canonicalQueryHash(entry.queryTokens, entry.qspecId);
  } catch {
    return false;
  }
  if (rederived !== entry.queryHash || entry.queryHash !== requestHash) return false;
  // Request-identity guard past the fp48 birthday bound: tokens + qspec exact
  // (model is provenance, not compared).
  if (entry.qspecId !== SKYMESH_QSPEC_ID) return false;
  if (entry.queryTokens.length !== requestTokens.length) return false;
  for (let i = 0; i < requestTokens.length; i++) {
    if (entry.queryTokens[i] !== requestTokens[i]) return false;
  }
  return true;
}

export interface BridgeConfig {
  /** WSS relay endpoint (the DO's /monitor/bridge upgrade). */
  readonly relay: string;
  /** Local aeon-monitor base, e.g. http://127.0.0.1:8722. No trailing /monitor. */
  readonly local: string;
  /** Shared secret presented to the relay on the WSS upgrade. */
  readonly token: string;
  /** Scenes to mirror; one local SSE subscription per entry. */
  readonly scenes: readonly string[];
  /** Status poll cadence (ms). */
  readonly statusPollMs: number;
  /** Backoff cap (ms) for relay reconnects. */
  readonly backoffCapMs: number;
  /** Local read retry cadence (ms) when the local monitor is down. */
  readonly localRetryMs: number;
  /** Mesh id this bridge publishes to (the relay routes per mesh id). */
  readonly meshId: string;
  /** Node id this bridge identifies as (frames carry it as metadata.nodeId). */
  readonly nodeId: string;
  /** When true, do NOT connect the hosted-relay uplink (DashRelay-only). */
  readonly noRelay: boolean;
  /** Optional DashRelay wss base (e.g. wss://dashrelay.com); '' = disabled. */
  readonly dashrelay: string;
  /** Path to the model the preflight prover loads (PARIS gate). `~` resolved. */
  readonly model: string;
  /**
   * Canonical model identity used in the GLOBAL ANSWER CACHE key (NOT the local
   * filesystem path -- two nodes with the same model at different paths MUST
   * share a cache key for the global cache to work cross-node). Defaults to the
   * model file's basename without extension; override with --model-id.
   */
  readonly modelId: string;
  /** Path to the paris-probe-rknot prover binary. `~` resolved. */
  readonly probeBin: string;
  /** Local fat-station inference node URL the bridge queries (decode-next path). */
  readonly nodeUrl: string;
  /**
   * GLOBAL ANSWER CACHE base URL (e.g. https://edgework.ai). '' = cache OFF: the
   * bridge never looks up or stores answers and every query runs inference. When
   * set, a mesh query first looks up the global cache and serves a verified hit,
   * else runs inference and (only if this node is admitted) stores the answer.
   */
  readonly cacheUrl: string;
}

const DEFAULT_RELAY = 'wss://skymesh.forkjoin.ai/monitor/bridge';
const DEFAULT_LOCAL = 'http://127.0.0.1:8722';
const DEFAULT_SCENES = 'skymesh,spectrum-waterfall,noaa-apt,image,mesh,residual,gate-telemetry,selftalk';
/** The local fat-station inference node the bridge queries (decode-next path). */
const DEFAULT_NODE_URL = 'http://127.0.0.1:8786';

/** Expand a leading `~` to the user's home directory; leave the rest as-is. */
export function resolveHome(p: string): string {
  if (p === '~') return os.homedir();
  if (p.startsWith('~/')) return path.join(os.homedir(), p.slice(2));
  return p;
}

/**
 * Resolve the default prover binary path: <gnosis repo root>/<DEFAULT_PROBE_REL>.
 * This .mts lives at <gnosis>/rtlsdr-mock-sim/skymesh-bridge.mts, so the gnosis
 * root is two levels up from the file's dir, and the repo root is one more up.
 */
function defaultProbeBin(): string {
  try {
    const here = new URL('.', import.meta.url).pathname; // .../rtlsdr-mock-sim/
    const repoRoot = path.resolve(here, '..', '..', '..'); // up to monorepo root
    return path.join(repoRoot, DEFAULT_PROBE_REL);
  } catch {
    return DEFAULT_PROBE_REL;
  }
}

/**
 * Canonical model identity for the GLOBAL cache key: the model file's basename
 * without its extension (e.g. /home/x/qwen2.5-0.5b-instruct.knot ->
 * "qwen2.5-0.5b-instruct"). Stable across machines/paths so nodes running the
 * SAME model share cache keys. Empty/odd input falls back to the raw string.
 */
export function canonicalModelId(modelPath: string): string {
  try {
    const base = path.basename(modelPath);
    // Strip ONLY a known model-file extension -- NOT any trailing dot-segment
    // (path.extname would mangle dotted names like "qwen2.5" -> "qwen2" or
    // "tinyllama-1.1b" -> "tinyllama-1"). Model weights are .knot/.gguf/etc.
    const ext = path.extname(base).toLowerCase();
    const KNOWN = new Set(['.knot', '.gguf', '.safetensors', '.bin', '.pt', '.pth', '.onnx']);
    const stem = KNOWN.has(ext) ? base.slice(0, -ext.length) : base;
    return stem.length > 0 ? stem : modelPath;
  } catch {
    return modelPath;
  }
}

/** Resolve the default node id (hostname), with a safe fallback. */
function defaultNodeId(): string {
  try {
    // os.hostname() via the env-agnostic require (the .mts runs under Node 22+).
    // Use a dynamic import-free path so the pure helpers stay test-friendly.
    return os.hostname() || 'skymesh-node';
  } catch {
    return 'skymesh-node';
  }
}

/** Build a config from argv + env (the runner / direct invocation path). */
export function configFromArgv(argv: readonly string[], env: NodeJS.ProcessEnv): BridgeConfig {
  return {
    relay: argValue(argv, '--relay', DEFAULT_RELAY),
    local: argValue(argv, '--local', DEFAULT_LOCAL).replace(/\/+$/, ''),
    token: argValue(argv, '--token', env.SKYMESH_BRIDGE_TOKEN ?? ''),
    scenes: argValue(argv, '--scenes', DEFAULT_SCENES)
      .split(',')
      .map((s) => s.trim())
      .filter((s) => s.length > 0),
    statusPollMs: Number.parseInt(argValue(argv, '--status-poll-ms', '1000'), 10),
    backoffCapMs: Number.parseInt(argValue(argv, '--backoff-cap-ms', '30000'), 10),
    localRetryMs: Number.parseInt(argValue(argv, '--local-retry-ms', '2000'), 10),
    meshId: argValue(argv, '--mesh-id', SKYMESH_GLOBAL_MESH_ID),
    nodeId: argValue(argv, '--node-id', defaultNodeId()),
    noRelay: argFlag(argv, '--no-relay'),
    dashrelay: argValue(argv, '--dashrelay', '').replace(/\/+$/, ''),
    model: resolveHome(argValue(argv, '--model', DEFAULT_PREFLIGHT_MODEL)),
    // Cache identity: --model-id wins; else the model file's basename (no ext).
    modelId: argValue(
      argv,
      '--model-id',
      canonicalModelId(resolveHome(argValue(argv, '--model', DEFAULT_PREFLIGHT_MODEL))),
    ),
    probeBin: resolveHome(argValue(argv, '--probe-bin', defaultProbeBin())),
    nodeUrl: argValue(argv, '--node-url', env.SKYMESH_NODE_URL ?? DEFAULT_NODE_URL).replace(/\/+$/, ''),
    // GLOBAL ANSWER CACHE: --cache-url turns it on; --no-cache forces it off even
    // if a URL is supplied (or via env SKYMESH_CACHE_URL). Default '' = cache OFF.
    cacheUrl: argFlag(argv, '--no-cache')
      ? ''
      : argValue(argv, '--cache-url', env.SKYMESH_CACHE_URL ?? '').replace(/\/+$/, ''),
  };
}

