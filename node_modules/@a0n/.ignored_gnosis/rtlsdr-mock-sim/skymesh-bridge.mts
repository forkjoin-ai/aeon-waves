#!/usr/bin/env node
/**
 * Skymesh hosted-edge bridge client.
 *
 * The inverse of the MonitorRelayDO: a small Node 22+ program that connects the
 * LOCAL aeon-monitor (plaintext HTTP on 127.0.0.1:8722) UP to the hosted relay
 * (WSS at wss://skymesh.forkjoin.ai/monitor/bridge). It forwards frames/status/
 * scenes UP and applies control DOWN, so the deployed Skymesh site can show real
 * live monitor data and drive the local radio with no CORS and no mixed content.
 *
 * The local monitor is never reachable from the public edge (127.0.0.1, plaintext);
 * this bridge dials OUT (outbound WSS, no inbound firewall hole) and the relay
 * caches + fans out the frames it pushes.
 *
 * Uplink protocol (FIXED -- byte-compatible with MonitorRelayDO.webSocketMessage,
 * see distributed-inference/docs/MONITOR_BRIDGE_DESIGN.md section 2.3):
 *
 *   UP   { type: "scenes",  scenes }              (on open + reconnect)
 *   UP   { type: "status",  status }              (on open + on change, ~1s poll)
 *   UP   { type: "frame",   envelope }            (per local SSE envelope)
 *   UP   { type: "control-result", id, ok, status, error }   (reply to a control)
 *   UP   { type: "query-result", id, reply, ... }  (reply to a mesh query)
 *   DOWN { type: "control", id, op, args }        (the relay forwards an app op)
 *   DOWN { type: "query", id, prompt?, tokens?, maxTokens }  (a mesh query)
 *
 * Zero heavy deps: the built-in WebSocket global (Node 22+) and global fetch /
 * ReadableStream for the local read surface. A tiny SSE `data:` parser consumes
 * the local stream server-side (NOT the browser EventSource).
 *
 * Usage: bin/skymesh-bridge [--relay wss://skymesh.forkjoin.ai/monitor/bridge]
 *                           [--local http://127.0.0.1:8722]
 *                           [--token $SKYMESH_BRIDGE_TOKEN]
 *                           [--scenes skymesh,spectrum-waterfall,...]
 *                           [--mesh-id skymesh-global] [--node-id $HOSTNAME]
 *                           [--dashrelay wss://dashrelay.com] [--no-relay]
 *
 * GLOBAL PARTYLINE (mesh id + node id): the relay routes per mesh id. Every
 * bridge publishing the default `skymesh-global` mesh joins one global room, so
 * the deployed app sees every node's frames; `--mesh-id <id>` carves a private
 * mesh. The first frame of identity is a `{type:"hello", nodeId}` on the relay
 * WS (and `?node=` on the upgrade); frames the relay returns carry
 * `metadata.nodeId` so the app can attribute each frame to a node.
 *
 * OPTIONAL DashRelay uplink (`--dashrelay <wssBase>`): an ADDITIVE second uplink
 * to a DashRelay room over the aeon-flow endpoint
 * (`<wssBase>/.aeon/flow?room=<meshId>`, opaque-relay mode). The join handshake is
 * the SAME JSON `{type:"join",room,mode:"opaque-relay",clientId}` text frame the
 * `/relay/sync` path uses (RelayRoomDO.handleAeonFlowUpgrade, src/durables/
 * RelayRoomDO.ts:1000 — first message must be a JSON JOIN, parseJoinMessage:289),
 * and the DO replies `{type:"joined"}` (joinPeer:1424) then `{type:"flow_ready"}`
 * (1107). After join, each local monitor envelope is carried as a single aeon
 * Flow frame on the MonitorFlow stream: `FlowCodec.encode(encodeMonitorFlowFrame
 * (envelope))` (binary), broadcast verbatim to the room's other peers
 * (opaque-relay relays binary frames as-is, processPeerFrame:1517 ->
 * broadcastToMode:1697). The bridge can publish to BOTH the hosted relay and
 * DashRelay, or DashRelay-only with `--no-relay`.
 *
 * DashRelay IS deployed at dashrelay.com (NOT the relay.* subdomain). The working
 * WS endpoint is the aeon-flow path `wss://dashrelay.com/.aeon/flow` (handshake
 * 101); the old `/relay/sync` opaque-relay join did NOT complete in probing
 * (HTTP 500 / WS 1006), so this transport now rides the aeon-flow endpoint and the
 * MonitorFlow Flow wire. Unit-tested against a mock aeon-flow relay.
 */

import os from 'node:os';
import path from 'node:path';
import { execFile } from 'node:child_process';
import {
  FlowCodec,
  encodeMonitorFlowFrame,
  type MonitorFlowFrame,
} from '@a0n/aeon/flow';
import { cacheFingerprint48HexSync } from '@a0n/bitwise/cache-fp48';

// --------------------------------------------------------------------------
// CLI
// --------------------------------------------------------------------------

/** Read a `--name value` flag from argv, or return the default. */
export function argValue(argv: readonly string[], name: string, def: string): string {
  const i = argv.indexOf(name);
  if (i === -1 || i + 1 >= argv.length) return def;
  return argv[i + 1]!;
}

/** Read a boolean `--name` flag (presence => true) from argv. */
export function argFlag(argv: readonly string[], name: string): boolean {
  return argv.includes(name);
}

/** The FIXED uplink message types (kept here so tests assert against the contract). */
export const UPLINK_MESSAGE_TYPES = ['scenes', 'status', 'frame', 'control-result', 'preflight-result', 'query-result'] as const;
export const DOWNLINK_MESSAGE_TYPES = ['control', 'preflight', 'query'] as const;

/** The default GLOBAL PARTYLINE mesh id (shared contract with the relay + app). */
export const SKYMESH_GLOBAL_MESH_ID = 'skymesh-global';

// --------------------------------------------------------------------------
// PREFLIGHT PARIS GATE (FIXED contract shared by bridge + relay + app).
//
// A node proves itself with a REAL inference test before joining the global
// mesh: the relay forwards a {type:"preflight",id} DOWN, the bridge spawns the
// VERIFIED paris-probe-rknot prover against its local model, parses the verdict
// from stdout, and replies {type:"preflight-result",...} UP. A PASS sets the
// bridge's internal `admitted` flag (carried in hello/status). The probe is REAL
// inference -- never a mocked verdict in the shipped path.
// --------------------------------------------------------------------------

