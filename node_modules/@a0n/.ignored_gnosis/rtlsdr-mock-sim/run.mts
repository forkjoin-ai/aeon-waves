function ensureDirFor(file: string): void {
  mkdirSync(dirname(file), { recursive: true });
}

type Mode =
  | 'synthetic'
  | 'replay'
  | 'batch'
  | 'fuse'
  | 'rf-key'
  | 'mars-link-budget'
  | 'mars-ladder'
  | 'mars-tx'
  | 'mars-rx';

const MODES: readonly Mode[] = [
  'synthetic',
  'replay',
  'batch',
  'fuse',
  'rf-key',
  'mars-link-budget',
  'mars-ladder',
  'mars-tx',
  'mars-rx',
];

function parseMode(): Mode {
  const argv = process.argv.slice(2);
  const hit = argv.find((a) => (MODES as readonly string[]).includes(a)) as Mode | undefined;
  if (hit === undefined) usage();
  return hit;
}

function canonicalCacheKeyPayload(): Uint8Array {
  return Uint8Array.from(encodeRfCacheKeyFrame(canonicalRfCacheKeyPacket).ascii, (c) =>
    c.charCodeAt(0),
  );
}

function parseRegime(raw: string): DistanceRegime {
  if (raw === 'opposition' || raw === 'mean' || raw === 'conjunction') return raw;
  throw new Error(`invalid --mars-regime ${raw}`);
}

function buildMfskOpts(): MfskOptions {
  const mod = (argValue('--mod', DEFAULT_MFSK.mod) as MfskMod);
  return {
    mod,
    iqRateHz: Number.parseInt(argValue('--iq-rate', String(DEFAULT_MFSK.iqRateHz)), 10),
    baud: Number.parseInt(argValue('--baud', String(DEFAULT_MFSK.baud)), 10),
    baseFreqHz: Number.parseInt(argValue('--base-freq', String(DEFAULT_MFSK.baseFreqHz)), 10),
    fec: resolveFecProfile(argValue('--fec-profile', 'rs+conv')),
    amplitude: Number.parseFloat(argValue('--amplitude', String(DEFAULT_MFSK.amplitude ?? 0.6))),
  };
}

function loadBatchSummary(path: string): BatchCaptureSummaryRow[] {
  const text = readFileSync(path, 'utf8');
  const parsed = JSON.parse(text) as unknown;
  if (!Array.isArray(parsed)) {
    throw new Error('batch summary must be a JSON array');
  }
  return parsed.filter(isBatchCaptureSummaryRow);
}

function parseCaptureFormat(raw: string | undefined): CaptureIqFormat | undefined {
  if (raw === undefined || raw.trim() === '') return undefined;
  if (raw === 'rtl_u8' || raw === 'signed_iq8') return raw;
  throw new Error(`invalid --capture-format ${raw}`);
}

function parseOptionalTxKind(raw: string): ExternalTxKind | null {
  if (raw.trim() === '') return null;
  if (
    raw === 'executable-stdin' ||
    raw === 'hackrf-transfer' ||
    raw === 'soapy-sdr-tx'
  ) {
    return raw;
  }
  throw new Error(`invalid --tx-kind ${raw}`);
}

function parseSymbolMode(raw: string): 'cache-key-frame' | 'monster-number' | 'polyglot-app-cache-key' {
  if (raw === 'cache-key-frame' || raw === 'monster-number' || raw === 'polyglot-app-cache-key') return raw;
  throw new Error(`invalid --symbol-mode ${raw}`);
}

function parseProtocol69FoilProbeTransport(raw: string): Protocol69FoilProbeTransport {
  if (raw === 'http' || raw === 'flow-udp' || raw === 'both') return raw;
  throw new Error(`invalid --protocol69-foil-transport ${raw}`);
}

function isBatchCaptureSummaryRow(value: unknown): value is BatchCaptureSummaryRow {
  if (typeof value !== 'object' || value === null || Array.isArray(value)) {
    return false;
  }
  const rec = value as Record<string, unknown>;
  return typeof rec.file === 'string' && rec.file.trim() !== '';
}

function isRecord(value: unknown): value is Record<string, unknown> {
  return typeof value === 'object' && value !== null && !Array.isArray(value);
}

function isProtocol69AppCacheKeyReceiptLike(value: unknown): value is Protocol69AppCacheKeyReceiptLike {
  if (!isRecord(value)) return false;
  if (typeof value.schemaVersion !== 'string') return false;
  if (typeof value.teleportKind !== 'string') return false;
  if (value.receiptReturn !== 'compute-cache-key') return false;
  if (typeof value.computeCacheKey !== 'string') return false;
  if (!isRecord(value.keyMaterial)) return false;
  return true;
}

function selectProtocol69AppReceiptFromJson(
  value: unknown,
  functionName: string,
): Protocol69AppCacheKeyReceiptLike {
  if (isProtocol69AppCacheKeyReceiptLike(value)) {
    return value;
  }
  if (isRecord(value) && Array.isArray(value.receipts)) {
    const receipts = value.receipts.filter(isProtocol69AppCacheKeyReceiptLike);
    if (receipts.length === 0) {
      throw new Error('protocol69 app report contains no cache-key receipts');
    }
    if (functionName.trim() === '') {
      return receipts[0]!;
    }
    const selected = receipts.find((receipt) => receipt.keyMaterial.functionName === functionName);
    if (selected) return selected;
    throw new Error(`protocol69 app report has no receipt for function ${functionName}`);
  }
  throw new Error('expected protocol69 app receipt or report JSON');
}

function loadProtocol69AppReceiptFile(
  path: string,
  functionName: string,
): Protocol69AppCacheKeyReceiptLike {
  return selectProtocol69AppReceiptFromJson(
    JSON.parse(readFileSync(path, 'utf8')) as unknown,
    functionName,
  );
}

function defaultPolyglotBin(): string {
  return resolve('polyglot/target/release/gnosis-polyglot');
}

function generateProtocol69AppReceipt(opts: {
  appSource: string;
  appFunction: string;
  polyglotBin: string;
  roomId: string;
  carrierHz: number;
  attenuationDb: string;
}): Protocol69AppCacheKeyReceiptLike {
  const argv = [
    opts.appSource,
    '--protocol69-teleport',
    '--carrier-hz',
    String(Math.round(opts.carrierHz)),
    '--antenna-count',
    '2',
  ];
  if (opts.appFunction.trim() !== '') {
    argv.push('--function', opts.appFunction);
  }
  if (opts.roomId.trim() !== '') {
    argv.push('--room-id', opts.roomId);
  }
  if (opts.attenuationDb.trim() !== '') {
    argv.push('--attenuation-db', opts.attenuationDb);
  }
  const result = spawnSync(opts.polyglotBin, argv, {
    cwd: process.cwd(),
    encoding: 'utf8',
    timeout: 30_000,
  });
  if ((result.status ?? 1) !== 0) {
    throw new Error(
      `gnosis-polyglot receipt generation failed: ${result.stderr || result.stdout || result.error?.message || 'unknown error'}`,
    );
  }
  return selectProtocol69AppReceiptFromJson(
    JSON.parse(result.stdout) as unknown,
    opts.appFunction,
  );
}

function collectCaptureFiles(root: string): string[] {
  const out: string[] = [];
  const stack = [root];
  while (stack.length > 0) {
    const cur = stack.pop()!;
    for (const entry of readdirSync(cur, { withFileTypes: true })) {
      const p = join(cur, entry.name);
      if (entry.isDirectory()) {
        stack.push(p);
        continue;
      }
      const ext = extname(entry.name).toLowerCase();
      if (ext === '.u8' || ext === '.cu8' || ext === '.cs8' || ext === '.s8') {
        out.push(p);
      }
    }
  }
  return out.sort();
}

async function main(): Promise<void> {
  const mode = parseMode();
  const iqRate = Number.parseFloat(argValue('--iq-rate', '2048000'));
  const audioRate = Number.parseFloat(argValue('--audio-rate', '48000'));
  const u8Out = resolve(argValue('--u8-out', '.qa-artifacts/rtlsdr/mock.u8'));
  const wavOut = resolve(argValue('--wav-out', '.qa-artifacts/rtlsdr/mock.wav'));

  if (mode === 'rf-key') {
    const transportRaw = argValue('--transport', 'simulated');
    if (transportRaw !== 'simulated' && transportRaw !== 'hardware') {
      console.error(`invalid --transport ${transportRaw} (expected simulated|hardware)`);
      process.exit(2);
    }
    const symbolMode = parseSymbolMode(argValue('--symbol-mode', 'cache-key-frame'));
    const protocol69FoilProbeEnabled = argFlag('--protocol69-foil-probe');
    if (protocol69FoilProbeEnabled && symbolMode !== 'monster-number') {
      console.error('--protocol69-foil-probe requires --symbol-mode monster-number');
      process.exit(2);
    }
    const txCenterFrequencyHz = Number.parseFloat(
      argValue(
        '--tx-center-frequency-hz',
        String(
          Number.parseFloat(process.env.GNOSIS_RF_TX_CENTER_FREQUENCY_HZ ?? '') ||
            defaultRfTxCenterFrequencyHz,
        ),
      ),
    );
    const txSampleRateHz = Number.parseFloat(
      argValue(
        '--tx-sample-rate-hz',
        String(
          Number.parseFloat(process.env.GNOSIS_RF_TX_SAMPLE_RATE_HZ ?? '') ||
            defaultRfTxSampleRateHz,
        ),
      ),
    );
    const txGainDb = Number.parseFloat(
      argValue(
        '--tx-gain-db',
        String(
          Number.parseFloat(process.env.GNOSIS_RF_TX_GAIN_DB ?? '') ||
            defaultRfTxGainDb,
        ),
      ),
    );
    const appFunction = argValue('--app-function', argValue('--function', ''));
    const appReceiptFile = argValue(
      '--app-receipt-file',
      process.env.GNOSIS_PROTOCOL69_APP_RECEIPT_FILE ?? '',
    ).trim();
    const appSource = argValue(
      '--app-source',
      process.env.GNOSIS_PROTOCOL69_APP_SOURCE ?? '',
    ).trim();
    const polyglotBin = argValue(
      '--polyglot-bin',
      process.env.GNOSIS_POLYGLOT_BIN ?? defaultPolyglotBin(),
    ).trim();
    const appReceipt =
      symbolMode === 'polyglot-app-cache-key'
        ? appReceiptFile !== ''
          ? loadProtocol69AppReceiptFile(appReceiptFile, appFunction)
          : appSource !== ''
            ? generateProtocol69AppReceipt({
                appSource,
                appFunction,
                polyglotBin,
                roomId: argValue('--room-id', process.env.GNOSIS_RF_ROOM_ID ?? ''),
                carrierHz: txCenterFrequencyHz,
                attenuationDb: argValue(
                  '--attenuation-db',
                  process.env.GNOSIS_RF_ATTENUATION_DB ?? '',
                ),
              })
            : undefined
        : undefined;
    if (symbolMode === 'polyglot-app-cache-key' && appReceipt === undefined) {
      console.error(
        '--symbol-mode polyglot-app-cache-key requires --app-source or --app-receipt-file',
      );
      process.exit(2);
    }
    if (appReceipt !== undefined) {
      buildProtocol69AppCacheKeyTransmission(appReceipt);
    }
    const protocol69FoilTransport = parseProtocol69FoilProbeTransport(
      argValue(
        '--protocol69-foil-transport',
        process.env.GNOSIS_PROTOCOL69_FOIL_TRANSPORT ?? 'both',
      ),
    );
    const protocol69FoilUrl = argValue(
      '--protocol69-foil-url',
      process.env.GNOSIS_PROTOCOL69_FOIL_URL ?? 'http://127.0.0.1:8787/.aeon/protocol69',
    );
    const protocol69FlowHost = argValue(
      '--protocol69-flow-host',
      process.env.GNOSIS_PROTOCOL69_FLOW_HOST ?? '127.0.0.1',
    );
    const protocol69FlowPort = Number.parseInt(
      argValue('--protocol69-flow-port', process.env.GNOSIS_PROTOCOL69_FLOW_PORT ?? '9082'),
      10,
    );
    const protocol69FlowPath = argValue(
      '--protocol69-flow-path',
      process.env.GNOSIS_PROTOCOL69_FLOW_PATH ?? '/.aeon/protocol69',
    );
    const protocol69TimeoutMs = Number.parseInt(
      argValue('--protocol69-timeout-ms', process.env.GNOSIS_PROTOCOL69_TIMEOUT_MS ?? '5000'),
      10,
    );
    const protocol69FoilProbe = protocol69FoilProbeEnabled
      ? await probeProtocol69Foil({
          transport: protocol69FoilTransport,
          url: protocol69FoilUrl,
          flowHost: protocol69FlowHost,
          flowPort: protocol69FlowPort,
          flowPath: protocol69FlowPath,
          timeoutMs: protocol69TimeoutMs,
        })
      : undefined;
    if (transportRaw === 'simulated') {
      console.log(
        JSON.stringify(
          buildMonsterRfCacheKeyEnvelope({
            transport: 'simulated',
            symbolMode,
            appTeleportReceipt: appReceipt,
            protocol69FoilProbe,
          }),
          null,
          2,
        ),
      );
      if (protocol69FoilProbe && !protocol69FoilProbe.ok) {
        process.exit(2);
      }
      return;
    }

    const rtlTestBin = argValue('--rtl-test-bin', process.env.RTL_TEST ?? 'rtl_test');
    const rtlSdrBin = argValue('--rtl-sdr-bin', process.env.RTL_SDR ?? 'rtl_sdr');
    const rxCaptureOnly = argFlag('--rx-capture-only');
    const rxCaptureOut = argValue(
      '--rx-capture-out',
      process.env.GNOSIS_RF_RX_CAPTURE_OUT ?? defaultRfKeyRxCapturePath,
    );
    const rxSamples = Number.parseInt(
      argValue(
        '--rx-samples',
        process.env.GNOSIS_RF_RX_SAMPLES ?? String(defaultRfKeyRxSamplePairs),
      ),
      10,
    );
    const rxDevice = argValue(
      '--rx-device',
      process.env.GNOSIS_RF_RX_DEVICE ?? '',
    ).trim();
    const txBin = argValue('--tx-bin', process.env.GNOSIS_RF_TX_BIN ?? '').trim();
    const txKind = parseOptionalTxKind(
      argValue('--tx-kind', process.env.GNOSIS_RF_TX_KIND ?? ''),
    );
    const txDeviceArgs = argValue(
      '--tx-device-args',
      process.env.GNOSIS_RF_TX_DEVICE_ARGS ?? '',
    ).trim();
    const txIqFile = argValue(
      '--tx-iq-file',
      process.env.GNOSIS_RF_TX_IQ_FILE ?? '',
    ).trim();
    const probe = probeRtlSdr(rtlTestBin);
    const rxCapture = rxCaptureOnly
      ? captureRtlSdrWindow({
          binary: rtlSdrBin,
          outputPath: rxCaptureOut,
          centerFrequencyHz: txCenterFrequencyHz,
          sampleRateHz: txSampleRateHz,
          samplePairs: rxSamples,
          deviceIndex: rxDevice,
        })
      : undefined;
    const resolvedTxKind = txKind ?? (txBin === '' ? null : inferExternalTxKind(txBin));
    const txDiscovery =
      resolvedTxKind === 'soapy-sdr-tx' &&
      txBin !== '' &&
      txDeviceArgs !== '' &&
      !argFlag('--skip-tx-discovery')
        ? probeSoapySdrDevice(txBin, txDeviceArgs)
        : undefined;
    const envelope = buildMonsterRfCacheKeyEnvelope({
      transport: 'hardware',
      rtlProbe: probe,
      txBin,
      txKind: resolvedTxKind,
      txDeviceArgs,
      txIqFile,
      txCenterFrequencyHz,
      txSampleRateHz,
      txGainDb,
      txDiscovery,
      rxCapture,
      symbolMode,
      appTeleportReceipt: appReceipt,
      protocol69FoilProbe,
    });
    if (rxCaptureOnly) {
      console.log(JSON.stringify(envelope, null, 2));
      if (!rxCapture?.ok) {
        process.exit(1);
      }
      return;
    }
    const preflightOnly = argFlag('--preflight-only');
    const executeTx = argFlag('--execute-tx');
    const txAvailable = envelope.monsterRfCacheKey.broadcaster.txAvailable;
    const rxHealthy = envelope.monsterRfCacheKey.receiver.healthy;
    if (!preflightOnly && (!txAvailable || !rxHealthy)) {
      console.log(JSON.stringify(envelope, null, 2));
      console.error(
        `REFUSED [rf-key hardware]: txAvailable=${txAvailable} rxHealthy=${rxHealthy}`,
      );
      process.exit(2);
    }
    const adapter = envelope.monsterRfCacheKey.broadcaster.adapter;
    if (executeTx) {
      const txHardwarePresent = adapter?.discovery?.hardwarePresent ?? true;
      if (!txAvailable || !rxHealthy || !txHardwarePresent || adapter === undefined) {
        console.log(JSON.stringify(envelope, null, 2));
        console.error(
          `REFUSED [rf-key hardware execute]: txAvailable=${txAvailable} rxHealthy=${rxHealthy} txHardwarePresent=${txHardwarePresent}`,
        );
        process.exit(2);
      }
      const txExecution = executeExternalTxAdapter(adapter);
      console.log(JSON.stringify({ ...envelope, txExecution }, null, 2));
      if (txExecution.status !== 0) {
        process.exit(1);
      }
      return;
    }
    console.log(JSON.stringify(envelope, null, 2));
    if (protocol69FoilProbe && !protocol69FoilProbe.ok) {
      process.exit(2);
    }
    return;
  }

  if (mode === 'mars-link-budget') {
    const regime = parseRegime(argValue('--mars-regime', 'mean'));
    const band = argValue('--band', 'x-down') as BandName;
    const sps = Math.round(
      Number(argValue('--iq-rate', '2400000')) / Number(argValue('--baud', '8000')),
    );
    const params = {
      distanceM: MARS_RANGE_KM[regime] * 1000,
      freqHz: BANDS[band],
      txPowerDbm: Number(argValue('--tx-power-dbm', '43')),
      txDishM: Number(argValue('--tx-dish-m', '4')),
      rxDishM: Number(argValue('--rx-dish-m', '34')),
      systemNoiseTempK: Number(argValue('--sys-temp-k', '30')),
      dataRateBps: Number(argValue('--data-rate-bps', '1000')),
      mod: argValue('--mod', 'mfsk8') as Modulation,
      fec: argValue('--fec-profile', 'rs+conv') as LbFecProfile,
      whipReplicas: Number(argValue('--whip-replicas', '4')),
    };
    const cert = buildLinkBudgetCertificate(`mars-${regime}-${band}`, params, sps);
    const certOut = argValue('--cert-out', '').trim();
    if (certOut !== '') {
      ensureDirFor(resolve(certOut));
      writeFileSync(resolve(certOut), JSON.stringify(cert, null, 2));
    }
    console.log(JSON.stringify(cert, null, 2));
    return;
  }

  if (mode === 'mars-ladder') {
    const cfg: LadderConfig = {
      band: argValue('--band', REFERENCE_CONFIG.band) as BandName,
      txPowerDbm: Number(argValue('--tx-power-dbm', String(REFERENCE_CONFIG.txPowerDbm))),
      txDishM: Number(argValue('--tx-dish-m', String(REFERENCE_CONFIG.txDishM))),
      rxDishM: Number(argValue('--rx-dish-m', String(REFERENCE_CONFIG.rxDishM))),
      systemNoiseTempK: Number(argValue('--sys-temp-k', String(REFERENCE_CONFIG.systemNoiseTempK))),
      dataRateBps: Number(argValue('--data-rate-bps', String(REFERENCE_CONFIG.dataRateBps))),
      mod: argValue('--mod', REFERENCE_CONFIG.mod) as Modulation,
      fec: argValue('--fec-profile', REFERENCE_CONFIG.fec) as LbFecProfile,
      whipReplicas: Number(argValue('--whip-replicas', String(REFERENCE_CONFIG.whipReplicas))),
    };
    const sweep = sweepLadder(cfg);
    const certOut = argValue('--cert-out', '').trim();
    if (certOut !== '') {
      ensureDirFor(resolve(certOut));
      writeFileSync(resolve(certOut), JSON.stringify(sweep, null, 2));
    }
    const csvOut = argValue('--csv-out', '').trim();
    if (csvOut !== '') {
      const header =
        'name,class,rangeKm,oneWaySec,roundTripSec,marginDb,marginCloses,teleportSavingSec';
      const lines = sweep.rows.map(
        (r) =>
          `${r.name},${r.class},${r.rangeKm},${r.oneWaySec.toFixed(3)},${r.roundTripSec.toFixed(3)},${r.marginDb.toFixed(2)},${r.marginCloses},${r.teleportSavingSec.toFixed(3)}`,
      );
      ensureDirFor(resolve(csvOut));
      writeFileSync(resolve(csvOut), [header, ...lines].join('\n') + '\n');
    }
    console.log(JSON.stringify(sweep, null, 2));
    return;
  }

  if (mode === 'mars-tx') {
    const o = buildMfskOpts();
    const payloadStr = argValue('--payload', '');
    const payload =
      payloadStr.trim() !== ''
        ? Uint8Array.from(payloadStr, (c) => c.charCodeAt(0))
        : canonicalCacheKeyPayload();
    const replicas = Number(argValue('--whip-replicas', '3'));
    const gap = Number(argValue('--whip-gap-samples', '256'));
    const built = buildWhipReplicasIq(payload, o, replicas, gap);
    const iqOut = resolve(argValue('--iq-int16-out', '.qa-artifacts/rtlsdr/mars-tx.iq16'));
    ensureDirFor(iqOut);
    const scale = Number(argValue('--tx-scale', '8192'));
    const bytes = writeInt16IqFile(iqOut, built.iq, scale);
    const txLo = Number(argValue('--tx-lo-hz', '433920000'));
    const hwGain = Number(argValue('--tx-hardwaregain-db', '-20'));
    const guard = checkLibiio();
    const setup = buildPlutoSetupCmds({
      txLoHz: txLo,
      sampleRateHz: o.iqRateHz,
      hardwaregainDb: hwGain,
    });
    const writedev = buildIioWritedevArgv({ bufferSize: built.frameSamples });
    console.log(
      JSON.stringify(
        {
          mode: 'mars-tx',
          payloadAscii: Buffer.from(payload).toString('utf8'),
          payloadLen: payload.length,
          mod: o.mod,
          fec: o.fec.name,
          baud: o.baud,
          iqRateHz: o.iqRateHz,
          baseFreqHz: o.baseFreqHz,
          replicas,
          gapSamples: gap,
          frameSamples: built.frameSamples,
          iqInt16Out: iqOut,
          iqInt16Bytes: bytes,
          txScale: scale,
          pluto: {
            uri: resolvePlutoUri(),
            txLoHz: txLo,
            sampleRateHz: o.iqRateHz,
            hardwaregainDb: hwGain,
            libiio: guard,
            setupCmds: setup.map((a) => ['iio_attr', ...a].join(' ')),
            writedevCmd: ['iio_writedev', ...writedev].join(' ') + ` < ${iqOut}`,
          },
        },
        null,
        2,
      ),
    );
    return;
  }

  if (mode === 'mars-rx') {
    const o = buildMfskOpts();
    const iqFile = argValue('--iq-file', '').trim();
    if (iqFile === '') {
      console.error('mars-rx requires --iq-file <path>');
      process.exit(1);
    }
    const raw = loadRtlU8Capture(resolve(iqFile));
    const fmt =
      parseCaptureFormat(argValue('--capture-format', '').trim() || undefined) ??
      inferCaptureIqFormatFromPath(resolve(iqFile));
    const iq = normalizeCaptureToRtlU8(raw, fmt);
    const payloadStr = argValue('--payload', '');
    const expectedPayload =
      payloadStr.trim() !== ''
        ? Uint8Array.from(payloadStr, (c) => c.charCodeAt(0))
        : canonicalCacheKeyPayload();
    const replicas = Number(argValue('--whip-replicas', '3'));
    const gap = Number(argValue('--whip-gap-samples', '256'));
    const fold = foldWhipReplicas(iq, o, replicas, expectedPayload.length, gap);
    const payloadAscii = fold.payload ? Buffer.from(fold.payload).toString('utf8') : null;
    const matches = fold.payload
      ? Buffer.from(fold.payload).equals(Buffer.from(expectedPayload))
      : false;
    console.log(
      JSON.stringify(
        {
          mode: 'mars-rx',
          iqFile: resolve(iqFile),
          format: fmt,
          mod: o.mod,
          fec: o.fec.name,
          baud: o.baud,
          iqRateHz: o.iqRateHz,
          baseFreqHz: o.baseFreqHz,
          ok: fold.ok,
          winnerReplica: fold.winnerReplica,
          recoveredAscii: payloadAscii,
          matchesExpected: matches,
          expectedAscii: Buffer.from(expectedPayload).toString('utf8'),
          attempts: fold.attempts.map((a) => ({
            ok: a.ok,
            syncScore: Number(a.syncScore.toFixed(3)),
            syncOffset: a.syncOffset,
            blockLen: a.blockLen,
            rsErrors: a.rsErrors,
            reason: a.reason,
          })),
        },
        null,
        2,
      ),
    );
    if (!matches) process.exitCode = 2;
    return;
  }

  if (mode === 'synthetic') {
    const seconds = Number.parseFloat(argValue('--seconds', '2'));
    const noiseRms = Number.parseFloat(argValue('--noise-rms', '0.08'));
    const ifErrorHz = Number.parseFloat(argValue('--if-error-hz', '4500'));
    ensureDirFor(u8Out);
    ensureDirFor(wavOut);
    const messageToneHz = Number.parseFloat(argValue('--message-tone-hz', '880'));
    const fold = runSyntheticPipeline({
      seconds,
      iqRate,
      audioRate,
      noiseRms,
      ifErrorHz,
      messageToneHz,
      u8Out,
      wavOut,
    });
    console.log(
      JSON.stringify(
        {
          mode: 'synthetic',
          u8Out,
          wavOut,
          bestIfOffsetHz: fold.bestOffsetHz,
          bestScore: fold.bestScore,
          iqSpinHintHz: fold.iqSpinHintHz,
          recommendedIfOffsetHz: fold.iqSpinHintHz,
          iqRateHz: iqRate,
          audioRateHz: audioRate,
        },
        null,
        2,
      ),
    );
    return;
  }

  if (mode === 'batch') {
    const captureDir = argValue('--capture-dir', '');
    if (captureDir.trim() === '') {
      console.error('batch requires --capture-dir <path>');
      process.exit(1);
    }
    const formatOverride = parseCaptureFormat(
      argValue('--capture-format', '').trim() || undefined,
    );
    const wavDir = resolve(
      argValue('--batch-wav-dir', '.qa-artifacts/rtlsdr/batch-wav'),
    );
    const summaryPath = resolve(
      argValue('--batch-summary', '.qa-artifacts/rtlsdr/batch-summary.json'),
    );
    mkdirSync(wavDir, { recursive: true });
    ensureDirFor(summaryPath);
    const files = collectCaptureFiles(resolve(captureDir));
    const span = Number.parseFloat(argValue('--mesh-span-hz', '12000'));
    const step = Number.parseFloat(argValue('--mesh-step-hz', '500'));
    const summary: Array<Record<string, unknown>> = [];
    for (const file of files) {
      const raw = loadRtlU8Capture(file);
      const inferred = inferCaptureIqFormatFromPath(file);
      const format = formatOverride ?? inferred;
      const iq = normalizeCaptureToRtlU8(raw, format);
      const hint = estimateMeanInstFreqHz(
        iq,
        iqRate,
        Math.min(300_000, Math.floor(iq.length / 2) - 1),
      );
      const offsets: number[] = [];
      for (let o = -span; o <= span; o += step) {
        offsets.push(hint + o);
      }
      const fold = forkRaceFoldIfDemod(iq, {
        iqSampleRateHz: iqRate,
        audioSampleRateHz: audioRate,
        ifOffsetsHz: offsets,
      });
      const wavOutPath = join(wavDir, `${basename(file)}.wav`);
      writeWavFile(wavOutPath, fold.pcm16, audioRate);
      summary.push({
        file: resolve(file),
        format,
        captureMtimeMs: statSync(file).mtimeMs,
        captureMtimeIso: new Date(statSync(file).mtimeMs).toISOString(),
        wavOut: wavOutPath,
        iqBytes: iq.length,
        iqPairs: iq.length / 2,
        iqSpinHintHz: fold.iqSpinHintHz,
        bestIfOffsetHz: fold.bestOffsetHz,
        bestScore: fold.bestScore,
      });
    }
    writeFileSync(summaryPath, JSON.stringify(summary, null, 2));
    console.log(
      JSON.stringify(
        {
          mode: 'batch',
          captureDir: resolve(captureDir),
          filesProcessed: summary.length,
          summaryPath,
          wavDir,
          iqRateHz: iqRate,
          audioRateHz: audioRate,
        },
        null,
        2,
      ),
    );
    return;
  }

  if (mode === 'fuse') {
    const batchSummaryPath = resolve(
      argValue('--batch-summary', '.qa-artifacts/rtlsdr/batch-summary.json'),
    );
    const rtl433JsonlPath = argValue('--rtl433-jsonl', '').trim();
    if (rtl433JsonlPath === '') {
      console.error('fuse requires --rtl433-jsonl <path>');
      process.exit(1);
    }
    const fusionOutPath = resolve(
      argValue('--fusion-out', '.qa-artifacts/rtlsdr/fusion.json'),
    );
    const fuseMaxDeltaSec = Number.parseFloat(
      argValue('--fuse-max-delta-sec', '180'),
    );
    ensureDirFor(fusionOutPath);
    const batchSummary = loadBatchSummary(batchSummaryPath);
    const rtl433Events = loadRtl433Jsonl(resolve(rtl433JsonlPath));
    const matches = correlateEventsToCaptures(
      batchSummary,
      rtl433Events,
      Math.max(0, Math.round(fuseMaxDeltaSec * 1000)),
    );
    const perCaptureEventCount = summarizeCaptureMatchCounts(batchSummary, matches);
    const fusion = {
      generatedAtIso: new Date().toISOString(),
      batchSummaryPath,
      rtl433JsonlPath: resolve(rtl433JsonlPath),
      batchCaptureCount: batchSummary.length,
      rtl433Summary: summarizeRtl433Events(rtl433Events),
      fuseMaxDeltaSec,
      matchCount: matches.length,
      perCaptureEventCount,
      eventCaptureMatches: matches,
      batchSummary,
      rtl433Events,
    };
    writeFileSync(fusionOutPath, JSON.stringify(fusion, null, 2));
    console.log(
      JSON.stringify(
        {
          mode: 'fuse',
          fusionOutPath,
          batchCaptureCount: batchSummary.length,
          rtl433EventCount: rtl433Events.length,
          matchCount: matches.length,
        },
        null,
        2,
      ),
    );
    return;
  }

  const iqPath = argValue('--iq-file', '');
  if (iqPath.trim() === '') {
    console.error('replay requires --iq-file <path>');
    process.exit(1);
  }
  const formatOverride = parseCaptureFormat(
    argValue('--capture-format', '').trim() || undefined,
  );
  const resolvedIqPath = resolve(iqPath);
  const raw = loadRtlU8Capture(resolvedIqPath);
  const inferred = inferCaptureIqFormatFromPath(resolvedIqPath);
  const format = formatOverride ?? inferred;
  const iq = normalizeCaptureToRtlU8(raw, format);
  const hint = estimateMeanInstFreqHz(
    iq,
    iqRate,
    Math.min(300_000, Math.floor(iq.length / 2) - 1),
  );
  const span = Number.parseFloat(argValue('--mesh-span-hz', '12000'));
  const step = Number.parseFloat(argValue('--mesh-step-hz', '500'));
  const offsets: number[] = [];
  for (let o = -span; o <= span; o += step) {
    offsets.push(hint + o);
  }
  const fold = forkRaceFoldIfDemod(iq, {
    iqSampleRateHz: iqRate,
    audioSampleRateHz: audioRate,
    ifOffsetsHz: offsets,
  });
  ensureDirFor(wavOut);
  writeWavFile(wavOut, fold.pcm16, audioRate);
  if (argFlag('--also-write-rotated-u8')) {
    const rotatedPath = resolve(argValue('--rotated-u8-out', u8Out));
    ensureDirFor(rotatedPath);
    const twoPi = Math.PI * 2;
    const w = (twoPi * fold.bestOffsetHz) / iqRate;
    const out = new Uint8Array(iq.length);
    for (let i = 0, p = 0; p + 1 < iq.length; i++, p += 2) {
      const re = (iq[p]! - 128) / 128;
      const im = (iq[p + 1]! - 128) / 128;
      const c = Math.cos(w * i);
      const s = Math.sin(w * i);
      const re2 = re * c + im * s;
      const im2 = im * c - re * s;
      out[p] = Math.min(255, Math.max(0, Math.round(128 + 127 * re2)));
      out[p + 1] = Math.min(255, Math.max(0, Math.round(128 + 127 * im2)));
    }
    writeRtlU8Capture(rotatedPath, out);
    console.log(JSON.stringify({ rotatedU8: rotatedPath }, null, 2));
  }
  console.log(
    JSON.stringify(
      {
        mode: 'replay',
        iqFile: resolvedIqPath,
        format,
        wavOut,
        bestIfOffsetHz: fold.bestOffsetHz,
        bestScore: fold.bestScore,
        iqSpinHintHz: fold.iqSpinHintHz,
        recommendedIfOffsetHz: fold.iqSpinHintHz,
        iqRateHz: iqRate,
        audioRateHz: audioRate,
      },
      null,
      2,
    ),
  );
}

void main().catch((e) => {
  console.error(e);
  process.exit(1);
});
