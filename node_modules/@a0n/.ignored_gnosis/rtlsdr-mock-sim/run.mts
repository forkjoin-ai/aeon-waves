  --batch-wav-dir <path> batch WAV output dir (default .qa-artifacts/rtlsdr/batch-wav)
  --batch-summary <path> batch JSON summary (default .qa-artifacts/rtlsdr/batch-summary.json)
  --rtl433-jsonl <path> fuse: rtl_433 JSONL input
  --fusion-out <path>   fuse: merged output (default .qa-artifacts/rtlsdr/fusion.json)
  --fuse-max-delta-sec <n> fuse: nearest-event capture window (default 180)
  --transport <simulated|hardware> rf-key transport (default simulated)
  --symbol-mode <cache-key-frame|monster-number|polyglot-app-cache-key>
                       rf-key payload mode; polyglot-app-cache-key emits an app receipt key
