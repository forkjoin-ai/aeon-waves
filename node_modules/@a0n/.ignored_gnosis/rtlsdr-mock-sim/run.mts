                       rf-key receiver capture output (default .qa-artifacts/rtlsdr/rf-key-window.u8)
  --rx-samples <n>      rf-key receiver IQ sample pairs (default 409600)
  --rx-device <index>   rf-key receiver rtl_sdr device index
  --tx-bin <path>       rf-key hardware: external transmitter backend
  --tx-kind <executable-stdin|hackrf-transfer|soapy-sdr-tx>
                       rf-key hardware: transmitter adapter kind
  --tx-device-args <args>
