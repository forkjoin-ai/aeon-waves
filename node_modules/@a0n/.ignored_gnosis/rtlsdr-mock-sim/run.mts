  pnpm --dir open-source/gnosis run rtlsdr-mock-sim -- synthetic [options]
  pnpm --dir open-source/gnosis run rtlsdr-mock-sim -- replay [options]
  pnpm --dir open-source/gnosis run rtlsdr-mock-sim -- batch [options]
  pnpm --dir open-source/gnosis run rtlsdr-mock-sim -- fuse [options]
  pnpm --dir open-source/gnosis run rtlsdr-mock-sim -- rf-key [options]

Options:
  --seconds <n>        synthetic duration (default 2)
  --iq-rate <hz>       IQ sample rate (default 2048000)
  --audio-rate <hz>    output WAV rate (default 48000)
  --noise-rms <n>      AWGN on IQ (default 0.08)
  --if-error-hz <hz>   synthetic mistune (default 4500)
  --message-tone-hz <hz>  synthetic FM message tone / scorer (default 880)
  --u8-out <path>      rtl_u8 output (default .qa-artifacts/rtlsdr/mock.u8)
