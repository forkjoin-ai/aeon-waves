{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "src-tauri/src",
  "prefix": "moonshine",
  "implicitDependencies": ["moonshine", "monster-guard"],
  "targets": {
    "build": {
      "dependsOn": ["moonshine:build", "monster-guard:build"],
      "executor": "nx:run-commands",
      "options": {
        "command": "cargo tauri build",
        "cwd": "{projectRoot}/src-tauri"
      }
    },
    "android:init": {
      "executor": "a0:run-commands",
      "options": {
        "command": "pnpm run init:android",
        "cwd": "{projectRoot}"
      }
    },
    "android:dev": {
      "dependsOn": ["moonshine:build", "monster-guard:build"],
      "executor": "a0:run-commands",
      "options": {
        "command": "pnpm run dev:android",
        "cwd": "{projectRoot}"
      }
    },
    "android:build": {
      "dependsOn": ["moonshine:build", "monster-guard:build"],
      "executor": "a0:run-commands",
      "options": {
        "command": "pnpm run build:android",
        "cwd": "{projectRoot}"
      }
    },
    "android:build:arm64": {
      "dependsOn": ["moonshine:build", "monster-guard:build"],
      "executor": "a0:run-commands",
      "options": {
        "command": "pnpm run build:android:arm64",
        "cwd": "{projectRoot}"
      }
    },
    "android-build": {
      "dependsOn": ["moonshine:build", "monster-guard:build"],
      "executor": "a0:run-commands",
      "options": {
        "command": "pnpm run build:android",
        "cwd": "{projectRoot}"
      }
    },
    "android-device-build": {
      "dependsOn": ["moonshine:build", "monster-guard:build"],
      "executor": "a0:run-commands",
      "options": {
        "command": "pnpm run build:android:device",
        "cwd": "{projectRoot}"
      }
    },
    "ios:init": {
      "executor": "a0:run-commands",
      "options": {
        "command": "pnpm run init:ios",
        "cwd": "{projectRoot}"
      }
    },
    "ios:dev": {
      "dependsOn": ["moonshine:build", "monster-guard:build"],
      "executor": "a0:run-commands",
      "options": {
        "command": "pnpm run dev:ios",
        "cwd": "{projectRoot}"
      }
    },
    "ios:build": {
      "dependsOn": ["moonshine:build", "monster-guard:build"],
      "executor": "a0:run-commands",
      "options": {
        "command": "pnpm run build:ios",
        "cwd": "{projectRoot}"
      }
    },
    "ios-build": {
      "dependsOn": ["moonshine:build", "monster-guard:build"],
      "executor": "a0:run-commands",
      "options": {
        "command": "pnpm run build:ios",
        "cwd": "{projectRoot}"
      }
    },
    "dev": {
      "dependsOn": ["moonshine:build", "monster-guard:build"],
      "executor": "nx:run-commands",
      "options": {
        "command": "cargo tauri dev",
        "cwd": "{projectRoot}/src-tauri"
      }
    },
    "check": {
      "executor": "nx:run-commands",
      "options": {
        "command": "mkdir -p ../dist && cargo check",
        "cwd": "{projectRoot}/src-tauri"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "mkdir -p dist && cargo test --manifest-path src-tauri/Cargo.toml",
        "cwd": "{projectRoot}"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "mkdir -p dist && cargo clippy --manifest-path src-tauri/Cargo.toml -- -D warnings",
        "cwd": "{projectRoot}"
      }
    }
  },
  "tags": ["type:app", "scope:gnosis", "platform:tauri", "lang:rust"]
}
