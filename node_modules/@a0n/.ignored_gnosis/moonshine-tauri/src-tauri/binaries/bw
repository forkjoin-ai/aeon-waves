#!/bin/bash
# Moonshine plugin wrapper (guarded + leased) — generated by setup.sh
export MONSTER_GUARD_HOME="/Users/buley/Documents/Code/monorepo/open-source/.moonshine.d"
# Redirect this plugin's child interpreter calls (python/node/bun/...) onto the
# sovereign polyglot runtime under monster-guard: the shim dir shadows the
# system interpreters on PATH, the shims attenuate to this plugin's caps, and
# FOIL stays engaged. A child interpreter the runtime can't execute fails
# closed (no silent fallthrough to a system tool).
export PATH="/Users/buley/Documents/Code/monorepo/open-source/.moonshine.shims:$PATH"
export MOONSHINE_PLUGIN_NAME="bw"
export MOONSHINE_PLUGIN_CAPS="fs"
export GNEXEC_FOIL_BACKEND=1
exec "/Users/buley/Documents/Code/monorepo/open-source/gnosis/monster-guard/target/release/monster-guard" run --name "bw" --caps "fs" -- "/Users/buley/Documents/Code/monorepo/open-source/.moonshine.bin/bw" "$@"
