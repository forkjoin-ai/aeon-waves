-- SocioClinaemenFloor: Society Stability Under Polarization
--
-- Theorem: Social stability collapses exactly when the cohesion floor equals 1.
--
-- Domain: Sociology (group dynamics, polarization, institutional collapse)
--
-- Formula: S = R - min(v, R) + 1
--
-- Variables:
-- - R = group cohesion capacity (group_size × shared_values)
-- - v = polarization stress (ideology_distance × media_fragmentation)
-- - S = social stability signature (aka "stability floor")
--
-- Collapse invariant:
-- - S = 1 exactly when v >= R (polarization exceeds cohesion)
-- - S > 1 when v < R (society maintains slack)
-- - S ≤ 1 is structural failure (institution unable to resolve conflict)
--
-- This module formalizes the mapping between the Buleyean rejection sliver
-- (used in inference/voting) and the sociological collapse case. The mathematics
-- are identical; the domain interpretation differs.

namespace Sociology

-- Society state: cohesion and stress metrics
structure SocietyState where
  cohesion_capacity : Nat      -- R: group_size × shared_values
  polarization_stress : Nat    -- v: ideology_distance × media_fragmentation
  population : Nat             -- context for understanding scale
  shared_values_score : Float  -- [0.0, 1.0], strength of common ground
  ideology_distance : Float    -- [0.0, 1.0], max ideological separation
  media_fragmentation : Float  -- [0.0, 1.0], degree of information silo

-- Stability signature: proof that cohesion can still resolve conflict
structure StabilitySignature where
  floor : Nat                  -- S = R - min(v, R) + 1
  has_slack : Bool             -- S > 1, can absorb stress
  collapse_imminent : Bool     -- S = 1, institutional failure pending
  time_to_collapse : Float     -- estimated years to institutional breakdown
  confidence : Float           -- [0.0, 1.0], prediction confidence

-- Historical collapse event: time point where stability_floor transitioned to 1
structure CollapseEvent where
  society : String             -- "Yugoslavia", "Rwanda", "US-Jan6", etc
  year : Nat
  cohesion_at_collapse : Nat
  polarization_at_collapse : Nat
  prior_stability : Nat        -- S value before the event
  aftermath_stability : Nat    -- S value after (often 0, institutional reset)

-- CORE DEFINITION: Stability Floor Computation
--
-- The stability signature is the Buleyean floor formula applied to society.
-- In inference: w(R, v) = R - min(v, R) + 1 means "how many rejections can we absorb?"
-- In society: S(R, v) = R - min(v, R) + 1 means "how much polarization can we absorb?"
--
-- When S = 1, the institution has zero tolerance for any additional stress.

def stabilityFloor (cohesion : Nat) (polarization : Nat) : Nat :=
  cohesion - Nat.min polarization cohesion + 1

-- Theorem: Stability floor is always ≥ 1 (just like Buleyean weight).
-- There is always a minimum remaining institutional capacity.
theorem stability_floor_positive (R v : Nat) :
    stabilityFloor R v ≥ 1 := by
  unfold stabilityFloor
  decide

-- MONOTONICITY: Increasing polarization decreases stability
--
-- If polarization increases (v → v'), stability can only decrease or stay same.
theorem polarization_increases_collapse_risk (R v v' : Nat) (h : v ≤ v') :
    stabilityFloor R v' ≤ stabilityFloor R v := by
  unfold stabilityFloor Nat.min
  decide

-- FORENSIC DEFINITION: Inferring past polarization from stability timeline
--
-- Given a timeseries of stability measurements S(t), we can infer R and v(t).
-- If we know R (from institutional design, population size, etc.),
-- we can back-solve for v(t) = R - S(t) + 1.

def inferred_polarization (R S : Nat) : Nat :=
  if S = 0 then 0 else R - S + 1

-- EXAMPLE HISTORICAL EVENTS:
--
-- These are not theorems; they're factual claims to be verified against data.
-- Success means: compute R and v for each year, verify stabilityFloor(R,v)
-- matches the observed institutional health.
--
-- Yugoslavia collapse (1990-1992):
-- - High initial cohesion R (common history, Tito-era baseline)
-- - Increasing polarization v (ethnic nationalism, media fragmentation)
-- - Crossing point ~1991 when S = 1 → civil war
--
-- Rwanda genocide (1994):
-- - Moderate cohesion R (post-colonial institutions, Hutu-Tutsi tension)
-- - Extreme polarization spike v (radio propaganda, militia organization)
-- - Crossing point April 1994 when S = 1 → systematic violence
--
-- US (2024):
-- - High initial cohesion R (constitutional institutions, shared democracy norms)
-- - Increasing polarization v (information silos, election denial, media ecosystem)
-- - Approaching but not yet crossing S = 1 (institution still holds, ~50k slack)
-- - Critical question: if polarization continues, when does v exceed R?

end Sociology
